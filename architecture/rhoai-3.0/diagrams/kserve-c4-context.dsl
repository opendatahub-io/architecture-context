/*
 * KServe C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/kserve.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and deploys ML/LLM models for inference"
        mlEngineer = person "ML Engineer" "Manages serving runtimes and model deployments"

        kserve = softwareSystem "KServe" "Kubernetes-native model serving platform providing serverless inference, model management, and LLM-optimized deployment orchestration" {
            controller = container "kserve-controller-manager" "Manages InferenceService, LLMInferenceService, TrainedModel, InferenceGraph CRD lifecycle; creates Deployments, Services, HTTPRoutes, VirtualServices, InferencePools, HPA, KEDA ScaledObjects" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Mutating and validating webhooks for InferenceService, ServingRuntime, TrainedModel, InferenceGraph, LLMInferenceService, LocalModelCache CRDs" "Go Admission Webhook"
            storageInitializer = container "Storage Initializer" "Downloads model artifacts from S3, GCS, PVC, HuggingFace, OCI into serving containers" "Init Container"
            agent = container "KServe Agent" "Multi-model config management, inference logging, request batching" "Sidecar Container"
            router = container "KServe Router" "Routes requests across InferenceGraph nodes, propagates Authorization headers" "Container"
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-based authentication/authorization proxy for inference endpoints (RHOAI 3.x pattern)" "Sidecar Container"
            llmdScheduler = container "llm-d inference-scheduler" "Gateway API ext_proc-based inference scheduler for LLM request routing; creates InferencePool and InferenceModel resources" "Deployment (per LLMInferenceService)"
            llmdRoutingSidecar = container "llm-d routing-sidecar" "NIXL-based routing sidecar for disaggregated prefill/decode LLM serving" "Init Container (restartable sidecar)"
        }

        /* External Dependencies */
        istio = softwareSystem "Istio Service Mesh" "VirtualService/DestinationRule-based traffic management and mTLS" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform (optional, not default in RHOAI 3.0)" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute-based ingress for inference endpoints (v1.2.1)" "External"
        gatewayAPIInfExt = softwareSystem "Gateway API Inference Extension" "InferencePool and InferenceModel CRDs for inference-aware routing (v0.3.0)" "External"
        keda = softwareSystem "KEDA" "Custom autoscaling via ScaledObjects (v2.16+)" "External"
        lws = softwareSystem "LeaderWorkerSet" "Multi-node GPU workload orchestration (v0.6.2)" "External"
        openshift = softwareSystem "OpenShift" "Platform providing Routes, SCCs, service-ca (v4.19-v4.20)" "External"
        prometheus = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor for metrics collection" "External"
        otelOperator = softwareSystem "OpenTelemetry Operator" "Distributed tracing collection (v0.113+)" "External"

        /* Internal RHOAI Dependencies */
        rhodsOperator = softwareSystem "rhods-operator" "Deploys KServe via overlays/odh kustomization; injects RELATED_IMAGE_* env vars" "Internal RHOAI"

        /* External Services */
        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, MinIO, etc.)" "External Service"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External Service"
        huggingface = softwareSystem "HuggingFace Hub" "Model download via hf:// URIs" "External Service"
        ociRegistry = softwareSystem "OCI Registries" "Model download via oci:// URIs" "External Service"

        /* Relationships - Users */
        dataScientist -> kserve "Creates InferenceService/LLMInferenceService via kubectl/Dashboard"
        mlEngineer -> kserve "Manages ServingRuntimes and deployment configurations"

        /* Relationships - External Dependencies */
        kserve -> istio "Uses for traffic routing (VirtualService/DestinationRule) and mTLS"
        kserve -> gatewayAPI "Uses for HTTPRoute-based ingress routing"
        kserve -> gatewayAPIInfExt "Uses for InferencePool/InferenceModel inference-aware routing"
        kserve -> knative "Uses for serverless deployment mode (optional)"
        kserve -> keda "Uses for custom autoscaling via ScaledObjects"
        kserve -> lws "Uses for multi-node GPU workload orchestration"
        kserve -> openshift "Uses Routes, SCCs, service-ca for TLS"
        kserve -> prometheus "Exposes metrics via ServiceMonitor/PodMonitor" "HTTP/15020"
        kserve -> otelOperator "Integrates for distributed tracing"

        /* Relationships - Internal */
        rhodsOperator -> kserve "Deploys via kustomize overlays/odh"

        /* Relationships - External Services */
        kserve -> s3 "Downloads model artifacts" "HTTPS/443"
        kserve -> gcs "Downloads model artifacts" "HTTPS/443"
        kserve -> huggingface "Downloads models" "HTTPS/443"
        kserve -> ociRegistry "Downloads model images" "HTTPS/443"

        /* Internal container relationships */
        controller -> webhookServer "Validates/mutates CRDs"
        controller -> storageInitializer "Injects as init container"
        controller -> agent "Injects as sidecar"
        controller -> kubeRbacProxy "Injects as auth sidecar (RHOAI 3.x)"
        controller -> llmdScheduler "Creates for LLMInferenceService"
        controller -> llmdRoutingSidecar "Injects for disaggregated serving"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
            element "Container" {
                shape RoundedBox
                background #4a90e2
                color #ffffff
            }
        }
    }
}
