        Gateway --> HTTPRoute
        HTTPRoute -->|"/v1/models, /maas-api/*"| MaaSAPI
    end

    subgraph "Kuadrant Policies"
        AuthPolicy["gateway-auth-policy<br/>(AuthPolicy)<br/>TokenReview + SubjectAccessReview"]
        RateLimitPolicy["gateway-rate-limits<br/>(RateLimitPolicy)<br/>free:5/2m, premium:20/2m, enterprise:50/2m"]
        TokenRateLimitPolicy["gateway-token-rate-limits<br/>(TokenRateLimitPolicy)<br/>free:100/1m, premium:50k/1m, enterprise:100k/1m"]
    end

    Client[External Client] -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Client -->|"HTTP/80"| InferenceGW

    AuthPolicy -->|enforces on| Gateway
    RateLimitPolicy -->|enforces on| Gateway
    TokenRateLimitPolicy -->|enforces on| Gateway

    AuthPolicy -->|"tier lookup callback<br/>HTTP/8080"| MaaSAPI

    subgraph "Consumed CRDs"
        InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
        LLMInferenceServiceCR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha1)"]
    end

    MaaSAPI -->|"list/watch"| InferenceServiceCR
    MaaSAPI -->|"list/watch"| LLMInferenceServiceCR

    subgraph "Kubernetes Resources (Dynamic)"
        Namespaces["Namespaces<br/>(per user/tier)"]
        ServiceAccounts["ServiceAccounts<br/>(per user/tier)"]
        SATokens["SA Tokens<br/>(short-lived)"]
    end

    MaaSAPI -->|creates| Namespaces
    MaaSAPI -->|creates| ServiceAccounts
    MaaSAPI -->|issues| SATokens

    KubeAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    MaaSAPI -->|"TokenReview, SA/NS CRUD"| KubeAPI
    AuthPolicy -->|"TokenReview,<br/>SubjectAccessReview"| KubeAPI

    Gateway -->|"/{ns}/{model}/*"| ModelBackend["Model Backend<br/>(KServe)"]
    InferenceGW -->|routes to| ModelBackend

