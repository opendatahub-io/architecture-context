    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style Metrics fill:#4a90e2,stroke:#333,stroke-width:2px

    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style LLMInferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceGraphCR fill:#f5a623,stroke:#333,stroke-width:2px
    style NIMAccountCR fill:#f5a623,stroke:#333,stroke-width:2px

    style KServe fill:#999,stroke:#333,stroke-width:2px
    style OpenShift fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style Kuadrant fill:#999,stroke:#333,stroke-width:2px
    style KEDA fill:#999,stroke:#333,stroke-width:2px
    style PrometheusOp fill:#999,stroke:#333,stroke-width:2px
    style GatewayAPI fill:#999,stroke:#333,stroke-width:2px
