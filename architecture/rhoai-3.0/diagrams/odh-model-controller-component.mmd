graph TB
    subgraph "odh-model-controller Component"
        Controller[Main Controller Manager]

        subgraph "Reconcilers"
            ISController[InferenceService Controller]
            SRController[ServingRuntime Controller]
            LLMController[LLMInferenceService Controller]
            IGController[InferenceGraph Controller]
            NIMController[NIM Account Controller]
            PodController[Pod Controller]
            SecretController[Secret Controller]
            CMController[ConfigMap Controller]
        end

        subgraph "Servers"
            Webhook[Webhook Server<br/>9443/TCP HTTPS]
            Metrics[Metrics Server<br/>8080/TCP HTTP]
            Health[Health Server<br/>8081/TCP HTTP]
        end

        Controller --> ISController
        Controller --> SRController
        Controller --> LLMController
        Controller --> IGController
        Controller --> NIMController
        Controller --> PodController
        Controller --> SecretController
        Controller --> CMController
        Controller --> Webhook
        Controller --> Metrics
        Controller --> Health
    end

    %% CRDs Watched
    InferenceServiceCR[InferenceService CR<br/>serving.kserve.io]
    ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io]
    LLMInferenceServiceCR[LLMInferenceService CR<br/>serving.kserve.io]
    InferenceGraphCR[InferenceGraph CR<br/>serving.kserve.io]
    NIMAccountCR[NIM Account CR<br/>nim.opendatahub.io]

    %% Resources Created
    Route[OpenShift Route]
    NetworkPolicy[NetworkPolicy]
    RBAC[Roles/RoleBindings]
    ServiceMonitor[ServiceMonitor]
    PodMonitor[PodMonitor]
    EnvoyFilter[Istio EnvoyFilter]
    AuthPolicy[Kuadrant AuthPolicy]
    HTTPRoute[Gateway API HTTPRoute]
    TriggerAuth[KEDA TriggerAuthentication]
    PullSecret[NIM Pull Secret]

    %% Watch relationships
    InferenceServiceCR -->|watched by| ISController
    ServingRuntimeCR -->|watched by| SRController
    LLMInferenceServiceCR -->|watched by| LLMController
    InferenceGraphCR -->|watched by| IGController
    NIMAccountCR -->|watched by| NIMController

    %% Creation relationships
    ISController -->|creates| Route
    ISController -->|creates| NetworkPolicy
    ISController -->|creates| RBAC
    ISController -->|creates| ServiceMonitor
    ISController -->|creates| PodMonitor
    ISController -->|creates| TriggerAuth

    LLMController -->|creates| AuthPolicy
    LLMController -->|creates| EnvoyFilter
    LLMController -->|creates| HTTPRoute

    NIMController -->|creates| PullSecret
    NIMController -->|processes| Templates[Runtime Templates]

    %% External Dependencies
    subgraph "External Dependencies"
        KServe[KServe v0.13+]
        Istio[Istio Service Mesh]
        Prometheus[Prometheus Operator]
        Kuadrant[Kuadrant]
        KEDA[KEDA 2.x]
        GatewayAPI[Gateway API v1]
        NGC[Nvidia NGC]
    end

    %% Internal ODH Dependencies
    subgraph "Internal ODH Dependencies"
        ModelRegistry[Model Registry]
        DSC[DataScienceCluster]
        ServiceCA[OpenShift Service CA]
    end

    Controller -->|depends on| KServe
    Controller -->|integrates| Istio
    Controller -->|integrates| Prometheus
    Controller -->|integrates| Kuadrant
    Controller -->|integrates| KEDA
    Controller -->|integrates| GatewayAPI
    NIMController -->|validates with| NGC
    ISController -.->|optional| ModelRegistry
    Controller -->|reads config| DSC
    Webhook -->|cert from| ServiceCA

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style ISController fill:#4a90e2,stroke:#333
    style SRController fill:#4a90e2,stroke:#333
    style LLMController fill:#4a90e2,stroke:#333
    style IGController fill:#4a90e2,stroke:#333
    style NIMController fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333
    style Metrics fill:#4a90e2,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style LLMInferenceServiceCR fill:#f5a623,stroke:#333
    style NIMAccountCR fill:#f5a623,stroke:#333
    style KServe fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style DSC fill:#7ed321,stroke:#333
