graph TB
    subgraph "odh-model-controller Component"
        direction TB

        subgraph Controllers["Controllers"]
            ISController[InferenceService Controller]
            SRController[ServingRuntime Controller]
            LLMController[LLMInferenceService Controller]
            IGController[InferenceGraph Controller]
            NIMController[NIM Account Controller]
            PodController[Pod Controller]
            SecretController[Secret Controller]
            CMController[ConfigMap Controller]
        end

        subgraph Servers["Servers"]
            Webhook[Webhook Server<br/>9443/TCP HTTPS]
            Metrics[Metrics Server<br/>8080/TCP HTTP]
        end
    end

    subgraph "Custom Resources"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io]
        LLMInferenceServiceCR[LLMInferenceService<br/>serving.kserve.io]
        InferenceGraphCR[InferenceGraph<br/>serving.kserve.io]
        NIMAccountCR[Account<br/>nim.opendatahub.io]
    end

    subgraph "Created Resources"
        Route[OpenShift Routes]
        NetworkPolicy[NetworkPolicies]
        ServiceMonitor[ServiceMonitors]
        PodMonitor[PodMonitors]
        EnvoyFilter[EnvoyFilters<br/>Istio]
        AuthPolicy[AuthPolicies<br/>Kuadrant]
        HTTPRoute[HTTPRoutes<br/>Gateway API]
        TriggerAuth[TriggerAuthentications<br/>KEDA]
        PullSecret[Image Pull Secrets]
        RuntimeTemplate[Runtime Templates]
    end

    subgraph "External Dependencies"
        KServe[KServe v0.13+]
        OpenShift[OpenShift Routes 4.x]
        Istio[Istio Service Mesh 1.x]
        Kuadrant[Kuadrant]
        KEDA[KEDA 2.x]
        PrometheusOp[Prometheus Operator]
        GatewayAPI[Gateway API v1]
        NvidiaAPI[Nvidia NGC API<br/>443/TCP HTTPS]
    end

    subgraph "Internal ODH Dependencies"
        ModelRegistry[Model Registry<br/>443/TCP HTTPS]
        DSCInit[DSC Initialization]
        ServiceCA[OpenShift Service CA]
    end

    %% Controller watches CRs
    InferenceServiceCR -.->|watched by| ISController
    ServingRuntimeCR -.->|watched by| SRController
    LLMInferenceServiceCR -.->|watched by| LLMController
    InferenceGraphCR -.->|watched by| IGController
    NIMAccountCR -.->|watched by| NIMController

    %% Controllers create resources
    ISController -->|creates| Route
    ISController -->|creates| NetworkPolicy
    ISController -->|creates| ServiceMonitor
    ISController -->|creates| PodMonitor
    ISController -->|creates| TriggerAuth

    LLMController -->|creates| AuthPolicy
    LLMController -->|creates| EnvoyFilter
    LLMController -->|creates| HTTPRoute

    NIMController -->|validates via| NvidiaAPI
    NIMController -->|creates| PullSecret
    NIMController -->|creates| RuntimeTemplate

    PodController -->|mutates| Webhook

    %% External dependencies
    ISController -.->|depends on| KServe
    ISController -.->|uses| OpenShift
    ISController -.->|uses| PrometheusOp
    ISController -.->|uses| KEDA

    LLMController -.->|uses| Istio
    LLMController -.->|uses| Kuadrant
    LLMController -.->|uses| GatewayAPI

    %% Internal dependencies
    ISController -.->|optional| ModelRegistry
    Controllers -.->|reads config| DSCInit
    Webhook -.->|TLS certs| ServiceCA

    Metrics -->|exposes| PrometheusOp

