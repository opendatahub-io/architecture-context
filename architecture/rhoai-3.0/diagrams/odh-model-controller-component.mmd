    style ISController fill:#4a90e2,stroke:#333,stroke-width:2px
    style SRController fill:#4a90e2,stroke:#333,stroke-width:2px
    style LLMController fill:#4a90e2,stroke:#333,stroke-width:2px
    style IGController fill:#4a90e2,stroke:#333,stroke-width:2px
    style NIMController fill:#4a90e2,stroke:#333,stroke-width:2px
