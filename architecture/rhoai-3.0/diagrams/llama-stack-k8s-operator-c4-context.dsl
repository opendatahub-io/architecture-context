/*
 * C4 Context Diagram - Llama Stack K8s Operator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/llama-stack-k8s-operator.md
 */

workspace {
    model {
        user = person "Platform User" "Creates LlamaStackDistribution CRs to deploy Llama Stack servers"

        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Manages lifecycle of Llama Stack server distributions on OpenShift/Kubernetes" {
            controller = container "LlamaStackDistribution Reconciler" "Watches LlamaStackDistribution CRs, reconciles Deployments, Services, SAs, PVCs, RoleBindings, NetworkPolicies" "Go Controller (controller-runtime)"
            kustomizeRenderer = container "Kustomize Renderer" "Renders base manifests with runtime plugins for namespace, name prefix, and field mutation" "Go Package (pkg/deploy)"
            clusterInfo = container "Cluster Info" "Detects operator namespace, loads distribution image mappings, performs upgrade cleanup" "Go Package (pkg/cluster)"
            featureFlags = container "Feature Flags" "ConfigMap-based feature flag system controlling NetworkPolicy creation" "Go Package (pkg/featureflags)"
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-authorized proxy for operator metrics endpoint" "Sidecar Container"
        }

        llamaStackServer = softwareSystem "Managed Llama Stack Server" "AI inference server deployed and managed by the operator" "Managed"

        kubernetesApi = softwareSystem "Kubernetes API" "Cluster control plane for resource management" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys the Llama Stack operator via kustomize overlays" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "External"
        openshiftScc = softwareSystem "OpenShift SCC" "Security Context Constraints for managed pods" "External"
        odhTrustedCa = softwareSystem "ODH Trusted CA Bundle" "Platform-provided trusted CA certificates ConfigMap" "Internal RHOAI"

        /* Relationships */
        user -> llamaStackOperator "Creates LlamaStackDistribution CR via kubectl" "HTTPS/443"
        rhodsOperator -> llamaStackOperator "Deploys via config/overlays/rhoai/" "Kustomize"
        llamaStackOperator -> kubernetesApi "Resource CRUD, watch, status updates" "HTTPS/443, TLS 1.2+"
        llamaStackOperator -> llamaStackServer "Health checks, provider/version queries" "HTTP/8321, plaintext"
        prometheus -> llamaStackOperator "Scrapes metrics via ServiceMonitor" "HTTPS/8443, TLS"
        llamaStackOperator -> openshiftScc "Binds anyuid SCC to managed service accounts" "RBAC"
        llamaStackOperator -> odhTrustedCa "Auto-detects and injects CA bundle" "ConfigMap"

        /* Internal container relationships */
        controller -> kustomizeRenderer "Renders manifests"
        controller -> clusterInfo "Detects namespace, loads distributions"
        controller -> featureFlags "Checks feature flags"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
