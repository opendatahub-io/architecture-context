%% Feast Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Admin"]
        MLApp["ML Application"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        UIRoute["feast-{name}-ui Route<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        Controller["feast-operator-controller-manager<br/>SA: feast-operator-controller-manager<br/>UID: 65532 | FIPS: Yes"]
        MetricsEP["Metrics: 8443/TCP HTTPS<br/>TLS (self-signed)<br/>Auth: Bearer Token"]
        HealthEP["Health: 8081/TCP HTTP<br/>No Auth"]
    end

    subgraph UserNS["CR NAMESPACE ({user-namespace})"]
        direction TB

        subgraph FeatureStore["Feast Feature Store Instance"]
            Online["Online Server<br/>feast-{name}-online<br/>80/443 → 6566/6567<br/>TLS (service serving)<br/>Auth: K8s RBAC / OIDC"]
            Offline["Offline Server<br/>feast-{name}-offline<br/>80/443 → 8815/8816<br/>TLS (service serving)<br/>Auth: K8s RBAC / OIDC"]
            Registry["Registry Server<br/>feast-{name}-registry<br/>gRPC: 6570/6571<br/>REST: 6572/6573<br/>TLS (service serving)<br/>Auth: K8s RBAC / OIDC"]
            UI["Feast UI<br/>feast-{name}-ui<br/>80/443 → 8888/8443<br/>TLS (service serving)<br/>Auth: None"]
            Cron["CronJob (ose-cli)<br/>SA: feast-{name}<br/>feast apply / materialize"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        GitRepo["External Git Repos<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Configurable Auth"]
        DBStore["External DB Stores<br/>(PostgreSQL, Redis, Snowflake)<br/>Various ports<br/>Secret-based Auth"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    MLApp -->|"HTTPS/443<br/>TLS (service serving)<br/>K8s RBAC / OIDC"| Online
    MLApp -->|"HTTPS/443<br/>TLS (service serving)<br/>K8s RBAC / OIDC"| Offline
    UIRoute -->|"HTTPS/443<br/>Reencrypt"| UI

    %% Operator flows
    K8sAPI -->|"Watch events<br/>SA Token"| Controller
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Feature store internal flows
    Online -->|"gRPC/REST"| Registry
    Offline -->|"gRPC/REST"| Registry
    Cron -->|"kubectl exec<br/>RBAC pods/exec"| Online

    %% Egress flows
    Online -->|"Various<br/>DB credentials"| DBStore
    Offline -->|"Various<br/>DB credentials"| DBStore
    Controller -->|"HTTPS/443<br/>TLS 1.2+"| GitRepo

    %% Auth flows
    Online -->|"TokenReview+SAR<br/>HTTPS/443"| K8sAPI
    Offline -->|"TokenReview+SAR<br/>HTTPS/443"| K8sAPI
    Registry -->|"TokenReview+SAR<br/>HTTPS/443"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef featurestore fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,MLApp external
    class UIRoute ingress
    class Controller,MetricsEP,HealthEP operator
    class Online,Offline,Registry,UI,Cron featurestore
    class K8sAPI,GitRepo,DBStore externalservice
