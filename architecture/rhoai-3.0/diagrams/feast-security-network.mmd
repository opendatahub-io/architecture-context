graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        MLModel[ML Models]
        DataScientist[Data Scientists]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Optional)"]
        RouteOnline["Route: {name}-online<br/>443/TCP HTTPS TLS 1.2+<br/>Edge/Passthrough"]
        RouteOffline["Route: {name}-offline<br/>443/TCP HTTPS TLS 1.2+<br/>Edge/Passthrough"]
        RouteRegistry["Route: {name}-registry<br/>443/TCP HTTPS TLS 1.2+<br/>Edge/Passthrough"]
        RouteUI["Route: {name}-ui<br/>443/TCP HTTPS TLS 1.2+<br/>Edge/Passthrough"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Kubernetes)"]
        direction TB

        subgraph UserNamespace["Namespace: {user-namespace}"]
            OnlineServer["Feast Online Server<br/>SA: {name}-feast-sa<br/>6566/TCP HTTP<br/>6567/TCP HTTPS TLS 1.2+<br/>Auth: OIDC/K8s RBAC/None"]

            OfflineServer["Feast Offline Server<br/>SA: {name}-feast-sa<br/>8815/TCP HTTP<br/>8816/TCP HTTPS TLS 1.2+<br/>Auth: OIDC/K8s RBAC/None"]

            RegistryServer["Feast Registry Server<br/>SA: {name}-feast-sa<br/>6570/TCP gRPC<br/>6571/TCP gRPC TLS 1.2+<br/>6572/TCP HTTP<br/>6573/TCP HTTPS TLS 1.2+<br/>Auth: OIDC/K8s RBAC/None"]

            UIServer["Feast UI<br/>SA: {name}-feast-sa<br/>8888/TCP HTTP<br/>8443/TCP HTTPS TLS 1.2+<br/>Auth: OIDC/K8s RBAC/None"]

            CronJob["Materialization CronJob<br/>SA: {name}-feast-sa<br/>Scheduled: feast materialize"]
        end

        subgraph SystemNamespace["Namespace: {system-namespace}"]
            Operator["Feast Operator<br/>SA: controller-manager<br/>8081/TCP HTTP - /healthz, /readyz<br/>8443/TCP HTTPS - /metrics"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Cloud IAM/Keys"]

        Database["Database<br/>PostgreSQL/Snowflake<br/>5432/TCP or 443/TCP<br/>TLS 1.2+<br/>Auth: DB Credentials"]

        OnlineStoreBackend["Online Store<br/>Redis/Cassandra/DynamoDB<br/>Varies/TCP<br/>TLS 1.2+ (configurable)<br/>Auth: DB/Service Creds"]

        OIDC["OIDC Provider<br/>OpenShift OAuth/Keycloak<br/>443/TCP HTTPS TLS 1.3<br/>Auth: OIDC Flow"]

        Git["Git Repository<br/>github.com/gitlab.com<br/>443/TCP HTTPS or 22/TCP SSH<br/>Auth: Token/SSH Key"]

        Prometheus["Prometheus<br/>Metrics Collection<br/>8443/TCP HTTPS TLS 1.2+"]

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    %% External to Ingress
    MLModel -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteOnline
    DataScientist -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteOffline
    DataScientist -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteRegistry
    DataScientist -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteUI

    %% Ingress to Services
    RouteOnline -->|HTTP/80 or HTTPS/443| OnlineServer
    RouteOffline -->|HTTP/80 or HTTPS/443| OfflineServer
    RouteRegistry -->|HTTP/80 or HTTPS/443| RegistryServer
    RouteUI -->|HTTP/80 or HTTPS/443| UIServer

    %% Internal Service Communication
    OnlineServer -->|HTTP/6572 or HTTPS/6573<br/>Internal| RegistryServer
    OfflineServer -->|HTTP/6572 or HTTPS/6573<br/>Internal| RegistryServer
    CronJob -->|HTTP or HTTPS<br/>Internal| RegistryServer
    CronJob -->|HTTP/8815 or HTTPS/8816<br/>Internal| OfflineServer
    CronJob -->|HTTP/6566 or HTTPS/6567<br/>Internal| OnlineServer

    %% Services to External Dependencies
    OnlineServer -->|Native Protocol<br/>TLS 1.2+<br/>DB Credentials| OnlineStoreBackend
    OfflineServer -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| S3
    OfflineServer -->|Native/443<br/>TLS 1.2+<br/>DB Credentials| Database
    RegistryServer -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| S3
    RegistryServer -->|Native Protocol<br/>TLS 1.2+<br/>DB Credentials| Database

    %% Authentication
    OnlineServer -.->|JWT Validation<br/>HTTPS/443| OIDC
    OfflineServer -.->|JWT Validation<br/>HTTPS/443| OIDC
    RegistryServer -.->|JWT Validation<br/>HTTPS/443| OIDC
    UIServer -.->|JWT Validation<br/>HTTPS/443| OIDC

    %% Operator Communication
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Scrape /metrics| Operator

    %% Feature Repo Sync
    RegistryServer -.->|HTTPS/443 or SSH/22<br/>Token/Key| Git

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class MLModel,DataScientist external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class OnlineServer,OfflineServer,RegistryServer,UIServer,CronJob internal
    class S3,Database,OnlineStoreBackend,OIDC,Git,Prometheus,K8sAPI externalservice
    class Operator operator
