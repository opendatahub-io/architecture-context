graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>ML Model / Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Routes)"]
        Route[OpenShift Routes<br/>feast-online/offline/registry/ui<br/>443/TCP → 80/443/TCP<br/>TLS Edge/Passthrough]
    end

    subgraph InternalCluster["INTERNAL CLUSTER (Namespace-scoped)"]
        direction TB

        subgraph OnlineStoreZone["Feast Online Store"]
            OnlineService["Service: feast-online<br/>ClusterIP<br/>80/TCP → 6566 HTTP<br/>443/TCP → 6567 HTTPS"]
            OnlinePod["Pod: Online Store<br/>SA: feast-online-sa<br/>POST /get-online-features<br/>POST /push<br/>TLS 1.2+ (6567)<br/>Auth: OIDC/K8s/None"]
        end

        subgraph OfflineStoreZone["Feast Offline Store"]
            OfflineService["Service: feast-offline<br/>ClusterIP<br/>80/TCP → 8815 HTTP<br/>443/TCP → 8816 HTTPS"]
            OfflinePod["Pod: Offline Store<br/>SA: feast-offline-sa<br/>POST /get-historical-features<br/>POST /offline-store-plan<br/>TLS 1.2+ (8816)<br/>Auth: OIDC/K8s/None"]
        end

        subgraph RegistryZone["Feast Registry Server"]
            RegistryService["Service: feast-registry<br/>ClusterIP<br/>80/TCP → 6570 gRPC, 6572 HTTP<br/>443/TCP → 6571 gRPC/TLS, 6573 HTTPS"]
            RegistryPod["Pod: Registry<br/>SA: feast-registry-sa<br/>gRPC /proto/*<br/>REST /registry/*<br/>TLS 1.2+ (6571/6573)<br/>Auth: OIDC/K8s/None"]
        end

        subgraph UIZone["Feast UI"]
            UIService["Service: feast-ui<br/>ClusterIP<br/>80/TCP → 8888 HTTP<br/>443/TCP → 8443 HTTPS"]
            UIPod["Pod: UI<br/>SA: feast-ui-sa<br/>GET / (Web UI)<br/>GET/POST /api/*<br/>TLS 1.2+ (8443)<br/>Auth: OIDC/K8s/None"]
        end

        subgraph OperatorZone["Feast Operator"]
            MetricsService["Service: controller-manager-metrics<br/>ClusterIP<br/>8443/TCP HTTPS"]
            OperatorPod["Pod: Feast Operator<br/>SA: controller-manager<br/>GET /healthz (8081 HTTP)<br/>GET /readyz (8081 HTTP)<br/>GET /metrics (8443 HTTPS TLS 1.2+)"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph Egress["EGRESS (to External Services)"]
        direction TB

        ObjectStorage["S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Cloud IAM / Access Keys"]
        Database["PostgreSQL / Snowflake<br/>5432/TCP or 443/TCP<br/>TLS 1.2+<br/>DB Credentials"]
        Cache["Redis / Cassandra / DynamoDB<br/>6379/9042 TCP<br/>TLS 1.2+<br/>Credentials"]
        OIDC["OIDC Provider<br/>OpenShift OAuth / External IdP<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client Credentials"]
        Git["Git Repository<br/>443/TCP HTTPS or 22/TCP SSH<br/>TLS 1.2+ / SSH<br/>Token / SSH Key"]
    end

    subgraph OptionalServices["OPTIONAL SERVICES"]
        ServiceMesh["Service Mesh (Istio)<br/>mTLS between services"]
        CertManager["cert-manager<br/>TLS certificate provisioning"]
        TrustedCA["odh-trusted-ca-bundle<br/>Custom CA certificates"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS Edge/Passthrough<br/>OIDC/K8s Token| Route
    Route -->|HTTP/80 or HTTPS/443<br/>TLS 1.2+| OnlineService
    Route -->|HTTP/80 or HTTPS/443<br/>TLS 1.2+| OfflineService
    Route -->|HTTP/80 or HTTPS/443<br/>TLS 1.2+| RegistryService
    Route -->|HTTP/80 or HTTPS/443<br/>TLS 1.2+| UIService

    OnlineService --> OnlinePod
    OfflineService --> OfflinePod
    RegistryService --> RegistryPod
    UIService --> UIPod
    MetricsService --> OperatorPod

    OnlinePod -->|Internal<br/>HTTP/HTTPS| RegistryService
    OfflinePod -->|Internal<br/>HTTP/HTTPS| RegistryService
    UIPod -->|Internal<br/>HTTP/HTTPS| RegistryService

    OnlinePod -->|HTTPS/443 or Native<br/>TLS 1.2+<br/>Credentials| Cache
    OfflinePod -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| ObjectStorage
    OfflinePod -->|5432/443 TCP<br/>TLS 1.2+<br/>DB Credentials| Database
    RegistryPod -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| ObjectStorage
    RegistryPod -->|5432/443 TCP<br/>TLS 1.2+<br/>DB Credentials| Database

    OnlinePod -.->|JWT Validation<br/>HTTPS/443<br/>TLS 1.2+| OIDC
    OfflinePod -.->|JWT Validation<br/>HTTPS/443<br/>TLS 1.2+| OIDC
    RegistryPod -.->|JWT Validation<br/>HTTPS/443<br/>TLS 1.2+| OIDC
    UIPod -.->|JWT Validation<br/>HTTPS/443<br/>TLS 1.2+| OIDC

    RegistryPod -.->|HTTPS/443 or SSH/22<br/>TLS 1.2+<br/>Token/Key| Git

    OperatorPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    OnlinePod -.->|mTLS| ServiceMesh
    OfflinePod -.->|mTLS| ServiceMesh
    RegistryPod -.->|mTLS| ServiceMesh
    UIPod -.->|mTLS| ServiceMesh

    OnlinePod -.->|Custom CA| TrustedCA
    OfflinePod -.->|Custom CA| TrustedCA
    RegistryPod -.->|Custom CA| TrustedCA

    OnlineService -.->|TLS Certs| CertManager
    OfflineService -.->|TLS Certs| CertManager
    RegistryService -.->|TLS Certs| CertManager
    UIService -.->|TLS Certs| CertManager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1bee7,stroke:#8e24aa,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Route ingress
    class OnlineService,OnlinePod,OfflineService,OfflinePod,RegistryService,RegistryPod,UIService,UIPod,MetricsService,OperatorPod,K8sAPI internal
    class ObjectStorage,Database,Cache,OIDC,Git egress
    class ServiceMesh,CertManager,TrustedCA optional
