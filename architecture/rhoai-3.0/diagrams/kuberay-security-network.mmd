graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CLI]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
        WebhookSvc["KubeRay Webhook Service<br/>ClusterIP 443→9443/TCP"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS TLS 1.2+<br/>POST /validate-ray-io-v1-raycluster<br/>POST /mutate-ray-io-v1-raycluster"]
        ServiceCA["OpenShift Service CA<br/>Cert Provisioning"]

        K8sAPI -->|mTLS| WebhookSvc
        WebhookSvc -->|forwards| WebhookServer
        ServiceCA -.->|provisions cert| WebhookServer
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>User: 65532 (non-root)<br/>CPU: 100m, Mem: 512Mi"]
        Controllers["Controllers:<br/>• RayCluster Controller<br/>• RayJob Controller<br/>• RayService Controller<br/>• NetworkPolicy Controller<br/>• Auth Controller<br/>• mTLS Controller"]
        MetricsSvc["kuberay-operator Service<br/>ClusterIP 8080/TCP<br/>/metrics (HTTP)"]

        Operator --> Controllers
        Operator --> MetricsSvc
    end

    subgraph UserNS["USER NAMESPACES ({user-namespace})"]
        direction TB

        subgraph RayCluster["Ray Cluster"]
            RayHead["Ray Head Pod<br/>SA: {cluster}-sa<br/>User: 1000 (Ray)<br/>SCC: run-as-ray-user<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
            RayWorkers["Ray Worker Pods<br/>SA: {cluster}-sa<br/>User: 1000 (Ray)<br/>SCC: run-as-ray-user<br/>Dynamic Ports"]
            NetworkPolicy["NetworkPolicy<br/>Isolates cluster traffic"]
        end

        RayWorkers -->|6379/TCP<br/>Optional mTLS| RayHead
        NetworkPolicy -.->|controls| RayHead
        NetworkPolicy -.->|controls| RayWorkers
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    subgraph OptionalIntegrations["OPTIONAL INTEGRATIONS"]
        CertManager["cert-manager<br/>Certificate Management"]
        OpenShiftRoute["OpenShift Route API<br/>Ingress"]
        GatewayAPI["Gateway API<br/>HTTPRoute"]
        Volcano["Volcano Scheduler<br/>Gang Scheduling"]
        Kueue["Kueue<br/>Job Queue"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    K8sAPI -->|invokes webhook<br/>mTLS| WebhookServer

    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token SA| K8sAPI
    Controllers -->|creates/manages| RayCluster
    Controllers -->|HTTP/8265<br/>health check| RayHead
    Controllers -->|TCP/10001<br/>Optional mTLS<br/>job submission| RayHead

    Prometheus -->|HTTP/8080<br/>no auth| MetricsSvc

    Controllers -.->|requests certs| CertManager
    Controllers -.->|creates routes| OpenShiftRoute
    Controllers -.->|creates HTTPRoutes| GatewayAPI
    Controllers -.->|annotations| Volcano
    Controllers -.->|queue management| Kueue

    CertManager -.->|provisions mTLS certs| RayCluster

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f5f5f5,stroke:#666,stroke-width:2px
    classDef optional fill:#e8e8e8,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class K8sAPI,WebhookSvc,WebhookServer,ServiceCA controlplane
    class Operator,Controllers,MetricsSvc operator
    class RayCluster,RayHead,RayWorkers,NetworkPolicy userns
    class Prometheus monitoring
    class CertManager,OpenShiftRoute,GatewayAPI,Volcano,Kueue optional
