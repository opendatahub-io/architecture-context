%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Browser"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP → 8265/TCP<br/>TLS 1.2+ termination<br/>Path: /ray/{ns}/{cluster}"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB
        Operator["kuberay-operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS: OpenShift serving certs"]
    end

    subgraph PlatformNS["PLATFORM NAMESPACE (redhat-ods-applications)"]
        HTTPRoute["HTTPRoute: {ns}-{cluster}<br/>Parent: data-science-gateway<br/>Path: /ray/{ns}/{cluster}"]
        RefGrant["ReferenceGrant<br/>kuberay-gateway-access<br/>Cross-namespace refs"]
    end

    subgraph RayNS["RAY CLUSTER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph HeadPodGroup["Ray Head Pod (SCC: run-as-ray-user UID 1000)"]
            HeadPod["Ray Head<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP<br/>GCS: 6379/TCP<br/>Metrics: 8080/TCP"]
            RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>Auth: TokenReview + SAR"]
        end

        WorkerPods["Ray Worker Pods (1..N)<br/>SCC: run-as-ray-user UID 1000<br/>mTLS: ray-worker-secret"]

        subgraph NetPolicies["NetworkPolicies (secure-trusted-network)"]
            HeadNP["Head NetworkPolicy<br/>Intra-cluster: all ports<br/>Same-NS: 10001, 8265<br/>Operator: 8265, 10001<br/>Monitoring: 8080<br/>Auth proxy: 8443"]
            WorkerNP["Worker NetworkPolicy<br/>Intra-cluster only"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        CertManager["cert-manager<br/>Issuer + Certificate CRs<br/>Auto-rotate TLS"]
        Redis["Redis (optional)<br/>6379/TCP<br/>TLS optional<br/>Password Auth"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTP/8265<br/>plaintext<br/>URL rewrite"| HeadPod

    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server client cert"| Webhook
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    Operator -.->|"creates"| HTTPRoute
    Operator -.->|"creates"| RefGrant
    Operator -.->|"injects"| RBACProxy
    Operator -.->|"creates"| HeadNP
    Operator -.->|"creates"| WorkerNP

    HeadPod <-->|"mTLS<br/>cert-manager certs"| WorkerPods
    HeadPod -->|"TCP/6379<br/>TLS optional<br/>Password"| Redis
    Operator -.->|"CRDs"| CertManager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef rayns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class Operator,Webhook operator
    class HeadPod,WorkerPods,HTTPRoute,RefGrant rayns
    class RBACProxy,HeadNP,WorkerNP security
    class K8sAPI,CertManager,Redis extsvc
