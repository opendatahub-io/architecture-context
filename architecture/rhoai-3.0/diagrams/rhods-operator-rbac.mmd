graph TD
    subgraph "Service Accounts"
        SA_Operator[redhat-ods-operator-controller-manager<br/>NS: redhat-ods-operator-system]
        SA_Prometheus[prometheus<br/>NS: redhat-ods-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[rhods-operator-rolebinding<br/>ClusterRoleBinding]
        CRB_Metrics[rhods-operator-metrics-reader<br/>RoleBinding]
        CRB_Prom[rhods-prometheus-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Operator[rhods-operator-role]
        CR_AuthProxy[auth-proxy-client]
        CR_CompEditor[component-editor-roles]
        CR_CompViewer[component-viewer-roles]
        CR_Metrics[metrics-reader]
        CR_Prom[rhods-prometheus-role]
    end

    subgraph "API Resource Groups"
        subgraph Core["Core Resources"]
            CoreResources["configmaps, events<br/>namespaces, secrets<br/>serviceaccounts<br/>pods, pods/exec, pods/log"]
        end

        subgraph Apps["Apps Resources"]
            AppsResources["deployments<br/>replicasets<br/>statefulsets"]
        end

        subgraph RBAC["RBAC Resources"]
            RBACResources["clusterroles<br/>clusterrolebindings<br/>roles, rolebindings"]
        end

        subgraph ODH["ODH Platform CRDs"]
            ODHResources["datascienceclusters<br/>dscinitializations<br/>components.*<br/>services.*"]
        end

        subgraph Monitoring["Monitoring Resources"]
            MonitoringResources["servicemonitors<br/>prometheusrules"]
        end

        subgraph OLM["OLM Resources"]
            OLMResources["subscriptions<br/>clusterserviceversions<br/>operatorconditions"]
        end

        subgraph Admission["Admission Resources"]
            AdmissionResources["validatingwebhookconfigurations<br/>mutatingwebhookconfigurations"]
        end

        subgraph CRDs["CRD Resources"]
            CRDResources["customresourcedefinitions"]
        end

        subgraph Auth["Authentication/Authorization"]
            AuthResources["tokenreviews<br/>subjectaccessreviews"]
        end
    end

    %% Service Account to RoleBinding
    SA_Operator -->|bound via| CRB_Operator
    SA_Prometheus -->|bound via| CRB_Prom

    %% RoleBinding to ClusterRole
    CRB_Operator -->|grants| CR_Operator
    CRB_Operator -->|grants| CR_AuthProxy
    CRB_Metrics -->|grants| CR_Metrics
    CRB_Prom -->|grants| CR_Prom

    %% ClusterRole to Resources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| CoreResources
    CR_Operator -->|"* (all verbs)"| AppsResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| RBACResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| ODHResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| MonitoringResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| OLMResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| AdmissionResources
    CR_Operator -->|"create, delete, get, list<br/>patch, update, watch"| CRDResources

    CR_AuthProxy -->|create| AuthResources

    CR_CompEditor -->|"create, delete, get, list<br/>patch, update, watch"| ODHResources
    CR_CompViewer -->|"get, list, watch"| ODHResources

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Prometheus fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CRB_Operator fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_Metrics fill:#f5a623,stroke:#333
    style CRB_Prom fill:#f5a623,stroke:#333

    style CR_Operator fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#7ed321,stroke:#333
    style CR_CompEditor fill:#7ed321,stroke:#333
    style CR_CompViewer fill:#7ed321,stroke:#333
    style CR_Metrics fill:#7ed321,stroke:#333
    style CR_Prom fill:#7ed321,stroke:#333

    style CoreResources fill:#d5e8d4,stroke:#333
    style AppsResources fill:#d5e8d4,stroke:#333
    style RBACResources fill:#d5e8d4,stroke:#333
    style ODHResources fill:#dae8fc,stroke:#333
    style MonitoringResources fill:#d5e8d4,stroke:#333
    style OLMResources fill:#d5e8d4,stroke:#333
    style AdmissionResources fill:#d5e8d4,stroke:#333
    style CRDResources fill:#d5e8d4,stroke:#333
    style AuthResources fill:#d5e8d4,stroke:#333
