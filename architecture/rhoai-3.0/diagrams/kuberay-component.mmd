graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator]
        Webhook[Webhook Server<br/>9443/TCP HTTPS]

        subgraph "Controllers"
            RayClusterCtrl[RayCluster Controller]
            RayJobCtrl[RayJob Controller]
            RayServiceCtrl[RayService Controller]
            NetworkPolicyCtrl[NetworkPolicy Controller]
            AuthCtrl[Authentication Controller]
            mTLSCtrl[mTLS Controller]
        end

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
        Operator --> NetworkPolicyCtrl
        Operator --> AuthCtrl
        Operator --> mTLSCtrl
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Resources"
        HeadPod[Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard]
        WorkerPods[Ray Worker Pods<br/>Dynamic ports]
        Services[Kubernetes Services]
        NetworkPolicies[Network Policies]
        Certificates[Certificates<br/>cert-manager]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional]
        Gateway[Gateway API<br/>Optional]
        Volcano[Volcano Scheduler<br/>Optional]
        Kueue[Kueue<br/>Optional]
    end

    User[User/CLI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    Webhook -->|validates/mutates| RayClusterCR

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| Services
    RayJobCtrl -->|submits jobs to| HeadPod
    RayServiceCtrl -->|manages| HeadPod

    NetworkPolicyCtrl -->|creates| NetworkPolicies
    mTLSCtrl -->|creates| Certificates

    Operator -->|watches/manages| K8sAPI
    mTLSCtrl -->|integrates| CertManager
    AuthCtrl -->|integrates| Gateway
    RayClusterCtrl -->|uses| Volcano
    RayJobCtrl -->|uses| Kueue

    WorkerPods -->|connects to| HeadPod

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style Webhook fill:#4a90e2,stroke:#333
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Gateway fill:#999,stroke:#333
    style Volcano fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
