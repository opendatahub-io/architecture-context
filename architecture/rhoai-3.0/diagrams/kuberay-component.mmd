%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "KubeRay Operator"
        direction TB
        Main[kuberay-operator<br/>Go Operator]

        subgraph "Controllers"
            RCCtrl[RayCluster Controller]
            RJCtrl[RayJob Controller]
            RSCtrl[RayService Controller]
            MTLSCtrl[RayCluster MTLS Controller]
            AuthCtrl[Authentication Controller]
            NPCtrl[NetworkPolicy Controller]
        end

        subgraph "Webhooks"
            MutWebhook[RayCluster Mutating Webhook<br/>9443/TCP]
            ValWebhook[RayCluster Validating Webhook<br/>9443/TCP]
        end

        Main --> RCCtrl
        Main --> RJCtrl
        Main --> RSCtrl
        Main --> MTLSCtrl
        Main --> AuthCtrl
        Main --> NPCtrl
        Main --> MutWebhook
        Main --> ValWebhook
    end

    %% CRDs
    RayClusterCR[RayCluster CR<br/>ray.io/v1]
    RayJobCR[RayJob CR<br/>ray.io/v1]
    RayServiceCR[RayService CR<br/>ray.io/v1]

    User[User / Pipeline] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RCCtrl
    RayJobCR -->|watched by| RJCtrl
    RayServiceCR -->|watched by| RSCtrl

    %% Resources created by controllers
    RCCtrl -->|creates| HeadPod[Ray Head Pod]
    RCCtrl -->|creates| WorkerPods[Ray Worker Pods]
    RCCtrl -->|creates| HeadSvc[Head Service<br/>8265, 10001, 6379]
    RJCtrl -->|creates| SubmitterJob[K8s Job<br/>Submitter]
    RSCtrl -->|creates| ServeSvc[Serve Service<br/>8000]

    AuthCtrl -->|creates| HTTPRoute[HTTPRoute<br/>Gateway API]
    AuthCtrl -->|creates| RefGrant[ReferenceGrant]
    AuthCtrl -->|injects| RBACProxy[kube-rbac-proxy<br/>sidecar 8443/TCP]

    MTLSCtrl -->|creates| Issuer[cert-manager Issuer]
    MTLSCtrl -->|creates| Certs[TLS Certificates]

    NPCtrl -->|creates| NetPol[NetworkPolicies<br/>head + worker]

    %% External Dependencies
    Main -->|depends on| K8sAPI[Kubernetes API]
    AuthCtrl -->|references| Gateway[data-science-gateway]
    MTLSCtrl -->|depends on| CertManager[cert-manager]
    Main -->|deployed by| RhodsOp[rhods-operator]

