graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator]
        RayClusterController[RayCluster Controller]
        RayJobController[RayJob Controller]
        RayServiceController[RayService Controller]
        NetworkPolicyController[NetworkPolicy Controller]
        AuthController[Authentication Controller]
        mTLSController[mTLS Controller]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS TLS 1.2+]

        Operator --> RayClusterController
        Operator --> RayJobController
        Operator --> RayServiceController
        Operator --> NetworkPolicyController
        Operator --> AuthController
        Operator --> mTLSController
        Operator --> WebhookServer
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Resources"
        RayHeadPod[Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client]
        RayWorkerPods[Ray Worker Pods<br/>Dynamic Ports]
        Services[Services]
        NetworkPolicies[NetworkPolicies]
        Deployments[Deployments]
        Jobs[Jobs]
        ConfigMaps[ConfigMaps]
        Secrets[Secrets]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Certificate Management]
        Prometheus[Prometheus<br/>8080/TCP HTTP]
        OSServiceCA[OpenShift Service CA<br/>Webhook Certs]
    end

    subgraph "Optional Integrations"
        OpenShiftRoute[OpenShift Route API]
        GatewayAPI[Gateway API<br/>HTTPRoute]
        Volcano[Volcano Scheduler<br/>Gang Scheduling]
        Yunikorn[Yunikorn Scheduler]
        Kueue[Kueue<br/>Job Queue]
    end

    User[User/CLI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterController
    RayJobCR -->|watched by| RayJobController
    RayServiceCR -->|watched by| RayServiceController

    RayClusterController -->|creates/manages| RayHeadPod
    RayClusterController -->|creates/manages| RayWorkerPods
    RayClusterController -->|creates/manages| Services
    RayClusterController -->|creates/manages| ConfigMaps
    RayClusterController -->|creates/manages| Secrets

    RayJobController -->|creates/manages| Jobs
    RayServiceController -->|creates/manages| Deployments

    NetworkPolicyController -->|creates/manages| NetworkPolicies
    AuthController -->|configures| OpenShiftRoute
    AuthController -->|configures| GatewayAPI
    mTLSController -->|requests certs from| CertManager

    WebhookServer -->|validates/mutates| RayClusterCR
    K8sAPI -->|invokes| WebhookServer

    Operator -->|reconciles via| K8sAPI
    Prometheus -->|scrapes metrics| Operator
    OSServiceCA -->|provisions cert| WebhookServer

    RayClusterController -.->|optional| Volcano
    RayClusterController -.->|optional| Yunikorn
    RayJobController -.->|optional| Kueue

    RayWorkerPods -->|connect to GCS| RayHeadPod

    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style RayClusterController fill:#4a90e2,stroke:#333
    style RayJobController fill:#4a90e2,stroke:#333
    style RayServiceController fill:#4a90e2,stroke:#333
    style WebhookServer fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style RayHeadPod fill:#bd10e0,stroke:#333
    style RayWorkerPods fill:#bd10e0,stroke:#333
