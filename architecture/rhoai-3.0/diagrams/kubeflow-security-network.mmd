%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway (Envoy)<br/>Namespace: openshift-ingress<br/>443/TCP TLS 1.2+<br/>TLS Termination"]
    end

    subgraph ControllerPlane["CONTROLLER PLANE (opendatahub namespace)"]
        direction TB
        Controller["ODH Notebook Controller<br/>SA: odh-notebook-controller-manager<br/>Image: odh-notebook-controller:v1.10.0-8"]
        WebhookSvc["Webhook Service<br/>443/TCP → 8443/TCP<br/>TLS (service-ca cert)<br/>Path: /mutate-notebook-v1"]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP plaintext"]
        HealthSvc["Health Probes<br/>8081/TCP HTTP plaintext<br/>/healthz, /readyz"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph NotebookPod["Notebook Pod (StatefulSet)"]
            KRBProxy["kube-rbac-proxy sidecar<br/>odh-kube-auth-proxy<br/>8443/TCP HTTPS<br/>TLS (service-ca cert)<br/>TokenReview + SAR"]
            NotebookContainer["Notebook Container<br/>8888/TCP HTTP plaintext"]
        end

        RefGrant["ReferenceGrant<br/>notebook-httproute-access"]
        NetPolCtrl["{name}-ctrl-np<br/>Ingress: TCP/8888<br/>from controller ns"]
        NetPolProxy["{name}-kube-rbac-proxy-np<br/>Ingress: TCP/8443<br/>from any"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>SA Token Auth"]
        ImageRegistry["OpenShift ImageStream Registry<br/>5000/TCP HTTPS TLS<br/>SA Token Auth"]
        ServiceCA["OpenShift service-ca operator<br/>Auto-provisions TLS certs"]
        DSPA["DSPA<br/>CRD watch via K8s API"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress to Notebook (with auth)
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token fwd"| KRBProxy
    KRBProxy -->|"HTTP/8888<br/>plaintext (localhost)<br/>X-Auth-Request headers"| NotebookContainer

    %% Ingress to Notebook (without auth)
    Gateway -.->|"HTTP/8888<br/>plaintext<br/>No auth"| NotebookContainer

    %% kube-rbac-proxy auth check
    KRBProxy -->|"HTTPS/443<br/>TLS<br/>TokenReview + SAR"| K8sAPI

    %% Controller operations
    Controller -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>CRUD resources"| K8sAPI
    Controller -->|"HTTPS/5000<br/>TLS<br/>SA Token<br/>Resolve images"| ImageRegistry
    Controller -->|"Watch DSPA CRs"| DSPA

    %% Webhook flow
    K8sAPI -->|"HTTPS/443→8443<br/>TLS (service-ca)<br/>API server cert"| WebhookSvc

    %% service-ca provisions certs
    ServiceCA -.->|"provisions TLS cert"| WebhookSvc
    ServiceCA -.->|"provisions TLS cert"| KRBProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Gateway ingress
    class Controller,WebhookSvc,MetricsSvc,HealthSvc controller
    class KRBProxy,NotebookContainer,RefGrant userns
    class K8sAPI,ImageRegistry,ServiceCA,DSPA internal
    class NetPolCtrl,NetPolProxy netpol
