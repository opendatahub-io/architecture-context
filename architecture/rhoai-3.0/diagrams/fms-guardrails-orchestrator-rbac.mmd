%% FMS Guardrails Orchestrator - RBAC & Security Diagram
%% Generated by: Claude Opus 4.6
%% Note: This component does not define Kubernetes RBAC resources.
%% This diagram shows the authentication/authorization model instead.

graph TD
    subgraph TLSModes["TLS Server Modes"]
        direction TB
        Plaintext["Plaintext Mode<br/>(No TLS env vars)<br/>Default"]
        TLSMode["TLS Mode<br/>TLS_KEY_PATH +<br/>TLS_CERT_PATH"]
        mTLSMode["mTLS Mode<br/>TLS + TLS_CLIENT_CA_CERT_PATH<br/>WebPKI Client Verification"]
    end

    subgraph AuthFlow["Authentication Flow"]
        direction TB
        V1Auth["v1 API Auth<br/>X-Forwarded-Access-Token<br/>→ Bearer token"]
        V2Auth["v2 API Auth<br/>Configurable<br/>passthrough_headers"]
        HealthAuth["Health Endpoints<br/>/health, /info<br/>No Auth Required"]
    end

    subgraph ClientTLS["Client-side TLS (per-service YAML config)"]
        direction TB
        CertPath["cert_path<br/>Client certificate"]
        KeyPath["key_path<br/>Client private key"]
        CACert["client_ca_cert_path<br/>CA certificate"]
        InsecureFlag["insecure flag<br/>Skip verification"]
        NamedTLS["Named TLS configs<br/>Reusable across services"]
    end

    subgraph Secrets["Secrets (Platform-managed)"]
        direction TB
        ServerCert["TLS Server Cert/Key<br/>Type: kubernetes.io/tls<br/>Provisioned by: Platform/Operator"]
        ClientCerts["TLS Client Certs<br/>Type: Opaque<br/>Provisioned by: Platform/Operator"]
        CACerts["TLS CA Certificates<br/>Type: Opaque<br/>Provisioned by: Platform/Operator"]
    end

    subgraph Backends["Backend Service Auth"]
        direction TB
        TGISAuth["TGIS / Chunker<br/>Auth: Client certs (mTLS)"]
        vLLMAuth["vLLM / OpenAI<br/>Auth: Bearer token (forwarded)"]
        DetectorAuth["Detectors<br/>Auth: Client certs or<br/>Header passthrough"]
    end

    %% Connections
    TLSMode --> ServerCert
    mTLSMode --> ServerCert
    mTLSMode --> CACerts
    CertPath --> ClientCerts
    KeyPath --> ClientCerts
    CACert --> CACerts

    V1Auth -->|"forwards token"| vLLMAuth
    V2Auth -->|"forwards headers"| DetectorAuth
    ClientTLS -->|"configures"| TGISAuth
    ClientTLS -->|"configures"| DetectorAuth

