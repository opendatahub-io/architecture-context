graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (OpenShift Router / DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge<br/>Re-encryption"]
        Route["OpenShift Route<br/>{registry-name}-https<br/>TLS Edge Termination"]

        Router --> Route
    end

    subgraph RegistryNamespace["MODEL REGISTRY INSTANCE NAMESPACE<br/>{registry-namespace}"]
        direction TB

        Service["ClusterIP Service<br/>{registry-name}<br/>8443/TCP (HTTPS)<br/>8080/TCP (HTTP)"]

        subgraph Pod["Registry Deployment Pod"]
            direction LR
            RBACProxy["kube-rbac-proxy<br/>:8443 HTTPS<br/>TLS 1.2+<br/>SubjectAccessReview Auth"]
            RESTServer["REST Server<br/>:8080 HTTP<br/>No Auth (localhost)"]
            gRPCServer["gRPC Server<br/>:9090 gRPC<br/>Internal Only"]

            RBACProxy -->|localhost<br/>HTTP/8080| RESTServer
            RESTServer -.->|sidecar| gRPCServer
        end

        Service --> RBACProxy

        NetworkPolicy["Network Policy<br/>{registry-name}-https-route<br/>Allows: OpenShift Router<br/>Port: 8443/TCP"]
        NetworkPolicy -.->|protects| Pod
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE<br/>opendatahub / redhat-ods-applications"]
        direction TB

        Controller["Controller Manager<br/>SA: controller-manager<br/>User: 65532:65532<br/>FIPS Mode"]

        WebhookService["Webhook Service<br/>:9443 HTTPS<br/>TLS Client Cert Auth"]

        Controller -->|serves| WebhookService
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>:6443 HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL DATABASE SERVICES"]
        direction LR
        PostgreSQL["PostgreSQL 16<br/>:5432 TCP<br/>TLS (optional)<br/>Password + Client Cert"]
        MySQL["MySQL 8.x<br/>:3306 TCP<br/>TLS (optional)<br/>Password + Client Cert"]
    end

    subgraph OptionalServices["OPTIONAL INTEGRATIONS"]
        Istio["Istio Service Mesh<br/>mTLS<br/>Gateway: ingressgateway"]
        ServiceCA["OpenShift Service CA<br/>Auto TLS Certs"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Route -->|HTTPS/8443<br/>TLS 1.2+ re-encrypted<br/>Bearer Token| Service

    %% Database connections
    RESTServer -->|PostgreSQL/5432<br/>TLS optional<br/>Password + Cert| PostgreSQL
    RESTServer -->|MySQL/3306<br/>TLS optional<br/>Password + Cert| MySQL
    gRPCServer -->|PostgreSQL/5432<br/>TLS optional<br/>Password + Cert| PostgreSQL
    gRPCServer -->|MySQL/3306<br/>TLS optional<br/>Password + Cert| MySQL

    %% Operator flows
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch/Reconcile| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>TLS Client Cert| WebhookService
    Controller -->|Creates/Manages| Pod

    %% Optional integrations
    Controller -.->|Optional| Istio
    ServiceCA -.->|Provisions TLS| RBACProxy
    ServiceCA -.->|Provisions TLS| WebhookService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:3px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef optional fill:#f5f5f5,stroke:#999,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Router,Route ingress
    class Service,Pod,RBACProxy,RESTServer,gRPCServer,NetworkPolicy application
    class Controller,WebhookService operator
    class K8sAPI controlplane
    class PostgreSQL,MySQL database
    class Istio,ServiceCA optional
