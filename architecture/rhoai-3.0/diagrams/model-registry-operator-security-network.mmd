graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Re-encryption"]
        IstioGW["Istio Gateway (Optional)<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE/MUTUAL"]
    end

    subgraph OperatorNS["Namespace: opendatahub / redhat-ods-applications"]
        direction TB

        Controller["Controller Manager<br/>SA: controller-manager<br/>FIPS Enabled<br/>User: 65532:65532"]

        subgraph ControllerPorts["Controller Endpoints"]
            Metrics["Metrics<br/>8443/TCP HTTPS<br/>Bearer Token"]
            Health["Health<br/>8081/TCP HTTP<br/>/healthz /readyz"]
            Webhook["Webhook<br/>9443/TCP HTTPS<br/>TLS Client Cert"]
        end

        Controller --> ControllerPorts
    end

    subgraph RegistryNS["Namespace: {user-namespace}"]
        direction TB

        subgraph RegistryPod["Model Registry Deployment - {registry-name}"]
            Proxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
            REST["REST Container<br/>8080/TCP HTTP<br/>/api/model_registry/v1alpha3/*"]
            GRPC["gRPC Container<br/>9090/TCP gRPC<br/>ml_metadata.MetadataStoreService"]

            Proxy -->|localhost:8080<br/>HTTP| REST
        end

        subgraph RegistryServices["Services"]
            SvcHTTP["{registry-name}<br/>8080/TCP"]
            SvcHTTPS["{registry-name}<br/>8443/TCP"]
            SvcGRPC["{registry-name}<br/>9090/TCP"]
        end

        subgraph NetworkPolicy["Network Policies"]
            NP["{registry-name}-https-route<br/>Ingress: OpenShift Router<br/>Port: 8443/TCP"]
        end
    end

    subgraph K8sCore["KUBERNETES CORE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP<br/>TLS Optional<br/>Password + Client Cert"]
        MySQL["MySQL Database<br/>3306/TCP<br/>TLS Optional<br/>Password + Client Cert"]
        Prometheus["Prometheus<br/>HTTPS/8443<br/>Bearer Token"]
        ServiceCA["OpenShift Service CA<br/>Auto-rotate TLS Certs"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Client -.->|HTTPS/443<br/>TLS MUTUAL<br/>Optional| IstioGW

    Router -->|HTTPS/8443<br/>Re-encrypted| SvcHTTPS
    IstioGW -.->|HTTPS/8443<br/>mTLS| SvcHTTPS

    %% Service to Pod
    SvcHTTPS --> Proxy
    SvcHTTP --> REST
    SvcGRPC --> GRPC

    %% Internal flows
    InternalClient[Internal Client Pod] -->|HTTP/8080| SvcHTTP
    InternalClient -->|gRPC/9090| SvcGRPC

    %% Database flows
    REST -->|PostgreSQL/5432<br/>TLS Optional<br/>Password/Cert| PostgreSQL
    REST -->|MySQL/3306<br/>TLS Optional<br/>Password/Cert| MySQL
    GRPC -->|PostgreSQL/5432<br/>TLS Optional<br/>Password/Cert| PostgreSQL
    GRPC -->|MySQL/3306<br/>TLS Optional<br/>Password/Cert| MySQL

    %% Controller flows
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| APIServer
    APIServer -->|Watch Events<br/>TLS 1.2+| Controller
    APIServer -->|HTTPS/9443<br/>TLS Client Cert| Webhook

    Controller -->|Creates/Manages| RegistryPod

    %% Monitoring
    Prometheus -->|HTTPS/8443<br/>Bearer Token| Metrics

    %% Service CA
    ServiceCA -.->|Provisions TLS<br/>Auto-rotate| Proxy
    ServiceCA -.->|Provisions TLS<br/>Auto-rotate| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8score fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Router,IstioGW ingress
    class Controller,ControllerPorts,Proxy,REST,GRPC,RegistryServices,NetworkPolicy,InternalClient trusted
    class APIServer k8score
    class PostgreSQL,MySQL,Prometheus externalservice
    class ServiceCA optional
