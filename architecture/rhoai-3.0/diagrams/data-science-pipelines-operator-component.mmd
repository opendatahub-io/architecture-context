graph TB
    subgraph "Data Science Pipelines Operator"
        Controller[DSPO Controller<br/>Operator]
        HealthProbes[Health Probes<br/>8081/TCP]
        Metrics[Metrics<br/>8080/TCP]

        Controller -->|monitors| HealthProbes
        Controller -->|exposes| Metrics
    end

    subgraph "DSP Instance Components (per namespace)"
        APIServer[DSP API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP HTTPS]
        PersistenceAgent[Persistence Agent<br/>Workflow Monitor]
        ScheduledWorkflow[Scheduled Workflow<br/>Cron Controller]
        WorkflowController[Workflow Controller<br/>Argo Workflows]

        APIServer -->|syncs state| PersistenceAgent
        APIServer -->|submits workflows| WorkflowController
        ScheduledWorkflow -->|triggers| APIServer
    end

    subgraph "Optional Storage Components"
        MariaDB[MariaDB<br/>3306/TCP<br/>TLS + Password]
        Minio[Minio<br/>9000/TCP<br/>S3 API]
        MLMDgRPC[MLMD gRPC<br/>8080/TCP]
        MLMDEnvoy[MLMD Envoy<br/>9090/TCP]

        MLMDEnvoy -->|forwards| MLMDgRPC
    end

    subgraph "Custom Resources"
        DSPA[DataSciencePipelinesApplication CR]
        WorkflowCR[Workflow CRs]
        PipelineCR[Pipeline CRs]
    end

    subgraph "External Dependencies"
        ArgoWorkflows[Argo Workflows v3.4+]
        K8sAPI[Kubernetes API<br/>6443/TCP]
        ExternalS3[External S3 Storage<br/>443/TCP HTTPS]
        ExternalDB[External Database<br/>3306/5432 TCP TLS]
    end

    subgraph "Internal ODH/RHOAI Dependencies"
        Dashboard[ODH Dashboard]
        DSC[DataScienceCluster CR]
        KServe[KServe]
        Workbenches[Workbenches/Notebooks]
        ServiceMesh[Service Mesh]
    end

    %% User Interactions
    User[Data Scientist] -->|creates| DSPA
    User -->|submits pipelines| APIServer

    %% Controller Reconciliation
    Controller -->|watches| DSPA
    Controller -->|creates/manages| APIServer
    Controller -->|creates/manages| PersistenceAgent
    Controller -->|creates/manages| ScheduledWorkflow
    Controller -->|creates/manages| WorkflowController
    Controller -->|creates/manages| MariaDB
    Controller -->|creates/manages| Minio
    Controller -->|creates/manages| MLMDgRPC

    %% Workflow Execution
    WorkflowController -->|creates| WorkflowCR
    WorkflowController -->|manages pods via| K8sAPI

    %% Data Storage
    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores metadata| ExternalDB
    PersistenceAgent -->|syncs to| MariaDB
    PersistenceAgent -->|syncs to| ExternalDB
    MLMDgRPC -->|stores lineage| MariaDB

    %% Artifact Storage
    APIServer -->|artifact URLs| Minio
    APIServer -->|artifact URLs| ExternalS3

    %% Pipeline CRs
    APIServer -->|manages| PipelineCR

    %% Integration with ODH/RHOAI
    Dashboard -->|API calls| APIServer
    DSC -->|deploys| Controller
    APIServer -->|creates| KServe
    Workbenches -->|API calls| APIServer
    ServiceMesh -->|mTLS| APIServer

    %% External Dependencies
    WorkflowController -.->|based on| ArgoWorkflows

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style PersistenceAgent fill:#4a90e2,stroke:#333,stroke-width:2px
    style ScheduledWorkflow fill:#4a90e2,stroke:#333,stroke-width:2px
    style WorkflowController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSPA fill:#f5a623,stroke:#333,stroke-width:2px
    style WorkflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style PipelineCR fill:#f5a623,stroke:#333,stroke-width:2px
    style MariaDB fill:#9b59b6,stroke:#333
    style Minio fill:#9b59b6,stroke:#333
    style MLMDgRPC fill:#9b59b6,stroke:#333
    style MLMDEnvoy fill:#9b59b6,stroke:#333
    style ArgoWorkflows fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style ExternalS3 fill:#999,stroke:#333
    style ExternalDB fill:#999,stroke:#333
