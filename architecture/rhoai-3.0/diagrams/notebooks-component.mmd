graph TB
    subgraph "Notebooks Component (Container Images)"
        subgraph "Jupyter Workbenches"
            JupyterMinimal[Jupyter Minimal<br/>Python 3.12, JupyterLab 4.4<br/>Port: 8888/TCP HTTP]
            JupyterDataScience[Jupyter DataScience<br/>pandas, numpy, scikit-learn<br/>Port: 8888/TCP HTTP]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.x, CUDA 12.8/ROCm 6.3<br/>Port: 8888/TCP HTTP]
            JupyterTensorFlow[Jupyter TensorFlow<br/>TensorFlow 2.16+, CUDA 12.8/ROCm 6.3<br/>Port: 8888/TCP HTTP]
            JupyterTrustyAI[Jupyter TrustyAI<br/>TrustyAI libraries<br/>Port: 8888/TCP HTTP]
            JupyterLLMCompressor[Jupyter LLMCompressor<br/>PyTorch + LLMCompressor<br/>Port: 8888/TCP HTTP]
        end

        subgraph "Other IDEs"
            RStudioServer[RStudio Server<br/>R 4.5.1, RStudio 2025.09.0<br/>Port: 8080/TCP HTTP]
            CodeServer[CodeServer<br/>VS Code, Node.js 22.18.0<br/>Port: 8787/TCP HTTP]
            NginxProxy[NGINX Proxy<br/>Reverse proxy for RStudio/CodeServer<br/>Port: 8888/TCP HTTP]
        end

        subgraph "Runtime Images"
            RuntimeImages[Pipeline Runtime Images<br/>Headless versions for KFP<br/>No UI, CLI only]
        end

        subgraph "Base Infrastructure"
            BaseImagesCPU[Base Images - CPU<br/>UBI9, Python 3.12]
            BaseImagesCUDA[Base Images - CUDA<br/>CUDA 12.8 Toolkit]
            BaseImagesROCm[Base Images - ROCm<br/>ROCm 6.3/6.4 Toolkit]
        end
    end

    subgraph "ODH Platform Components"
        NotebookController[ODH Notebook Controller<br/>Manages Notebook CRD]
        Dashboard[ODH Dashboard<br/>UI for workbench selection]
        OAuthProxy[OAuth Proxy Sidecar<br/>Authentication]
    end

    subgraph "External Services"
        PyPI[PyPI<br/>files.pythonhosted.org:443]
        CRAN[CRAN<br/>cran.rstudio.com:443]
        GitHub[GitHub<br/>github.com:443/22]
        QuayIO[Quay.io<br/>Container Registry:443]
        S3Storage[S3 Storage<br/>443/TCP HTTPS]
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
    end

    subgraph "Kubeflow Integration"
        KFPController[Kubeflow Pipelines<br/>Pipeline orchestration]
        ModelRegistry[Model Registry<br/>8080/TCP HTTP]
    end

    %% User interactions
    User[Data Scientist] -->|creates workbench| Dashboard
    Dashboard -->|discovers images via| ImageStreams[ImageStreams<br/>manifests/base/*.yaml]
    ImageStreams -->|references| QuayIO

    %% Workbench lifecycle
    NotebookController -->|creates pod from| JupyterMinimal
    NotebookController -->|creates pod from| JupyterDataScience
    NotebookController -->|creates pod from| JupyterPyTorch
    NotebookController -->|creates pod from| JupyterTensorFlow
    NotebookController -->|creates pod from| RStudioServer
    NotebookController -->|creates pod from| CodeServer
    NotebookController -->|injects| OAuthProxy

    %% Authentication flow
    User -->|HTTPS/443| OAuthProxy
    OAuthProxy -->|authenticated| JupyterMinimal
    OAuthProxy -->|authenticated| RStudioServer
    OAuthProxy -->|authenticated| CodeServer

    %% Nginx proxy
    RStudioServer -->|proxied by| NginxProxy
    CodeServer -->|proxied by| NginxProxy

    %% Base image dependencies
    JupyterMinimal -.->|built from| BaseImagesCPU
    JupyterDataScience -.->|built from| BaseImagesCPU
    JupyterPyTorch -.->|built from| BaseImagesCUDA
    JupyterPyTorch -.->|built from| BaseImagesROCm
    JupyterTensorFlow -.->|built from| BaseImagesCUDA
    JupyterTensorFlow -.->|built from| BaseImagesROCm

    %% Pipeline integration
    KFPController -->|executes using| RuntimeImages
    RuntimeImages -->|accesses| S3Storage
    RuntimeImages -->|registers models| ModelRegistry

    %% External dependencies
    JupyterMinimal -->|pip install| PyPI
    JupyterDataScience -->|pip install| PyPI
    RStudioServer -->|install.packages| CRAN
    CodeServer -->|git clone| GitHub
    JupyterMinimal -->|git push/pull| GitHub
    JupyterMinimal -->|oc commands| K8sAPI
    JupyterDataScience -->|data/models| S3Storage

