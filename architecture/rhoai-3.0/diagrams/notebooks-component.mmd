graph TB
    subgraph "Notebooks Component - Workbench Images"
        subgraph "Jupyter Workbenches"
            JupyterMinimal[Jupyter Minimal<br/>Python 3.12 + JupyterLab 4.4]
            JupyterDS[Jupyter DataScience<br/>pandas, numpy, scikit-learn]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.x + CUDA/ROCm]
            JupyterTF[Jupyter TensorFlow<br/>TensorFlow 2.16+]
            JupyterTrusty[Jupyter TrustyAI<br/>Model Explainability]
            JupyterLLM[Jupyter LLMCompressor<br/>LLM Optimization]
        end

        subgraph "Alternative IDEs"
            RStudio[RStudio Server<br/>R 4.5.1 + IDE]
            CodeServer[CodeServer<br/>VS Code Browser IDE]
        end

        subgraph "Supporting Services"
            NGINXProxy[NGINX Proxy<br/>Reverse Proxy]
            ApacheHTTPD[Apache httpd<br/>RStudio Auth]
        end

        subgraph "Runtime Images"
            RuntimeImages[Pipeline Runtime Images<br/>Headless - No UI]
        end

        subgraph "Base Images"
            BaseCPU[Base CPU<br/>UBI9 x86_64/aarch64/ppc64le/s390x]
            BaseCUDA[Base CUDA 12.8<br/>UBI9 x86_64/aarch64]
            BaseROCm[Base ROCm 6.3/6.4<br/>UBI9 x86_64]
        end
    end

    subgraph "ODH Platform"
        NotebookController[ODH Notebook Controller]
        Dashboard[ODH Dashboard]
        OAuthProxy[OAuth Proxy Sidecar]
    end

    subgraph "External Services"
        PyPI[PyPI<br/>Python Packages]
        CRAN[CRAN<br/>R Packages]
        GitHub[GitHub<br/>Source Control]
        Quay[Quay.io<br/>Container Registry]
        S3[S3 Storage<br/>Data/Models]
        K8sAPI[Kubernetes API]
    end

    subgraph "Integration Points"
        KFP[Kubeflow Pipelines]
        ModelRegistry[Model Registry]
    end

    %% Base Image Dependencies
    JupyterMinimal -.->|built from| BaseCPU
    JupyterDS -.->|built from| BaseCPU
    JupyterPyTorch -.->|built from| BaseCUDA
    JupyterPyTorch -.->|built from| BaseROCm
    JupyterTF -.->|built from| BaseCUDA
    JupyterTF -.->|built from| BaseROCm
    JupyterTrusty -.->|built from| BaseCPU
    JupyterLLM -.->|built from| BaseCUDA
    RStudio -.->|built from| BaseCPU
    RStudio -.->|built from| BaseCUDA
    CodeServer -.->|built from| BaseCPU
    RuntimeImages -.->|built from| BaseCPU

    %% Supporting Service Connections
    RStudio -->|proxied by| NGINXProxy
    RStudio -->|auth via| ApacheHTTPD
    CodeServer -->|proxied by| NGINXProxy

    %% ODH Platform Management
    NotebookController -->|creates/manages| JupyterMinimal
    NotebookController -->|creates/manages| JupyterDS
    NotebookController -->|creates/manages| JupyterPyTorch
    NotebookController -->|creates/manages| JupyterTF
    NotebookController -->|creates/manages| RStudio
    NotebookController -->|creates/manages| CodeServer
    NotebookController -->|injects| OAuthProxy
    Dashboard -->|displays| JupyterMinimal
    Dashboard -->|displays| JupyterDS
    Dashboard -->|displays| RStudio
    Dashboard -->|displays| CodeServer
    OAuthProxy -->|protects| JupyterMinimal
    OAuthProxy -->|protects| RStudio
    OAuthProxy -->|protects| CodeServer

    %% External Dependencies
    JupyterMinimal -->|install packages| PyPI
    JupyterDS -->|install packages| PyPI
    JupyterPyTorch -->|install packages| PyPI
    JupyterTF -->|install packages| PyPI
    RStudio -->|install packages| CRAN
    CodeServer -->|clone repos| GitHub
    JupyterMinimal -->|git operations| GitHub
    JupyterDS -->|store data/models| S3
    JupyterPyTorch -->|store data/models| S3
    JupyterTF -->|store data/models| S3
    JupyterMinimal -->|oc commands| K8sAPI
    JupyterDS -->|oc commands| K8sAPI

    %% Integration Points
    KFP -->|executes| RuntimeImages
    JupyterDS -->|register models| ModelRegistry
    JupyterPyTorch -->|register models| ModelRegistry
    JupyterTF -->|register models| ModelRegistry

