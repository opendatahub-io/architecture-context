        InferenceAuth["Model Inference Endpoints<br/>Auth: Configurable<br/>(Bearer Token / None)<br/>Purpose: Served model queries"]
        AnthropicAuth["Anthropic API<br/>Auth: API Key<br/>Purpose: Claude model queries"]
    end

    subgraph "Secrets (Environment Variables)"
        HFToken["HF_TOKEN<br/>Type: Bearer Token<br/>Provisioned: User/Operator<br/>Auto-Rotate: No"]
        WatsonXKey["WATSONX_API_KEY<br/>Type: API Key<br/>Provisioned: User/Operator<br/>Auto-Rotate: No"]
        WatsonXURL["WATSONX_URL<br/>Type: URL<br/>Provisioned: User/Operator"]
        WatsonXProject["WATSONX_PROJECT_ID<br/>Type: String<br/>Provisioned: User/Operator"]
        GitAuth["git_auth_secret<br/>Type: Git credentials<br/>Provisioned: Konflux/PaC<br/>(Build-time only)"]
    end

    %% Flows
    SA -->|creates Job with| Container
    JobRBAC -->|grants permissions to| SA

    Container -->|uses| HFAuth
    Container -->|uses| WatsonXAuth
    Container -->|uses| InferenceAuth
    Container -->|uses| AnthropicAuth

    HFAuth -->|reads from| HFToken
    WatsonXAuth -->|reads from| WatsonXKey
    WatsonXAuth -->|reads from| WatsonXURL
    WatsonXAuth -->|reads from| WatsonXProject

