/*
 * FMS Guardrails Orchestrator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        client = person "Client Application" "Sends text generation and content detection requests"

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "REST API orchestrator coordinating AI text generation with safety guardrails (Rust/axum)" {
            mainServer = container "Main HTTP Server" "Handles guardrails API requests, orchestrates generation and detection" "Rust/axum, Port 8033/TCP"
            healthServer = container "Health Server" "Dedicated health check and info endpoints" "Rust/axum, Port 8034/TCP"
            generationClient = container "GenerationClient" "gRPC client for TGIS/Caikit NLP text generation" "tonic gRPC"
            openAiClient = container "OpenAiClient" "HTTP client for OpenAI-compatible generation backends" "reqwest HTTP"
            detectorClient = container "DetectorClient" "HTTP client for content safety detector services" "reqwest HTTP"
            chunkerClient = container "ChunkerClient" "gRPC client for text chunking/tokenization" "tonic gRPC"
            tlsModule = container "TLS Module" "Configures TLS/mTLS for server and client connections" "rustls/ring (FIPS)"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server for LLM generation" "Internal RHOAI"
        caikitNlp = softwareSystem "Caikit NLP" "NLP text generation service" "Internal RHOAI"
        vllm = softwareSystem "vLLM / OpenAI-compatible Server" "Chat completions and text completions generation" "Internal RHOAI"
        detectors = softwareSystem "Detector Services" "Content safety analysis (HAP, toxicity, etc.)" "Internal RHOAI"
        chunkers = softwareSystem "Chunker Services" "Caikit-based text chunking/tokenization" "Internal RHOAI"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Traces and metrics collection" "External"

        /* Relationships */
        client -> orchestrator "Sends generation/detection requests" "HTTP/HTTPS 8033/TCP, TLS 1.2+"
        client -> orchestrator "Health checks" "HTTP 8034/TCP"

        orchestrator -> tgis "Text generation (Generate, GenerateStream)" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> caikitNlp "Text generation via Caikit NLP API" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> vllm "Chat completions, text completions" "HTTP/HTTPS, TLS, Bearer token"
        orchestrator -> detectors "Content safety analysis" "HTTP/HTTPS, TLS/mTLS"
        orchestrator -> chunkers "Text chunking/tokenization" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> otelCollector "Export traces and metrics" "OTLP gRPC/HTTP, 4317/4318 TCP"

        /* Container-level relationships */
        mainServer -> generationClient "Delegates generation"
        mainServer -> openAiClient "Delegates OpenAI generation"
        mainServer -> detectorClient "Delegates detection"
        mainServer -> chunkerClient "Delegates chunking"
        mainServer -> tlsModule "TLS configuration"
        generationClient -> tgis "gRPC Generate/GenerateStream"
        generationClient -> caikitNlp "gRPC TextGenerationTaskPredict"
        openAiClient -> vllm "POST /v1/chat/completions, /v1/completions"
        detectorClient -> detectors "POST /api/v1/text/contents, chat, context, generation"
        chunkerClient -> chunkers "gRPC ChunkerTokenizationTaskPredict"
    }

    views {
        systemContext orchestrator "SystemContext" {
            include *
            autoLayout
        }

        container orchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
