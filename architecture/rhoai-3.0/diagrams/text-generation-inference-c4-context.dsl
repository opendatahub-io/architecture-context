// C4 Context Diagram - Text Generation Inference Server (TGIS)
// Generated by: Claude Opus 4.6

workspace {
    model {
        client = person "ML Application / Client" "Sends inference requests to TGIS via KServe/ModelMesh"

        tgis = softwareSystem "Text Generation Inference Server (TGIS)" "High-performance LLM inference server with gRPC API, tensor parallelism, and multiple inference engine backends" {
            launcher = container "Launcher" "Process orchestrator - starts shards and router, manages lifecycle" "Rust Binary"
            router = container "Router" "Request routing, batching, scheduling; exposes gRPC (8033) and HTTP (3000) endpoints" "Rust Binary (Tonic + Axum)"
            modelShards = container "Model Shards" "Model loading and GPU inference via PyTorch; one or more shards with NCCL tensor parallelism" "Python Service"
            customKernels = container "Custom CUDA Kernels" "Optimized CUDA kernels for flash attention and GPTQ quantization" "Python/CUDA Extension"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Serverless ML inference platform that deploys TGIS as a runtime backend" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage (PVC)" "Persistent storage for pre-downloaded model weights" "Infrastructure"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "Infrastructure"
        otlpCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "Infrastructure"
        pytorch = softwareSystem "PyTorch + CUDA" "Deep learning framework and GPU compute runtime" "External"
        nccl = softwareSystem "NCCL" "NVIDIA collective communications for multi-GPU tensor parallelism" "External"

        // System-level relationships
        client -> kserve "Sends inference requests"
        kserve -> tgis "Deploys and sends gRPC requests" "gRPC/8033 TLS optional"
        tgis -> modelStorage "Loads model weights at startup" "Filesystem mount"
        tgis -> pytorch "Uses for GPU inference" "In-process"
        tgis -> nccl "Uses for tensor parallel AllReduce" "TCP/29500"
        prometheus -> tgis "Scrapes metrics" "HTTP/3000"
        tgis -> otlpCollector "Exports traces (optional)" "gRPC OTLP"

        // Container-level relationships
        launcher -> router "Starts and manages"
        launcher -> modelShards "Starts and manages"
        router -> modelShards "gRPC inference requests" "UDS (Unix Domain Socket)"
        modelShards -> customKernels "Uses optimized kernels"
        kserve -> router "gRPC inference requests" "8033/TCP TLS optional mTLS optional"
        prometheus -> router "HTTP metrics scrape" "3000/TCP"
        modelStorage -> modelShards "Volume mount" "/shared_model_storage"
    }

    views {
        systemContext tgis "SystemContext" {
            include *
            autoLayout
        }

        container tgis "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
