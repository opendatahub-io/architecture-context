graph TD
    subgraph "Service Accounts"
        SA[notebook-controller-service-account<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding<br/>Scope: Cluster-wide]
        CRB2[notebook-controller-proxy-rolebinding<br/>Scope: Cluster-wide]
    end

    subgraph "Role Bindings"
        RB1[notebook-controller-leader-election-rolebinding<br/>Scope: opendatahub namespace]
    end

    subgraph "ClusterRoles"
        CR1[notebook-controller-role<br/>Main Controller Permissions]
        CR2[notebook-controller-proxy-role<br/>Metrics Proxy Permissions]
    end

    subgraph "Roles"
        R1[notebook-controller-leader-election-role<br/>Leader Election ConfigMap Access]
    end

    subgraph "Core API Resources"
        Pods[pods<br/>API Group: core]
        Services[services<br/>API Group: core]
        Events[events<br/>API Group: core]
    end

    subgraph "Apps API Resources"
        StatefulSets[statefulsets<br/>API Group: apps]
    end

    subgraph "Kubeflow API Resources"
        Notebooks[notebooks<br/>API Group: kubeflow.org]
        NotebooksStatus[notebooks/status<br/>API Group: kubeflow.org]
        NotebooksFinalizers[notebooks/finalizers<br/>API Group: kubeflow.org]
    end

    subgraph "Istio API Resources"
        VirtualServices[virtualservices<br/>API Group: networking.istio.io]
    end

    subgraph "RBAC API Resources"
        TokenReviews[tokenreviews<br/>API Group: authentication.k8s.io]
        SubjectAccessReviews[subjectaccessreviews<br/>API Group: authorization.k8s.io]
    end

    subgraph "Leader Election Resources"
        ConfigMaps[configmaps<br/>API Group: core<br/>Namespace: opendatahub]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% ClusterRole notebook-controller-role Permissions
    CR1 -->|"get, list, watch, delete"| Pods
    CR1 -->|"* (all verbs)"| Services
    CR1 -->|"get, list, watch, create, patch"| Events
    CR1 -->|"* (all verbs)"| StatefulSets
    CR1 -->|"* (all verbs)"| Notebooks
    CR1 -->|"* (all verbs)"| NotebooksStatus
    CR1 -->|"* (all verbs)"| NotebooksFinalizers
    CR1 -->|"* (all verbs)"| VirtualServices

    %% ClusterRole notebook-controller-proxy-role Permissions
    CR2 -->|create| TokenReviews
    CR2 -->|create| SubjectAccessReviews

    %% Role notebook-controller-leader-election-role Permissions
    R1 -->|"get, create, update"| ConfigMaps

    %% Styling
    style SA fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,color:#000,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,color:#000,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,color:#000,stroke:#333,stroke-width:2px
    style CRB1 fill:#dae8fc,color:#000,stroke:#333,stroke-width:1px
    style CRB2 fill:#dae8fc,color:#000,stroke:#333,stroke-width:1px
    style RB1 fill:#dae8fc,color:#000,stroke:#333,stroke-width:1px

    style Pods fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style Services fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style Events fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style StatefulSets fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style Notebooks fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style NotebooksStatus fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style NotebooksFinalizers fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style VirtualServices fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style TokenReviews fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style SubjectAccessReviews fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
    style ConfigMaps fill:#7ed321,color:#000,stroke:#333,stroke-width:1px
