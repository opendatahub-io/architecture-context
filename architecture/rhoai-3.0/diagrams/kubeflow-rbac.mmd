graph TD
    subgraph "Service Account"
        SA[notebook-controller-service-account<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding<br/>ClusterRoleBinding]
        CRB2[notebook-controller-proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB1[notebook-controller-leader-election-rolebinding<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRoles"
        CR1[notebook-controller-role<br/>ClusterRole]
        CR2[notebook-controller-proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        R1[notebook-controller-leader-election-role<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph "API Resources - ClusterRole: notebook-controller-role"
        direction TB

        subgraph "Core Resources"
            Pods["pods<br/>get, list, watch, delete"]
            Services["services<br/>* (all verbs)"]
            Events["events<br/>get, list, watch, create, patch"]
        end

        subgraph "Apps Resources"
            StatefulSets["statefulsets<br/>* (all verbs)"]
        end

        subgraph "Kubeflow Resources"
            Notebooks["notebooks<br/>* (all verbs)"]
            NotebooksStatus["notebooks/status<br/>* (all verbs)"]
            NotebooksFinalizers["notebooks/finalizers<br/>* (all verbs)"]
        end

        subgraph "Istio Resources"
            VirtualServices["virtualservices<br/>networking.istio.io<br/>* (all verbs)"]
        end
    end

    subgraph "API Resources - ClusterRole: notebook-controller-proxy-role"
        TokenReviews["tokenreviews<br/>authentication.k8s.io<br/>create"]
        SubjectAccessReviews["subjectaccessreviews<br/>authorization.k8s.io<br/>create"]
    end

    subgraph "API Resources - Role: notebook-controller-leader-election-role"
        ConfigMaps["configmaps<br/>get, list, watch, create, update, patch, delete"]
        Leases["leases<br/>coordination.k8s.io<br/>get, list, watch, create, update, patch, delete"]
        EventsLocal["events<br/>create, patch"]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% ClusterRole bindings
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% Role bindings
    RB1 -->|grants| R1

    %% ClusterRole permissions
    CR1 -->|permissions| Pods
    CR1 -->|permissions| Services
    CR1 -->|permissions| Events
    CR1 -->|permissions| StatefulSets
    CR1 -->|permissions| Notebooks
    CR1 -->|permissions| NotebooksStatus
    CR1 -->|permissions| NotebooksFinalizers
    CR1 -->|permissions| VirtualServices

    CR2 -->|permissions| TokenReviews
    CR2 -->|permissions| SubjectAccessReviews

    %% Role permissions
    R1 -->|permissions| ConfigMaps
    R1 -->|permissions| Leases
    R1 -->|permissions| EventsLocal

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CRB1 fill:#7ed321,stroke:#333,color:#fff
    style CRB2 fill:#7ed321,stroke:#333,color:#fff
    style RB1 fill:#7ed321,stroke:#333,color:#fff

    style Pods fill:#d5e8d4,stroke:#82b366,color:#333
    style Services fill:#d5e8d4,stroke:#82b366,color:#333
    style Events fill:#d5e8d4,stroke:#82b366,color:#333
    style StatefulSets fill:#d5e8d4,stroke:#82b366,color:#333
    style Notebooks fill:#d5e8d4,stroke:#82b366,color:#333
    style NotebooksStatus fill:#d5e8d4,stroke:#82b366,color:#333
    style NotebooksFinalizers fill:#d5e8d4,stroke:#82b366,color:#333
    style VirtualServices fill:#d5e8d4,stroke:#82b366,color:#333
    style TokenReviews fill:#d5e8d4,stroke:#82b366,color:#333
    style SubjectAccessReviews fill:#d5e8d4,stroke:#82b366,color:#333
    style ConfigMaps fill:#d5e8d4,stroke:#82b366,color:#333
    style Leases fill:#d5e8d4,stroke:#82b366,color:#333
    style EventsLocal fill:#d5e8d4,stroke:#82b366,color:#333
