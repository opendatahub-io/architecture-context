graph TB
    subgraph External["EXTERNAL SERVICES"]
        NGC["Nvidia NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key Auth"]
        MR["Model Registry (Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+ (skip verify: config)<br/>Bearer Token"]
    end

    subgraph Cluster["KUBERNETES CLUSTER"]
        subgraph Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>Scrapes metrics"]
        end

        subgraph ODH["Namespace: opendatahub"]
            subgraph Controller["odh-model-controller Pod<br/>SA: odh-model-controller<br/>User: 2000 (non-root)<br/>FIPS Compliant"]
                MainController["Main Controller<br/>Reconcilers"]
                WebhookServer["Webhook Server<br/>9443/TCP<br/>HTTPS TLS 1.2+<br/>Cert: Service CA"]
                MetricsServer["Metrics Server<br/>8080/TCP<br/>HTTP (TODO: HTTPS)<br/>Bearer Token"]
                HealthServer["Health Server<br/>8081/TCP<br/>HTTP<br/>No Auth"]

                MainController -->|in-process| WebhookServer
                MainController -->|in-process| MetricsServer
                MainController -->|in-process| HealthServer
            end

            WebhookSvc["Service:<br/>odh-model-controller-webhook-service<br/>ClusterIP<br/>443/TCP → 9443/TCP"]
            MetricsSvc["Service:<br/>odh-model-controller-metrics-service<br/>ClusterIP<br/>8080/TCP → 8080/TCP"]

            WebhookSvc -->|routes to| WebhookServer
            MetricsSvc -->|routes to| MetricsServer
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token Auth"]
        TemplateAPI["OpenShift Template API<br/>443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        ServiceCA["OpenShift Service CA<br/>Provides webhook cert<br/>Auto-rotates"]
    end

    %% External connections
    MainController -->|Validate NIM<br/>HTTPS/443<br/>TLS 1.2+<br/>API Key| NGC
    MainController -.->|Register models<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Optional| MR

    %% Internal API connections
    MainController -->|Watch/Reconcile<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    MainController -->|Process templates<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| TemplateAPI
    K8sAPI -->|Validate/Mutate<br/>HTTPS/443 → 9443<br/>TLS 1.2+<br/>TLS Client Cert| WebhookSvc

    %% Monitoring
    Prometheus -->|Scrape /metrics<br/>HTTP/8080<br/>Bearer Token| MetricsSvc

    %% Certificate provisioning
    ServiceCA -.->|Provisions cert<br/>odh-model-controller-webhook-cert<br/>kubernetes.io/tls<br/>Auto-rotate| WebhookServer

    subgraph Resources["Resources Managed by Controller"]
        direction LR
        CRDs["CRDs:<br/>InferenceService<br/>ServingRuntime<br/>LLMInferenceService<br/>InferenceGraph<br/>NIM Account"]
        OpenShiftRes["OpenShift:<br/>Routes<br/>Templates"]
        K8sRes["K8s Resources:<br/>NetworkPolicies<br/>RBAC<br/>Secrets<br/>ConfigMaps"]
        MonRes["Monitoring:<br/>ServiceMonitors<br/>PodMonitors"]
        MeshRes["Service Mesh:<br/>EnvoyFilters<br/>AuthPolicies<br/>HTTPRoutes"]
        KEDARes["KEDA:<br/>TriggerAuthentications"]
    end

    MainController -->|creates/updates| CRDs
    MainController -->|creates/updates| OpenShiftRes
    MainController -->|creates/updates| K8sRes
    MainController -->|creates/updates| MonRes
    MainController -->|creates/updates| MeshRes
    MainController -->|creates/updates| KEDARes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:3px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef api fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef resources fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class NGC,MR external
    class MainController,WebhookServer,MetricsServer,HealthServer controller
    class WebhookSvc,MetricsSvc service
    class K8sAPI,TemplateAPI,ServiceCA api
    class Prometheus monitoring
    class CRDs,OpenShiftRes,K8sRes,MonRes,MeshRes,KEDARes resources
