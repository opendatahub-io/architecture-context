graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/System]
        Prom[Prometheus]
    end

    subgraph K8sBoundary["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer Token, TLS certs<br/>AuthZ: RBAC"]
    end

    subgraph ControllerPod["CONTROLLER POD (opendatahub namespace)"]
        direction TB

        PodInfo["odh-model-controller<br/>SA: odh-model-controller<br/>User: 2000 (non-root)<br/>Image: ubi9/ubi-minimal FIPS"]

        subgraph Services["Internal Services"]
            Webhook["Webhook Server<br/>Port: 9443/TCP (internal)<br/>Service: webhook-service:443<br/>HTTPS TLS 1.2+<br/>TLS Cert: Service CA<br/><br/>Endpoints:<br/>POST /validate/*<br/>POST /mutate/*"]

            Metrics["Metrics Server<br/>Port: 8080/TCP (internal)<br/>Service: metrics-service:8080<br/>HTTP (TODO: HTTPS/8443)<br/>Auth: Bearer Token<br/><br/>Endpoint:<br/>GET /metrics"]

            Health["Health Probes<br/>Port: 8081/TCP (internal)<br/>HTTP No Auth<br/><br/>Endpoints:<br/>GET /healthz<br/>GET /readyz"]
        end
    end

    subgraph EgressTargets["EGRESS TARGETS"]
        K8sAPIEgress["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]

        NGC["Nvidia NGC API<br/>nvcr.io, api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API Key"]

        MR["Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+ (skip verify: configurable)<br/>Auth: Bearer Token"]

        TemplateAPI["OpenShift Template API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
    end

    subgraph CreatedResources["RESOURCES CREATED (User Namespaces)"]
        direction LR
        Routes["OpenShift Routes<br/>(external ingress)"]
        NetworkPolicies["NetworkPolicies<br/>(network isolation)"]
        Monitoring["ServiceMonitor<br/>PodMonitor"]
        RBAC["RBAC Resources<br/>(SA, Roles, RoleBindings)"]
        KEDA["KEDA TriggerAuth<br/>(autoscaling)"]
        Istio["Istio EnvoyFilter<br/>(SSL passthrough)"]
        Kuadrant["Kuadrant AuthPolicy<br/>(auth/authz)"]
        GatewayHTTP["Gateway HTTPRoute<br/>(Gateway API routing)"]
        Secrets["Image Pull Secrets<br/>Runtime Templates"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    Prom -->|HTTP/8080<br/>Bearer Token| Metrics

    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>TLS client cert| Webhook
    K8sAPI -.->|Watch events| PodInfo

    PodInfo -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPIEgress
    PodInfo -->|HTTPS/443<br/>TLS 1.2+<br/>API Key| NGC
    PodInfo -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| MR
    PodInfo -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| TemplateAPI

    PodInfo -.->|creates via K8s API| Routes
    PodInfo -.->|creates via K8s API| NetworkPolicies
    PodInfo -.->|creates via K8s API| Monitoring
    PodInfo -.->|creates via K8s API| RBAC
    PodInfo -.->|creates via K8s API| KEDA
    PodInfo -.->|creates via K8s API| Istio
    PodInfo -.->|creates via K8s API| Kuadrant
    PodInfo -.->|creates via K8s API| GatewayHTTP
    PodInfo -.->|creates via K8s API| Secrets

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef boundary fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef resources fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,Prom external
    class K8sAPI boundary
    class PodInfo,Webhook,Metrics,Health controller
    class K8sAPIEgress,NGC,MR,TemplateAPI egress
    class Routes,NetworkPolicies,Monitoring,RBAC,KEDA,Istio,Kuadrant,GatewayHTTP,Secrets resources

    %% Annotations
    style ControllerPod fill:#d5e8d4,stroke:#82b366,stroke-width:3px,stroke-dasharray: 5 5
    style Services fill:#c8e6c9,stroke:#66bb6a,stroke-width:2px
    style CreatedResources fill:#f3e5f5,stroke:#ab47bc,stroke-width:2px
    style EgressTargets fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
