    %% Inference Provider Dependencies - Required (one of)
    LlamaOperator -->|"ollama distribution<br/>required"| Ollama[Ollama Server]
    LlamaOperator -->|"vllm distribution<br/>required"| vLLM[vLLM Server]
    LlamaOperator -->|"tgi distribution<br/>required"| TGI[TGI Server]
    LlamaOperator -->|"bedrock distribution<br/>required"| Bedrock[AWS Bedrock]
    LlamaOperator -->|"together distribution<br/>required"| Together[Together AI]

    %% External Services
    LlamaOperator -->|"image storage<br/>runtime"| Registry[Container Registry<br/>quay.io]
    LlamaOperator -->|"model downloads<br/>runtime"| HF[HuggingFace Hub]

    %% Internal ODH Dependencies - None
    %% (This operator is standalone)

    %% API Server Integration
    K8s -->|provides| K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
    LlamaOperator -->|"watches/manages<br/>CRDs & resources"| K8sAPI

