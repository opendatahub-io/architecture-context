graph LR
    LlamaStackOp[Llama Stack K8s Operator<br/>v0.4.0]

    %% External Dependencies (Required)
    LlamaStackOp -->|container orchestration| K8s[Kubernetes 1.20+]
    LlamaStackOp -->|operator framework| ControllerRuntime[controller-runtime v0.20+]
    LlamaStackOp -->|manifest templating| Kustomize[Kustomize<br/>embedded]
    LlamaStackOp -->|backend inference| InferenceProvider[Inference Provider<br/>Ollama/vLLM/TGI/etc]

    %% External Dependencies (Optional)
    LlamaStackOp -.->|metrics collection| PrometheusOp[Prometheus Operator]
    LlamaStackOp -.->|security constraints| OpenShiftSCC[OpenShift SCC]

    %% External Services
    LlamaStackOp -->|pull images| ContainerReg[Container Registry<br/>quay.io]
    LlamaStackOp -.->|download models| HuggingFace[HuggingFace Hub]

    %% Specific Inference Providers
    subgraph InferenceBackends["Inference Backends"]
        Ollama[Ollama Server<br/>11434/TCP HTTP]
        vLLM[vLLM Server<br/>8000/TCP HTTP]
        TGI[TGI Server<br/>8080/TCP HTTP]
        Bedrock[AWS Bedrock]
        Together[Together AI]
    end

    InferenceProvider -->|distribution: ollama| Ollama
    InferenceProvider -->|distribution: vllm/remote-vllm| vLLM
    InferenceProvider -->|distribution: tgi| TGI
    InferenceProvider -->|distribution: bedrock| Bedrock
    InferenceProvider -->|distribution: together| Together

    %% Managed Resources
    subgraph ManagedPerCR["Managed Resources (per LlamaStackDistribution)"]
        ServiceAccount[ServiceAccount]
        RoleBinding[RoleBinding]
        PVC[PersistentVolumeClaim]
        Deployment[Deployment]
        Service[Service]
        NetworkPolicy[NetworkPolicy]
    end

    LlamaStackOp -->|creates & manages| ManagedPerCR

    %% Internal Dependencies
    subgraph InternalComponents["Internal Components"]
        DistController[Distribution Controller]
        KustomizeTransform[Kustomize Transformer]
        DistResolver[Distribution Resolver]
        NetworkMgr[Network Policy Manager]
        StorageProv[Storage Provisioner]
    end

    LlamaStackOp -->|contains| InternalComponents

    %% Observability
    subgraph Observability["Observability"]
        Prometheus[Prometheus]
        MetricsProxy[kube-rbac-proxy<br/>8443/TCP]
    end

    LlamaStackOp -->|exposes via| MetricsProxy
    Prometheus -.->|scrapes| MetricsProxy

    %% Kubernetes API
    LlamaStackOp -->|API calls| K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
    K8s -->|provides| K8sAPI

    %% Styling
    style LlamaStackOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies (Required)
    style K8s fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Kustomize fill:#999,stroke:#333,color:#fff
    style InferenceProvider fill:#999,stroke:#333,color:#fff

    %% External Dependencies (Optional)
    style PrometheusOp fill:#ccc,stroke:#333,color:#333
    style OpenShiftSCC fill:#ccc,stroke:#333,color:#333

    %% External Services
    style ContainerReg fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff

    %% Inference Backends
    style Ollama fill:#e8e8e8,stroke:#333,color:#333
    style vLLM fill:#e8e8e8,stroke:#333,color:#333
    style TGI fill:#e8e8e8,stroke:#333,color:#333
    style Bedrock fill:#e8e8e8,stroke:#333,color:#333
    style Together fill:#e8e8e8,stroke:#333,color:#333

    %% Managed Resources
    style ServiceAccount fill:#7ed321,stroke:#333,color:#fff
    style RoleBinding fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#7ed321,stroke:#333,color:#fff
    style Deployment fill:#7ed321,stroke:#333,color:#fff
    style Service fill:#7ed321,stroke:#333,color:#fff
    style NetworkPolicy fill:#7ed321,stroke:#333,color:#fff

    %% Observability
    style Prometheus fill:#e8e8e8,stroke:#333,color:#333
    style MetricsProxy fill:#7ed321,stroke:#333,color:#fff

    %% Kubernetes API
    style K8sAPI fill:#999,stroke:#333,color:#fff
