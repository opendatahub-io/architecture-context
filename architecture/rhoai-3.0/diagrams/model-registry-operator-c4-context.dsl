/*
 * Model Registry Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/model-registry-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates ModelRegistry CRs, accesses model registry and catalog APIs"
        admin = person "Platform Admin" "Deploys and configures RHOAI platform, manages operator lifecycle"

        modelRegistryOperator = softwareSystem "Model Registry Operator" "Manages lifecycle of Model Registry instances and Model Catalog service for ML model metadata management" {
            operatorManager = container "Operator Manager" "Main entry point; controller-runtime manager with leader election, health/readiness probes, metrics, webhook server" "Go Binary"
            mrReconciler = container "ModelRegistryReconciler" "Reconciles ModelRegistry CRs; creates Deployments, Services, Routes, NetworkPolicies, RBAC resources per registry instance" "Go Controller"
            mcReconciler = container "ModelCatalogReconciler" "Manages singleton Model Catalog service with Deployment, Service, Route, ConfigMaps, PostgreSQL" "Go Controller"
            storageMigration = container "StorageMigrationManager" "Performs CRD storage version migration from v1alpha1 to v1beta1" "Go Background Task"
            admissionWebhooks = container "Admission Webhooks" "Mutating (OAuth→kube-rbac-proxy migration, route defaults) and Validating (DB config, namespace, unique names) webhooks" "Mutating/Validating Webhook"
        }

        managedRegistry = softwareSystem "Model Registry Instance" "REST API + gRPC metadata server + kube-rbac-proxy for ML model metadata management" {
            restContainer = container "REST Container" "Model Registry REST API serving model metadata operations" "model-registry image, 8080/TCP"
            grpcServer = container "MLMD gRPC Server" "ML Metadata gRPC server for metadata storage operations" "mlmd-grpc-server image"
            kubeRbacProxy = container "kube-rbac-proxy" "Authentication proxy enforcing SubjectAccessReview for API access" "kube-rbac-proxy image, 8443/TCP"
        }

        managedCatalog = softwareSystem "Model Catalog" "Curated catalog of ML models with metadata collection, benchmarks, and configurable catalog sources" {
            catalogContainer = container "Catalog Container" "Model Catalog REST API with catalog sources and benchmark data" "model-catalog image, 8080/TCP"
            catalogProxy = container "kube-rbac-proxy (Catalog)" "Authentication proxy for catalog API" "kube-rbac-proxy image, 8443/TCP"
        }

        # External Systems
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys Model Registry Operator via kustomize overlays with image parameter injection" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource CRUD, webhook calls, auth delegation" "Infrastructure"
        openshiftRouter = softwareSystem "OpenShift Router / Ingress" "Exposes services externally via Routes with TLS reencrypt" "Infrastructure"
        postgresql = softwareSystem "PostgreSQL" "Backend database for model metadata storage (auto-provisioned or external)" "External Database"
        mysql = softwareSystem "MySQL" "Alternative backend database for model metadata storage" "External Database"
        openshiftPlatform = softwareSystem "OpenShift Platform" "Provides serving certs, ingress domain config, user groups" "Infrastructure"
        platformCR = softwareSystem "Platform ModelRegistry CR" "components.platform.opendatahub.io ModelRegistry CR for catalog owner reference" "Internal RHOAI"

        # Relationships - Users
        user -> managedRegistry "Accesses model registry REST API" "HTTPS/443 via Route"
        user -> managedCatalog "Browses model catalog" "HTTPS/443 via Route"
        admin -> modelRegistryOperator "Creates ModelRegistry CRs via kubectl" "HTTPS/443"

        # Relationships - Operator
        rhodsOperator -> modelRegistryOperator "Deploys via kustomize overlays/odh" "kustomize"
        modelRegistryOperator -> k8sAPI "CRUD on managed resources, watch CRs" "HTTPS/443"
        modelRegistryOperator -> managedRegistry "Creates and manages" "Kubernetes API"
        modelRegistryOperator -> managedCatalog "Creates and manages" "Kubernetes API"
        modelRegistryOperator -> openshiftPlatform "Reads ingress domain, provisions serving certs" "HTTPS/443"
        modelRegistryOperator -> platformCR "Reads default-modelregistry CR for owner reference" "HTTPS/443"

        # Relationships - Managed Registry
        kubeRbacProxy -> k8sAPI "TokenReview, SubjectAccessReview" "HTTPS/443"
        kubeRbacProxy -> restContainer "Proxies authenticated requests" "HTTP/8080 localhost"
        restContainer -> grpcServer "Metadata operations" "gRPC"
        restContainer -> postgresql "Model metadata storage" "PostgreSQL/5432"
        restContainer -> mysql "Alternative metadata storage" "MySQL/3306"
        openshiftRouter -> kubeRbacProxy "Routes external traffic" "HTTPS/8443 reencrypt"

        # Relationships - Managed Catalog
        catalogProxy -> k8sAPI "TokenReview, SubjectAccessReview" "HTTPS/443"
        catalogProxy -> catalogContainer "Proxies authenticated requests" "HTTP/8080 localhost"
        catalogContainer -> postgresql "Catalog data storage" "PostgreSQL/5432"
        openshiftRouter -> catalogProxy "Routes external traffic" "HTTPS/8443 reencrypt"

        # Relationships - K8s API to Operator
        k8sAPI -> admissionWebhooks "Webhook calls for ModelRegistry CRs" "HTTPS/9443 mTLS"
    }

    views {
        systemContext modelRegistryOperator "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistryOperator "OperatorContainers" {
            include *
            autoLayout
        }

        container managedRegistry "RegistryContainers" {
            include *
            autoLayout
        }

        container managedCatalog "CatalogContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "External Database" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
