graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client / Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Gateway["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+/1.3<br/>RequestAuthentication<br/>(JWT validation if present)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>Edge/Reencrypt TLS<br/>Host: {isvc}-{ns}.apps.{cluster}"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Port: 8012/TCP<br/>PeerAuth: STRICT mTLS"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            subgraph PredictorPod["Predictor Pod"]
                direction LR
                StorageInit["storage-initializer<br/>(init container)<br/>Downloads model"]
                KServeContainer["kserve-container<br/>(main)<br/>Model Server<br/>8080/TCP HTTP"]
                KServeAgent["kserve-agent<br/>(sidecar)<br/>Lifecycle mgmt"]
                IstioProxy["istio-proxy<br/>(sidecar)<br/>mTLS enforcement"]
            end

            PredictorSA["ServiceAccount:<br/>{isvc-name}-sa"]
            PredictorService["Service:<br/>{isvc-name}-predictor<br/>80/TCP → 8080/TCP"]

            Router["InferenceGraph Router<br/>8080/TCP HTTP<br/>mTLS"]
        end

        subgraph NS_KServe["Namespace: kserve"]
            Controller["KServe Controller<br/>SA: kserve-controller-manager<br/>ClusterRole: kserve-manager-role"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS 1.2+<br/>cert-manager issued cert"]
            ControllerMetrics["Metrics Endpoint<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Bearer Token"]
            ControllerHealth["Health Endpoint<br/>8081/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS SigV4 / Access Key"]
        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Azure Storage Key"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token (optional)"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token JWT"]
        CertManager["cert-manager<br/>Certificate CRD<br/>TLS cert issuance"]
    end

    subgraph IntegrationPoints["INTEGRATION POINTS"]
        direction TB
        Knative["Knative Serving<br/>CRD: Service<br/>Serverless autoscaling"]
        Istio["Istio Control Plane<br/>CRD: VirtualService, DestinationRule<br/>Traffic routing"]
        Authorino["Authorino<br/>AuthorizationPolicy<br/>JWT validation"]
        Prometheus["Prometheus<br/>8080/TCP, 8443/TCP<br/>Metrics scraping"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP TLS 1.2+<br/>Metadata/Versioning"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+/1.3<br/>Bearer Token/API Key"| Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Route

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/8012<br/>mTLS STRICT<br/>Service Identity"| Activator
    Route -->|"HTTP/8080<br/>mTLS (if enabled)"| PredictorService

    %% Service Mesh Internal
    Activator -->|"HTTP/80<br/>mTLS STRICT"| PredictorService
    PredictorService -->|"HTTP/8080<br/>mTLS"| KServeContainer

    Router -->|"HTTP/80<br/>mTLS"| PredictorService

    %% Storage Initializer to External
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4/Key"| S3
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA JSON"| GCS
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Key"| Azure
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Controller to K8s API
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token JWT"| K8sAPI
    Webhook -->|"Invoked by<br/>API Server<br/>mTLS"| K8sAPI

    %% K8s API to Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>API Server mTLS"| Webhook

    %% Controller interactions
    Controller -->|"Creates CRDs"| Knative
    Controller -->|"Creates CRDs"| Istio
    Controller -->|"Certificate CR"| CertManager

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No Auth"| KServeContainer
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| ControllerMetrics

    %% Integration
    KServeContainer -.->|"Optional<br/>HTTP API<br/>TLS 1.2+"| ModelRegistry
    Gateway -.->|"Optional<br/>JWT Validation"| Authorino

    %% Secrets
    CertManager -->|"Issues TLS cert"| WebhookSecret["Secret:<br/>kserve-webhook-server-cert<br/>(kubernetes.io/tls)<br/>Auto-rotate: Yes"]
    WebhookSecret -.->|"Mounts to"| Webhook

    StorageSecret["Secret:<br/>storage-config<br/>(Opaque)<br/>S3/GCS/Azure/HF creds<br/>Auto-rotate: No"]
    StorageSecret -.->|"Mounted by"| StorageInit

    SAToken["Secret:<br/>{isvc-name}-sa-token<br/>(kubernetes.io/service-account-token)<br/>Auto-rotate: Yes"]
    SAToken -.->|"Mounted by"| KServeContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,Route ingress
    class Activator,PredictorPod,PredictorService,Router,Controller,Webhook,ControllerMetrics,ControllerHealth,PredictorSA,StorageInit,KServeContainer,KServeAgent,IstioProxy servicemesh
    class S3,GCS,Azure,HFHub externalservice
    class K8sAPI,CertManager controlplane
    class Knative,Istio,Authorino,Prometheus,ModelRegistry integration
    class WebhookSecret,StorageSecret,SAToken secret
