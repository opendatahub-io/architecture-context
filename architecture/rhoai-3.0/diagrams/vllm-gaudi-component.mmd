%% Component Structure Diagram for vLLM Gaudi
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "vLLM Gaudi Runtime"
        subgraph "API Layer"
            OpenAIServer["OpenAI API Server<br/>(FastAPI/Uvicorn)<br/>Port 8000/TCP"]
            TGISAdapter["TGIS gRPC Adapter<br/>(vllm-tgis-adapter)<br/>Port 8033/TCP"]
            Metrics["Prometheus Metrics<br/>/metrics endpoint"]
            SSLRefresher["SSL Certificate<br/>Refresher"]
            OTel["OpenTelemetry<br/>Tracing"]
        end

        subgraph "Engine Layer"
            AsyncEngine["Async LLM Engine<br/>(ZMQ IPC)"]
            CLI["vLLM CLI"]
        end

        subgraph "HPU Execution Layer"
            HPUWorker["HPU Worker"]
            HPUModelRunner["HPU Model Runner"]
            HPUPoolingRunner["HPU Pooling<br/>Model Runner"]
            HPUEncDecRunner["HPU Encoder-Decoder<br/>Model Runner"]
            MultiStepWorker["Multi-Step HPU<br/>Worker (Speculative)"]
        end
    end

    %% Internal flows
    OpenAIServer -->|"HTTP requests"| AsyncEngine
    TGISAdapter -->|"gRPC→HTTP proxy<br/>localhost:8000"| OpenAIServer
    AsyncEngine -->|"scheduling &<br/>batching"| HPUWorker
    HPUWorker --> HPUModelRunner
    HPUWorker --> HPUPoolingRunner
    HPUWorker --> HPUEncDecRunner
    HPUWorker --> MultiStepWorker
    OpenAIServer --- Metrics
    OpenAIServer --- SSLRefresher
    OpenAIServer --- OTel

    %% External interactions
    Client["Client / KServe Router"] -->|"POST /v1/chat/completions<br/>HTTP/HTTPS"| OpenAIServer
    TGISClient["KServe / TGIS Client"] -->|"gRPC<br/>GenerationService"| TGISAdapter

    HPUWorker -->|"PCIe/Device"| GaudiHPU["Intel Gaudi 2/3<br/>HPU Accelerator"]
    HPUWorker -.->|"Ray distributed<br/>6379/TCP"| RayCluster["Ray Cluster<br/>(Multi-HPU)"]

    %% Dependencies
    OpenAIServer -->|"model loading<br/>HTTPS/443"| HFHub["HuggingFace Hub /<br/>Model Storage"]
    OTel -.->|"gRPC/4317"| OTelCollector["OpenTelemetry<br/>Collector"]
    Prometheus["Prometheus"] -->|"HTTP scrape<br/>8000/TCP"| Metrics

    KServe["KServe<br/>InferenceService"] -->|"manages"| OpenAIServer
    KServe -->|"manages"| TGISAdapter

