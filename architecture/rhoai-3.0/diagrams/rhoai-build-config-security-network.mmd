%% Security Network Diagram - RHOAI Build Config
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Dev["Developer / CI Trigger"]
        RenovateBot["Renovate / Dependabot<br/>Automated Digest Updates"]
    end

    subgraph CICD["CI/CD LAYER (GitHub + Konflux)"]
        direction TB

        subgraph GitHub["GitHub Repository"]
            Repo["rhoai-3.0 branch<br/>bundle/, catalog/, config/"]
            GHA["GitHub Actions<br/>process-operator-bundle"]
        end

        subgraph KonfluxPlatform["Konflux Platform"]
            PAC["PipelinesAsCode<br/>Webhook Receiver"]
            Tekton["Tekton PipelineRun<br/>Auth: git_auth_secret"]
            EC["Enterprise Contract<br/>Cosign Verification<br/>Policy: openshift-pipelines/public-key"]
        end
    end

    subgraph Registries["CONTAINER REGISTRIES"]
        Quay["quay.io<br/>Staging Registry<br/>443/TCP HTTPS TLS 1.2+"]
        RHIO["registry.redhat.io<br/>Production Registry<br/>443/TCP HTTPS TLS 1.2+"]
        Brew["brew.registry.redhat.io<br/>Base Images<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph TargetCluster["TARGET CLUSTER (OCP v4.19/v4.20)"]
        direction TB

        subgraph OLMNamespace["OLM"]
            OLM["Operator Lifecycle Manager<br/>Bundle Unpacking"]
        end

        subgraph OperatorNS["Namespace: redhat-ods-operator"]
            Operator["rhods-operator<br/>SA: redhat-ods-operator-controller-manager<br/>Replicas: 3"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Auth: Bearer Token"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>plaintext"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    %% External flows
    Dev -->|"HTTPS/443<br/>TLS 1.2+<br/>GitHub Token"| Repo
    RenovateBot -->|"HTTPS/443<br/>TLS 1.2+<br/>GitHub Token"| Repo

    %% CI/CD flows
    Repo -->|"Webhook<br/>HTTPS/443<br/>Webhook Secret"| PAC
    Repo --> GHA
    GHA -->|"Patches CSV<br/>HTTPS/443<br/>GitHub Token"| Repo
    PAC -->|"Triggers"| Tekton
    Tekton -->|"git clone<br/>HTTPS/443<br/>git_auth_secret"| Repo
    Tekton -->|"Validates"| EC

    %% Registry flows
    Tekton -->|"Push images<br/>HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| Quay
    EC -->|"Cosign verify<br/>HTTPS/443<br/>TLS 1.2+<br/>Public key"| Quay
    Quay -->|"Mirror/Promote<br/>HTTPS/443<br/>Registry creds"| RHIO
    Brew -->|"Base images<br/>HTTPS/443"| Tekton

    %% Target cluster flows
    RHIO -->|"Pull bundle<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| OLM
    OLM -->|"Install CSV+CRDs"| Operator
    Operator --> MetricsSvc
    Operator --> HealthProbe
    Operator -->|"Reconciliation<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cicd fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef registry fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Dev,RenovateBot external
    class Repo,GHA,PAC,Tekton cicd
    class EC security
    class Quay,RHIO,Brew registry
    class OLM,Operator,MetricsSvc,HealthProbe,K8sAPI cluster
