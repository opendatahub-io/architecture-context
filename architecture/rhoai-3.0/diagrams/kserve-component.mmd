%% KServe Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.0/kserve.md

graph TB
    subgraph KServeOperator["KServe Operator (kserve namespace)"]
        Controller["kserve-controller-manager<br/>Go Operator (controller-runtime)<br/>Ports: 8080/metrics, 8081/health, 9443/webhooks"]
        Webhook["Webhook Server<br/>Mutating + Validating<br/>Port: 9443/TCP TLS"]
        Controller -->|validates/mutates via| Webhook
    end

    subgraph InferenceWorkloads["Inference Workloads (user namespace)"]
        direction TB
        StorageInit["kserve-storage-initializer<br/>Init Container<br/>Downloads model artifacts"]
        Agent["kserve-agent<br/>Sidecar Container<br/>Multi-model config, logging, batching"]
        KubeRBACProxy["kube-rbac-proxy<br/>Sidecar Container<br/>Port: 8443/TCP HTTPS<br/>TokenReview/SubjectAccessReview"]
        Predictor["Predictor Container<br/>Port: 8080/TCP HTTP"]
        Router["kserve-router<br/>InferenceGraph routing<br/>Authorization header propagation"]
    end

    subgraph LLMWorkloads["LLM Workloads (user namespace)"]
        direction TB
        Scheduler["llm-d inference-scheduler<br/>ext_proc gRPC scheduler<br/>Port: 9002/TCP gRPC TLS"]
        RoutingSidecar["llm-d routing-sidecar<br/>NIXL-based sidecar<br/>Disaggregated prefill/decode"]
        VLLMContainer["vLLM Container<br/>Port: 8001/TCP HTTPS"]
    end

    %% CRDs
    User[Data Scientist / Client] -->|creates| ISVC[InferenceService CR<br/>serving.kserve.io/v1beta1]
    User -->|creates| LLMISVC[LLMInferenceService CR<br/>serving.kserve.io/v1alpha1]
    User -->|creates| ServingRT[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
    User -->|creates| TrainedModel[TrainedModel CR<br/>serving.kserve.io/v1beta1]
    User -->|creates| InfGraph[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]

    ISVC -->|watched by| Controller
    LLMISVC -->|watched by| Controller
    ServingRT -->|watched by| Controller
    TrainedModel -->|watched by| Controller
    InfGraph -->|watched by| Controller

    %% Resources created by controller
    Controller -->|creates| Deployment[Deployment]
    Controller -->|creates| Service[Service]
    Controller -->|creates| HTTPRoute[HTTPRoute]
    Controller -->|creates| VirtualService[VirtualService]
    Controller -->|creates| InferencePool[InferencePool]
    Controller -->|creates| InferenceModel[InferenceModel]
    Controller -->|creates| HPA[HPA / KEDA ScaledObject]
    Controller -->|creates| SelfSignedCerts[Self-signed TLS Certs]

    %% External dependencies
    Controller -->|traffic mgmt| Istio[Istio Service Mesh]
    Controller -->|ingress routing| GatewayAPI[Gateway API v1.2.1]
    Controller -->|inference routing| GAIE[Gateway API Inference Extension v0.3.0]
    Controller -->|autoscaling| KEDA[KEDA v2.16+]
    Controller -->|multi-node| LWS[LeaderWorkerSet v0.6.2]
    Controller -->|serverless| Knative[Knative Serving]

    %% Internal RHOAI
    RHODSOp[rhods-operator] -->|deploys via kustomize| Controller
    Controller -->|uses| CABundle[odh-kserve-custom-ca-bundle]
    Controller -->|cert injection| ServiceCA[OpenShift service-ca]

    %% Storage
    StorageInit -->|downloads from| S3[S3 / GCS / HF / OCI / PVC]

