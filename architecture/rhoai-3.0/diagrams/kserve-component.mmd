graph TB
    subgraph "KServe Platform"
        direction TB

        subgraph "Control Plane"
            Controller[KServe Controller Manager<br/>Go Operator]
            Webhook[Webhook Server<br/>9443/TCP HTTPS]
            Controller -->|validates/mutates| Webhook
        end

        subgraph "Data Plane - Inference Runtime"
            Agent[KServe Agent<br/>Go Sidecar]
            Router[KServe Router<br/>InferenceGraph Routing]
            StorageInit[Storage Initializer<br/>Python Init Container]
            LocalModelMgr[LocalModel Manager<br/>Go Service]
            LocalNodeAgent[LocalModelNode Agent<br/>Go DaemonSet]
        end

        subgraph "Model Servers"
            HFServer[HuggingFace Server<br/>LLMs & Transformers]
            SklearnServer[Sklearn Server<br/>8080/TCP HTTP]
            XGBoostServer[XGBoost Server<br/>8080/TCP HTTP]
            TorchServe[TorchServe<br/>PyTorch Models]
            TritonServer[Triton Server<br/>Multi-Framework]
        end
    end

    subgraph "User Resources"
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        InferenceGraphCR[InferenceGraph CR<br/>Multi-Model Pipeline]
        LLMInferenceServiceCR[LLMInferenceService CR<br/>serving.kserve.io/v1alpha1]
        TrainedModelCR[TrainedModel CR<br/>ModelMesh Mode]
    end

    subgraph "External Dependencies"
        Knative[Knative Serving<br/>Serverless Autoscaling]
        Istio[Istio Service Mesh<br/>mTLS & Traffic Mgmt]
        CertManager[cert-manager<br/>TLS Certificates]
        Gateway[Gateway API<br/>Alternative Routing]
    end

    subgraph "Internal ODH/RHOAI Components"
        ServiceMesh[Service Mesh<br/>VirtualService/DestinationRule]
        Authorino[Authorino<br/>Token Authorization]
        ModelRegistry[Model Registry<br/>Model Metadata API]
        DSPipelines[Data Science Pipelines<br/>ML Pipeline Integration]
    end

    subgraph "External Services"
        S3[S3 Storage<br/>AWS/Minio<br/>443/TCP HTTPS]
        GCS[GCS Storage<br/>Google Cloud<br/>443/TCP HTTPS]
        Azure[Azure Blob<br/>443/TCP HTTPS]
        HFHub[HuggingFace Hub<br/>443/TCP HTTPS]
    end

    %% User interactions
    User[User/CI] -->|creates| InferenceServiceCR
    User -->|creates| LLMInferenceServiceCR
    User -->|creates| InferenceGraphCR

    %% CRD watching
    InferenceServiceCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    InferenceGraphCR -->|watched by| Controller
    LLMInferenceServiceCR -->|watched by| Controller
    TrainedModelCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|creates| Knative
    Controller -->|creates| ServiceMesh
    Controller -->|integrates| Istio
    Controller -->|uses| CertManager
    Controller -->|creates routes via| Gateway

    %% Storage initialization
    StorageInit -->|downloads from| S3
    StorageInit -->|downloads from| GCS
    StorageInit -->|downloads from| Azure
    StorageInit -->|downloads from| HFHub

    %% Model server deployment
    Controller -->|deploys| HFServer
    Controller -->|deploys| SklearnServer
    Controller -->|deploys| XGBoostServer
    Controller -->|deploys| TorchServe
    Controller -->|deploys| TritonServer

    %% Agent and router integration
    Agent -->|lifecycle mgmt| HFServer
    Router -->|routes to| HFServer
    Router -->|routes to| SklearnServer

    %% Internal integrations
    Controller -->|integrates| Authorino
    Controller -->|fetches metadata| ModelRegistry
    DSPipelines -->|auto-deploys| Controller

    %% Local model caching
    LocalModelMgr -->|manages| LocalNodeAgent

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style LLMInferenceServiceCR fill:#f5a623,stroke:#333
    style InferenceGraphCR fill:#f5a623,stroke:#333
    style Knative fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style ServiceMesh fill:#7ed321,stroke:#333
    style Authorino fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style DSPipelines fill:#7ed321,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style Azure fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style HFServer fill:#50c878,stroke:#333
    style SklearnServer fill:#50c878,stroke:#333
    style XGBoostServer fill:#50c878,stroke:#333
