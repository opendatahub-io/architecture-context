graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: opendatahub"]
        SA_PerRegistry["per-registry SA<br/>Namespace: user-namespace"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager[manager-rolebinding<br/>Cluster-wide]
        CRB_Proxy[proxy-rolebinding<br/>Namespace: opendatahub]
    end

    subgraph "Role Bindings"
        RB_LeaderElection["leader-election-rolebinding<br/>Namespace: opendatahub"]
        RB_PerRegistry["registry-user-REGISTRY<br/>Namespace: user-namespace"]
    end

    subgraph "Cluster Roles"
        CR_Manager[manager-role<br/>Cluster-wide]
        CR_Editor[modelregistry-editor-role<br/>Cluster-wide]
        CR_Viewer[modelregistry-viewer-role<br/>Cluster-wide]
        CR_MetricsReader[metrics-reader<br/>Cluster-wide]
    end

    subgraph "Roles"
        R_LeaderElection["leader-election-role<br/>Namespace: opendatahub"]
        R_Proxy["proxy-role<br/>Namespace: opendatahub"]
        R_PerRegistry["registry-user-REGISTRY<br/>Namespace: user-namespace"]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[ConfigMaps<br/>core/v1]
        Core_Secrets[Secrets<br/>core/v1]
        Core_Services[Services<br/>core/v1]
        Core_ServiceAccounts[ServiceAccounts<br/>core/v1]
        Core_PVCs[PersistentVolumeClaims<br/>core/v1]
        Core_Pods[Pods<br/>core/v1]
        Core_Events[Events<br/>core/v1]
        Core_Endpoints[Endpoints<br/>core/v1]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[Deployments<br/>apps/v1]
    end

    subgraph "API Resources - Model Registry"
        MR_CRD[ModelRegistry<br/>modelregistry.opendatahub.io/v1beta1]
        MR_Status[ModelRegistry/status]
        MR_Finalizers[ModelRegistry/finalizers]
    end

    subgraph "API Resources - OpenShift"
        OS_Routes[Routes<br/>route.openshift.io]
        OS_CustomHost[Routes/custom-host<br/>route.openshift.io]
        OS_Groups[Groups<br/>user.openshift.io]
        OS_Ingresses[Ingresses<br/>config.openshift.io]
    end

    subgraph "API Resources - RBAC"
        RBAC_Roles[Roles<br/>rbac.authorization.k8s.io]
        RBAC_RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
        RBAC_ClusterRoleBindings[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - Network"
        Net_NetworkPolicies[NetworkPolicies<br/>networking.k8s.io]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReviews[TokenReviews<br/>authentication.k8s.io]
        Auth_SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io]
    end

    subgraph "API Resources - Migration"
        Migrate_StorageVersionMigrations[StorageVersionMigrations<br/>migration.k8s.io]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[Leases<br/>coordination.k8s.io]
    end

    subgraph "Non-Resource URLs"
        NonResource_Metrics["/metrics"]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_LeaderElection
    SA_PerRegistry -->|bound via| RB_PerRegistry

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| R_Proxy
    RB_LeaderElection -->|grants| R_LeaderElection
    RB_PerRegistry -->|grants| R_PerRegistry

    %% Manager Role Permissions (Core)
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_ConfigMaps
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Secrets
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Services
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_ServiceAccounts
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_PVCs
    CR_Manager -->|get,list,watch| Core_Pods
    CR_Manager -->|get,list,watch| Core_Endpoints
    CR_Manager -->|create,patch| Core_Events

    %% Manager Role Permissions (Apps)
    CR_Manager -->|create,delete,get,list,patch,update,watch| Apps_Deployments

    %% Manager Role Permissions (Model Registry)
    CR_Manager -->|create,delete,get,list,patch,update,watch| MR_CRD
    CR_Manager -->|get,patch,update| MR_Status
    CR_Manager -->|update| MR_Finalizers

    %% Manager Role Permissions (OpenShift)
    CR_Manager -->|create,delete,get,list,patch,update,watch| OS_Routes
    CR_Manager -->|create,delete,get,list,patch,update,watch| OS_CustomHost
    CR_Manager -->|create,delete,get,list,patch,update,watch| OS_Groups
    CR_Manager -->|get,list,watch| OS_Ingresses

    %% Manager Role Permissions (RBAC)
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_Roles
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_RoleBindings
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_ClusterRoleBindings

    %% Manager Role Permissions (Network)
    CR_Manager -->|create,delete,get,list,patch,update,watch| Net_NetworkPolicies

    %% Manager Role Permissions (Auth)
    CR_Manager -->|create| Auth_TokenReviews
    CR_Manager -->|create| Auth_SubjectAccessReviews

    %% Manager Role Permissions (Migration)
    CR_Manager -->|create,delete,get,list,patch,update,watch| Migrate_StorageVersionMigrations

    %% Leader Election Role Permissions
    R_LeaderElection -->|get,list,watch,create,update,patch,delete| Core_ConfigMaps
    R_LeaderElection -->|get,list,watch,create,update,patch,delete| Coord_Leases
    R_LeaderElection -->|create,patch| Core_Events

    %% Metrics Reader Permissions
    CR_MetricsReader -->|get| NonResource_Metrics

    %% Editor/Viewer Permissions
    CR_Editor -->|create,delete,get,list,patch,update,watch| MR_CRD
    CR_Editor -->|get| MR_Status
    CR_Viewer -->|get,list,watch| MR_CRD
    CR_Viewer -->|get| MR_Status

    %% User Roles (granted to data scientists/ML engineers)
    User[Data Scientists<br/>ML Engineers] -.->|granted| CR_Editor
    User -.->|granted| CR_Viewer

    %% Per-Registry Role (kube-rbac-proxy enforcement)
    R_PerRegistry -->|SubjectAccessReview<br/>enforced by kube-rbac-proxy| RegistryService[Model Registry Service<br/>8443/TCP HTTPS]

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_PerRegistry fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Editor fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Viewer fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_MetricsReader fill:#f5a623,stroke:#333,stroke-width:2px
    style R_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_PerRegistry fill:#f5a623,stroke:#333,stroke-width:2px

    style MR_CRD fill:#7ed321,stroke:#333,stroke-width:2px
    style MR_Status fill:#7ed321,stroke:#333,stroke-width:2px
    style MR_Finalizers fill:#7ed321,stroke:#333,stroke-width:2px

    style RegistryService fill:#7ed321,stroke:#333,stroke-width:2px

    style User fill:#e1d5e7,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
