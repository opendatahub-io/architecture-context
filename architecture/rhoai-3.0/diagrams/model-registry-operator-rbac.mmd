graph TD
    subgraph SAs["Service Accounts"]
        SA_Controller[controller-manager]
        SA_Registry[Per-registry SA]
    end

    subgraph CRBs["ClusterRole Bindings"]
        CRB_Manager[manager-rolebinding]
        CRB_Proxy[proxy-rolebinding]
    end

    subgraph RBs["Role Bindings"]
        RB_Leader[leader-election-rolebinding]
        RB_Registry[registry-user rolebinding]
    end

    subgraph CRs["ClusterRoles"]
        CR_Manager[manager-role]
        CR_Editor[modelregistry-editor-role]
        CR_Viewer[modelregistry-viewer-role]
        CR_Metrics[metrics-reader]
        CR_Proxy[proxy-role]
    end

    subgraph Rs["Roles"]
        R_Leader[leader-election-role]
        R_Registry[registry-user role]
    end

    subgraph Core["API Resources: Core"]
        Core_ConfigMaps[ConfigMaps, Secrets, Services]
        Core_Events[Events]
        Core_Endpoints[Endpoints, Pods]
    end

    subgraph Apps["API Resources: Apps"]
        Apps_Deployments[Deployments]
    end

    subgraph MR["API Resources: ModelRegistry"]
        MR_CRD[ModelRegistry CR]
        MR_Finalizers[ModelRegistry Finalizers]
        MR_Status[ModelRegistry Status]
    end

    subgraph OS["API Resources: OpenShift"]
        OS_Routes[Routes]
        OS_Groups[Groups]
        OS_Ingress[Ingresses]
    end

    subgraph Net["API Resources: Networking"]
        Net_Policies[NetworkPolicies]
    end

    subgraph RBAC["API Resources: RBAC"]
        RBAC_Resources[Roles, RoleBindings, ClusterRoleBindings]
    end

    subgraph Auth["API Resources: Auth"]
        Auth_TokenReview[TokenReviews]
        Auth_SAR[SubjectAccessReviews]
    end

    subgraph Mig["API Resources: Migration"]
        Migration[StorageVersionMigrations]
    end

    subgraph NonRes["Non-Resource URLs"]
        Metrics["metrics endpoint"]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader
    SA_Registry -->|bound via| RB_Registry

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader
    RB_Registry -->|grants| R_Registry

    %% Manager Role Permissions
    CR_Manager -->|full CRUD| Core_ConfigMaps
    CR_Manager -->|create,patch| Core_Events
    CR_Manager -->|get,list,watch| Core_Endpoints
    CR_Manager -->|full CRUD| Apps_Deployments
    CR_Manager -->|full CRUD| MR_CRD
    CR_Manager -->|update| MR_Finalizers
    CR_Manager -->|get,patch,update| MR_Status
    CR_Manager -->|full CRUD| OS_Routes
    CR_Manager -->|full CRUD| OS_Groups
    CR_Manager -->|get,list,watch| OS_Ingress
    CR_Manager -->|full CRUD| Net_Policies
    CR_Manager -->|full CRUD| RBAC_Resources
    CR_Manager -->|create| Auth_TokenReview
    CR_Manager -->|create| Auth_SAR
    CR_Manager -->|full CRUD| Migration

    %% Editor Role Permissions
    CR_Editor -->|full CRUD| MR_CRD
    CR_Editor -->|get| MR_Status

    %% Viewer Role Permissions
    CR_Viewer -->|get,list,watch| MR_CRD
    CR_Viewer -->|get,list,watch| MR_Status

    %% Metrics Reader
    CR_Metrics -->|get| Metrics

    %% Leader Election Role
    R_Leader -->|full CRUD| Core_ConfigMaps
    R_Leader -->|create,patch| Core_Events

    %% Registry User Role
    R_Registry -.->|service access| SA_Registry

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#e8e8e8,stroke:#333,stroke-width:1px

    class SA_Controller,SA_Registry serviceaccount
    class CRB_Manager,CRB_Proxy,RB_Leader,RB_Registry binding
    class CR_Manager,CR_Editor,CR_Viewer,CR_Metrics,CR_Proxy,R_Leader,R_Registry role
    class Core_ConfigMaps,Core_Events,Core_Endpoints,Apps_Deployments,MR_CRD,MR_Finalizers,MR_Status,OS_Routes,OS_Groups,OS_Ingress,Net_Policies,RBAC_Resources,Auth_TokenReview,Auth_SAR,Migration,Metrics resource
