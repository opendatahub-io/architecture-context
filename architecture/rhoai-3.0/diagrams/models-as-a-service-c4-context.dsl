// Models as a Service - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist / Developer" "Consumes LLM inference APIs with tiered access"
        platformAdmin = person "Platform Administrator" "Manages tier policies and gateway configuration"

        // Main System
        maas = softwareSystem "Models as a Service (MaaS)" "Platform for exposing LLM inference services with tiered API key management, rate limiting, and policy enforcement" {
            maasApi = container "maas-api" "Core API for token issuance/revocation, model discovery, and tier lookup. Creates Namespaces and ServiceAccounts per user/tier." "Go/Gin HTTP Service"
            tierMapping = container "tier-to-group-mapping" "Maps OpenShift user groups to subscription tiers (free/premium/enterprise)" "ConfigMap"
        }

        // Gateway Layer
        gatewayLayer = softwareSystem "Gateway Layer" "Traffic routing, TLS termination, authentication, authorization, and rate limiting" {
            maasGateway = container "maas-default-gateway" "Primary ingress gateway for MaaS. Handles HTTPS termination." "Gateway API Gateway"
            inferenceGateway = container "openshift-ai-inference" "Default inference gateway for LLMInferenceService resources" "Gateway API Gateway"
            httpRoute = container "maas-api-route" "Routes /v1/models and /maas-api/* to maas-api service" "HTTPRoute"
        }

        // Kuadrant
        kuadrant = softwareSystem "Kuadrant" "API gateway policy engine for authentication, authorization, and rate limiting" "External" {
            authorino = container "Authorino" "Authentication (TokenReview) and authorization (SubjectAccessReview) enforcement" "Kuadrant Component"
            limitador = container "Limitador" "Rate limiting enforcement (request + token limits)" "Kuadrant Component"
        }

        // External Dependencies
        openshift = softwareSystem "OpenShift" "Kubernetes platform with Gateway API support" "External"
        kserve = softwareSystem "KServe" "Model serving platform providing InferenceService and LLMInferenceService CRDs" "Internal RHOAI"
        certManager = softwareSystem "cert-manager" "TLS certificate management for gateway" "External"
        kubeApi = softwareSystem "Kubernetes API Server" "TokenReview, SubjectAccessReview, resource CRUD" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor and TelemetryPolicy" "External"

        // Internal RHOAI Dependencies
        odhOperator = softwareSystem "ODH/RHOAI Operator" "Provides KServe with RawDeployment mode" "Internal RHOAI"

        // Relationships - User interactions
        dataScientist -> maasGateway "Requests tokens and model inference" "HTTPS/443"
        platformAdmin -> maas "Configures tiers and policies" "kubectl/YAML"

        // Gateway Layer relationships
        maasGateway -> httpRoute "Routes traffic"
        httpRoute -> maasApi "Forwards requests" "HTTP/8080"
        maasGateway -> kserve "Forwards model inference requests" "HTTP/HTTPS"
        inferenceGateway -> kserve "Routes inference traffic" "HTTP/80"

        // Kuadrant enforcement
        authorino -> maasApi "Tier lookup callback" "HTTP/8080"
        authorino -> kubeApi "TokenReview, SubjectAccessReview" "HTTPS/443"
        limitador -> maasGateway "Rate limit decisions"

        // maas-api interactions
        maasApi -> kubeApi "TokenReview, Namespace/SA CRUD, CRD list/watch" "HTTPS/443"
        maasApi -> tierMapping "Reads tier configuration"

        // Platform dependencies
        maas -> kserve "Lists InferenceService and LLMInferenceService CRs" "HTTPS/443"
        maas -> kuadrant "Uses for auth and rate limiting"
        maas -> certManager "TLS certificates for gateway"
        maas -> openshift "Runs on OpenShift with Gateway API"
        kserve -> odhOperator "Managed by"

        // Observability
        prometheus -> limitador "Scrapes metrics" "HTTP (ServiceMonitor)"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "MaaSContainers" {
            include *
            autoLayout
        }

        container gatewayLayer "GatewayContainers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
