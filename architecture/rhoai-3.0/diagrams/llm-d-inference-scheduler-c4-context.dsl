// C4 Context Diagram: llm-d-inference-scheduler
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.0/llm-d-inference-scheduler.md

workspace {
    model {
        client = person "Client Application" "Sends LLM inference requests"
        admin = person "Platform Admin" "Configures InferencePool and scheduling profiles"

        llmdScheduler = softwareSystem "llm-d Inference Scheduler (EPP)" "Endpoint Picker that makes optimized routing decisions for LLM inference requests using pluggable filters, scorers, and scrapers" {
            epp = container "EPP Service" "Main gRPC service receiving ext-proc callbacks from Envoy and selecting target pods" "Go gRPC Service"
            pluginRegistry = container "Plugin Registry" "Registers filter, scorer, pre-request, and profile handler plugins" "Go Package"
            filters = container "Filter Plugins" "ByLabel, ByLabelSelector, Decode, Prefill filters" "Go Plugins"
            scorers = container "Scorer Plugins" "PrecisePrefixCache, LoadAware, SessionAffinity, ActiveRequest scorers" "Go Plugins"
            preRequestHandlers = container "Pre-Request Plugins" "PrefillHeaderHandler for P/D scheduling" "Go Plugins"
            profileHandlers = container "Profile Handlers" "PdProfileHandler for prefill/decode profile selection" "Go Plugins"
        }

        envoy = softwareSystem "Envoy Data Plane" "Proxy with ext-proc filter for routing inference traffic" "External"
        inferenceGateway = softwareSystem "Inference Gateway" "Kubernetes Gateway API Gateway for inference traffic" "External"
        istio = softwareSystem "Istio (istiod)" "Service mesh control plane, revision: llm-d-gateway" "External"
        gie = softwareSystem "Gateway API Inference Extension" "Core scheduling framework and ext-proc runner (v1.0.0)" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API CRDs (v1.3.0)" "External"
        vllm = softwareSystem "vLLM Model-Serving Pods" "LLM inference servers (target pods)" "Internal RHOAI"
        kvCacheMgr = softwareSystem "llm-d KV-Cache Manager" "KV-cache indexer and event pool (v0.3.1)" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for watching resources" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Tokenizer model downloads" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection" "External"

        // User interactions
        client -> inferenceGateway "Sends inference requests" "HTTP/80"
        admin -> k8sAPI "Creates InferencePool, configures profiles" "kubectl/HTTPS"

        // Gateway to EPP flow
        inferenceGateway -> envoy "Routes traffic"
        envoy -> llmdScheduler "ext-proc callbacks for routing decisions" "gRPC/9002"
        llmdScheduler -> envoy "Returns selected pod endpoint" "gRPC/9002"
        envoy -> vllm "Forwards inference request to selected pod" "HTTP/8000"

        // EPP dependencies
        llmdScheduler -> k8sAPI "Watches InferencePool, Pods, EndpointSlices" "HTTPS/443"
        llmdScheduler -> hfHub "Downloads tokenizer models" "HTTPS/443"
        llmdScheduler -> istio "Receives xDS configuration" "gRPC/15010"

        // Internal integrations
        vllm -> llmdScheduler "Sends KV-cache events" "ZMQ/5557"
        prometheus -> llmdScheduler "Scrapes metrics" "HTTP/9090"

        // Framework dependency
        llmdScheduler -> gie "Extends with llm-d plugins"
        llmdScheduler -> gatewayAPI "Uses Gateway and HTTPRoute CRDs"

        // Internal container relationships
        epp -> pluginRegistry "Loads plugins"
        pluginRegistry -> filters "Registers"
        pluginRegistry -> scorers "Registers"
        pluginRegistry -> preRequestHandlers "Registers"
        pluginRegistry -> profileHandlers "Registers"
    }

    views {
        systemContext llmdScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmdScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #5ba3f5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
