// Data Science Pipelines Tekton - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages ML pipelines via UI or SDK"
        admin = person "Platform Admin" "Deploys and configures DSP Tekton components"

        dspTekton = softwareSystem "Data Science Pipelines Tekton" "Kubeflow Pipelines backend on Tekton for ML pipeline orchestration, scheduling, and metadata tracking" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API server for pipeline CRUD, run management, experiments, and job scheduling" "Go Service" "Port 8888/TCP (REST), 8887/TCP (gRPC)"
            persistenceAgent = container "ds-pipeline-persistenceagent" "Watches Tekton PipelineRun/TaskRun status and persists results to API server" "Go Service"
            scheduledWorkflow = container "ds-pipeline-scheduledworkflow" "Reconciles ScheduledWorkflow CRDs to create Tekton PipelineRuns on cron/periodic schedules" "Go Controller"
            ui = container "ds-pipeline-ui" "Web UI for pipeline visualization, run management, and experiment tracking" "React/Node.js" "Port 3000/TCP"
            oauthProxy = container "OAuth Proxy" "OpenShift OAuth proxy sidecar for UI authentication" "Sidecar" "Port 8443/TCP (HTTPS)"
            cacheServer = container "cache-server" "Mutating admission webhook for task-level caching of Tekton TaskRuns" "Go Webhook" "Port 443/TCP (HTTPS)"
            cacheDeployer = container "cache-deployer" "Deploys webhook TLS certificates and MutatingWebhookConfiguration" "Go Job"
            viewerController = container "ml-pipeline-viewer-crd" "Reconciles Viewer CRDs to create TensorBoard Deployments/Services" "Go Controller"
            metadataGrpc = container "metadata-grpc-server" "ML Metadata (MLMD) gRPC server for artifact and execution metadata" "Go/C++ Service" "Port 8080/TCP (gRPC)"
            metadataEnvoy = container "metadata-envoy" "gRPC-Web proxy for metadata-grpc-server" "Envoy Proxy" "Port 9090/TCP"
            metadataWriter = container "metadata-writer" "Writes pipeline run metadata from Tekton artifacts to MLMD" "Python Service"
            loopController = container "tekton-pipelineloop-controller" "Custom Tekton controller for PipelineLoop CRD enabling iterative pipeline execution" "Go Controller"
            loopWebhook = container "tekton-pipelineloop-webhook" "Admission webhook for PipelineLoop CRD validation and defaults" "Go Webhook"
            vizServer = container "visualization-server" "Generates pipeline output visualizations (HTML)" "Python Service" "Port 8888/TCP"
            artifactManager = container "artifact-manager" "Manages artifact retrieval from object storage" "Python Service"
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine (PipelineRun, TaskRun)" "External"
        mysql = softwareSystem "MySQL/MariaDB" "Persistent storage for pipeline metadata, cache, and MLMD" "External"
        s3 = softwareSystem "S3/Minio Object Storage" "Artifact storage (pipeline outputs, logs)" "External"
        kubernetes = softwareSystem "Kubernetes API" "Container orchestration and CR management" "External"
        openshift = softwareSystem "OpenShift Platform" "OAuth, Routes, Serving Certs" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "Registers DSP as OdhApplication with quickstarts" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys DSP components via kustomize manifests" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "External"
        istio = softwareSystem "Istio Service Mesh" "mTLS and AuthorizationPolicy (multi-user mode)" "External"

        // User interactions
        user -> oauthProxy "Creates/manages pipelines via UI" "HTTPS/8443"
        user -> apiServer "Creates/manages pipelines via SDK" "HTTP/8888, gRPC/8887"
        admin -> rhoaiOperator "Deploys DSP components"

        // Internal flows
        oauthProxy -> ui "Proxies authenticated requests" "HTTP/3000"
        ui -> apiServer "Pipeline operations" "HTTP/8888"
        ui -> metadataEnvoy "Query ML metadata" "HTTP/9090 gRPC-Web"
        apiServer -> vizServer "Generate visualizations" "HTTP/8888"
        persistenceAgent -> apiServer "Report run status" "HTTP/8888"
        metadataWriter -> metadataGrpc "Write run metadata" "gRPC/8080"
        metadataEnvoy -> metadataGrpc "Proxy gRPC requests" "gRPC/8080"
        cacheDeployer -> cacheServer "Deploy webhook certs"

        // External dependencies
        apiServer -> mysql "Store pipeline metadata" "MySQL/3306"
        apiServer -> s3 "Store/retrieve artifacts" "HTTP/9000 or HTTPS/443"
        apiServer -> kubernetes "Create Tekton CRs" "HTTPS/443"
        persistenceAgent -> kubernetes "Watch PipelineRun status" "HTTPS/443"
        scheduledWorkflow -> kubernetes "Watch ScheduledWorkflows, create PipelineRuns" "HTTPS/443"
        cacheServer -> mysql "Query/update cache" "MySQL/3306"
        metadataGrpc -> mysql "Store MLMD data" "MySQL/3306"
        loopController -> kubernetes "Manage PipelineLoop CRs" "HTTPS/443"
        oauthProxy -> openshift "OAuth authentication" "HTTPS/443"

        // Integration points
        dspTekton -> tekton "Workflow execution via Tekton CRDs" "HTTPS/443 via K8s API"
        odhDashboard -> dspTekton "Registers as OdhApplication"
        rhoaiOperator -> dspTekton "Deploys via kustomize"
        prometheus -> apiServer "Scrapes /metrics" "HTTP/8888"
        dspTekton -> istio "Service mesh security (multi-user)" "mTLS"
    }

    views {
        systemContext dspTekton "SystemContext" {
            include *
            autoLayout
        }

        container dspTekton "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
