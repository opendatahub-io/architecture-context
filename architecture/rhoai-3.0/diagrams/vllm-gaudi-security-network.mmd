    %% Metrics
    Prometheus["Prometheus"] -->|"HTTP/8000<br/>GET /metrics<br/>Optional TLS"| MetricsEP

    %% Egress flows
    OpenAIServer -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub
    OpenAIServer -.->|"gRPC/4317<br/>OTLP traces"| OTelCollector
    HPUWorker -.->|"TCP/6379,8265<br/>plaintext"| RayHead

