// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys AI trustworthiness services, evaluation jobs, and guardrails"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages TrustyAI explainability services, LM evaluation jobs, and guardrails orchestration" {
            operatorManager = container "Operator Manager" "controller-runtime manager with leader election" "Go Binary"
            tasController = container "TAS Controller" "Reconciles TrustyAIService CRs; creates Deployments, Services, Routes, PVCs" "Go Controller"
            lmesController = container "LMES Controller" "Reconciles LMEvalJob CRs; creates evaluation Pods with driver sidecars" "Go Controller"
            jobMgrController = container "Job Manager Controller" "Kueue integration for LMEvalJob workload scheduling" "Go Controller"
            gorchController = container "GORCH Controller" "Reconciles GuardrailsOrchestrator CRs; creates multi-container Deployments" "Go Controller"
        }

        // Internal ODH/RHOAI Systems
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys the operator via kustomize overlays" "Internal RHOAI"
        kserve = softwareSystem "KServe / ModelMesh" "Model serving infrastructure for InferenceServices" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects" "Internal RHOAI"
        monitoring = softwareSystem "OpenShift Monitoring" "Prometheus-based metrics collection" "Internal RHOAI"

        // External Dependencies
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS and traffic routing" "External"
        kueue = softwareSystem "Kueue" "Workload queuing for job scheduling" "External"
        certSigner = softwareSystem "OpenShift Service Serving Cert Signer" "Automatic TLS certificate provisioning" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server" "External"

        // External Services
        s3 = softwareSystem "S3-Compatible Storage" "Model and evaluation data storage" "External Service"
        database = softwareSystem "Database" "TrustyAI data storage backend (optional)" "External Service"

        // User interactions
        user -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator CRs via kubectl/Dashboard"
        user -> odhDashboard "Manages AI services via web UI"

        // Internal integrations
        rhodsOperator -> trustyaiOperator "Deploys via kustomize, injects RELATED_IMAGE env vars"
        trustyaiOperator -> kserve "Patches InferenceService deployments; auto-configures guardrails endpoints" "Kubernetes API"
        trustyaiOperator -> monitoring "Exposes metrics via ServiceMonitor" "HTTP/8080"
        trustyaiOperator -> istio "Creates DestinationRules/VirtualServices for mTLS and traffic routing" "Kubernetes API"
        trustyaiOperator -> kueue "Creates Workload resources for LMEvalJob scheduling" "Kubernetes API"
        trustyaiOperator -> certSigner "Auto-provisions TLS certificates via annotations"
        trustyaiOperator -> k8sAPI "Manages all Kubernetes resources" "HTTPS/443"

        // External service integrations
        trustyaiOperator -> s3 "LMEvalJob offline storage" "HTTPS/443 AWS IAM"
        trustyaiOperator -> database "TrustyAI data persistence" "JDBC TLS"

        // Container relationships
        operatorManager -> tasController "Initializes and runs"
        operatorManager -> lmesController "Initializes and runs"
        operatorManager -> jobMgrController "Initializes and runs"
        operatorManager -> gorchController "Initializes and runs"

        tasController -> kserve "Patches InferenceService with payload processor env vars" "Kubernetes API"
        tasController -> istio "Creates DestinationRule, VirtualService" "Kubernetes API"
        lmesController -> kueue "Creates Workload for job scheduling" "Kubernetes API"
        gorchController -> kserve "Auto-discovers InferenceServices for generator/detector endpoints" "Kubernetes API"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
