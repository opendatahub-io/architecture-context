graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph DSPANamespace["DSPA NAMESPACE: {dspa-namespace}<br/>APPLICATION LAYER (pod-to-pod TLS)"]
        direction TB

        subgraph APIServerPod["DSP API Server Pod"]
            OAuth["OAuth Proxy<br/>8443/TCP HTTPS<br/>Secret: ds-pipelines-proxy-tls-{name}"]
            APIServer["API Server<br/>8888/TCP HTTP TLS<br/>8887/TCP gRPC TLS<br/>SA: ds-pipeline-{name}"]
        end

        subgraph Storage["Data Storage"]
            MariaDB["MariaDB StatefulSet<br/>3306/TCP MySQL TLS<br/>Secret: mariadb-tls-{name}<br/>Secret: {db-credentials}<br/>PVC: mariadb-{name}<br/>NetworkPolicy: mariadb-{name}"]
        end

        subgraph WorkflowExecution["Workflow Execution"]
            WorkflowController["Argo Workflow Controller<br/>8001/TCP HTTP TLS<br/>SA: ds-pipeline-argo-{name}"]
            PipelinePod["Pipeline Execution Pod<br/>(ephemeral)<br/>SA: pipeline-runner-{name}"]
        end

        subgraph MetadataTracking["ML Metadata (Optional)"]
            MLMDEnvoy["MLMD Envoy<br/>9090/TCP HTTP TLS<br/>NetworkPolicy: mlmd-envoy-dashboard-access"]
            MLMDgRPC["MLMD gRPC<br/>8080/TCP gRPC TLS mTLS<br/>Secret: metadata-grpc-tls-{name}<br/>NetworkPolicy: ds-pipeline-metadata-grpc-{name}"]
        end

        subgraph Agents["Background Agents"]
            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-{name}"]
            ScheduledWorkflow["Scheduled Workflow Controller<br/>SA: ds-pipeline-{name}"]
        end

        OAuth -->|HTTP/8888<br/>TLS pod-to-pod<br/>Bearer Token| APIServer
        APIServer -->|MySQL/3306<br/>TLS<br/>DB Password| MariaDB
        APIServer -->|HTTP/8001<br/>TLS<br/>SA Token| WorkflowController
        APIServer -->|gRPC/8080<br/>TLS mTLS| MLMDgRPC
        PersistenceAgent -->|gRPC/8887<br/>TLS<br/>SA Token| APIServer
        PersistenceAgent -->|MySQL/3306<br/>TLS<br/>DB Password| MariaDB
        ScheduledWorkflow -->|gRPC/8887<br/>TLS<br/>SA Token| APIServer
        PipelinePod -->|HTTP/8888<br/>TLS<br/>SA Token| APIServer
        PipelinePod -->|gRPC/8080<br/>TLS mTLS| MLMDgRPC
        MLMDEnvoy -->|gRPC/8080<br/>TLS mTLS| MLMDgRPC
        MLMDgRPC -->|MySQL/3306<br/>TLS<br/>DB Password| MariaDB
    end

    subgraph K8sCluster["KUBERNETES CLUSTER"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / S3 Credentials<br/>Secret: {storage-credentials}"]
        ExternalDB["External Database (Optional)<br/>3306/5432 TCP TLS 1.2+<br/>MySQL/PostgreSQL<br/>Secret: {db-credentials}"]
        Registry["Container Registries<br/>registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secrets"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE: redhat-ods-applications"]
        DSPOController["DSPO Controller Manager<br/>8080/TCP (metrics)<br/>8081/TCP (health)<br/>SA: controller-manager<br/>ClusterRole: manager-role"]
    end

    subgraph Integrations["INTEGRATION POINTS"]
        Dashboard["ODH Dashboard<br/>UI Integration"]
        Workbenches["Workbenches/Notebooks<br/>Pipeline Authoring"]
    end

    %% External flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route
    Route -->|HTTPS/8443<br/>TLS Reencrypt| OAuth

    %% Workflow execution flows
    WorkflowController -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Create Workflows/Pods| K8sAPI
    K8sAPI -->|Creates| PipelinePod

    %% Pipeline pod external access
    PipelinePod -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    PipelinePod -.->|TLS 1.2+<br/>DB Credentials| ExternalDB

    %% Operator flows
    DSPOController -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Manage DSPA Resources| K8sAPI
    DSPOController -->|Monitors| DSPACR[DataSciencePipelinesApplication CR]
    DSPACR -.->|Triggers reconciliation| DSPOController

    %% Integration flows
    Dashboard -->|HTTPS/443<br/>TLS 1.2+<br/>via Route| Route
    Workbenches -->|HTTP/8888<br/>TLS pod-to-pod<br/>SA Token| APIServer

    %% Image pulls
    K8sAPI -.->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef integration fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class OAuth,APIServer,WorkflowController,PipelinePod,MLMDEnvoy,MLMDgRPC,PersistenceAgent,ScheduledWorkflow application
    class MariaDB storage
    class S3,ExternalDB,Registry,K8sAPI externalservice
    class DSPOController,DSPACR operator
    class Dashboard,Workbenches integration
