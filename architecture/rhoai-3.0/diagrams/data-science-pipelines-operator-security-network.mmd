graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt<br/>Host: *.apps.cluster.domain"]
    end

    subgraph DSPA_Namespace["DSPA NAMESPACE: {dspa-namespace}<br/>Pod-to-Pod TLS: ENABLED"]
        direction TB

        subgraph APIServerPod["API Server Pod<br/>SA: ds-pipeline-{name}"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>Token Validation"]
            APIContainer["API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>TLS: service-serving cert"]
            OAuthProxy -->|localhost| APIContainer
        end

        subgraph PersistenceAgentPod["Persistence Agent Pod<br/>SA: ds-pipeline-{name}"]
            PA["Persistence Agent<br/>Watches: Workflow CRs<br/>Syncs to DB + API"]
        end

        subgraph WorkflowControllerPod["Workflow Controller Pod<br/>SA: ds-pipeline-argo-{name}"]
            WFC["Argo Workflow Controller<br/>9090/TCP metrics<br/>Creates pipeline pods"]
        end

        subgraph PipelinePod["Pipeline Execution Pod<br/>SA: pipeline-runner-{name}"]
            PipelineContainer["User Pipeline Component<br/>Image: {user-specified}"]
        end

        subgraph MariaDBPod["MariaDB Pod<br/>SA: ds-pipeline-{name}<br/>NetworkPolicy: mariadb-{name}"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>TLS: ds-pipelines-mariadb-tls-{name}<br/>Auth: DB Password<br/>Storage: PVC"]
        end

        subgraph MLMDPod["MLMD gRPC Pod (Optional)<br/>SA: ds-pipeline-{name}<br/>NetworkPolicy: ds-pipeline-metadata-grpc-{name}"]
            MLMD["MLMD gRPC<br/>8080/TCP gRPC<br/>TLS: ds-pipeline-metadata-grpc-tls-certs-{name}<br/>Auth: mTLS"]
        end

        subgraph MLMDEnvoyPod["MLMD Envoy Pod (Optional)<br/>SA: ds-pipeline-{name}<br/>NetworkPolicy: mlmd-envoy-dashboard-access"]
            Envoy["MLMD Envoy Proxy<br/>9090/TCP HTTP<br/>Forwards to MLMD gRPC"]
        end

        subgraph MinioPod["Minio Pod (Optional - dev/test only)<br/>SA: ds-pipeline-{name}"]
            Minio["Minio<br/>9000/TCP S3 API<br/>80/TCP alternate<br/>Auth: S3 Credentials<br/>Storage: PVC"]
        end
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE: redhat-ods-applications"]
        DSPOController["DSPO Controller<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health<br/>Watches: DSPA CRs"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Tokens"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExternalS3["External S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM or S3 Credentials<br/>Purpose: Artifact storage (production)"]
        ExternalDB["External Database<br/>3306/TCP MySQL or 5432/TCP PostgreSQL<br/>TLS 1.2+<br/>Auth: DB Credentials<br/>Purpose: Metadata storage (production)"]
        Registry["Container Registries<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ImagePullSecrets<br/>Purpose: Pull component images"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route

    %% Ingress to API Server
    Route -->|HTTPS/8443<br/>Reencrypt<br/>OAuth Validation| OAuthProxy

    %% Internal API flows
    OAuthProxy -->|HTTP/8888<br/>pod-to-pod TLS<br/>Bearer Token| APIContainer
    APIContainer -->|MySQL/3306<br/>pod-to-pod TLS<br/>DB Password| MariaDB
    PA -->|gRPC/8887<br/>pod-to-pod TLS<br/>ServiceAccount Token| APIContainer
    PA -->|MySQL/3306<br/>pod-to-pod TLS<br/>DB Password| MariaDB
    PipelineContainer -->|HTTP/8888<br/>pod-to-pod TLS<br/>ServiceAccount Token| APIContainer
    PipelineContainer -->|gRPC/8080<br/>pod-to-pod TLS<br/>mTLS| MLMD
    MLMD -->|MySQL/3306<br/>pod-to-pod TLS<br/>DB Password| MariaDB
    Envoy -->|gRPC/8080<br/>pod-to-pod TLS| MLMD

    %% Workflow Controller
    WFC -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    APIContainer -->|HTTP/8001<br/>pod-to-pod TLS<br/>ServiceAccount Token| WFC

    %% DSPO Controller
    DSPOController -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Egress to External Services
    APIContainer -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| ExternalS3
    PipelineContainer -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| ExternalS3
    APIContainer -.->|MySQL or PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+<br/>DB Credentials| ExternalDB
    PA -.->|MySQL or PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+<br/>DB Credentials| ExternalDB
    MLMD -.->|MySQL or PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+<br/>DB Credentials| ExternalDB

    %% Alternative: Minio (internal dev/test)
    APIContainer -->|HTTP/9000<br/>S3 API<br/>S3 Credentials| Minio
    PipelineContainer -->|HTTP/9000<br/>S3 API<br/>S3 Credentials| Minio

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef control fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class Client external
    class Route ingress
    class OAuthProxy,APIContainer,PA,WFC,PipelineContainer,MariaDB,MLMD,Envoy,Minio trusted
    class DSPOController operator
    class K8sAPI control
    class ExternalS3,ExternalDB,Registry externalservice
