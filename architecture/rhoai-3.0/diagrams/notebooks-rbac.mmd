graph TD
    subgraph "Workbench Access RBAC (managed by notebook controllers)"
        direction TB

        subgraph "Users"
            User["Data Scientist<br/>(OpenShift User)"]
        end

        subgraph "Authentication"
            OAuth["OpenShift OAuth<br/>(Bearer Token)"]
            KubeRBAC["kube-rbac-proxy<br/>(sidecar, port 8443/TCP)<br/>Injected by notebook-controller"]
        end

        subgraph "Authorization"
            RBAC["Kubernetes RBAC<br/>(per-notebook access control)"]
        end

        subgraph "Workbench Resources (this component provides images)"
            direction LR
            IS_Jupyter["ImageStream<br/>image.openshift.io/v1<br/>Jupyter variants (10)"]
            IS_CodeServer["ImageStream<br/>image.openshift.io/v1<br/>Code Server (1)"]
            IS_RStudio["ImageStream<br/>image.openshift.io/v1<br/>RStudio (via BuildConfig)"]
            IS_Runtime["ImageStream<br/>image.openshift.io/v1<br/>Pipeline Runtimes (7)"]
        end

        subgraph "Build Resources"
            BC_RStudio["BuildConfig<br/>build.openshift.io/v1<br/>RStudio CPU + CUDA (2)"]
            Secret["rhel-subscription-secret<br/>(Opaque)<br/>Manual provisioning<br/>No auto-rotation"]
        end
    end

    subgraph "Controllers (manage RBAC, not part of this component)"
        RhodsOp["rhods-operator<br/>Deploys ImageStream/<br/>BuildConfig manifests"]
        NotebookCtrl["odh-notebook-controller<br/>Creates Pods, HTTPRoutes,<br/>Injects kube-rbac-proxy"]
        Dashboard["odh-dashboard<br/>Reads ImageStream labels:<br/>opendatahub.io/notebook-image=true"]
    end

    %% Access flow
    User -->|"authenticates via"| OAuth
    OAuth -->|"token validated by"| KubeRBAC
    KubeRBAC -->|"checks"| RBAC
    RBAC -->|"grants access to<br/>workbench pod"| IS_Jupyter
    RBAC -->|"grants access to<br/>workbench pod"| IS_CodeServer
    RBAC -->|"grants access to<br/>workbench pod"| IS_RStudio

    %% Controller relationships
    RhodsOp -->|"deploys"| IS_Jupyter
    RhodsOp -->|"deploys"| IS_CodeServer
    RhodsOp -->|"deploys"| IS_RStudio
    RhodsOp -->|"deploys"| IS_Runtime
    RhodsOp -->|"deploys"| BC_RStudio
    NotebookCtrl -->|"creates pods from"| IS_Jupyter
    NotebookCtrl -->|"creates pods from"| IS_CodeServer
    NotebookCtrl -->|"creates pods from"| IS_RStudio
    NotebookCtrl -->|"injects"| KubeRBAC
    Dashboard -->|"reads metadata"| IS_Jupyter
    Dashboard -->|"reads metadata"| IS_CodeServer
    Dashboard -->|"reads metadata"| IS_RStudio
    BC_RStudio -->|"uses"| Secret

    %% Styling
    style User fill:#4a90e2,color:#fff
    style OAuth fill:#e74c3c,color:#fff
    style KubeRBAC fill:#e74c3c,color:#fff
    style RBAC fill:#f5a623,color:#fff
    style IS_Jupyter fill:#7ed321,color:#fff
    style IS_CodeServer fill:#7ed321,color:#fff
    style IS_RStudio fill:#7ed321,color:#fff
    style IS_Runtime fill:#7ed321,color:#fff
    style BC_RStudio fill:#9b59b6,color:#fff
    style Secret fill:#e67e22,color:#fff
    style RhodsOp fill:#95a5a6,color:#fff
    style NotebookCtrl fill:#95a5a6,color:#fff
    style Dashboard fill:#95a5a6,color:#fff
