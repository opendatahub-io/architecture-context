graph TD
    subgraph "Service Accounts (per workbench instance)"
        SA["{notebook-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "OAuth Authentication"
        OAuthProxy["OAuth Proxy Sidecar<br/>Validates OpenShift Tokens<br/>Enforces Namespace Access"]
        OAuthConfig["Secret: {notebook-name}-oauth-config<br/>Type: Opaque<br/>OAuth proxy configuration"]
        OAuthCookie["Secret: {notebook-name}-oauth-cookie-secret<br/>Type: Opaque<br/>Session cookies"]
    end

    subgraph "User Secrets (mounted into workbench)"
        GitSecret["git-credentials<br/>Type: kubernetes.io/basic-auth<br/>Keys: username, password/token"]
        AWSSecret["aws-credentials<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY"]
        DBSecret["database-credentials<br/>Type: Opaque<br/>Keys: DB_HOST, DB_USER, DB_PASSWORD"]
    end

    subgraph "RBAC Managed by ODH Notebook Controller"
        NotebookCRD["Notebook CRD<br/>apiVersion: kubeflow.org/v1<br/>Lifecycle management"]
        NotebookController["ODH Notebook Controller<br/>Watches Notebook CRD<br/>Creates workbench pods"]
    end

    subgraph "Workbench Resources"
        Pod["Workbench Pod<br/>{notebook-name}"]
        Service["Service: notebook-{name}<br/>ClusterIP 8888/TCP"]
        Route["Route: {notebook-name}<br/>*.apps.{cluster}<br/>443/TCP HTTPS Edge TLS"]
        PVC["PersistentVolumeClaim<br/>{notebook-name}-pvc<br/>20-100 GiB"]
    end

    subgraph "Kubernetes API Access"
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3"]
        NamespaceResources["Namespace Resources<br/>Pods, Services, Secrets, ConfigMaps<br/>Limited to {user-namespace}"]
    end

    subgraph "External Authentication"
        GitAuth["GitHub<br/>Git Token or SSH Key"]
        S3Auth["S3 Storage<br/>AWS IAM Credentials"]
        RegistryAuth["Quay.io<br/>Pull Secret"]
    end

    %% Service Account relationships
    SA -->|uses| OAuthConfig
    SA -->|uses| OAuthCookie
    SA -.->|optional mount| GitSecret
    SA -.->|optional mount| AWSSecret
    SA -.->|optional mount| DBSecret

    %% OAuth flow
    OAuthProxy -->|validates| SA
    OAuthProxy -->|enforces| NamespaceAccess["User must have access to<br/>{user-namespace}"]

    %% Notebook Controller
    NotebookController -->|creates| SA
    NotebookController -->|creates| Pod
    NotebookController -->|creates| Service
    NotebookController -->|creates| Route
    NotebookController -->|creates| OAuthConfig
    NotebookController -->|creates| OAuthCookie
    NotebookController -->|watches| NotebookCRD

    %% Pod relationships
    Pod -->|uses ServiceAccount| SA
    Pod -->|bound to| Service
    Pod -->|mounted| PVC
    Route -->|routes to| Service

    %% Kubernetes API access
    SA -->|Bearer Token| K8sAPI
    K8sAPI -->|authorizes| NamespaceResources
    Pod -->|oc/kubectl commands| K8sAPI

    %% External auth
    Pod -->|uses| GitSecret
    Pod -->|uses| AWSSecret
    GitSecret -->|authenticates to| GitAuth
    AWSSecret -->|authenticates to| S3Auth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuthConfig fill:#ffe6cc,stroke:#333
    style OAuthCookie fill:#ffe6cc,stroke:#333
    style NotebookController fill:#7ed321,stroke:#333,stroke-width:3px
    style NotebookCRD fill:#7ed321,stroke:#333
    style Pod fill:#d5e8d4,stroke:#333
    style Service fill:#d5e8d4,stroke:#333
    style Route fill:#d5e8d4,stroke:#333
    style PVC fill:#d5e8d4,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style NamespaceResources fill:#fff2cc,stroke:#333
    style GitSecret fill:#e1d5e7,stroke:#333
    style AWSSecret fill:#e1d5e7,stroke:#333
    style DBSecret fill:#e1d5e7,stroke:#333
    style GitAuth fill:#999,stroke:#333
    style S3Auth fill:#999,stroke:#333
    style RegistryAuth fill:#999,stroke:#333
    style NamespaceAccess fill:#fff2cc,stroke:#333
