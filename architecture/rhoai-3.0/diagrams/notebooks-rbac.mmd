graph TD
    subgraph "User Authentication"
        User[Data Scientist User]
        OSUser[OpenShift User Identity]
    end

    subgraph "Workbench Pod RBAC"
        SA["Service Account<br/>notebook-name"]
        SAToken["Service Account Token<br/>Mounted at /var/run/secrets/"]
    end

    subgraph "OAuth Proxy Authentication"
        OAuthProxy[OAuth Proxy Sidecar]
        OAuthConfig["Secret: notebook-name-oauth-config"]
        OAuthCookie["Secret: notebook-name-oauth-cookie-secret"]
    end

    subgraph "User-Provided Secrets"
        GitCreds["Secret: git-credentials<br/>Type: kubernetes.io/basic-auth<br/>Keys: username, password/token"]
        AWSCreds["Secret: aws-credentials<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY"]
        DBCreds["Secret: database-credentials<br/>Type: Opaque<br/>Keys: host, username, password, database"]
    end

    subgraph "Access Control Enforcement"
        NamespaceAccess["Namespace Access Control<br/>User must have access to user-namespace"]
        K8sRBAC["Kubernetes RBAC<br/>Controls oc CLI permissions"]
        S3Auth["S3 IAM Authentication<br/>AWS credentials"]
        GitAuth["Git Authentication<br/>HTTPS or SSH credentials"]
    end

    subgraph "Managed By ODH Notebook Controller"
        Controller[ODH Notebook Controller]
        NotebookCR["Notebook Custom Resource<br/>Defines workbench configuration"]
    end

    subgraph "External API Access"
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        S3API["S3 Storage API<br/>443/TCP HTTPS"]
        GitAPI["Git Repository<br/>443/TCP HTTPS or 22/TCP SSH"]
        ModelRegAPI["Model Registry API<br/>8080/TCP HTTP"]
    end

    %% User to OpenShift
    User -->|Authenticates via| OSUser
    OSUser -->|OpenShift Session| OAuthProxy

    %% OAuth Proxy Configuration
    OAuthProxy -->|Uses config| OAuthConfig
    OAuthProxy -->|Uses cookie secret| OAuthCookie
    OAuthProxy -->|Enforces| NamespaceAccess

    %% Workbench Pod Service Account
    Controller -->|Creates| SA
    Controller -->|Creates| NotebookCR
    Controller -->|Provisions| OAuthConfig
    Controller -->|Provisions| OAuthCookie
    SA -->|Mounts| SAToken

    %% User-provided secrets
    User -->|Creates| GitCreds
    User -->|Creates| AWSCreds
    User -->|Creates| DBCreds

    %% Secret usage by workbench
    SAToken -->|Bearer token for| K8sAPI
    AWSCreds -->|Credentials for| S3API
    GitCreds -->|Credentials for| GitAPI

    %% Access enforcement
    NamespaceAccess -->|Permits| OAuthProxy
    SAToken -->|Subject to| K8sRBAC
    K8sRBAC -->|Controls access to| K8sAPI
    AWSCreds -->|Subject to| S3Auth
    S3Auth -->|Controls access to| S3API
    GitCreds -->|Subject to| GitAuth
    GitAuth -->|Controls access to| GitAPI
    SAToken -->|Optional bearer for| ModelRegAPI

    %% Styling
    style User fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style OSUser fill:#6c8ebf,stroke:#333,stroke-width:2px,color:#fff
    style SA fill:#7ed321,stroke:#333,stroke-width:2px
    style SAToken fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthConfig fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuthCookie fill:#f5a623,stroke:#333,stroke-width:2px
    style GitCreds fill:#ff8c00,stroke:#333,stroke-width:2px
    style AWSCreds fill:#ff8c00,stroke:#333,stroke-width:2px
    style DBCreds fill:#ff8c00,stroke:#333,stroke-width:2px
    style NamespaceAccess fill:#9370db,stroke:#333,stroke-width:2px,color:#fff
    style K8sRBAC fill:#9370db,stroke:#333,stroke-width:2px,color:#fff
    style S3Auth fill:#9370db,stroke:#333,stroke-width:2px,color:#fff
    style GitAuth fill:#9370db,stroke:#333,stroke-width:2px,color:#fff
    style Controller fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookCR fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style S3API fill:#e8e8e8,stroke:#333,stroke-width:2px
    style GitAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ModelRegAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
