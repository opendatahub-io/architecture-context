graph LR
    KServe["<b>KServe Operator</b><br/>Model Serving Platform"]

    subgraph "External Dependencies (Required)"
        Kubernetes["Kubernetes 1.25+<br/>Container Orchestration"]
        CertManager["cert-manager 1.0+<br/>TLS Certificate Mgmt"]
    end

    subgraph "External Dependencies (Conditional)"
        Knative["Knative Serving 1.8+<br/>Serverless Autoscaling<br/>(Serverless Mode)"]
        Istio["Istio 1.17+<br/>Service Mesh<br/>(Serverless Mode)"]
        GatewayAPI["Gateway API v1beta1+<br/>Traffic Routing<br/>(Alternative to Istio)"]
        KEDA["KEDA 2.x<br/>Event-Driven Autoscaling<br/>(Raw Deployment Mode)"]
    end

    subgraph "External Dependencies (Optional)"
        Prometheus["Prometheus 2.x<br/>Metrics Collection"]
        OTel["OpenTelemetry Collector 0.x<br/>Distributed Tracing"]
    end

    subgraph "Internal ODH/RHOAI Dependencies"
        ServiceMesh["Service Mesh (Istio)<br/>mTLS Enforcement<br/>VirtualService, DestinationRule"]
        Authorino["Authorino<br/>Token Authorization<br/>JWT Validation"]
        ModelRegistry["Model Registry<br/>Model Metadata & Versioning<br/>HTTP API"]
        DSPipelines["Data Science Pipelines<br/>ML Pipeline Integration<br/>Auto Deployment"]
        ODHOperator["ODH Operator<br/>Lifecycle Management<br/>DataScienceCluster CRD"]
    end

    subgraph "External Services (Egress)"
        S3["S3 Storage (AWS/MinIO)<br/>443/TCP HTTPS<br/>Model Artifacts"]
        GCS["GCS Storage<br/>443/TCP HTTPS<br/>Model Artifacts"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>Model Artifacts"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>Pre-trained Models"]
    end

    subgraph "Consumed By (Integration Points)"
        Dashboard["ODH Dashboard<br/>UI for InferenceService Mgmt"]
        CLI["kubectl / oc CLI<br/>User Interface"]
        CICD["CI/CD Pipelines<br/>Automated Deployment"]
    end

    %% Required External Dependencies
    KServe -->|"CRD reconciliation<br/>6443/TCP HTTPS<br/>ServiceAccount Token"| Kubernetes
    KServe -->|"TLS cert issuance<br/>Certificate CRD<br/>Webhook server"| CertManager

    %% Conditional External Dependencies
    KServe -->|"Serverless mode<br/>Creates Knative Service CRD<br/>Scale-to-zero"| Knative
    KServe -->|"Serverless mode<br/>Creates VirtualService, DestinationRule<br/>Traffic routing, mTLS"| Istio
    KServe -->|"Alternative routing<br/>HTTPRoute, Gateway CRD<br/>No Istio dependency"| GatewayAPI
    KServe -->|"Raw mode<br/>ScaledObject CRD<br/>Event-driven scaling"| KEDA

    %% Optional External Dependencies
    KServe -->|"Metrics scrape<br/>8080/TCP, 8443/TCP<br/>ServiceMonitor"| Prometheus
    KServe -->|"Trace export<br/>4317/TCP gRPC<br/>Request tracking"| OTel

    %% Internal ODH/RHOAI Dependencies
    KServe -->|"Pod-to-pod mTLS<br/>PeerAuthentication STRICT<br/>Service Identity"| ServiceMesh
    KServe -->|"Inference endpoint auth<br/>AuthorizationPolicy<br/>JWT validation"| Authorino
    KServe -.->|"Model metadata lookup<br/>8080/TCP HTTP<br/>Optional integration"| ModelRegistry
    KServe -.->|"Service Mesh sidecars<br/>Envoy proxy injection"| ServiceMesh

    %% External Services (Egress)
    KServe -->|"Model download<br/>AWS SigV4 / Access Key<br/>storage-initializer"| S3
    KServe -->|"Model download<br/>GCP Service Account<br/>storage-initializer"| GCS
    KServe -->|"Model download<br/>Azure Storage Key<br/>storage-initializer"| Azure
    KServe -->|"HF model download<br/>HF Token (optional)<br/>storage-initializer"| HFHub

    %% Integration Points (Consumed By)
    Dashboard -->|"UI management<br/>Create/Update/Delete InferenceService"| KServe
    DSPipelines -->|"Auto deploy models<br/>InferenceService CR creation<br/>Pipeline step"| KServe
    ODHOperator -->|"Lifecycle mgmt<br/>DataScienceCluster CRD<br/>Install/Upgrade/Delete"| KServe
    CLI -->|"kubectl/oc commands<br/>CR CRUD operations"| KServe
    CICD -->|"GitOps deployment<br/>CI/CD automation"| KServe

