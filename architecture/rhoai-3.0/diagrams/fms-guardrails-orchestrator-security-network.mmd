%% FMS Guardrails Orchestrator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted / Cluster Consumers)"]
        Client["Client Application"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE (Rust/axum)"]
        direction TB
        MainServer["fms-guardrails-orchestr8<br/>8033/TCP HTTP/HTTPS<br/>TLS 1.2+ (rustls/ring)<br/>Modes: Plaintext | TLS | mTLS"]
        HealthSrv["Health Server<br/>8034/TCP HTTP<br/>Plaintext<br/>No Auth"]
    end

    subgraph Backends["BACKEND SERVICES (Internal / Platform-managed)"]
        direction TB

        TGIS["TGIS Generation Server<br/>Default 8033/TCP<br/>gRPC/HTTP2<br/>TLS/mTLS<br/>Client certs"]

        CaikitNLP["Caikit NLP Server<br/>gRPC/HTTP2<br/>TLS/mTLS<br/>Client certs"]

        vLLM["vLLM / OpenAI-compatible<br/>Default 8080/TCP<br/>HTTP/HTTPS<br/>TLS<br/>Bearer token (forwarded)"]

        Detectors["Detector Services<br/>(HAP, toxicity, etc.)<br/>Default 8080/TCP (API)<br/>Default 8081/TCP (Health)<br/>HTTP/HTTPS, TLS/mTLS"]

        Chunkers["Chunker Services<br/>(Caikit-based)<br/>Default 8085/TCP<br/>gRPC/HTTP2<br/>TLS/mTLS, Client certs"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTelCollector["OpenTelemetry Collector<br/>4317/TCP (gRPC)<br/>4318/TCP (HTTP)<br/>OTLP Protocol"]
    end

    %% Ingress flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ (optional)<br/>Auth: Header passthrough<br/>or mTLS client cert"| MainServer
    Client -.->|"HTTP 8034/TCP<br/>Plaintext<br/>No Auth"| HealthSrv

    %% Egress flows
    MainServer -->|"gRPC/HTTP2<br/>TLS/mTLS<br/>Client certs"| TGIS
    MainServer -->|"gRPC/HTTP2<br/>TLS/mTLS<br/>Client certs"| CaikitNLP
    MainServer -->|"HTTP/HTTPS<br/>TLS<br/>Bearer token"| vLLM
    MainServer -->|"HTTP/HTTPS<br/>TLS/mTLS<br/>Client certs"| Detectors
    MainServer -->|"gRPC/HTTP2<br/>TLS/mTLS<br/>Client certs"| Chunkers
    MainServer -->|"OTLP gRPC/HTTP<br/>Traces & Metrics"| OTelCollector

