/*
 * C4 Context Diagram - RHOAI 3.0 Platform
 * Generated by Claude Opus 4.6
 * Source: architecture/rhoai-3.0/PLATFORM.md
 */

workspace {
    model {
        // Users
        admin = person "Platform Admin" "Installs and configures RHOAI platform"
        dataScientist = person "Data Scientist" "Develops ML models, runs experiments, deploys models"
        mlEngineer = person "ML Engineer" "Builds pipelines, manages model lifecycle"
        appDeveloper = person "Application Developer" "Consumes model inference APIs"

        // RHOAI Platform
        rhoai = softwareSystem "Red Hat OpenShift AI 3.0" "Enterprise AI/ML platform on OpenShift" {
            rhodsOperator = container "rhods-operator" "Central lifecycle manager for all RHOAI components. Manages DSC/DSCI CRDs." "Go, OLM Operator"
            dashboard = container "ODH Dashboard" "Primary UI with Module Federation plugins for model registry and GenAI." "TypeScript, React, PatternFly"
            gatewayInfra = container "Gateway Infrastructure" "data-science-gateway (Envoy), kube-auth-proxy (OAuth2/OIDC), EnvoyFilter (ext_authz)" "Gateway API, Go"
            kserveController = container "KServe Controller" "Manages InferenceService, LLMInferenceService, ServingRuntime lifecycle" "Go Operator"
            modelController = container "ODH Model Controller" "Reconciles InferenceServices, creates Routes, AuthPolicies, EnvoyFilters, NIM integration" "Go Controller"
            dspOperator = container "DSP Operator" "Deploys per-namespace DSP stack: API Server, Argo Workflows, ML Metadata" "Go Operator"
            dspServer = container "DSP API Server" "KFP v2 pipeline API (REST/gRPC)" "Go, 8888/HTTP, 8887/gRPC"
            argoWorkflows = container "Argo Workflows" "Workflow execution engine for pipelines" "Go"
            mlMetadata = container "ML Metadata" "Pipeline metadata storage (50+ RPC methods)" "C++, gRPC/8080"
            notebookController = container "ODH Notebook Controller" "Notebook pod lifecycle, HTTPRoute creation, kube-rbac-proxy injection" "Go Controller"
            trainingOperator = container "Training Operator" "Distributed ML training (PyTorchJob, TFJob, etc.)" "Go Operator"
            kuberay = container "KubeRay Operator" "Ray distributed computing (RayCluster, RayJob, RayService)" "Go Operator"
            trustyaiOperator = container "TrustyAI Operator" "Manages TrustyAI, LM Eval, Guardrails deployments" "Go Operator"
            trustyaiService = container "TrustyAI Service" "Fairness metrics, drift detection, explainability" "Java, Quarkus, 8080/HTTP"
            guardrailsOrchestrator = container "Guardrails Orchestrator" "LLM safety guardrails orchestration with detectors" "Rust, 8033/HTTP"
            modelRegistryOperator = container "Model Registry Operator" "Deploys Model Registry instances with kube-rbac-proxy" "Go Operator"
            modelRegistry = container "Model Registry" "ML model metadata REST/gRPC API" "Go, 8080/HTTP, 9090/gRPC"
            feastOperator = container "Feast Operator" "Feature store operator (FeatureStore CRD)" "Go Operator"
            llamaStackOperator = container "Llama Stack Operator" "AI agent deployment (LlamaStackDistribution CRD)" "Go Operator"
            monitoringStack = container "Monitoring Stack" "Prometheus, Thanos, Tempo, OpenTelemetry" "MonitoringStack CRs"
            maas = container "Models-as-a-Service" "Kuadrant-integrated API gateway for model serving" "Kuadrant, Gateway API"

            // Inference Runtimes
            ovms = container "OpenVINO Model Server" "High-performance CPU inference (TFS, KServe v2, OpenAI APIs)" "C++, gRPC+REST"
            vllmCPU = container "vLLM CPU" "LLM inference without GPU (OpenAI + TGIS)" "Python, HTTP+gRPC"
            vllmGaudi = container "vLLM Gaudi" "LLM inference on Intel Gaudi 2/3" "Python, HTTP+gRPC"
            tgis = container "Text Generation Inference" "IBM TGIS LLM inference server" "Rust/Python, gRPC+HTTP"
            llmdEPP = container "llm-d EPP" "Endpoint picker for prefill/decode disaggregated routing" "Go, 9002/gRPC, 5557/ZMQ"
            llmdSidecar = container "llm-d Routing Sidecar" "P/D routing with SSRF protection" "Go, 8000/HTTPS"
        }

        // External Dependencies
        ocp = softwareSystem "OpenShift Container Platform" "Kubernetes platform (v4.19, v4.20)" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator deployment and lifecycle" "External"
        istio = softwareSystem "OpenShift Service Mesh / Istio" "Service mesh, Envoy proxy, EnvoyFilters" "External"
        gatewayController = softwareSystem "OpenShift Gateway Controller" "Kubernetes Gateway API implementation" "External"
        kuadrant = softwareSystem "Kuadrant" "API management and auth policies for Gateway API" "External"
        certManager = softwareSystem "cert-manager / service-ca" "TLS certificate provisioning" "External"
        kueue = softwareSystem "Kueue" "Workload scheduling and quotas" "External"

        // External Services
        s3 = softwareSystem "S3-compatible Storage" "Model artifact and pipeline artifact storage (AWS S3, MinIO)" "External Service"
        database = softwareSystem "Database (MariaDB/PostgreSQL)" "Pipeline metadata, model registry, TrustyAI persistence" "External Service"
        huggingface = softwareSystem "HuggingFace Hub" "Model download repository" "External Service"
        nvidia = softwareSystem "NVIDIA NGC API" "NIM API key validation and model catalog" "External Service"
        oauthServer = softwareSystem "OpenShift OAuth / OIDC Provider" "User authentication" "External Service"
        registry = softwareSystem "Container Registry (registry.redhat.io)" "73 container images, UBI9 base" "External Service"

        // Relationships - Users
        admin -> rhoai "Installs, configures platform via DSC/DSCI CRs"
        dataScientist -> dashboard "Creates notebooks, deploys models, monitors fairness"
        mlEngineer -> dashboard "Creates pipelines, manages model registry"
        appDeveloper -> gatewayInfra "Sends inference requests via HTTPS/443"

        // Internal relationships
        rhodsOperator -> dashboard "Deploys via kustomize"
        rhodsOperator -> kserveController "Deploys via kustomize"
        rhodsOperator -> modelController "Deploys via kustomize"
        rhodsOperator -> dspOperator "Deploys via kustomize"
        rhodsOperator -> notebookController "Deploys via kustomize"
        rhodsOperator -> trainingOperator "Deploys via kustomize"
        rhodsOperator -> kuberay "Deploys via kustomize"
        rhodsOperator -> trustyaiOperator "Deploys via kustomize"
        rhodsOperator -> modelRegistryOperator "Deploys via kustomize"
        rhodsOperator -> feastOperator "Deploys via kustomize"
        rhodsOperator -> llamaStackOperator "Deploys via kustomize"
        rhodsOperator -> gatewayInfra "Creates Gateway, kube-auth-proxy, EnvoyFilter"
        rhodsOperator -> monitoringStack "Creates MonitoringStack, Thanos, Tempo, OTEL"
        rhodsOperator -> maas "Deploys MaaS components"

        dspOperator -> dspServer "Deploys per-DSPA namespace"
        dspOperator -> argoWorkflows "Deploys per-DSPA namespace"
        dspOperator -> mlMetadata "Deploys per-DSPA namespace"

        trustyaiOperator -> trustyaiService "Deploys per-namespace"
        trustyaiOperator -> guardrailsOrchestrator "Deploys per-namespace"

        modelRegistryOperator -> modelRegistry "Deploys with kube-rbac-proxy"

        kserveController -> ovms "Manages runtimes"
        kserveController -> vllmCPU "Manages runtimes"
        kserveController -> vllmGaudi "Manages runtimes"
        kserveController -> tgis "Manages runtimes"
        kserveController -> llmdEPP "Manages disaggregated inference"

        dashboard -> monitoringStack "Queries Thanos for metrics" "HTTPS/9092"
        dashboard -> modelRegistry "Model metadata" "HTTP/8080"
        dspServer -> mlMetadata "Pipeline metadata" "gRPC/8080"
        trustyaiService -> kserveController "Monitors inference" "HTTP/gRPC"
        modelController -> modelRegistry "Syncs InferenceService state" "HTTPS"

        // External dependencies
        rhodsOperator -> ocp "Deploys on" "HTTPS/6443"
        rhodsOperator -> olm "Installed via" "OLM"
        gatewayInfra -> gatewayController "Uses" "Gateway API"
        gatewayInfra -> istio "EnvoyFilters" "gRPC"
        maas -> kuadrant "Auth policies" "Gateway API"
        kserveController -> istio "Service mesh" "gRPC"
        trainingOperator -> kueue "Workload scheduling"

        // External services
        gatewayInfra -> oauthServer "User authentication" "HTTPS/443"
        dspServer -> s3 "Artifact storage" "HTTPS/443"
        dspServer -> database "Pipeline persistence" "SQL/3306,5432"
        mlMetadata -> database "Metadata persistence" "SQL/3306,5432"
        modelRegistry -> database "Registry persistence" "SQL/5432,3306"
        ovms -> s3 "Model download" "HTTPS/443"
        ovms -> huggingface "Model download" "HTTPS/443"
        vllmCPU -> s3 "Model download" "HTTPS/443"
        vllmCPU -> huggingface "Model download" "HTTPS/443"
        vllmGaudi -> huggingface "Model download" "HTTPS/443"
        modelController -> nvidia "NIM validation" "HTTPS/443"
        rhodsOperator -> registry "Image pulls" "HTTPS/443"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #d32f2f
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
