%% RBAC Visualization for kube-auth-proxy
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.0/kube-auth-proxy.md

graph TD
    subgraph "Authentication & Authorization Model"
        direction TB

        subgraph AuthModeRBAC["Auth Mode (kube-auth-proxy)"]
            direction TB
            AuthSA["ServiceAccount<br/>(configured by deployer)"]
            AuthEndpoints["Protected Endpoints<br/>/* on 4180/TCP"]

            subgraph AuthMechanisms["Authentication Mechanisms"]
                OIDCAuth["OIDC Provider<br/>OAuth2 Code Flow<br/>Cookie Session"]
                OSAuth["OpenShift OAuth<br/>OAuth2 Code Flow<br/>Cookie Session"]
                BearerAuth["Bearer JWT<br/>Token Validation"]
                ExtAuthz["Envoy ext_authz<br/>/oauth2/auth<br/>202/401 response"]
            end

            subgraph NoAuthEndpoints["No Auth Required"]
                Ping["/ping<br/>Liveness"]
                Ready["/ready<br/>Readiness"]
                SignIn["/oauth2/sign_in<br/>Login page"]
                Start["/oauth2/start<br/>OAuth initiation"]
            end

            AuthEndpoints --> OIDCAuth
            AuthEndpoints --> OSAuth
            AuthEndpoints --> BearerAuth
            ExtAuthz -->|"checks"| AuthEndpoints
        end

        subgraph RBACModeRBAC["RBAC Mode (kube-rbac-proxy)"]
            direction TB
            RBACSA["ServiceAccount<br/>(needs SubjectAccessReview<br/>create permission)"]
            RBACEndpoints["Protected Endpoints<br/>/* on 8443/TCP HTTPS"]

            subgraph SARFlow["SubjectAccessReview Flow"]
                CallerToken["Caller Bearer Token"]
                SARCheck["SubjectAccessReview<br/>via Kubernetes API<br/>HTTPS/443"]
                SARResult["Allowed / Denied"]
            end

            RBACSA -->|"creates SAR using<br/>own SA token"| SARCheck
            RBACEndpoints --> CallerToken
            CallerToken -->|"validated via"| SARCheck
            SARCheck --> SARResult
        end
    end

    subgraph Secrets["Secrets (provisioned by deployer)"]
        CookieSecret["kube-auth-proxy-secret<br/>(Opaque)<br/>cookie-secret: session encryption<br/>client-secret: OIDC (optional)<br/>No auto-rotate"]
        TLSSecret["TLS cert/key<br/>(kubernetes.io/tls)<br/>HTTPS listener<br/>cert-manager rotation"]
        SAToken["ServiceAccount Token<br/>(kubernetes.io/service-account-token)<br/>OpenShift OAuth credentials<br/>Auto-rotated by K8s"]
        JWTKey["JWT signing key<br/>(Opaque)<br/>Optional, embedded placeholder<br/>No auto-rotate"]
    end

    subgraph FIPSCompliance["FIPS Compliance"]
        FIPS["Build Flags:<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>-tags strictfipsruntime<br/><br/>Base: ubi9/ubi-minimal<br/>Build: ubi9/go-toolset:1.24<br/>Validation: check-payload"]
    end

    AuthSA -.->|"uses"| CookieSecret
    AuthSA -.->|"uses"| TLSSecret
    AuthSA -.->|"auto-mounted"| SAToken
    RBACSA -.->|"uses"| TLSSecret

    style AuthSA fill:#4a90e2,color:#fff
    style RBACSA fill:#4a90e2,color:#fff
    style OIDCAuth fill:#5dade2
    style OSAuth fill:#5dade2
    style BearerAuth fill:#5dade2
    style ExtAuthz fill:#5dade2
    style CallerToken fill:#f5a623
