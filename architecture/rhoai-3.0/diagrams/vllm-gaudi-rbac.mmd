%% RBAC Visualization for vLLM Gaudi
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Container Security Context"
        Container["vLLM Gaudi Container<br/>UID: 2000 (user: vllm)<br/>GID: 0 (root group)<br/>Non-root execution"]
    end

    subgraph "RBAC (Managed by KServe/RHOAI Operator)"
        Note1["No RBAC roles defined<br/>by this component directly"]
        KServeRBAC["KServe manages RBAC<br/>for serving runtime pods"]
        RHOAIOperator["RHOAI Operator manages<br/>namespace-level permissions"]
    end

    subgraph "Authentication Mechanisms"
        subgraph "HTTP API (Port 8000)"
            V1Auth["/v1/* endpoints<br/>Bearer Token (optional)<br/>via --api-key or VLLM_API_KEY<br/>FastAPI middleware<br/>401 if token set & missing"]
            PublicEP["/health, /metrics, /version<br/>/tokenize, /detokenize<br/>No auth enforced"]
        end

        subgraph "gRPC API (Port 8033)"
            GRPCAuth["TGIS GenerationService<br/>No built-in auth<br/>Relies on network-level security"]
        end
    end

    subgraph "Secrets"
        SSLSecret["SSL key/cert<br/>Type: kubernetes.io/tls<br/>Purpose: TLS for API server<br/>Provisioned by: User/Operator<br/>Auto-rotate: Yes (SSLCertRefresher)"]
        APIKeySecret["API key<br/>Type: Opaque<br/>Purpose: Bearer token auth<br/>Provisioned by: User/Operator<br/>Auto-rotate: No"]
        HFTokenSecret["HuggingFace token<br/>Type: Opaque<br/>Purpose: Model download auth<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    subgraph "Security Features"
        FIPS["FIPS Compliant<br/>(enabled operator feature)"]
        Disconnected["Disconnected Support<br/>HF_HUB_OFFLINE=1"]
        NoStats["Usage Stats Disabled<br/>VLLM_NO_USAGE_STATS=1"]
    end

    Container -->|"uses"| SSLSecret
    Container -->|"uses"| APIKeySecret
    Container -.->|"uses (if needed)"| HFTokenSecret
    KServeRBAC -->|"grants permissions to"| Container
    RHOAIOperator -->|"configures"| KServeRBAC
    V1Auth -->|"validates against"| APIKeySecret
    SSLSecret -->|"loaded by"| Container

