graph LR
    TrainingOp[Kubeflow Training Operator]

    %% External Dependencies (Required)
    TrainingOp -->|container orchestration| K8s[Kubernetes 1.27+]

    %% External Dependencies (Optional)
    TrainingOp -.->|webhook certs| CertManager[cert-manager]
    TrainingOp -.->|gang scheduling| Volcano[Volcano Scheduler]
    TrainingOp -.->|gang scheduling alt| SchedPlugins[scheduler-plugins]
    TrainingOp -.->|metrics scraping| Prometheus[Prometheus]

    %% Internal ODH Dependencies
    ODHOperator[opendatahub-operator] -->|deploys| TrainingOp
    Dashboard[ODH Dashboard] -->|UI integration| TrainingOp

    %% Kubernetes Sub-components
    TrainingOp -->|REST API| K8sAPI[Kubernetes API Server]
    TrainingOp -->|schedules pods| K8sScheduler[Kubernetes Scheduler]
    Volcano -.->|extends| K8sScheduler
    SchedPlugins -.->|extends| K8sScheduler

    %% External Services (Used by Training Pods)
    TrainingOp -->|creates pods| TrainingPods[Training Job Pods]
    TrainingPods -->|pull images| Registry[Container Registries<br/>quay.io, registry.redhat.io]
    TrainingPods -->|data/checkpoints| S3[S3 / Object Storage]

    %% CRDs Watched/Created
    subgraph CRDs["Custom Resources"]
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob<br/>kubeflow.org/v1]
        JAXJob[JAXJob<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob<br/>kubeflow.org/v1]
        PodGroup[PodGroup<br/>scheduling.volcano.sh/v1beta1<br/>scheduling.x-k8s.io/v1alpha1]
        HPA[HorizontalPodAutoscaler<br/>autoscaling/v2]
    end

    TrainingOp -->|watches/reconciles| PyTorchJob
    TrainingOp -->|watches/reconciles| TFJob
    TrainingOp -->|watches/reconciles| MPIJob
    TrainingOp -->|watches/reconciles| XGBoostJob
    TrainingOp -->|watches/reconciles| JAXJob
    TrainingOp -->|watches/reconciles| PaddleJob
    TrainingOp -.->|creates optional| PodGroup
    TrainingOp -.->|creates elastic| HPA

    %% Created Kubernetes Resources
    subgraph K8sResources["Kubernetes Resources Created"]
        Pods[Pods<br/>Master/Workers/PS]
        Services[ClusterIP Services<br/>Pod Discovery]
        ConfigMaps[ConfigMaps]
        Secrets[Secrets]
        ServiceAccounts[ServiceAccounts]
        Roles[Roles/RoleBindings]
    end

    TrainingOp -->|creates/manages| Pods
    TrainingOp -->|creates/manages| Services
    TrainingOp -->|creates/manages| ConfigMaps
    TrainingOp -->|watches| Secrets
    TrainingOp -->|creates/manages| ServiceAccounts
    TrainingOp -->|creates/manages| Roles

    %% Python SDK
    PythonSDK[Python SDK<br/>kubeflow-training<br/>PyPI] -->|creates jobs| PyTorchJob
    PythonSDK -->|creates jobs| TFJob
    PythonSDK -->|creates jobs| MPIJob

    %% Styling
    style TrainingOp fill:#4a90e2,stroke:#333,stroke-width:4px

    %% External - Required
    style K8s fill:#ff9800,stroke:#333,stroke-width:2px
    style K8sAPI fill:#ff9800,stroke:#333
    style K8sScheduler fill:#ff9800,stroke:#333

    %% External - Optional
    style CertManager fill:#cccccc,stroke:#333,stroke-dasharray: 5 5
    style Volcano fill:#cccccc,stroke:#333,stroke-dasharray: 5 5
    style SchedPlugins fill:#cccccc,stroke:#333,stroke-dasharray: 5 5
    style Prometheus fill:#cccccc,stroke:#333,stroke-dasharray: 5 5

    %% Internal ODH
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px

    %% External Services
    style Registry fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333

    %% CRDs
    style PyTorchJob fill:#e1f5fe,stroke:#0277bd
    style TFJob fill:#e1f5fe,stroke:#0277bd
    style MPIJob fill:#e1f5fe,stroke:#0277bd
    style XGBoostJob fill:#e1f5fe,stroke:#0277bd
    style JAXJob fill:#e1f5fe,stroke:#0277bd
    style PaddleJob fill:#e1f5fe,stroke:#0277bd
    style PodGroup fill:#fff9c4,stroke:#f57f17,stroke-dasharray: 5 5
    style HPA fill:#fff9c4,stroke:#f57f17,stroke-dasharray: 5 5

    %% K8s Resources
    style Pods fill:#e8f5e9,stroke:#2e7d32
    style Services fill:#e8f5e9,stroke:#2e7d32
    style ConfigMaps fill:#e8f5e9,stroke:#2e7d32
    style Secrets fill:#e8f5e9,stroke:#2e7d32
    style ServiceAccounts fill:#e8f5e9,stroke:#2e7d32
    style Roles fill:#e8f5e9,stroke:#2e7d32

    %% Managed
    style TrainingPods fill:#b39ddb,stroke:#4527a0

    %% SDK
    style PythonSDK fill:#fff3e0,stroke:#e65100
