%% RBAC & Security Visualization - Text Generation Inference Server (TGIS)
%% Generated by: Claude Opus 4.6
%% Note: TGIS does not define RBAC resources. This diagram shows container security and auth.

graph TD
    subgraph ContainerSecurity["Container Security Context"]
        SecurityCtx["Security Settings"]
        NonRoot["runAsNonRoot: true<br/>User: tgis (UID 2000)"]
        NoCaps["capabilities: drop ALL"]
        NoPrivEsc["allowPrivilegeEscalation: false"]
        NotPriv["privileged: false"]
        Seccomp["seccompProfile: RuntimeDefault"]
        ReadOnly["readOnlyRootFilesystem: true<br/>(optional patch)"]

        SecurityCtx --> NonRoot
        SecurityCtx --> NoCaps
        SecurityCtx --> NoPrivEsc
        SecurityCtx --> NotPriv
        SecurityCtx --> Seccomp
        SecurityCtx --> ReadOnly
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        subgraph GRPCAuth["gRPC Endpoint (8033/TCP)"]
            TLSConfig["TLS Encryption<br/>(optional via TLS_CERT_PATH)"]
            MTLSConfig["mTLS Client Auth<br/>(optional via TLS_CLIENT_CA_CERT_PATH)"]
            TLSConfig --> MTLSConfig
        end

        subgraph HTTPAuth["HTTP Endpoint (3000/TCP)"]
            NoAuth["No Authentication<br/>/health, /metrics<br/>Internal use only"]
        end
    end

    subgraph Secrets["Secrets"]
        TLSCert["TLS cert/key<br/>Type: kubernetes.io/tls<br/>Purpose: gRPC server TLS<br/>Mount: TLS_CERT_PATH, TLS_KEY_PATH<br/>Auto-Rotate: No"]
        ClientCA["TLS client CA cert<br/>Type: Opaque<br/>Purpose: mTLS client verification<br/>Mount: TLS_CLIENT_CA_CERT_PATH<br/>Auto-Rotate: No"]
    end

    subgraph RBAC["RBAC"]
        NoRBAC["No RBAC Resources Defined<br/>TGIS runs as a non-privileged<br/>workload container"]
    end

    %% Connections
    TLSCert -->|"mounted as"| TLSConfig
    ClientCA -->|"mounted as"| MTLSConfig

