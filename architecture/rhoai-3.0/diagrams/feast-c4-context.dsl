// Feast Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates FeatureStore CRs and queries features from ML applications"
        admin = person "Platform Admin" "Deploys and manages the Feast Operator via rhods-operator"

        feastOperator = softwareSystem "Feast Operator" "Manages lifecycle of Feast feature store deployments on Kubernetes/OpenShift" {
            controller = container "feast-operator-controller-manager" "Reconciles FeatureStore CRs; creates Deployments, Services, ConfigMaps, PVCs, RBAC, CronJobs, Routes" "Go Operator (controller-runtime)"
            onlineServer = container "Online Feature Server" "Serves online features via HTTP/HTTPS" "Python 3.11"
            offlineServer = container "Offline Feature Server" "Serves offline features via HTTP/HTTPS" "Python 3.11"
            registryServer = container "Registry Server" "Serves feature registry via gRPC and REST" "Python 3.11"
            uiServer = container "Feast UI" "Web UI for browsing feature store" "Python 3.11"
            cronJob = container "CronJob" "Executes feast apply and materialize-incremental" "ose-cli Container"
            namespaceRegistry = container "Namespace Registry" "Tracks deployed FeatureStore instances across namespaces" "ConfigMap"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys Feast Operator via kustomize overlays" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "Infrastructure"
        openshiftAPI = softwareSystem "OpenShift API Server" "OpenShift extensions (Routes, Service CA)" "Infrastructure"
        trustedCA = softwareSystem "odh-trusted-ca-bundle" "Custom CA bundle for TLS trust" "Internal ODH"

        externalDB = softwareSystem "External DB Stores" "Snowflake, PostgreSQL, Redis - feature persistence backends" "External"
        gitRepos = softwareSystem "External Git Repositories" "Feature repository source code" "External"

        // System-level relationships
        user -> feastOperator "Creates FeatureStore CRs via kubectl, queries features from ML apps"
        admin -> rhodsOperator "Manages RHOAI platform deployment"
        rhodsOperator -> feastOperator "Deploys via kustomize overlay"

        feastOperator -> k8sAPI "Resource CRUD, leader election, RBAC, TokenReview" "HTTPS/443"
        feastOperator -> openshiftAPI "Route creation for UI services" "HTTPS/443"
        feastOperator -> externalDB "Feature store persistence (offline/online/registry)" "Various protocols"
        feastOperator -> gitRepos "Git clone for feature repo initialization" "HTTPS/443"
        trustedCA -> feastOperator "Custom CA bundle mounted into Feast pods"

        // Container-level relationships
        user -> controller "Creates FeatureStore CR" "kubectl / HTTPS"
        controller -> k8sAPI "Watches CRs, creates resources" "HTTPS/443 TLS 1.2+"
        controller -> openshiftAPI "Creates Routes" "HTTPS/443 TLS 1.2+"

        user -> onlineServer "Queries online features" "HTTPS/443 K8s RBAC or OIDC"
        user -> offlineServer "Queries offline features" "HTTPS/443 K8s RBAC or OIDC"
        user -> uiServer "Browses feature store" "HTTPS/443"

        onlineServer -> registryServer "Fetches feature metadata" "gRPC/REST"
        offlineServer -> registryServer "Fetches feature metadata" "gRPC/REST"
        onlineServer -> externalDB "Reads/writes feature values" "Various"
        offlineServer -> externalDB "Reads feature values" "Various"
        cronJob -> onlineServer "kubectl exec: feast apply/materialize" "Pod exec"

        onlineServer -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
        offlineServer -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
        registryServer -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
    }

    views {
        systemContext feastOperator "SystemContext" {
            include *
            autoLayout
        }

        container feastOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #9b59b6
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #e8e8e8
                color #333333
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
