graph TB
    subgraph "Notebook Controller Component"
        NotebookReconciler[NotebookReconciler<br/>Main Controller]
        CullingReconciler[CullingReconciler<br/>Idle Notebook Culler]
        MetricsCollector[Metrics Collector<br/>Prometheus Exporter]
        HealthProbes[Health/Readiness Probes<br/>:8081/healthz, /readyz]
        VSGenerator[VirtualService Generator<br/>Istio Integration]
        EventRecorder[Event Recorder<br/>Event Propagation]

        NotebookReconciler -->|manages| StatefulSet
        NotebookReconciler -->|creates| Service
        NotebookReconciler -->|creates when USE_ISTIO=true| VSGenerator
        NotebookReconciler -->|propagates events| EventRecorder
        CullingReconciler -->|polls /api/kernels| NotebookPods
        CullingReconciler -->|adds STOP_ANNOTATION| NotebookCR
    end

    subgraph "Custom Resources"
        NotebookCR[Notebook CR<br/>kubeflow.org/v1]
        NotebookCR_v1beta1[Notebook CR<br/>kubeflow.org/v1beta1]
        NotebookCR_v1alpha1[Notebook CR<br/>kubeflow.org/v1alpha1]
    end

    subgraph "Kubernetes Resources"
        StatefulSet[StatefulSet<br/>Notebook Instance]
        Service[ClusterIP Service<br/>80→8888]
        NotebookPods[Notebook Pods<br/>Jupyter Server]
        VirtualService[Istio VirtualService<br/>Ingress Routing]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        Istio[Istio Service Mesh<br/>VirtualService CRD]
        Prometheus[Prometheus<br/>Metrics Scraping]
    end

    subgraph "Internal ODH Dependencies"
        JupyterWebApp[jupyter-web-app<br/>UI for Notebook Creation]
        ODHDashboard[odh-dashboard<br/>Status Monitoring]
        NotebookImages[notebook-images<br/>Container Images]
    end

    %% User interactions
    User[User] -->|creates via UI| JupyterWebApp
    JupyterWebApp -->|creates| NotebookCR

    %% Controller watches
    NotebookCR -->|watched by| NotebookReconciler
    NotebookCR_v1beta1 -.->|legacy API| NotebookReconciler
    NotebookCR_v1alpha1 -.->|alpha API| NotebookReconciler

    %% Kubernetes API interactions
    NotebookReconciler -->|CRUD operations| K8sAPI
    CullingReconciler -->|updates via| K8sAPI
    K8sAPI -->|manages| StatefulSet
    K8sAPI -->|manages| Service
    StatefulSet -->|creates| NotebookPods

    %% Istio integration
    VSGenerator -->|creates| VirtualService
    VirtualService -->|routes to| Service
    Service -->|exposes| NotebookPods

    %% Monitoring
    MetricsCollector -->|exposes :8080/metrics| Prometheus
    ODHDashboard -->|reads status| NotebookCR

    %% Image reference
    NotebookPods -.->|uses images from| NotebookImages

    %% Istio dependency
    VirtualService -.->|requires| Istio

    style NotebookReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style CullingReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Istio fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#333,stroke-width:2px
    style JupyterWebApp fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHDashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookImages fill:#7ed321,stroke:#333,stroke-width:2px
