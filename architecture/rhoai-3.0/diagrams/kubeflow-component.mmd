graph TB
    subgraph "Notebook Controller Component"
        NotebookReconciler[NotebookReconciler<br/>Main Controller]
        CullingReconciler[CullingReconciler<br/>Optional Idle Culler]
        MetricsCollector[Metrics Collector<br/>Prometheus Exporter]
        HealthProbes[Health/Readiness Probes<br/>/healthz /readyz]
        VirtualServiceGen[VirtualService Generator<br/>Istio Integration]
        EventRecorder[Event Recorder<br/>Event Propagation]

        NotebookReconciler -->|emits metrics| MetricsCollector
        NotebookReconciler -->|records events| EventRecorder
        NotebookReconciler -->|creates when USE_ISTIO=true| VirtualServiceGen
    end

    subgraph "Custom Resources"
        NotebookCR[Notebook CR<br/>kubeflow.org/v1]
        NotebookCRBeta[Notebook CR<br/>kubeflow.org/v1beta1]
        NotebookCRAlpha[Notebook CR<br/>kubeflow.org/v1alpha1]
    end

    subgraph "Managed Resources"
        StatefulSet[StatefulSet<br/>Notebook Instance]
        Service[ClusterIP Service<br/>Port 80→8888]
        VirtualService[Istio VirtualService<br/>External Ingress]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        Istio[Istio Control Plane<br/>Optional]
        Prometheus[Prometheus<br/>Optional]
    end

    subgraph "Internal ODH Dependencies"
        JupyterWebApp[jupyter-web-app<br/>UI for Notebook Creation]
        ODHDashboard[odh-dashboard<br/>Status Monitoring]
        NotebookImages[notebook-images<br/>Container Images]
    end

    %% User interactions
    User[User/Data Scientist] -->|creates via UI| JupyterWebApp
    JupyterWebApp -->|creates| NotebookCR
    User -->|kubectl create| NotebookCR

    %% Controller watches CRs
    NotebookCR -->|watched by| NotebookReconciler
    NotebookCRBeta -.->|backward compat| NotebookCR
    NotebookCRAlpha -.->|backward compat| NotebookCR

    %% Controller creates resources
    NotebookReconciler -->|creates/updates| StatefulSet
    NotebookReconciler -->|creates| Service
    NotebookReconciler -->|updates status| NotebookCR
    VirtualServiceGen -->|creates| VirtualService

    %% Culling controller
    CullingReconciler -->|watches| NotebookCR
    CullingReconciler -->|polls /api/kernels| StatefulSet
    CullingReconciler -->|adds STOP_ANNOTATION| NotebookCR

    %% External integrations
    NotebookReconciler -->|CRUD operations| K8sAPI
    CullingReconciler -->|CRUD operations| K8sAPI
    VirtualServiceGen -->|creates VirtualService| Istio
    MetricsCollector -->|exposes metrics| Prometheus

    %% Internal integrations
    ODHDashboard -->|reads status| NotebookCR
    StatefulSet -->|uses images from| NotebookImages

    style NotebookReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style CullingReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style Prometheus fill:#999,stroke:#333,stroke-width:2px
    style JupyterWebApp fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHDashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookImages fill:#7ed321,stroke:#333,stroke-width:2px
