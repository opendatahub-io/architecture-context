    %% Connections - Namespace Role Permissions
    RB1 -.->|grants| NR_Accel
    RB1 -.->|grants| NR_Config
    RB1 -.->|grants| NR_Apps
    RB1 -.->|grants| NR_Docs
    RB1 -.->|grants| NR_QuickStarts
