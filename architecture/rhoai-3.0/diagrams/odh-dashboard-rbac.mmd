        NSNotebooks["kubeflow.org<br/>notebooks<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OdhApps["dashboard.opendatahub.io<br/>odhapplications<br/>Verbs: get, list"]
        OdhDocs["dashboard.opendatahub.io<br/>odhdocuments<br/>Verbs: get, list"]
        QuickStarts["console.openshift.io<br/>odhquickstarts<br/>Verbs: get, list"]
        Templates["template.openshift.io<br/>templates<br/>Verbs: * (all)"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes<br/>Verbs: * (all)"]
        NIMAccounts["nim.opendatahub.io<br/>accounts<br/>Verbs: get, list, watch, create, update, patch, delete"]
    end

