graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: opendatahub or<br/>redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard]
        CRB2[odh-dashboard-auth-delegator<br/>Namespace: kube-system]
        CRB3[odh-dashboard-cluster-monitoring-view<br/>Namespace: openshift-monitoring]
        CRB4[odh-dashboard-image-puller<br/>All user namespaces]
        CRB5[odh-dashboard-model-serving-view<br/>All user namespaces]
    end

    subgraph "Roles"
        CR[odh-dashboard<br/>ClusterRole]
        NR[odh-dashboard<br/>Role - Namespace-scoped]
        AuthDelegator[system:auth-delegator<br/>ClusterRole]
        MonitoringView[cluster-monitoring-view<br/>ClusterRole]
        ImagePuller[system:image-puller<br/>ClusterRole]
        ModelServingView[model-serving-view<br/>ClusterRole]
    end

    subgraph "Cluster-scoped API Resources"
        direction TB

        Storage["storage.k8s.io<br/>storageclasses<br/>Verbs: update, patch"]
        Nodes["core<br/>nodes<br/>Verbs: get, list"]
        MachineAS["machine.openshift.io<br/>autoscaling.openshift.io<br/>machineautoscalers, machinesets<br/>Verbs: get, list"]
        ClusterConfig["core, config.openshift.io<br/>clusterversions, ingresses<br/>Verbs: get, watch, list"]
        CSV["operators.coreos.com<br/>clusterserviceversions, subscriptions<br/>Verbs: get, list, watch"]
        ImageStreams["core, image.openshift.io<br/>imagestreams/layers<br/>Verbs: get"]
        ConfigSecrets["core<br/>configmaps, pvcs, secrets<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Routes["route.openshift.io<br/>routes<br/>Verbs: get, list, watch"]
        ConsoleLinks["console.openshift.io<br/>consolelinks<br/>Verbs: get, list, watch"]
        Consoles["operator.openshift.io<br/>consoles<br/>Verbs: get, list, watch"]
        RHMI["core, integreatly.org<br/>rhmis<br/>Verbs: get, watch, list"]
        UsersGroups["user.openshift.io<br/>groups, users<br/>Verbs: get, list, watch"]
        PodsServicesSA["core<br/>pods, serviceaccounts, services<br/>Verbs: get, list, watch"]
        Namespaces["core<br/>namespaces<br/>Verbs: patch"]
        RBAC["rbac.authorization.k8s.io<br/>rolebindings, clusterrolebindings, roles<br/>Verbs: list, get, create, patch, delete"]
        Events["core, events.k8s.io<br/>events<br/>Verbs: get, list, watch"]
        Notebooks["kubeflow.org<br/>notebooks<br/>Verbs: get, list, watch, create, update, patch, delete"]
        DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>Verbs: list, watch, get"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations<br/>Verbs: list, watch, get"]
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>Verbs: get, list, watch"]
        ModelRegistries["modelregistry.opendatahub.io<br/>modelregistries<br/>Verbs: get, list, watch, create, update, patch, delete"]
        Endpoints["core<br/>endpoints<br/>Verbs: get"]
        Auths["services.platform.opendatahub.io<br/>auths<br/>Verbs: get"]
        LlamaStack["llamastack.io<br/>llamastackdistributions<br/>Verbs: get, list, watch"]
        FeatureStores["feast.dev<br/>featurestores<br/>Verbs: get, list, watch"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
    end

    subgraph "Namespace-scoped API Resources"
        direction TB

        AccelProfiles["dashboard.opendatahub.io<br/>acceleratorprofiles<br/>Verbs: create, get, list, update, patch, delete"]
        NSRoutes["route.openshift.io<br/>routes<br/>Verbs: get, list, watch"]
        CronJobs["batch<br/>cronjobs<br/>Verbs: get, update, delete"]
        NSImageStreams["image.openshift.io<br/>imagestreams<br/>Verbs: create, get, list, update, patch, delete"]
