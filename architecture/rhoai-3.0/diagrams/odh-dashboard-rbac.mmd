graph TB
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: opendatahub or<br/>redhat-ods-applications]
    end

    subgraph "ClusterRoleBindings"
        CRB1[odh-dashboard<br/>→ ClusterRole: odh-dashboard]
        CRB2[odh-dashboard-auth-delegator<br/>→ ClusterRole: system:auth-delegator<br/>Namespace: kube-system]
        CRB3[odh-dashboard-cluster-monitoring-view<br/>→ ClusterRole: cluster-monitoring-view<br/>Namespace: openshift-monitoring]
    end

    subgraph "RoleBindings (Namespace-scoped)"
        RB1[odh-dashboard<br/>→ Role: odh-dashboard<br/>Namespace: opendatahub/redhat-ods-applications]
        RB2[odh-dashboard-image-puller<br/>→ ClusterRole: system:image-puller<br/>All user namespaces]
        RB3[odh-dashboard-model-serving-view<br/>→ Role: model-serving-view<br/>All user namespaces]
    end

    subgraph "ClusterRole Permissions"
        direction LR

        subgraph CR_Core["Core Resources (Cluster)"]
            CR_Storage[storage.k8s.io/storageclasses<br/>update, patch]
            CR_Nodes[core/nodes<br/>get, list]
            CR_Machines[machine.openshift.io<br/>autoscaling.openshift.io<br/>machineautoscalers, machinesets<br/>get, list]
            CR_Config[core, config.openshift.io<br/>clusterversions, ingresses<br/>get, watch, list]
            CR_Operators[operators.coreos.com<br/>clusterserviceversions, subscriptions<br/>get, list, watch]
            CR_Images[core, image.openshift.io<br/>imagestreams/layers<br/>get]
            CR_Routes[route.openshift.io/routes<br/>get, list, watch]
            CR_Console[console.openshift.io/consolelinks<br/>operator.openshift.io/consoles<br/>get, list, watch]
            CR_Users[user.openshift.io<br/>groups, users<br/>get, list, watch]
        end

        subgraph CR_K8s["Kubernetes Resources (Cluster)"]
            CR_ConfigMaps[core/configmaps, secrets, pvcs<br/>create, delete, get, list,<br/>patch, update, watch]
            CR_Pods[core/pods, services, serviceaccounts<br/>get, list, watch]
            CR_Namespaces[core/namespaces<br/>patch]
            CR_RBAC[rbac.authorization.k8s.io<br/>rolebindings, clusterrolebindings, roles<br/>list, get, create, patch, delete]
            CR_Events[core, events.k8s.io/events<br/>get, list, watch]
            CR_Endpoints[core/endpoints<br/>get]
            CR_Auth[authentication.k8s.io/tokenreviews<br/>authorization.k8s.io/subjectaccessreviews<br/>create]
        end

        subgraph CR_ODH["ODH CRDs (Cluster)"]
            CR_Notebooks[kubeflow.org/notebooks<br/>get, list, watch, create,<br/>update, patch, delete]
            CR_DSC[datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>list, watch, get]
            CR_DSCI[dscinitialization.opendatahub.io<br/>dscinitializations<br/>list, watch, get]
            CR_KServe[serving.kserve.io/inferenceservices<br/>get, list, watch]
            CR_ModelReg[modelregistry.opendatahub.io<br/>modelregistries<br/>get, list, watch, create,<br/>update, patch, delete]
            CR_Feast[feast.dev/featurestores<br/>get, list, watch]
            CR_Llama[llamastack.io/llamastackdistributions<br/>get, list, watch]
            CR_Services[services.platform.opendatahub.io<br/>auths<br/>get]
        end
    end

    subgraph "Namespace Role Permissions"
        direction LR

        subgraph NR_Dashboard["Dashboard Resources (Namespace)"]
            NR_Accel[dashboard.opendatahub.io<br/>acceleratorprofiles<br/>create, get, list, update,<br/>patch, delete]
            NR_Config[opendatahub.io<br/>odhdashboardconfigs<br/>get, list, watch, create,<br/>update, patch, delete]
            NR_Apps[dashboard.opendatahub.io<br/>odhapplications<br/>get, list]
            NR_Docs[dashboard.opendatahub.io<br/>odhdocuments<br/>get, list]
            NR_QuickStarts[console.openshift.io<br/>odhquickstarts<br/>get, list]
        end

        subgraph NR_Workloads["Workload Resources (Namespace)"]
            NR_Notebooks[kubeflow.org/notebooks<br/>get, list, watch, create,<br/>update, patch, delete]
            NR_Builds[build.openshift.io<br/>builds, buildconfigs<br/>list]
            NR_Images[image.openshift.io/imagestreams<br/>create, get, list, update,<br/>patch, delete]
            NR_Deployments[apps/deployments<br/>patch, update]
            NR_DeployConfigs[apps.openshift.io<br/>deploymentconfigs, deploymentconfigs/instantiate<br/>get, list, watch, create,<br/>update, patch, delete]
            NR_CronJobs[batch/cronjobs<br/>get, update, delete]
        end

        subgraph NR_Serving["Model Serving (Namespace)"]
            NR_Templates[template.openshift.io/templates<br/>all verbs]
            NR_Runtimes[serving.kserve.io/servingruntimes<br/>all verbs]
            NR_NIM[nim.opendatahub.io/accounts<br/>get, list, watch, create,<br/>update, patch, delete]
        end

        subgraph NR_Routes["Routes (Namespace)"]
            NR_RoutesNS[route.openshift.io/routes<br/>get, list, watch]
        end
    end

    %% Connections - Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    SA -->|bound via| RB2
    SA -->|bound via| RB3

