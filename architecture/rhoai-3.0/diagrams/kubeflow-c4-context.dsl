// C4 Context Diagram - ODH Notebook Controller (kubeflow)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and uses Jupyter notebook workbenches via ODH Dashboard"
        platformAdmin = person "Platform Admin" "Deploys and configures RHOAI platform"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends upstream Kubeflow Notebook Controller with OpenShift/RHOAI-specific capabilities including Gateway API ingress, kube-rbac-proxy authentication, network policies, and Elyra pipeline integration" {
            controllerManager = container "ODH Notebook Controller Manager" "Reconciles Notebook CRs to create HTTPRoutes, ReferenceGrants, NetworkPolicies, ServiceAccounts, ConfigMaps, ClusterRoleBindings, and Elyra pipeline secrets" "Go Operator (controller-runtime v0.21.0)"
            mutatingWebhook = container "Notebook Mutating Webhook" "Intercepts Notebook create/update to inject kube-rbac-proxy sidecar, CA certs, ImageStream resolution, pipeline runtime volumes, and proxy env vars" "Admission Webhook (8443/TCP HTTPS)"
            kubeRbacProxy = container "kube-rbac-proxy Sidecar" "Per-notebook authentication sidecar that enforces RBAC via TokenReview/SubjectAccessReview before proxying to the notebook" "odh-kube-auth-proxy Container (8443/TCP HTTPS)"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller that manages Notebook StatefulSet lifecycle" "External"
        dataScienceGateway = softwareSystem "data-science-gateway" "Platform Gateway (Envoy) in openshift-ingress namespace for notebook traffic ingress via Gateway API" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI that creates Notebook CRs with annotations processed by the controller" "Internal RHOAI"
        dspa = softwareSystem "Data Science Pipelines (DSPA)" "DataSciencePipelinesApplication CRDs watched for Elyra pipeline integration" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys the controller using kustomize overlays" "Internal RHOAI"
        openshiftImageStreams = softwareSystem "OpenShift ImageStreams" "Provides notebook container image references via ImageStream tags" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca Operator" "Auto-provisions TLS certificates for webhook and kube-rbac-proxy Services via annotations" "External"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Central API for all resource CRUD operations, TokenReview, SubjectAccessReview" "External"
        openshiftProxy = softwareSystem "OpenShift Cluster Proxy" "Provides HTTP_PROXY/HTTPS_PROXY/NO_PROXY configuration" "External"

        // User interactions
        dataScientist -> odhDashboard "Creates Notebook workbenches via UI"
        odhDashboard -> odhNotebookController "Creates Notebook CRs with annotations"
        dataScientist -> dataScienceGateway "Accesses notebooks via browser (HTTPS/443)"

        // Controller interactions
        odhNotebookController -> kubernetesAPI "CRUD: HTTPRoutes, ReferenceGrants, NetworkPolicies, Services, Secrets, ConfigMaps, CRBs" "HTTPS/443 TLS"
        odhNotebookController -> dataScienceGateway "Creates HTTPRoutes as parent reference" "Gateway API"
        odhNotebookController -> dspa "Reads DSPA CRs for Elyra pipeline config" "HTTPS/443 TLS"
        odhNotebookController -> openshiftImageStreams "Resolves notebook images from ImageStream tags" "HTTPS/443 TLS"
        odhNotebookController -> openshiftProxy "Reads cluster proxy config" "HTTPS/443 TLS"

        // Auth flow
        dataScienceGateway -> kubeRbacProxy "Forwards authenticated requests" "HTTPS/8443 TLS"
        kubeRbacProxy -> kubernetesAPI "TokenReview + SubjectAccessReview" "HTTPS/443 TLS"

        // Webhook flow
        kubernetesAPI -> mutatingWebhook "Calls on Notebook create/update" "HTTPS/443 TLS"

        // Deployment
        platformAdmin -> rhodsOperator "Deploys RHOAI platform"
        rhodsOperator -> odhNotebookController "Deploys via kustomize"

        // Co-controller
        kubeflowNotebookController -> kubernetesAPI "Manages Notebook StatefulSets" "HTTPS/443 TLS"

        // Cert provisioning
        openshiftServiceCA -> odhNotebookController "Provisions TLS certs for webhook and kube-rbac-proxy"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
