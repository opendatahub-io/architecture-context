/* Model Registry - C4 Context Diagram (Structurizr DSL)
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Creates and manages ML models, versions, and artifacts"
        mlEngineer = person "ML Engineer" "Deploys models and manages inference services"

        // Model Registry System
        modelRegistry = softwareSystem "Model Registry" "Centralized metadata repository for managing ML models, versions, artifacts, and serving environments" {
            proxyServer = container "Model Registry Proxy Server" "Core REST API server exposing OpenAPI v1alpha3 endpoints for ML model metadata CRUD operations" "Go REST API (go-chi)" "Service"
            isController = container "InferenceService Controller" "Watches KServe InferenceService CRs, synchronizes state with Model Registry API, manages finalizers" "Go (controller-runtime)" "Controller"
            bff = container "UI Backend-for-Frontend" "API gateway between React frontend and Model Registry/Catalog APIs with Kubernetes auth" "Go HTTP Service" "Service"
            uiFrontend = container "UI Frontend" "Web UI for browsing and managing model registry entries" "React/TypeScript SPA" "Frontend"
            catalogServer = container "Model Catalog Server" "Catalog API for browsing curated model sources (HuggingFace, YAML, database)" "Go REST API" "Service"
            csi = container "CSI Storage Initializer" "KServe init container that resolves model-registry:// URIs to download model artifacts" "Go CLI" "InitContainer"
            asyncUpload = container "Async Upload Job" "Kubernetes Job for asynchronous model artifact upload between storage backends" "Python" "Job"
            embedMD = container "EmbedMD Datastore" "Embedded metadata store using GORM ORM" "Go Library (GORM)" "DataAccess"
        }

        // External Systems
        mysql = softwareSystem "MySQL 8.x" "Primary metadata store backend" "External Database"
        postgresql = softwareSystem "PostgreSQL 13+" "Alternative metadata store and catalog persistence backend" "External Database"
        kserve = softwareSystem "KServe" "Kubernetes-native serverless ML inference platform providing InferenceService CRDs" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Service mesh providing mTLS, traffic routing, and authorization policies" "External Platform"
        k8sApi = softwareSystem "Kubernetes API Server" "Kubernetes cluster API for resource management" "External Platform"
        huggingFace = softwareSystem "HuggingFace" "Public ML model hub for catalog source data" "External Service"
        s3Storage = softwareSystem "Model Artifact Storage (S3/OBC)" "Object storage for ML model artifacts" "External Storage"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External Platform"
        dashboard = softwareSystem "ODH Dashboard" "OpenShift AI Dashboard providing UI for platform management" "Internal RHOAI"

        // User interactions
        dataScientist -> modelRegistry "Registers models, creates versions, uploads artifacts via REST API and UI"
        mlEngineer -> modelRegistry "Manages inference services and serving environments"
        dataScientist -> uiFrontend "Browses and manages model registry via web UI" "HTTPS"

        // Internal container relationships
        uiFrontend -> bff "API calls" "HTTP/HTTPS 8080"
        bff -> proxyServer "Proxies REST API calls" "HTTP 8080 (Istio mTLS)"
        bff -> catalogServer "Catalog queries" "HTTP 8080"
        bff -> k8sApi "User auth verification" "HTTPS 443"
        proxyServer -> embedMD "CRUD operations"
        catalogServer -> embedMD "Catalog persistence"
        embedMD -> mysql "Metadata persistence" "MySQL/3306 TLS 1.2+"
        embedMD -> postgresql "Metadata persistence" "PostgreSQL/5432"
        isController -> proxyServer "Syncs InferenceService state" "HTTP/HTTPS 8080"
        isController -> k8sApi "Watches InferenceService CRs, updates status" "HTTPS 443"
        csi -> proxyServer "Resolves model-registry:// URIs" "HTTP 8080"
        csi -> s3Storage "Downloads model artifacts" "HTTPS 443"
        asyncUpload -> s3Storage "Uploads model artifacts" "HTTPS 443"

        // External system relationships
        modelRegistry -> mysql "Stores metadata" "MySQL/3306 TLS 1.2+"
        modelRegistry -> postgresql "Stores metadata (catalog)" "PostgreSQL/5432"
        modelRegistry -> kserve "Watches InferenceService CRs" "Kubernetes Watch"
        modelRegistry -> istio "mTLS, traffic routing, AuthorizationPolicy" "HTTP 8080"
        modelRegistry -> k8sApi "Resource management, auth verification" "HTTPS 443"
        modelRegistry -> s3Storage "Downloads/uploads model artifacts" "HTTPS 443"
        catalogServer -> huggingFace "Loads catalog source data" "HTTPS 443"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS 8443"
        dashboard -> modelRegistry "Integrates with Model Registry UI" "HTTP/HTTPS"
        kserve -> modelRegistry "Uses CSI storage initializer for model-registry:// URIs"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External Database" {
                background #dae8fc
                shape Cylinder
            }
            element "External Platform" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #fff2cc
            }
            element "External Storage" {
                background #fff2cc
                shape Cylinder
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Service" {
                background #4a90e2
                color #ffffff
            }
            element "Controller" {
                background #4a90e2
                color #ffffff
            }
            element "Frontend" {
                background #4a90e2
                color #ffffff
                shape WebBrowser
            }
            element "InitContainer" {
                background #4a90e2
                color #ffffff
            }
            element "Job" {
                background #4a90e2
                color #ffffff
            }
            element "DataAccess" {
                background #50c878
                color #ffffff
                shape Cylinder
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
