/*
 * C4 Context Diagram for kube-auth-proxy
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/kube-auth-proxy.md
 */

workspace {
    model {
        user = person "User / Browser" "Accesses applications protected by kube-auth-proxy"
        envoyProxy = person "Envoy Proxy" "Gateway API sidecar requesting ext_authz decisions"

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "FIPS-compliant authentication/authorization reverse proxy for RHOAI" {
            entrypoint = container "entrypoint" "Selects between auth and rbac mode based on PROXY_MODE" "Go Binary"
            authProxy = container "kube-auth-proxy" "OAuth2/OIDC authentication proxy with session management and upstream forwarding" "Go Binary" {
                tags "AuthMode"
            }
            rbacProxy = container "kube-rbac-proxy" "Kubernetes RBAC authorization proxy performing SubjectAccessReview checks (v0.19.1)" "Go Binary" {
                tags "RBACMode"
            }
            oidcProvider = component "OIDC Provider Package" "Handles authentication via standards-compliant OIDC providers" "Go Package"
            openshiftProvider = component "OpenShift Provider Package" "Handles authentication via OpenShift internal OAuth with auto-discovery" "Go Package"
            sessionStore = component "Session Store" "Manages authentication sessions via cookies or Redis backend" "Go Package"
            metricsExporter = component "Prometheus Metrics" "Exposes request metrics (total, in-flight, latency)" "Go Package"
        }

        oidcIdP = softwareSystem "OIDC Provider" "External OpenID Connect identity provider" {
            tags "External"
        }
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "OpenShift internal OAuth2 authorization server" {
            tags "OpenShift"
        }
        openshiftAPI = softwareSystem "OpenShift API Server" "OpenShift API for user identity resolution (user.openshift.io/v1)" {
            tags "OpenShift"
        }
        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes API for ServiceAccount validation and SubjectAccessReview" {
            tags "OpenShift"
        }
        redis = softwareSystem "Redis" "Optional session storage for multi-replica deployments" {
            tags "Optional"
        }
        upstreamApp = softwareSystem "Upstream Application" "Target application protected by the proxy" {
            tags "Internal"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "Internal"
        }

        # User interactions
        user -> kubeAuthProxy "Authenticates via OAuth2/OIDC or Bearer token" "HTTPS/443"
        envoyProxy -> kubeAuthProxy "Requests auth decisions via ext_authz" "HTTP/4180"

        # Internal flows
        entrypoint -> authProxy "Routes when PROXY_MODE=auth"
        entrypoint -> rbacProxy "Routes when PROXY_MODE=rbac (default)"
        authProxy -> oidcProvider "Delegates OIDC authentication"
        authProxy -> openshiftProvider "Delegates OpenShift OAuth authentication"
        authProxy -> sessionStore "Manages user sessions"
        authProxy -> metricsExporter "Records request metrics"

        # Egress - auth mode
        kubeAuthProxy -> oidcIdP "Token redemption and user info" "HTTPS/443 TLS 1.2+ OAuth2 Client Credentials"
        kubeAuthProxy -> openshiftOAuth "OAuth authorization and token exchange" "HTTPS/443 TLS 1.2+ OAuth2 Client Credentials"
        kubeAuthProxy -> openshiftAPI "User identity lookup" "HTTPS/443 TLS 1.2+ Bearer Token"

        # Egress - rbac mode
        kubeAuthProxy -> k8sAPI "SubjectAccessReview checks" "HTTPS/443 TLS 1.2+ ServiceAccount Token"

        # Optional / Integration
        kubeAuthProxy -> redis "Session storage (optional)" "TCP/6379 Optional TLS"
        kubeAuthProxy -> upstreamApp "Proxied pre-authenticated requests" "HTTP X-Forwarded-User headers"
        prometheus -> kubeAuthProxy "Scrapes metrics" "HTTP configurable port"
    }

    views {
        systemContext kubeAuthProxy "SystemContext" {
            include *
            autoLayout
        }

        container kubeAuthProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Component" {
                background #85bbf0
                color #000000
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "OpenShift" {
                background #cc0000
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Optional" {
                background #e1d5e7
                color #000000
            }
            element "AuthMode" {
                background #4a90e2
                color #ffffff
            }
            element "RBACMode" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
