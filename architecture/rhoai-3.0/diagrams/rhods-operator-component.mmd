    %% DSC creates component CRDs
    DSCCtrl -->|creates| CompCRDs["Component CRDs<br/>(Dashboard, Kserve, Ray,<br/>Kueue, Workbenches, DSP,<br/>ModelRegistry, TrustyAI,<br/>TrainingOperator, Feast,<br/>LlamaStack, ModelController)"]

