graph TB
    subgraph "RHODS Operator (OpenDataHub Operator)"
        Manager[RHODS Operator Manager<br/>controller-runtime]

        subgraph "Core Controllers"
            DSCCtrl[DataScienceCluster Controller]
            DSCICtrl[DSCInitialization Controller]
            Webhooks[Validating/Mutating Webhooks<br/>9443/TCP HTTPS]
        end

        subgraph "Service Controllers"
            GatewayCtrl[Gateway Service Controller<br/>Deploys GatewayClass, Gateway, EnvoyFilter]
            AuthCtrl[Auth Service Controller]
            MonitoringCtrl[Monitoring Service Controller<br/>Prometheus, Alertmanager]
            CertCtrl[Cert ConfigMap Generator]
        end

        subgraph "Component Controllers"
            DashboardCtrl[Dashboard Controller]
            WorkbenchCtrl[Workbenches Controller]
            PipelineCtrl[DataSciencePipelines Controller]
            KServeCtrl[KServe Controller]
            KueueCtrl[Kueue Controller]
            RayCtrl[Ray Controller]
            TrustyAICtrl[TrustyAI Controller]
            ModelRegCtrl[ModelRegistry Controller]
            TrainingCtrl[TrainingOperator Controller]
            FeastCtrl[FeastOperator Controller]
            LlamaStackCtrl[LlamaStackOperator Controller]
            ModelControllerCtrl[ModelController Controller]
        end

        Manager --> DSCCtrl
        Manager --> DSCICtrl
        Manager --> Webhooks
        Manager --> GatewayCtrl
        Manager --> AuthCtrl
        Manager --> MonitoringCtrl
        Manager --> CertCtrl
        Manager --> DashboardCtrl
        Manager --> WorkbenchCtrl
        Manager --> PipelineCtrl
        Manager --> KServeCtrl
        Manager --> KueueCtrl
        Manager --> RayCtrl
        Manager --> TrustyAICtrl
        Manager --> ModelRegCtrl
        Manager --> TrainingCtrl
        Manager --> FeastCtrl
        Manager --> LlamaStackCtrl
        Manager --> ModelControllerCtrl
    end

    User[User/GitOps] -->|creates| DSCCR[DataScienceCluster CR]
    User -->|creates| DSCICR[DSCInitialization CR]

    DSCCR -->|watched by| DSCCtrl
    DSCICR -->|watched by| DSCICtrl

    DSCCtrl -->|enables/disables| DashboardCtrl
    DSCCtrl -->|enables/disables| WorkbenchCtrl
    DSCCtrl -->|enables/disables| PipelineCtrl
    DSCCtrl -->|enables/disables| KServeCtrl

    DSCICtrl -->|initializes| GatewayCtrl
    DSCICtrl -->|initializes| MonitoringCtrl

    subgraph "Gateway API Infrastructure (openshift-ingress ns)"
        GatewayClass[GatewayClass<br/>data-science-gateway-class]
        Gateway[Gateway<br/>data-science-gateway<br/>443/TCP HTTPS]
        EnvoyFilter[EnvoyFilter<br/>authn-filter<br/>ext_authz]
        KubeAuthProxy[kube-auth-proxy Deployment<br/>4180/TCP HTTP, 8443/TCP HTTPS]
        OAuthClient[OAuthClient<br/>odh]
    end

    GatewayCtrl -->|creates| GatewayClass
    GatewayCtrl -->|creates| Gateway
    GatewayCtrl -->|creates| EnvoyFilter
    GatewayCtrl -->|creates| KubeAuthProxy
    GatewayCtrl -->|creates| OAuthClient

    subgraph "Component Resources"
        HTTPRoutes[HTTPRoute CRs<br/>per workload]
        KubeRBACProxy[kube-rbac-proxy sidecars<br/>injected per workload]
    end

    WorkbenchCtrl -->|creates| HTTPRoutes
    WorkbenchCtrl -->|injects| KubeRBACProxy
    DashboardCtrl -->|creates| HTTPRoutes

    HTTPRoutes -->|references| Gateway

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP]
        IngressController[OpenShift Ingress Controller]
        OAuth[OpenShift OAuth Server<br/>IntegratedOAuth mode]
        OIDC[External OIDC Provider<br/>ROSA/OIDC mode]
        Prometheus[Prometheus Operator]
        Istio[Istio/Service Mesh]
        Quay[quay.io, registry.redhat.io<br/>Container Registries]
    end

    Manager -->|API operations| K8sAPI
    GatewayCtrl -->|provisions gateway| IngressController
    KubeAuthProxy -->|authenticates| OAuth
    KubeAuthProxy -->|authenticates| OIDC
    MonitoringCtrl -->|creates ServiceMonitors| Prometheus
    GatewayCtrl -->|creates EnvoyFilters| Istio
    Manager -->|pulls images| Quay

    style Manager fill:#4a90e2,stroke:#333,stroke-width:4px
    style DSCCtrl fill:#4a90e2,stroke:#333
    style DSCICtrl fill:#4a90e2,stroke:#333
    style GatewayCtrl fill:#7ed321,stroke:#333,stroke-width:2px
    style Gateway fill:#f5a623,stroke:#333,stroke-width:2px
    style EnvoyFilter fill:#f5a623,stroke:#333
    style KubeAuthProxy fill:#f5a623,stroke:#333
    style HTTPRoutes fill:#f5a623,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style IngressController fill:#999,stroke:#333
    style OAuth fill:#999,stroke:#333
    style OIDC fill:#999,stroke:#333
