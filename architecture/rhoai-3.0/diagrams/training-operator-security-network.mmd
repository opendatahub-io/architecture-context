graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[Data Scientist]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>User creds + SA tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["Training Operator Pod"]
            Controller["Controller Manager<br/>SA: kubeflow-training-operator<br/>UID: 65532 (non-root)<br/>FIPS-compliant"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>mTLS"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        WebhookSvc["Service:<br/>kubeflow-training-operator<br/>443→9443/TCP HTTPS"]
        MetricsSvc["Service Endpoint<br/>8080/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACES (Training Jobs)"]
        direction TB

        subgraph MasterPodGroup["Master Pod"]
            MasterPod["Master Pod<br/>{job-name}-master-0<br/>Image: {user-training-image}"]
            MasterSvc["Service: {job-name}-master-0<br/>23456/TCP (ClusterIP)"]
        end

        subgraph WorkerPodGroup["Worker Pods"]
            WorkerPod["Worker Pods<br/>{job-name}-worker-N<br/>Image: {user-training-image}"]
            WorkerSvc["Service: {job-name}-worker-N<br/>23456/TCP (ClusterIP)"]
        end

        InitContainer["Init Containers<br/>PyTorch: operator image<br/>MPI: kubectl-delivery"]
    end

    subgraph OptionalScheduling["OPTIONAL GANG SCHEDULING"]
        Volcano["Volcano Scheduler<br/>OR<br/>scheduler-plugins"]
        PodGroup["PodGroup CRD<br/>scheduling.volcano.sh/v1"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registries<br/>quay.io, docker.io<br/>443/TCP HTTPS TLS1.2+<br/>Image Pull Secrets"]
        Storage["S3/Object Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access Keys"]
        Prometheus["Prometheus<br/>(Optional)"]
    end

    subgraph CRDs["CUSTOM RESOURCES"]
        PyTorchJob["PyTorchJob<br/>kubeflow.org/v1"]
        TFJob["TFJob<br/>kubeflow.org/v1"]
        MPIJob["MPIJob<br/>kubeflow.org/v1"]
        XGBoostJob["XGBoostJob<br/>kubeflow.org/v1"]
    end

    %% User interactions
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig| K8sAPI

    %% API to Operator
    K8sAPI -->|HTTPS/9443<br/>mTLS<br/>Webhook validation| WebhookSvc
    WebhookSvc --> Webhook
    Webhook -.->|Validates| PyTorchJob
    Webhook -.->|Validates| TFJob
    Webhook -.->|Validates| MPIJob
    Webhook -.->|Validates| XGBoostJob

    %% Operator to API
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRDs, create pods/svcs| K8sAPI

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No Auth<br/>Scrape metrics| MetricsSvc
    MetricsSvc --> Metrics

    %% Health probes
    K8sAPI -.->|HTTP/8081<br/>kubelet probes| Health

    %% CRD Management
    Controller -.->|Watches| PyTorchJob
    Controller -.->|Watches| TFJob
    Controller -.->|Watches| MPIJob
    Controller -.->|Watches| XGBoostJob

    %% Resource Creation
    Controller -->|Creates via K8s API| MasterPod
    Controller -->|Creates via K8s API| WorkerPod
    Controller -->|Creates via K8s API| MasterSvc
    Controller -->|Creates via K8s API| WorkerSvc

    %% Gang Scheduling
    Controller -.->|Creates if enabled| PodGroup
    Volcano -.->|HTTPS/6443<br/>SA Token<br/>Watch & bind| K8sAPI
    PodGroup -.->|Watched by| Volcano

    %% Training Pod Communication
    WorkerPod -->|TCP/23456<br/>Plaintext<br/>Framework-specific| MasterPod

    %% External Dependencies
    MasterPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secret| Registry
    WorkerPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secret| Registry
    MasterPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Creds<br/>Datasets & checkpoints| Storage
    WorkerPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Creds<br/>Datasets & checkpoints| Storage

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef training fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crd fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,Webhook,Metrics,Health,WebhookSvc,MetricsSvc operator
    class MasterPod,WorkerPod,MasterSvc,WorkerSvc,InitContainer training
    class Registry,Storage,Prometheus externalservice
    class PyTorchJob,TFJob,MPIJob,XGBoostJob crd
    class Volcano,PodGroup optional
