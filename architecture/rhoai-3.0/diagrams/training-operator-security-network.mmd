graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist / User]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB

        TrainingOp["Training Operator Pod<br/>SA: kubeflow-training-operator<br/>UID: 65532 (non-root)<br/>Image: quay.io/opendatahub/training-operator:v1.9.0-odh-3"]

        subgraph Endpoints["Exposed Endpoints"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
            Webhooks["Validation Webhooks<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS"]
        end

        TrainingOp --- Metrics
        TrainingOp --- Health
        TrainingOp --- Webhooks
    end

    subgraph UserNS["USER NAMESPACE: {user-namespace}"]
        direction TB

        subgraph TrainingJob["Training Job Pods"]
            direction LR
            MasterPod["Master Pod<br/>Port: 23456/TCP<br/>Service: {job}-master-0"]
            WorkerPods["Worker Pods<br/>Port: 23456/TCP<br/>Service: {job}-worker-N"]
        end
    end

    subgraph OptionalComponents["OPTIONAL COMPONENTS"]
        Volcano["Volcano/scheduler-plugins<br/>Gang Scheduling"]
        Prometheus["Prometheus<br/>Metrics Collection"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS TLS1.2+"]
        S3["S3 / Object Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+"]
    end

    %% User to API
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User Credentials| K8sAPI

    %% API to Webhook
    K8sAPI -->|HTTPS/9443<br/>mTLS<br/>Validate CRD| Webhooks

    %% Operator to API
    TrainingOp -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch/Create Resources| K8sAPI

    %% Operator creates job pods
    TrainingOp -.->|Creates Pods/Services| TrainingJob

    %% Training pod communication
    WorkerPods -->|TCP/23456<br/>No Encryption<br/>No Auth<br/>Framework Coordination| MasterPod

    %% Training pods to external services
    TrainingJob -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secrets| Registry
    TrainingJob -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM Credentials<br/>Datasets & Checkpoints| S3

    %% Optional: Gang scheduling
    TrainingOp -.->|HTTPS/6443<br/>Create PodGroup CRD| Volcano

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No Auth<br/>Scrape Metrics| Metrics
    K8sAPI -.->|HTTP/8081<br/>Liveness/Readiness| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef operatorns fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    classDef userns fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef optional fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef externalservice fill:#fff9c4,stroke:#fbc02d,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class TrainingOp,Metrics,Health,Webhooks operatorns
    class TrainingJob,MasterPod,WorkerPods userns
    class Volcano,Prometheus optional
    class Registry,S3 externalservice

    %% Additional security annotations
    classDef secure fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef insecure fill:#f8d7da,stroke:#dc3545,stroke-width:2px

    class Webhooks,K8sAPI,Registry,S3 secure
    class MasterPod,WorkerPods insecure
