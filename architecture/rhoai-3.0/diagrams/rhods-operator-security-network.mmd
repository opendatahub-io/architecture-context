%% RHODS Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.0/rhods-operator.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Admin / User Browser"]
    end

    subgraph Ingress["INGRESS - Gateway API (openshift-ingress)"]
        direction TB
        Gateway["data-science-gateway<br/>(Envoy Proxy)<br/>443/TCP HTTPS<br/>TLS 1.2+ Terminate<br/>Cert: {gateway-name}-tls"]
        EnvoyFilter["EnvoyFilter: authn-filter<br/>(ext_authz check)"]
        KAP["kube-auth-proxy<br/>Ports: 4180, 8443, 9000<br/>TLS: service-serving-cert<br/>Modes: IntegratedOAuth / OIDC"]
        HTTPRoute["HTTPRoute: oauth-callback<br/>Path: /oauth2"]
        Gateway --> EnvoyFilter
        EnvoyFilter --> KAP
        HTTPRoute --> KAP
    end

    subgraph OperatorNS["OPERATOR (redhat-ods-operator)"]
        Operator["rhods-operator-controller-manager<br/>SA: redhat-ods-operator-controller-manager<br/>Probes: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS Bearer<br/>Webhooks: 9443/TCP HTTPS mTLS"]
    end

    subgraph AppNS["APPLICATION (redhat-ods-applications)"]
        direction TB
        Dashboard["ODH Dashboard"]
        Workbenches["Notebook Controller"]
        KServe["KServe"]
        DSP["DSP Operator"]
        KubeRay["KubeRay"]
        Kueue["Kueue"]
        TrustyAI["TrustyAI"]
        ModelReg["Model Registry"]
        ModelCtrl["Model Controller"]
        TrainOp["Training Operator"]
        FeastOp["Feast Operator"]
        LlamaOp["LlamaStack Operator"]
    end

    subgraph MonitoringNS["MONITORING (redhat-ods-monitoring)"]
        MonStack["MonitoringStack<br/>Prometheus/Thanos<br/>9090/TCP HTTP"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>TLS optional"]
        Tempo["Tempo<br/>4317/TCP gRPC<br/>TLS configurable"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client credentials"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        CertMgr["cert-manager (optional)<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% User flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Cookie / Bearer"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-CA)<br/>Cookie forwarding"| KAP
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OAuth
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDC

    %% Gateway to backends (post-auth)
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Bearer Token (Lua injected)"| Dashboard
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Bearer Token (Lua injected)"| Workbenches

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"deploys via<br/>kustomize manifests"| Dashboard
    Operator -->|"deploys via<br/>kustomize manifests"| KServe

    %% Monitoring
    MonStack -->|"HTTP/9090<br/>metrics scrape"| Operator
    OTEL -->|"gRPC/4317"| Tempo

