graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Platform Admin / GitOps]
    end

    subgraph ControlPlane["KUBERNETES API SERVER (Control Plane)"]
        API["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC + ServiceAccount"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator-system)"]
        direction TB

        Webhook["Webhook Server<br/>Service: webhook-service<br/>443/TCP → 9443/TCP<br/>TLS 1.2+ (mTLS)<br/>SA: redhat-ods-operator-controller-manager"]

        Manager["Operator Manager (3 replicas)<br/>Controllers: DSC, DSCI, Components<br/>Security: runAsNonRoot<br/>SA: redhat-ods-operator-controller-manager"]

        Health["Health Probes<br/>/healthz, /readyz<br/>8081/TCP HTTP<br/>No Auth"]

        Metrics["Metrics Endpoint<br/>Service: metrics-service<br/>8443/TCP HTTPS<br/>Protected by: kube-rbac-proxy"]
    end

    subgraph MonitoringNS["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        direction TB

        Prometheus["Prometheus<br/>Service: prometheus<br/>9091/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>SA: prometheus"]

        PrometheusRoute["OpenShift Route<br/>prometheus-{ns}.apps.{domain}<br/>TLS: edge (reencrypt)<br/>Auth: OAuth Proxy"]

        AlertManager["AlertManager<br/>Service: alertmanager<br/>9093/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>Auth: OAuth Proxy"]

        Blackbox["Blackbox Exporter<br/>Service: blackbox-exporter<br/>9115/TCP HTTP<br/>No encryption"]
    end

    subgraph ClusterMonitoring["OPENSHIFT CLUSTER MONITORING"]
        OpenShiftProm["OpenShift Monitoring<br/>Prometheus<br/>NS: openshift-monitoring<br/>Federation"]
    end

    subgraph Egress["EGRESS CONNECTIONS"]
        ImageRegistry["Image Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>Pull Secrets"]

        GitRepos["Component Git Repos<br/>443/TCP HTTPS<br/>Public (build time)"]
    end

    %% Flows
    Admin -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| API
    API -->|"POST /validate, /mutate<br/>9443/TCP HTTPS<br/>mTLS (K8s API cert)"| Webhook
    API -->|"Watch/List<br/>HTTPS<br/>ServiceAccount Token"| Manager

    Manager -->|"GET/POST Resources<br/>6443/TCP HTTPS<br/>ServiceAccount Token"| API

    Manager -.->|"8081/TCP HTTP<br/>Liveness/Readiness"| Health

    Prometheus -->|"GET /metrics<br/>8443/TCP HTTPS<br/>ServiceAccount Token"| Metrics
    Prometheus -->|"GET<br/>9115/TCP HTTP"| Blackbox

    OpenShiftProm -->|"Federation scrape<br/>9091/TCP HTTPS<br/>ServiceAccount Token"| Prometheus

    PrometheusRoute -->|"HTTPS<br/>OAuth"| Prometheus

    Manager -->|"Pull images<br/>443/TCP HTTPS<br/>Pull Secrets"| ImageRegistry
    Manager -.->|"Build time<br/>443/TCP HTTPS"| GitRepos

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clustermon fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Admin external
    class API controlplane
    class Webhook,Manager,Health,Metrics operator
    class Prometheus,PrometheusRoute,AlertManager,Blackbox monitoring
    class OpenShiftProm clustermon
    class ImageRegistry,GitRepos egress
