/* C4 Context Diagram - Distributed Workloads
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Submits distributed training jobs and notebooks"
        mlEngineer = person "ML Engineer" "Manages training runtimes and GPU resources"

        distributedWorkloads = softwareSystem "Distributed Workloads" "GPU-accelerated training runtime images and E2E test suite for RHOAI distributed workloads stack" {
            trainingImages = container "Training Runtime Images" "PyTorch with CUDA/ROCm GPU support across multiple Python/PyTorch versions" "Container Images (UBI9)"
            rayImages = container "Ray Runtime Images" "Ray cluster base images with CUDA/ROCm support" "Container Images (UBI9)"
            testSuite = container "E2E Test Suite" "Comprehensive Go-based integration tests for distributed workload components" "Go Test Framework"
            supportLib = container "Test Support Library" "Shared K8s/OpenShift client utilities, RBAC, routing, storage helpers" "Go Library"
        }

        /* Internal RHOAI Dependencies */
        kuberay = softwareSystem "KubeRay Operator" "Manages Ray clusters for distributed workloads" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and resource quota management" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages distributed PyTorch training jobs" "Internal RHOAI"
        trainerV2 = softwareSystem "Kubeflow Trainer v2" "Next-gen training job management with ClusterTrainingRuntime" "Internal RHOAI"
        notebookController = softwareSystem "ODH Notebook Controller" "Manages Jupyter notebook workloads with auth injection" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for spawning notebooks and managing workloads" "Internal RHOAI"
        monitoring = softwareSystem "OpenShift Monitoring" "Prometheus-based GPU utilization metrics (DCGM)" "Internal RHOAI"

        /* External Dependencies */
        ocp = softwareSystem "OpenShift Container Platform" "Target deployment platform (v4.19-v4.20)" "External"
        s3 = softwareSystem "S3-Compatible Storage" "Dataset download and model artifact storage" "External"
        registries = softwareSystem "Container Registries" "quay.io/rhoai, quay.io/modh, registry.access.redhat.com" "External"
        konflux = softwareSystem "Konflux / Tekton" "CI/CD pipeline for container image builds" "External"
        nvidia = softwareSystem "NVIDIA CUDA Ecosystem" "CUDA Toolkit, cuDNN, NCCL for GPU compute" "External"
        amd = softwareSystem "AMD ROCm Ecosystem" "ROCm runtime for AMD GPU compute" "External"

        /* Relationships */
        dataScientist -> distributedWorkloads "Runs training jobs using runtime images"
        mlEngineer -> distributedWorkloads "Manages runtimes and runs E2E tests"

        distributedWorkloads -> kuberay "Creates RayCluster/RayJob CRs" "HTTPS/6443"
        distributedWorkloads -> kueue "Creates ClusterQueue/LocalQueue for resource quota" "HTTPS/6443"
        distributedWorkloads -> trainingOperator "Creates PyTorchJob CRs for distributed training" "HTTPS/6443"
        distributedWorkloads -> trainerV2 "Creates TrainJob with ClusterTrainingRuntime" "HTTPS/6443"
        distributedWorkloads -> notebookController "Creates Notebook CRs for workload notebooks" "HTTPS/6443"
        distributedWorkloads -> dashboard "Notebook spawner UI interaction" "HTTPS/443"
        distributedWorkloads -> monitoring "Queries GPU utilization metrics (DCGM_FI_DEV_GPU_UTIL)" "HTTPS/443"

        distributedWorkloads -> ocp "Deploys on OpenShift clusters" "HTTPS/6443"
        distributedWorkloads -> s3 "Downloads datasets, uploads models" "HTTPS/443"
        distributedWorkloads -> registries "Pulls/pushes container images" "HTTPS/443"
        distributedWorkloads -> nvidia "Uses CUDA/cuDNN/NCCL for NVIDIA GPU compute"
        distributedWorkloads -> amd "Uses ROCm for AMD GPU compute"
        konflux -> distributedWorkloads "Builds container images via Tekton pipelines"

        testSuite -> supportLib "Uses shared test utilities"
        trainingImages -> nvidia "Includes CUDA toolkit"
        trainingImages -> amd "Includes ROCm runtime"
        rayImages -> nvidia "Includes CUDA + cuDNN"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
