graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist /<br/>External Client]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Router)"]
        Router["OpenShift Routes<br/>443/TCP HTTPS<br/>TLS 1.2+ Termination"]
    end

    subgraph PlatformNS["PLATFORM: redhat-ods-applications"]
        direction TB

        Dashboard["ODH Dashboard<br/>8443/TCP HTTPS<br/>OAuth2 (kube-rbac-proxy)<br/>SA: odh-dashboard"]

        KServeCtrl["KServe Controller<br/>9443/TCP mTLS (webhook)<br/>SA: kserve-controller-manager<br/>RBAC: kserve-manager-role"]

        ModelCtrl["ODH Model Controller<br/>9443/TCP mTLS (webhook)<br/>SA: odh-model-controller<br/>Creates: Routes, EnvoyFilters"]

        NotebookCtrl["Notebook Controller<br/>SA: notebook-controller<br/>RBAC: notebook-controller-role<br/>Creates: StatefulSets, VirtualServices"]

        DSPOp["DSP Operator<br/>SA: dsp-operator<br/>RBAC: manager-role"]
    end

    subgraph UserNS["USER NAMESPACE: {user-namespace}"]
        direction TB

        Notebook["Workbench Pod<br/>8888/TCP HTTP (JupyterLab)<br/>8443/TCP HTTPS (OAuth Proxy)<br/>SA: {notebook-name}-sa<br/>PVC: workspace storage"]

        DSP["DSP API Server<br/>8888/TCP HTTP<br/>Bearer Token Auth<br/>SA: ds-pipeline-{name}"]

        Argo["Argo Workflow<br/>Controller<br/>2746/TCP HTTP"]

        Pipeline["Pipeline Pod<br/>SA: pipeline-runner<br/>RBAC: ISVC create"]

        ISVC["InferenceService<br/>Predictor Pod<br/>8080/TCP HTTP<br/>mTLS (Service Mesh)<br/>SA: {isvc-name}-sa"]

        ModelReg["Model Registry<br/>8080/8081 gRPC/REST<br/>8443/TCP HTTPS (OAuth)<br/>SA: model-registry-{name}"]

        Feast["Feast Feature Store<br/>6566/6567 HTTP/HTTPS (online)<br/>8815/8816 HTTP/HTTPS (offline)<br/>SA: feast-{name}"]

        TrustyAI["TrustyAI Service<br/>8080/TCP HTTP (internal)<br/>8443/TCP HTTPS (OAuth)<br/>SA: trustyai-{name}"]

        TrainingJob["PyTorchJob Pods<br/>23456/TCP (master-worker)<br/>SA: {job-name}-sa"]

        RayCluster["Ray Cluster<br/>6379/TCP Redis<br/>8265/TCP Dashboard<br/>10001/TCP GCS"]

        LlamaStack["Llama Stack Server<br/>8321/TCP HTTP<br/>SA: llamastack-{name}"]
    end

    subgraph MonitoringNS["MONITORING: redhat-ods-monitoring"]
        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>9091/TCP HTTPS (OAuth)<br/>SA: prometheus<br/>PVC: metrics storage"]

        AlertManager["AlertManager<br/>9093/TCP HTTP<br/>9094/TCP HTTPS (OAuth)"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio - Optional)"]
        direction LR

        IstioGW["Istio Gateway<br/>8080/8443 HTTP/HTTPS<br/>TLS passthrough/termination"]

        Envoy["Envoy Sidecar<br/>15001/15006 TCP<br/>mTLS PERMISSIVE<br/>SPIFFE certs (90d)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Keys"]

        DB["PostgreSQL / MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ (optional)<br/>Username/Password"]

        ContainerReg["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>Pull Secrets"]

        PyPI["PyPI / CRAN<br/>443/TCP HTTPS<br/>Public (no auth)"]

        Git["GitHub / GitLab<br/>443/TCP HTTPS<br/>22/TCP SSH<br/>PAT / SSH keys"]

        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>API Token"]
    end

    subgraph K8sAPI["KUBERNETES API"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Tokens"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Bearer Token"| Router

    %% Ingress to Platform Components
    Router -->|"HTTPS → 8443<br/>Reencrypt<br/>OAuth2"| Dashboard
    Router -->|"HTTPS → 8888<br/>Edge TLS<br/>OAuth Proxy"| Notebook
    Router -->|"HTTPS → 8888<br/>Reencrypt"| DSP
    Router -->|"HTTPS → 8080<br/>Istio Gateway"| IstioGW
    Router -->|"HTTPS → 8443<br/>Edge TLS"| ModelReg
    Router -->|"HTTPS → 8443<br/>Edge TLS"| TrustyAI
    Router -->|"HTTPS → 9090<br/>Reencrypt"| Prometheus

    %% Dashboard to API Server
    Dashboard -->|"HTTPS/6443<br/>ServiceAccount Token<br/>Watch CRDs"| APIServer

    %% Platform Controllers to API Server
    KServeCtrl -->|"HTTPS/6443<br/>ServiceAccount Token<br/>ISVC CRUD"| APIServer
    NotebookCtrl -->|"HTTPS/6443<br/>ServiceAccount Token<br/>StatefulSet CRUD"| APIServer
    ModelCtrl -->|"HTTPS/6443<br/>ServiceAccount Token<br/>Route/EnvoyFilter CRUD"| APIServer
    DSPOp -->|"HTTPS/6443<br/>ServiceAccount Token<br/>DSPA CRUD"| APIServer

    %% Controller creates workloads
    NotebookCtrl -.->|Creates| Notebook
    DSPOp -.->|Creates| DSP
    KServeCtrl -.->|Creates| ISVC
    ModelCtrl -.->|"Provisions Route,<br/>ServiceMonitor"| ISVC

    %% Workbench workflows
    Notebook -->|"HTTP/8888<br/>Bearer Token"| DSP
    DSP -->|"Creates Workflow CR"| Argo
    Argo -.->|"Launches"| Pipeline
    Pipeline -->|"HTTP/6443<br/>ServiceAccount<br/>Create ISVC"| APIServer
    Pipeline -->|"HTTPS/8443<br/>Bearer Token<br/>Register model"| ModelReg

    %% InferenceService dependencies
    ISVC -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM SigV4"| S3
    ISVC -->|"HTTP/6566<br/>Get features"| Feast
    TrustyAI -->|"HTTP/8080<br/>mTLS (mesh)<br/>Guardrails injection"| ISVC

    %% Model Registry to DB
    ModelReg -->|"PostgreSQL/5432<br/>MySQL/3306<br/>TLS 1.2+ (optional)<br/>User/Pass"| DB

    %% Feast storage
    Feast -->|"HTTPS/443<br/>TLS 1.2+<br/>S3 credentials"| S3
    Feast -->|"PostgreSQL/5432<br/>MySQL/3306<br/>Feature DB"| DB

    %% TrustyAI storage
    TrustyAI -->|"JDBC<br/>TLS 1.2+ (optional)<br/>User/Pass"| DB

    %% Training jobs
    TrainingJob -->|"HTTPS/443<br/>AWS IAM<br/>Training data"| S3
    TrainingJob -->|"HTTP/8815<br/>Historical features"| Feast

    %% Llama Stack
    LlamaStack -->|"HTTPS/443<br/>API Token<br/>Model downloads"| HF

    %% Workbench egress
    Notebook -->|"HTTPS/443<br/>Pull secrets"| ContainerReg
    Notebook -->|"HTTPS/443<br/>pip/conda/R"| PyPI
    Notebook -->|"HTTPS/443, SSH/22<br/>PAT/SSH keys"| Git
    Notebook -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Service Mesh
    IstioGW -->|"HTTP/8080<br/>mTLS PERMISSIVE"| ISVC
    Envoy -.->|"Injected into"| ISVC
    Envoy -.->|"Injected into"| DSP

    %% Monitoring
    Prometheus -->|"HTTP/8080, HTTPS/8443<br/>ServiceAccount Token<br/>Scrape /metrics"| Dashboard
    Prometheus -->|"Scrape /metrics"| KServeCtrl
    Prometheus -->|"Scrape /metrics"| ISVC
    Prometheus -->|"Scrape /metrics"| TrustyAI
    TrustyAI -->|"HTTP/9090<br/>Export metrics"| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userworkload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef servicemesh fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:3px
    classDef k8s fill:#b3e5fc,stroke:#0288d1,stroke-width:2px

    class User external
    class Router ingress
    class Dashboard,KServeCtrl,ModelCtrl,NotebookCtrl,DSPOp platform
    class Notebook,DSP,Argo,Pipeline,ISVC,ModelReg,Feast,TrustyAI,TrainingJob,RayCluster,LlamaStack userworkload
    class Prometheus,AlertManager monitoring
    class IstioGW,Envoy servicemesh
    class S3,DB,ContainerReg,PyPI,Git,HF externalservice
    class APIServer k8s
