%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.0/model-registry-operator.md

graph TB
    subgraph Operator["Model Registry Operator<br/>(redhat-ods-applications)"]
        direction TB
        Manager["Operator Manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP"]
        MRReconciler["ModelRegistryReconciler<br/>Go Controller"]
        MCReconciler["ModelCatalogReconciler<br/>Go Controller"]
        StorageMigration["StorageMigrationManager<br/>Background Task<br/>v1alpha1 → v1beta1"]
        Webhooks["Admission Webhooks<br/>Mutating + Validating<br/>9443/TCP HTTPS"]

        Manager --> MRReconciler
        Manager --> MCReconciler
        Manager --> StorageMigration
        Manager --> Webhooks
    end

    subgraph ManagedRegistry["Managed Model Registry Instance<br/>(per ModelRegistry CR)"]
        direction TB
        RestContainer["REST Container<br/>model-registry<br/>8080/TCP HTTP"]
        GRPCServer["MLMD gRPC Server<br/>mlmd-grpc-server"]
        KRBProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        RegistryPostgres["PostgreSQL<br/>5432/TCP<br/>(auto-provisioned)"]

        KRBProxy -->|"localhost 8080"| RestContainer
        RestContainer --> GRPCServer
        RestContainer --> RegistryPostgres
    end

    subgraph ManagedCatalog["Managed Model Catalog<br/>(singleton)"]
        direction TB
        CatalogContainer["Catalog Container<br/>8080/TCP HTTP"]
        CatalogKRBP["kube-rbac-proxy<br/>8443/TCP HTTPS"]
        CatalogPostgres["Catalog PostgreSQL<br/>5432/TCP"]
        CatalogInit["Init Containers<br/>catalog-data-init<br/>benchmark-data-init"]

        CatalogKRBP -->|"localhost 8080"| CatalogContainer
        CatalogInit -->|"emptyDir"| CatalogContainer
        CatalogContainer --> CatalogPostgres
    end

    %% CRDs
    User[User / Client] -->|creates| ModelRegistryCR["ModelRegistry CR<br/>modelregistry.opendatahub.io<br/>v1beta1"]
    ModelRegistryCR -->|watched by| MRReconciler
    MRReconciler -->|creates/manages| ManagedRegistry

    MCReconciler -->|creates/manages| ManagedCatalog

    %% External Dependencies
    MRReconciler -->|"CRUD 443/TCP"| K8sAPI["Kubernetes API Server"]
    MCReconciler -->|"CRUD 443/TCP"| K8sAPI
    Webhooks -->|"validates/mutates"| ModelRegistryCR
    StorageMigration -->|"StorageVersionMigration"| K8sAPI

    %% OpenShift Integration
    MRReconciler -->|creates| Routes["OpenShift Routes<br/>(reencrypt TLS)"]
    MRReconciler -->|creates| NetPol["NetworkPolicies"]
    MCReconciler -->|creates| CatalogRoute["Catalog Route<br/>(reencrypt TLS)"]

    %% Platform Integration
    MCReconciler -->|"reads"| PlatformCR["components.platform<br/>ModelRegistry CR"]
    RhodsOp["rhods-operator"] -->|"deploys via kustomize"| Operator

    %% External DB
    RestContainer -->|"5432/TCP"| ExtPostgres["External PostgreSQL"]
    RestContainer -->|"3306/TCP"| ExtMySQL["External MySQL"]

