graph TB
    subgraph "Model Registry Operator"
        Controller[Controller Manager<br/>Deployment]
        Webhook[Webhook Server<br/>:9443]
        Controller -->|validates/mutates| Webhook
    end

    subgraph "Model Registry Instance (per CR)"
        RESTServer[REST Server<br/>:8080 HTTP]
        gRPCServer[gRPC Server<br/>:9090 gRPC]
        RBACProxy[kube-rbac-proxy<br/>:8443 HTTPS]

        RBACProxy -->|proxy| RESTServer
        RESTServer -->|sidecar| gRPCServer
    end

    subgraph "External/Backend"
        PostgreSQL[(PostgreSQL 16<br/>:5432)]
        MySQL[(MySQL 8.x<br/>:3306)]
    end

    User[User/Client] -->|creates| ModelRegistryCR[ModelRegistry CR<br/>v1beta1]
    ModelRegistryCR -->|watched by| Controller

    Controller -->|creates| RESTDeployment[REST Deployment]
    Controller -->|creates| Service[ClusterIP Service]
    Controller -->|creates| Route[OpenShift Route<br/>443/TCP]
    Controller -->|creates| NetworkPolicy[Network Policy]

    RESTDeployment -->|contains| RESTServer
    RESTDeployment -->|contains| gRPCServer
    RESTDeployment -->|contains| RBACProxy

    RESTServer -->|queries| PostgreSQL
    RESTServer -->|queries| MySQL
    gRPCServer -->|queries| PostgreSQL
    gRPCServer -->|queries| MySQL

    Controller -->|depends on| K8sAPI[Kubernetes API]
    Controller -->|optional| IstioGateway[Istio Gateway]
    Controller -->|integrates| ServiceCA[OpenShift Service CA]

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style RESTServer fill:#7ed321,stroke:#333,stroke-width:2px
    style gRPCServer fill:#7ed321,stroke:#333,stroke-width:2px
    style RBACProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style ModelRegistryCR fill:#f5a623,stroke:#333,stroke-width:2px
    style PostgreSQL fill:#999,stroke:#333,stroke-width:2px
    style MySQL fill:#999,stroke:#333,stroke-width:2px
    style IstioGateway fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
