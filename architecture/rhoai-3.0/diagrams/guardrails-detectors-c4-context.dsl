// C4 Context Diagram for Guardrails Detectors
// Generated by: Claude Opus 4.6
workspace {
    model {
        datascientist = person "Data Scientist" "Configures guardrails policies and custom detectors"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Suite of detector microservices for text content analysis (PII, safety, toxicity, file-type validation, LLM-as-judge)" {
            builtInDetector = container "Built-in Detector" "Regex PII detection (email, CC, SSN, phone, IP), file-type validation (JSON, XML, YAML), custom Python detectors" "Python FastAPI, Port 8080"
            huggingfaceDetector = container "HuggingFace Detector" "ML-based content classification using AutoModelForSequenceClassification and GraniteForCausalLM models" "Python FastAPI + PyTorch, Port 8000"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-Judge evaluation using vllm_judge for safety, toxicity, accuracy, helpfulness scoring" "Python FastAPI + vllm_judge, Port 8000"
            regexRegistry = component "RegexDetectorRegistry" "Registry of regex-based PII detectors" "Python Module"
            fileTypeRegistry = component "FileTypeDetectorRegistry" "Registry of file-type validators with schema support" "Python Module"
            customRegistry = component "CustomDetectorRegistry" "User-defined detectors with AST security scanning" "Python Module"
            instrumentedDetector = component "InstrumentedDetector" "Base class providing Prometheus metrics" "Python Base Class"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestrates detector invocations for content analysis pipelines" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Manages detector deployment via ServingRuntime and InferenceService CRDs" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS and traffic management for KServe-deployed detectors" "External"
        vllmServer = softwareSystem "vLLM Server" "External LLM server providing OpenAI-compatible API for LLM Judge evaluations" "Internal RHOAI"
        s3Storage = softwareSystem "S3/Minio Storage" "Model artifact storage for HuggingFace models" "External"
        prometheus = softwareSystem "Prometheus" "Monitoring system that scrapes trustyai_guardrails_* metrics" "External"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Management UI with dashboard label integration" "Internal RHOAI"

        // Relationships
        orchestrator -> guardrailsDetectors "Sends detection requests via POST /api/v1/text/contents" "HTTP/8080 (plaintext), HTTP/8000 (Istio mTLS)"
        guardrailsDetectors -> vllmServer "Sends evaluation prompts for LLM-as-judge scoring" "HTTP/8080 (Istio mTLS)"
        guardrailsDetectors -> s3Storage "Downloads model artifacts at startup via KServe storage initializer" "HTTP/9000 (AWS IAM credentials)"
        kserve -> guardrailsDetectors "Deploys and manages HF and LLM Judge detector lifecycle" "ServingRuntime, InferenceService CRDs"
        istio -> guardrailsDetectors "Provides sidecar proxy for mTLS encryption" "Sidecar injection"
        prometheus -> guardrailsDetectors "Scrapes /metrics endpoint for monitoring" "HTTP/8080, HTTP/8000"
        dashboard -> guardrailsDetectors "Displays detectors via opendatahub.io/dashboard label" "Label integration"
        datascientist -> orchestrator "Configures guardrails policies"

        // Container relationships
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080 plaintext"
        orchestrator -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000 Istio mTLS"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents" "HTTP/8000 Istio mTLS"
        llmJudgeDetector -> vllmServer "POST evaluation prompts" "HTTP/8080 Istio mTLS"
        huggingfaceDetector -> s3Storage "Download models at init" "HTTP/9000"
        builtInDetector -> regexRegistry "Invokes PII detection"
        builtInDetector -> fileTypeRegistry "Invokes file-type validation"
        builtInDetector -> customRegistry "Invokes custom detectors"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Component" {
                background #85BBF0
                color #000000
            }
        }
    }
}
