            BaseImage["Base Image:<br/>ubi9-minimal:9.6"]
            FIPS["FIPS Compliant: Yes"]
        end

        subgraph "Secrets Management"
            direction TB
            AWSKey["AWS_ACCESS_KEY_ID<br/>Type: env var<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
            AWSSecret["AWS_SECRET_ACCESS_KEY<br/>Type: env var<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
            GCPCreds["GOOGLE_APPLICATION_CREDENTIALS<br/>Type: env var/file<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
            AzureCreds["AZURE_STORAGE_CONNECTION_STRING<br/>Type: env var<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
            HFToken["HF_TOKEN<br/>Type: env var (optional)<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
        end
