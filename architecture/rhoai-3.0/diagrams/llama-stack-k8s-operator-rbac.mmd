graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: redhat-ods-applications]
        SA_Managed["{instance-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_Metrics[metrics-reader<br/>ClusterRole]
        CR_Editor[llsd-editor-role<br/>ClusterRole]
        CR_Viewer[llsd-viewer-role<br/>ClusterRole]
    end

    subgraph "ClusterRole: manager-role Permissions"
        direction TB

        Perm_LLSD["llamastack.io<br/>llamastackdistributions<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_LLSD_Status["llamastack.io<br/>llamastackdistributions/status<br/>get, patch, update"]
        Perm_LLSD_Finalizers["llamastack.io<br/>llamastackdistributions/finalizers<br/>update"]

        Perm_Deployments["apps<br/>deployments<br/>get, list, watch, create,<br/>update, patch, delete"]

        Perm_Services["core<br/>services<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_SA["core<br/>serviceaccounts<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_PVC["core<br/>persistentvolumeclaims<br/>get, list, watch, create"]
        Perm_ConfigMaps["core<br/>configmaps<br/>get, list, watch, create,<br/>update, patch"]

        Perm_NetPolicies["networking.k8s.io<br/>networkpolicies<br/>get, list, watch, create,<br/>update, patch, delete"]

        Perm_RoleBindings["rbac.authorization.k8s.io<br/>rolebindings<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_ClusterRoles["rbac.authorization.k8s.io<br/>clusterroles<br/>get, list, watch"]
        Perm_ClusterRoleBindings["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get, list, delete"]

        Perm_SCC["security.openshift.io<br/>securitycontextconstraints<br/>use (anyuid)"]
    end

    subgraph "ClusterRole: leader-election-role Permissions"
        direction TB

        Perm_LE_ConfigMaps["core<br/>configmaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_LE_Leases["coordination.k8s.io<br/>leases<br/>get, list, watch, create,<br/>update, patch, delete"]
        Perm_LE_Events["core<br/>events<br/>create, patch"]
    end

    subgraph "ClusterRole: metrics-reader Permissions"
        direction TB

        Perm_Metrics_Pods["core<br/>pods<br/>get, list, watch"]
        Perm_Metrics_Services["core<br/>services<br/>get"]
    end

    subgraph "Role Bindings"
        CRB_Manager[manager-role-binding<br/>ClusterRoleBinding]
        RB_LeaderElection[leader-election-role-binding<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
        RB_Metrics[metrics-auth-rolebinding<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Managed Resource Permissions"
        Perm_Managed_PVC["Managed ServiceAccount<br/>can access PVCs<br/>via cluster-scoped role"]
    end

    %% Service Account to Role Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_LeaderElection
    SA_Controller -->|bound via| RB_Metrics

    SA_Managed -->|bound via| Perm_Managed_PVC

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_LeaderElection -->|grants| CR_LeaderElection
    RB_Metrics -->|grants| CR_Metrics

    %% ClusterRoles to Permissions
    CR_Manager -->|permits| Perm_LLSD
    CR_Manager -->|permits| Perm_LLSD_Status
    CR_Manager -->|permits| Perm_LLSD_Finalizers
    CR_Manager -->|permits| Perm_Deployments
    CR_Manager -->|permits| Perm_Services
    CR_Manager -->|permits| Perm_SA
    CR_Manager -->|permits| Perm_PVC
    CR_Manager -->|permits| Perm_ConfigMaps
    CR_Manager -->|permits| Perm_NetPolicies
    CR_Manager -->|permits| Perm_RoleBindings
    CR_Manager -->|permits| Perm_ClusterRoles
    CR_Manager -->|permits| Perm_ClusterRoleBindings
    CR_Manager -->|permits| Perm_SCC

    CR_LeaderElection -->|permits| Perm_LE_ConfigMaps
    CR_LeaderElection -->|permits| Perm_LE_Leases
    CR_LeaderElection -->|permits| Perm_LE_Events

    CR_Metrics -->|permits| Perm_Metrics_Pods
    CR_Metrics -->|permits| Perm_Metrics_Services

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef clusterRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef permission fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    classDef binding fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef managed fill:#50E3C2,stroke:#333,stroke-width:2px,color:#000

    class SA_Controller,SA_Managed serviceAccount
    class CR_Manager,CR_LeaderElection,CR_Metrics,CR_Editor,CR_Viewer clusterRole
    class Perm_LLSD,Perm_LLSD_Status,Perm_LLSD_Finalizers,Perm_Deployments,Perm_Services,Perm_SA,Perm_PVC,Perm_ConfigMaps,Perm_NetPolicies,Perm_RoleBindings,Perm_ClusterRoles,Perm_ClusterRoleBindings,Perm_SCC,Perm_LE_ConfigMaps,Perm_LE_Leases,Perm_LE_Events,Perm_Metrics_Pods,Perm_Metrics_Services permission
    class CRB_Manager,RB_LeaderElection,RB_Metrics binding
    class Perm_Managed_PVC managed
