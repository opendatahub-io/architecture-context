graph TD
    subgraph ServiceAccounts["Service Accounts"]
        ControllerSA["controller-manager<br/>(redhat-ods-applications)"]
        InstanceSA["{instance-name}-sa<br/>(user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        ManagerBinding["manager-role-binding<br/>(cluster-scoped)"]
        LeaderElectionBinding["leader-election-role-binding<br/>(redhat-ods-applications)"]
        MetricsBinding["metrics-auth-rolebinding<br/>(redhat-ods-applications)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        ManagerRole["manager-role"]
        LeaderElectionRole["leader-election-role"]
        MetricsReaderRole["metrics-reader"]
        EditorRole["llsd-editor-role<br/>(for users)"]
        ViewerRole["llsd-viewer-role<br/>(for users)"]
    end

    subgraph ManagerRolePerms["manager-role Permissions"]
        direction TB

        LlamaStackPerms["llamastack.io<br/>llamastackdistributions<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        StatusPerms["llamastack.io<br/>llamastackdistributions/status<br/>━━━━━━━━━━━━━━━<br/>get, patch, update"]

        FinalizerPerms["llamastack.io<br/>llamastackdistributions/finalizers<br/>━━━━━━━━━━━━━━━<br/>update"]

        DeploymentPerms["apps<br/>deployments<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        ServicePerms["core<br/>services<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        SAPerms["core<br/>serviceaccounts<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        PVCPerms["core<br/>persistentvolumeclaims<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create"]

        ConfigMapPerms["core<br/>configmaps<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update, patch"]

        NetPolPerms["networking.k8s.io<br/>networkpolicies<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        RBACPerms["rbac.authorization.k8s.io<br/>rolebindings: all verbs<br/>clusterroles: get, list, watch<br/>clusterrolebindings: get, list, delete"]

        SCCPerms["security.openshift.io<br/>securitycontextconstraints<br/>━━━━━━━━━━━━━━━<br/>use (including anyuid)"]
    end

    subgraph LeaderElectionPerms["leader-election-role Permissions"]
        direction TB

        LEConfigMaps["core<br/>configmaps<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        LELeases["coordination.k8s.io<br/>leases<br/>━━━━━━━━━━━━━━━<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]

        LEEvents["core<br/>events<br/>━━━━━━━━━━━━━━━<br/>create, patch"]
    end

    subgraph MetricsReaderPerms["metrics-reader Permissions"]
        direction TB

        MetricsPods["core<br/>pods<br/>━━━━━━━━━━━━━━━<br/>get, list, watch"]

        MetricsServices["core<br/>services<br/>━━━━━━━━━━━━━━━<br/>get"]
    end

    subgraph UserRolePerms["User Roles Permissions"]
        direction TB

        EditorPerms["llsd-editor-role<br/>━━━━━━━━━━━━━━━<br/>llamastackdistributions:<br/>create, delete, get,<br/>list, patch, update, watch"]

        ViewerPerms["llsd-viewer-role<br/>━━━━━━━━━━━━━━━<br/>llamastackdistributions:<br/>get, list, watch"]
    end

    %% Bindings
    ControllerSA -->|bound via| ManagerBinding
    ManagerBinding -->|grants| ManagerRole
    ManagerRole -->|includes| ManagerRolePerms

    ControllerSA -->|bound via| LeaderElectionBinding
    LeaderElectionBinding -->|grants| LeaderElectionRole
    LeaderElectionRole -->|includes| LeaderElectionPerms

    ControllerSA -->|bound via| MetricsBinding
    MetricsBinding -->|grants| MetricsReaderRole
    MetricsReaderRole -->|includes| MetricsReaderPerms

    %% Instance SA created by operator
    ControllerSA -.->|creates| InstanceSA
    InstanceSA -.->|bound to| PVCReaderRole["PVC Reader Role<br/>(cluster-scoped)"]

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef perms fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#333
    classDef userrole fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    class ControllerSA,InstanceSA sa
    class ManagerBinding,LeaderElectionBinding,MetricsBinding binding
    class ManagerRole,LeaderElectionRole,MetricsReaderRole,PVCReaderRole role
    class EditorRole,ViewerRole userrole
    class LlamaStackPerms,StatusPerms,FinalizerPerms,DeploymentPerms,ServicePerms,SAPerms,PVCPerms,ConfigMapPerms,NetPolPerms,RBACPerms,SCCPerms,LEConfigMaps,LELeases,LEEvents,MetricsPods,MetricsServices,EditorPerms,ViewerPerms perms
