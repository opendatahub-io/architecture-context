// C4 Context Diagram: llama-stack-provider-ragas
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits LLM evaluation jobs via Llama Stack Eval API"

        llamaStackProviderRagas = softwareSystem "llama-stack-provider-ragas" "Llama Stack evaluation provider integrating Ragas metrics for RAG evaluation (inline and remote modes)" {
            inlineProvider = container "Inline Provider" "Runs Ragas evaluations in-process within Llama Stack server" "Python (inline::trustyai_ragas)"
            remoteProvider = container "Remote Provider" "Submits Ragas evaluations as Kubeflow Pipeline runs" "Python (remote::trustyai_ragas)"
            inlineLLMWrapper = container "LlamaStackInlineLLM" "Adapts Llama Stack inference API to Ragas/LangChain LLM interface" "Python Wrapper"
            inlineEmbedWrapper = container "LlamaStackInlineEmbeddings" "Adapts Llama Stack inference API to Ragas embeddings interface" "Python Wrapper"
            remoteLLMWrapper = container "LlamaStackRemoteLLM" "Adapts Llama Stack client SDK to Ragas/LangChain LLM interface" "Python Wrapper"
            remoteEmbedWrapper = container "LlamaStackRemoteEmbeddings" "Adapts Llama Stack client SDK to Ragas embeddings interface" "Python Wrapper"
            kfpPipeline = container "KFP Pipeline" "Two-step pipeline: retrieve dataset, run Ragas evaluation, persist to S3" "Kubeflow Pipeline Definition"
            containerImage = container "Container Image" "UBI9 Python 3.12 container for KFP components" "odh-trustyai-ragas-lls-provider-dsp-rhel9"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts provider plugins and exposes Eval, Inference, DatasetIO APIs" "Internal"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines (Data Science Pipelines)" "Pipeline orchestration for distributed evaluation workloads" "Internal RHOAI"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for evaluation results (JSONL format)" "External"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides ConfigMap for KFP component base image resolution" "Internal RHOAI"
        inferenceBackend = softwareSystem "Inference Backend (Ollama / vLLM)" "LLM completions and embedding model inference" "External"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster API for ConfigMap/Secret access and kubeconfig loading" "External"

        // User interactions
        user -> llamaStackServer "Submits evaluation jobs via Eval API" "HTTP/8321"
        llamaStackServer -> llamaStackProviderRagas "Routes eval requests to provider plugin"

        // Inline mode
        inlineProvider -> inlineLLMWrapper "Uses for LLM calls"
        inlineProvider -> inlineEmbedWrapper "Uses for embeddings"
        inlineLLMWrapper -> llamaStackServer "In-process Python API calls for inference"
        inlineEmbedWrapper -> llamaStackServer "In-process Python API calls for embeddings"

        // Remote mode
        remoteProvider -> kubeflowPipelines "Submits and monitors pipeline runs" "HTTPS/443 Bearer Token"
        remoteProvider -> s3Storage "Retrieves evaluation results" "HTTPS/443 AWS IAM"
        remoteProvider -> kubernetesAPI "Reads ConfigMaps, loads kubeconfig" "HTTPS/443 SA Token"
        remoteProvider -> trustyaiOperator "Reads ragas-provider-image from ConfigMap"
        kfpPipeline -> llamaStackServer "Callbacks for dataset retrieval and inference" "HTTP/8321"
        kfpPipeline -> s3Storage "Writes evaluation results (JSONL)" "HTTPS/443 AWS IAM"

        // Inference
        llamaStackServer -> inferenceBackend "LLM completions and embeddings" "HTTP/11434"

        // Integration
        kubeflowPipelines -> kfpPipeline "Orchestrates pipeline execution"
    }

    views {
        systemContext llamaStackProviderRagas "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackProviderRagas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #f5a623
                color #ffffff
            }
        }
    }
}
