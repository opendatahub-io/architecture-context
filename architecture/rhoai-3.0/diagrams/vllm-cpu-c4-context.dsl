/*
 * vllm-cpu C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/vllm-cpu.md
 */

workspace {
    model {
        # Actors
        datascientist = person "Data Scientist" "Submits inference requests to LLM models"
        sre = person "SRE / Platform Admin" "Manages and monitors the inference platform"

        # Primary System
        vllmcpu = softwareSystem "vLLM CPU" "CPU-optimized LLM inference engine providing OpenAI-compatible REST API and TGIS gRPC endpoints" {
            openaiServer = container "OpenAI API Server" "FastAPI-based HTTP server providing OpenAI-compatible REST endpoints for chat completions, embeddings, and more" "Python/FastAPI" "Port 8000/TCP"
            tgisAdapter = container "vllm-tgis-adapter" "gRPC adapter providing TGIS protocol compatibility for KServe/Caikit integration" "Python/gRPC" "Port 8033/TCP"
            vllmEngine = container "vLLM Engine" "Core inference engine with PagedAttention, continuous batching, and CPU-optimized kernels" "Python/C++"
            cpuKernels = container "CPU Kernels" "CPU-optimized compute kernels for attention, cache operations, and quantization" "C/C++ Extensions"
            prometheusMetrics = container "Prometheus Metrics" "Metrics exporter at /metrics endpoint" "Python Middleware"
            sslSupport = container "SSL/TLS Support" "Optional TLS termination with certificate hot-reload" "Python ssl Module"
        }

        # Internal ODH Systems
        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle, deploys vLLM as runtime container" "Internal RHOAI"
        modelMesh = softwareSystem "Model Mesh" "Alternative model serving integration via TGIS protocol" "Internal RHOAI"
        caikit = softwareSystem "Caikit" "AI toolkit using TGIS protocol for serving" "Internal RHOAI"

        # External Systems
        hfhub = softwareSystem "HuggingFace Hub" "Model weights and tokenizer downloads" "External"
        s3storage = softwareSystem "S3 / PVC Storage" "Model weight storage" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"

        # Relationships - User interactions
        datascientist -> vllmcpu "Sends inference requests" "HTTP/8000, gRPC/8033"
        sre -> prometheus "Monitors inference performance"

        # Relationships - Internal
        openaiServer -> vllmEngine "Forwards inference requests" "In-process"
        tgisAdapter -> vllmEngine "Forwards gRPC requests" "In-process"
        vllmEngine -> cpuKernels "Executes inference" "In-process"
        openaiServer -> prometheusMetrics "Exposes metrics" "In-process"
        openaiServer -> sslSupport "TLS termination" "In-process"

        # Relationships - Platform
        kserve -> vllmcpu "Deploys and manages as InferenceService runtime"
        caikit -> vllmcpu "Sends TGIS gRPC requests" "gRPC/8033"
        modelMesh -> vllmcpu "Sends TGIS gRPC requests" "gRPC/8033"

        # Relationships - External
        vllmcpu -> hfhub "Downloads model weights and tokenizers" "HTTPS/443"
        vllmcpu -> s3storage "Loads model weights" "HTTPS/443 or NFS"
        prometheus -> vllmcpu "Scrapes /metrics endpoint" "HTTP/8000"
    }

    views {
        systemContext vllmcpu "SystemContext" {
            include *
            autoLayout
        }

        container vllmcpu "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
