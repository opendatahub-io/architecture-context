graph TD
    subgraph "Service Account"
        SA[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Pods["Core API ('')<br/>pods, services, serviceaccounts<br/>configmaps, events, secrets, endpoints"]
        PodsStatus["Core API ('')<br/>pods/status, pods/proxy<br/>services/status, services/proxy"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments"]
    end

    subgraph "Batch API Resources"
        Jobs["batch<br/>jobs"]
    end

    subgraph "Ray CRDs"
        RayCRDs["ray.io<br/>rayclusters, rayjobs, rayservices"]
        RayStatus["ray.io<br/>rayclusters/status<br/>rayjobs/status<br/>rayservices/status"]
        RayFinalizers["ray.io<br/>rayclusters/finalizers<br/>rayjobs/finalizers<br/>rayservices/finalizers"]
    end

    subgraph "Networking Resources"
        Network["networking.k8s.io<br/>ingresses, networkpolicies<br/>ingressclasses"]
    end

    subgraph "OpenShift Resources"
        Routes["route.openshift.io<br/>routes"]
        OpenshiftConfig["config.openshift.io<br/>authentications, oauths"]
        OpenshiftOperator["operator.openshift.io<br/>kubeapiservers"]
    end

    subgraph "cert-manager Resources"
        Certificates["cert-manager.io<br/>certificates, issuers"]
        CertStatus["cert-manager.io<br/>certificates/status"]
    end

    subgraph "Gateway API Resources"
        Gateways["gateway.networking.k8s.io<br/>gateways"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes, referencegrants"]
    end

    subgraph "RBAC Resources"
        RBACResources["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterroles, clusterrolebindings"]
    end

    subgraph "Other Resources"
        Leases["coordination.k8s.io<br/>leases"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - Full CRUD
    CR -->|get, list, watch<br/>create, update, patch, delete| Pods
    CR -->|get, list, watch<br/>patch, update| Deployments
    CR -->|get, list, watch<br/>create, update, patch, delete| Jobs
    CR -->|get, list, watch<br/>create, update, patch, delete| RayCRDs
    CR -->|get, list, watch<br/>create, update, patch, delete| Network
    CR -->|get, list, watch<br/>create, update, patch, delete| Routes
    CR -->|get, list, watch<br/>create, update, patch, delete| Certificates
    CR -->|get, list, watch<br/>create, update, patch, delete| HTTPRoutes
    CR -->|get, list, watch<br/>create, update, delete| RBACResources

    %% Permissions - Status Updates
    CR -->|get, patch, update| PodsStatus
    CR -->|get, patch, update| RayStatus
    CR -->|get, patch, update| CertStatus

    %% Permissions - Finalizers
    CR -->|update| RayFinalizers

    %% Permissions - Read Only
    CR -->|get, list, watch| Gateways
    CR -->|get, list, watch| OpenshiftConfig
    CR -->|get, list, watch| OpenshiftOperator

    %% Permissions - Create Only
    CR -->|create| TokenReviews
    CR -->|create| SubjectAccessReviews

    %% Permissions - Lease Management
    CR -->|get, list, create, update| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsStatus fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333,color:#fff
    style RayCRDs fill:#9b59b6,stroke:#333,color:#fff
    style RayStatus fill:#9b59b6,stroke:#333,color:#fff
    style RayFinalizers fill:#9b59b6,stroke:#333,color:#fff
    style Network fill:#7ed321,stroke:#333,color:#fff
    style Routes fill:#ee0000,stroke:#333,color:#fff
    style OpenshiftConfig fill:#ee0000,stroke:#333,color:#fff
    style OpenshiftOperator fill:#ee0000,stroke:#333,color:#fff
    style Certificates fill:#34495e,stroke:#333,color:#fff
    style CertStatus fill:#34495e,stroke:#333,color:#fff
    style Gateways fill:#16a085,stroke:#333,color:#fff
    style HTTPRoutes fill:#16a085,stroke:#333,color:#fff
    style RBACResources fill:#e67e22,stroke:#333,color:#fff
    style Leases fill:#95a5a6,stroke:#333,color:#fff
    style TokenReviews fill:#95a5a6,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#95a5a6,stroke:#333,color:#fff
