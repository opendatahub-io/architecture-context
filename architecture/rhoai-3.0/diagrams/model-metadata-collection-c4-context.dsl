// C4 Context Diagram - Model Metadata Collection
// Generated by: Claude Opus 4.6

workspace {
    model {
        ciEngineer = person "CI/CD Engineer" "Maintains build pipelines and model catalog updates"
        dataScientist = person "Data Scientist" "Browses and selects AI models from the catalog"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time pipeline that extracts, enriches, and catalogs metadata from Red Hat AI model container images" {
            modelExtractor = container "model-extractor" "Discovers models from HuggingFace, extracts model cards from OCI containers, enriches metadata, generates catalog YAML" "Go CLI (build-time only)"
            metadataReport = container "metadata-report" "Generates metadata completeness reports analyzing field coverage and data sources" "Go CLI (build-time only)"
            dataContainer = container "Data Container" "Minimal ubi9-micro container holding pre-generated catalog YAML files, served via volume mount (sleep infinity)" "Container (ubi9-micro)"
        }

        huggingface = softwareSystem "HuggingFace" "AI model hosting platform with collections and metadata API" "External"
        redHatRegistry = softwareSystem "Red Hat Container Registry" "OCI container registry hosting ModelCar images with embedded model cards" "External"
        konflux = softwareSystem "Konflux CI/CD" "Build system for multi-arch container images via Tekton pipelines" "External"
        quay = softwareSystem "Quay.io" "Container image registry for RHOAI images" "External"

        modelCatalogUI = softwareSystem "Model Catalog UI" "ODH Dashboard component displaying available AI models" "Internal RHOAI"

        // Build-time relationships
        modelExtractor -> huggingface "Discovers model collections, fetches metadata and READMEs" "HTTPS/443, TLS 1.2+, Public API"
        modelExtractor -> redHatRegistry "Fetches OCI manifests and model card layers" "HTTPS/443, TLS 1.2+, Docker Auth"
        modelExtractor -> dataContainer "Generates catalog YAML files" "File I/O"
        konflux -> dataContainer "Builds multi-arch container image" "Tekton PipelineRun"
        konflux -> quay "Pushes built container image" "HTTPS/443"

        // Runtime relationships
        modelCatalogUI -> dataContainer "Reads catalog YAML via volume mount" "File I/O, /app/data/"
        dataScientist -> modelCatalogUI "Browses model catalog"
        ciEngineer -> konflux "Triggers builds via git push"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
