/*
 * C4 Context Diagram: Guardrails Regex Detector
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/guardrails-regex-detector.md
 */

workspace {
    model {
        orchestratorTeam = person "Platform Engineer" "Configures and deploys guardrails detection pipeline"

        regexDetector = softwareSystem "Guardrails Regex Detector" "Lightweight Rust HTTP microservice that detects PII and custom patterns in text using regex matching" {
            mainService = container "regex-detector" "Rust binary serving detection API on configurable port (default 8080)" "Rust / axum 0.7.9 / tokio 1.41.1"
            detectorsModule = container "detectors module" "Built-in PII regex patterns (email, SSN, credit card) and custom regex handling" "Rust Module"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Routes content through various detector services to enforce guardrails on AI model inputs and outputs" "Internal RHOAI"
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform (OCP v4.19/v4.20)" "External"
        serviceMesh = softwareSystem "Service Mesh" "Provides mTLS encryption and network policies at platform level" "External"

        # Relationships
        orchestrator -> regexDetector "Sends text content detection requests" "HTTP POST /api/v1/text/contents, 8080/TCP"
        kubernetes -> regexDetector "Health check probes" "HTTP GET /health, 8080/TCP"
        serviceMesh -> regexDetector "Provides transport encryption" "mTLS"

        # Internal relationships
        mainService -> detectorsModule "Uses for pattern matching"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
        }

        container regexDetector "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
