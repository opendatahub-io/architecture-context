graph TD
    subgraph "Service Accounts"
        SA1[controller-manager<br/>NS: trustyai-service-operator-system]
        SA2[default<br/>NS: user-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[default-lmeval-user-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR1[manager-role<br/>Full Operator Permissions]
        CR2[non-admin-lmeval-role<br/>LMEvalJob User Permissions]
    end

    subgraph "API Resources - Core"
        Core1[configmaps, pvcs, pods<br/>secrets, services<br/>serviceaccounts]
        Core2[pods/exec]
        Core3[events]
        Core4[persistentvolumes]
    end

    subgraph "API Resources - Apps"
        Apps1[deployments<br/>deployments/finalizers<br/>deployments/status]
    end

    subgraph "API Resources - KServe"
        KServe1[inferenceservices<br/>inferenceservices/finalizers<br/>servingruntimes]
    end

    subgraph "API Resources - TrustyAI CRDs"
        TrustyAI1[trustyaiservices<br/>trustyaiservices/finalizers<br/>trustyaiservices/status]
        TrustyAI2[lmevaljobs<br/>lmevaljobs/finalizers<br/>lmevaljobs/status]
        TrustyAI3[guardrailsorchestrators<br/>guardrailsorchestrators/finalizers<br/>guardrailsorchestrators/status]
    end

    subgraph "API Resources - Monitoring"
        Mon1[servicemonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - Networking"
        Net1[routes<br/>route.openshift.io]
        Net2[virtualservices<br/>destinationrules<br/>networking.istio.io]
    end

    subgraph "API Resources - Kueue"
        Kueue1[workloads<br/>workloads/finalizers<br/>workloads/status]
        Kueue2[resourceflavors<br/>workloadpriorityclasses]
    end

    subgraph "API Resources - RBAC"
        RBAC1[clusterrolebindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - Coordination"
        Coord1[leases<br/>coordination.k8s.io]
    end

    %% Service Account to Bindings
    SA1 -->|bound via| CRB1
    SA2 -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% manager-role permissions (Full CRUD)
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Core1
    CR1 -->|"create, delete<br/>get, list, watch"| Core2
    CR1 -->|"create, patch<br/>update, watch"| Core3
    CR1 -->|"get, list, watch"| Core4
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| Apps1
    CR1 -->|"get, list, patch<br/>update, watch, delete"| KServe1
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| TrustyAI1
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| TrustyAI2
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| TrustyAI3
    CR1 -->|"create, list, watch"| Mon1
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| Net1
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| Net2
    CR1 -->|"create, delete, get, list<br/>patch, update, watch"| Kueue1
    CR1 -->|"get, list, watch"| Kueue2
    CR1 -->|"create, delete, get<br/>list, update, watch"| RBAC1
    CR1 -->|"create, get, update"| Coord1

    %% non-admin-lmeval-role permissions (Limited)
    CR2 -->|"create, delete, get, list<br/>patch, update, watch"| TrustyAI2
    CR2 -.->|"get (status only)"| TrustyAI2

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px
    style CRB1 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB2 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:3px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px

    style Core1 fill:#d0d0d0,stroke:#333
    style Core2 fill:#d0d0d0,stroke:#333
    style Core3 fill:#d0d0d0,stroke:#333
    style Core4 fill:#d0d0d0,stroke:#333
    style Apps1 fill:#d0d0d0,stroke:#333
    style KServe1 fill:#e8e8f0,stroke:#333
    style TrustyAI1 fill:#ffe6cc,stroke:#333
    style TrustyAI2 fill:#ffe6cc,stroke:#333
    style TrustyAI3 fill:#ffe6cc,stroke:#333
    style Mon1 fill:#d0d0d0,stroke:#333
    style Net1 fill:#d0d0d0,stroke:#333
    style Net2 fill:#d0d0d0,stroke:#333
    style Kueue1 fill:#d0d0d0,stroke:#333
    style Kueue2 fill:#d0d0d0,stroke:#333
    style RBAC1 fill:#d0d0d0,stroke:#333
    style Coord1 fill:#d0d0d0,stroke:#333
