graph TD
    subgraph "Service Accounts"
        SAController[controller-manager<br/>Operator SA]
        SADefault[default<br/>Per Namespace]
        SATrustyAI[trustyai-name-sa<br/>TrustyAI Service SA]
        SAGORCH[gorch-name-sa<br/>Guardrails SA]
        SALMES[lmevaljob-name-sa<br/>LMEvalJob SA]
    end

    subgraph "ClusterRole Bindings"
        CRBManager[manager-rolebinding<br/>ClusterRoleBinding]
        CRBLMEval[default-lmeval-user-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "RoleBindings (Operator Namespace)"
        RBLeader[leader-election-rolebinding]
        RBAuthProxy[auth-proxy-rolebinding]
    end

    subgraph "ClusterRoles"
        CRManager[manager-role<br/>Comprehensive Operator Permissions]
        CRLeader[leader-election-role<br/>Leader Election]
        CRAuthProxy[auth-proxy-role<br/>Proxy Authentication]
        CRNonAdminLMEval[non-admin-lmeval-role<br/>LMEvalJob User Permissions]
    end

    subgraph "Core API Resources"
        CoreConfigMaps[core/ConfigMaps<br/>create,delete,get,list,patch,update,watch]
        CorePVCs[core/PersistentVolumeClaims<br/>create,delete,get,list,patch,update,watch]
        CorePods[core/Pods<br/>create,delete,get,list,patch,update,watch]
        CorePodsExec[core/Pods/exec<br/>create,delete,get,list,watch]
        CoreSecrets[core/Secrets<br/>create,delete,get,list,patch,update,watch]
        CoreServices[core/Services<br/>create,delete,get,list,patch,update,watch]
        CoreEvents[core/Events<br/>create,patch,update,watch]
        CorePVs[core/PersistentVolumes<br/>get,list,watch]
        CoreSAs[core/ServiceAccounts<br/>create,delete,get,list,update,watch]
    end

    subgraph "Apps API Resources"
        AppsDeployments[apps/Deployments<br/>create,delete,get,list,patch,update,watch]
        AppsDeploymentsFinalizers[apps/Deployments/finalizers<br/>update]
        AppsDeploymentsStatus[apps/Deployments/status<br/>get,patch,update]
    end

    subgraph "KServe API Resources"
        KServeInferenceServices[serving.kserve.io/InferenceServices<br/>get,list,patch,update,watch]
        KServeInferenceServicesFinalizers[serving.kserve.io/InferenceServices/finalizers<br/>delete,get,list,patch,update,watch]
        KServeServingRuntimes[serving.kserve.io/ServingRuntimes<br/>get,list,watch]
    end

    subgraph "TrustyAI API Resources"
        TrustyAIServices[trustyai.opendatahub.io/TrustyAIServices<br/>create,delete,get,list,patch,update,watch]
        TrustyAIServicesFinalizers[trustyai.opendatahub.io/TrustyAIServices/finalizers<br/>update]
        TrustyAIServicesStatus[trustyai.opendatahub.io/TrustyAIServices/status<br/>get,patch,update]

        LMEvalJobs[trustyai.opendatahub.io/LMEvalJobs<br/>create,delete,get,list,patch,update,watch]
        LMEvalJobsFinalizers[trustyai.opendatahub.io/LMEvalJobs/finalizers<br/>update]
        LMEvalJobsStatus[trustyai.opendatahub.io/LMEvalJobs/status<br/>get,patch,update]
        LMEvalJobsStatusReadOnly[trustyai.opendatahub.io/LMEvalJobs/status<br/>get ONLY]

        GuardrailsOrchestrators[trustyai.opendatahub.io/GuardrailsOrchestrators<br/>create,delete,get,list,patch,update,watch]
        GuardrailsOrchestratorsFinalizers[trustyai.opendatahub.io/GuardrailsOrchestrators/finalizers<br/>update]
        GuardrailsOrchestratorsStatus[trustyai.opendatahub.io/GuardrailsOrchestrators/status<br/>get,patch,update]
    end

    subgraph "Monitoring API Resources"
        MonitoringServiceMonitors[monitoring.coreos.com/ServiceMonitors<br/>create,list,watch]
    end

    subgraph "OpenShift API Resources"
        RouteRoutes[route.openshift.io/Routes<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Istio API Resources"
        IstioDestinationRules[networking.istio.io/DestinationRules<br/>create,delete,get,list,patch,update,watch]
        IstioVirtualServices[networking.istio.io/VirtualServices<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Kueue API Resources"
        KueueWorkloads[kueue.x-k8s.io/Workloads<br/>create,delete,get,list,patch,update,watch]
        KueueWorkloadsFinalizers[kueue.x-k8s.io/Workloads/finalizers<br/>update]
        KueueWorkloadsStatus[kueue.x-k8s.io/Workloads/status<br/>get,patch,update]
        KueueResourceFlavors[kueue.x-k8s.io/ResourceFlavors<br/>get,list,watch]
        KueueWorkloadPriorityClasses[kueue.x-k8s.io/WorkloadPriorityClasses<br/>get,list,watch]
    end

    subgraph "RBAC API Resources"
        RBACClusterRoleBindings[rbac.authorization.k8s.io/ClusterRoleBindings<br/>create,delete,get,list,update,watch]
    end

    subgraph "Coordination API Resources"
        CoordinationLeases[coordination.k8s.io/Leases<br/>create,get,update,patch,delete]
    end

    subgraph "API Extensions Resources"
        APIExtCRDs[apiextensions.k8s.io/CustomResourceDefinitions<br/>get,list,watch]
    end

    subgraph "Scheduling API Resources"
        SchedulingPriorityClasses[scheduling.k8s.io/PriorityClasses<br/>get,list,watch]
    end

    %% Service Account to Bindings
    SAController -->|bound via| CRBManager
    SAController -->|bound via| RBLeader
    SAController -->|bound via| RBAuthProxy
    SADefault -->|bound via| CRBLMEval

    %% Bindings to Roles
    CRBManager -->|grants| CRManager
    CRBLMEval -->|grants| CRNonAdminLMEval
    RBLeader -->|grants| CRLeader
    RBAuthProxy -->|grants| CRAuthProxy

    %% Manager Role Permissions
    CRManager -->|full CRUD| CoreConfigMaps
    CRManager -->|full CRUD| CorePVCs
    CRManager -->|full CRUD| CorePods
    CRManager -->|exec access| CorePodsExec
    CRManager -->|full CRUD| CoreSecrets
    CRManager -->|full CRUD| CoreServices
    CRManager -->|event mgmt| CoreEvents
    CRManager -->|read-only| CorePVs
    CRManager -->|full CRUD| CoreSAs

    CRManager -->|full CRUD| AppsDeployments
    CRManager -->|finalizers| AppsDeploymentsFinalizers
    CRManager -->|status mgmt| AppsDeploymentsStatus

    CRManager -->|watch/patch| KServeInferenceServices
    CRManager -->|finalizers| KServeInferenceServicesFinalizers
    CRManager -->|read-only| KServeServingRuntimes

    CRManager -->|full CRUD| TrustyAIServices
    CRManager -->|finalizers| TrustyAIServicesFinalizers
    CRManager -->|status mgmt| TrustyAIServicesStatus
    CRManager -->|full CRUD| LMEvalJobs
    CRManager -->|finalizers| LMEvalJobsFinalizers
    CRManager -->|status mgmt| LMEvalJobsStatus
    CRManager -->|full CRUD| GuardrailsOrchestrators
    CRManager -->|finalizers| GuardrailsOrchestratorsFinalizers
    CRManager -->|status mgmt| GuardrailsOrchestratorsStatus

    CRManager -->|create/watch| MonitoringServiceMonitors
    CRManager -->|full CRUD| RouteRoutes
    CRManager -->|full CRUD| IstioDestinationRules
    CRManager -->|full CRUD| IstioVirtualServices

    CRManager -->|full CRUD| KueueWorkloads
    CRManager -->|finalizers| KueueWorkloadsFinalizers
    CRManager -->|status mgmt| KueueWorkloadsStatus
    CRManager -->|read-only| KueueResourceFlavors
    CRManager -->|read-only| KueueWorkloadPriorityClasses

    CRManager -->|full CRUD| RBACClusterRoleBindings
    CRManager -->|leader election| CoordinationLeases
    CRManager -->|read-only| APIExtCRDs
    CRManager -->|read-only| SchedulingPriorityClasses

    %% Leader Election Role Permissions
    CRLeader -->|leader election| CoreConfigMaps
    CRLeader -->|leader election| CoordinationLeases
    CRLeader -->|event mgmt| CoreEvents

    %% Non-Admin LMEval Role Permissions
    CRNonAdminLMEval -->|full CRUD| LMEvalJobs
    CRNonAdminLMEval -->|read-only| LMEvalJobsStatusReadOnly

    %% Styling
    style SAController fill:#4a90e2,color:#fff
    style CRManager fill:#e74c3c,color:#fff
    style CRLeader fill:#e67e22,color:#fff
    style CRNonAdminLMEval fill:#3498db,color:#fff

    style TrustyAIServices fill:#7ed321
    style LMEvalJobs fill:#7ed321
    style GuardrailsOrchestrators fill:#7ed321

    style KServeInferenceServices fill:#f5a623
    style IstioDestinationRules fill:#f5a623
    style IstioVirtualServices fill:#f5a623
    style RouteRoutes fill:#f5a623
