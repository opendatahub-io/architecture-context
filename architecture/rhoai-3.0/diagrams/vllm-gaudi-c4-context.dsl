/* C4 Context Diagram for vLLM Gaudi */
/* Generated by: Claude Opus 4.6 */

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries LLM models for inference"
        application = person "Application / Client" "Sends inference requests via API"

        vllmGaudi = softwareSystem "vLLM Gaudi" "High-throughput LLM inference engine optimized for Intel Gaudi AI accelerators" {
            openaiServer = container "OpenAI API Server" "OpenAI-compatible HTTP inference API (chat, completions, embeddings, scoring, reranking, transcription)" "Python FastAPI/Uvicorn" "8000/TCP"
            tgisAdapter = container "TGIS gRPC Adapter" "TGIS-compatible gRPC interface for KServe integration" "Python gRPC (vllm-tgis-adapter)" "8033/TCP"
            asyncEngine = container "Async LLM Engine" "Request scheduling, continuous batching, and token generation" "Python"
            hpuWorker = container "HPU Worker" "Gaudi-specific model execution, KV cache management, distributed inference" "Python PyTorch"
            prometheusMetrics = container "Prometheus Metrics" "Metrics endpoint for monitoring" "prometheus-fastapi-instrumentator"
            sslRefresher = container "SSL Certificate Refresher" "Dynamic TLS cert reload without restart" "Python"
            otelTracing = container "OpenTelemetry Tracing" "Distributed tracing via OTLP exporter" "OpenTelemetry SDK"
        }

        kserve = softwareSystem "KServe" "Model serving platform managing InferenceService lifecycle" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and artifacts" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "UI for managing model serving" "Internal RHOAI"

        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Platform"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed trace collection" "Platform"
        gaudiHardware = softwareSystem "Intel Gaudi 2/3 Accelerators" "AI accelerator hardware (HPU)" "Hardware"
        hfHub = softwareSystem "HuggingFace Hub / Model Storage" "Model weight storage (S3/PVC/HF Hub)" "External"
        rayCluster = softwareSystem "Ray Cluster" "Distributed computing for multi-HPU inference" "External"

        /* User interactions */
        datascientist -> kserve "Deploys InferenceService with vLLM Gaudi runtime"
        application -> vllmGaudi "Sends inference requests" "HTTPS/443 via Gateway"

        /* Internal container relationships */
        openaiServer -> asyncEngine "Submits requests" "ZMQ IPC"
        tgisAdapter -> openaiServer "Proxies gRPC to HTTP" "HTTP/8000 localhost"
        asyncEngine -> hpuWorker "Dispatches inference" "PyTorch distributed"
        openaiServer -> prometheusMetrics "Exposes metrics"
        openaiServer -> sslRefresher "Refreshes TLS certs"
        openaiServer -> otelTracing "Sends trace spans"

        /* External interactions */
        kserve -> vllmGaudi "Manages as serving runtime container" "HTTP/8000, gRPC/8033"
        vllmGaudi -> gaudiHardware "Executes model inference" "PCIe/Device"
        vllmGaudi -> hfHub "Downloads model weights" "HTTPS/443"
        vllmGaudi -> rayCluster "Coordinates distributed inference" "TCP/6379, 8265"
        prometheus -> vllmGaudi "Scrapes metrics" "HTTP/8000 /metrics"
        otelTracing -> otelCollector "Exports traces" "gRPC/4317 OTLP"
        modelRegistry -> vllmGaudi "Provides model metadata" "HTTP"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #f5a623
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Hardware" {
                background #e74c3c
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
