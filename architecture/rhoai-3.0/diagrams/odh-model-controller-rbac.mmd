graph TD
    subgraph "Service Account"
        SA[odh-model-controller<br/>ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[metrics-auth-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[odh-model-controller-role]
        CR2[leader-election-role]
        CR3[metrics-auth-role]
    end

    subgraph "Core Resources"
        Core1[core<br/>configmaps, secrets, serviceaccounts, services<br/>Verbs: create, delete, get, list, patch, update, watch]
        Core2[core<br/>endpoints, namespaces, pods<br/>Verbs: create, get, list, patch, update, watch]
        Core3[core<br/>events<br/>Verbs: create, patch]
    end

    subgraph "KServe Resources"
        KServe1[serving.kserve.io<br/>inferenceservices, inferenceservices/finalizers<br/>Verbs: get, list, patch, update, watch, create, delete]
        KServe2[serving.kserve.io<br/>servingruntimes, servingruntimes/finalizers<br/>Verbs: create, get, list, update, watch]
        KServe3[serving.kserve.io<br/>llminferenceservices, llminferenceservices/status, llminferenceservices/finalizers<br/>Verbs: get, list, patch, post, update, watch]
        KServe4[serving.kserve.io<br/>inferencegraphs, inferencegraphs/finalizers, llminferenceserviceconfigs<br/>Verbs: get, list, watch, update]
    end

    subgraph "OpenShift Resources"
        OS1[route.openshift.io<br/>routes, routes/custom-host<br/>Verbs: create, delete, get, list, patch, update, watch]
        OS2[template.openshift.io<br/>templates<br/>Verbs: create, delete, get, list, patch, update, watch]
        OS3[config.openshift.io<br/>authentications<br/>Verbs: get, list, watch]
    end

    subgraph "Networking Resources"
        Net1[networking.k8s.io<br/>networkpolicies, ingresses<br/>Verbs: create, delete, get, list, patch, update, watch]
        Net2[networking.istio.io<br/>envoyfilters<br/>Verbs: create, delete, get, list, patch, update, watch]
        Net3[gateway.networking.k8s.io<br/>gateways, gateways/finalizers, httproutes<br/>Verbs: get, list, patch, update, watch]
    end

    subgraph "Monitoring Resources"
        Mon1[monitoring.coreos.com<br/>servicemonitors, podmonitors<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Security & Auth Resources"
        Sec1[rbac.authorization.k8s.io<br/>clusterrolebindings, roles, rolebindings<br/>Verbs: create, delete, get, list, patch, update, watch]
        Sec2[kuadrant.io<br/>authpolicies, authpolicies/status<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Autoscaling Resources"
        Auto1[keda.sh<br/>triggerauthentications<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "NIM Resources"
        NIM1[nim.opendatahub.io<br/>accounts, accounts/status, accounts/finalizers<br/>Verbs: get, list, patch, update, watch]
    end

    subgraph "ODH Platform Resources"
        ODH1[datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>Verbs: get, list, watch]
        ODH2[dscinitialization.opendatahub.io<br/>dscinitializations<br/>Verbs: get, list, watch]
    end

    subgraph "Metrics Resources"
        Metrics1[metrics.k8s.io<br/>nodes, pods<br/>Verbs: get, list, watch]
    end

    subgraph "Leader Election Resources"
        Leader1[core, coordination.k8s.io<br/>configmaps, leases, events<br/>Verbs: get, list, watch, create, update, patch, delete]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
