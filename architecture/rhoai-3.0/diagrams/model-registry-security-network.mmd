%% Model Registry - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (Istio Gateway)"]
        Gateway["Istio VirtualService<br/>kubeflow-gateway<br/>8080/TCP → 8080/TCP<br/>TLS Mode: ISTIO_MUTUAL"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_Kubeflow["Namespace: kubeflow"]
            ProxyServer["Model Registry Proxy Server<br/>SA: model-registry<br/>Port: 8080/TCP HTTP<br/>FIPS: strictfipsruntime<br/>HTTP/2: Disabled"]
            CatalogServer["Model Catalog Server<br/>Port: 8080/TCP HTTP<br/>Istio mTLS in-mesh"]
            BFF["UI BFF<br/>SA: model-registry-ui<br/>Port: 8080/TCP HTTP/HTTPS<br/>TLS 1.3 (optional)"]
            UIFrontend["UI Frontend<br/>(React SPA)"]
            ISController["InferenceService Controller<br/>SA: controller-manager<br/>Metrics: 8443/TCP HTTPS<br/>Health: 8081/TCP"]
        end

        subgraph NS_KServe["Namespace: user-namespace"]
            CSI["CSI Storage Initializer<br/>(KServe init container)"]
        end
    end

    subgraph DataStores["DATA STORES"]
        MySQL["MySQL 8.x<br/>Port: 3306/TCP<br/>TLS 1.2+ configurable<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL 13+<br/>Port: 5432/TCP<br/>sslmode configurable<br/>Auth: Username/Password"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>Port: 443/TCP<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
        HuggingFace["HuggingFace API<br/>Port: 443/TCP<br/>TLS 1.2+<br/>Auth: None"]
        S3["Model Artifact Storage<br/>(S3/OBC)<br/>Port: 443/TCP<br/>TLS 1.2+<br/>Auth: Storage Credentials"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>Port: 8443/TCP HTTPS"]
    end

    %% External flows
    Client -->|"HTTP/HTTPS 8080<br/>TLS 1.3 (optional)<br/>User/Bearer Token"| Gateway
    Client -->|"HTTP/HTTPS 8080<br/>TLS 1.3 (optional)<br/>User Token"| BFF

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/8080<br/>Istio mTLS STRICT<br/>AuthzPolicy: ALLOW ALL"| ProxyServer

    %% Internal mesh flows
    BFF -->|"HTTP/8080<br/>Istio mTLS<br/>Internal SA Token"| ProxyServer
    BFF -->|"HTTP/8080<br/>Istio mTLS"| CatalogServer
    UIFrontend -->|"HTTP/8080"| BFF

    %% Controller flows
    ISController -->|"HTTP/HTTPS 8080<br/>configurable TLS<br/>Bearer Token"| ProxyServer

    %% CSI flows
    CSI -->|"HTTP/8080<br/>plaintext<br/>No Auth"| ProxyServer
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage Credentials"| S3

    %% Data store flows
    ProxyServer -->|"MySQL/3306 or PG/5432<br/>TLS 1.2+ configurable<br/>Username/Password DSN"| MySQL
    ProxyServer -->|"MySQL/3306 or PG/5432<br/>TLS 1.2+ configurable<br/>Username/Password DSN"| PostgreSQL
    CatalogServer -->|"PG/5432<br/>configurable sslmode<br/>Username/Password"| PostgreSQL

    %% External service flows
    BFF -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    ISController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    CatalogServer -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| HuggingFace
    Prometheus -->|"HTTPS/8443<br/>TLS (self-signed)<br/>Bearer Token + RBAC"| ISController

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class ProxyServer,CatalogServer,BFF,UIFrontend,ISController,CSI servicemesh
    class MySQL,PostgreSQL datastore
    class K8sAPI,HuggingFace,S3,Prometheus externalservice
