%% RBAC Visualization for Guardrails Detectors
%% Generated by: Claude Opus 4.6
graph TD
    subgraph "Service Accounts"
        SA1[user-one<br/>example deployment SA]
    end

    subgraph "Role Bindings"
        RB1[user-one-view<br/>RoleBinding<br/>Namespace: deployment namespace]
    end

    subgraph "Cluster Roles"
        CR1[view<br/>ClusterRole<br/>standard Kubernetes view role]
    end

    subgraph "API Resources (view access)"
        Pods[core<br/>Pods]
        Services[core<br/>Services]
        ConfigMaps[core<br/>ConfigMaps]
        Deployments[apps<br/>Deployments]
    end

    SA1 -->|bound via| RB1
    RB1 -->|grants| CR1
    CR1 -->|"get, list, watch"| Pods
    CR1 -->|"get, list, watch"| Services
    CR1 -->|"get, list, watch"| ConfigMaps
    CR1 -->|"get, list, watch"| Deployments

    subgraph "KServe CRDs (consumed, not defined)"
        ServingRuntime[serving.kserve.io<br/>ServingRuntime<br/>v1alpha1]
        InferenceService[serving.kserve.io<br/>InferenceService<br/>v1beta1]
    end

    subgraph "Authentication Mechanisms"
        IstioMTLS["Istio mTLS (STRICT)<br/>PeerAuthentication<br/>HF + Judge detectors"]
        PlatformAuth["RHOAI Platform Auth<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
        CustomDetSec["Custom Detector Security<br/>AST static analysis<br/>Forbidden: os, subprocess,<br/>sys, shutil, eval, exec,<br/>open, compile, input"]
    end

    subgraph "Secrets"
        S3Creds["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>endpoint, bucket, region<br/>Auto-rotate: No"]
    end

