graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>TLS 1.2+"]
        Gateway["Gateway HTTPRoute<br/>(Alternative)<br/>443/TCP → 8443/TCP<br/>TLS Passthrough"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Trusted)"]
        direction TB

        subgraph Service["Service: odh-dashboard"]
            SvcEndpoint["ClusterIP<br/>8443/TCP"]
        end

        subgraph Pod["Pod: odh-dashboard<br/>NS: opendatahub/redhat-ods-applications<br/>SA: odh-dashboard"]
            direction LR

            Proxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>8444/TCP Health<br/>OAuth2 Validation<br/>Header Injection"]
            Backend["odh-dashboard<br/>8080/TCP HTTP<br/>Node.js/Fastify<br/>React SPA Server<br/>WebSocket Support"]

            Proxy -->|HTTP 8080/TCP<br/>Pod-local<br/>User/Group Headers| Backend
        end

        Service --> Proxy

        subgraph InternalServices["INTERNAL SERVICES"]
            direction TB

            K8sAPI["Kubernetes API<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS1.2+<br/>SA Token Auth"]
            Thanos["Thanos Querier<br/>thanos-querier.openshift-monitoring.svc<br/>9092/TCP HTTPS TLS1.2+<br/>SA Token Auth"]
            ModelReg["Model Registry<br/>model-registry-*.svc<br/>8080/TCP HTTP, 9090/TCP gRPC<br/>Bearer Token Auth"]
            KServe["KServe Predictors<br/>{inferenceservice-name}.svc<br/>8080/8443 HTTP/HTTPS<br/>Varies Auth"]
            ImageReg["Image Registry<br/>image-registry.openshift-image-registry<br/>443/TCP HTTPS TLS1.2+<br/>SA Token Auth"]
        end

        subgraph AuthServices["AUTHENTICATION"]
            OAuth["OpenShift OAuth<br/>oauth-openshift.openshift-authentication.svc<br/>443/TCP HTTPS TLS1.2+<br/>OAuth2 Flow"]
        end
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Bearer Token| Route
    User -.->|Alternative| Gateway

    %% Ingress to Service
    Route -->|HTTPS/8443<br/>TLS Reencrypt| SvcEndpoint
    Gateway -.->|HTTPS/8443<br/>TLS Passthrough| SvcEndpoint

    %% Proxy to OAuth
    Proxy <-->|HTTPS/443<br/>OAuth2 Flow<br/>Token Validation| OAuth

    %% Backend Egress
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>SA Token| Thanos
    Backend -->|HTTP/8080, gRPC/9090<br/>Bearer Token| ModelReg
    Backend -->|HTTP/8080, HTTPS/8443<br/>Varies| KServe
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| ImageReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef proxy fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef backend fill:#4a90e2,stroke:#2874c7,stroke-width:2px,color:#fff
    classDef service fill:#e1f5e1,stroke:#6bb66b,stroke-width:1px,color:#000
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef auth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000

    class User external
    class Route,Gateway ingress
    class Proxy proxy
    class Backend backend
    class SvcEndpoint service
    class K8sAPI,Thanos,ModelReg,KServe,ImageReg internal
    class OAuth auth

    %% Trust boundary annotations
    style External fill:#fff,stroke:#f00,stroke-width:3px,stroke-dasharray: 5 5
    style Ingress fill:#fff,stroke:#f90,stroke-width:3px,stroke-dasharray: 5 5
    style ClusterNetwork fill:#fff,stroke:#0a0,stroke-width:3px,stroke-dasharray: 5 5
