graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt<br/>Auto-generated host"]
        Gateway["Gateway HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Passthrough<br/>Via Gateway host"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        Proxy["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS<br/>Port: 8444/TCP HTTPS (health)<br/>TLS Cert: dashboard-proxy-tls<br/>SA: odh-dashboard"]

        ProxyFunc["OAuth2 Flow:<br/>1. Validate JWT Bearer<br/>2. Query OpenShift OAuth<br/>3. Inject headers:<br/>   X-Auth-Request-User<br/>   X-Auth-Request-Groups<br/>   X-Forwarded-Access-Token"]

        Proxy -.->|function| ProxyFunc
    end

    subgraph AppLayer["APPLICATION LAYER (Pod-local, Trusted)"]
        Backend["ODH Dashboard Backend<br/>Node.js/Fastify<br/>Port: 8080/TCP HTTP<br/>SA: odh-dashboard<br/>Image: ubi9/nodejs-20"]

        BackendFunc["Functions:<br/>- Serve React SPA<br/>- Proxy K8s API<br/>- WebSocket server<br/>- Enforce RBAC"]

        Backend -.->|functions| BackendFunc
    end

    subgraph EgressInternal["EGRESS - Internal Cluster Services"]
        direction TB

        K8sAPI["Kubernetes API<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS1.2+<br/>Auth: SA Token<br/>Purpose: CRD/resource CRUD"]

        Thanos["Thanos Querier<br/>thanos-querier.openshift-monitoring.svc<br/>9092/TCP HTTPS TLS1.2+<br/>Auth: SA Token<br/>Purpose: Prometheus metrics"]

        ModelReg["Model Registry Services<br/>model-registry-*.svc<br/>8080/TCP HTTP, 9090/TCP gRPC<br/>Auth: Bearer Token<br/>Purpose: Model registry mgmt"]

        KServePred["KServe Predictor Services<br/>*.svc (user namespaces)<br/>8080/TCP HTTP, 8443/TCP HTTPS<br/>Auth: None or Bearer<br/>Purpose: Inference proxying"]
    end

    subgraph EgressAuth["EGRESS - External Authentication"]
        OAuth["OpenShift OAuth<br/>oauth-openshift.openshift-authentication.svc<br/>443/TCP HTTPS TLS1.2+<br/>Auth: OAuth2 Protocol<br/>Purpose: User authentication"]
    end

    %% External flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Route
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Gateway

    %% Ingress to Auth
    Route -->|HTTPS/8443<br/>TLS 1.2+<br/>OAuth2 Bearer| Proxy
    Gateway -->|HTTPS/8443<br/>TLS 1.2+<br/>OAuth2 Bearer| Proxy

    %% Auth to App
    Proxy -->|HTTP/8080<br/>Plaintext pod-local<br/>Headers User Group Token| Backend

    %% App to Egress
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>SA Token| Thanos
    Backend -->|HTTP/8080, gRPC/9090<br/>Varies<br/>Bearer Token| ModelReg
    Backend -->|HTTP/8080, HTTPS/8443<br/>Varies<br/>None or Bearer| KServePred

    %% Proxy to OAuth
    Proxy -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth2| OAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egressauth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef function fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Route,Gateway ingress
    class Proxy auth
    class Backend app
    class K8sAPI,Thanos,ModelReg,KServePred egress
    class OAuth egressauth
    class ProxyFunc,BackendFunc function
