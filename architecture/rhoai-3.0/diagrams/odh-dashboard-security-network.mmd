%% ODH Dashboard - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP<br/>TLS 1.2+<br/>HTTPRoute: path /"]
    end

    subgraph Pod["POD: rhods-dashboard<br/>Namespace: redhat-ods-applications<br/>SA: rhods-dashboard<br/>Replicas: 2"]
        direction TB

        subgraph SidecarKRBP["kube-rbac-proxy"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>8444/TCP (health)<br/>TLS: dashboard-proxy-tls<br/>AuthN: SubjectAccessReview<br/>(list projects)"]
        end

        subgraph MainContainer["odh-dashboard"]
            BackendApp["Backend (Node.js/Fastify)<br/>8080/TCP HTTP (loopback)<br/>API proxy + SPA server<br/>Guards: requestSecurityGuard,<br/>secureAdminRoute"]
        end

        subgraph SidecarMR["model-registry-ui"]
            MRUI["Model Registry UI<br/>8043/TCP HTTPS<br/>TLS: serving cert<br/>Module Federation Remote"]
        end

        subgraph SidecarGA["gen-ai-ui"]
            GAUI["Gen AI UI<br/>8143/TCP HTTPS<br/>TLS: serving cert<br/>Module Federation Remote"]
        end

        KRBP -->|"HTTP/8080<br/>loopback (plaintext)<br/>X-Auth-Request-User/Groups<br/>X-Forwarded-Access-Token"| BackendApp
        BackendApp -->|"HTTPS/8043<br/>TLS (serving cert)<br/>Bearer token"| MRUI
        BackendApp -->|"HTTPS/8143<br/>TLS (serving cert)<br/>Bearer token"| GAUI
    end

    subgraph ClusterServices["INTERNAL CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: SA token +<br/>User token passthrough"]
        Thanos["Thanos Querier<br/>(openshift-monitoring)<br/>9092/TCP HTTPS TLS<br/>Auth: User token"]
    end

    subgraph ManagedCRDs["MANAGED CRD RESOURCES"]
        KServe["KServe<br/>(InferenceService)"]
        Kubeflow["Kubeflow<br/>(Notebook)"]
        ModelReg["Model Registry<br/>(ModelRegistry)"]
        DSC["DSC / DSCI"]
        LlamaStack["LlamaStack"]
        FeastCR["Feast<br/>(FeatureStore)"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (serving cert)<br/>User token forwarded"| KRBP

    %% Auth check
    KRBP -->|"HTTPS/443<br/>SubjectAccessReview<br/>SA token"| K8sAPI

    %% Egress flows
    BackendApp -->|"HTTPS/443<br/>TLS<br/>User Bearer token<br/>(passthrough)"| K8sAPI
    BackendApp -->|"HTTPS/9092<br/>TLS<br/>User Bearer token"| Thanos

    %% CRD management (via K8s API)
    K8sAPI -.-> KServe
    K8sAPI -.-> Kubeflow
    K8sAPI -.-> ModelReg
    K8sAPI -.-> DSC
    K8sAPI -.-> LlamaStack
    K8sAPI -.-> FeastCR

