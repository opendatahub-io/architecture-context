graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI Client]
        Prometheus[Prometheus<br/>optional]
    end

    subgraph K8sAPI["KUBERNETES API SERVER (Trust Boundary)"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        Controller["Operator Controller Manager<br/>SA: controller-manager<br/>Security: non-root UID 1001<br/>Resources: 500m/1Gi limit"]

        subgraph Metrics["Metrics Endpoints"]
            MetricsInternal["Metrics<br/>8080/TCP HTTP<br/>localhost only"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token"]
        end

        subgraph Health["Health Endpoints"]
            Liveness["Liveness<br/>/healthz 8081/TCP"]
            Readiness["Readiness<br/>/readyz 8081/TCP"]
        end

        Controller -->|localhost| MetricsInternal
        RBACProxy -->|proxy| MetricsInternal
        Controller -->|exposes| Liveness
        Controller -->|exposes| Readiness
    end

    subgraph UserNS["USER NAMESPACE (per LlamaStackDistribution)"]
        direction TB

        subgraph ManagedResources["Managed Resources"]
            SA["ServiceAccount<br/>{instance-name}-sa"]
            PVC["PersistentVolumeClaim<br/>10Gi default<br/>/opt/app-root/src/.llama/"]
            LlamaStackPod["Llama Stack Server Pod<br/>8321/TCP HTTP<br/>no auth"]
            Service["ClusterIP Service<br/>{instance-name}-service<br/>8321:8321"]
            NetPolicy["NetworkPolicy<br/>{instance-name}-network-policy"]
        end

        LlamaStackPod -->|mounts| PVC
        Service -->|routes to| LlamaStackPod
        NetPolicy -->|protects| LlamaStackPod
        LlamaStackPod -->|uses| SA
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        subgraph InferenceProviders["Inference Providers"]
            Ollama["Ollama<br/>11434/TCP HTTP"]
            vLLM["vLLM<br/>8000/TCP HTTP"]
            TGI["TGI<br/>8080/TCP HTTP"]
        end

        Registry["Container Registry<br/>quay.io 443/TCP HTTPS TLS1.2+"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS TLS1.2+<br/>Token Auth"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS1.2+<br/>kubectl/SA Token| APIServer
    APIServer -->|Watch CRDs<br/>SA Token| Controller
    Controller -->|HTTPS/6443<br/>TLS1.2+<br/>SA Token<br/>Create Resources| APIServer

    Controller -->|HTTP/8321<br/>Health Check<br/>no auth| Service

    Prometheus -->|HTTPS/8443<br/>Bearer Token| RBACProxy

    Service -->|HTTP/8321| LlamaStackPod

    LlamaStackPod -->|HTTP<br/>Inference| Ollama
    LlamaStackPod -->|HTTP<br/>Inference| vLLM
    LlamaStackPod -->|HTTP<br/>Inference| TGI

    LlamaStackPod -->|HTTPS/443<br/>TLS1.2+<br/>Pull Images| Registry
    LlamaStackPod -.->|HTTPS/443<br/>TLS1.2+<br/>Token Auth<br/>Download Models| HuggingFace

    %% Network Policy Rules
    NetPolicy -.->|Allow Ingress from:<br/>app.kubernetes.io/part-of=llama-stack<br/>operator namespace| LlamaStackPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userspace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Prometheus external
    class APIServer k8sapi
    class Controller,RBACProxy,MetricsInternal,Liveness,Readiness operator
    class SA,PVC,LlamaStackPod,Service userspace
    class Ollama,vLLM,TGI,Registry,HuggingFace externalservice
    class NetPolicy security
