graph TB
    subgraph Operator["Llama Stack K8s Operator"]
        direction TB
        Controller["LlamaStackDistribution<br/>Reconciler<br/>(Go Controller)"]
        KustomizeRenderer["Kustomize Renderer<br/>(pkg/deploy)"]
        ClusterInfo["Cluster Info<br/>(pkg/cluster)"]
        FeatureFlags["Feature Flags<br/>(pkg/featureflags)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]

        Controller -->|renders manifests| KustomizeRenderer
        Controller -->|detects namespace,<br/>loads distributions| ClusterInfo
        Controller -->|checks flags| FeatureFlags
    end

    User[User / kubectl] -->|creates/updates| LLSDCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LLSDCR -->|watched by| Controller

    subgraph ManagedResources["Managed Resources (per CR)"]
        direction TB
        Deployment["Deployment<br/>{instance-name}"]
        Service["Service<br/>{instance-name}-service<br/>8321/TCP"]
        SA["ServiceAccount<br/>{instance-name}-sa"]
        PVC["PersistentVolumeClaim<br/>{instance-name}-pvc"]
        RB["RoleBinding<br/>{instance-name}-rb"]
        NP["NetworkPolicy<br/>{instance-name}-network-policy"]
    end

    Controller -->|creates/manages| Deployment
    Controller -->|creates if ports defined| Service
    Controller -->|creates| SA
    Controller -->|creates if storage configured| PVC
    Controller -->|creates| RB
    Controller -->|creates if feature flag enabled| NP

    subgraph LlamaStackServer["Managed Llama Stack Server"]
        HealthEndpoint["/v1/health<br/>8321/TCP"]
        ProvidersEndpoint["/v1/providers<br/>8321/TCP"]
        VersionEndpoint["/v1/version<br/>8321/TCP"]
    end

    Controller -->|health check| HealthEndpoint
    Controller -->|query providers| ProvidersEndpoint
    Controller -->|query version| VersionEndpoint

    Controller -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    Prometheus["Prometheus"] -->|scrapes metrics| KubeRBACProxy

    subgraph ConfigMaps["ConfigMaps"]
        OperatorConfig["llama-stack-operator-config<br/>(feature flags)"]
        TrustedCA["odh-trusted-ca-bundle<br/>(auto-detected)"]
        UserConfig["User ConfigMap<br/>(run.yaml)"]
    end

    FeatureFlags -->|reads| OperatorConfig
    Controller -->|auto-detects| TrustedCA
    Controller -->|mounts| UserConfig

    RhodsOperator["rhods-operator"] -->|deploys via kustomize| Operator

