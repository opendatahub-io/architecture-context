/*
 * MLflow C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/mlflow.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates experiments, tracks runs, registers models, manages prompts, invokes AI Gateway"
        platformAdmin = person "Platform Admin" "Configures MLflow namespaces, manages artifact storage, deploys MLflow instances"

        mlflow = softwareSystem "MLflow" "Open-source ML lifecycle platform with Kubernetes-native workspace isolation, RBAC, and federated UI" {
            trackingServer = container "MLflow Tracking Server" "Core experiment tracking, run management, metric logging, artifact serving" "Python (Flask + FastAPI), Gunicorn"
            modelRegistry = container "Model Registry" "Model versioning, aliases, tags, and lifecycle management" "Python Service"
            aiGateway = container "AI Gateway" "Proxies requests to LLM providers with endpoint routing" "FastAPI Router"
            otelIngestion = container "OTEL Ingestion" "OpenTelemetry Protocol REST API for ingesting spans/traces" "FastAPI Router"
            k8sWorkspaceProvider = container "K8s Workspace Provider" "Maps Kubernetes namespaces to MLflow workspaces" "Python Plugin"
            k8sAuthPlugin = container "K8s Auth Plugin" "Enforces Kubernetes RBAC via SubjectAccessReview" "Python Plugin"
            mlflowConfigCache = container "MLflowConfig Cache" "Watches and caches MLflowConfig CRD for per-namespace artifact storage" "Python Component"
            reactUI = container "React UI" "Web dashboard for experiment tracking, model registry, traces, prompt management" "TypeScript/React"
            federatedModule = container "Federated UI Module" "Exports components for embedding in OpenShift AI dashboard" "Webpack Module Federation"
            graphqlAPI = container "GraphQL API" "GraphQL endpoint for experiment/run/model queries" "Python (Graphene)"
            prometheusExporter = container "Prometheus Exporter" "Exports Prometheus metrics" "prometheus-flask-exporter"
        }

        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication reverse proxy, validates Bearer tokens, forwards user identity headers" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Namespace management, RBAC enforcement, Secret access, CRD management" "Platform"
        postgresql = softwareSystem "PostgreSQL" "Relational database for tracking store, model registry, gateway configuration" "Backend"
        s3Storage = softwareSystem "S3-Compatible Storage" "Object storage for ML artifacts (experiments, models)" "External"
        llmProviders = softwareSystem "LLM Providers" "OpenAI, Anthropic, Gemini, Mistral - AI inference providers" "External"
        odhDashboard = softwareSystem "OpenShift AI Dashboard" "Web dashboard for RHOAI, embeds MLflow UI via Module Federation" "Internal RHOAI"
        mlWorkloads = softwareSystem "ML Workloads" "Python SDK clients sending traces and metrics" "Internal"

        /* Relationships */
        dataScientist -> kubeRBACProxy "Creates experiments, logs runs, registers models" "HTTPS/8443"
        kubeRBACProxy -> mlflow "Forwards authenticated requests" "HTTP/5000 (x-remote-user headers)"

        k8sAuthPlugin -> k8sAPI "SubjectAccessReview / SelfSubjectAccessReview" "HTTPS/443"
        k8sWorkspaceProvider -> k8sAPI "Lists/watches namespaces" "HTTPS/443"
        mlflowConfigCache -> k8sAPI "Watches MLflowConfig CRDs, reads Secrets" "HTTPS/443"

        trackingServer -> postgresql "Stores experiments, runs, metrics, model metadata" "TCP/5432 TLS"
        trackingServer -> s3Storage "Uploads/downloads artifacts" "HTTPS/443"
        aiGateway -> llmProviders "Proxies LLM inference requests" "HTTPS/443"

        odhDashboard -> mlflow "Embeds experiment/prompt UI via Module Federation" "HTTPS/443"
        mlWorkloads -> mlflow "Sends OTLP traces" "HTTP/5000"

        platformAdmin -> k8sAPI "Configures namespaces, MLflowConfig CRDs, secrets"
    }

    views {
        systemContext mlflow "SystemContext" {
            include *
            autoLayout
        }

        container mlflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Backend" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
