    %% Internal relationships
    Controller -->|"watches"| ISVC
    Controller -->|"syncs state via REST"| Proxy
    CSI -->|"resolves model-registry:// URIs"| Proxy
    CSI -.->|"registered via"| CSC

    %% Database connections
    Proxy -->|"CRUD metadata"| MySQL
    Catalog -->|"catalog metadata + pglock"| PostgreSQL

    %% External connections
    Catalog -->|"sync models"| HuggingFace

    %% ODH integrations
    KServe -->|"creates"| ISVC
    Istio -->|"mTLS sidecar"| Proxy
    Istio -->|"mTLS sidecar"| Catalog
    Dashboard -->|"REST API consumer"| Proxy
    UI -->|"REST API"| Proxy

    %% Async job
    AsyncJob -->|"uploads models"| Proxy

