// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/kuberay.md

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Ray clusters, jobs, and services on OpenShift"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, Ray jobs, and Ray services on Kubernetes/OpenShift" {
            rcController = container "RayCluster Controller" "Creates/manages head pods, worker pods, services, ingress, autoscaler RBAC" "Go Reconciler"
            rjController = container "RayJob Controller" "Manages RayJob lifecycle, creates submitter Jobs, manages associated RayClusters" "Go Reconciler"
            rsController = container "RayService Controller" "Manages RayService lifecycle with rolling updates and serve endpoint management" "Go Reconciler"
            authController = container "Authentication Controller" "Creates HTTPRoute CRs, ReferenceGrants, kube-rbac-proxy ConfigMaps per RayCluster" "Go Reconciler"
            npController = container "NetworkPolicy Controller" "Creates head and worker NetworkPolicies when secure-trusted-network annotation is present" "Go Reconciler"
            mtlsController = container "RayCluster mTLS Controller" "Manages cert-manager Issuers and Certificates for intra-cluster mTLS" "Go Reconciler"
            mutatingWebhook = container "Mutating Webhook" "Enforces enableIngress=false, sets secure-trusted-network=true on all RayClusters" "Go Admission Webhook" "9443/TCP HTTPS"
            validatingWebhook = container "Validating Webhook" "Validates RayCluster name format and spec constraints" "Go Admission Webhook" "9443/TCP HTTPS"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys kuberay-operator via kustomize openshift overlay" "Internal RHOAI"
        dataScienceGateway = softwareSystem "data-science-gateway" "OpenShift Gateway API gateway in openshift-ingress namespace" "Internal RHOAI"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication proxy sidecar injected into Ray head pods" "Internal RHOAI"
        certManager = softwareSystem "cert-manager" "Certificate management for mTLS between Ray head and worker nodes" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for CRD management, pod/service CRUD, RBAC operations" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection from operator and Ray clusters" "External"
        volcanoScheduler = softwareSystem "Volcano Scheduler" "Optional gang scheduling for Ray pods via PodGroup CRDs" "External"
        yunikornScheduler = softwareSystem "Yunikorn Scheduler" "Optional batch scheduling via label-based integration" "External"

        // User interactions
        user -> kuberay "Creates RayCluster, RayJob, RayService CRs via kubectl/API"
        user -> dataScienceGateway "Accesses Ray Dashboard via /ray/{ns}/{cluster}" "HTTPS/443"

        // Internal RHOAI dependencies
        rhodsOperator -> kuberay "Deploys via kustomize overlays"
        kuberay -> dataScienceGateway "HTTPRoutes reference for external ingress" "Gateway API"
        kuberay -> kubeRBACProxy "Injects as sidecar for RBAC-based auth" "8443/TCP HTTPS"

        // External dependencies
        kuberay -> k8sAPI "CRD management, pod/service CRUD, RBAC" "HTTPS/443"
        kuberay -> certManager "Creates Issuer + Certificate CRDs for mTLS" "CRD API"
        kuberay -> volcanoScheduler "Gang scheduling integration" "PodGroup CRD"
        kuberay -> yunikornScheduler "Batch scheduling via labels" "Labels/Annotations"
        prometheus -> kuberay "Scrapes operator and cluster metrics" "HTTP/8080"
        k8sAPI -> kuberay "Sends admission webhook requests" "HTTPS/9443"

        // Gateway flow
        dataScienceGateway -> kubeRBACProxy "Forwards dashboard requests" "HTTPS/8443"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
