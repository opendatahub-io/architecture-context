// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Ray clusters, jobs, and services for distributed computing"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and services on Kubernetes/OpenShift with RHOAI auth and mTLS extensions" {
            rcController = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker pods, services, manages autoscaling" "Go Controller"
            rjController = container "RayJob Controller" "Reconciles RayJob CRs: creates RayCluster and batch Jobs for job submission" "Go Controller"
            rsController = container "RayService Controller" "Reconciles RayService CRs: manages Ray Serve applications with blue-green upgrades" "Go Controller"
            authController = container "Authentication Controller" "Creates HTTPRoutes, injects kube-rbac-proxy sidecars, manages ServiceAccounts and ReferenceGrants" "Go Controller (RHOAI)"
            mtlsController = container "mTLS Controller" "Manages cert-manager Issuers and Certificates for intra-cluster mTLS" "Go Controller (RHOAI)"
            npController = container "NetworkPolicy Controller" "Creates per-cluster NetworkPolicies for head and worker pods" "Go Controller (RHOAI)"
            webhook = container "Admission Webhook" "Mutating and validating webhooks for RayCluster CRs" "Go Webhook Server"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Container orchestration control plane" "External"
        gatewayAPI = softwareSystem "Gateway API / data-science-gateway" "Platform gateway for external ingress to Ray dashboards" "Internal RHOAI"
        certManager = softwareSystem "cert-manager" "X.509 certificate lifecycle management" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for distributed workloads" "External"
        redis = softwareSystem "Redis" "External storage for GCS fault tolerance" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys and configures KubeRay operator" "Internal RHOAI"

        // User interactions
        user -> kuberay "Creates RayCluster, RayJob, RayService CRs via kubectl/dashboard"
        user -> gatewayAPI "Accesses Ray Dashboard via HTTPS/443"

        // KubeRay dependencies
        kuberay -> k8sAPI "Watches CRDs, manages pods/services/secrets" "HTTPS/443 TLS 1.2+"
        kuberay -> certManager "Creates Issuer and Certificate CRs for mTLS" "CRD"
        kuberay -> gatewayAPI "Creates HTTPRoute and ReferenceGrant CRs" "CRD"
        kuberay -> volcano "Gang scheduling for Ray pods" "HTTPS/443"
        kuberay -> redis "GCS fault tolerance storage" "TCP/6379"
        prometheus -> kuberay "Scrapes operator and Ray cluster metrics" "HTTP/8080"
        rhoaiOperator -> kuberay "Deploys via kustomize manifests"

        // Internal container relationships
        rcController -> k8sAPI "Creates pods, services, configmaps" "HTTPS/443"
        rjController -> rcController "Creates RayCluster for job" "Internal"
        rsController -> rcController "Manages RayCluster for serving" "Internal"
        authController -> gatewayAPI "Creates HTTPRoute CRs" "CRD"
        mtlsController -> certManager "Creates Issuer/Certificate CRs" "CRD"
    }

    views {
        systemContext kuberay "SystemContext" "KubeRay Operator in the RHOAI ecosystem" {
            include *
            autoLayout
        }

        container kuberay "Containers" "Internal structure of KubeRay Operator" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
