%% TrustyAI Explainability - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client / Dashboard"]
    end

    subgraph Ingress["INGRESS (Operator-Managed)"]
        RBACProxy["kube-rbac-proxy<br/>Deployed by TrustyAI Operator<br/>RBAC-based access control"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Namespace-scoped)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            TrustyAI["TrustyAI Service<br/>trustyai-service (ClusterIP)<br/>8080/TCP (HTTP) | 4443/TCP (HTTPS)<br/>TLS cert: /etc/tls/internal/"]
        end

        subgraph NS_Serving["Namespace: {serving-namespace}"]
            ModelMesh["ModelMesh Serving<br/>Payload Processor"]
            KServeLogger["KServe InferenceLogger<br/>Knative CloudEvents"]
            KServeModel["KServe Model Server<br/>gRPC v2"]
        end

        subgraph NS_Monitoring["Namespace: {monitoring-namespace}"]
            Prometheus["Prometheus Server"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        MinIO["MinIO/S3 Storage<br/>9000/TCP (MinIO) | 443/TCP (S3)<br/>AccessKey/SecretKey Auth"]
        Database["MariaDB/MySQL<br/>3306/TCP<br/>username/password Auth"]
    end

    %% Inbound flows
    Client -->|"HTTPS/443<br/>TLS (operator-managed)<br/>kube-rbac-proxy auth"| RBACProxy
    RBACProxy -->|"HTTP/8080 or HTTPS/4443<br/>plaintext or TLS<br/>Delegated auth"| TrustyAI

    ModelMesh -->|"HTTP/8080<br/>POST /consumer/kserve/v2<br/>plaintext, No auth"| TrustyAI
    KServeLogger -->|"HTTP/8080<br/>CloudEvents<br/>plaintext, No auth"| TrustyAI
    Prometheus -->|"HTTP/8080<br/>GET /q/metrics<br/>plaintext, No auth"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"gRPC/varies<br/>KServe v2 protocol<br/>plaintext, No auth"| KServeModel
    TrustyAI -->|"HTTP or HTTPS<br/>9000 or 443/TCP<br/>AccessKey/SecretKey"| MinIO
    TrustyAI -->|"MySQL/3306<br/>MySQL protocol<br/>plaintext, user/pass"| Database

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef serving fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RBACProxy ingress
    class TrustyAI internal
    class ModelMesh,KServeLogger,KServeModel serving
    class Prometheus monitoring
    class MinIO,Database externalservice
