/*
 * RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/RHOAI-Build-Config.md
 */

workspace {
    model {
        developer = person "Developer" "Pushes source changes to trigger builds"
        clusterAdmin = person "Cluster Admin" "Installs and manages RHOAI on OpenShift"

        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration for Red Hat OpenShift AI operator bundle, FBC catalog fragment, and 107 image references" {
            bundle = container "Operator Bundle" "OLM bundle with CSV, 27 CRDs, RBAC, and 92 RELATED_IMAGE refs" "Dockerfile (FROM scratch)"
            catalog = container "FBC Fragment" "File-Based Catalog for OLM with per-OCP-version Dockerfiles (v4.19, v4.20, v4.21)" "opm"
            tektonPipelines = container "Tekton PipelineRuns" "Konflux CI/CD pipelines for hermetic bundle and multi-arch FBC builds" "Tekton"
            buildConfig = container "Build Configuration" "Image registry mappings, OCP version matrix, build args" "YAML"
            integrationTests = container "Integration Tests" "Enterprise Contract verification and test scenarios" "Tekton Tasks"
            releaseArtifacts = container "Release Artifacts" "Stage (RC2, RC4) and production release metadata" "YAML"
        }

        konflux = softwareSystem "Konflux/AppStudio" "CI/CD build system for hermetic container builds" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Supply chain verification via cosign" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager for operator installation" "External"
        github = softwareSystem "GitHub" "Source code repositories for RHOAI components" "External"
        quay = softwareSystem "Quay.io Registry" "Container image registry (quay.io/rhoai/*)" "External"
        registryRedhat = softwareSystem "Red Hat Registry" "registry.redhat.io - base images and dependencies" "External"
        brewRegistry = softwareSystem "Brew Registry" "brew.registry.redhat.io - FBC base images" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target deployment platform (v4.19, v4.20, v4.21)" "External"
        pnc = softwareSystem "PNC (Project Newcastle)" "Java artifact builds for TrustyAI" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection from openshift-monitoring" "External"

        # Relationships - Developer
        developer -> rhoaiBuildConfig "Pushes source changes" "git/HTTPS"
        developer -> github "Commits code" "HTTPS/443"

        # Relationships - Build System
        rhoaiBuildConfig -> konflux "Triggers hermetic builds" "HTTPS/443"
        rhoaiBuildConfig -> github "Clones source repositories" "HTTPS/443"
        rhoaiBuildConfig -> quay "Pushes bundle and FBC images" "HTTPS/443"
        rhoaiBuildConfig -> brewRegistry "Pulls FBC base images" "HTTPS/443"
        rhoaiBuildConfig -> registryRedhat "References 15 additional images" "HTTPS/443"
        rhoaiBuildConfig -> enterpriseContract "Verifies supply chain" "In-cluster"
        rhoaiBuildConfig -> pnc "Builds TrustyAI Java artifacts" "HTTPS/443"

        # Relationships - Installation
        clusterAdmin -> olm "Creates Subscription"
        olm -> quay "Pulls FBC fragment and bundle images" "HTTPS/443"
        olm -> ocp "Deploys rhods-operator" "K8s API"
        ocp -> quay "Pulls 92 RELATED_IMAGE containers" "HTTPS/443"
        ocp -> registryRedhat "Pulls 15 additional images" "HTTPS/443"
        prometheus -> rhoaiBuildConfig "Scrapes /metrics" "HTTPS/8443"

        # Internal relationships
        tektonPipelines -> bundle "Builds" "Hermetic"
        tektonPipelines -> catalog "Builds" "Multi-arch"
        integrationTests -> enterpriseContract "Runs verification" "Tekton Task"
        bundle -> catalog "Nudges rebuild" "catalog-patch"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #85bbf0
                color #000000
            }
        }
    }
}
