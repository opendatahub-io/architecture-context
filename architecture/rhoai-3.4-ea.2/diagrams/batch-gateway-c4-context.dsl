/*
 * C4 Context Diagram - batch-gateway
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/batch-gateway.md
 */

workspace {
    model {
        user = person "API Client" "Submits batch inference jobs and manages files via OpenAI-compatible API"

        batchGateway = softwareSystem "Batch Gateway" "OpenAI-compatible Batch API gateway for asynchronous LLM inference request processing" {
            apiServer = container "API Server" "OpenAI-compatible REST API for file upload/download and batch job CRUD operations" "Go HTTP Service, port 8000/TCP"
            processor = container "Batch Processor" "Polls priority queue for batch jobs, dispatches inference requests to downstream gateways, writes results" "Go Worker Service, port 9090/TCP"
            redisClient = container "Redis Client" "Pluggable backend for metadata storage, priority queue, event channels" "go-redis/v9"
            s3Client = container "S3 Client" "S3-compatible storage for batch input/output JSONL files" "AWS SDK v2"
            workerPool = container "Worker Pool" "Manages fixed pool of worker goroutines for concurrent job processing" "Go goroutines"
        }

        redis = softwareSystem "Redis" "Metadata storage, priority queue, event channels, temporary status" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Batch input/output JSONL file storage (AWS S3, MinIO)" "External"
        inferenceGateway = softwareSystem "Inference Gateway (llm-d / GAIE)" "Downstream inference request processing, OpenAI-compatible API" "Internal ODH"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning for API server" "External"
        gatewayAPI = softwareSystem "Kubernetes Gateway API" "Platform-level routing of batch API paths (planned)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection" "External"

        /* External relationships */
        user -> batchGateway "Submits batch jobs, uploads files" "HTTP/HTTPS 8000/TCP, X-MaaS-User header"
        batchGateway -> redis "Stores metadata, queues jobs, publishes events" "Redis protocol/6379"
        batchGateway -> s3Storage "Uploads/downloads JSONL files" "HTTPS/443"
        batchGateway -> inferenceGateway "Dispatches individual inference requests" "HTTP/HTTPS, Bearer Token"
        certManager -> batchGateway "Provisions TLS certificates" "Kubernetes Secrets"
        gatewayAPI -> batchGateway "Routes external traffic to batch API" "HTTPRoute (planned)"
        prometheus -> batchGateway "Scrapes metrics" "HTTP /metrics"

        /* Internal container relationships */
        apiServer -> redisClient "Store/retrieve batch and file metadata"
        apiServer -> s3Client "Upload/download JSONL files"
        processor -> redisClient "Poll queue, update status, receive events"
        processor -> s3Client "Read input files, write output files"
        processor -> workerPool "Manage concurrent job execution"
        workerPool -> inferenceGateway "Send inference requests" "HTTP/HTTPS"
        redisClient -> redis "Connect" "Redis protocol/6379, optional TLS"
        s3Client -> s3Storage "Connect" "HTTPS/443, AWS IAM"
    }

    views {
        systemContext batchGateway "SystemContext" {
            include *
            autoLayout
        }

        container batchGateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
