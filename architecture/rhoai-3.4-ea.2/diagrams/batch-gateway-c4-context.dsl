/*
 * Batch Gateway - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/batch-gateway.md
 */

workspace {
    model {
        client = person "API Client" "Submits batch inference requests via OpenAI-compatible API"

        batchGateway = softwareSystem "Batch Gateway" "OpenAI-compatible Batch API gateway for bulk LLM inference requests" {
            apiServer = container "API Server" "Exposes /v1/files and /v1/batches REST endpoints for batch job and file management" "Go HTTP Service" "Port 8000/TCP"
            batchProcessor = container "Batch Processor" "Polls priority queue, dequeues batch jobs, dispatches inference requests via worker pool" "Go Worker Service" "Port 9090/TCP (metrics)"
            workerPool = container "Worker Pool" "Manages concurrent goroutines for parallel job processing" "Go Goroutine Pool"
            inferenceClient = container "Inference HTTP Client" "Sends inference requests to downstream gateway with retry, TLS, mTLS" "Go HTTP Client"
            redisLayer = container "Redis Database Layer" "Metadata storage, priority queue, event channels, status tracking" "Go Client Library"
            s3Store = container "S3 File Store" "Stores and retrieves batch input/output JSONL files" "Go Client Library"
            fsStore = container "Filesystem File Store" "Alternative local filesystem storage for batch files" "Go Client Library"
            metrics = container "Prometheus Metrics" "HTTP request metrics and job processing metrics" "Go Library"
        }

        redis = softwareSystem "Redis" "Metadata storage, priority queue, event channels, status tracking" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Batch input/output JSONL file storage (AWS S3, MinIO)" "External"
        inferenceGateway = softwareSystem "Inference Gateway (llm-d/GAIE)" "Downstream LLM inference endpoint" "Internal ODH"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        # External relationships
        client -> batchGateway "Submits batch jobs, uploads files" "HTTP/HTTPS 8000/TCP"
        batchGateway -> redis "Stores metadata, queues jobs, publishes events" "Redis 6379/TCP, TLS optional"
        batchGateway -> s3Storage "Stores/retrieves batch JSONL files" "HTTPS 443/TCP"
        batchGateway -> inferenceGateway "Forwards individual inference requests" "HTTP/HTTPS, TLS/mTLS"
        certManager -> batchGateway "Provisions TLS certificates" "Kubernetes CR"
        prometheus -> batchGateway "Scrapes metrics" "HTTP/HTTPS 8000/TCP, 9090/TCP"

        # Internal container relationships
        client -> apiServer "POST /v1/files, /v1/batches" "HTTP/HTTPS 8000/TCP"
        apiServer -> redisLayer "Store batch metadata, enqueue jobs"
        apiServer -> s3Store "Upload/download JSONL files"
        apiServer -> fsStore "Upload/download JSONL files (local)"
        batchProcessor -> redisLayer "Poll queue, update status"
        batchProcessor -> workerPool "Dispatch jobs to workers"
        workerPool -> inferenceClient "Send inference requests"
        workerPool -> s3Store "Read input JSONL"
        inferenceClient -> inferenceGateway "POST inference request" "HTTP/HTTPS, TLS/mTLS"
        apiServer -> metrics "Record HTTP metrics"
        batchProcessor -> metrics "Record job processing metrics"
    }

    views {
        systemContext batchGateway "SystemContext" {
            include *
            autoLayout
        }

        container batchGateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
