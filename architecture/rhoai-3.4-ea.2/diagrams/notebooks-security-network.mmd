    subgraph WorkbenchPod["WORKBENCH POD"]
        direction TB

        RBAC["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        JupyterLab["JupyterLab<br/>8888/TCP HTTP"]
        CodeServerNGINX["code-server NGINX<br/>8888/TCP HTTP"]
        CodeServerBackend["code-server<br/>8787/TCP HTTP"]
        RStudioNGINX["RStudio NGINX<br/>8888/TCP HTTP"]
        RStudioBackend["RStudio Server<br/>8787/TCP HTTP"]

        RBAC -->|HTTP/8888<br/>plaintext<br/>pre-authenticated| JupyterLab
        RBAC -->|HTTP/8888<br/>plaintext<br/>pre-authenticated| CodeServerNGINX
        RBAC -->|HTTP/8888<br/>plaintext<br/>pre-authenticated| RStudioNGINX
        CodeServerNGINX --> CodeServerBackend
        RStudioNGINX --> RStudioBackend
    end

    subgraph RuntimePod["PIPELINE RUNTIME POD"]
        Runtime["Runtime Container<br/>(Elyra bootstrapper)<br/>User: 1001 non-root"]
    end

    subgraph EgressServices["EGRESS (External Services)"]
        PyPI["PyPI / Package Registries<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token/SSH"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
    end

    subgraph ImageReg["IMAGE REGISTRATION"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secret"]
        ImageStream["OpenShift ImageStream API"]
        Operator["RHOAI Operator"]
    end

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SubjectAccessReview"| RBAC

    %% Egress flows from workbench
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>Token/SSH"| Git
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3
    JupyterLab -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Pipeline runtime flows
    DSP["Data Science Pipelines<br/>Controller"] -->|"Pod creation<br/>ServiceAccount"| Runtime
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3

    %% Image registration flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    ImageStream -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| Registry

