// TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Configures fairness metrics, drift detection, and requests model explanations"
        mlEngineer = person "ML Engineer" "Deploys models and monitors fairness/drift metrics"

        trustyai = softwareSystem "TrustyAI Explainability" "AI fairness metrics, model explainability, and data drift detection service for ML models" {
            service = container "explainability-service" "Quarkus REST service exposing fairness, drift, and explainability endpoints" "Java 17 / Quarkus 3.8.5"
            core = container "explainability-core" "Core XAI library: SPD, DIR, KS-Test, FourierMMD, LIME, SHAP, Counterfactuals" "Java Library"
            connectors = container "explainability-connectors" "gRPC client for KServe Prediction Protocol v2" "Java Library"
            arrow = container "explainability-arrow" "Apache Arrow integration for Java-Python data exchange" "Java Library"

            service -> core "Uses for metric calculation and explanations"
            service -> connectors "Uses for gRPC inference requests"
            service -> arrow "Uses for Arrow-based data exchange"
        }

        // Internal ODH/RHOAI Systems
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages TrustyAI service instances" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Model serving platform with payload forwarding" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference with InferenceLogger" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal OpenShift"

        // External Systems
        mariadb = softwareSystem "MariaDB/MySQL" "Relational database for persistent inference data storage" "External Storage"
        minio = softwareSystem "MinIO" "S3-compatible object storage for inference data" "External Storage"
        pvc = softwareSystem "PVC Storage" "Kubernetes Persistent Volume for flat file storage" "Kubernetes"

        // Relationships
        dataScientist -> trustyai "Configures metrics, requests explanations via REST API" "HTTPS/443"
        mlEngineer -> prometheus "Monitors fairness and drift metrics" "HTTPS"

        trustyaiOperator -> trustyai "Deploys, configures, manages lifecycle" "Kubernetes API"

        modelMesh -> trustyai "Sends inference payloads" "HTTP/8080 POST /consumer/kserve/v2"
        kserve -> trustyai "Sends inference CloudEvents" "HTTP/8080 CloudEvent"

        trustyai -> modelMesh "Sends gRPC inference requests for explanations" "gRPC/8081 KServe v2"
        trustyai -> kserve "Sends gRPC inference requests for explanations" "gRPC/8081 KServe v2"

        prometheus -> trustyai "Scrapes fairness/drift metrics" "HTTP/8080 GET /q/metrics (4s interval)"

        trustyai -> pvc "Reads/writes inference data" "Filesystem /inputs"
        trustyai -> mariadb "Reads/writes inference data" "JDBC/3306"
        trustyai -> minio "Reads/writes inference data" "HTTP(S)/9000"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
            description "TrustyAI Explainability system context showing integrations with model serving, monitoring, and storage"
        }

        container trustyai "Containers" {
            include *
            autoLayout
            description "TrustyAI internal container structure: service, core library, connectors, and arrow modules"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal OpenShift" {
                background #7ed321
                color #ffffff
            }
            element "External Storage" {
                background #999999
                color #ffffff
            }
            element "Kubernetes" {
                background #326ce5
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
