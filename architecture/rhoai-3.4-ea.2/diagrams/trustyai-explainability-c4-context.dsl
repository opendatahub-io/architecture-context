/* TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        datascientist = person "Data Scientist" "Monitors ML model fairness, drift, and requests explainability results"
        sre = person "SRE / Platform Admin" "Monitors metrics and service health via Prometheus/Grafana"

        trustyai = softwareSystem "TrustyAI Explainability" "Quarkus REST service providing fairness metrics, bias tracking, data drift detection, and explainable AI for ML model inference monitoring" {
            service = container "explainability-service" "Main REST API service providing fairness metrics, drift detection, and inference payload consumption" "Quarkus 3.8.5, Java 17"
            core = container "explainability-core" "Core algorithms: fairness (SPD, DIR), drift (KS Test, Meanshift, FourierMMD), explainers (LIME, SHAP, Counterfactual)" "Java Library"
            connectors = container "explainability-connectors" "KServe v1/v2 HTTP and gRPC prediction provider connectors" "Java Library, gRPC"
            prometheusScheduler = container "PrometheusScheduler" "Schedules periodic metric recalculation and publishes to Prometheus" "Quarkus Scheduler"

            service -> core "Uses algorithms" "Java method calls"
            service -> connectors "Queries model servers" "Java method calls"
            prometheusScheduler -> core "Computes metrics" "Java method calls"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages TrustyAI service instances, manages TrustyAIService CRD, RBAC, ingress" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Model serving platform that sends inference payloads to TrustyAI" "Internal RHOAI"
        kserve = softwareSystem "KServe" "ML model serving with InferenceLogger for CloudEvents and gRPC model access" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring platform" "External"
        minio = softwareSystem "MinIO/S3 Storage" "Object storage for inference data persistence" "External"
        database = softwareSystem "MariaDB/MySQL" "Relational database for inference data storage (Hibernate ORM)" "External"
        knativeEventing = softwareSystem "Knative Eventing" "Event mesh for CloudEvent delivery from KServe InferenceLogger" "External"

        datascientist -> trustyai "Requests fairness/drift metrics and explainability" "REST/HTTP 8080"
        sre -> prometheus "Monitors TrustyAI metrics" "Prometheus UI/Grafana"

        trustyaiOperator -> trustyai "Deploys and configures" "Kubernetes API"
        modelMesh -> trustyai "Sends inference payloads" "HTTP/8080 POST /consumer/kserve/v2"
        knativeEventing -> trustyai "Delivers inference CloudEvents" "HTTP/8080 CloudEvents"
        kserve -> trustyai "Sends inference events via InferenceLogger" "CloudEvents HTTP/8080"
        trustyai -> kserve "Queries model servers for explainability" "gRPC KServe v2"
        prometheus -> trustyai "Scrapes computed metrics" "HTTP/8080 GET /q/metrics"
        trustyai -> minio "Stores/retrieves inference data" "HTTP/HTTPS 9000 or 443"
        trustyai -> database "Stores/retrieves inference data" "MySQL/3306"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
