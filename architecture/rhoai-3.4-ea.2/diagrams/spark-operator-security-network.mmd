graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        Browser["User Browser"]
        ClientApp["Client Application"]
    end

    subgraph Ingress["INGRESS"]
        SparkIngress["{app}-ui-ingress<br/>80/443 → 4040/TCP<br/>HTTP/HTTPS<br/>TLS Configurable"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (redhat-ods-applications)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        subgraph OperatorNS["Operator Namespace"]
            Controller["Controller Deployment<br/>SA: controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Security: nonRoot, readOnly, drop ALL"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS (self-signed)<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Security: nonRoot, readOnly, drop ALL"]
        end
    end

    subgraph AppNS["APPLICATION NAMESPACE (NetworkPolicy Protected)"]
        direction TB
        Driver["Spark Driver Pod<br/>SA: spark<br/>7078/TCP driver-rpc<br/>7079/TCP blockmanager<br/>4040/TCP Spark UI"]
        Executors["Spark Executor Pods"]
        ConnectServer["Spark Connect Server<br/>15002/TCP gRPC<br/>7078, 7079, 4040/TCP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Prometheus["Prometheus<br/>Scrape 8080/TCP HTTP"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS TLS 1.2+<br/>(Optional)"]
        CertMgr["cert-manager<br/>(Optional)"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Browser -->|"HTTP(S)/80,443<br/>Optional TLS<br/>No Auth"| SparkIngress
    ClientApp -->|"gRPC/15002<br/>plaintext<br/>No Auth"| ConnectServer

    %% Ingress to internal
    SparkIngress -->|"HTTP/4040<br/>plaintext<br/>No Auth"| Driver

    %% API Server to Webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (self-signed)<br/>API server cert"| Webhook

    %% Controller to API Server
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Webhook to API Server
    Webhook -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Controller manages resources
    Controller -->|"Creates/Manages<br/>via API Server"| Driver
    Controller -->|"Creates/Manages"| ConnectServer

    %% Spark internal communication
    Executors -->|"TCP/7078<br/>plaintext<br/>driver-rpc"| Driver
    Executors -->|"TCP/7079<br/>plaintext<br/>blockmanager"| Driver

    %% Driver creates executors
    Driver -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (spark)"| K8sAPI

    %% External services
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>Scrape"| Controller
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>Scrape"| Webhook
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>(Optional)"| Volcano
    CertMgr -.->|"Cert provisioning<br/>(Optional)"| Webhook

