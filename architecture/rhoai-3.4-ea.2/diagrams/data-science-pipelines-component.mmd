graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["ml-pipeline<br/>(API Server)<br/>REST 8888/TCP<br/>gRPC 8887/TCP<br/>Webhook 8443/TCP"]
            UI["ml-pipeline-ui<br/>(React Frontend)<br/>3000/TCP"]
            VizServer["ml-pipeline-visualizationserver<br/>8888/TCP"]
        end

        subgraph Controllers["Controllers & Agents"]
            PersistenceAgent["ml-pipeline-persistenceagent<br/>(State Sync Agent)"]
