            ProfileCtrl["pipelines-profile-controller<br/>(Multi-user RBAC)"]
        end

        subgraph Webhooks["Admission Webhooks"]
            CacheServer["cache-server<br/>(Mutating Webhook)<br/>8443/TCP"]
            CacheDeployer["cache-deployer<br/>(Setup Job)"]
        end

        subgraph StepBinaries["Pipeline Step Binaries"]
            Driver["ml-pipeline-driver<br/>(Input Resolution)"]
            Launcher["ml-pipeline-launcher<br/>(Execution & Upload)"]
        end
    end

    subgraph Metadata["Metadata Services"]
        MLMD["metadata-grpc-server<br/>(MLMD)<br/>8080/TCP"]
        Envoy["metadata-envoy<br/>(gRPC-Web Proxy)<br/>9090/TCP"]
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWFCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    WorkflowCR["Workflow CR<br/>argoproj.io"]

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>Controller"]
    MySQL["MySQL/PostgreSQL<br/>3306/5432"]
    MinIO["MinIO/S3<br/>9000/443"]
    K8sAPI["Kubernetes API<br/>443/TCP"]
    Istio["Istio Service Mesh"]

    %% Internal Integrations
    DSPO["data-science-pipelines-operator<br/>(DSPO)"]
    Dashboard["OpenShift AI Dashboard"]

    %% Relationships
    User["User / Data Scientist"] -->|"submits pipelines"| UI
    UI -->|"REST calls"| APIServer
    Dashboard -->|"REST API"| APIServer

    APIServer -->|"stores artifacts"| MinIO
    APIServer -->|"stores metadata"| MySQL
    APIServer -->|"creates"| WorkflowCR
    APIServer -->|"validates/mutates"| PipelineVersionCR

    PipelineVersionCR -->|"watched by"| APIServer
    PipelineCR -->|"watched by"| APIServer
    ScheduledWFCR -->|"reconciled by"| ScheduledWF
    ViewerCR -->|"reconciled by"| ViewerCRD
    WorkflowCR -->|"executed by"| ArgoWF
    WorkflowCR -->|"watched by"| PersistenceAgent

    ScheduledWF -->|"creates"| WorkflowCR
    PersistenceAgent -->|"syncs state to"| APIServer

    ArgoWF -->|"runs"| Driver
    Driver -->|"launches"| Launcher
    Launcher -->|"uploads artifacts"| MinIO
    Launcher -->|"records metadata"| MLMD
    Envoy -->|"proxies to"| MLMD

    CacheDeployer -->|"configures"| CacheServer
    K8sAPI -->|"admission webhook"| CacheServer
    CacheServer -->|"checks cache"| MySQL

    DSPO -->|"deploys/manages"| DSP

    APIServer -->|"auth checks"| K8sAPI
    Istio -.->|"mTLS, AuthZ"| DSP

