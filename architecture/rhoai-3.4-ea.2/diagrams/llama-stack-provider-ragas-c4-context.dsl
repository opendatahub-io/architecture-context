// C4 Context Diagram: llama-stack-provider-ragas
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Evaluates RAG system quality using Ragas metrics"

        llamaStackProviderRagas = softwareSystem "llama-stack-provider-ragas" "Ragas evaluation provider plugin for Llama Stack, enabling RAG assessment via inline or remote (KFP) execution" {
            inlineProvider = container "RagasEvaluatorInline" "Runs Ragas evaluation in-process with Llama Stack server" "Python Plugin"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluation jobs to Kubeflow Pipelines" "Python Plugin"
            inlineWrappers = container "Inline LLM/Embedding Wrappers" "Adapts Llama Stack inference API to Ragas interfaces (in-process)" "Python"
            remoteWrappers = container "Remote LLM/Embedding Wrappers" "Adapts Llama Stack client SDK to Ragas interfaces (HTTP)" "Python"
            kfpPipeline = container "ragas_evaluation_pipeline" "Two-step KFP pipeline: retrieve data, run Ragas evaluation" "KFP Pipeline"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts provider plugins and serves eval/inference/dataset APIs" "Internal"
        kfp = softwareSystem "Kubeflow Pipelines (Data Science Pipelines)" "Distributed pipeline execution backend" "Internal ODH"
        ollama = softwareSystem "Ollama / vLLM" "LLM and embedding model inference backend" "External"
        s3 = softwareSystem "S3-compatible Storage" "Stores evaluation results from remote pipeline runs" "External"
        trustyaiOp = softwareSystem "trustyai-service-operator" "Provides ConfigMap for base image resolution" "Internal ODH"
        k8sAPI = softwareSystem "Kubernetes API" "ConfigMap reads, kubeconfig loading" "External"

        // User interactions
        user -> llamaStackServer "Submits evaluation jobs via Eval API" "HTTP/8321"
        llamaStackServer -> llamaStackProviderRagas "Dispatches eval requests to provider plugin" "in-process"

        // Internal container relationships
        inlineProvider -> inlineWrappers "Uses for LLM/embedding access"
        remoteProvider -> remoteWrappers "Uses for LLM/embedding access"
        remoteProvider -> kfpPipeline "Defines and submits pipeline"

        // External integrations
        llamaStackProviderRagas -> llamaStackServer "In-process provider plugin" "N/A"
        llamaStackProviderRagas -> kfp "Submits and monitors pipeline runs" "HTTPS/443"
        llamaStackProviderRagas -> ollama "LLM and embedding inference (via Llama Stack)" "HTTP/11434"
        llamaStackProviderRagas -> s3 "Writes/reads evaluation results" "HTTPS/443"
        llamaStackProviderRagas -> trustyaiOp "Reads ConfigMap for base image" "Kubernetes API"
        llamaStackProviderRagas -> k8sAPI "Reads ConfigMap, loads kubeconfig" "HTTPS/443"

        // KFP pipeline callbacks
        kfpPipeline -> llamaStackServer "Retrieves datasets and inference" "HTTP/8321"
        kfpPipeline -> s3 "Writes evaluation results" "HTTPS/443"
    }

    views {
        systemContext llamaStackProviderRagas "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackProviderRagas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
            element "Container" {
                shape RoundedBox
            }
        }
    }
}
