// C4 Context Diagram: odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Platform Admin" "Creates InferenceServices, LLMInferenceServices, and NIM Accounts"

        odmController = softwareSystem "odh-model-controller" "Manages OpenShift-specific integrations and lifecycle resources for KServe InferenceServices, LLMInferenceServices, and NVIDIA NIM accounts" {
            isvcController = container "InferenceService Controller" "Watches InferenceService CRs; creates Routes, metrics resources, RBAC, NetworkPolicies, KEDA resources" "Go Controller"
            llmController = container "LLMInferenceService Controller" "Watches LLMInferenceService CRs; creates AuthPolicies and EnvoyFilters" "Go Controller"
            srController = container "ServingRuntime Controller" "Watches ServingRuntime CRs; manages monitoring RoleBindings and Ray TLS CA" "Go Controller"
            igController = container "InferenceGraph Controller" "Watches InferenceGraph CRs" "Go Controller"
            cmController = container "ConfigMap Controller" "Merges CA bundles into unified ConfigMap" "Go Controller"
            secretController = container "Secret Controller" "Aggregates S3 credentials into storage-config" "Go Controller"
            podController = container "Pod Controller" "Generates per-pod Ray TLS certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Validates NGC keys, fetches catalog, creates NIM resources" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating and validating webhooks for Pods, InferenceServices, InferenceGraphs, NIM Accounts" "Go Service" "9443/TCP HTTPS"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs" "Internal ODH"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Authentication enforcement via AuthPolicy CRs" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and deployment status" "Internal ODH"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for creating InferenceServices and data connections" "Internal ODH"
        dsc = softwareSystem "DataScienceCluster / DSCInit" "Platform initialization and configuration" "Internal ODH"

        gatewayAPI = softwareSystem "Gateway API (Istio/Envoy)" "Ingress gateway and traffic management" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "External route exposure for InferenceServices" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection via ServiceMonitors and PodMonitors" "External"
        certManager = softwareSystem "OpenShift Service CA" "Auto-provisioned webhook TLS certificates" "External"
        keda = softwareSystem "KEDA" "Kubernetes event-driven autoscaling" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for all controller operations" "External"
        ngcAPI = softwareSystem "NVIDIA NGC API" "NIM API key validation and model catalog" "External Service"

        // User interactions
        user -> odmController "Creates InferenceService, LLMInferenceService, NIM Account CRs via kubectl/dashboard"
        dashboard -> odmController "Creates data connection Secrets"

        // Internal ODH dependencies
        odmController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRs" "HTTPS/443"
        odmController -> kuadrant "Creates AuthPolicy CRs for LLMInferenceService authentication" "HTTPS/443"
        odmController -> modelRegistry "Syncs InferenceService deployment status (opt-in)" "HTTPS/variable"
        odmController -> dsc "Reads DataScienceCluster and DSCInitialization for config" "HTTPS/443"

        // External dependencies
        odmController -> gatewayAPI "Watches Gateways, reads HTTPRoutes; creates EnvoyFilters" "HTTPS/443"
        odmController -> openshiftRouter "Creates Route CRs for external InferenceService access" "HTTPS/443"
        odmController -> prometheus "Creates ServiceMonitors, PodMonitors, RoleBindings" "HTTPS/443"
        odmController -> keda "Creates TriggerAuthentication resources" "HTTPS/443"
        odmController -> k8sAPI "Controller-runtime watch, create, update operations" "HTTPS/443"
        odmController -> ngcAPI "Validates NIM API keys, fetches model catalog" "HTTPS/443"
        certManager -> odmController "Provisions webhook TLS certificate via serving-cert annotation"
    }

    views {
        systemContext odmController "SystemContext" {
            include *
            autoLayout
        }

        container odmController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
            }
        }
    }
}
