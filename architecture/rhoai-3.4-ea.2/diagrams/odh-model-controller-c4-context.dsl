// C4 Context Diagram for odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys ML models via InferenceService and LLMInferenceService"
        admin = person "Platform Admin" "Manages NIM accounts and platform configuration"

        odhModelController = softwareSystem "odh-model-controller" "Kubernetes controller automating model serving infrastructure for KServe InferenceServices on OpenShift AI" {
            controllerManager = container "Controller Manager" "Watches InferenceService, ServingRuntime, LLMInferenceService, NIM Account CRs and reconciles ancillary resources" "Go (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates and mutates InferenceService, InferenceGraph, NIM Account, and Pod resources" "Go (9443/TCP HTTPS)"
            gatewayDiscovery = container "Gateway Discovery Server" "REST API for discovering Gateway API Gateways with RBAC-based filtering" "Go (8443/TCP HTTPS)"
        }

        // Internal ODH Components
        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService, ServingRuntime, LLMInferenceService CRDs" "Internal ODH"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Web UI for managing data science projects and model serving" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages RHOAI components via kustomize" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "Internal ODH"

        // External Dependencies
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for all resource CRUD operations" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller for external Route access" "External"
        istio = softwareSystem "Istio" "Service mesh - EnvoyFilter for Authorino TLS bootstrap" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "API gateway auth - AuthPolicy for Gateway API auth enforcement" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API for ingress (Gateway, HTTPRoute)" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling (TriggerAuthentication)" "External"
        certManager = softwareSystem "OpenShift service-ca" "Certificate provisioning for webhook TLS" "External"

        // External Services
        nvidiaAPI = softwareSystem "NVIDIA NIM API" "NGC API for NIM account validation and model catalog" "External Service"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata for InferenceService sync" "Internal ODH"

        // Relationships - User
        user -> odhModelController "Creates InferenceService / LLMInferenceService via kubectl" "HTTPS/443"
        admin -> odhModelController "Creates NIM Account CRs" "HTTPS/443"
        rhoaiDashboard -> gatewayDiscovery "Discovers available Gateways" "HTTPS/8443, Bearer Token"

        // Relationships - Internal
        controllerManager -> k8sAPI "CRUD on Routes, Services, Secrets, ConfigMaps, AuthPolicies, EnvoyFilters" "HTTPS/443, SA Token"
        controllerManager -> nvidiaAPI "Validates NIM API keys, fetches model catalog" "HTTPS/443, NGC API Key"
        controllerManager -> modelRegistry "Syncs InferenceService metadata" "HTTPS, Bearer Token"
        gatewayDiscovery -> k8sAPI "SelfSubjectAccessReview + list Gateways" "HTTPS/443, Bearer Token"
        webhookServer -> k8sAPI "Called by API server for admission reviews" "HTTPS/9443"

        // Relationships - Dependencies
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, LLMInferenceService CRDs"
        odhModelController -> openshiftRouter "Creates Routes for external model access"
        odhModelController -> istio "Creates EnvoyFilters for Authorino TLS"
        odhModelController -> kuadrant "Creates AuthPolicies for gateway/route auth"
        odhModelController -> prometheus "Creates ServiceMonitors and PodMonitors"
        odhModelController -> keda "Creates TriggerAuthentications for autoscaling"
        rhodsOperator -> odhModelController "Deploys via kustomize overlay"

        // Deployment
        deploymentEnvironment "Production" {
            deploymentNode "OpenShift Cluster" {
                deploymentNode "Namespace: opendatahub" {
                    containerInstance controllerManager
                    containerInstance webhookServer
                    containerInstance gatewayDiscovery
                }
            }
        }
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
