/*
 * MLflow Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages MLflow experiments, runs, and models"

        mlflowOperator = softwareSystem "MLflow Operator" "Kubernetes operator that deploys and manages MLflow tracking server instances with workspace isolation, Gateway API ingress, and Kubernetes-native authentication" {
            controller = container "MLflow Operator Controller" "Reconciles MLflow CRs; renders Helm charts and applies resources via Server-Side Apply; creates HTTPRoute and ConsoleLink CRs" "Go / controller-runtime"
            helmRenderer = container "Helm Chart Renderer" "Converts MLflow CR spec into Helm values and renders chart templates to unstructured Kubernetes objects" "Go / Helm v3"
            mlflowServer = container "MLflow Server" "MLflow tracking server with experiment tracking, model registry, artifact serving, and workspace support" "Python / uvicorn"
            caBundleInit = container "CA Bundle Init Container" "Combines system, platform, and custom CA bundles into a single PEM file at startup" "Shell"
            caBundleWatcher = container "CA Bundle Watcher Sidecar" "Monitors CA bundle ConfigMap changes and regenerates combined CA bundle at runtime (30s poll)" "Shell"
        }

        dataScienceGateway = softwareSystem "Data Science Gateway" "Platform Gateway API ingress gateway in openshift-ingress namespace" "External Platform"
        openshiftConsole = softwareSystem "OpenShift Console" "OpenShift web console with application menu" "External Platform"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring via ServiceMonitor" "External Platform"
        k8sAPI = softwareSystem "Kubernetes API" "Kubernetes API server for RBAC, workspace enumeration, and resource management" "External Platform"
        serviceCA = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning for services" "External Platform"
        odhCABundle = softwareSystem "odh-trusted-ca-bundle" "Platform-provided CA certificate bundle ConfigMap" "Internal RHOAI"

        postgresql = softwareSystem "PostgreSQL" "Backend and registry metadata store" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Artifact storage (MinIO, SeaweedFS, AWS S3)" "External"

        # User interactions
        user -> mlflowOperator "Creates MLflow CR, accesses MLflow UI/API via Gateway" "HTTPS/443"
        user -> dataScienceGateway "Accesses MLflow via platform URL" "HTTPS/443"

        # Internal container relationships
        controller -> helmRenderer "Renders Helm chart templates"
        controller -> k8sAPI "Watches CRs, applies resources via SSA" "HTTPS/6443"
        mlflowServer -> k8sAPI "SelfSubjectAccessReview for kubernetes-auth" "HTTPS/6443"
        mlflowServer -> postgresql "Stores experiment/run metadata" "PostgreSQL/5432"
        mlflowServer -> s3Storage "Stores and retrieves ML artifacts" "HTTPS/443,9000,8333"

        # Platform integrations
        dataScienceGateway -> mlflowServer "Routes traffic via HTTPRoute" "HTTPS/8443"
        mlflowOperator -> dataScienceGateway "Creates HTTPRoute CRs referencing gateway"
        mlflowOperator -> openshiftConsole "Creates ConsoleLink CR for menu entry"
        prometheus -> mlflowServer "Scrapes /metrics endpoint" "HTTPS/8443"
        prometheus -> mlflowOperator "Scrapes operator /metrics" "HTTPS/8443"
        serviceCA -> mlflowServer "Provisions TLS certificates"
        odhCABundle -> mlflowServer "Provides platform CA certificates"
    }

    views {
        systemContext mlflowOperator "SystemContext" {
            include *
            autoLayout
        }

        container mlflowOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Platform" {
                background #7ed321
                color #ffffff
            }
            element "Internal RHOAI" {
                background #50e3c2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
