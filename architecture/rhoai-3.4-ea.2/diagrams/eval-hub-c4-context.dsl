/*
 * EvalHub C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/eval-hub.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages LLM evaluation jobs"

        evalHub = softwareSystem "EvalHub" "Lightweight REST API service for orchestrating LLM evaluations across multiple backends on OpenShift" {
            apiServer = container "EvalHub API Server" "Main REST API orchestrating LLM evaluations across backends" "Go REST Service, 8080/TCP"
            authModule = container "Auth Module" "Kubernetes-delegated authentication (TokenReview) and authorization (SAR)" "Go Module"
            k8sRuntime = container "K8s Runtime" "Creates Kubernetes batch/v1 Jobs and ConfigMaps for evaluation workloads" "Go Module"
            mlflowClient = container "MLflow Client" "Integrates with MLflow tracking server for experiment management" "Go Module"
            sqlStorage = container "SQL Storage" "Database abstraction layer (SQLite / PostgreSQL)" "Go Module"
            metricsMiddleware = container "Metrics Middleware" "Prometheus metrics collection for HTTP request observability" "Go Module"
            otelModule = container "OTEL Module" "OpenTelemetry distributed tracing integration" "Go Module"
            providerConfigs = container "Provider Configs" "Declarative provider/benchmark definitions" "YAML"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages EvalHub instances via EvalHub CR" "Internal RHOAI"
        mlflow = softwareSystem "MLflow Tracking Server" "Experiment tracking, run logging, and result aggregation" "Internal RHOAI"
        k8sApiServer = softwareSystem "Kubernetes API Server" "Job/ConfigMap CRUD, TokenReview, SubjectAccessReview" "External"
        adapterImages = softwareSystem "Evaluation Adapter Images" "Provider-specific adapters (lm-eval-harness, RAGAS, Garak, GuideLLM, LightEval, MTEB)" "Internal RHOAI"
        s3 = softwareSystem "AWS S3" "Test data storage for evaluation datasets" "External"
        postgresql = softwareSystem "PostgreSQL" "Production persistent storage" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed trace collection" "External"
        prometheus = softwareSystem "Prometheus" "Metrics scraping and monitoring" "External"
        modelEndpoints = softwareSystem "Model Inference Endpoints" "LLM model serving endpoints for evaluation" "External"

        # External relationships
        user -> evalHub "Creates evaluation jobs, views results" "HTTPS/8080, Bearer Token"
        trustyaiOperator -> evalHub "Deploys and manages via EvalHub CR" "CRD reconciliation"

        # EvalHub outbound
        evalHub -> k8sApiServer "Job/ConfigMap CRUD, TokenReview, SAR" "HTTPS/443, SA Token"
        evalHub -> mlflow "Create experiments, log runs" "HTTP(S)/5000, Projected SA Token"
        evalHub -> postgresql "Persistent storage (production)" "TCP/5432"
        evalHub -> otelCollector "Export traces" "gRPC/4317"
        evalHub -> adapterImages "Creates batch/v1 Jobs" "Kubernetes Job API"

        # Adapter relationships
        adapterImages -> modelEndpoints "Inference requests during evaluation" "HTTPS, API Key/Token"
        adapterImages -> evalHub "Status callbacks" "HTTP(S)/8080, Bearer Token"
        adapterImages -> mlflow "Log evaluation results" "HTTP(S)/5000, Projected SA Token"
        adapterImages -> s3 "Download test datasets (init container)" "HTTPS/443, AWS Credentials"

        # Monitoring
        prometheus -> evalHub "Scrape metrics" "HTTP(S)/8080"

        # Internal container relationships
        apiServer -> authModule "Authenticates/authorizes requests"
        apiServer -> k8sRuntime "Creates evaluation jobs"
        apiServer -> mlflowClient "Manages experiments"
        apiServer -> sqlStorage "Persists evaluation data"
        apiServer -> metricsMiddleware "Collects request metrics"
        apiServer -> otelModule "Traces requests"
        apiServer -> providerConfigs "Loads provider definitions"
    }

    views {
        systemContext evalHub "SystemContext" {
            include *
            autoLayout
        }

        container evalHub "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
