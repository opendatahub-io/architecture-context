// EvalHub C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/eval-hub.md

workspace {
    model {
        datascientist = person "Data Scientist" "Submits and monitors LLM evaluation jobs"
        platformadmin = person "Platform Admin" "Manages EvalHub deployment via TrustyAI Operator"

        evalhub = softwareSystem "EvalHub" "Lightweight REST API service for orchestrating LLM evaluations across multiple backends on OpenShift" {
            apiServer = container "EvalHub API Server" "Main HTTP server for evaluation API endpoints" "Go REST API (net/http.ServeMux)" "Port 8080/TCP"
            authModule = container "Auth Module" "Kubernetes TokenReview (authn) and SubjectAccessReview (authz)" "Go (k8s apiserver libraries)"
            k8sRuntime = container "K8s Runtime" "Creates Kubernetes batch/v1 Jobs and ConfigMaps for evaluation benchmarks" "Go (client-go)"
            sqlStorage = container "SQL Storage" "Persists evaluation jobs, providers, and collections" "SQLite (dev) / PostgreSQL (prod)"
            mlflowClient = container "MLflow Client" "Creates and manages MLflow experiments for result tracking" "Go HTTP client"
            otelModule = container "OTEL Module" "OpenTelemetry tracing via OTLP-gRPC/HTTP" "Go (OpenTelemetry SDK)"
            initContainer = container "eval-hub-init" "Downloads S3 test data into evaluation job pods" "Go binary (init container)"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys EvalHub via EvalHub CR, provisions ServiceAccount and service CA" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Job/ConfigMap CRUD, TokenReview, SubjectAccessReview" "Platform"
        mlflow = softwareSystem "MLflow Tracking Server" "Experiment tracking, run logging, result storage" "Internal RHOAI"
        postgresql = softwareSystem "PostgreSQL" "Persistent storage for evaluation data" "Platform"
        s3 = softwareSystem "S3-compatible Storage" "Test data download for evaluation jobs" "External"
        modelEndpoint = softwareSystem "Model Inference Endpoint" "LLM inference endpoint (KServe/vLLM) targeted by evaluation benchmarks" "Internal RHOAI"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing backend" "Platform"
        prometheus = softwareSystem "Prometheus" "Metrics collection at /metrics endpoint" "Platform"
        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Runs 167 LLM evaluation benchmarks via Kubernetes Jobs" "Internal RHOAI"
        guidellm = softwareSystem "GuideLLM" "Performance benchmarking (sweep, throughput, concurrent, constant, poisson)" "Internal RHOAI"
        lighteval = softwareSystem "LightEval" "Lightweight evaluation (reasoning, math, knowledge, safety)" "Internal RHOAI"

        // User interactions
        datascientist -> evalhub "Creates and monitors evaluation jobs" "REST API / HTTPS"
        platformadmin -> trustyaiOperator "Deploys EvalHub via EvalHub CR" "kubectl"

        // Operator manages EvalHub
        trustyaiOperator -> evalhub "Deploys and manages lifecycle" "Kubernetes CR (trustyai.opendatahub.io/v1alpha1)"

        // EvalHub to platform services
        evalhub -> k8sAPI "Job/ConfigMap CRUD, TokenReview, SubjectAccessReview" "HTTPS/443"
        evalhub -> mlflow "Create experiments, log results" "HTTP(S)/5000"
        evalhub -> postgresql "Persist evaluation data" "PostgreSQL/5432"
        evalhub -> otelCollector "Export traces" "gRPC/4317"
        prometheus -> evalhub "Scrape metrics" "HTTP(S)/8080"

        // EvalHub creates evaluation jobs
        evalhub -> lmEvalHarness "Creates Kubernetes Jobs for evaluation" "Kubernetes batch/v1"
        evalhub -> guidellm "Creates Kubernetes Jobs for performance benchmarks" "Kubernetes batch/v1"
        evalhub -> lighteval "Creates Kubernetes Jobs for lightweight evals" "Kubernetes batch/v1"

        // Evaluation jobs access external services
        lmEvalHarness -> modelEndpoint "Runs inference benchmarks" "HTTPS/443"
        guidellm -> modelEndpoint "Runs performance benchmarks" "HTTPS/443"
        lighteval -> modelEndpoint "Runs lightweight benchmarks" "HTTPS/443"
        evalhub -> s3 "Downloads test data (via eval-hub-init)" "HTTPS/443"

        // Container relationships
        apiServer -> authModule "Authenticates and authorizes requests"
        apiServer -> k8sRuntime "Creates evaluation jobs"
        apiServer -> sqlStorage "Persists data"
        apiServer -> mlflowClient "Tracks experiments"
        apiServer -> otelModule "Exports traces"
    }

    views {
        systemContext evalhub "SystemContext" {
            include *
            autoLayout
        }

        container evalhub "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #333333
            }
        }
    }
}
