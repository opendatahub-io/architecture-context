%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Operator Service Accounts"
        SA_Op["SA: mlflow-operator-<br/>controller-manager"]
    end

    subgraph "MLflow Server Service Account"
        SA_MLflow["SA: mlflow"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["manager-rolebinding"]
        CRB_Metrics["metrics-auth-rolebinding"]
        CRB_MLflow["mlflow-rolebinding"]
    end

    subgraph "Cluster Roles (Operator)"
        CR_Manager["ClusterRole:<br/>manager-role"]
        CR_MetricsAuth["ClusterRole:<br/>metrics-auth-role"]
        CR_MetricsReader["ClusterRole:<br/>metrics-reader"]
    end

    subgraph "Cluster Roles (MLflow Server Runtime)"
        CR_MLflow["ClusterRole:<br/>mlflow (shared)"]
    end

    subgraph "Aggregate Roles (User-Facing)"
        CR_View["ClusterRole:<br/>mlflow-view<br/>Aggregates to: view, edit, admin"]
        CR_Edit["ClusterRole:<br/>mlflow-edit<br/>Aggregates to: edit, admin"]
        CR_Integration["ClusterRole:<br/>mlflow-integration<br/>(standalone)"]
    end

    subgraph "Operator Managed Resources"
        R_MLflow["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        R_MLflowConfig["mlflow.kubeflow.org<br/>mlflowconfigs"]
        R_Core["core<br/>namespaces, secrets<br/>(mlflow-artifact-connection)"]
        R_Gateway["gateway.networking.k8s.io<br/>httproutes"]
        R_Console["console.openshift.io<br/>consolelinks"]
        R_RBAC["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings"]
    end

    subgraph "Namespace Resources (Role)"
        R_NS["core: configmaps, pvc,<br/>secrets, serviceaccounts,<br/>services<br/>apps: deployments<br/>networking.k8s.io: networkpolicies<br/>monitoring.coreos.com: servicemonitors"]
    end

    subgraph "Auth Resources"
        R_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        R_Metrics["/metrics<br/>(non-resource URL)"]
    end

    subgraph "User-Facing Resources"
        R_UserMLflow["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        R_UserKF["mlflow.kubeflow.org<br/>mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewayendpoints,<br/>gatewaymodeldefinitions,<br/>gatewaysecrets"]
    end

    %% Operator bindings
    SA_Op -->|bound via| CRB_Manager
    SA_Op -->|bound via| CRB_Metrics
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth

    %% Operator permissions
    CR_Manager -->|"full CRUD"| R_MLflow
    CR_Manager -->|"get, list, watch"| R_MLflowConfig
    CR_Manager -->|"get, list, watch / get"| R_Core
    CR_Manager -->|"full CRUD"| R_Gateway
    CR_Manager -->|"full CRUD"| R_Console
    CR_Manager -->|"full CRUD"| R_RBAC
    CR_Manager -->|"full CRUD (namespace)"| R_NS
    CR_MetricsAuth -->|"create"| R_TokenReview
    CR_MetricsAuth -->|"create"| R_SAR
    CR_MetricsReader -->|"get"| R_Metrics

    %% MLflow Server bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow
    CR_MLflow -->|"get, list, watch"| R_Core
    CR_MLflow -->|"get, list, watch"| R_MLflowConfig

    %% User-facing roles
    CR_View -->|"get, list, watch"| R_UserMLflow
    CR_View -->|"get, list"| R_UserKF
    CR_Edit -->|"full CRUD"| R_UserMLflow
    CR_Edit -->|"full CRUD + use"| R_UserKF
    CR_Integration -->|"get, list, create, update"| R_UserKF

