%% Data Science Pipelines - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (Istio Gateway)"]
        Gateway["Istio Ingress Gateway<br/>kubeflow-gateway<br/>VirtualService: ml-pipeline-ui<br/>TLS Mode: ISTIO_MUTUAL"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS)"]
        direction TB

        subgraph NS_KF["Namespace: kubeflow / dspa-namespace"]
            direction TB

            PipelineUI["ml-pipeline-ui<br/>80/TCP → 3000/TCP<br/>HTTP<br/>AuthZ: gateway SA only"]

            APIServer["ml-pipeline (API Server)<br/>REST: 8888/TCP<br/>gRPC: 8887/TCP<br/>Webhook: 8443/TCP<br/>Auth: Bearer Token (SA JWT)<br/>Multi-user: SAR + TokenReview"]

            PersAgent["ml-pipeline-persistenceagent<br/>Watches Workflow CRs<br/>Syncs state to API Server"]

            SchedWF["ml-pipeline-scheduledworkflow<br/>Watches ScheduledWorkflow CRs<br/>Creates Workflow CRs"]

            CacheSrv["cache-server<br/>443/TCP → 8443/TCP<br/>HTTPS (TLS certs)<br/>Auth: K8s API mTLS"]

            VizServer["ml-pipeline-visualizationserver<br/>8888/TCP HTTP<br/>AuthZ: pipeline SAs only"]

            MLMDServer["metadata-grpc-server<br/>8080/TCP gRPC<br/>No encryption / No auth"]

            EnvoyProxy["metadata-envoy<br/>9090/TCP gRPC-Web"]

            StepPods["Pipeline Step Pods<br/>(driver + launcher)<br/>SA: pipeline-runner"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>Auth: SA Token"]
        ArgoCtrl["Argo Workflows Controller<br/>Executes Workflow CRs"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DB["MySQL/PostgreSQL<br/>3306/5432 TCP<br/>Optional TLS<br/>Auth: Username/Password<br/>(mysql-secret)"]
        ObjectStore["MinIO / S3 Storage<br/>9000/443 TCP<br/>HTTP/HTTPS<br/>Auth: Access Key/Secret Key<br/>(mlpipeline-minio-artifact)"]
    end

    %% External to Ingress
    User -->|"HTTP/80<br/>Istio mTLS<br/>kubeflow-userid header"| Gateway

    %% Ingress to Services
    Gateway -->|"HTTP/3000<br/>Istio mTLS<br/>AuthorizationPolicy"| PipelineUI

    %% Internal flows
    PipelineUI -->|"HTTP/8888<br/>Optional TLS<br/>Bearer Token"| APIServer
    PersAgent -->|"HTTP-gRPC/8888-8887<br/>Optional TLS<br/>SA Token"| APIServer
    EnvoyProxy -->|"gRPC/8080<br/>No encryption"| MLMDServer

    %% To Control Plane
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    PersAgent -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    SchedWF -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    K8sAPI -->|"HTTPS/8443<br/>TLS<br/>K8s API mTLS"| CacheSrv

    %% Argo flows
    K8sAPI --- ArgoCtrl
    ArgoCtrl -->|"Creates step pods"| StepPods

    %% Step pod flows
    StepPods -->|"HTTP-HTTPS/9000-443<br/>Optional TLS<br/>Access Key"| ObjectStore
    StepPods -->|"gRPC/8080<br/>No encryption"| MLMDServer

    %% To External Services
    APIServer -->|"MySQL-PG/3306-5432<br/>Optional TLS<br/>Username/Password"| DB
    APIServer -->|"HTTP-HTTPS/9000-443<br/>Optional TLS<br/>Access Key"| ObjectStore
    CacheSrv -->|"MySQL/3306<br/>Optional TLS<br/>Username/Password"| DB

