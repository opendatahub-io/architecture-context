/*
 * ML Metadata - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/ml-metadata.md
 */

workspace {
    model {
        pipelineRunner = person "Pipeline Runner" "Executes ML pipeline steps and records metadata"
        dataScientist = person "Data Scientist" "Views pipeline results and artifact lineage via DSP UI"

        mlMetadata = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving metadata associated with ML workflows - artifacts, executions, contexts, and lineage" {
            grpcServer = container "metadata_store_server" "C++ gRPC server exposing MetadataStoreService with 50+ RPCs for metadata CRUD operations" "C++ / gRPC / HTTP2"
            metadataStore = container "MetadataStore" "Core business logic for metadata operations with pluggable database backends" "C++ Library"
            metadataAccessObject = container "MetadataAccessObject" "Database abstraction layer supporting MySQL, PostgreSQL, and SQLite" "C++ Library"
            protoDefinitions = container "Proto Definitions" "Schema definitions for metadata types, store configuration, and gRPC service" "Protocol Buffers"
        }

        dspApiServer = softwareSystem "DSP API Server" "Data Science Pipelines API Server - records and queries pipeline metadata" "Internal RHOAI"
        dspPersistenceAgent = softwareSystem "DSP Persistence Agent" "Persists pipeline execution metadata" "Internal RHOAI"
        dspOperator = softwareSystem "DSP Operator" "Data Science Pipelines Operator - deploys and configures MLMD" "Internal RHOAI"
        dspUI = softwareSystem "DSP UI" "Data Science Pipelines UI - displays artifact lineage and execution history" "Internal RHOAI"

        mysql = softwareSystem "MySQL / MariaDB" "Primary production metadata backend storage" "External Database"
        postgresql = softwareSystem "PostgreSQL" "Alternative production metadata backend storage" "External Database"

        # Relationships
        pipelineRunner -> dspApiServer "Submits pipeline runs"
        dataScientist -> dspUI "Views pipeline results and lineage"

        dspApiServer -> mlMetadata "Records and queries pipeline run metadata" "gRPC/HTTP2 8080/TCP"
        dspPersistenceAgent -> mlMetadata "Persists pipeline execution metadata" "gRPC/HTTP2 8080/TCP"
        dspUI -> dspApiServer "Retrieves artifact lineage and execution history"
        dspOperator -> mlMetadata "Deploys and configures MLMD server"

        mlMetadata -> mysql "Stores metadata (artifacts, executions, contexts, events, types)" "MySQL Protocol 3306/TCP"
        mlMetadata -> postgresql "Stores metadata (alternative backend)" "PostgreSQL Protocol 5432/TCP"

        # Container relationships
        grpcServer -> metadataStore "Delegates business logic"
        metadataStore -> metadataAccessObject "Database operations"
        metadataAccessObject -> mysql "SQL queries" "MySQL Protocol 3306/TCP"
        metadataAccessObject -> postgresql "SQL queries" "PostgreSQL Protocol 5432/TCP"
    }

    views {
        systemContext mlMetadata "SystemContext" {
            include *
            autoLayout
        }

        container mlMetadata "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External Database" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
