graph TB
    subgraph KubeRayOperator["KubeRay Operator (opendatahub namespace)"]
        direction TB
        RCController["RayCluster Controller<br/>Reconciler"]
        RJController["RayJob Controller<br/>Reconciler"]
        RSController["RayService Controller<br/>Reconciler"]
        AuthController["Authentication Controller<br/>Reconciler"]
        NPController["NetworkPolicy Controller<br/>Reconciler"]
        MTLSController["RayCluster mTLS Controller<br/>Reconciler"]
        MutWebhook["Mutating Webhook<br/>9443/TCP HTTPS"]
        ValWebhook["Validating Webhook<br/>9443/TCP HTTPS"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% User
    User["User / Data Scientist"]

    %% Created Resources
    HeadPod["Ray Head Pod<br/>8265, 10001, 6379, 8080"]
    WorkerPods["Ray Worker Pods"]
    HeadSvc["Head Service<br/>(ClusterIP)"]
    HeadlessSvc["Headless Service"]
    HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    RefGrant["ReferenceGrant"]
    NetPol["NetworkPolicies<br/>(head + workers)"]
    Certs["cert-manager<br/>Issuer + Certificates"]
    SubmitterJob["Submitter Job Pod"]
    KubeRBACProxy["kube-rbac-proxy<br/>sidecar (8443/TCP)"]

    %% External Dependencies
    K8sAPI["Kubernetes API Server"]
    DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    CertManager["cert-manager"]
    Prometheus["Prometheus"]

    %% Internal Dependencies
    RhodsOperator["rhods-operator<br/>(deploys via kustomize)"]

    %% User creates CRs
    User -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% Webhook intercepts
    RayClusterCR -->|"admission"| MutWebhook
    MutWebhook -->|"sets enableIngress=false<br/>sets secure-trusted-network=true"| ValWebhook

    %% Controllers watch CRDs
    RayClusterCR -->|watched by| RCController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController
    RayClusterCR -->|watched by| AuthController
    RayClusterCR -->|watched by| NPController
    RayClusterCR -->|watched by| MTLSController

    %% RayCluster Controller creates
    RCController -->|creates| HeadPod
    RCController -->|creates| WorkerPods
    RCController -->|creates| HeadSvc
    RCController -->|creates| HeadlessSvc

    %% RayJob Controller creates
    RJController -->|creates| SubmitterJob
    SubmitterJob -->|submits job via| HeadPod

    %% Auth Controller creates
    AuthController -->|creates| HTTPRoute
    AuthController -->|creates| RefGrant
    AuthController -->|injects| KubeRBACProxy

    %% NetworkPolicy Controller creates
    NPController -->|creates| NetPol

    %% mTLS Controller creates
    MTLSController -->|creates| Certs

    %% External interactions
    HTTPRoute -->|references| DSGateway
    Certs -->|managed by| CertManager
    KubeRayOperator -->|API calls| K8sAPI
    Prometheus -->|scrapes 8080/TCP| KubeRayOperator
    RhodsOperator -->|deploys| KubeRayOperator

