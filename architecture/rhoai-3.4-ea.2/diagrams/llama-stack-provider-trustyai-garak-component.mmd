%% Component Structure Diagram: llama-stack-provider-trustyai-garak
%% Generated by: Claude Opus 4.6

graph TB
    subgraph Provider["Llama Stack Provider: TrustyAI Garak"]
        direction TB
        Base[GarakEvalBase<br/>Shared evaluation logic]
        InlineAdapter[GarakInlineEvalAdapter<br/>Local subprocess execution]
        RemoteAdapter[GarakRemoteEvalAdapter<br/>KFP pipeline submission]
        ShieldOrch[SimpleShieldOrchestrator<br/>Input/Output shield scans]
        S3Utils[S3 Utilities<br/>boto3 S3 client factory]
        ResultUtils[Result Utilities<br/>AVID, TBSA, ART reports]

        Base --> InlineAdapter
        Base --> RemoteAdapter
        InlineAdapter -->|subprocess| GarakEngine[Garak Engine<br/>NVIDIA garak >=0.14.0]
        RemoteAdapter -->|delegates| KFPClient[KFP Client<br/>kfp >=2.14.6]
        Base -->|orchestrates| ShieldOrch
        Base -->|uses| ResultUtils
        RemoteAdapter -->|uses| S3Utils
    end

    subgraph EvalHub["Eval-Hub Integration"]
        GarakAdapterEH[GarakAdapter<br/>Eval-hub adapter]
        GarakKFPAdapterEH[GarakKFPAdapter<br/>KFP execution mode]
        KFPPipeline[evalhub KFP Pipeline<br/>6-step pipeline]

        GarakAdapterEH --> GarakKFPAdapterEH
        GarakKFPAdapterEH -->|submits| KFPPipeline
    end

    subgraph ExternalSystems["External Systems"]
        LlamaStack[Llama Stack Server<br/>8321/TCP HTTP]
        KFPServer[Kubeflow Pipelines API<br/>443/TCP HTTPS]
        vLLM[vLLM / Inference Server<br/>HTTP/HTTPS]
        S3[S3 Storage<br/>443/TCP HTTPS]
        PostgreSQL[PostgreSQL 15<br/>5432/TCP]
    end

    subgraph SafetyAPIs["Llama Stack Safety"]
        SafetyAPI[Safety API<br/>Input/Output shields]
        LlamaGuard[Llama Guard]
        PromptGuard[Prompt Guard]
        SafetyAPI --> LlamaGuard
        SafetyAPI --> PromptGuard
    end

    %% Client interaction
    Client[Client / User] -->|POST /alpha/eval/run_eval| LlamaStack
    LlamaStack -->|loads provider| Provider

    %% Provider to external
    RemoteAdapter -->|submit pipeline| KFPServer
    RemoteAdapter -->|poll status| KFPServer
    InlineAdapter -->|scan target| vLLM
    KFPPipeline -->|scan target| vLLM
    KFPPipeline -->|upload artifacts| S3
    RemoteAdapter -->|download results| S3
    LlamaStack -->|metadata| PostgreSQL
    ShieldOrch -->|test shields| SafetyAPI

    %% Kubernetes resources
    ConfigMap["ConfigMap:<br/>llamastack-garak-config"]
    Secret["Secrets:<br/>postgres-secret<br/>model-auth<br/>Data Connection"]
    ConfigMap -.->|config| Provider
    Secret -.->|credentials| Provider

