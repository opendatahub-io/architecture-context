%% Models as a Service - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.2/models-as-a-service.md

graph TB
    subgraph MaaS["Models as a Service (MaaS)"]
        direction TB
        subgraph APIServer["maas-api (Go/Gin)"]
            APIKeys[API Key Management<br/>CRUD, Validate, Hash]
            ModelDiscovery[Model Discovery<br/>/v1/models]
            SubscriptionSelect[Subscription Selection<br/>/v1/subscriptions/select]
            TierLookup[Tier Lookup<br/>/v1/tiers/lookup]
            KeyValidate[Key Validation Callback<br/>/internal/v1/api-keys/validate]
        end

        subgraph Controller["maas-controller (Go Operator)"]
            ModelRefCtrl[MaaSModelRef<br/>Controller]
            AuthPolicyCtrl[MaaSAuthPolicy<br/>Controller]
            SubCtrl[MaaSSubscription<br/>Controller]
        end
    end

    %% CRDs
    MaaSModelRefCR[MaaSModelRef CR<br/>maas.opendatahub.io/v1alpha1]
    MaaSAuthPolicyCR[MaaSAuthPolicy CR<br/>maas.opendatahub.io/v1alpha1]
    MaaSSubscriptionCR[MaaSSubscription CR<br/>maas.opendatahub.io/v1alpha1]

    %% Controller watches CRDs
    MaaSModelRefCR -->|watched by| ModelRefCtrl
    MaaSAuthPolicyCR -->|watched by| AuthPolicyCtrl
    MaaSSubscriptionCR -->|watched by| SubCtrl

    %% Controller creates Kuadrant resources
    AuthPolicyCtrl -->|creates/updates| KuadrantAuthPolicy[Kuadrant AuthPolicy<br/>per-model HTTPRoute]
    SubCtrl -->|creates/updates| KuadrantTRLP[Kuadrant TokenRateLimitPolicy<br/>per-model HTTPRoute]

    %% Controller watches KServe
    ModelRefCtrl -->|watches| LLMInferenceService[LLMInferenceService<br/>serving.kserve.io]
    ModelRefCtrl -->|watches/validates| HTTPRoute[HTTPRoute<br/>Gateway API]

    %% Gateway
    subgraph IngressLayer["Ingress (openshift-ingress)"]
        Gateway[maas-default-gateway<br/>openshift-default GatewayClass<br/>443/TCP TLS Terminate]
        GatewayDefaultAuth[gateway-default-auth<br/>Default Deny AuthPolicy]
        GatewayDefaultDeny[gateway-default-deny<br/>Zero-Token Rate Limit]
    end

    %% External Dependencies
    Client[Client] -->|HTTPS/443<br/>Bearer sk-oai-*| Gateway
    Gateway -->|ext_authz gRPC| Authorino[Kuadrant/Authorino]
    Authorino -->|HTTP callback<br/>HTTPS/8443| KeyValidate
    Authorino -->|HTTP callback<br/>HTTPS/8443| SubscriptionSelect
    Authorino -->|rate limit check| Limitador[Kuadrant/Limitador]
    Gateway -->|routes to| APIServer
    Gateway -->|routes to| ModelPod[Model Pod<br/>LLMInferenceService Backend]

    %% Database
    APIKeys -->|store/validate| PostgreSQL[(PostgreSQL<br/>5432/TCP TLS)]

    %% Kubernetes API
    Controller -->|CRD operations| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]

