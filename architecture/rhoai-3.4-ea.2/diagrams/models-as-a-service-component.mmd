graph TB
    subgraph MaaS["Models as a Service (MaaS)"]
        direction TB
        subgraph API["maas-api (Go/Gin)"]
            APIServer["REST API Server<br/>8080/TCP HTTP | 8443/TCP HTTPS"]
            KeyMgmt["API Key Management<br/>(sk-oai-* format)"]
            ModelDiscovery["Model Discovery<br/>(/v1/models)"]
            TierLookup["Tier Lookup<br/>(/v1/tiers/lookup)"]
            SubSelect["Subscription Selection<br/>(/v1/subscriptions/select)"]
            KeyValidate["API Key Validation<br/>(/internal/v1/api-keys/validate)"]
            APIServer --> KeyMgmt
            APIServer --> ModelDiscovery
            APIServer --> TierLookup
            APIServer --> SubSelect
            APIServer --> KeyValidate
        end

        subgraph Controller["maas-controller (Go/controller-runtime)"]
            ModelRefCtrl["MaaSModelRef<br/>Controller"]
            AuthPolicyCtrl["MaaSAuthPolicy<br/>Controller"]
            SubCtrl["MaaSSubscription<br/>Controller"]
        end
    end

    %% CRDs
    MaaSModelRefCR["MaaSModelRef CR<br/>(maas.opendatahub.io/v1alpha1)"]
    MaaSAuthPolicyCR["MaaSAuthPolicy CR<br/>(maas.opendatahub.io/v1alpha1)"]
    MaaSSubscriptionCR["MaaSSubscription CR<br/>(maas.opendatahub.io/v1alpha1)"]

    %% CRD watches
    MaaSModelRefCR -->|watched by| ModelRefCtrl
    MaaSAuthPolicyCR -->|watched by| AuthPolicyCtrl
    MaaSSubscriptionCR -->|watched by| SubCtrl

    %% Controller outputs
    ModelRefCtrl -->|validates & resolves| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthPolicyCtrl -->|creates| KuadrantAuthPolicy["Kuadrant AuthPolicy"]
    SubCtrl -->|creates| KuadrantTRLP["Kuadrant<br/>TokenRateLimitPolicy"]

    %% Kuadrant policies target HTTPRoutes
    KuadrantAuthPolicy -->|targets| HTTPRoute
    KuadrantTRLP -->|targets| HTTPRoute

    %% Gateway
    Gateway["maas-default-gateway<br/>openshift-ingress namespace<br/>443/TCP HTTPS | 80/TCP HTTP"]
    HTTPRoute -->|references| Gateway

    %% External dependencies
    ModelRefCtrl -->|watches| LLMInferenceService["KServe<br/>LLMInferenceService"]
    KuadrantAuthPolicy -->|enforced by| Authorino["Kuadrant Authorino"]
    KuadrantTRLP -->|enforced by| Limitador["Kuadrant Limitador"]
    Authorino -->|callbacks| KeyValidate
    Authorino -->|callbacks| SubSelect
    APIServer -->|stores keys| PostgreSQL["PostgreSQL<br/>5432/TCP"]

    %% Users
    User["Client / Data Scientist"] -->|inference request| Gateway
    User -->|API key mgmt| Gateway

