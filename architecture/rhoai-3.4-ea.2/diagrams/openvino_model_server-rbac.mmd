    end

    subgraph Endpoints["OVMS Endpoints"]
        subgraph Authenticated["Authenticated Endpoints (API Key optional)"]
            TFS["/v1/models/* - TFS API"]
            KFS["/v2/models/* - KFS v2 API"]
            OpenAIv3["/v3/chat/completions - LLM"]
            Embeddings["/v3/embeddings"]
            Rerank["/v3/rerank"]
