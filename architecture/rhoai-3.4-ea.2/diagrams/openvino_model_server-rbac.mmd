    %% Authentication Flow
    Client -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>mTLS"| KubeRBAC
    KubeRBAC -->|"HTTP (plaintext)<br/>localhost"| APIKeyCheck

    APIKeyCheck -->|"Yes"| APIKeyValidate
    APIKeyCheck -->|"No"| NoAuth
    APIKeyValidate --> Authenticated
    NoAuth --> Authenticated

    Client -.->|"Direct (no platform)"| APIKeyCheck

    %% Unauthenticated endpoints bypass all auth
    HealthLive -.->|"Always accessible"| Client
    HealthReady -.->|"Always accessible"| Client
    Metrics -.->|"Always accessible"| Client

    %% Platform RBAC
    KServeController -->|"creates"| OVMSPodSA
    ModelMeshController -->|"creates"| OVMSPodSA

    %% Secrets
    APIKeySecret -.->|"API_KEY env"| APIKeyCheck
    AWSCreds -.->|"mounted"| OVMSPodSA
    AzureCreds -.->|"mounted"| OVMSPodSA
    GCPCreds -.->|"mounted"| OVMSPodSA
    HFToken -.->|"mounted"| OVMSPodSA

