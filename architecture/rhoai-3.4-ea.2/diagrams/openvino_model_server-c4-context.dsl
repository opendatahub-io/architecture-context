/*
 * OpenVINO Model Server - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/openvino_model_server.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys models and sends inference requests"
        mlEngineer = person "ML Engineer" "Configures serving runtimes and pipelines"

        ovms = softwareSystem "OpenVINO Model Server (OVMS)" "High-performance C++ model inference server providing gRPC and REST APIs compatible with KServe, TensorFlow Serving, and OpenAI protocols" {
            grpcModule = container "GRPCServerModule" "gRPC listener serving KServe v2, TFS PredictService, and TFS ModelService" "C++ / gRPC"
            httpModule = container "HTTPServerModule" "REST/HTTP listener for TFS, KFS v2, OpenAI v3, and metrics endpoints" "C++ / Drogon"
            servableManager = container "ServableManagerModule" "Manages model lifecycle - loading, unloading, versioning, configuration" "C++"
            modelManager = container "ModelManager" "Central model registry managing model instances, DAG pipelines, and MediaPipe graphs" "C++"
            mediaPipeEngine = container "MediaPipe Graph Engine" "Graph-based execution for LLM, embeddings, rerank, image gen, audio" "C++ / MediaPipe"
            dagScheduler = container "DAG Pipeline Scheduler" "Directed Acyclic Graph execution for chaining multiple models" "C++"
            metricModule = container "MetricModule" "Prometheus metrics collection and exposure" "C++ / Prometheus"
            hfPullModule = container "HFPullModelModule" "HuggingFace Hub model download and preparation" "C++ / libgit2"
            pythonInterp = container "PythonInterpreterModule" "Embedded Python interpreter for custom node execution" "C++ / Python"
            openvinoRuntime = container "OpenVINO Runtime" "Core inference engine for model execution" "C++ Library / OpenVINO 2025.4"
        }

        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle for OVMS pods" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Alternative serving runtime lifecycle management" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "Creates InferenceService CRs that use OVMS" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "Consumes inference endpoints in pipeline tasks" "Internal RHOAI"
        platformGateway = softwareSystem "Platform Gateway" "RHOAI data-science-gateway with TLS termination" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"

        s3 = softwareSystem "S3-Compatible Storage" "Model artifact storage" "External"
        azure = softwareSystem "Azure Blob Storage" "Model artifact storage" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model repository for downloading models" "External"

        /* Relationships */
        datascientist -> platformGateway "Sends inference requests" "HTTPS/443"
        mlEngineer -> dashboard "Creates InferenceService" "HTTPS"
        mlEngineer -> kserve "Configures ServingRuntime" "kubectl"

        platformGateway -> ovms "Forwards requests" "HTTP/gRPC (plaintext)"
        kserve -> ovms "Manages pod lifecycle" "Kubernetes API"
        modelmesh -> ovms "Manages pod lifecycle" "Kubernetes API"
        dashboard -> kserve "Creates InferenceService CRs" "Kubernetes API"
        dsPipelines -> ovms "Consumes inference endpoints" "HTTP/gRPC"

        ovms -> s3 "Downloads model artifacts" "HTTPS/443"
        ovms -> azure "Downloads model artifacts" "HTTPS/443"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443"
        ovms -> huggingface "Downloads models" "HTTPS/443"
        prometheus -> ovms "Scrapes /metrics" "HTTP"

        /* Container relationships */
        grpcModule -> modelManager "Routes inference requests"
        httpModule -> modelManager "Routes inference requests"
        servableManager -> modelManager "Model lifecycle operations"
        modelManager -> dagScheduler "Executes DAG pipelines"
        modelManager -> mediaPipeEngine "Executes MediaPipe graphs"
        modelManager -> openvinoRuntime "Executes model inference"
        hfPullModule -> huggingface "Downloads models" "HTTPS/443"
        metricModule -> prometheus "Exposes metrics" "HTTP"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
