/*
 * C4 Context Diagram: OpenVINO Model Server (OVMS)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/openvino_model_server.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys models and sends inference requests"
        mlEngineer = person "ML Engineer" "Configures model serving pipelines"

        ovms = softwareSystem "OpenVINO Model Server (OVMS)" "High-performance C++ model inference server supporting KServe v2, TFS, and OpenAI-compatible APIs over gRPC and REST" {
            grpcModule = container "GRPCServerModule" "Hosts gRPC inference services (KServe v2, TFS Predict, Model Service)" "C++ / gRPC"
            httpModule = container "HTTPServerModule" "Hosts REST API for inference, health checks, metrics, and OpenAI-compatible endpoints" "C++ / Drogon"
            servableManager = container "ServableManagerModule" "Manages model lifecycle: loading, versioning, unloading, runtime configuration" "C++"
            modelManager = container "Model Manager" "Repository scanning, model loading, version policy, hot-reload" "C++"
            mediaPipe = container "MediaPipe Graph Executor" "Executes graph-based pipelines for LLM, embeddings, rerank, image gen, audio" "C++ / MediaPipe"
            dagScheduler = container "DAG Scheduler" "Orchestrates Directed Acyclic Graph pipelines of inference steps" "C++"
            metricModule = container "MetricModule" "Prometheus-compatible metrics registry and endpoint" "C++"
            hfPullModule = container "HfPullModelModule" "Downloads models from HuggingFace Hub with optional conversion" "C++"
        }

        kserve = softwareSystem "KServe" "Deploys and manages OVMS pods as InferenceService runtime" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Multi-model serving platform; OVMS serves as backend runtime" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "UI listing OVMS as an available serving runtime" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Platform"
        kubernetesAPI = softwareSystem "Kubernetes API" "Health probes (liveness, readiness)" "Platform"

        s3 = softwareSystem "S3 Storage" "Model artifact storage (AWS S3 or compatible)" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage (GCS)" "External"
        azure = softwareSystem "Azure Blob Storage" "Model artifact storage (Azure)" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model download and conversion" "External"
        openvinoRuntime = softwareSystem "OpenVINO Runtime" "Core inference execution engine (in-process library)" "External / Intel"

        /* User interactions */
        dataScientist -> ovms "Sends inference requests via REST/gRPC"
        mlEngineer -> kserve "Creates InferenceService with OVMS runtime"

        /* Internal RHOAI interactions */
        kserve -> ovms "Deploys and manages OVMS pods"
        modelMesh -> ovms "Uses OVMS as backend runtime container"
        dashboard -> ovms "Lists as available serving runtime" "Reference"

        /* Platform interactions */
        prometheus -> ovms "Scrapes /metrics endpoint" "HTTP/REST port"
        kubernetesAPI -> ovms "Health probes /v2/health/*" "HTTP/REST port"

        /* OVMS egress to external services */
        ovms -> s3 "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        ovms -> azure "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        ovms -> huggingface "Pulls and converts models" "HTTPS/443 TLS 1.2+"
        ovms -> openvinoRuntime "Executes inference" "In-process library call"

        /* Container-level relationships */
        grpcModule -> servableManager "Routes gRPC inference requests"
        httpModule -> servableManager "Routes REST inference requests"
        httpModule -> mediaPipe "Routes OpenAI /v3 requests"
        servableManager -> modelManager "Model lifecycle operations"
        modelManager -> dagScheduler "Pipeline orchestration"
        hfPullModule -> huggingface "Downloads models" "HTTPS/443"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #ff9800
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
