graph TB
    subgraph "llm-d-kv-cache Component"
        subgraph "Go Library (consumed by llm-d-inference-scheduler)"
            Indexer["kvcache.Indexer<br/>(Main Orchestrator)"]
            TokenProcessor["kvblock.TokenProcessor<br/>(FNV-64a / CBOR)"]
            Scorer["kvblock.Scorer<br/>(Prefix Matching + Device-Tier Scoring)"]
            TokenPool["tokenization.Pool<br/>(Sync/Async Workers)"]
            EventPool["kvevents.Pool<br/>(Sharded ZMQ Workers)"]
