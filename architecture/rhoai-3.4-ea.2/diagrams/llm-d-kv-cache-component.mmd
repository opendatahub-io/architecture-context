            SubManager["SubscriberManager"]
        end

        subgraph "Index Backends"
            IndexIface["kvblock.Index Interface"]
            InMemory["InMemory (LRU)"]
            CostAware["CostAwareMemory (Ristretto)"]
            RedisBackend["Redis / Valkey Backend"]
        end

        subgraph "Sidecar Container"
            UDSTokenizer["UDS Tokenizer Service<br/>(Python gRPC Server)<br/>Socket: /tmp/tokenizer/tokenizer-uds.socket"]
            HealthEndpoint["/health<br/>8082/TCP"]
        end

        subgraph "KV Connector Plugins"
            FSBackend["llmd_fs_backend<br/>(Python/C++/CUDA)"]
            PVCEvictor["pvc_evictor<br/>(Python Service)"]
        end
    end

    %% Internal relationships
    Indexer -->|coordinates| TokenPool
    Indexer -->|uses| TokenProcessor
    Indexer -->|delegates| Scorer
    Indexer -->|queries| IndexIface
    TokenPool -->|gRPC via UDS| UDSTokenizer
    EventPool -->|updates| IndexIface
    IndexIface --- InMemory
    IndexIface --- CostAware
    IndexIface --- RedisBackend
    PodReconciler -->|manages| SubManager
    SubManager -->|creates/removes| EventPool

    %% External interactions
    Scheduler["llm-d-inference-scheduler"] -->|Go library import| Indexer
    vLLMPods["vLLM Fleet"] -->|ZMQ PUB/SUB<br/>5557/TCP| EventPool
    PodReconciler -->|watches pods<br/>443/TCP HTTPS| K8sAPI["Kubernetes API"]
    RedisBackend -->|6379/TCP| RedisServer["Redis / Valkey Server"]
    UDSTokenizer -.->|443/TCP HTTPS| HFHub["HuggingFace Hub"]
    Prometheus["Prometheus"] -->|scrape 8080/TCP| Indexer

