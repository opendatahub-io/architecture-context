%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.2/kube-auth-proxy.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
        APIClient["API Client"]
        SAClient["Service Account Client"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (Auth/AuthZ Boundary)"]
        direction TB

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            KAP["kube-auth-proxy<br/>4180/TCP HTTP | 443/TCP HTTPS<br/>TLS 1.2+<br/>FIPS: strictfipsruntime<br/>AuthN: OIDC, OpenShift OAuth,<br/>Cookie, Bearer JWT, K8s SA Token"]
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            KRP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>FIPS: strictfipsruntime<br/>AuthN: Delegating, X.509, OIDC<br/>AuthZ: SubjectAccessReview"]
        end
    end

    subgraph AppPod["APPLICATION POD (Localhost)"]
        Upstream["Upstream Application<br/>configurable port<br/>HTTP/HTTPS/h2c"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>TokenReview + SubjectAccessReview"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Client Credentials"]
        Envoy["Envoy Gateway (ext_authz)<br/>4180/TCP HTTP<br/>plaintext"]
        Prometheus["Prometheus<br/>configurable port<br/>HTTP/HTTPS<br/>Metrics scraping"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Client Credentials"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Optional TLS<br/>Password Auth"]
    end

    %% Inbound flows
    User -->|"HTTP/4180 or HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Flow"| KAP
    SAClient -->|"HTTP/4180 or HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token"| KAP
    APIClient -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token or X.509 mTLS"| KRP
    Envoy -->|"HTTP/4180<br/>plaintext<br/>ext_authz check"| KAP

    %% Proxy to upstream
    KAP -->|"configurable port<br/>HTTP/HTTPS<br/>X-Forwarded-User<br/>X-Forwarded-Email"| Upstream
    KRP -->|"configurable port<br/>HTTP/HTTPS/h2c<br/>x-remote-user<br/>x-remote-groups"| Upstream

    %% Egress to cluster services
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    KRP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Credentials"| OSAuth

    %% Egress to external services
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Credentials"| OIDC
    KAP -.->|"TCP/6379<br/>Optional TLS<br/>Password"| Redis

    %% Prometheus scraping
    Prometheus -.->|"HTTP/HTTPS<br/>Metrics scrape"| KAP
    Prometheus -.->|"HTTP/HTTPS<br/>Metrics scrape"| KRP

