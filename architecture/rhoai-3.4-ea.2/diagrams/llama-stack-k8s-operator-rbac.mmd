%% RBAC Visualization: Llama Stack K8s Operator
%% Generated by: Claude Opus 4.6

graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance-name}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Leader["leader-election-rolebinding"]
    end

    subgraph RoleBindings["Per-Instance Role Bindings"]
        RB_Instance["{instance-name}-rb<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Leader["leader-election-role"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph ManagerResources["manager-role Resources"]
        R_LSD["llamastack.io<br/>llamastackdistributions<br/>llamastackdistributions/status<br/>llamastackdistributions/finalizers"]
        R_Core["core (v1)<br/>configmaps<br/>persistentvolumeclaims<br/>serviceaccounts<br/>services"]
        R_Apps["apps<br/>deployments"]
        R_Net["networking.k8s.io<br/>ingresses<br/>networkpolicies"]
        R_Auto["autoscaling<br/>horizontalpodautoscalers"]
        R_Policy["policy<br/>poddisruptionbudgets"]
        R_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>clusterroles<br/>rolebindings"]
        R_SCC["security.openshift.io<br/>securitycontextconstraints"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        R_Leases["coordination.k8s.io<br/>leases"]
        R_CM["core (v1)<br/>configmaps"]
        R_Events["core (v1)<br/>events"]
    end

    %% Manager SA bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_Manager -->|"bound via"| CRB_Leader
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Leader -->|"grants"| CR_Leader

    %% Instance SA bindings
    SA_Instance -->|"bound via"| RB_Instance
    RB_Instance -->|"grants"| CR_SCC

    %% Manager role permissions
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| R_LSD
    CR_Manager -->|"get,list,watch,create,<br/>update,patch"| R_Core
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| R_Apps
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| R_Net
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| R_Auto
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| R_Policy
    CR_Manager -->|"get,list,watch,delete"| R_RBAC
    CR_Manager -->|"use"| R_SCC

    %% Leader election permissions
    CR_Leader -->|"get,list,watch,create,<br/>update,patch,delete"| R_Leases
    CR_Leader -->|"get,list,watch,create,<br/>update,patch,delete"| R_CM
    CR_Leader -->|"create,patch"| R_Events

    style SA_Manager fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_Leader fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
