/*
 * C4 Context Diagram: Guardrails Detectors
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/guardrails-detectors.md
 */

workspace {
    model {
        orchestrator = person "FMS Guardrails Orchestrator" "Orchestrates guardrailing of LLM text generation by invoking detector microservices"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Collection of detector algorithm microservices for text content analysis (PII, safety, file-type, LLM-as-judge)" {
            builtInDetector = container "Built-in Detector" "Lightweight heuristic detectors: regex PII (email, CC, SSN, phone, IP, postcode), file-type validation (JSON, XML, YAML + schema), custom Python functions with AST sandboxing" "Python FastAPI :8080"
            huggingfaceDetector = container "HuggingFace Detector" "ML model-based content classification using AutoModelForSequenceClassification and GraniteForCausalLM with GPU/CUDA support" "Python FastAPI :8000"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-judge evaluation using vLLM Judge library for safety, toxicity, accuracy, helpfulness metrics" "Python FastAPI :8000"
            detectorBaseAPI = container "DetectorBaseAPI" "Shared FastAPI base class with health endpoint, detector registry, Prometheus instrumentation, error handling" "Python Framework"
            instrumentedDetector = container "InstrumentedDetector" "Prometheus instrumentation mixin tracking detections, requests, errors, and runtime" "Python Mixin"
        }

        vllmServer = softwareSystem "vLLM-compatible Inference Server" "External LLM server for content evaluation (OpenAI-compatible API)" "External"
        kserve = softwareSystem "KServe" "Serverless ML inference platform for deploying HuggingFace detector as InferenceService" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal"
        trustyai = softwareSystem "TrustyAI" "AI trustworthiness platform (project umbrella)" "Internal RHOAI"

        /* External Dependencies */
        fastapi = softwareSystem "FastAPI" "Python web framework" "External Library"
        pytorch = softwareSystem "PyTorch" "ML inference framework with multi-arch support" "External Library"
        hfTransformers = softwareSystem "HuggingFace Transformers" "Model loading and tokenization" "External Library"
        vllmJudge = softwareSystem "vLLM Judge Library" "LLM-as-a-judge evaluation framework" "External Library"

        /* Relationships */
        orchestrator -> guardrailsDetectors "Invokes detector /api/v1/text/contents endpoints" "HTTP"
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080"
        orchestrator -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents" "HTTP/8000"
        llmJudgeDetector -> vllmServer "Sends evaluation requests" "HTTP/HTTPS (configurable)"
        kserve -> huggingfaceDetector "Deploys as InferenceService"
        prometheus -> guardrailsDetectors "Scrapes /metrics endpoint" "HTTP"
        builtInDetector -> detectorBaseAPI "extends"
        huggingfaceDetector -> detectorBaseAPI "extends"
        llmJudgeDetector -> detectorBaseAPI "extends"
        builtInDetector -> instrumentedDetector "uses"
        huggingfaceDetector -> instrumentedDetector "uses"
        llmJudgeDetector -> instrumentedDetector "uses"
        huggingfaceDetector -> pytorch "ML inference"
        huggingfaceDetector -> hfTransformers "Model loading"
        llmJudgeDetector -> vllmJudge "LLM evaluation"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Library" {
                background #cccccc
                color #333333
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #fdcb6e
                color #333333
                shape person
            }
        }
    }
}
