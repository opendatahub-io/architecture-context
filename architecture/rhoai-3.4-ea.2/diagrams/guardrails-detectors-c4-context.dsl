/*
 * C4 Context Diagram: Guardrails Detectors
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/guardrails-detectors.md
 */
workspace {
    model {
        orchestratorUser = person "FMS Guardrails Orchestrator" "Orchestration service that routes content through detector pipeline for safety analysis"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Collection of detector microservices providing content safety analysis via regex/heuristic, ML model, and LLM-as-a-judge patterns" {
            builtInDetector = container "Built-in Detector" "Lightweight regex-based PII detection, file-type validation, and custom Python detector functions" "Python FastAPI/Uvicorn :8080"
            huggingfaceDetector = container "HuggingFace Detector" "Generic HuggingFace model-based text classification (SequenceClassification, GraniteForCausalLM) with optional GPU" "Python FastAPI/Uvicorn :8000"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-judge content evaluation via external vLLM server using built-in and custom metrics" "Python FastAPI/Uvicorn :8000"
            commonLibrary = container "Common Library" "Shared FastAPI base app, request/response schemas, instrumented detector base class, logging" "Python Library"
        }

        kserve = softwareSystem "KServe" "Kubernetes model serving platform - manages InferenceService/ServingRuntime lifecycle" "Internal ODH"
        istio = softwareSystem "Istio Service Mesh" "Service mesh providing mTLS encryption and PeerAuthentication" "Internal ODH"
        s3Storage = softwareSystem "S3-compatible Storage (MinIO)" "Object storage for ML model weights" "External"
        externalVllm = softwareSystem "External vLLM Server" "OpenAI-compatible LLM inference server for judge evaluation" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model repository for downloading pretrained models (dev/example only)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal ODH"

        # Relationships - Inbound
        orchestratorUser -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080 mTLS"
        orchestratorUser -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000 mTLS"
        orchestratorUser -> llmJudgeDetector "POST /api/v1/text/contents" "HTTP/8000 mTLS"

        # Internal relationships
        builtInDetector -> commonLibrary "Uses"
        huggingfaceDetector -> commonLibrary "Uses"
        llmJudgeDetector -> commonLibrary "Uses"

        # Deployment relationships
        kserve -> huggingfaceDetector "Deploys via InferenceService/ServingRuntime"
        kserve -> llmJudgeDetector "Deploys via InferenceService/ServingRuntime"
        istio -> guardrailsDetectors "Provides mTLS sidecar injection"

        # Egress relationships
        huggingfaceDetector -> s3Storage "Downloads model weights" "HTTP/9000 AWS credentials"
        llmJudgeDetector -> externalVllm "Sends evaluation requests" "HTTP/8080 OpenAI API"
        huggingfaceDetector -> huggingfaceHub "Downloads models (dev only)" "HTTPS/443"

        # Monitoring
        prometheus -> builtInDetector "Scrapes /metrics" "HTTP/8080"
        prometheus -> huggingfaceDetector "Scrapes /metrics" "HTTP/8000"
        prometheus -> llmJudgeDetector "Scrapes /metrics" "HTTP/8000"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
