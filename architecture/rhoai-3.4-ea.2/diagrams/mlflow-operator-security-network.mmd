%% MLflow Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User/Client"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE + backend TLS<br/>URL rewrite: /mlflow/* → /*"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph NS_Target["Namespace: {target-namespace}"]
            MLflowServer["MLflow Server<br/>SA: mlflow<br/>8443/TCP HTTPS (service-ca)<br/>Auth: kubernetes-auth<br/>(SelfSubjectAccessReview)"]
            NetworkPol["NetworkPolicy: mlflow<br/>Ingress: 8443/TCP any NS<br/>Egress: DNS, HTTPS, K8s API,<br/>PG, MySQL, MinIO, SeaweedFS"]
        end
    end

    subgraph OperatorLayer["OPERATOR LAYER"]
        Operator["MLflow Operator<br/>controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>Auth: Bearer Token (TokenReview)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>(ServiceMonitor)"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
        ServiceCA["OpenShift service-ca<br/>TLS cert provisioning"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>(MinIO/SeaweedFS/AWS S3)<br/>443, 9000, 8333/TCP<br/>TLS 1.2+<br/>AWS credentials"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (PGSSLMODE)<br/>Connection string creds"]
    end

    %% External to Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s)"| Gateway

    %% Gateway to MLflow
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Proxied headers"| MLflowServer

    %% MLflow to backends
    MLflowServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>SelfSubjectAccessReview"| K8sAPI
    MLflowServer -->|"HTTPS/443,9000,8333<br/>TLS 1.2+<br/>AWS AccessKey/SecretKey"| S3
    MLflowServer -->|"PostgreSQL/5432<br/>TLS (configurable)<br/>Connection creds"| PostgreSQL

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRs + SSA"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS (service-ca)<br/>No auth (ServiceMonitor)"| MLflowServer
    Prometheus -->|"HTTPS/8443<br/>Bearer Token<br/>(TokenReview + SAR)"| Operator

    %% CA/TLS
    ServiceCA -.->|provisions| MLflowServer
    CABundle -.->|mounted into| MLflowServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class MLflowServer,NetworkPol app
    class Operator operator
    class K8sAPI,Prometheus,CABundle,ServiceCA platform
    class S3,PostgreSQL externalservice
