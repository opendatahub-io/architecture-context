    %% External to K8s
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% K8s to Operator
    K8sAPI -->|"Watch/Informer<br/>In-cluster<br/>SA Token"| Operator

    %% Operator to K8s (resource creation)
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Creates: Deploy, Svc, CM, PVC, RBAC"| K8sAPI

    %% ML App to Feast Services
    MLApp -->|"HTTP/80 or HTTPS/443<br/>K8s RBAC / OIDC"| OnlineStore
    MLApp -->|"HTTP/80 or HTTPS/443<br/>K8s RBAC / OIDC"| OfflineStore
    MLApp -->|"gRPC/80 or gRPC+TLS/443"| RegistryGRPC
    MLApp -->|"HTTP/80 or HTTPS/443"| RegistryREST

    %% External access to UI via Route
    User -->|"HTTPS/443<br/>Edge/Reencrypt TLS"| Route
    Route -->|"HTTP/8888 or HTTPS/8443"| FeastUI

    %% Feast to External Services
    OnlineStore -->|"Varies<br/>User-configured"| DB
    OfflineStore -->|"Varies<br/>User-configured"| DB
    RegistryGRPC -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / GCP SA"| S3
    CronJob -->|"Pod exec<br/>SA Token"| OnlineStore

    %% Prometheus
    Prometheus -->|"HTTPS/8443<br/>TLS (self-signed)<br/>Bearer Token"| Operator

