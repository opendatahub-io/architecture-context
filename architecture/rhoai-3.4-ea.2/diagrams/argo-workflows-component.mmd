graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        direction TB
        Controller["Workflow Controller<br/>(Go, client-go informers)<br/>Metrics: 9090/TCP<br/>Health: 6060/TCP"]
        Executor["Argo Executor (argoexec)<br/>(Go Sidecar Binary)<br/>Emissary Pattern"]
        Server["Argo Server<br/>(Go API Server)<br/>gRPC + HTTP: 2746/TCP"]
        UI["Workflow UI<br/>(TypeScript/React)"]
        CRDCtrl["CRD Controller<br/>(CronWorkflow, TaskSet, GC)"]

        Server --> UI
        Controller --> CRDCtrl
    end

    %% Users
    DSP["DSP API Server"] -->|"creates"| WorkflowCR["Workflow CR<br/>(argoproj.io/v1alpha1)"]
    User["User / Client"] -->|"HTTPS/2746"| Server

    %% CRDs
    WorkflowCR -->|"watched by"| Controller
    CronWfCR["CronWorkflow CR"] -->|"watched by"| CRDCtrl
    WfTemplateCR["WorkflowTemplate CR"] -->|"referenced by"| Controller
    ClusterWfTemplateCR["ClusterWorkflowTemplate CR"] -->|"referenced by"| Controller
    WfTaskSetCR["WorkflowTaskSet CR"] -->|"managed by"| CRDCtrl
    WfArtifactGCCR["WorkflowArtifactGCTask CR"] -->|"managed by"| CRDCtrl

    %% Execution flow
    Controller -->|"creates pods"| WorkflowPod["Workflow Step Pod"]
    Executor -.->|"runs inside"| WorkflowPod

    %% External Dependencies
    Controller -->|"HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    Executor -->|"HTTPS/6443"| K8sAPI
    Server -->|"HTTPS/6443"| K8sAPI
    Executor -->|"HTTPS/443"| S3["S3-compatible<br/>Object Storage"]
    Server -->|"HTTPS/443"| S3
    Controller -->|"TCP/5432"| PostgreSQL["PostgreSQL<br/>(Optional Archive)"]
    Server -->|"TCP/5432"| PostgreSQL
    Server -->|"HTTPS/443"| OIDC["OIDC Provider<br/>(Optional SSO)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"HTTP/9090 scrape"| Controller

