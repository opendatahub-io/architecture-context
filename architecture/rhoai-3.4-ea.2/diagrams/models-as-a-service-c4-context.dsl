/*
 * Models as a Service - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/models-as-a-service.md
 */

workspace {
    model {
        user = person "API Consumer" "Developers and applications consuming LLM inference endpoints via API keys"
        admin = person "Platform Admin" "Configures models, auth policies, subscriptions, and API keys"

        maas = softwareSystem "Models as a Service (MaaS)" "Platform for providing LLM inference models as managed services with API key authentication, subscription-based access control, and token-based rate limiting" {
            maasApi = container "maas-api" "API key management, model discovery, subscription selection, tier lookup; Authorino callback target for API key validation" "Go HTTP Service (Gin)" "8443/TCP HTTPS"
            maasController = container "maas-controller" "Reconciles MaaSModelRef, MaaSAuthPolicy, MaaSSubscription CRDs; creates Kuadrant AuthPolicy and TokenRateLimitPolicy resources" "Go Operator (controller-runtime)"
            maasGateway = container "maas-default-gateway" "External ingress gateway; TLS termination; routes traffic to model and API HTTPRoutes" "Gateway API (openshift-default GatewayClass)" "443/TCP HTTPS"
        }

        openshift = softwareSystem "OpenShift" "Kubernetes platform with Gateway API support" "External"
        kuadrantAuthorino = softwareSystem "Kuadrant/Authorino" "Authentication and authorization enforcement via AuthPolicy and ext_authz" "External"
        kuadrantLimitador = softwareSystem "Kuadrant/Limitador" "Token-based rate limiting via TokenRateLimitPolicy" "External"
        gatewayApi = softwareSystem "Gateway API" "Ingress routing via Gateway and HTTPRoute resources" "External"
        kserve = softwareSystem "KServe" "LLMInferenceService CRD for model serving backends" "Internal ODH"
        postgresql = softwareSystem "PostgreSQL" "Persistent storage for API key management (hash-based keys)" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        # User interactions
        user -> maas "Sends inference requests and manages API keys" "HTTPS/443 Bearer sk-oai-*"
        admin -> maas "Creates MaaSModelRef, MaaSAuthPolicy, MaaSSubscription CRDs" "kubectl / HTTPS"

        # Internal MaaS flows
        maasGateway -> kuadrantAuthorino "ext_authz authentication check" "gRPC mTLS"
        kuadrantAuthorino -> maasApi "API key validation and subscription selection callbacks" "HTTPS/8443"
        kuadrantAuthorino -> kuadrantLimitador "Token rate limit check" "gRPC mTLS"
        maasApi -> postgresql "Store and validate API keys" "PostgreSQL/5432 TLS"

        # Controller interactions
        maasController -> kserve "Watches LLMInferenceService status" "HTTPS/443 ServiceAccount"
        maasController -> gatewayApi "Watches/validates HTTPRoutes, reads Gateways" "HTTPS/443 ServiceAccount"
        maasController -> kuadrantAuthorino "Creates Kuadrant AuthPolicy per model" "HTTPS/443 ServiceAccount"
        maasController -> kuadrantLimitador "Creates TokenRateLimitPolicy per model" "HTTPS/443 ServiceAccount"

        # External
        maas -> kserve "Routes inference traffic to model backends" "HTTP/HTTPS per-model"
        maas -> prometheus "Exposes metrics" "HTTP/8080"
        maas -> certManager "TLS certificate provisioning" "Kubernetes API"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
