%% Security Network Diagram: Model Metadata Collection
%% Generated by: Claude Opus 4.6

graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Pipeline)"]
        direction TB

        subgraph CI_NS["Namespace: CI/CD"]
            Tekton["Tekton PipelineRun<br/>Konflux / PipelinesAsCode"]
            Extractor["model-extractor CLI<br/>Go 1.24+"]
        end

        Tekton -->|executes| Extractor
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress - Build-Time Only)"]
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth (public)"]
        RedHatReg["registry.redhat.io<br/>OCI Registry API v2<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Registry Auth"]
        Quay["quay.io<br/>Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Konflux SA"]
    end

    subgraph Runtime["RUNTIME (Data Container - No Network)"]
        direction TB

        subgraph App_NS["Namespace: Application"]
            DataContainer["Data Container<br/>UBI9-minimal<br/>sleep infinity<br/>NO PORTS<br/>NO NETWORK"]
            DataVolume["/app/data<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>other-models-catalog.yaml"]
            Dashboard["RHOAI Dashboard Pod<br/>(Consumer)"]
        end

        DataContainer --- DataVolume
        Dashboard -->|"Volume mount<br/>(read-only)<br/>Filesystem only"| DataVolume
    end

    %% Build-time flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>30s timeout"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Credentials"| RedHatReg
    Tekton -->|"HTTPS/443<br/>TLS 1.2+<br/>Push multi-arch image"| Quay

    %% Build output becomes runtime container
    Quay -.->|"Image pull<br/>(deployment)"| DataContainer

    %% Styling
    classDef buildtime fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef nonetwork fill:#e8f5e9,stroke:#4caf50,stroke-width:3px,stroke-dasharray: 5 5
    classDef consumer fill:#dcedc8,stroke:#689f38,stroke-width:2px

    class Tekton,Extractor buildtime
    class HuggingFace,RedHatReg,Quay external
    class DataContainer nonetwork
    class DataVolume runtime
    class Dashboard consumer
