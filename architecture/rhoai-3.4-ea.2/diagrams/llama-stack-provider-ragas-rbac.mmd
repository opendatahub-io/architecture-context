%% RBAC Visualization - llama-stack-provider-ragas
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Runtime Identity"
        SA[Llama Stack Server<br/>ServiceAccount]
        KFPPodSA[KFP Pipeline Pod<br/>ServiceAccount]
    end

    subgraph "Required Permissions"
        direction TB

        subgraph "Base Image Resolution"
            ConfigMapPerm["core API Group<br/>configmaps<br/>Verbs: get"]
        end

        subgraph "KFP Pipeline Operations"
            KFPPerm["KFP REST API<br/>pipelines, runs<br/>Verbs: create, get"]
        end
    end

    subgraph "Target Resources"
        direction TB

        CM_TrustyAI["ConfigMap<br/>trustyai-service-operator-config<br/>NS: redhat-ods-applications / opendatahub"]
        CM_Ragas["ConfigMap<br/>kubeflow-ragas-config<br/>NS: user namespace"]
        KFPRuns["KFP Runs<br/>Pipeline Executions"]
    end

    subgraph "Secrets Access"
        direction TB

        AWSCreds["aws-credentials (Opaque)<br/>Keys: ACCESS_KEY_ID,<br/>SECRET_ACCESS_KEY, DEFAULT_REGION<br/>Purpose: S3 results storage"]
        KFPToken["kubeflow-pipelines-token (Opaque)<br/>Purpose: KFP API Bearer token"]
        InferenceSecret["llama-stack-inference-model-secret (Opaque)<br/>Keys: VLLM_URL, VLLM_API_TOKEN,<br/>VLLM_TLS_VERIFY, INFERENCE_MODEL"]
        S3KFPCreds["S3 credentials for KFP (Opaque)<br/>Mounted via kubernetes.use_secret_as_env<br/>Purpose: AWS creds in KFP pods"]
    end

    %% Permission flows
    SA -->|"reads"| ConfigMapPerm
    SA -->|"uses"| KFPPerm
    ConfigMapPerm -->|"get"| CM_TrustyAI
    ConfigMapPerm -->|"get"| CM_Ragas
    KFPPerm -->|"create, get"| KFPRuns

    %% Secret access
    SA -->|"mounts"| KFPToken
    SA -->|"mounts"| InferenceSecret
    SA -->|"reads"| AWSCreds
    KFPPodSA -->|"env vars"| S3KFPCreds

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style KFPPodSA fill:#4a90e2,color:#fff
    style ConfigMapPerm fill:#f5a623,color:#fff
    style KFPPerm fill:#f5a623,color:#fff
    style CM_TrustyAI fill:#7ed321,color:#fff
    style CM_Ragas fill:#7ed321,color:#fff
    style KFPRuns fill:#7ed321,color:#fff
    style AWSCreds fill:#f8cecc,stroke:#b85450
    style KFPToken fill:#f8cecc,stroke:#b85450
    style InferenceSecret fill:#f8cecc,stroke:#b85450
    style S3KFPCreds fill:#f8cecc,stroke:#b85450
