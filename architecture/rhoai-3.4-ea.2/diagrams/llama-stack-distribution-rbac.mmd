graph TD
    subgraph PlatformAuth["Platform Authentication (RHOAI 3.x)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar at ingress)"]
        GatewayAPI["Gateway API<br/>(HTTPRoute)"]
    end

    subgraph Container["Llama Stack Container"]
        direction TB
        Server["Llama Stack Server<br/>Port 8321/TCP HTTP<br/>No built-in auth<br/>Non-root user (UBI9)"]
    end

    subgraph Secrets["Environment Variable Secrets"]
        direction TB
        subgraph InferenceSecrets["Inference Provider Secrets"]
            VLLM_TOKEN["VLLM_API_TOKEN<br/>vLLM inference auth"]
            AWS_BEDROCK["AWS_BEARER_TOKEN_BEDROCK<br/>AWS Bedrock access"]
            AZURE_KEY["AZURE_API_KEY<br/>Azure OpenAI access"]
            WATSONX_KEY["WATSONX_API_KEY<br/>IBM WatsonX access"]
            OPENAI_KEY["OPENAI_API_KEY<br/>OpenAI API access"]
        end

        subgraph StorageSecrets["Storage Secrets"]
            PG_PASS["POSTGRES_PASSWORD<br/>PostgreSQL auth"]
            AWS_KEYS["AWS_ACCESS_KEY_ID /<br/>AWS_SECRET_ACCESS_KEY<br/>S3 storage access"]
        end

        subgraph VectorDBSecrets["Vector DB Secrets"]
            QDRANT_KEY["QDRANT_API_KEY<br/>Qdrant access"]
            MILVUS_TOK["MILVUS_TOKEN<br/>Milvus access"]
        end

        subgraph ToolSecrets["Tool Secrets"]
            BRAVE_KEY["BRAVE_SEARCH_API_KEY<br/>Brave Search access"]
            TAVILY_KEY["TAVILY_SEARCH_API_KEY<br/>Tavily Search access"]
        end

        subgraph PipelineSecrets["Pipeline Secrets"]
            KFP_TOKEN["KUBEFLOW_PIPELINES_TOKEN<br/>Kubeflow Pipelines access"]
        end
    end

    subgraph BuildSecrets["Build-Time Secrets (Konflux)"]
        BOT_PAT["rhel-ai-private-index-auth/BOT_PAT<br/>GitLab PAT for wheel releases"]
        GIT_AUTH["git_auth_secret<br/>Git auth for Konflux builds"]
    end

    subgraph AuthFlow["Authentication Flow"]
        ExternalClient["External Client<br/>HTTPS/443"]
    end

    %% Auth flow
    ExternalClient -->|"1. HTTPS request<br/>TLS 1.2+"| GatewayAPI
    GatewayAPI -->|"2. Token validation"| KubeRBACProxy
    KubeRBACProxy -->|"3. Authenticated<br/>HTTP/8321 plaintext"| Server

    %% Secrets usage
    Server -->|"reads at runtime"| InferenceSecrets
    Server -->|"reads at runtime"| StorageSecrets
    Server -->|"reads at runtime"| VectorDBSecrets
    Server -->|"reads at runtime"| ToolSecrets
    Server -->|"reads at runtime"| PipelineSecrets

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style ExternalClient fill:#f9f9f9,stroke:#999

    style VLLM_TOKEN fill:#fff2cc,stroke:#d6b656
    style AWS_BEDROCK fill:#fff2cc,stroke:#d6b656
    style AZURE_KEY fill:#fff2cc,stroke:#d6b656
    style WATSONX_KEY fill:#fff2cc,stroke:#d6b656
    style OPENAI_KEY fill:#fff2cc,stroke:#d6b656
    style PG_PASS fill:#fff2cc,stroke:#d6b656
    style AWS_KEYS fill:#fff2cc,stroke:#d6b656
    style QDRANT_KEY fill:#fff2cc,stroke:#d6b656
    style MILVUS_TOK fill:#fff2cc,stroke:#d6b656
    style BRAVE_KEY fill:#fff2cc,stroke:#d6b656
    style TAVILY_KEY fill:#fff2cc,stroke:#d6b656
    style KFP_TOKEN fill:#fff2cc,stroke:#d6b656
    style BOT_PAT fill:#f8cecc,stroke:#b85450
    style GIT_AUTH fill:#f8cecc,stroke:#b85450
