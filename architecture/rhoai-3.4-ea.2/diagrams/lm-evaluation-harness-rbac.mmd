%% LM Evaluation Harness - RBAC Visualization
%% Generated by: Claude Opus 4.6
%% Note: This component defines NO RBAC resources itself.
%% RBAC is managed by the LMES Operator / TrustyAI that creates the Job.
%% This diagram shows the authentication and authorization model.

graph TD
    subgraph "Job Creator (LMES Operator / TrustyAI)"
        OperatorSA["Operator ServiceAccount<br/>(manages RBAC for jobs)"]
    end

    subgraph "LMES Job Container - Authentication Model"
        direction TB
        Container["LMES Job Container<br/>User: 65532:65532 (non-root)<br/>FIPS Compliant"]
    end

    subgraph "Mounted Credentials"
        ModelCreds["Model Credentials<br/>Type: Opaque<br/>Contains: API Key / Auth Headers<br/>Provisioned by: EvalHub/Operator"]
        RegistryAuth["OCI Registry Auth<br/>Type: dockerconfigjson<br/>Contains: Docker auth config<br/>Provisioned by: Operator/User"]
        CACerts["CA Certificate Bundle<br/>Type: Opaque<br/>Contains: Custom CA certs<br/>Provisioned by: Operator/User"]
    end

    subgraph "Authentication Endpoints"
        ModelAuth["Model Inference API<br/>Method: POST<br/>Auth: Bearer Token<br/>(OPENAI_API_KEY env var)"]
        EvalHubAuth["EvalHub Callback API<br/>Method: POST<br/>Auth: Bearer Token<br/>(auth_token_path file)"]
        RegistryEndpoint["OCI Registry<br/>Method: Push<br/>Auth: Docker auth config<br/>(/tmp/.docker/config.json)"]
        HFAuth["HuggingFace Hub<br/>Method: GET<br/>Auth: HF_TOKEN<br/>(optional)"]
    end

    OperatorSA -->|"creates Job +<br/>mounts secrets"| Container

    ModelCreds -->|"env: OPENAI_API_KEY"| Container
    RegistryAuth -->|"mount: /tmp/.docker/"| Container
    CACerts -->|"mount: CA path"| Container

    Container -->|"Bearer Token"| ModelAuth
    Container -->|"Bearer Token"| EvalHubAuth
    Container -->|"Docker Auth"| RegistryEndpoint
    Container -.->|"HF_TOKEN (optional)"| HFAuth

