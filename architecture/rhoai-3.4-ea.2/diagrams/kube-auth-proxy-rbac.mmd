%% RBAC Visualization: kube-auth-proxy
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.2/kube-auth-proxy.md

graph TD
    subgraph "Service Accounts"
        SA["(Parent Component SA)<br/>e.g., notebook-controller-sa"]
    end

    subgraph "Proxy Modes"
        KAP["kube-auth-proxy<br/>(Auth Mode - port 4180)"]
        KRBAC["kube-rbac-proxy<br/>(RBAC Mode - port 8443)"]
    end

    subgraph "Required API Permissions"
        TR["authentication.k8s.io<br/>tokenreviews"]
        Users["user.openshift.io<br/>users"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "Authentication Mechanisms"
        OIDC["OIDC ID Token<br/>External OIDC Provider"]
        OSAuth["OpenShift OAuth Token<br/>OpenShift OAuth Server"]
        SATok["K8s ServiceAccount Token<br/>TokenReview Validation"]
        Cookie["Cookie Session<br/>Cookie/Redis Store"]
        Bearer["Bearer Token<br/>ServiceAccount"]
    end

    subgraph "Authorization Policies"
        EmailDomain["Email Domain<br/>Validation"]
        AllowedGroups["Allowed Groups<br/>Check"]
        K8sRBAC["Kubernetes RBAC<br/>SubjectAccessReview"]
    end

    subgraph "Secrets"
        OAuthSecret["OAuth Client Secret<br/>(Opaque)<br/>Admin / External IDP"]
        CookieSecret["Cookie Secret<br/>(Opaque)<br/>Session encryption"]
        TLSCert["TLS Cert/Key<br/>(kubernetes.io/tls)<br/>cert-manager / Admin"]
        SATokSecret["ServiceAccount Token<br/>(auto-mounted)<br/>Auto-rotate: Yes"]
        CACert["CA Certificates<br/>(Opaque)<br/>OAuth/OIDC verification"]
        JWTKey["JWT Signing Key<br/>(Opaque)<br/>/etc/ssl/private/"]
    end

    %% SA uses proxy modes
    SA -->|"runs as"| KAP
    SA -->|"runs as"| KRBAC

    %% Permissions needed
    KAP -->|"create"| TR
    KAP -->|"get"| Users
    KRBAC -->|"create"| SAR
    KRBAC -->|"create"| TR

    %% Auth mechanisms per mode
    KAP --- OIDC
    KAP --- OSAuth
    KAP --- SATok
    KAP --- Cookie
    KRBAC --- Bearer

    %% Authorization policies
    KAP -->|"enforces"| EmailDomain
    KAP -->|"enforces"| AllowedGroups
    KRBAC -->|"enforces"| K8sRBAC

    %% Secret usage
    KAP -->|"uses"| OAuthSecret
    KAP -->|"uses"| CookieSecret
    KRBAC -->|"uses"| TLSCert
    KAP -->|"uses"| SATokSecret
    KAP -->|"uses"| CACert
    KAP -->|"uses"| JWTKey

