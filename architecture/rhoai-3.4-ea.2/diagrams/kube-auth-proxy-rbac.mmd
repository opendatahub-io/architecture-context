    BearerToken -->|"validates via"| AllAuth
    BearerToken -->|"validates via"| AllRBAC
    CookieAuth -->|"validates via"| AllAuth
    OIDCAuth -->|"validates via"| AllRBAC
    X509 -->|"validates via"| AllRBAC
    OAuthFlow -->|"initiates"| AllAuth
    CookieAuth -->|"validates via"| ExtAuthz
    BearerToken -->|"validates via"| ExtAuthz

