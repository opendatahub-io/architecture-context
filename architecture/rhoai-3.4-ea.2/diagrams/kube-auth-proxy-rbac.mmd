        CookieAuth["Session Cookie<br/>(OIDC/OAuth signed)"]
        OAuthFlow["OpenShift OAuth<br/>Authorization Code"]
    end

    subgraph Endpoints["Endpoint Security"]
        direction TB
        AllAuth["/* (auth mode)<br/>AuthN: OIDC/OAuth/Cookie/Bearer/SA Token"]
        AllRBAC["/* (rbac mode)<br/>AuthN: Bearer/X.509/OIDC<br/>AuthZ: SubjectAccessReview"]
        ExtAuthz["/oauth2/auth (auth mode)<br/>ext_authz compatible<br/>Returns: 200/401"]
