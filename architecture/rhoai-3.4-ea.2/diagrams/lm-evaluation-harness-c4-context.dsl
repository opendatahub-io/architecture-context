/*
 * C4 Context Diagram: LM Evaluation Harness (LMES Job)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Defines evaluation jobs via LMEvalJob CRDs"

        lmesJob = softwareSystem "LM Evaluation Harness (LMES Job)" "Batch-oriented container for executing language model evaluations using EleutherAI lm-evaluation-harness" {
            adapter = container "LMEvalAdapter" "EvalHub framework adapter - orchestrates evaluation lifecycle, job spec parsing, and result reporting" "Python (main.py)"
            lmEvalEngine = container "lm_eval Engine" "Core evaluation engine - manages tasks, models, metrics, and evaluation logic" "Python Library"
            evalHubSDK = container "eval-hub-sdk" "Integration with EvalHub platform - callbacks, OCI artifact management, MLflow" "Python SDK"
            localCompletions = container "local-completions" "OpenAI-compatible API client for model inference endpoints" "Python Module"
            ociPublisher = container "OCI Artifact Publisher" "Packages evaluation results as OCI artifacts and pushes via skopeo" "Python Script (oci.py)"
        }

        trustyaiOperator = softwareSystem "TrustyAI / LMEval Operator" "Creates and manages Kubernetes Jobs from LMEvalJob CRDs" "Internal RHOAI"
        evalHub = softwareSystem "EvalHub Service" "Receives status updates, evaluation results, and completion notifications" "Internal RHOAI"
        mlflow = softwareSystem "MLflow" "Experiment tracking - logs metrics, parameters, and artifacts" "Internal RHOAI"
        modelEndpoint = softwareSystem "Model Inference Endpoint" "Target model being evaluated (vLLM, TGI) via OpenAI-compatible API" "External"
        ociRegistry = softwareSystem "OCI Registry" "Stores evaluation result artifacts" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Downloads tokenizers and benchmark datasets" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Model artifacts and dataset storage" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Job creation and lifecycle management" "Infrastructure"

        # Relationships
        dataScientist -> trustyaiOperator "Creates LMEvalJob CR via kubectl"
        trustyaiOperator -> k8sAPI "Creates Kubernetes Job" "HTTPS/6443, TLS 1.3"
        k8sAPI -> lmesJob "Schedules Job pod with ConfigMap"

        lmesJob -> modelEndpoint "Sends evaluation prompts, receives completions" "HTTP(S), TLS 1.2+, Bearer Token"
        lmesJob -> evalHub "Reports status and results" "HTTP(S), TLS 1.2+, Bearer Token"
        lmesJob -> ociRegistry "Pushes evaluation result artifacts" "HTTPS/443, TLS 1.2+, Registry Auth"
        lmesJob -> hfHub "Downloads tokenizers and datasets" "HTTPS/443, TLS 1.2+"
        lmesJob -> mlflow "Logs metrics and parameters" "HTTP(S), TLS 1.2+"
        lmesJob -> s3Storage "Downloads model artifacts or datasets" "HTTPS/443, TLS 1.2+, AWS IAM"

        # Internal container relationships
        adapter -> lmEvalEngine "Orchestrates evaluation"
        adapter -> evalHubSDK "Uses for platform integration"
        lmEvalEngine -> localCompletions "Sends prompts to model"
        evalHubSDK -> ociPublisher "Packages and pushes artifacts"
    }

    views {
        systemContext lmesJob "SystemContext" {
            include *
            autoLayout
        }

        container lmesJob "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Software System" {
                background #1168BD
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #6c757d
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
