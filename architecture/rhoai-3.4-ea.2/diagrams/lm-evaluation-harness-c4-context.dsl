/*
 * LM Evaluation Harness - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Triggers model evaluation jobs via EvalHub"
        operator = person "Platform Operator" "Manages LMES Operator and infrastructure"

        lmesJob = softwareSystem "LM Evaluation Harness (LMES Job)" "Batch container for executing language model evaluation benchmarks" {
            lmEvalAdapter = container "LMEvalAdapter (main.py)" "EvalHub FrameworkAdapter - orchestrates benchmark execution, status reporting, and result persistence" "Python 3.11"
            lmEvalCore = container "lm_eval Core Framework" "Evaluation engine with model backends, task definitions, metrics, and evaluator logic" "Python Library"
            localCompletions = container "local-completions Backend" "OpenAI-compatible API client for model inference" "Python Model Backend"
            ociPublisher = container "OCI Artifact Publisher" "Creates and pushes OCI artifacts with evaluation results via skopeo" "Python Script"
            offlineMetrics = container "Offline Metrics" "54 self-contained metric implementations for disconnected evaluation" "Python Modules"
            evalTasks = container "Evaluation Tasks" "155+ task categories (ARC, BBH, MMLU, etc.)" "YAML + Python"
        }

        evalHub = softwareSystem "EvalHub Service" "Job orchestration, status tracking, and result aggregation" "Internal ODH"
        lmesOperator = softwareSystem "LMES Operator (TrustyAI)" "Creates Kubernetes Jobs with ConfigMaps and Secrets" "Internal ODH"
        modelEndpoint = softwareSystem "Model Inference Endpoint" "Language model serving with OpenAI-compatible API" "Internal/External"
        ociRegistry = softwareSystem "OCI Registry" "Container registry for storing evaluation result artifacts" "External"
        huggingFaceHub = softwareSystem "HuggingFace Hub" "Model tokenizers, datasets, and configs" "External"
        mlflow = softwareSystem "MLflow Tracking Server" "Experiment tracking and metric logging" "External"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster orchestration and workload management" "Platform"

        /* Relationships */
        dataScientist -> evalHub "Submits evaluation jobs"
        evalHub -> lmesOperator "Triggers job creation"
        lmesOperator -> kubernetesAPI "Creates Job + ConfigMap" "HTTPS/443"
        kubernetesAPI -> lmesJob "Schedules and runs batch job"

        lmEvalAdapter -> lmEvalCore "Orchestrates evaluation"
        lmEvalCore -> localCompletions "Uses for model inference"
        lmEvalCore -> evalTasks "Loads benchmark tasks"
        lmEvalCore -> offlineMetrics "Computes evaluation metrics"
        lmEvalAdapter -> ociPublisher "Publishes result artifacts"

        lmesJob -> modelEndpoint "Sends evaluation prompts" "HTTPS/Variable, Bearer Token"
        lmesJob -> evalHub "Reports job status and results" "HTTPS/Variable, Bearer Token"
        lmesJob -> ociRegistry "Pushes result OCI artifacts" "HTTPS/443, Docker auth"
        lmesJob -> huggingFaceHub "Downloads tokenizers and datasets" "HTTPS/443, HF_TOKEN"
        lmesJob -> mlflow "Logs metrics and parameters" "HTTPS/Variable, Token auth"
    }

    views {
        systemContext lmesJob "SystemContext" {
            include *
            autoLayout
        }

        container lmesJob "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
