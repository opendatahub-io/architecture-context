// Training Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/training-operator.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or pipelines"

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Kubernetes-native operator for managing distributed training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, and JAX" {
            controller = container "Training Operator Controller" "Reconciles 6 training job CRDs; manages Pod, Service, NetworkPolicy, HPA lifecycle" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates CREATE/UPDATE on all training job CRDs" "Go HTTPS Server (port 9443)"
            certController = container "Cert Controller" "Self-manages TLS certificates for webhook server" "open-policy-agent/cert-controller"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"
        prometheus = softwareSystem "OpenShift Monitoring (Prometheus)" "Metrics collection and alerting" "Internal RHOAI"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages RHOAI components" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for batch workloads (optional)" "External"
        schedulerPlugins = softwareSystem "Scheduler Plugins" "Kubernetes scheduler plugins for gang scheduling (optional)" "External"
        kueue = softwareSystem "Kueue" "Multi-cluster job scheduling (optional)" "External"

        // Relationships
        user -> trainingOperator "Submits training jobs (PyTorchJob, TFJob, etc.) via kubectl/API"
        rhodsOperator -> trainingOperator "Deploys via kustomize overlay"

        trainingOperator -> k8sAPI "CRUD on Pods, Services, NetworkPolicies, HPAs, CRDs" "HTTPS/443 TLS 1.2+"
        k8sAPI -> trainingOperator "Webhook validation calls" "HTTPS/443->9443 TLS (self-signed)"
        prometheus -> trainingOperator "Scrapes metrics via PodMonitor" "HTTP/8080 plaintext"

        trainingOperator -> volcano "Creates PodGroup CRs for gang scheduling" "Kubernetes CRD"
        trainingOperator -> schedulerPlugins "Creates PodGroup CRs for gang scheduling" "Kubernetes CRD"
        trainingOperator -> kueue "Delegates job scheduling via ManagedBy field" "Kubernetes CRD"

        // Internal container relationships
        controller -> webhookServer "Webhook validation"
        certController -> webhookServer "Provides TLS certificates"
        controller -> k8sAPI "Watches CRDs, creates Pods/Services" "HTTPS/443"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
