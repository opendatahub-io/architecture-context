/*
 * C4 Context Diagram: llm-d Inference Scheduler
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/llm-d-inference-scheduler.md
 */

workspace {
    model {
        user = person "ML Engineer / Client" "Sends inference requests to LLM models"

        llmdScheduler = softwareSystem "llm-d Inference Scheduler" "Optimized routing and scheduling for LLM inference workloads via Gateway API Inference Extension EPP" {
            epp = container "EPP (Endpoint Picker)" "Receives ext-proc callbacks from Envoy, runs scheduling plugins (filters, scorers), returns routing decisions" "Go gRPC Service"
            pdSidecar = container "P/D Routing Sidecar" "HTTP reverse proxy alongside decode workers, orchestrates prefill/decode disaggregation" "Go HTTP Reverse Proxy"
            pluginFramework = container "Plugin Framework" "Registers and manages pluggable filters, scorers, profile handlers for request scheduling" "Go Library"
            udsTokenizer = container "UDS Tokenizer Sidecar" "Handles tokenization via gRPC over Unix Domain Socket for prefix cache scoring" "Container Sidecar"
            ssrfValidator = container "SSRF AllowlistValidator" "Watches InferencePool and Pod resources to build allowlist of valid prefill targets" "Go Controller"
        }

        envoyGateway = softwareSystem "Envoy Gateway" "Data plane proxy with ext-proc filter for routing decisions" "External"
        gatewayAPICRDs = softwareSystem "Gateway API CRDs" "Gateway, HTTPRoute resources for traffic routing (v1.3.0)" "External"
        gieCRDs = softwareSystem "Gateway API Inference Extension CRDs" "InferencePool, InferenceModel resources (v1.3.0)" "External"
        vllm = softwareSystem "vLLM Model Servers" "Model serving engine (prefill and decode workers)" "External"
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform (v1.25.0+)" "External"
        zmq = softwareSystem "ZeroMQ (KV-Cache Events)" "Real-time KV-cache state tracking via ZMQ PUB/SUB" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        huggingface = softwareSystem "HuggingFace" "Tokenizer model downloads" "External"

        # User interactions
        user -> llmdScheduler "Sends inference requests via HTTP"

        # Core integrations
        envoyGateway -> epp "ext-proc gRPC callback for routing decisions" "gRPC/9002 plaintext"
        epp -> envoyGateway "Returns pod routing decision" "gRPC/9002 plaintext"
        envoyGateway -> pdSidecar "Forwards P/D inference requests" "HTTP(S)/8000 TLS 1.2+"
        envoyGateway -> vllm "Forwards non-P/D inference requests" "HTTP/8000"
        pdSidecar -> vllm "Proxies prefill and decode requests" "HTTP(S)/8001 TLS 1.2+"

        # EPP dependencies
        epp -> pluginFramework "Runs scheduling pipeline"
        epp -> udsTokenizer "Tokenization for prefix cache scoring" "gRPC over UDS"
        zmq -> epp "KV-cache event subscription" "ZMQ SUB/5556 plaintext"
        epp -> kubernetes "Watches InferencePool, Pod resources" "HTTPS/443"

        # P/D Sidecar dependencies
        pdSidecar -> ssrfValidator "Validates prefill targets"
        ssrfValidator -> kubernetes "Watches InferencePool + Pod allowlist" "HTTPS/443"

        # Monitoring
        prometheus -> epp "Scrapes metrics" "HTTP/9090"

        # CRD dependencies
        llmdScheduler -> gatewayAPICRDs "Consumes Gateway, HTTPRoute CRDs"
        llmdScheduler -> gieCRDs "Consumes InferencePool, InferenceModel CRDs"

        # External
        udsTokenizer -> huggingface "Downloads tokenizer models" "HTTPS/443"
    }

    views {
        systemContext llmdScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmdScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
