/*
 * C4 Context Diagram: llm-d-inference-scheduler
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/llm-d-inference-scheduler.md
 */

workspace {
    model {
        user = person "ML Engineer / Client" "Sends inference requests to LLM models"

        llmdScheduler = softwareSystem "llm-d Inference Scheduler" "Optimized inference request scheduler for LLM workloads via Gateway API and Envoy ext-proc" {
            epp = container "EPP (Endpoint Picker)" "gRPC ext-proc server that selects optimal model-serving pods using pluggable filter/scorer pipeline" "Go Service, gRPC"
            pdSidecar = container "PD Routing Sidecar" "HTTP reverse proxy for disaggregated prefill/decode orchestration with SSRF protection" "Go Service, HTTPS"
            udsTokenizer = container "UDS Tokenizer Sidecar" "Provides tokenization over Unix Domain Socket for precise prefix cache scoring" "Sidecar Container"
            filterPlugins = container "Filter Plugins" "Exclude candidate pods (decode-filter, prefill-filter, by-label)" "Go Plugin Framework"
            scorerPlugins = container "Scorer Plugins" "Score candidate pods (prefix-cache, load-aware, session-affinity)" "Go Plugin Framework"
        }

        envoyGateway = softwareSystem "Envoy Gateway" "Data plane proxy with ext-proc support for inference routing" "External"
        gatewayAPI = softwareSystem "Gateway API (GIE)" "Kubernetes Gateway API Inference Extension - InferencePool CRDs" "External"
        vllm = softwareSystem "vLLM Model Servers" "Model serving engine for LLM inference (prefill and decode workers)" "External"
        kvCache = softwareSystem "llm-d KV Cache" "KV cache indexing for precise prefix cache scoring via ZMQ events" "Internal"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for watching InferencePool and Pod resources" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Tokenizer model download for prefix cache matching" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        istio = softwareSystem "Istio Service Mesh" "Traffic management and TLS termination in production" "External"

        user -> envoyGateway "Sends inference requests" "HTTP/HTTPS 80-443/TCP"
        envoyGateway -> epp "ext-proc callback for endpoint selection" "gRPC 9002/TCP plaintext"
        epp -> envoyGateway "Returns selected endpoint" "gRPC 9002/TCP"
        envoyGateway -> pdSidecar "Routes to decode worker" "HTTPS 8000/TCP TLS 1.2+"
        pdSidecar -> vllm "Proxies prefill/decode requests" "HTTP/HTTPS 8000-8001/TCP"
        epp -> k8sAPI "Watches InferencePool and Pod resources" "HTTPS 443/TCP"
        epp -> huggingface "Downloads tokenizer configs" "HTTPS 443/TCP"
        epp -> udsTokenizer "Tokenization requests" "gRPC over UDS"
        epp -> filterPlugins "Applies filters"
        epp -> scorerPlugins "Applies scorers"
        vllm -> epp "KV cache events" "ZMQ PUB/SUB 5556/TCP"
        prometheus -> epp "Scrapes metrics" "HTTP 9090/TCP"
        epp -> gatewayAPI "Reads InferencePool CRDs" "via Kubernetes API"
        istio -> envoyGateway "Manages traffic routing" "Control plane"
    }

    views {
        systemContext llmdScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmdScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
