// C4 Context Diagram: llama-stack-provider-trustyai-garak
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "AI Engineer / Red Teamer" "Submits LLM vulnerability scans and reviews security assessment results"

        garakProvider = softwareSystem "Llama Stack Provider: TrustyAI Garak" "Out-of-tree Llama Stack evaluation provider for automated LLM red-teaming using NVIDIA Garak" {
            inlineAdapter = container "GarakInlineEvalAdapter" "Runs Garak scans locally as subprocess with concurrent job semaphore" "Python Provider Plugin"
            remoteAdapter = container "GarakRemoteEvalAdapter" "Submits Garak scans as KFP pipeline runs, polls status, retrieves results" "Python Provider Plugin"
            baseEval = container "GarakEvalBase" "Shared evaluation logic: benchmark registration, command building, shield orchestration, result parsing" "Python Base Class"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Orchestrates input/output shield scans around LLM inference" "Python Module"
            evalHubAdapter = container "GarakAdapter (eval-hub)" "Eval-hub framework integration adapter" "Python Adapter"
            kfpPipeline = container "evalhub KFP Pipeline" "Six-step pipeline: validate, resolve_taxonomy, sdg_generate, prepare_prompts, garak_scan, write_kfp_outputs" "Kubeflow Pipeline"
            s3Utils = container "S3 Utilities" "Shared boto3 S3 client factory for Data Connection credential injection" "Python Module"
            resultUtils = container "Result Utilities" "Report parsing, AVID conversion, TBSA calculation, ART report generation" "Python Module"
        }

        llamaStack = softwareSystem "Llama Stack Distribution" "Hosts the Llama Stack server that loads this provider" "Internal ODH"
        kfp = softwareSystem "Data Science Pipelines (DSPA)" "Kubeflow Pipelines for executing Garak scan workflows" "Internal ODH"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages provider image configuration" "Internal ODH"
        evalHub = softwareSystem "Eval Hub" "Evaluation framework for LLM assessment" "Internal ODH"

        vllm = softwareSystem "vLLM / Inference Server" "Target LLM model being scanned for vulnerabilities" "External"
        s3 = softwareSystem "S3 Storage (MinIO / AWS)" "Scan artifact storage for reports and results" "External"
        postgresql = softwareSystem "PostgreSQL 15" "Llama Stack persistent metadata storage" "External"
        safetyShields = softwareSystem "Safety Shields (Llama Guard, Prompt Guard)" "Input/output guardrail testing via Llama Stack Safety API" "Internal ODH"

        // Relationships
        user -> llamaStack "Submits eval jobs via REST API" "HTTP/8321"
        llamaStack -> garakProvider "Loads and invokes evaluation provider" "Plugin API"

        remoteAdapter -> kfp "Submits/polls/cancels KFP pipeline runs" "HTTPS/443, Bearer Token"
        inlineAdapter -> vllm "Scans target LLM model" "HTTP(S)/varies, API Key"
        kfpPipeline -> vllm "Runs vulnerability probes against model" "HTTP(S)/varies, API Key"
        kfpPipeline -> s3 "Uploads scan artifacts and reports" "HTTPS/443, AWS IAM"
        remoteAdapter -> s3 "Downloads scan results" "HTTPS/443, AWS IAM"
        llamaStack -> postgresql "Stores metadata" "PostgreSQL/5432, Password"
        shieldOrchestrator -> safetyShields "Tests input/output guardrails" "HTTP/8321"
        evalHubAdapter -> kfpPipeline "Delegates execution to KFP" "In-process"

        trustyaiOperator -> garakProvider "Configures provider image via ConfigMap" "ConfigMap"

        // Base class relationships
        baseEval -> inlineAdapter "Shared logic" "Inheritance"
        baseEval -> remoteAdapter "Shared logic" "Inheritance"
        baseEval -> shieldOrchestrator "Orchestrates shield tests" "In-process"
        baseEval -> resultUtils "Generates reports" "In-process"
        remoteAdapter -> s3Utils "Creates S3 clients" "In-process"
    }

    views {
        systemContext garakProvider "SystemContext" {
            include *
            autoLayout
        }

        container garakProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
