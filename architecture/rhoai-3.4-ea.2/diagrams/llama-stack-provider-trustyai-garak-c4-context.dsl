/*
 * C4 Context Diagram: TrustyAI Garak Llama Stack Provider
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / Security Engineer" "Submits LLM vulnerability scans and reviews results"

        garakProvider = softwareSystem "TrustyAI Garak Llama Stack Provider" "Llama Stack Eval provider integrating NVIDIA Garak for automated LLM vulnerability scanning" {
            inlineAdapter = container "GarakInlineEvalAdapter" "Runs Garak scans locally as subprocesses with asyncio semaphore concurrency" "Python Llama Stack Provider"
            remoteAdapter = container "GarakRemoteEvalAdapter" "Orchestrates Garak scans via Kubeflow Pipelines; submits 6-step KFP pipeline" "Python Llama Stack Provider"
            garakBase = container "GarakEvalBase" "Shared logic: benchmark registration, config deep-merge, probe validation, shield integration" "Python Base Class"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Orchestrates input/output shield scanning around LLM inference via Safety API" "Python Module"
            sdgModule = container "SDG Module" "Synthetic Data Generation for adversarial prompt creation from harm taxonomies" "Python Module"
            intentsModule = container "Intents Module" "Loads and validates custom policy taxonomies for intent-based risk assessment" "Python Module"
            kfpComponents = container "KFP Pipeline Components" "6-step pipeline: validate, resolve_taxonomy, sdg_generate, prepare_prompts, garak_scan, parse_results" "Python KFP Components"
            evalHubAdapter = container "GarakAdapter (EvalHub)" "Integrates with eval-hub platform; supports simple and KFP execution modes" "Python Framework Adapter"
            containerImage = container "Container Image" "Base image for KFP pipeline pods with Garak and all dependencies" "OCI Container (UBI9 + Python 3.12)"
        }

        llamaStackDistribution = softwareSystem "Llama Stack Distribution" "Hosts Llama Stack providers; provides inference, files, safety, shields APIs" "Internal RHOAI"
        dspa = softwareSystem "Data Science Pipelines (DSPA)" "Kubeflow Pipelines infrastructure for remote scan execution" "Internal RHOAI"
        vllm = softwareSystem "vLLM / Model Serving" "Target LLM inference endpoint (OpenAI-compatible API)" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides garak-provider-image reference via ConfigMap" "Internal RHOAI"
        evalHub = softwareSystem "eval-hub" "Evaluation platform for running and reporting Garak scans" "Internal RHOAI"
        garak = softwareSystem "Garak (NVIDIA)" "Core LLM vulnerability scanning engine" "External"
        postgresql = softwareSystem "PostgreSQL 15" "Persistent storage for Llama Stack Distribution state" "External"
        s3 = softwareSystem "S3 / MinIO" "Artifact storage for KFP pipeline (EvalHub KFP mode)" "External"

        user -> garakProvider "Submits vulnerability scans via Eval API" "HTTP/8321"
        garakProvider -> llamaStackDistribution "Hosted by; calls Files, Safety, Shields, Inference APIs" "HTTP/8321"
        garakProvider -> dspa "Submits and monitors KFP pipeline runs" "HTTPS/8443"
        garakProvider -> vllm "Probes target LLM for vulnerabilities" "HTTP(S)/443"
        garakProvider -> garak "Uses as core scanning engine" "subprocess"
        garakProvider -> postgresql "State persistence (via Llama Stack)" "PostgreSQL/5432"
        garakProvider -> s3 "Artifact storage (EvalHub KFP mode)" "HTTPS/443"
        garakProvider -> evalHub "Framework adapter integration" "API"
        trustyaiOperator -> garakProvider "Provides container image reference" "ConfigMap"

        inlineAdapter -> garakBase "extends"
        remoteAdapter -> garakBase "extends"
        inlineAdapter -> shieldOrchestrator "uses for shield testing"
        remoteAdapter -> kfpComponents "submits pipeline"
        garakBase -> sdgModule "uses for adversarial prompt generation"
        garakBase -> intentsModule "uses for taxonomy loading"
    }

    views {
        systemContext garakProvider "SystemContext" {
            include *
            autoLayout
        }

        container garakProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
