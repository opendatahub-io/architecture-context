%% Data Flow Diagram for llm-d-kv-cache
%% Generated by: Claude Opus 4.6

sequenceDiagram
    participant Scheduler as llm-d-inference-scheduler
    participant Indexer as kvcache.Indexer<br/>(Go Library)
    participant TokenPool as tokenization.Pool
    participant UDS as UDS Tokenizer Sidecar<br/>UDS Socket (gRPC)
    participant TokenProc as kvblock.TokenProcessor<br/>(FNV-64a / CBOR)
    participant Index as kvblock.Index<br/>(InMemory / Redis)
    participant Scorer as kvblock.Scorer
    participant vLLM as vLLM Pod Fleet<br/>5557/TCP ZMQ
    participant EventPool as kvevents.Pool<br/>(Sharded Workers)
    participant K8sAPI as Kubernetes API<br/>443/TCP HTTPS
    participant PodRecon as PodReconciler

    rect rgb(230, 245, 255)
        Note over Scheduler,Scorer: Flow 1: KV-Cache Aware Scoring (Read Path)
        Scheduler->>Indexer: Score(prompt, model) [Go function call]
        Indexer->>TokenPool: Tokenize request
        TokenPool->>UDS: gRPC Tokenize (plaintext UDS)
        UDS-->>TokenPool: TokenizeResponse (token IDs + offsets)
        TokenPool-->>Indexer: Token IDs
        Indexer->>TokenProc: ComputeBlockKeys(tokens)
        TokenProc-->>Indexer: Block hashes (FNV-64a)
        Indexer->>Index: Lookup(block_hashes)
        Index-->>Indexer: Pod locations + device tiers
        Indexer->>Scorer: Score(pod_locations, device_tiers)
        Scorer-->>Indexer: Scored pod list (prefix match + tier weights)
        Indexer-->>Scheduler: PodScores response
    end

    rect rgb(255, 245, 230)
        Note over vLLM,Index: Flow 2: KV-Event Ingestion (Write Path)
        vLLM->>EventPool: KVEvent (BlockStored/BlockRemoved)<br/>ZMQ PUB/SUB 5557/TCP (msgpack, plaintext)
        EventPool->>EventPool: Shard to worker (by pod)
        EventPool->>Index: Store/Remove block mapping<br/>(In-process or Redis 6379/TCP)
    end

    rect rgb(230, 255, 230)
        Note over K8sAPI,vLLM: Flow 3: Pod Discovery (Auto-Discovery)
        PodRecon->>K8sAPI: Watch pods (label selector)<br/>HTTPS 443/TCP, SA Token
        K8sAPI-->>PodRecon: Pod Added/Removed events
        PodRecon->>EventPool: Add/Remove ZMQ subscriber
        EventPool->>vLLM: ZMQ SUB connect<br/>5557/TCP (plaintext)
    end
