/*
 * vLLM CPU - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/vllm-cpu.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM inference endpoints"

        vllmCpu = softwareSystem "vLLM CPU" "CPU-optimized LLM inference and serving engine with OpenAI-compatible API" {
            apiServer = container "OpenAI API Server" "FastAPI/Uvicorn HTTP server exposing OpenAI-compatible REST API" "Python (FastAPI)" "Web Server"
            grpcServer = container "gRPC Server" "Binary gRPC interface for efficient router communication" "Python (grpcio)" "Service"
            asyncEngine = container "AsyncLLM Engine (V1)" "Core async inference engine with PagedAttention and continuous batching" "Python"
            cpuKernels = container "CPU Kernels" "CPU-optimized compute kernels for attention, caching, model execution" "C++/Python"
            modelExecutor = container "Model Executor" "Loads and executes HuggingFace-compatible models on CPU" "Python"
            tokenizer = container "Tokenizer Service" "Tokenization and detokenization for model I/O" "Python"
            structuredOutput = container "Structured Output Engine" "Enforces JSON schema, regex, grammar constraints" "Python"
            loraManager = container "LoRA Adapter Manager" "Dynamic loading/unloading of LoRA adapters" "Python"
            metrics = container "Prometheus Metrics" "Exposes inference performance and server load metrics" "Python"
        }

        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle, routing, and autoscaling" "Internal RHOAI"
        gateway = softwareSystem "RHOAI Data Science Gateway" "Platform Gateway API for external access with TLS termination" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Cluster monitoring and metrics collection" "Internal RHOAI"
        rustRouter = softwareSystem "Rust-based vLLM Router" "High-performance routing for multi-engine setups" "Internal RHOAI"

        hfHub = softwareSystem "HuggingFace Hub" "Model weight and tokenizer hosting" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for model artifacts" "External"
        pvc = softwareSystem "Persistent Volume Claims" "Pre-cached model weight storage" "External"

        # External relationships
        user -> gateway "Sends inference requests" "HTTPS/443"
        gateway -> vllmCpu "Routes to inference endpoint" "HTTP/8000"
        kserve -> vllmCpu "Manages as ServingRuntime container" "Kubernetes API"
        rustRouter -> vllmCpu "High-performance inference routing" "gRPC/50051"
        prometheus -> vllmCpu "Scrapes metrics" "HTTP/8000 /metrics"

        vllmCpu -> hfHub "Downloads model weights and configs" "HTTPS/443"
        vllmCpu -> s3Storage "Loads model weights from object storage" "HTTPS/443"
        vllmCpu -> pvc "Reads pre-cached model weights" "File I/O"

        # Internal container relationships
        apiServer -> asyncEngine "Submits inference requests" "In-process/IPC"
        grpcServer -> asyncEngine "Submits inference requests" "In-process"
        asyncEngine -> modelExecutor "Executes model forward pass" "In-process"
        asyncEngine -> cpuKernels "CPU-optimized operations" "In-process"
        apiServer -> tokenizer "Tokenize/detokenize" "In-process"
        apiServer -> structuredOutput "Apply output constraints" "In-process"
        apiServer -> loraManager "Load/unload adapters" "In-process"
        apiServer -> metrics "Record metrics" "In-process"
    }

    views {
        systemContext vllmCpu "SystemContext" {
            include *
            autoLayout
        }

        container vllmCpu "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Web Server" {
                shape WebBrowser
            }
        }
    }
}
