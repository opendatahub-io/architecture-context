// vLLM CPU - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        client = person "API Client" "Application or user sending inference requests via OpenAI-compatible API"
        datascientist = person "Data Scientist" "Deploys and configures vLLM serving runtimes via RHOAI Dashboard"

        // Main System
        vllmCpu = softwareSystem "vLLM CPU" "CPU-optimized LLM inference serving with OpenAI-compatible and gRPC APIs" {
            openaiServer = container "OpenAI API Server" "OpenAI-compatible REST API for chat completions, embeddings, and more" "Python (FastAPI/Uvicorn)" "Port 8000/TCP"
            grpcServer = container "gRPC Server" "High-performance binary protocol for Rust router integration" "Python (grpcio)" "Port 50051/TCP"
            asyncEngine = container "AsyncLLM Engine" "Asynchronous inference with PagedAttention, continuous batching, speculative decoding" "Python"
            cpuKernels = container "CPU Attention Kernels" "Architecture-optimized attention (AVX/AMX, NEON, VSX, VXE)" "C++"
            dnnl = container "DNNL Integration" "Intel oneDNN kernel acceleration" "C++"
            mcpServer = container "MCP Tool Server" "Model Context Protocol tool integration" "Python"
            metrics = container "Prometheus Metrics" "Built-in metrics exporter" "Python"
            tlsSupport = container "SSL/TLS Support" "Optional TLS with hot-reloadable certificates" "Python"
        }

        // Internal ODH Systems
        kserve = softwareSystem "KServe" "Manages vLLM as an InferenceService serving runtime" "Internal ODH"
        dashboard = softwareSystem "RHOAI Dashboard" "UI for deploying and monitoring inference services" "Internal ODH"
        modelMesh = softwareSystem "Model Mesh" "Alternative serving runtime manager" "Internal ODH"

        // External Systems
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        hfhub = softwareSystem "HuggingFace Hub" "Model weight and tokenizer downloads" "External"
        modelStorage = softwareSystem "Model Storage (S3/PVC)" "Model artifact storage backends" "External"
        rustRouter = softwareSystem "Rust Router" "High-performance request routing via gRPC" "External"
        mcpTools = softwareSystem "MCP Tool Servers" "Remote tool execution servers" "External"

        // Relationships - External Actors
        client -> vllmCpu "Sends inference requests" "HTTP/8000, Optional TLS, API Key"
        datascientist -> dashboard "Configures serving runtimes" "HTTPS"

        // Relationships - Internal ODH
        kserve -> vllmCpu "Manages as InferenceService runtime" "HTTP/8000"
        dashboard -> kserve "Creates InferenceService CRs" "Kubernetes API"

        // Relationships - External
        rustRouter -> vllmCpu "Sends inference requests" "gRPC/50051, plaintext"
        prometheus -> vllmCpu "Scrapes /metrics" "HTTP/8000"
        vllmCpu -> hfhub "Downloads model weights" "HTTPS/443, HF Token"
        vllmCpu -> modelStorage "Loads model artifacts" "HTTPS/NFS, varies"
        vllmCpu -> mcpTools "Executes remote tools" "HTTP (SSE), varies"

        // Container relationships
        openaiServer -> asyncEngine "Submits inference tasks" "Python IPC"
        grpcServer -> asyncEngine "Submits inference tasks" "Python IPC"
        asyncEngine -> cpuKernels "Executes attention" "C++ binding"
        asyncEngine -> dnnl "Accelerates kernels" "C++ binding"
        openaiServer -> metrics "Exports metrics"
        openaiServer -> tlsSupport "TLS termination"
        mcpServer -> openaiServer "Tool integration"
    }

    views {
        systemContext vllmCpu "SystemContext" {
            include *
            autoLayout
        }

        container vllmCpu "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
