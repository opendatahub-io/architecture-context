// C4 Context Diagram: Llama Stack Distribution
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs inference, RAG, evaluation, and safety workflows"
        mlEngineer = person "ML Engineer" "Deploys and configures Llama Stack with backend providers"

        llamaStack = softwareSystem "Llama Stack Distribution" "Unified API gateway for AI/ML inference, safety, evaluation, and vector storage backends (port 8321)" {
            server = container "Llama Stack Server" "Core API server exposing REST endpoints for inference, agents, eval, safety, vector I/O, tools, files, scoring, batches, and datasetio" "Python 3.12 / FastAPI / Uvicorn"
            config = container "Distribution Config" "Defines all API providers, storage backends, registered resources, and server settings" "YAML (config.yaml)"
            embeddingModel = container "Granite Embedding Model" "Pre-downloaded IBM Granite 125m English embedding model for local embedding" "HuggingFace Model"
        }

        // Internal RHOAI Dependencies
        vllm = softwareSystem "vLLM" "Primary LLM and embedding inference backend" "Internal RHOAI"
        trustyaiFMS = softwareSystem "TrustyAI FMS Orchestrator" "Content safety guardrails service" "Internal RHOAI"
        trustyaiLMEval = softwareSystem "TrustyAI LM Eval" "Model evaluation via LM Evaluation Harness" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "Distributed evaluation and security benchmarking pipelines (RAGAS, Garak)" "Internal RHOAI"
        rhoaiPlatform = softwareSystem "RHOAI Platform" "Gateway API + kube-rbac-proxy for ingress, TLS termination, and auth" "Internal RHOAI"

        // Data Stores
        postgresql = softwareSystem "PostgreSQL" "Persistent storage for KV store, SQL store, inference logs, and agent state" "Database"

        // Vector Databases
        milvus = softwareSystem "Milvus" "Vector database for similarity search" "External"
        pgvector = softwareSystem "pgvector" "PostgreSQL extension for vector similarity search" "External"
        qdrant = softwareSystem "Qdrant" "Vector database for similarity search" "External"

        // Cloud Inference Providers
        awsBedrock = softwareSystem "AWS Bedrock" "Cloud inference provider" "External Cloud"
        azureOpenAI = softwareSystem "Azure OpenAI" "Cloud inference provider" "External Cloud"
        vertexAI = softwareSystem "Google Vertex AI" "Cloud inference provider" "External Cloud"
        openAI = softwareSystem "OpenAI" "Cloud inference provider" "External Cloud"
        watsonX = softwareSystem "IBM WatsonX" "Cloud inference provider" "External Cloud"

        // Tool Services
        braveSearch = softwareSystem "Brave Search API" "Web search tool" "External"
        tavilySearch = softwareSystem "Tavily Search API" "Web search tool" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Dataset and model downloads" "External"
        s3Storage = softwareSystem "S3 / S3-compatible Storage" "File and evaluation result storage" "External"

        // Observability
        otelCollector = softwareSystem "OpenTelemetry Collector" "Optional distributed tracing and metrics" "External"

        // Relationships - Users
        datascientist -> llamaStack "Sends inference, RAG, eval, and safety requests via" "HTTPS/443 (via platform ingress)"
        mlEngineer -> llamaStack "Configures providers and deploys" "kubectl / RHOAI Dashboard"

        // Relationships - Platform
        rhoaiPlatform -> llamaStack "Routes traffic and enforces auth" "HTTP/8321"

        // Relationships - Internal RHOAI
        llamaStack -> vllm "Sends inference and embedding requests" "HTTP/HTTPS configurable"
        llamaStack -> trustyaiFMS "Sends content safety checks" "HTTP/HTTPS configurable"
        llamaStack -> trustyaiLMEval "Triggers model evaluations" "HTTP/K8s API"
        llamaStack -> kubeflowPipelines "Orchestrates evaluation pipelines" "HTTP/HTTPS configurable"

        // Relationships - Data Stores
        llamaStack -> postgresql "Stores state (KV, SQL, logs, agents)" "PostgreSQL/5432"
        llamaStack -> milvus "Vector similarity search" "gRPC/HTTP"
        llamaStack -> pgvector "Vector similarity search" "PostgreSQL/5432"
        llamaStack -> qdrant "Vector similarity search" "HTTP:6333/gRPC:6334"

        // Relationships - Cloud Providers
        llamaStack -> awsBedrock "Cloud inference" "HTTPS/443"
        llamaStack -> azureOpenAI "Cloud inference" "HTTPS/443"
        llamaStack -> vertexAI "Cloud inference" "HTTPS/443"
        llamaStack -> openAI "Cloud inference" "HTTPS/443"
        llamaStack -> watsonX "Cloud inference" "HTTPS/443"

        // Relationships - Tools & Services
        llamaStack -> braveSearch "Web search queries" "HTTPS/443"
        llamaStack -> tavilySearch "Web search queries" "HTTPS/443"
        llamaStack -> huggingFace "Downloads datasets and models" "HTTPS/443"
        llamaStack -> s3Storage "Stores files and eval results" "HTTPS/443"
        llamaStack -> otelCollector "Exports traces and metrics" "OTLP HTTP"
    }

    views {
        systemContext llamaStack "SystemContext" {
            include *
            autoLayout
        }

        container llamaStack "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Cloud" {
                background #f5a623
                color #ffffff
            }
            element "Database" {
                background #438dd5
                color #ffffff
                shape Cylinder
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
