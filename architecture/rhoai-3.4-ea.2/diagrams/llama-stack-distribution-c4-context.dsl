/*
 * C4 Context Diagram - Llama Stack Distribution
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-16
 */

workspace {
    model {
        user = person "Data Scientist / Developer" "Creates inference requests, agent workflows, evaluations, and RAG queries"

        llamaStack = softwareSystem "Llama Stack Distribution" "Pre-configured container distribution of Meta's Llama Stack providing unified REST API for AI/ML inference, agents, evaluation, safety, and tool runtimes" {
            server = container "Llama Stack Server" "Core API server exposing unified REST API on port 8321 for all AI/ML capabilities" "Python FastAPI/Uvicorn"
            config = container "Distribution Config" "Declares APIs, providers, storage backends, registered resources, and server settings" "YAML Configuration"
            entrypoint = container "Entrypoint Script" "Container entrypoint that resolves config and optionally wraps with OpenTelemetry instrumentation" "Shell Script"
        }

        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages lifecycle and deployment of llama-stack-distribution pods" "Internal RHOAI"

        # Persistence
        postgresql = softwareSystem "PostgreSQL" "Primary persistence backend for KV store and SQL store" "External"

        # Inference Providers
        vllm = softwareSystem "vLLM Serving Runtime" "LLM and embedding model inference" "Internal RHOAI"
        bedrock = softwareSystem "AWS Bedrock" "Remote inference provider" "External Cloud"
        azure = softwareSystem "Azure OpenAI" "Remote inference provider" "External Cloud"
        vertexai = softwareSystem "Google Vertex AI" "Remote inference provider" "External Cloud"
        watsonx = softwareSystem "IBM WatsonX" "Remote inference provider" "External Cloud"
        openai = softwareSystem "OpenAI API" "Remote inference provider" "External Cloud"

        # Vector Databases
        milvus = softwareSystem "Milvus" "Remote vector database for similarity search" "External"
        qdrant = softwareSystem "Qdrant" "Remote vector database" "External"

        # Safety & Evaluation
        trustyaiFMS = softwareSystem "TrustyAI FMS Orchestrator" "Content safety guardrails" "Internal RHOAI"
        trustyaiLMEval = softwareSystem "TrustyAI LM-Eval" "Model evaluation benchmarks" "Internal RHOAI"
        kubeflow = softwareSystem "Kubeflow Pipelines" "Remote evaluation pipeline execution for RAGAS and Garak" "Internal RHOAI"

        # Tool Runtimes
        braveSearch = softwareSystem "Brave Search API" "Web search tool runtime" "External Cloud"
        tavilySearch = softwareSystem "Tavily Search API" "Web search tool runtime" "External Cloud"

        # External Services
        huggingface = softwareSystem "HuggingFace Hub" "Model and dataset downloads" "External Cloud"
        s3 = softwareSystem "S3 Storage" "File storage backend" "External Cloud"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Telemetry export (traces, metrics)" "External"

        # Relationships
        user -> llamaStack "Sends inference, agent, eval, and RAG requests" "HTTP/8321"
        rhoaiOperator -> llamaStack "Manages lifecycle and deployment"

        llamaStack -> postgresql "Persists metadata, agent state, conversations" "PostgreSQL/5432"
        llamaStack -> vllm "LLM inference and embedding" "HTTP-HTTPS/8000"
        llamaStack -> bedrock "Remote inference" "HTTPS/443"
        llamaStack -> azure "Remote inference" "HTTPS/443"
        llamaStack -> vertexai "Remote inference" "HTTPS/443"
        llamaStack -> watsonx "Remote inference" "HTTPS/443"
        llamaStack -> openai "Remote inference" "HTTPS/443"
        llamaStack -> milvus "Vector storage and similarity search" "gRPC/HTTP"
        llamaStack -> qdrant "Vector storage and similarity search" "HTTP-gRPC/6333-6334"
        llamaStack -> trustyaiFMS "Content safety checks" "HTTPS"
        llamaStack -> trustyaiLMEval "Model evaluation" "HTTP/HTTPS"
        llamaStack -> kubeflow "Remote eval pipelines (RAGAS, Garak)" "HTTP/HTTPS"
        llamaStack -> braveSearch "Web search" "HTTPS/443"
        llamaStack -> tavilySearch "Web search" "HTTPS/443"
        llamaStack -> huggingface "Downloads models and datasets" "HTTPS/443"
        llamaStack -> s3 "File storage" "HTTPS/443"
        llamaStack -> otelCollector "Exports traces and metrics" "HTTP OTLP/4318"
    }

    views {
        systemContext llamaStack "SystemContext" {
            include *
            autoLayout
        }

        container llamaStack "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Cloud" {
                background #777777
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
