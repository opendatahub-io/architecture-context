// ODH Dashboard - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/odh-dashboard.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates notebooks, deploys models, manages data science workflows"
        admin = person "Platform Admin" "Configures cluster settings, manages hardware profiles and serving runtimes"

        odhDashboard = softwareSystem "ODH Dashboard" "Web-based management dashboard for Red Hat OpenShift AI (RHOAI)" {
            rbacProxy = container "kube-rbac-proxy" "TLS-terminating authentication proxy enforcing OpenShift RBAC" "Go Sidecar" "Auth"
            backend = container "odh-dashboard Backend" "Serves static assets, proxies K8s API calls, manages module federation" "Node.js 22 / Fastify 4"
            frontend = container "odh-dashboard Frontend" "PatternFly-based UI for data science workflow management" "React 18 SPA"
            modelRegistryUI = container "model-registry-ui" "Model Registry UI micro-frontend" "Federated Plugin (8043)"
            genAIUI = container "gen-ai-ui" "Gen AI Studio UI micro-frontend" "Federated Plugin (8143)"
            maasUI = container "maas-ui" "Model-as-a-Service UI micro-frontend" "Federated Plugin (8243)"
            mlflowUI = container "mlflow-ui" "MLflow experiment tracking UI micro-frontend" "Federated Plugin (8343)"
            evalHubUI = container "eval-hub-ui" "Evaluation Hub UI micro-frontend" "Federated Plugin (8543)"
            automlUI = container "automl-ui" "AutoML UI micro-frontend" "Federated Plugin (8643)"
            autoragUI = container "autorag-ui" "AutoRAG UI micro-frontend" "Federated Plugin (8743)"
        }

        // External Dependencies
        openshift = softwareSystem "OpenShift Platform" "Container platform (v4.19-v4.21)" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        gatewayAPI = softwareSystem "data-science-gateway" "Gateway API HTTPRoute for external ingress" "External"
        prometheus = softwareSystem "Prometheus/Thanos" "Metrics queries via thanos-querier (port 9092)" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys dashboard via kustomize overlays" "Internal ODH"
        notebookController = softwareSystem "Kubeflow Notebooks" "Jupyter notebook workbench management" "Internal ODH"
        kserve = softwareSystem "KServe" "Model serving via InferenceService CRD" "Internal ODH"
        modelRegistryOp = softwareSystem "Model Registry Operator" "Model registry management" "Internal ODH"
        dsc = softwareSystem "DataScienceCluster" "Cluster-level DSC configuration" "Internal ODH"
        perses = softwareSystem "data-science-perses" "Observability dashboards" "Internal ODH"
        mlflow = softwareSystem "MLflow" "Experiment tracking and model management" "Internal ODH"

        // Relationships - External
        dataScientist -> odhDashboard "Manages notebooks, models, pipelines via browser" "HTTPS/443"
        admin -> odhDashboard "Configures cluster settings, hardware profiles" "HTTPS/443"

        odhDashboard -> k8sAPI "CRD management, resource watching, RBAC checks" "HTTPS/443"
        odhDashboard -> prometheus "Prometheus metrics queries" "HTTPS/9092"
        odhDashboard -> perses "Observability dashboard proxy" "HTTP/8080"
        odhDashboard -> mlflow "Embedded MLflow UI" "HTTPS/8443"
        gatewayAPI -> odhDashboard "Routes external traffic" "HTTPS/8443"
        rhodsOperator -> odhDashboard "Deploys via kustomize" "Kustomize"

        // Relationships - Internal ODH
        odhDashboard -> notebookController "Creates/manages Jupyter notebooks" "K8s API (Notebook CRD)"
        odhDashboard -> kserve "Displays/manages model serving" "K8s API (InferenceService CRD)"
        odhDashboard -> modelRegistryOp "Model registry management" "K8s API (ModelRegistry CRD)"
        odhDashboard -> dsc "Reads cluster configuration" "K8s API (DSC CRD)"

        // Container relationships
        rbacProxy -> k8sAPI "SubjectAccessReview" "HTTPS/443"
        rbacProxy -> backend "Authenticated requests" "HTTP/8080 localhost"
        backend -> frontend "Serves SPA" "HTTP"
        backend -> modelRegistryUI "Proxies requests" "HTTPS/8043"
        backend -> genAIUI "Proxies requests" "HTTPS/8143"
        backend -> maasUI "Proxies requests" "HTTPS/8243"
        backend -> mlflowUI "Proxies requests" "HTTPS/8343"
        backend -> evalHubUI "Proxies requests" "HTTPS/8543"
        backend -> automlUI "Proxies requests" "HTTPS/8643"
        backend -> autoragUI "Proxies requests" "HTTPS/8743"
        backend -> k8sAPI "K8s API calls" "HTTPS/443"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Auth" {
                background #e74c3c
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
