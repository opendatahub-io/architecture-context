// ODH Dashboard - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates notebooks, deploys models, runs pipelines"
        platformAdmin = person "Platform Administrator" "Configures cluster settings, manages RBAC, monitors platform"

        odhDashboard = softwareSystem "ODH Dashboard" "Primary web UI for Red Hat OpenShift AI - unified management interface for data science workloads" {
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-based authentication proxy enforcing OpenShift project list permissions" "Go Sidecar" "Auth Proxy"
            dashboardBackend = container "Dashboard Backend" "Backend-for-frontend proxying K8s API requests, serving static frontend, aggregating platform APIs" "Node.js 22 / Fastify"
            dashboardFrontend = container "Dashboard Frontend" "Single-page application with Webpack Module Federation host" "React 18 / PatternFly 6"
            modelRegistryUI = container "model-registry-ui" "Model Registry management federated UI module" "React (Module Federation)" "Federated Module"
            genAiUI = container "gen-ai-ui" "Generative AI management federated UI module" "React (Module Federation)" "Federated Module"
            maasUI = container "maas-ui" "Model-as-a-Service management federated UI module" "React (Module Federation)" "Federated Module"
            mlflowUI = container "mlflow-ui" "MLflow experiment tracking federated UI module" "React (Module Federation)" "Federated Module"
            evalHubUI = container "eval-hub-ui" "Evaluation Hub federated UI module" "React (Module Federation)" "Federated Module"
            automlUI = container "automl-ui" "AutoML management federated UI module" "React (Module Federation)" "Federated Module"
            autoragUI = container "autorag-ui" "AutoRAG management federated UI module" "React (Module Federation)" "Federated Module"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform API for all resource management" "External"
        openshiftAPI = softwareSystem "OpenShift API Server" "OpenShift-specific APIs (Routes, Users, Groups, Projects)" "External"
        rhodsOperator = softwareSystem "RHODS Operator" "Manages DataScienceCluster and DSCInitialization CRs" "Internal ODH"
        notebookController = softwareSystem "Kubeflow Notebook Controller" "Manages Jupyter notebook instances" "Internal ODH"
        kserve = softwareSystem "KServe" "Serverless ML model serving platform" "Internal ODH"
        pipelines = softwareSystem "Kubeflow Pipelines" "ML pipeline orchestration and management" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "ML model metadata and versioning registry" "Internal ODH"
        trustyai = softwareSystem "TrustyAI" "AI model explainability and fairness" "Internal ODH"
        mlmd = softwareSystem "ML Metadata" "ML artifact and experiment metadata store" "Internal ODH"
        prometheus = softwareSystem "Prometheus/Thanos" "Metrics collection and querying" "External"
        llamaStack = softwareSystem "Llama Stack" "Llama Stack distribution management" "Internal ODH"
        feast = softwareSystem "Feast" "Feature store management" "Internal ODH"
        perses = softwareSystem "Perses" "Observability dashboards" "Internal ODH"
        dataScienceGateway = softwareSystem "data-science-gateway" "Platform ingress gateway (Gateway API)" "External"
        openshiftConsole = softwareSystem "OpenShift Console" "OpenShift web console with application menu" "External"

        // User interactions
        dataScientist -> odhDashboard "Manages notebooks, models, pipelines via browser" "HTTPS/443"
        platformAdmin -> odhDashboard "Configures platform settings, manages RBAC" "HTTPS/443"

        // Ingress
        dataScienceGateway -> odhDashboard "Routes external traffic to dashboard" "HTTPS/443 → 8443"

        // Dashboard dependencies
        odhDashboard -> k8sAPI "All resource CRUD operations" "HTTPS/443"
        odhDashboard -> openshiftAPI "Users, groups, routes, projects" "HTTPS/443"
        odhDashboard -> rhodsOperator "Reads platform configuration" "CRD watch"
        odhDashboard -> notebookController "Creates/manages notebooks" "CRD (Notebook)"
        odhDashboard -> kserve "Model serving management" "CRD (InferenceService)"
        odhDashboard -> pipelines "Pipeline CRUD and monitoring" "REST proxy HTTPS/8443"
        odhDashboard -> modelRegistry "Model registry management" "REST proxy HTTPS/8443"
        odhDashboard -> trustyai "AI explainability service" "REST proxy HTTPS/443"
        odhDashboard -> mlmd "ML metadata queries" "REST proxy HTTPS/8443"
        odhDashboard -> prometheus "Metrics queries for dashboards" "HTTPS/9091"
        odhDashboard -> llamaStack "Llama Stack management" "REST proxy HTTPS/8443"
        odhDashboard -> feast "Feature store management" "CRD (FeatureStore)"
        odhDashboard -> perses "Observability dashboard data" "HTTP/8080"

        // Integration points
        odhDashboard -> openshiftConsole "ConsoleLink CR for menu integration" "N/A"

        // Container-level interactions
        dataScientist -> kubeRbacProxy "HTTPS requests with Bearer token" "HTTPS/8443"
        kubeRbacProxy -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
        kubeRbacProxy -> dashboardBackend "Authenticated requests" "HTTP/8080 localhost"
        dashboardBackend -> dashboardFrontend "Serves SPA assets"
        dashboardFrontend -> modelRegistryUI "Loads federated module" "HTTPS/8043"
        dashboardFrontend -> genAiUI "Loads federated module" "HTTPS/8143"
        dashboardFrontend -> maasUI "Loads federated module" "HTTPS/8243"
        dashboardFrontend -> mlflowUI "Loads federated module" "HTTPS/8343"
        dashboardFrontend -> evalHubUI "Loads federated module" "HTTPS/8543"
        dashboardFrontend -> automlUI "Loads federated module" "HTTPS/8643"
        dashboardFrontend -> autoragUI "Loads federated module" "HTTPS/8743"
        dashboardBackend -> k8sAPI "K8s API calls with user token" "HTTPS/443"
        dashboardBackend -> pipelines "Pipeline API proxy" "HTTPS/8443"
        dashboardBackend -> modelRegistry "Model Registry API proxy" "HTTPS/8443"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Auth Proxy" {
                background #e74c3c
                color #ffffff
            }
            element "Federated Module" {
                background #8e44ad
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
        }
    }
}
