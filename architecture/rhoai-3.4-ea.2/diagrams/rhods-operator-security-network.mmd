%% RHOAI Operator (rhods-operator) - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router / LB<br/>443/TCP HTTPS"]
        Gateway["data-science-gateway (Envoy)<br/>Namespace: openshift-ingress<br/>443/TCP TLS Terminate (TLS 1.2+)<br/>GatewayClass: data-science-gateway-class"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KAP["kube-auth-proxy<br/>Namespace: openshift-ingress<br/>SA: kube-auth-proxy<br/>8443/TCP HTTPS (service-CA TLS)<br/>9000/TCP HTTP (metrics)<br/>HPA: 2-10 replicas"]
        EnvoyFilter["EnvoyFilter<br/>data-science-authn-filter<br/>ext_authz + Lua token forwarding"]
    end

    subgraph OAuthZone["IDENTITY PROVIDER"]
        OAuth["OAuth/OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>OpenShift OAuth or External OIDC"]
    end

    subgraph BackendServices["BACKEND SERVICES (via HTTPRoute)"]
        direction LR
        Dashboard["Dashboard"]
        KServe["KServe"]
        ModelReg["Model Registry"]
        DSP["DS Pipelines"]
        OtherSvc["Other Components..."]
    end

    subgraph RedirectInfra["LEGACY REDIRECT"]
        DashRedirect["dashboard-redirect (nginx)<br/>Namespace: redhat-ods-applications<br/>8080/TCP HTTP<br/>301 redirect to rh-ai domain"]
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE"]
        Operator["rhods-operator<br/>Namespace: redhat-ods-operator<br/>SA: controller-manager<br/>8080/TCP metrics | 8081/TCP health<br/>9443/TCP HTTPS webhooks"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+"]
        IstioSM["Istio / Service Mesh<br/>EnvoyFilter + DestinationRule"]
        Monitoring["MonitoringStack<br/>Prometheus / Tempo / OTel"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+"| Router
    Router -->|"HTTPS/443<br/>TLS Terminate"| Gateway

    %% Gateway → Auth
    Gateway -->|"ext_authz<br/>HTTPS/8443<br/>service-CA TLS"| KAP
    EnvoyFilter -.->|configures| Gateway

    %% Auth → OAuth
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials"| OAuth

    %% Gateway → Backends (post-auth)
    Gateway -->|"HTTPS (SIMPLE TLS)<br/>Bearer token forwarded<br/>via DestinationRule"| Dashboard
    Gateway -->|"HTTPS"| KServe
    Gateway -->|"HTTPS"| ModelReg
    Gateway -->|"HTTPS"| DSP
    Gateway -->|"HTTPS"| OtherSvc

    %% Legacy redirect
    User -.->|"HTTPS/443<br/>TLS (edge)<br/>legacy URL"| DashRedirect
    DashRedirect -.->|"301 redirect to<br/>rh-ai.domain"| User

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (RBAC)"| K8sAPI
    Operator -->|deploys| Gateway
    Operator -->|deploys| KAP
    Operator -->|configures| IstioSM
    Operator -->|deploys| Monitoring

    %% Network Policy annotation
    KAP -.->|"NetworkPolicy:<br/>ingress from gateway (8443)<br/>ingress from monitoring (9000)"| KAP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef redirect fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router,Gateway ingress
    class KAP,EnvoyFilter,OAuth auth
    class Dashboard,KServe,ModelReg,DSP,OtherSvc backend
    class Operator operator
    class K8sAPI,IstioSM,Monitoring cluster
    class DashRedirect redirect
