%% RHOAI Operator (rhods-operator) - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User Browser / API Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Namespace: openshift-ingress"]
        direction TB
        Route["OpenShift Route / LoadBalancer<br/>443/TCP<br/>TLS 1.2+ Terminate"]
        Gateway["data-science-gateway (Envoy)<br/>GatewayClass: data-science-gateway-class<br/>443/TCP → 8443/TCP<br/>TLS Terminate"]
        Filter["EnvoyFilter: data-science-authn-filter<br/>Intercepts all gateway traffic"]
        AuthProxy["kube-auth-proxy<br/>8443/TCP (auth) | 9000/TCP (metrics)<br/>TLS: service-CA cert<br/>Auth: OAuth2/OIDC + K8s TokenReview<br/>NetworkPolicy: gateway pods + monitoring only"]

        Route --> Gateway
        Gateway --> Filter
        Filter --> AuthProxy
    end

    subgraph OAuthZone["AUTHENTICATION PROVIDERS"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>IntegratedOAuth mode"]
        OIDCProvider["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>OIDC mode"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB
        OperatorMgr["Operator Manager<br/>SA: controller-manager<br/>3 replicas, leader election<br/>Health: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP"]
        WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS: service serving certs<br/>Auth: API server client cert"]

        subgraph PlatformCtrl["Platform Controllers"]
            DSCICtrl["DSCI Controller"]
            DSCCtrl["DSC Controller"]
            GWCtrl["Gateway Controller"]
            AuthCtrlr["Auth Controller"]
            MonCtrl["Monitoring Controller"]
        end

        subgraph CompCtrl["Component Controllers (16)"]
            CompList["Dashboard | Workbenches | Kserve<br/>ModelController | ModelRegistry | MaaS<br/>DSP | Ray | Kueue | TrainingOp<br/>Trainer | TrustyAI | Feast<br/>LlamaStack | MLflow | Spark"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
    end

    subgraph Monitoring["MONITORING STACK"]
        MonStack["MonitoringStack<br/>(Prometheus)"]
        Thanos["ThanosQuerier<br/>9090/TCP HTTP"]
        OTel["OpenTelemetry Collector"]
        TempoSvc["Tempo<br/>4317/TCP gRPC"]
        Perses["Perses Dashboards"]
    end

    subgraph ExtServices["EXTERNAL SERVICES"]
        Registry["Container Image Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull secret"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (initial)"| Route

    %% Auth flows
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuthClient creds"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDCProvider

    %% Gateway to backend
    Gateway -->|"HTTP/HTTPS<br/>Auth headers proxied"| CompList

    %% Operator to K8s API
    OperatorMgr -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>Client cert"| WebhookSrv

    %% Operator to external
    OperatorMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| Registry

    %% Monitoring flows
    MonStack -->|"HTTP/HTTPS<br/>SA token"| CompList
    Thanos -->|"HTTP/9090"| MonStack
    OTel -->|"gRPC/4317<br/>Optional TLS"| TempoSvc
    Perses -->|"HTTP/9090"| MonStack

    %% Monitoring scrapes kube-auth-proxy metrics
    MonStack -->|"HTTP/9000<br/>NetworkPolicy allowed"| AuthProxy

