%% Note: NeMo Guardrails does not define its own RBAC.
%% Authentication is delegated to the RHOAI platform layer.
graph TD
    subgraph "External Access"
        Client["External Client"]
    end

    subgraph "Platform Authentication Layer"
        Gateway["RHOAI Platform Gateway<br/>(Gateway API / HTTPRoute)"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>Enforces AuthN/AuthZ"]
    end

    subgraph "NeMo Guardrails Endpoints (No Server-Level Auth)"
        ChatEndpoint["POST /v1/chat/completions<br/>Auth: None (server-level)<br/>Enforcement: Platform Gateway"]
        CheckEndpoint["POST /v1/guardrail/checks<br/>Auth: None (server-level)<br/>Enforcement: Platform Gateway"]
        ConfigEndpoint["GET /v1/rails/configs<br/>Auth: None (server-level)<br/>Enforcement: Platform Gateway"]
        ModelsEndpoint["GET /v1/models<br/>Auth: None (server-level)<br/>Enforcement: Platform Gateway"]
        HealthEndpoint["GET /<br/>Health Check<br/>No Auth Required"]
    end

    subgraph "Backend LLM Authentication"
        LLMAuth["Backend LLM API<br/>Auth: Bearer Token / API Key<br/>Enforcement: Application Code<br/>Config: guardrails config.yaml"]
    end

    subgraph "Secrets"
        LLMSecret["LLM API Key<br/>Type: Opaque<br/>Provisioned by: User/deployer<br/>Auto-Rotate: No"]
        RedisSecret["Redis Password (Optional)<br/>Type: Opaque<br/>Provisioned by: User/deployer<br/>Auto-Rotate: No"]
    end

    Client -->|"Bearer Token<br/>(platform-managed)"| Gateway
    Gateway --> KubeRBACProxy
    KubeRBACProxy -->|"Authenticated request"| ChatEndpoint
    KubeRBACProxy -->|"Authenticated request"| CheckEndpoint
    KubeRBACProxy -->|"Authenticated request"| ConfigEndpoint
    KubeRBACProxy -->|"Authenticated request"| ModelsEndpoint
    Client -->|"Direct (in-cluster)"| HealthEndpoint

    ChatEndpoint -->|"Uses API Key from config"| LLMAuth
    CheckEndpoint -->|"Uses API Key from config"| LLMAuth

    LLMSecret -->|"Mounted/injected"| LLMAuth
    RedisSecret -->|"Mounted/injected<br/>(optional)"| ChatEndpoint

