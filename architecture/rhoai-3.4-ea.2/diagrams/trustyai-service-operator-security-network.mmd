    TASKRBP -->|"HTTP/8080<br/>localhost<br/>No auth"| TASSvc
    GORCHKRBP -->|"HTTP/8032<br/>internal"| GORCHSvc
    NEMOKRBP -->|"internal"| NEMOSvc

