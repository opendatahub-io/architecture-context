    TASSvc -->|"TCP/5432<br/>Optional TLS"| PostgreSQL
    EvalHubSvc -->|"TCP/5432<br/>Optional TLS"| PostgreSQL
    LMEval -->|"HTTPS/443<br/>TLS 1.2+"| S3
    LMEval -->|"HTTPS/443<br/>TLS 1.2+"| OCI
    LMEval -->|"HTTP/HTTPS/gRPC"| InferenceServices
    EvalHubSvc -->|"gRPC/HTTP"| OTLP
    GORCHSvc -->|"gRPC/HTTP"| OTLP

