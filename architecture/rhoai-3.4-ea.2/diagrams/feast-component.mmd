%% Feast Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph FeastOperator["Feast Operator (controller-manager)"]
        direction TB
        FSReconciler["FeatureStoreReconciler<br/>(Controller)"]
        NBReconciler["NotebookConfigMapReconciler<br/>(Controller)"]
        FeastSvc["FeastServices<br/>(Service Logic)"]
        FeastAuth["FeastAuthorization<br/>(Auth Logic)"]

        FSReconciler --> FeastSvc
        FSReconciler --> FeastAuth
    end

    subgraph FeatureStorePod["Feast Deployment (per FeatureStore CR)"]
        direction TB
        OnlineServer["Online Store<br/>gRPC 6566/6567"]
        OfflineServer["Offline Store<br/>gRPC 8815/8816"]
        RegistryServer["Registry Server<br/>gRPC 6570/6571<br/>REST 6572/6573"]
        UIServer["Feast UI<br/>HTTP 8888/8443"]
        CronJob["CronJob<br/>feast apply &<br/>materialize-incremental"]
    end

    User[User / Admin] -->|creates| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|watched by| FSReconciler

    FSReconciler -->|creates/manages| FeatureStorePod
    FSReconciler -->|creates| Services["Services<br/>(online/offline/registry/ui)"]
    FSReconciler -->|creates| ConfigMaps["ConfigMaps<br/>(feature_store.yaml)"]
    FSReconciler -->|creates| PVC["PersistentVolumeClaims"]
    FSReconciler -->|creates| RBAC["Roles & RoleBindings"]
    FSReconciler -->|creates| CronJob
    FSReconciler -->|"creates (OCP)"| Route["OpenShift Route<br/>UI ingress"]

    NotebookCR["Kubeflow Notebook<br/>(with feast-integration label)"] -->|watched by| NBReconciler
    NBReconciler -->|creates| NBConfigMap["Notebook Feast ConfigMap<br/>(client config)"]

    FeastAuth -->|configures| KubeRBAC["Kubernetes RBAC Auth<br/>(TokenReview + SAR)"]
    FeastAuth -->|configures| OIDC["OIDC Auth<br/>(JWT validation)"]

    %% External Dependencies
    FSReconciler -->|interacts with| K8sAPI["Kubernetes API Server"]
    FeatureStorePod -->|optional| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    FeatureStorePod -->|optional| Snowflake["Snowflake<br/>443/TCP"]
    FeatureStorePod -->|optional| Cassandra["Cassandra<br/>9042/TCP"]
    FeatureStorePod -->|optional| S3["S3/GCS Object Store<br/>443/TCP"]

    %% ODH Integration
    FSReconciler -->|mounts| ODHCA["ODH Trusted CA Bundle"]
    FSReconciler -->|"uses (OCP)"| ServingCerts["OpenShift Service<br/>Serving Certs"]

