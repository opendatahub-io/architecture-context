    %% Flows
    User -->|"HTTPS/443"| Router
    Router -->|"Reencrypt TLS/8443"| KubeRBACProxy
    KubeRBACProxy -->|"proxied/8888"| APIServer

    DSPACR -->|"watched by"| Controller
    Controller -->|"deploys"| APIServer
    Controller -->|"deploys"| PersistenceAgent
    Controller -->|"deploys"| ScheduledWorkflow
    Controller -->|"deploys"| WorkflowController
    Controller -->|"deploys"| MLMDgRPC
    Controller -->|"deploys"| MLMDEnvoy
    Controller -->|"deploys"| MariaDB
    Controller -->|"deploys"| Minio
    Controller -->|"health check"| MariaDB
    Controller -->|"health check"| Minio

    APIServer -->|"stores metadata"| MariaDB
    APIServer -->|"stores artifacts"| Minio
    APIServer -->|"creates"| WorkflowCR

    PersistenceAgent -->|"reads status"| WorkflowCR
    PersistenceAgent -->|"updates"| APIServer

    ScheduledWorkflow -->|"manages"| ScheduledWorkflowCR
    WorkflowController -->|"manages"| WorkflowCR
    Webhook -->|"validates"| PipelineVersionCR

    MLMDEnvoy -->|"proxies"| MLMDgRPC

    RHODSOp -->|"deploys via kustomize"| DSPO
    ServiceCA -->|"provisions TLS certs"| DSPAStack
    Prometheus -->|"scrapes metrics"| Controller
    Prometheus -->|"scrapes metrics"| APIServer
    Workbenches -->|"REST API/8888"| APIServer
    APIServer -->|"creates InferenceService"| KServe
    APIServer -->|"creates AppWrappers"| CodeFlare

    Controller -->|"CRUD operations"| K8sAPI

