// C4 Context Diagram: llm-d-kv-cache
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Users / Actors
        inferenceScheduler = softwareSystem "llm-d-inference-scheduler" "Embeds KV-cache indexer library for cache-aware routing decisions" "Internal llm-d"

        // Main System
        kvCache = softwareSystem "llm-d-kv-cache" "Pluggable KV-Cache indexing and management library for KV-Cache-aware routing in vLLM-based LLM inference platforms" {
            indexer = container "KV-Cache Indexer" "Tokenizes prompts, generates block keys, queries index, scores pods for cache-aware routing" "Go Library (pkg/kvcache)"
            blockIndex = container "KV-Block Index" "Pluggable data store mapping KV-block hashes to pod locations; backends: LRU, Ristretto, Redis, Valkey" "Go Library (pkg/kvcache/kvblock)"
            eventsPool = container "KV-Events Pool" "Sharded worker pool consuming ZMQ events from vLLM pods" "Go Library (pkg/kvevents)"
            zmqManager = container "ZMQ Subscriber Manager" "Manages per-pod ZMQ subscriber lifecycle with K8s pod reconciler" "Go Library (pkg/kvevents)"
            tokenPool = container "Tokenization Pool" "Worker pool for prompt tokenization with composite fallback" "Go Library (pkg/tokenization)"
            udsTokenizer = container "UDS Tokenizer Service" "gRPC tokenizer service over Unix Domain Sockets using vLLM tokenizer" "Python gRPC Sidecar"
            indexerGRPC = container "Indexer gRPC Service" "Remote KV-cache scoring via GetPodScores RPC" "gRPC API (50051/TCP)"
            fsBackend = container "llmd-fs-backend" "vLLM offloading connector for filesystem-backed KV-cache with GPU DMA" "Python/CUDA Extension"
            pvcEvictor = container "PVC Evictor" "Multi-process utility for automatic disk space management on KV-cache PVCs" "Python Service"
            metrics = container "Prometheus Metrics" "Cache admissions, evictions, lookup hits, latency, tokenization metrics" "Go Library"
            tracing = container "OpenTelemetry Tracing" "OTLP-based distributed tracing with W3C trace context" "Go Library"
        }

        // External Dependencies
        vllmFleet = softwareSystem "vLLM Fleet" "vLLM inference engine pods publishing KV-cache events" "External"
        redisValkey = softwareSystem "Redis / Valkey" "Optional distributed KV-block index backend" "External Optional"
        k8sAPI = softwareSystem "Kubernetes API Server" "Pod discovery and watch for auto-configuring ZMQ subscribers" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Tokenizer model downloads" "External"
        otlpCollector = softwareSystem "OTLP Collector" "Distributed tracing export endpoint" "External Optional"
        prometheus = softwareSystem "Prometheus" "Metrics scraping" "External"

        // Relationships - External
        inferenceScheduler -> kvCache "Embeds kvcache.Indexer library" "Go in-process"
        kvCache -> vllmFleet "Subscribes to KVEvents" "ZMQ PUB/SUB 5557/TCP plaintext"
        kvCache -> redisValkey "Distributed index backend" "Redis 6379/TCP Optional TLS"
        kvCache -> k8sAPI "Pod discovery reconciler" "HTTPS 443/TCP TLS 1.2+"
        kvCache -> hfHub "Download tokenizer models" "HTTPS 443/TCP TLS 1.2+ Bearer Token"
        kvCache -> otlpCollector "Export traces" "gRPC 4317/TCP"
        prometheus -> kvCache "Scrape metrics" "HTTP"

        // Relationships - Internal
        indexer -> tokenPool "Tokenize prompts"
        indexer -> blockIndex "Query/score blocks"
        tokenPool -> udsTokenizer "gRPC over UDS" "/tmp/tokenizer/*.socket"
        eventsPool -> blockIndex "Update index"
        zmqManager -> eventsPool "Feed events"
        indexer -> indexerGRPC "Exposes API"
        indexer -> metrics "Emit metrics"
        indexer -> tracing "Record traces"
    }

    views {
        systemContext kvCache "SystemContext" {
            include *
            autoLayout
        }

        container kvCache "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #bbbbbb
                color #ffffff
                border dashed
            }
            element "Internal llm-d" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
