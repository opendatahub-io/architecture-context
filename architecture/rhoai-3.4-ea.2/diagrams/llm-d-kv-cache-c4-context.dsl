// C4 Context Diagram for llm-d-kv-cache
// Generated by: Claude Opus 4.6

workspace {
    model {
        scheduler = person "Inference Scheduler" "llm-d-inference-scheduler - routes inference requests using KV-cache aware scoring"

        kvCache = softwareSystem "llm-d-kv-cache" "Pluggable KV-Cache management library and tokenizer sidecar for KV-Cache aware routing in vLLM-based LLM inference" {
            indexer = container "kvcache.Indexer" "Main orchestrator - coordinates tokenization, index lookup, and scoring" "Go Library"
            eventPool = container "kvevents.Pool" "Sharded worker pool ingesting KVEvents from vLLM pods via ZMQ" "Go Library"
            blockIndex = container "kvblock.Index" "Core data store mapping KV-block hashes to pod locations" "Go Library (InMemory/Ristretto/Redis)"
            tokenProcessor = container "kvblock.TokenProcessor" "Converts token sequences into KV-block keys using FNV-64a hashing" "Go Library"
            scorer = container "kvblock.Scorer" "Scores pods based on prefix matching with device-tier weights" "Go Library"
            podReconciler = container "PodReconciler" "Watches vLLM pods and manages ZMQ subscribers" "Go Controller (controller-runtime)"
            udsTokenizer = container "UDS Tokenizer Service" "Python gRPC tokenizer sidecar via Unix Domain Socket" "Python gRPC Server"
            indexerService = container "IndexerService" "gRPC service wrapping Indexer for remote scoring" "Go gRPC Server"
        }

        vllm = softwareSystem "vLLM Fleet" "vLLM inference engine pods emitting KV-cache events" "External"
        redis = softwareSystem "Redis / Valkey" "Distributed KV-block index backend (optional)" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for pod discovery" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Tokenizer model repository" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing (optional)" "External"

        // Relationships
        scheduler -> kvCache "Uses for KV-cache aware pod scoring" "Go library import"
        kvCache -> vllm "Subscribes to KV-cache events" "ZMQ PUB/SUB 5557/TCP plaintext"
        kvCache -> redis "Stores/queries KV-block index" "Redis 6379/TCP Optional TLS"
        kvCache -> k8sApi "Discovers vLLM pods" "HTTPS 443/TCP TLS 1.2+"
        kvCache -> hfHub "Downloads tokenizer models" "HTTPS 443/TCP TLS 1.2+"
        prometheus -> kvCache "Scrapes metrics" "HTTP 8080/TCP"
        kvCache -> otelCollector "Exports tracing spans" "OTLP gRPC 4317/TCP"

        // Internal container relationships
        indexer -> udsTokenizer "Tokenizes prompts" "gRPC over UDS"
        indexer -> blockIndex "Queries block locations" "Go interface"
        indexer -> tokenProcessor "Computes block keys" "Go function call"
        indexer -> scorer "Scores pods" "Go function call"
        eventPool -> blockIndex "Updates block mappings" "Go interface / Redis"
        podReconciler -> eventPool "Manages ZMQ subscribers" "Go function call"
    }

    views {
        systemContext kvCache "SystemContext" {
            include *
            autoLayout
        }

        container kvCache "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #7ed321
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
