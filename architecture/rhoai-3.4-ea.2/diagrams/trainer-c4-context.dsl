// Trainer C4 Context Diagram
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/trainer.md

workspace {
    model {
        user = person "Data Scientist" "Creates and manages distributed ML training jobs"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes-native operator for orchestrating distributed ML training jobs (PyTorch, JAX, TensorFlow, MPI)" {
            controllerManager = container "trainer-controller-manager" "Main controller managing TrainJob, TrainingRuntime, and ClusterTrainingRuntime CRDs" "Go Operator (controller-runtime)"
            trainJobController = container "TrainJob Controller" "Reconciles TrainJob CRs, creates JobSets, NetworkPolicies, PodGroups" "Reconciler"
            runtimeController = container "TrainingRuntime Controller" "Manages namespace-scoped TrainingRuntime CRs with finalizer protection" "Reconciler"
            clusterRuntimeController = container "ClusterTrainingRuntime Controller" "Manages cluster-scoped ClusterTrainingRuntime CRs with finalizer protection" "Reconciler"
            webhooks = container "Validating Webhooks" "Validates TrainJob, TrainingRuntime, ClusterTrainingRuntime on CREATE/UPDATE" "Admission Webhooks (9443/TCP)"
            progressionTracking = container "RHAI Progression Tracking" "Polls training pod HTTP metrics for real-time progress" "Extension (pkg/rhai/progression)"
            networkPolicyEnforcement = container "RHAI NetworkPolicy" "Creates per-TrainJob NetworkPolicies for pod isolation" "Extension (pkg/rhai/networkpolicy)"
            certManager = container "Certificate Manager" "Self-managed TLS certificate rotation for webhook server" "cert-controller"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane" "External"
        jobsetController = softwareSystem "JobSet Controller" "Manages replicated Job templates for distributed training (jobset.x-k8s.io v0.10.1)" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Container platform with ImageStreams, SCC (v4.19-v4.21)" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and monitoring" "External"
        coscheduling = softwareSystem "Coscheduling Plugin" "Gang-scheduling via PodGroup CRs (scheduler-plugins v0.34.1)" "External Optional"
        volcano = softwareSystem "Volcano Scheduler" "Gang-scheduling via Volcano PodGroup CRs (v1.13.1)" "External Optional"
        kueue = softwareSystem "Kueue" "Multi-cluster job management" "External Optional"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys trainer manifests from Kustomize overlay" "Internal RHOAI"

        // Relationships
        user -> trainer "Creates TrainJob CRs via kubectl/API" "HTTPS/443"
        trainer -> k8sAPI "CRUD operations on JobSets, PodGroups, Secrets, ConfigMaps, NetworkPolicies" "HTTPS/443, TLS 1.2+, SA Token"
        trainer -> jobsetController "Creates JobSet CRs for distributed training management" "CRD ownership"
        k8sAPI -> trainer "Webhook validation callbacks" "HTTPS/9443, TLS (self-signed)"
        prometheus -> trainer "Scrapes controller metrics" "HTTPS/8443, TLS (self-signed)"
        trainer -> coscheduling "Creates PodGroup CRs for gang-scheduling" "CRD creation"
        trainer -> volcano "Creates Volcano PodGroup CRs for gang-scheduling" "CRD creation"
        trainer -> kueue "Delegates jobs via managedBy field" "CRD field"
        rhoaiOperator -> trainer "Deploys manifests via Kustomize overlay"

        // Internal container relationships
        controllerManager -> trainJobController "manages"
        controllerManager -> runtimeController "manages"
        controllerManager -> clusterRuntimeController "manages"
        controllerManager -> webhooks "serves"
        trainJobController -> progressionTracking "uses"
        trainJobController -> networkPolicyEnforcement "uses"
        certManager -> webhooks "provides TLS certificates"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #cccccc
                color #333333
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
