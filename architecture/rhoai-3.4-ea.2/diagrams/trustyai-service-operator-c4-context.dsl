// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/trustyai-service-operator.md

workspace {
    model {
        // Users
        datascientist = person "Data Scientist" "Creates TrustyAIService, LMEvalJob, and EvalHub resources for model evaluation and monitoring"
        mlops = person "MLOps Engineer" "Configures Guardrails Orchestrator and NeMo Guardrails for LLM safety"
        platformadmin = person "Platform Admin" "Deploys and manages the operator via rhods-operator"

        // Main system
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller operator managing TrustyAI explainability, LM evaluation, guardrails orchestration, NeMo guardrails, and EvalHub on OpenShift" {
            operatorManager = container "Operator Manager" "Main entry point running all controllers, health/readiness on 8081/TCP" "Go Binary"
            tasController = container "TAS Controller" "Reconciles TrustyAIService CRs, creates Deployments with kube-rbac-proxy, Services, Routes, ServiceMonitors, Istio resources" "Go Controller"
            lmesController = container "LMES Controller" "Reconciles LMEvalJob CRs, creates evaluation job Pods, manages lifecycle via pod exec" "Go Controller"
            gorchController = container "GORCH Controller" "Reconciles GuardrailsOrchestrator CRs, creates multi-container Deployments, Routes, auto-config" "Go Controller"
            nemoController = container "NEMO Controller" "Reconciles NemoGuardrails CRs, creates Deployments with CA bundle init containers" "Go Controller"
            evalhubController = container "EVALHUB Controller" "Reconciles EvalHub CRs, creates Deployments, ConfigMaps, multi-tenant RBAC" "Go Controller"
            jobMgrController = container "Job Manager Controller" "Integrates LMEvalJob with Kueue for resource-aware scheduling" "Go Controller"
        }

        // Internal ODH Systems
        rhodsOperator = softwareSystem "rhods-operator" "Deploys TrustyAI operator via kustomize overlays" "Internal ODH"
        kserve = softwareSystem "KServe" "Model serving with InferenceService CRDs" "Internal ODH"
        serviceMesh = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for traffic management and mTLS" "Internal ODH"
        dscConfig = softwareSystem "DSC Config" "OpenDataHub operator-level configuration (ConfigMap)" "Internal ODH"

        // External Dependencies
        openshift = softwareSystem "OpenShift Platform" "Container platform with Routes, Service Serving Certs" "External"
        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Authentication proxy sidecar for RBAC enforcement" "External"
        kueue = softwareSystem "Kueue" "Job queue management for resource-aware scheduling" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "External"
        certManager = softwareSystem "OpenShift Service Serving Certs" "Auto-provisioned TLS certificates" "External"

        // External Services
        huggingface = softwareSystem "HuggingFace Hub" "Model and dataset repository for evaluations" "External Service"
        database = softwareSystem "Database (PostgreSQL/MariaDB)" "Persistent storage for TrustyAI Service and EvalHub" "External Service"

        // Relationships - Users
        datascientist -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, EvalHub CRs via kubectl/API"
        mlops -> trustyaiOperator "Creates GuardrailsOrchestrator, NemoGuardrails CRs"
        platformadmin -> rhodsOperator "Configures RHOAI deployment"

        // Relationships - Internal
        rhodsOperator -> trustyaiOperator "Deploys via kustomize overlay" "Kustomize"
        trustyaiOperator -> kserve "Watches/patches InferenceService, reads ServingRuntime" "K8s API/TLS"
        trustyaiOperator -> serviceMesh "Creates VirtualService/DestinationRule" "K8s API/TLS"
        trustyaiOperator -> dscConfig "Reads DSC-level configuration" "K8s API/TLS"
        trustyaiOperator -> kueue "Creates Workload resources for job scheduling" "K8s API/TLS"
        trustyaiOperator -> prometheus "Exposes metrics via ServiceMonitor" "HTTP/8080"
        trustyaiOperator -> openshift "Creates Routes for external access" "K8s API/TLS"
        trustyaiOperator -> certManager "Auto-provisioned TLS certs via annotations" "Annotation"
        trustyaiOperator -> kubeRbacProxy "Deploys as sidecar for RBAC auth" "Container sidecar"

        // Relationships - External
        trustyaiOperator -> huggingface "Downloads models/datasets for LMEvalJobs" "HTTPS/443"
        trustyaiOperator -> database "Stores TrustyAI and EvalHub data" "TCP/TLS"

        // Container relationships
        operatorManager -> tasController "Manages"
        operatorManager -> lmesController "Manages"
        operatorManager -> gorchController "Manages"
        operatorManager -> nemoController "Manages"
        operatorManager -> evalhubController "Manages"
        operatorManager -> jobMgrController "Manages"

        tasController -> kserve "Patches InferenceService Deployments" "K8s API"
        lmesController -> huggingface "Job Pods download models" "HTTPS/443"
        gorchController -> kserve "Reads ServingRuntime for auto-config" "K8s API"
        jobMgrController -> kueue "Creates Workload resources" "K8s API"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #000000
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
