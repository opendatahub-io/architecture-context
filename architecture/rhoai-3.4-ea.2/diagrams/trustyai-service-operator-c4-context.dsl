/*
 * C4 Context Diagram - TrustyAI Service Operator
 * Generated by: Claude Opus 4.6
 */
workspace {
    model {
        user = person "Data Scientist / MLOps Engineer" "Creates and monitors AI/ML models for trustworthiness, fairness, and evaluation"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller Go operator managing TrustyAI explainability, LM evaluation, guardrails orchestration, NeMo Guardrails, and EvalHub services" {
            tasController = container "TrustyAI Service Controller (TAS)" "Manages TrustyAI explainability service deployments with kube-rbac-proxy sidecars" "Go Controller"
            lmesController = container "LMEvalJob Controller (LMES)" "Manages LM evaluation job pods with driver sidecars" "Go Controller"
            jobMgrController = container "Job Manager Controller (JOB_MGR)" "Kueue integration for LMEvalJob workload scheduling" "Go Controller"
            gorchController = container "GuardrailsOrchestrator Controller (GORCH)" "Manages guardrails orchestrator deployments with auto-config" "Go Controller"
            nemoController = container "NeMo Guardrails Controller" "Manages NVIDIA NeMo Guardrails server deployments" "Go Controller"
            evalhubController = container "EvalHub Controller" "Manages centralized evaluation hub with multi-tenant support" "Go Controller"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService CRDs" "External"
        kueue = softwareSystem "Kueue" "Job scheduling and resource management for Kubernetes" "External"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection via ServiceMonitors" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for traffic management and mTLS" "External"
        openshiftCA = softwareSystem "OpenShift Service CA" "Automatic TLS certificate provisioning" "External"
        odhOperator = softwareSystem "OpenDataHub Operator" "Platform operator providing DSC configuration" "Internal ODH"
        postgresql = softwareSystem "PostgreSQL" "Relational database for persistent storage" "External"
        s3 = softwareSystem "S3-compatible Storage" "Object storage for datasets and model artifacts" "External"
        ociRegistries = softwareSystem "OCI Registries" "Container registries for result upload" "External"
        otlp = softwareSystem "OpenTelemetry Collector" "Telemetry and observability data export" "External"
        gitRepos = softwareSystem "Git Repositories" "Source code for custom evaluation tasks" "External"

        user -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator, NemoGuardrails, EvalHub CRs via kubectl"
        trustyaiOperator -> kserve "Watches InferenceServices, patches payload processors, discovers detectors" "HTTPS/443"
        trustyaiOperator -> kueue "Creates Workload CRs for job scheduling" "HTTPS/443"
        trustyaiOperator -> prometheus "Exposes metrics via ServiceMonitors" "HTTP/8080"
        trustyaiOperator -> istio "Creates DestinationRules and VirtualServices" "HTTPS/443"
        trustyaiOperator -> openshiftCA "Requests TLS certificates via annotations"
        trustyaiOperator -> postgresql "Persistent storage for TrustyAI Service and EvalHub" "TCP/5432"
        trustyaiOperator -> s3 "Downloads offline datasets for LMEvalJobs" "HTTPS/443"
        trustyaiOperator -> ociRegistries "Uploads evaluation results" "HTTPS/443"
        trustyaiOperator -> otlp "Exports telemetry from EvalHub and GORCH" "gRPC/HTTP"
        trustyaiOperator -> gitRepos "Clones custom evaluation task sources" "HTTPS/443"
        odhOperator -> trustyaiOperator "Provides DSC configuration via trustyai-dsc-config ConfigMap"

        tasController -> kserve "Patches InferenceService deployments" "HTTPS/443"
        lmesController -> s3 "Offline dataset storage" "HTTPS/443"
        jobMgrController -> kueue "Workload scheduling" "HTTPS/443"
        gorchController -> kserve "Discovers InferenceServices by label" "HTTPS/443"
        evalhubController -> postgresql "Database backend" "TCP/5432"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
