graph TB
    subgraph Clients["CLIENTS (Internal/External)"]
        Client["Client<br/>(Notebooks, Applications)"]
    end

    subgraph GatewayService["GATEWAY SERVICE (ClusterIP - Internal)"]
        Gateway["vllm-orchestrator-gateway<br/>8090/TCP HTTP (plaintext)<br/>Rust/axum<br/>No Auth Enforcement"]

        subgraph Routes["Dynamic Routes"]
            PII["/{pii}/v1/chat/completions"]
            Pass["/{passthrough}/v1/chat/completions"]
        end
    end

    subgraph TLSConfig["TLS CONFIGURATION (Optional)"]
        Certs["/etc/tls/private/<br/>tls.crt + tls.key<br/>Provisioned by: cert-manager"]
        CA["/etc/tls/ca/<br/>service-ca.crt<br/>Provisioned by: service-ca-operator"]
    end

    subgraph Upstream["UPSTREAM SERVICES"]
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP HTTP/HTTPS<br/>POST /api/v2/chat/completions-detection"]
    end

    subgraph Indirect["INDIRECT SERVICES (via Orchestrator)"]
        LLM["vLLM / LLM Backend"]
        Detectors["Guardrails Detectors<br/>(regex-detector, etc.)"]
    end

    %% Flows
    Client -->|"HTTP/8090 (plaintext)<br/>Auth: Authorization header<br/>(pass-through)"| Gateway
    Gateway --- Routes
    Gateway -.->|"mTLS certs<br/>(when available)"| TLSConfig
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Client cert + fwd Authorization<br/>Forwards: Authorization, X-Forwarded-*<br/>Drops: all other headers"| Orchestrator
    Orchestrator -->|"Configured in orchestrator"| LLM
    Orchestrator -->|"Configured in orchestrator"| Detectors

