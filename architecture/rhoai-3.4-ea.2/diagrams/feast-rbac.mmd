        Res_Routes["route.openshift.io<br/>routes"]
        Res_Batch["batch<br/>cronjobs"]
        Res_KF["kubeflow.org<br/>notebooks"]
        Res_CRD["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph Resources_Dynamic["Dynamic Role Resources"]
        Res_DynRBAC["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        Res_DynAuth["authentication.k8s.io<br/>tokenreviews"]
        Res_DynSAR["rbac.authorization.k8s.io<br/>subjectaccessreviews"]
        Res_DynNS["core<br/>namespaces"]
    end

    subgraph Resources_CronJob["CronJob Role Resources"]
        Res_CJDeploy["apps<br/>deployments (specific)"]
        Res_CJPods["core<br/>pods"]
        Res_CJExec["core<br/>pods/exec"]
    end

    %% Operator SA bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Metrics
    SA_Operator -->|bound via| RB_LeaderElection
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    RB_LeaderElection -->|grants| R_LeaderElection

    %% Manager role permissions
    CR_Manager -->|"get,list,watch<br/>create,update,patch,delete"| Res_FS
    CR_Manager -->|"get,list,create<br/>update,watch,delete"| Res_Apps
    CR_Manager -->|"get,list,create<br/>update,watch,delete"| Res_Core
    CR_Manager -->|"get,list,watch"| Res_CoreRO
    CR_Manager -->|"create"| Res_Exec
    CR_Manager -->|"get,list,create<br/>update,watch,delete"| Res_RBAC
    CR_Manager -->|"create"| Res_Auth
    CR_Manager -->|"get,list,create<br/>update,watch,delete"| Res_Routes
    CR_Manager -->|"get,list,watch<br/>create,update,patch,delete"| Res_Batch
    CR_Manager -->|"get,list,watch"| Res_KF
    CR_Manager -->|"get,list"| Res_CRD

    %% Feast SA bindings (dynamic)
    SA_Feast -->|bound via| RB_Feast
    SA_Feast -->|bound via| CRB_TokenReview
    RB_Feast -->|grants| R_Feast
    CRB_TokenReview -->|grants| CR_TokenReview

    R_Feast -->|"get,list,watch"| Res_DynRBAC
    R_Feast -->|"create"| Res_DynAuth
    R_Feast -->|"create"| Res_DynSAR
    R_Feast -->|"get,list,watch"| Res_DynNS

    %% CronJob SA bindings
    SA_CronJob -->|bound via| RB_CronJob
    RB_CronJob -->|grants| R_CronJob
    R_CronJob -->|"get"| Res_CJDeploy
    R_CronJob -->|"list"| Res_CJPods
    R_CronJob -->|"create"| Res_CJExec

