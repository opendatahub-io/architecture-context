%% Generated by: Claude Opus 4.6

graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-<br/>controller-manager"]
        SA_Feast["feast-{name}-sa<br/>(per FeatureStore)"]
        SA_CronJob["feast-{name}-cronjob-sa<br/>(per FeatureStore)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["feast-operator-<br/>manager-rolebinding"]
        CRB_Metrics["feast-operator-<br/>metrics-auth-rolebinding"]
        CRB_TokenReview["feast-token-review-<br/>cluster-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["feast-operator-manager-role"]
        CR_MetricsAuth["feast-operator-metrics-auth-role"]
        CR_MetricsReader["feast-operator-metrics-reader"]
        CR_TokenReview["feast-token-review-cluster-role"]
    end

    subgraph RoleBindings_NS["RoleBindings (Namespace-scoped)"]
        RB_LeaderElection["feast-operator-<br/>leader-election-rolebinding"]
        RB_Feast["feast-{name}-rolebinding"]
        RB_CronJob["feast-{name}-cronjob-<br/>rolebinding"]
    end

    subgraph Roles_NS["Roles (Namespace-scoped)"]
        R_LeaderElection["feast-operator-<br/>leader-election-role"]
        R_Feast["feast-{name}"]
        R_CronJob["feast-{name}-cronjob"]
    end

    subgraph Resources_Manager["Manager Role Resources"]
        Res_FS["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers"]
        Res_Apps["apps<br/>deployments"]
        Res_Core["core<br/>services, configmaps<br/>pvcs, serviceaccounts"]
