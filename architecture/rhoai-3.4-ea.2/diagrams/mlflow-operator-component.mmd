%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.2/mlflow-operator.md

graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["MLflow Operator<br/>Controller Manager<br/>(Go, controller-runtime)"]
        HelmEngine["Embedded Helm Chart<br/>Engine (Helm v3 SDK)"]
        Controller -->|renders| HelmEngine
    end

    subgraph MLflowPod["MLflow Server Pod (Helm-deployed)"]
        MLflowServer["MLflow Tracking Server<br/>(Python/uvicorn)<br/>Port: 8443/TCP HTTPS"]
        CAInit["CA Bundle<br/>Init Container"]
        CAWatcher["CA Bundle<br/>Watcher Sidecar"]
        CAInit -->|initializes certs| MLflowServer
        CAWatcher -->|updates certs| MLflowServer
    end

    %% CRDs
    User[Data Scientist] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    NSOwner[Namespace Owner] -->|creates| MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| MLflowServer

    %% Operator creates resources
    HelmEngine -->|creates| MLflowServer
    Controller -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    Controller -->|creates| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy"]
    Controller -->|creates| PVC["PersistentVolumeClaim"]

    %% External dependencies
    HTTPRoute -->|references| Gateway["data-science-gateway<br/>(openshift-ingress)"]
    Controller -->|authenticates via| K8sAPI["Kubernetes API<br/>6443/TCP"]
    MLflowServer -->|RBAC check via| K8sAPI
    MLflowServer -->|stores metadata| DB["PostgreSQL / MySQL<br/>5432/TCP / 3306/TCP"]
    MLflowServer -->|stores artifacts| S3["S3 / MinIO / SeaweedFS<br/>443/TCP / 9000/TCP / 8333/TCP"]

    %% Integration
    ServiceMonitor -->|scraped by| Prometheus["Prometheus"]
    ConsoleLink -->|visible in| Console["OpenShift Console"]
    RHODSOp["rhods-operator"] -->|deploys| Controller

