%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "MLflow Operator"
        Controller["MLflow Operator<br/>(controller-manager)<br/>Go / controller-runtime"]
        HelmRenderer["Helm Chart Renderer<br/>(internal library)"]
        Controller -->|renders via| HelmRenderer
    end

    subgraph "MLflow Server Stack"
        MLflowServer["MLflow Server<br/>(uvicorn / Python)<br/>Port 8443/TCP HTTPS"]
        InitContainer["CA Bundle Init Container<br/>Combines CA PEM files"]
        Sidecar["CA Bundle Watcher Sidecar<br/>30s poll interval"]
        InitContainer -.->|initializes| MLflowServer
        Sidecar -.->|updates CA bundle| MLflowServer
    end

    %% CRDs
    MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller

    %% Operator creates resources
    Controller -->|creates via SSA| MLflowServer
    Controller -->|creates| HTTPRoute["HTTPRoute CR<br/>(Gateway API v1)"]
    Controller -->|creates| ConsoleLink["ConsoleLink CR<br/>(OpenShift)"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy"]
    Controller -->|creates| ServiceMonitor["ServiceMonitor CR"]
    Controller -->|creates| RBAC["ClusterRoles &<br/>ClusterRoleBindings"]

    %% External Dependencies
    HTTPRoute -->|references| Gateway["data-science-gateway<br/>(openshift-ingress)"]
    MLflowServer -->|auth via| K8sAPI["Kubernetes API<br/>SelfSubjectAccessReview"]
    MLflowServer -->|stores artifacts| S3["S3-compatible Storage<br/>(MinIO/SeaweedFS/AWS S3)"]
    MLflowServer -->|stores metadata| PostgreSQL["PostgreSQL<br/>Backend Store"]
    Controller -->|reads| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Integration
    Prometheus["Prometheus"] -->|scrapes /metrics| MLflowServer
    ConsoleLink -->|adds menu entry| OpenShiftConsole["OpenShift Console"]

