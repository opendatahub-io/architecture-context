        subgraph "Base Images"
            BaseCPU["Base Image<br/>UBI9 Python 3.12<br/>(CPU)"]
            BaseCUDA["Base Image<br/>UBI9 + CUDA<br/>(12.6/12.8/12.9/13.0)"]
            BaseROCm["Base Image<br/>UBI9 + ROCm<br/>(6.2/6.3/6.4)"]
        end

        subgraph "Jupyter Workbenches"
            JupMinimal["Jupyter Minimal<br/>CPU / CUDA / ROCm"]
            JupDS["Jupyter Data Science<br/>CPU"]
            JupPyTorch["Jupyter PyTorch<br/>CUDA / ROCm"]
            JupPyTorchLLM["Jupyter PyTorch<br/>LLM Compressor (CUDA)"]
            JupTF["Jupyter TensorFlow<br/>CUDA / ROCm"]
            JupTrustyAI["Jupyter TrustyAI<br/>CPU"]
        end

        subgraph "Other Workbenches"
            CodeServer["Code Server<br/>Data Science (CPU)"]
            RStudio["RStudio Server<br/>CPU / CUDA"]
        end

        subgraph "Pipeline Runtimes"
            RTMinimal["Runtime Minimal<br/>CPU"]
            RTDS["Runtime Data Science<br/>CPU"]
            RTPyTorch["Runtime PyTorch<br/>CUDA / ROCm"]
            RTTF["Runtime TensorFlow<br/>CUDA / ROCm"]
            RTLLMComp["Runtime LLM Compressor<br/>CUDA"]
        end

        subgraph "Build & Manifests"
            Tekton["Tekton Pipelines<br/>(94 pipelines)"]
            Kustomize["Kustomize Manifests<br/>(ImageStreams)"]
            BuildInputs["Build Input Scripts<br/>(Go CLI)"]
        end
    end

    %% Base image dependencies
    BaseCPU --> JupMinimal
    BaseCPU --> JupDS
    BaseCPU --> CodeServer
    BaseCPU --> JupTrustyAI
    BaseCUDA --> JupPyTorch
    BaseCUDA --> JupPyTorchLLM
    BaseCUDA --> JupTF
    BaseCUDA --> RStudio
    BaseROCm --> JupPyTorch
    BaseROCm --> JupTF

    %% Tekton builds all images
    Tekton -->|builds| JupMinimal
    Tekton -->|builds| JupDS
    Tekton -->|builds| CodeServer
    Tekton -->|builds| RStudio
    Tekton -->|builds| RTMinimal

    %% Kustomize references all images
    Kustomize -->|ImageStream refs| JupMinimal
    Kustomize -->|ImageStream refs| JupDS
    Kustomize -->|ImageStream refs| CodeServer
    Kustomize -->|ImageStream refs| RStudio
    Kustomize -->|ImageStream refs| RTMinimal

    %% External consumers
    Operator["rhods-operator"] -->|reads & applies| Kustomize
    NotebookCtrl["ODH Notebook Controller"] -->|pulls images via| IS["ImageStreams"]
    Dashboard["ODH Dashboard"] -->|reads annotations| IS
    Kustomize -->|produces| IS

    %% External registries
    Tekton -->|pushes to| RRHI["registry.redhat.io/rhoai/"]
    Tekton -->|pushes to| Quay["quay.io/modh/"]

