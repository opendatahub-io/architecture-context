%% EvalHub RBAC Visualization
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.2/eval-hub.md

graph TD
    subgraph AuthFlow["Authentication & Authorization Flow"]
        Client["Client Request<br/>Bearer Token + X-Tenant header"]
        AuthN["TokenReview<br/>(DelegatingAuthenticator)<br/>2min cache TTL"]
        AuthZ["SubjectAccessReview<br/>(DelegatingAuthorizer)<br/>5min allow / 30s deny cache"]
        TenantNS["Namespace Scope<br/>(from X-Tenant header)"]

        Client -->|"Bearer Token"| AuthN
        AuthN -->|"authenticated identity"| AuthZ
        AuthZ -->|"namespace = X-Tenant"| TenantNS
    end

    subgraph ServiceAccounts["Service Accounts"]
        EvalHubSA["EvalHub ServiceAccount<br/>(operator-provisioned)"]
        JobSA["&lt;instance&gt;-&lt;namespace&gt;-job<br/>(tenant namespace)<br/>Used by eval K8s Jobs"]
    end

    subgraph EvaluationsRBAC["Evaluations API RBAC"]
        EvalResource["trustyai.opendatahub.io<br/>Resource: evaluations"]
        EvalVerbs["Verbs: create, get, list, delete"]
        EvalEndpoint["Endpoint: /api/v1/evaluations/jobs"]

        EvalEndpoint -->|"maps to"| EvalResource
        EvalResource -->|"permitted"| EvalVerbs
    end

    subgraph MLflowRBAC["MLflow Experiment RBAC"]
        MLflowResource["mlflow.kubeflow.org<br/>Resource: experiments"]
        MLflowVerbs["Verbs: create, get"]
        MLflowEndpoint["Endpoint: /api/v1/evaluations/jobs (POST)"]

        MLflowEndpoint -->|"additionally requires"| MLflowResource
        MLflowResource -->|"permitted"| MLflowVerbs
    end

    subgraph EventsRBAC["Status Events RBAC"]
        EventResource["trustyai.opendatahub.io<br/>Resource: status-events"]
        EventVerbs["Verbs: create"]
        EventEndpoint["Endpoint: /api/v1/evaluations/jobs/*/events"]

        EventEndpoint -->|"maps to"| EventResource
        EventResource -->|"permitted"| EventVerbs
    end

    subgraph CollectionsRBAC["Collections RBAC"]
        CollResource["trustyai.opendatahub.io<br/>Resource: collections"]
        CollVerbs["Verbs: create, get, list,<br/>update, patch, delete"]
        CollEndpoint["Endpoint: /api/v1/evaluations/collections"]

        CollEndpoint -->|"maps to"| CollResource
        CollResource -->|"permitted"| CollVerbs
    end

    subgraph ProvidersRBAC["Providers RBAC"]
        ProvResource["trustyai.opendatahub.io<br/>Resource: providers"]
        ProvVerbs["Verbs: create, get, list,<br/>update, patch, delete"]
        ProvEndpoint["Endpoint: /api/v1/evaluations/providers"]

        ProvEndpoint -->|"maps to"| ProvResource
        ProvResource -->|"permitted"| ProvVerbs
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth)"]
        Health["/api/v1/health"]
        Metrics["/metrics"]
        Docs["/docs, /openapi.yaml"]
    end

    %% Connections
    TenantNS -->|"checks against"| EvaluationsRBAC
    TenantNS -->|"checks against"| MLflowRBAC
    TenantNS -->|"checks against"| EventsRBAC
    TenantNS -->|"checks against"| CollectionsRBAC
    TenantNS -->|"checks against"| ProvidersRBAC

    EvalHubSA -->|"used by API server for<br/>K8s API access"| AuthN
    JobSA -->|"used by eval jobs for<br/>K8s API + MLflow access"| EventsRBAC

