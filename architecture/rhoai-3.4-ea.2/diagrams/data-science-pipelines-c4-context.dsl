// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/data-science-pipelines.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates, schedules, and monitors ML pipelines"

        dsp = softwareSystem "Data Science Pipelines" "End-to-end ML workflow orchestration platform based on Kubeflow Pipelines v2" {
            apiServer = container "ml-pipeline API Server" "REST/gRPC API for pipeline CRUD, run management, experiment tracking, artifact serving" "Go Service" "Core"
            ui = container "ml-pipeline-ui" "Web UI for pipeline visualization, run monitoring, experiment management" "React/Node.js" "Core"
            persistenceAgent = container "ml-pipeline-persistenceagent" "Watches Argo Workflows and reports status back to API server" "Go Agent" "Core"
            scheduledWorkflow = container "ml-pipeline-scheduledworkflow" "CRD controller for ScheduledWorkflow; manages cron-based scheduling" "Go Controller" "Core"
            viewerCRD = container "ml-pipeline-viewer-crd" "CRD controller for Viewer resources; manages visualization deployments" "Go Controller" "Core"
            cacheServer = container "cache-server" "Mutating admission webhook for pipeline step caching" "Go Webhook" "Core"
            vizServer = container "ml-pipeline-visualizationserver" "Generates HTML visualizations from pipeline output artifacts" "Python Service" "Core"
            mlmd = container "metadata-grpc-server (MLMD)" "ML Metadata store for artifact and execution lineage" "C++ gRPC Service" "Metadata"
            envoy = container "metadata-envoy" "gRPC-Web to gRPC proxy fronting MLMD server" "Envoy Proxy" "Metadata"
            driver = container "kfp-driver" "V2 pipeline driver injected into Argo Workflow pods" "Go Binary" "Runtime"
            launcher = container "kfp-launcher" "V2 pipeline launcher for user container execution" "Go Binary" "Runtime"
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Pipeline execution engine; runs workflows as Kubernetes pods" "External"
        mysql = softwareSystem "MySQL / PostgreSQL" "Relational database for pipeline metadata, run state, experiments" "External"
        minio = softwareSystem "MinIO / S3 Storage" "Object storage for pipeline artifacts and logs" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "CRD management, pod management, RBAC, TokenReview" "External"
        dspo = softwareSystem "Data Science Pipelines Operator" "Deploys and manages all DSP components" "Internal RHOAI"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Web dashboard for RHOAI platform" "Internal RHOAI"

        // User interactions
        user -> dsp "Creates/monitors pipelines via SDK or UI"
        user -> ui "Browses pipeline runs, experiments" "HTTP/3000"
        user -> apiServer "Submits pipelines, creates runs" "REST/8888, gRPC/8887"

        // Internal container interactions
        ui -> apiServer "Fetches pipeline data" "HTTP/8888"
        ui -> envoy "Queries metadata" "gRPC-Web/9090"
        envoy -> mlmd "Proxies metadata requests" "gRPC/8080"
        apiServer -> vizServer "Proxies visualization requests" "HTTP/8888"
        persistenceAgent -> apiServer "Reports workflow status" "gRPC/8887"
        scheduledWorkflow -> apiServer "Creates scheduled runs" "gRPC/8887"
        driver -> apiServer "Pipeline orchestration" "gRPC/8887"
        driver -> mlmd "Records metadata/lineage" "gRPC/8080"

        // External dependencies
        apiServer -> argoWorkflows "Creates Workflow CRs" "HTTPS/443 via K8s API"
        apiServer -> mysql "Stores pipeline metadata" "DB Protocol/3306"
        apiServer -> minio "Stores/retrieves artifacts" "HTTP(S)/9000,443"
        apiServer -> k8sAPI "Manages CRDs, pods, RBAC" "HTTPS/443"
        persistenceAgent -> k8sAPI "Watches Workflows" "HTTPS/443"
        scheduledWorkflow -> k8sAPI "Watches ScheduledWorkflows" "HTTPS/443"
        viewerCRD -> k8sAPI "Manages Viewer deployments" "HTTPS/443"
        cacheServer -> mysql "Checks cache entries" "DB Protocol/3306"
        launcher -> minio "Uploads artifacts" "HTTP(S)/9000,443"
        k8sAPI -> cacheServer "Pod admission webhook" "HTTPS/8443"

        // Platform interactions
        dspo -> dsp "Deploys and configures all components"
        dashboard -> ui "Links to pipeline UI" "HTTP"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Core" {
                background #4a90e2
                color #ffffff
            }
            element "Metadata" {
                background #6c8ebf
                color #ffffff
            }
            element "Runtime" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
