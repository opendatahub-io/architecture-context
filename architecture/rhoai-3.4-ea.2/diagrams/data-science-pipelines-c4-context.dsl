// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates, schedules, and monitors ML pipelines"
        admin = person "Platform Admin" "Deploys and configures DSP components via DSPO"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines v2 - End-to-end ML workflow orchestration on Kubernetes" {
            apiServer = container "ml-pipeline (API Server)" "Central API server for pipeline, run, experiment, and artifact management" "Go Service" {
                tags "Primary"
            }
            ui = container "ml-pipeline-ui" "Web UI for visualizing pipelines, runs, experiments, and artifacts" "React/TypeScript + Node.js Express" {
                tags "Primary"
            }
            persistenceAgent = container "ml-pipeline-persistenceagent" "Watches Argo Workflow CRs and syncs execution state to API server database" "Go Agent"
            scheduledWorkflow = container "ml-pipeline-scheduledworkflow" "Reconciles ScheduledWorkflow CRs to create Argo Workflows on schedule" "Go Controller"
            cacheServer = container "cache-server" "Mutating admission webhook for task output caching" "Go Webhook Server"
            driver = container "ml-pipeline-driver" "V2 pipeline step driver for input resolution and caching decisions" "Go Binary"
            launcher = container "ml-pipeline-launcher" "V2 pipeline step launcher for user container execution and artifact upload" "Go Binary"
            vizServer = container "ml-pipeline-visualizationserver" "Generates pipeline run visualizations" "Python Service"
            viewerCrd = container "ml-pipeline-viewer-crd" "Reconciles Viewer CRs for visualization server deployments" "Go Controller"
            mlmd = container "metadata-grpc-server" "ML Metadata gRPC server for artifact and execution lineage tracking" "Go/gRPC Service"
            envoy = container "metadata-envoy" "Envoy sidecar proxying gRPC-Web requests to MLMD" "Envoy Proxy"
            profileController = container "pipelines-profile-controller" "Manages per-namespace pipeline resources in multi-user mode" "Go Controller"
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Workflow execution engine for pipeline DAGs" {
            tags "External"
        }
        mysql = softwareSystem "MySQL/PostgreSQL" "Relational database for pipeline metadata and run state" {
            tags "External"
        }
        minio = softwareSystem "MinIO/S3 Storage" "S3-compatible object storage for pipeline artifacts and logs" {
            tags "External"
        }
        istio = softwareSystem "Istio Service Mesh" "mTLS, authorization policies, and traffic routing" {
            tags "External"
        }
        k8sApi = softwareSystem "Kubernetes API Server" "CRD management, pod lifecycle, admission webhooks" {
            tags "External"
        }

        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Deploys and manages all DSP components via DSPApplication CR" {
            tags "Internal RHOAI"
        }
        dashboard = softwareSystem "OpenShift AI Dashboard" "Provides pipeline management UI integration" {
            tags "Internal RHOAI"
        }

        // User relationships
        user -> dsp "Creates and monitors ML pipelines"
        user -> ui "Submits pipelines via web UI"
        admin -> dspo "Configures DSPApplication CR"

        // Internal container relationships
        ui -> apiServer "REST API calls" "HTTP/8888"
        persistenceAgent -> apiServer "Syncs workflow state" "HTTP-gRPC/8888-8887"
        apiServer -> mysql "Stores pipeline metadata" "MySQL/3306 or PG/5432"
        apiServer -> minio "Stores pipeline artifacts" "HTTP-HTTPS/9000-443"
        apiServer -> k8sApi "Creates Workflow CRs, auth checks" "HTTPS/443"
        scheduledWorkflow -> k8sApi "Watches ScheduledWorkflow CRs, creates Workflows" "HTTPS/443"
        persistenceAgent -> k8sApi "Watches Workflow CRs" "HTTPS/443"
        cacheServer -> mysql "Checks task cache entries" "MySQL/3306"
        launcher -> minio "Uploads artifacts" "HTTP-HTTPS/9000-443"
        launcher -> mlmd "Records execution metadata" "gRPC/8080"
        envoy -> mlmd "Proxies gRPC-Web requests" "gRPC/8080"

        // External relationships
        dsp -> argoWorkflows "Pipeline execution via Workflow CRs" "HTTPS/443 (K8s API)"
        dsp -> mysql "Pipeline metadata persistence" "MySQL/3306 or PG/5432"
        dsp -> minio "Artifact and pipeline storage" "HTTP-HTTPS/9000-443"
        dsp -> istio "Traffic routing, mTLS, authorization" ""
        dsp -> k8sApi "CRD management, pod lifecycle" "HTTPS/443"

        // Integration relationships
        dspo -> dsp "Deploys and manages all components"
        dashboard -> apiServer "Pipeline management UI integration" "HTTP/8888"
        k8sApi -> cacheServer "Admission webhook calls" "HTTPS/8443"
        argoWorkflows -> driver "Runs driver in step pods"
        driver -> launcher "Launches user containers"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Primary" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
