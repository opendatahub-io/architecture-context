/*
 * Model Registry - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/model-registry.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates, versions, and deploys ML models"
        mlEngineer = person "ML Engineer" "Manages model lifecycle and serving environments"

        modelRegistry = softwareSystem "Model Registry" "Central metadata registry for ML model lifecycle management" {
            proxy = container "Model Registry Proxy" "REST API server for CRUD operations on ML model metadata (v1alpha3)" "Go REST API, Port 8080"
            catalog = container "Model Catalog Server" "Curated model discovery from HuggingFace and MCP sources (v1alpha1)" "Go REST API, Port 8080"
            controller = container "InferenceService Controller" "Watches KServe InferenceService CRs and syncs state to registry" "Go controller-runtime"
            csi = container "CSI Storage Initializer" "Resolves model-registry:// URIs for KServe model loading" "Go CLI Tool"
            ui = container "Model Registry UI" "Browser-based UI for model registry management" "Node.js BFF, Port 8080"
            asyncJob = container "Async Upload Job" "Asynchronous model uploads from sources to S3/OCI destinations" "Python 3.11+"
        }

        kserve = softwareSystem "KServe" "ML model serving platform providing InferenceService CRDs" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS, traffic management, and authorization" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for OpenShift AI platform management" "Internal RHOAI"
        mysql = softwareSystem "MySQL" "Relational database for model registry metadata persistence" "External Database"
        postgresql = softwareSystem "PostgreSQL" "Relational database for catalog metadata and leader election" "External Database"
        huggingface = softwareSystem "HuggingFace Hub" "External model repository for catalog source sync" "External Service"
        k8sApi = softwareSystem "Kubernetes API" "Kubernetes control plane API server" "Platform"
        artifactStore = softwareSystem "Model Artifact Store" "S3/OCI storage for ML model artifacts" "External Storage"

        # User interactions
        dataScientist -> modelRegistry "Registers models, creates versions, tracks experiments"
        mlEngineer -> modelRegistry "Manages serving environments, deploys models"
        dataScientist -> ui "Browses and manages models via web UI"

        # Internal container relationships
        ui -> proxy "REST API calls" "HTTP/8080"
        controller -> proxy "Syncs InferenceService state" "HTTP/8080, Bearer Token"
        csi -> proxy "Resolves model-registry:// URIs" "HTTP/8080"
        asyncJob -> proxy "Uploads model metadata" "HTTP/8080"

        # External dependencies
        proxy -> mysql "Persists model metadata" "MySQL/3306, TLS 1.2+"
        catalog -> postgresql "Stores catalog data, leader election (pglock)" "PostgreSQL/5432"
        catalog -> huggingface "Syncs model catalog" "HTTPS/443, HF_API_KEY"
        controller -> k8sApi "Watches InferenceService CRs, updates labels" "HTTPS/443, SA Token"
        csi -> artifactStore "Downloads model artifacts" "S3/OCI/HTTP, Varies"

        # Internal ODH integrations
        modelRegistry -> kserve "Watches InferenceService CRDs, registers storage initializer"
        modelRegistry -> istio "mTLS sidecar injection, AuthorizationPolicy, DestinationRule"
        dashboard -> modelRegistry "Consumes REST API for model management views" "HTTP/8080, mTLS"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "External Database" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #999999
                color #ffffff
            }
            element "External Storage" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
