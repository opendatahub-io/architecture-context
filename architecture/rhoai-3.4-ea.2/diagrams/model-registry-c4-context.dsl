// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/model-registry.md

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Registers models, tracks versions, and manages ML artifacts"
        mlEngineer = person "ML Engineer" "Deploys models and manages inference services"

        // Main System
        modelRegistry = softwareSystem "Model Registry" "Central repository for ML model metadata - registered models, versions, artifacts, inference services, and serving environments" {
            proxyServer = container "Model Registry Proxy Server" "REST API (v1alpha3) for CRUD operations on models, versions, artifacts, inference services, serving environments" "Go REST API Service"
            catalogServer = container "Model Catalog Server" "Catalog API (v1alpha1) for browsing curated models from HuggingFace and MCP servers" "Go REST API Service"
            controller = container "Model Registry Controller" "Watches InferenceService CRs and syncs state with Model Registry" "Go Operator (controller-runtime)"
            storageInitializer = container "MR Storage Initializer" "Resolves model-registry:// URIs and downloads model artifacts for inference" "Go CLI / Init Container"
            uiBFF = container "Model Registry UI (BFF)" "Backend-for-Frontend proxy serving React SPA and proxying API calls" "Go HTTP Server"
            uiFrontend = container "Model Registry UI (Frontend)" "User interface for managing model registry entities" "React/TypeScript SPA (PatternFly)"
            asyncUploadJob = container "Async Upload Job" "Uploads models from sources (HuggingFace) to destinations (S3/OCI)" "Python Job"
            pythonClient = container "Python Client SDK" "Python SDK for interacting with Model Registry REST API" "Python Library"
        }

        // Internal ODH Systems
        kserve = softwareSystem "KServe" "Kubernetes-native model serving with InferenceService CRDs" "Internal ODH"
        dashboard = softwareSystem "OpenShift AI Dashboard" "RHOAI web console for managing AI/ML workloads" "Internal ODH"
        pipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration and automation" "Internal ODH"

        // External Systems
        istio = softwareSystem "Istio Service Mesh" "Service mesh providing mTLS, traffic routing, and AuthorizationPolicy" "External"
        mysql = softwareSystem "MySQL" "Relational database for model registry metadata persistence" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for catalog metadata and leader election" "External"
        huggingface = softwareSystem "HuggingFace Hub" "External model repository for curated model catalog" "External"
        modelStorage = softwareSystem "Model Storage (S3/OCI)" "Object storage for model artifacts" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Kubernetes control plane for CRD management" "External"

        // User Relationships
        dataScientist -> modelRegistry "Registers models, versions, and artifacts via REST API or UI"
        mlEngineer -> modelRegistry "Manages inference services and serving environments"

        // Internal Container Relationships
        uiFrontend -> uiBFF "HTTP requests" "HTTP/8080"
        uiBFF -> proxyServer "Proxy API calls" "HTTP/8080 mTLS"
        uiBFF -> catalogServer "Proxy catalog calls" "HTTP/8080 mTLS"
        uiBFF -> k8sAPI "Kubernetes API calls" "HTTPS/443"
        controller -> proxyServer "Sync InferenceService state" "HTTP/8080"
        controller -> k8sAPI "Watch/update InferenceService CRs" "HTTPS/443"
        storageInitializer -> proxyServer "Resolve model-registry:// URIs" "HTTP/8080"
        storageInitializer -> modelStorage "Download model artifacts" "HTTPS/443"
        asyncUploadJob -> proxyServer "Upload model metadata" "HTTP/8080"
        asyncUploadJob -> modelStorage "Upload model files" "HTTPS/443"
        pythonClient -> proxyServer "REST API calls" "HTTP/8080"
        proxyServer -> mysql "Model metadata persistence" "MySQL/3306"
        catalogServer -> postgresql "Catalog metadata and leader election" "PostgreSQL/5432"
        catalogServer -> huggingface "Fetch model metadata" "HTTPS/443"

        // ODH Internal Relationships
        kserve -> controller "Provides InferenceService CRDs" "Watch/HTTPS/443"
        kserve -> storageInitializer "Triggers via ClusterStorageContainer" ""
        dashboard -> modelRegistry "Embeds Model Registry UI" "HTTP/8080"
        pipelines -> modelRegistry "Registers models from pipeline steps" "HTTP/8080 mTLS"

        // External Relationships
        modelRegistry -> istio "mTLS, traffic routing, AuthorizationPolicy" ""
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
