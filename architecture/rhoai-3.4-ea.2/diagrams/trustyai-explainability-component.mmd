%% TrustyAI Explainability - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB
        Service["explainability-service<br/>(Quarkus REST Service)<br/>Port: 8080/TCP, 4443/TCP"]
        Core["explainability-core<br/>(Java Library)<br/>Fairness, Drift, Explainers"]
        Connectors["explainability-connectors<br/>(Java Library)<br/>gRPC KServe v2 Client"]
        Arrow["explainability-arrow<br/>(Java Library)<br/>Apache Arrow Integration"]

        Service -->|uses| Core
        Service -->|uses| Connectors
        Service -->|uses| Arrow
    end

    subgraph APIs["REST API Endpoints"]
        FairnessAPI["/metrics/group/fairness/*<br/>SPD, DIR"]
        DriftAPI["/metrics/drift/*<br/>KS-Test, FourierMMD, Meanshift"]
        ExplainerAPI["/explainers/local/*<br/>LIME, SHAP, CF, TSSaliency<br/>(ODH-only in RHOAI)"]
        ConsumerAPI["/consumer/kserve/v2<br/>Inference Payload Consumer"]
        MetricsAPI["/q/metrics<br/>Prometheus Metrics"]
    end

    Service --> FairnessAPI
    Service --> DriftAPI
    Service --> ExplainerAPI
    Service --> ConsumerAPI
    Service --> MetricsAPI

    %% External Dependencies
    ModelMesh["ModelMesh Serving"] -->|REST payload| ConsumerAPI
    KServe["KServe InferenceLogger"] -->|CloudEvents| Service
    Connectors -->|gRPC 8081/TCP<br/>KServe v2 Protocol| ModelServers["KServe/ModelMesh<br/>Model Servers"]

    %% Storage Backends
    Service -->|filesystem| PVC["PVC Storage<br/>/inputs (1Gi)"]
    Service -->|JDBC 3306/TCP| MariaDB["MariaDB/MySQL"]
    Service -->|HTTP 9000/TCP| MinIO["MinIO Object Storage"]

    %% Monitoring
    Prometheus["Prometheus/<br/>OpenShift Monitoring"] -->|scrape /q/metrics<br/>4s interval| MetricsAPI

    %% Operator Management
    Operator["TrustyAI Service Operator"] -->|deploys/manages| Service
    Operator -->|creates| ConfigMap["trustyai-config<br/>ConfigMap"]
    ConfigMap -->|configures| Service

