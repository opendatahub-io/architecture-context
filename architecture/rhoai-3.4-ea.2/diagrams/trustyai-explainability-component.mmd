%% TrustyAI Explainability - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "TrustyAI Explainability Service"
        subgraph "Quarkus REST Service (explainability-service)"
            FairnessEndpoints["Fairness Endpoints<br/>/metrics/group/fairness/spd<br/>/metrics/group/fairness/dir"]
            DriftEndpoints["Drift Endpoints<br/>/metrics/drift/meanshift<br/>/metrics/drift/kstest<br/>/metrics/drift/fouriermmd"]
            ExplainerEndpoints["Explainer Endpoints<br/>/explainers/local/lime<br/>/explainers/local/shap<br/>(Disabled in RHOAI)"]
            ConsumerEndpoint["Consumer Endpoint<br/>/consumer/kserve/v2"]
            CloudEventConsumer["CloudEvent Consumer<br/>Knative Funqy"]
            DataEndpoints["Data Endpoints<br/>/data/upload<br/>/data/download"]
            InfoEndpoint["Info Endpoint<br/>/info, /info/tags, /info/names"]
            HealthMetrics["Health & Metrics<br/>/q/health/ready<br/>/q/health/live<br/>/q/metrics"]
            PrometheusScheduler["PrometheusScheduler<br/>Periodic metric recalculation"]
        end

        subgraph "Reconcilers"
            MMReconciler["ModelMesh Inference<br/>Payload Reconciler"]
            KSReconciler["KServe Inference<br/>Payload Reconciler"]
        end

        subgraph "Core Library (explainability-core)"
            FairnessAlgo["Fairness Algorithms<br/>SPD, DIR"]
            DriftAlgo["Drift Detection<br/>KS Test, Meanshift, FourierMMD"]
            ExplainAlgo["Explainability<br/>LIME, SHAP, Counterfactual<br/>PDP, TSSaliency"]
        end

        subgraph "Connectors (explainability-connectors)"
            KServeV2HTTP["KServe v2 HTTP<br/>Prediction Provider"]
            KServeV2GRPC["KServe v2 gRPC<br/>Prediction Provider"]
        end

        subgraph "Storage Backends"
            PVCStorage["PVC Storage<br/>Flat file CSV"]
            MinioStorage["MinIO Storage<br/>S3-compatible"]
            HibernateStorage["Hibernate Storage<br/>MariaDB/MySQL"]
        end
    end

    %% Internal flows
    ConsumerEndpoint -->|reconciles| MMReconciler
    CloudEventConsumer -->|reconciles| KSReconciler
    MMReconciler -->|stores| PVCStorage
    MMReconciler -->|stores| MinioStorage
    MMReconciler -->|stores| HibernateStorage
    KSReconciler -->|stores| PVCStorage
    KSReconciler -->|stores| MinioStorage
    KSReconciler -->|stores| HibernateStorage

    FairnessEndpoints -->|uses| FairnessAlgo
    DriftEndpoints -->|uses| DriftAlgo
    ExplainerEndpoints -->|uses| ExplainAlgo
    ExplainerEndpoints -->|queries via| KServeV2GRPC
    PrometheusScheduler -->|computes| FairnessAlgo
    PrometheusScheduler -->|computes| DriftAlgo
    PrometheusScheduler -->|reads| PVCStorage

    %% External interactions
    ModelMesh["ModelMesh Serving"] -->|POST /consumer/kserve/v2<br/>8080/TCP HTTP| ConsumerEndpoint
    KServeLogger["KServe InferenceLogger"] -->|CloudEvents<br/>8080/TCP HTTP| CloudEventConsumer
    Prometheus["Prometheus"] -->|GET /q/metrics<br/>8080/TCP HTTP| HealthMetrics
    KServeModel["KServe Model Server"] <-->|gRPC v2| KServeV2GRPC
    MinioServer["MinIO/S3"] <-->|HTTP/HTTPS| MinioStorage
    Database["MariaDB/MySQL<br/>3306/TCP"] <-->|MySQL protocol| HibernateStorage
    Operator["TrustyAI Operator"] -.->|deploys & manages| ConsumerEndpoint

