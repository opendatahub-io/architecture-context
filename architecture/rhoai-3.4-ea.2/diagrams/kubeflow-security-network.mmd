    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress to User NS (Auth Mode)
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token forwarded<br/>(Auth Mode)"| KRBP

    %% Ingress to User NS (Non-Auth Mode)
    Gateway -.->|"HTTP/8888<br/>No encryption<br/>No auth<br/>(Non-Auth Mode)"| NotebookContainer

    %% kube-rbac-proxy to Notebook
    KRBP -->|"HTTP/8888<br/>plaintext (loopback)<br/>X-Auth-Request headers"| NotebookContainer

    %% kube-rbac-proxy to K8s API
    KRBP -->|"HTTPS/443<br/>TLS 1.2+<br/>TokenReview + SAR"| K8sAPI

    %% Controller to K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD resources"| K8sAPI

    %% Controller to OpenShift API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OSAPI

    %% K8s API to Webhook
    K8sAPI -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Webhook auth"| WebhookSvc

    %% HTTPRoute references
    HTTPRouteRes -.->|"parent ref"| Gateway
    RefGrant -.->|"allows cross-ns<br/>backend ref"| HTTPRouteRes

    %% service-ca provisions certs
    ServiceCA -.->|"provisions TLS certs"| WebhookSvc
    ServiceCA -.->|"provisions TLS certs"| KRBP

