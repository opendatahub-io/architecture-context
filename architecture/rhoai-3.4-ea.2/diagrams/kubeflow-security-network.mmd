    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph NotebookPod["Notebook Pod"]
            KRBP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS (service-ca)<br/>Auth: TokenReview + SAR"]
            NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>(loopback only)"]
        end

        KRBPSvc["{name}-kube-rbac-proxy Service<br/>ClusterIP 8443/TCP<br/>TLS (service-ca)"]

        NetPol1["{name}-ctrl-np<br/>Allow TCP/8888<br/>from controller NS"]
        NetPol2["{name}-kube-rbac-proxy-np<br/>Allow TCP/8443<br/>from any"]

        RefGrant["ReferenceGrant<br/>Allow HTTPRoute cross-NS refs"]
    end

    subgraph CentralNS["CENTRAL NAMESPACE (opendatahub)"]
        HTTPRoute["HTTPRoute<br/>nb-{ns}-{notebook}<br/>Parent: data-science-gateway"]
    end

    subgraph K8sCluster["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External flow
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Gateway to notebook (with auth)
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer token fwd"| KRBPSvc
    KRBPSvc --> KRBP

    %% kube-rbac-proxy auth flow
    KRBP -->|"HTTPS/443<br/>TokenReview<br/>SA token"| K8sAPI
    KRBP -->|"HTTPS/443<br/>SubjectAccessReview<br/>SA token"| K8sAPI

    %% kube-rbac-proxy to notebook
    KRBP -->|"HTTP/8888<br/>loopback<br/>X-Auth-Request headers"| NotebookContainer

    %% Controller flows
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token<br/>Watch Notebooks"| K8sAPI
    Controller -->|"creates"| HTTPRoute
    Controller -->|"creates"| RefGrant
    Controller -->|"creates"| NetPol1
    Controller -->|"creates"| NetPol2
    Controller -->|"creates"| KRBPSvc

    %% HTTPRoute references
    HTTPRoute -.->|"parent ref"| Gateway
    HTTPRoute -.->|"backend ref<br/>(cross-NS via ReferenceGrant)"| KRBPSvc

    %% Webhook flow
    K8sAPI -->|"HTTPS/443<br/>TLS (service-ca)<br/>API server auth"| WebhookSvc

