// C4 Context Diagram - Workload Variant Autoscaler
// Generated by: Claude Opus 4.6

workspace {
    model {
        admin = person "Platform Admin" "Configures autoscaling parameters via ConfigMaps"
        datascientist = person "Data Scientist" "Creates VariantAutoscaling CRs to define model variants"

        wva = softwareSystem "Workload Variant Autoscaler" "Kubernetes controller that performs intelligent autoscaling for LLM inference model servers based on saturation metrics, GPU capacity, and cost optimization" {
            vaController = container "VariantAutoscaling Controller" "Watches VariantAutoscaling CRs, applies optimization decisions, updates status" "Go controller-runtime Reconciler"
            ipController = container "InferencePool Controller" "Watches InferencePool CRs, tracks pool endpoint data" "Go controller-runtime Reconciler"
            cmController = container "ConfigMap Controller" "Watches ConfigMaps for scaling configuration, supports global/namespace overrides" "Go controller-runtime Reconciler"
            satEngine = container "Saturation Engine" "Runs saturation-based analysis using Prometheus metrics to compute desired replica counts" "Go background loop"
            sfzEngine = container "Scale-from-Zero Engine" "Handles scale-from-zero by directly scaling targets via scale subresource API" "Go background loop"
            collector = container "Collector / Prometheus Source" "Queries Prometheus for vLLM metrics with configurable TTL caching" "Go metrics client"
            actuator = container "Actuator" "Emits WVA custom Prometheus metrics (wva_desired_replicas, wva_desired_ratio)" "Go metrics emitter"
            directActuator = container "Direct Actuator" "Scales Deployments/StatefulSets via Kubernetes scale subresource" "Go scale client"
            datastore = container "Datastore" "In-memory store tracking namespace associations, InferencePool data, config state" "Go in-memory cache"
        }

        prometheus = softwareSystem "Prometheus" "OpenShift cluster monitoring - metrics backend for vLLM metrics and WVA metric emission" "External"
        vllm = softwareSystem "vLLM Inference Servers" "LLM inference model servers providing KV cache utilization, queue depth, request rate metrics" "External"
        k8sapi = softwareSystem "Kubernetes API Server" "Cluster API for CRD watches, status updates, and scale subresource operations" "External"
        hpakeda = softwareSystem "HPA / KEDA" "External autoscaler that reads WVA metrics and performs actual pod scaling" "External"
        gatewayapi = softwareSystem "Gateway API Inference Extension" "InferencePool CRD for workload-aware scheduling integration" "External"
        epp = softwareSystem "EPP (Endpoint Picker)" "Inference scheduler providing flow control queue metrics for scale-to-zero" "Internal RHOAI"
        promOperator = softwareSystem "Prometheus Operator" "ServiceMonitor CRD for configuring Prometheus scraping" "External"

        // Person interactions
        datascientist -> wva "Creates VariantAutoscaling CR via kubectl"
        admin -> wva "Configures scaling parameters via ConfigMaps"

        // WVA external interactions
        wva -> prometheus "Queries vLLM metrics" "HTTPS/443, Bearer Token"
        wva -> k8sapi "Watches CRDs, updates status, scale subresource" "HTTPS/443, SA Token"
        wva -> epp "Queries flow control queue metrics" "HTTPS, Bearer Token"
        prometheus -> vllm "Scrapes inference metrics"
        hpakeda -> wva "Reads wva_desired_ratio metric" "HTTPS/8443, Bearer Token"
        hpakeda -> k8sapi "Scales target pods" "HTTPS/443, SA Token"
        gatewayapi -> wva "InferencePool CRs watched by controller"
        promOperator -> wva "ServiceMonitor configures scraping"

        // Internal container interactions
        satEngine -> collector "Requests vLLM metrics"
        collector -> prometheus "Queries Prometheus API" "HTTPS/443"
        satEngine -> actuator "Emits scaling metrics"
        sfzEngine -> epp "Reads EPP queue metrics" "HTTPS"
        sfzEngine -> directActuator "Triggers scale-from-zero"
        directActuator -> k8sapi "Scale subresource API" "HTTPS/443"
        cmController -> datastore "Updates configuration"
        ipController -> datastore "Tracks InferencePool data"
        vaController -> k8sapi "Updates CR status" "HTTPS/443"
    }

    views {
        systemContext wva "SystemContext" {
            include *
            autoLayout
        }

        container wva "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
