/*
 * C4 Context Diagram: Workload Variant Autoscaler
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/workload-variant-autoscaler.md
 */

workspace {
    model {
        user = person "ML Engineer / Platform Admin" "Configures autoscaling policies for LLM inference variants"

        wva = softwareSystem "Workload Variant Autoscaler (WVA)" "Intelligent autoscaler for LLM inference model server replicas based on saturation metrics" {
            vaController = container "VariantAutoscaling Controller" "Reconciles VariantAutoscaling CRs, resolves scale targets, updates status" "Go Controller (controller-runtime)"
            ipController = container "InferencePool Controller" "Reconciles InferencePool CRs, tracks endpoint pools in datastore" "Go Controller (controller-runtime)"
            cmController = container "ConfigMap Controller" "Watches ConfigMaps for saturation and scale-to-zero configuration" "Go Controller (controller-runtime)"
            saturationEngine = container "Saturation Engine" "Collects Prometheus metrics, runs saturation analysis, computes optimal replica counts" "Background Engine Loop"
            scaleFromZeroEngine = container "Scale-from-Zero Engine" "Monitors request traffic, triggers scale-up for idle deployments" "Background Engine Loop"
            actuator = container "Actuator" "Emits WVA scaling metrics for consumption by HPA/KEDA" "Prometheus Metrics Emitter"
            collector = container "Collector" "Gathers cluster state and vLLM server metrics from Prometheus" "Metrics Collector"
            datastore = container "Datastore" "Tracks namespaces, InferencePool endpoints, shared state" "In-memory Store"
            decisionCache = container "Decision Cache" "Enables saturation engine to trigger VA reconciliation" "Shared Cache"
        }

        prometheus = softwareSystem "Prometheus / Thanos Querier" "Metrics aggregation and querying (OpenShift Monitoring)" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API for CRD management, deployment scaling, leader election" "External"
        hpa = softwareSystem "HPA / KEDA" "Horizontal Pod Autoscaler / Event-driven autoscaler" "External"
        prometheusOperator = softwareSystem "Prometheus Operator" "Manages ServiceMonitor CRs for metrics scraping" "External"
        gatewayApiExt = softwareSystem "Gateway API Inference Extension" "Provides InferencePool CRDs for endpoint pool tracking" "Internal RHOAI"
        vllm = softwareSystem "vLLM Inference Servers" "LLM model servers exposing saturation metrics" "Internal RHOAI"

        # User interactions
        user -> wva "Creates VariantAutoscaling CRs via kubectl/oc"

        # WVA to external systems
        wva -> prometheus "Queries vLLM saturation metrics (KV cache, queue depth)" "HTTPS/443, TLS 1.2+, Bearer Token"
        wva -> k8sApi "Manages CRDs, scales Deployments, watches ConfigMaps" "HTTPS/443, TLS 1.2+, Bearer Token"
        wva -> gatewayApiExt "Watches InferencePool resources" "Kubernetes API"

        # External systems to WVA
        prometheusOperator -> wva "Scrapes WVA metrics via ServiceMonitor" "HTTPS/8443, TLS, Bearer Token"
        hpa -> prometheus "Reads WVA scaling metrics" "HTTPS/443"

        # Indirect relationships
        vllm -> prometheus "Exposes inference metrics" "Prometheus scraping"

        # Internal container relationships
        saturationEngine -> collector "Collects metrics"
        collector -> prometheus "Queries PromQL" "HTTPS/443"
        saturationEngine -> decisionCache "Stores decisions"
        decisionCache -> vaController "Triggers reconciliation"
        vaController -> k8sApi "Updates VA status" "HTTPS/443"
        scaleFromZeroEngine -> prometheus "Queries request counts" "HTTPS/443"
        scaleFromZeroEngine -> k8sApi "Scales Deployments" "HTTPS/443"
        ipController -> datastore "Updates endpoint pools"
        cmController -> saturationEngine "Propagates config changes"
        actuator -> prometheusOperator "Serves /metrics" "HTTPS/8443"
    }

    views {
        systemContext wva "SystemContext" {
            include *
            autoLayout
        }

        container wva "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
