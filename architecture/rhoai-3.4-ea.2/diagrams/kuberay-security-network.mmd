%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>HTTPRoute: /ray/{ns}/{cluster}"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Enforced)"]
        direction TB

        subgraph NS_Operator["Namespace: {operator-namespace}"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP<br/>Probes: 8081/TCP"]
            Webhook["Admission Webhook<br/>9443/TCP HTTPS<br/>OpenShift serving cert"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            HeadPod["Ray Head Pod<br/>UID: 1000 (SCC)<br/>6379/TCP (GCS)<br/>8265/TCP (Dashboard)<br/>10001/TCP (Client)<br/>8080/TCP (Metrics)"]
            KRBPSidecar["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>→ 127.0.0.1:8265"]
            WorkerPods["Ray Worker Pods<br/>UID: 1000 (SCC)<br/>NP: intra-cluster only"]
            HeadNP["NetworkPolicy: {cluster}-head<br/>Intra-cluster + same-ns + operator + gateway"]
            WorkerNP["NetworkPolicy: {cluster}-workers<br/>Intra-cluster only"]
        end

        subgraph NS_Platform["Namespace: {platform-namespace}"]
            HTTPRoute["HTTPRoute CRs<br/>ParentRef: data-science-gateway<br/>BackendRef: {cluster}-head-svc"]
            RefGrant["ReferenceGrant CRs<br/>Cross-namespace access"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Configurable encryption<br/>Password auth (optional)"]
        CertManager["cert-manager<br/>CRD-based<br/>Issuer + Certificate"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS<br/>Gang scheduling"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Ingress to cluster
    Gateway -->|"HTTPS/8443<br/>TLS<br/>kube-rbac-proxy auth"| KRBPSidecar
    KRBPSidecar -->|"HTTP/8265<br/>plaintext (loopback)"| HeadPod

    %% Auth flow
    KRBPSidecar -->|"HTTPS/443<br/>TokenReview + SAR"| K8sAPI

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"HTTP/8265<br/>plaintext<br/>in-cluster"| HeadPod

    %% HTTPRoute references
    HTTPRoute -.->|"ParentRef"| Gateway
    RefGrant -.->|"enables cross-ns"| HTTPRoute

    %% Intra-cluster communication
    HeadPod <-->|"TCP/6379, 10001<br/>mTLS (cert-manager)"| WorkerPods

    %% Optional external
    HeadPod -.->|"TCP/6379<br/>configurable"| Redis

    %% cert-manager
    Operator -->|"CRD: Issuer, Certificate"| CertManager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef netpolicy fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class Operator,Webhook,HeadPod,KRBPSidecar,WorkerPods,HTTPRoute,RefGrant internal
    class Redis,CertManager,Volcano externalservice
    class K8sAPI controlplane
    class HeadNP,WorkerNP netpolicy
