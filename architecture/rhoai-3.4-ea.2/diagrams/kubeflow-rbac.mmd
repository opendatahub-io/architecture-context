graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["odh-notebook-controller-manager<br/>(opendatahub namespace)"]
        SA_Notebook["{notebook-name}<br/>({notebook-namespace})<br/><i>Dynamic - per notebook</i>"]
    end

    subgraph StaticBindings["Static Cluster Role Bindings"]
        CRB_Manager["odh-notebook-controller-<br/>manager-rolebinding<br/>(Cluster-scoped)"]
    end

    subgraph DynamicBindings["Dynamic Bindings (per notebook)"]
        CRB_AuthDeleg["{notebook-name}-rbac-<br/>{namespace}-auth-delegator<br/>(ClusterRoleBinding)"]
        RB_Elyra["elyra-pipelines-{notebook-name}<br/>(RoleBinding in user NS)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_NotebooksAdmin["notebooks-admin<br/><i>(aggregates notebooks-edit)</i>"]
        CR_NotebooksEdit["notebooks-edit"]
        CR_NotebooksView["notebooks-view"]
    end

    subgraph Roles["Namespace Roles"]
        R_LeaderElection["leader-election-role<br/>(controller namespace)"]
        R_DSPAccess["ds-pipeline-user-access-dspa<br/>(user namespace)"]
    end

    subgraph ManagerResources["manager-role API Resources"]
        Res_Core["core<br/>configmaps, secrets,<br/>serviceaccounts, services"]
        Res_Auth["authentication.k8s.io<br/>tokenreviews"]
        Res_Authz["authorization.k8s.io<br/>subjectaccessreviews"]
        Res_Proxy["config.openshift.io<br/>proxies"]
        Res_DSPA["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications,<br/>datasciencepipelinesapplications/api"]
        Res_Gateway["gateway.networking.k8s.io<br/>gateways, httproutes,<br/>referencegrants"]
        Res_Image["image.openshift.io<br/>imagestreams"]
        Res_Kubeflow["kubeflow.org<br/>notebooks, notebooks/finalizers,<br/>notebooks/status"]
        Res_NetPol["networking.k8s.io<br/>networkpolicies,<br/>networkpolicies/finalizers"]
        Res_OAuth["oauth.openshift.io<br/>oauthclients"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles"]
        Res_Route["route.openshift.io<br/>routes"]
    end

    subgraph UserResources["User Role Resources"]
        Res_UserNotebooks["kubeflow.org<br/>notebooks, notebooks/status"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        Res_Leases["coordination.k8s.io<br/>leases"]
        Res_ConfigMaps["core<br/>configmaps"]
        Res_Events["core<br/>events"]
    end

    %% Static bindings
    SA_Manager -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    %% Manager role permissions
    CR_Manager -->|"create, get, list,<br/>patch, update, watch"| Res_Core
    CR_Manager -->|"create"| Res_Auth
    CR_Manager -->|"create"| Res_Authz
    CR_Manager -->|"get, list, watch"| Res_Proxy
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Res_DSPA
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Res_Gateway
    CR_Manager -->|"get, list, watch"| Res_Image
    CR_Manager -->|"get, list, patch,<br/>update, watch"| Res_Kubeflow
    CR_Manager -->|"create, get, list,<br/>patch, update, watch"| Res_NetPol
    CR_Manager -->|"delete, get, list,<br/>patch, update, watch"| Res_OAuth
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Res_RBAC
    CR_Manager -->|"get, list, watch"| Res_Route

    %% Dynamic bindings
    SA_Notebook -->|bound via| CRB_AuthDeleg
    CRB_AuthDeleg -->|grants| CR_AuthDeleg
    SA_Notebook -->|bound via| RB_Elyra
    RB_Elyra -->|grants| R_DSPAccess

    %% User roles
    CR_NotebooksAdmin -->|aggregates| CR_NotebooksEdit
    CR_NotebooksEdit -->|"get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"| Res_UserNotebooks
    CR_NotebooksView -->|"get, list, watch"| Res_UserNotebooks

    %% Leader election
    SA_Manager -->|leader election| R_LeaderElection
    R_LeaderElection -->|"full CRUD"| Res_Leases
    R_LeaderElection -->|"full CRUD"| Res_ConfigMaps
    R_LeaderElection -->|"create, patch"| Res_Events

