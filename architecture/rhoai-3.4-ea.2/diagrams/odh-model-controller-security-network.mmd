        subgraph NS_Serving["Namespace: {serving-namespace} (dynamic)"]
            PredictorSvc["Predictor Service<br/>8080/8443 TCP<br/>HTTP/HTTPS"]
            ISVCMetrics["{isvc}-metrics Service<br/>{prom-port}/TCP HTTP"]
            RayTLS["ray-tls Secret<br/>(per-pod certs)"]
