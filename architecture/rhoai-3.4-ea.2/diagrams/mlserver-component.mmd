graph TB
    subgraph MLServerCore["MLServer Core (Python Service)"]
        direction TB
        DataPlane[DataPlane<br/>V2 Protocol Handler]
        ModelRegistry[MultiModelRegistry<br/>Model Lifecycle Manager]
        Batcher[AdaptiveBatcher<br/>Request Batching]
        Cache[ResponseCache<br/>Prediction Caching]
        PoolRegistry[InferencePoolRegistry<br/>Parallel Workers]
    end

    subgraph Servers["Network Servers"]
        RESTServer["RESTServer<br/>FastAPI/Uvicorn<br/>Port 8080/TCP"]
        GRPCServer["GRPCServer<br/>grpcio<br/>Port 8081/TCP"]
        MetricsServer["MetricsServer<br/>FastAPI/Uvicorn<br/>Port 8082/TCP"]
        KafkaServer["KafkaServer (Optional)<br/>aiokafka<br/>Port 9092/TCP"]
    end

    subgraph Runtimes["Inference Runtimes (Plugins)"]
        SKLearn[mlserver-sklearn<br/>Scikit-learn]
        XGBoost[mlserver-xgboost<br/>XGBoost]
        LightGBM[mlserver-lightgbm<br/>LightGBM]
        ONNX[mlserver-onnx<br/>ONNX Runtime]
    end

    subgraph CLI["CLI"]
        CLITool["mlserver CLI<br/>(click)"]
    end

    %% Internal connections
    RESTServer -->|inference requests| DataPlane
    GRPCServer -->|inference requests| DataPlane
    KafkaServer -->|inference requests| DataPlane
    DataPlane -->|load/unload| ModelRegistry
    DataPlane -->|batch requests| Batcher
    DataPlane -->|cache lookups| Cache
    ModelRegistry -->|manage workers| PoolRegistry
    ModelRegistry -->|load runtime| Runtimes

    %% External integrations
    Client[Client] -->|REST V2 Protocol| RESTServer
    Client -->|gRPC V2 Protocol| GRPCServer
    Prometheus[Prometheus] -->|scrape /metrics| MetricsServer
    KafkaBroker[Kafka Broker] <-->|events| KafkaServer
    OTELCollector[OpenTelemetry<br/>Collector] <---|trace export| MLServerCore
    ModelStorage[Model Storage<br/>/mnt/models] -->|model artifacts| ModelRegistry

    %% Platform
    KServe[KServe<br/>InferenceService] -->|manages container| MLServerCore
    PlatformGateway[Platform Gateway<br/>Envoy] -->|routes traffic| RESTServer
    PlatformGateway -->|routes traffic| GRPCServer

    CLITool -->|starts| MLServerCore

