%% RBAC Visualization: Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Note: This component does not define RBAC resources directly.
%% RBAC is managed by ODH Notebook Controller and rhods-operator.
%% This diagram shows the runtime RBAC model for workbench access.

graph TD
    subgraph Users
        DS["Data Scientist<br/>(OpenShift User)"]
    end

    subgraph AuthenticationLayer["Authentication Layer"]
        OIDC["OpenShift OAuth/OIDC<br/>443/TCP HTTPS"]
        GW["OpenShift Gateway<br/>(Envoy)"]
    end

    subgraph AuthorizationLayer["Authorization Layer - per Workbench Pod"]
        KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS"]
        SAR["SubjectAccessReview<br/>(Kubernetes RBAC check)"]
    end

    subgraph WorkbenchAccessControl["Workbench Access Control"]
        direction TB
        NS["Namespace: user-project"]

        subgraph RBACResources["RBAC Resources - managed by ODH Notebook Controller"]
            Role["Role<br/>(namespace-scoped)"]
            RB["RoleBinding<br/>(user to role)"]
        end

        subgraph ControlledResources["Controlled Resources"]
            NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]
            NotebookPod["Workbench Pod"]
            NotebookSvc["Workbench Service"]
        end
    end

    subgraph ContainerSecurity["Container Security"]
        direction TB
        NonRoot["USER 1001<br/>(non-root)"]
        UBI["Base: UBI 9"]
        SCC["OpenShift SCC<br/>(restricted)"]
        FIPS["FIPS Compliant"]
    end

    subgraph Secrets
        RHELSecret["rhel-subscription-secret<br/>(Opaque)<br/>RHEL sub for RStudio BuildConfig<br/>Manual provisioning, No auto-rotate"]
    end

    DS -->|"authenticates via"| OIDC
    OIDC -->|"identity passed to"| GW
    GW -->|"HTTPS/8443"| KRBAC
    KRBAC -->|"performs"| SAR
    SAR -->|"checks"| RB
    RB -->|"grants permissions via"| Role
    Role -->|"access to"| NotebookCR
    Role -->|"access to"| NotebookPod
    Role -->|"access to"| NotebookSvc

    NotebookPod -->|"runs as"| NonRoot
    NotebookPod -->|"built from"| UBI
    NotebookPod -->|"constrained by"| SCC
    NotebookPod -->|"enforces"| FIPS

