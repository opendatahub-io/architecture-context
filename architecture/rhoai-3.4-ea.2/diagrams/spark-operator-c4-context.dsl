// Spark Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/spark-operator.md

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Submits and manages Spark applications on Kubernetes"
        clientApp = person "Client Application" "Connects to Spark Connect server for interactive Spark sessions"

        // Main System
        sparkOperator = softwareSystem "Spark Operator" "Kubernetes operator that manages the lifecycle of Apache Spark applications on OpenShift" {
            controller = container "Controller Deployment" "Watches SparkApplication, ScheduledSparkApplication, SparkConnect CRs; creates/manages driver pods, executor pods, services, ingresses" "Go Operator (controller-runtime)"
            webhook = container "Webhook Server" "Mutates Spark pods (inject config, volumes, env vars), validates/defaults SparkApplication and ScheduledSparkApplication CRs" "Admission Webhook (Go)"
            sparkAppController = component "SparkApplication Controller" "Manages full lifecycle: submission, monitoring, restart, TTL cleanup" "Reconciler" {
                tags "Reconciler"
            }
            scheduledController = component "ScheduledSparkApplication Controller" "Cron-based scheduling with concurrency policies" "Reconciler" {
                tags "Reconciler"
            }
            connectController = component "SparkConnect Controller" "Manages Spark Connect server pods, services, and ConfigMaps" "Reconciler" {
                tags "Reconciler"
            }
            batchScheduler = component "Batch Scheduler Interface" "Pluggable scheduler support for Volcano and kube-scheduler-plugins" "Plugin" {
                tags "Plugin"
            }
        }

        // External Dependencies
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (>= 1.25.0)" {
            tags "External"
        }
        apacheSpark = softwareSystem "Apache Spark" "Base Spark runtime (4.0.1) for driver/executor containers" {
            tags "External"
        }
        certManager = softwareSystem "cert-manager" "Optional self-signed certificate management for webhook TLS" {
            tags "External" "Optional"
        }
        volcanoScheduler = softwareSystem "Volcano Scheduler" "Optional batch scheduler for gang scheduling (v1.10.0)" {
            tags "External" "Optional"
        }
        kubeSchedulerPlugins = softwareSystem "kube-scheduler-plugins" "Optional alternative batch scheduler (v0.32.7)" {
            tags "External" "Optional"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "External"
        }

        // Internal ODH Dependencies
        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Deploys spark-operator via kustomize overlay" {
            tags "Internal RHOAI"
        }

        // Managed Resources
        sparkDriverPod = softwareSystem "Spark Driver Pod" "Runs Spark driver process, creates executor pods" {
            tags "Managed"
        }
        sparkExecutorPods = softwareSystem "Spark Executor Pods" "Run Spark executor processes for distributed computation" {
            tags "Managed"
        }
        sparkConnectServer = softwareSystem "Spark Connect Server" "gRPC server for interactive Spark sessions" {
            tags "Managed"
        }

        // Relationships
        dataScientist -> sparkOperator "Creates SparkApplication / ScheduledSparkApplication / SparkConnect CRs via kubectl" "HTTPS/443"
        clientApp -> sparkConnectServer "Connects for interactive sessions" "gRPC/15002"

        rhoaiOperator -> sparkOperator "Deploys via kustomize overlay" "Kustomize"

        sparkOperator -> kubernetes "CRUD operations on pods, services, ingresses, CRDs" "HTTPS/443"
        sparkOperator -> sparkDriverPod "Creates and monitors driver pods"
        sparkOperator -> sparkExecutorPods "Manages executor lifecycle (via driver)"
        sparkOperator -> sparkConnectServer "Creates Connect server pods and services"

        controller -> webhook "API server routes admission requests" "HTTPS/9443"
        controller -> kubernetes "Watch CRs, create/update resources" "HTTPS/443"
        webhook -> kubernetes "Read SparkApplications, pods" "HTTPS/443"

        sparkOperator -> certManager "Optional: TLS certificate management" "Kubernetes API"
        sparkOperator -> volcanoScheduler "Optional: gang scheduling via PodGroup CRDs" "HTTPS/443"
        sparkOperator -> kubeSchedulerPlugins "Optional: alternative batch scheduling" "Kubernetes API"

        prometheus -> sparkOperator "Scrapes metrics endpoint" "HTTP/8080"

        sparkDriverPod -> kubernetes "Creates executor pods" "HTTPS/443"
        sparkExecutorPods -> sparkDriverPod "RPC communication" "TCP/7078,7079"
    }

    views {
        systemContext sparkOperator "SystemContext" {
            include *
            autoLayout
        }

        container sparkOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Optional" {
                background #bbbbbb
                color #ffffff
                border dashed
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #45b7d1
                color #ffffff
            }
            element "Reconciler" {
                background #4a90e2
                color #ffffff
            }
            element "Plugin" {
                background #e8e8e8
                color #333333
            }
        }
    }
}
