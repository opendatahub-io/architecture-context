    EvalHub -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR + Job CRUD"| K8sAPI
    EvalHub -->|"HTTP(S)/5000<br/>TLS 1.2+<br/>Projected SA Token"| MLflow
    EvalHub -->|"OTLP gRPC/4317"| OTELCollector
    EvalHub -->|"TCP/5432"| PostgreSQL

    EvalHub -->|"creates batch/v1 Jobs"| AdapterPods

    InitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials"| S3
    Adapter -->|"HTTPS<br/>TLS 1.2+<br/>API Key/Token"| ModelEP
    Adapter -->|"HTTP(S)/8080<br/>Bearer Token<br/>status callback"| EvalHub
    Adapter -->|"HTTP(S)/5000<br/>Projected SA Token"| MLflow

    Prometheus -->|"HTTP(S)/8080<br/>scrape /metrics"| EvalHub

