%% Security Network Diagram - Workload Variant Autoscaler
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (No External Ingress)"]
        direction TB
        NoIngress["No external ingress configured<br/>WVA operates entirely within cluster"]
    end

    subgraph Cluster["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_WVA["Namespace: workload-variant-autoscaler-system"]
            direction TB
            WVA["WVA Controller Manager<br/>SA: controller-manager<br/>runAsNonRoot: true<br/>seccomp: RuntimeDefault<br/>caps: drop ALL"]
            MetricsEP["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS (self-signed/cert-managed)<br/>Auth: Bearer Token<br/>(TokenReview + SAR)"]
            HealthEP["Health Probes<br/>8081/TCP HTTP<br/>plaintext<br/>Auth: None"]
            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP"]
            EPPSA["epp-metrics-reader SA<br/>Token: epp-metrics-token"]
        end

        subgraph NS_Monitoring["OpenShift Cluster Monitoring"]
            Prometheus["Prometheus<br/>443/TCP HTTPS<br/>TLS"]
        end

        subgraph NS_K8s["Kubernetes Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS"]
        end

        subgraph NS_Autoscaler["Autoscaler Namespace"]
            HPAKEDA["HPA / KEDA<br/>External Autoscaler"]
        end

        subgraph NS_Inference["Inference Namespaces"]
            vLLM["vLLM Inference Servers"]
            EPP["EPP (Endpoint Picker)<br/>HTTPS TLS"]
        end
    end

    %% Network Policy
    NP["NetworkPolicy: allow-metrics-traffic<br/>From: ns with label metrics=enabled<br/>Port: 8443/TCP"]

    %% Flows
    WVA -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA token)"| Prometheus
    WVA -->|"HTTPS/443<br/>TLS<br/>SA token<br/>Watch CRDs, scale subresource"| K8sAPI
    WVA -->|"HTTPS/varies<br/>TLS<br/>Bearer Token (epp-metrics-token)"| EPP
    Prometheus -->|"scrapes"| vLLM
    HPAKEDA -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>GET /metrics"| MetricsSvc
    MetricsSvc -->|"8443"| MetricsEP
    HPAKEDA -->|"HTTPS/443<br/>TLS<br/>SA token<br/>scale subresource"| K8sAPI
    NP -.->|"protects"| MetricsSvc

