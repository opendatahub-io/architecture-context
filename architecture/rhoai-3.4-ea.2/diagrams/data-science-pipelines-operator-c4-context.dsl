// Data Science Pipelines Operator - C4 Context Diagram
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/data-science-pipelines-operator.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs ML pipelines via Dashboard or Notebooks"
        platformAdmin = person "Platform Admin" "Configures DSPA CRs to provision pipeline environments"

        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Kubernetes operator managing lifecycle of Data Science Pipelines application stacks (KFP v2)" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, deploys and reconciles all DSP sub-components" "Go Operator (controller-runtime)"
            apiServer = container "KFP API Server" "REST (8888) and gRPC (8887) endpoints for pipeline CRUD operations" "Go Service"
            kubeRBACProxy = container "kube-rbac-proxy" "Authenticates external access via SubjectAccessReview" "Sidecar (8443)"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo Workflows to API server DB" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow" "Manages cron-scheduled pipeline runs via ScheduledWorkflow CRDs" "Go Service"
            workflowController = container "Workflow Controller" "Argo Workflow Controller managing Workflow CRs for pipeline execution" "Go Service"
            mlmdGRPC = container "MLMD gRPC Server" "ML Metadata gRPC server for artifact and execution lineage tracking (8080)" "gRPC Service"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD gRPC with kube-rbac-proxy sidecar (9090/8443)" "Envoy"
            mariaDB = container "MariaDB" "Default database backend for pipeline metadata (3306)" "MariaDB 10.x"
            minio = container "Minio" "Default object storage for pipeline artifacts (9000)" "Minio"
            webhook = container "Webhook Server" "Validating/Mutating webhook for PipelineVersion CRs (9443)" "Go Service"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys DSPO via kustomize overlays" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Pipeline management UI" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches (Notebooks)" "Notebook pipeline submissions" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics monitoring and alerting" "Platform"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller providing external access via Routes" "Platform"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Auto-generates TLS certificates for service-to-service communication" "Platform"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "Platform"

        kserve = softwareSystem "KServe" "ML model serving platform" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare / KubeRay" "Distributed computing framework" "Internal RHOAI"

        externalDB = softwareSystem "External Database" "External MariaDB/MySQL for pipeline metadata (optional)" "External"
        externalS3 = softwareSystem "External S3 Storage" "External S3-compatible object store for pipeline artifacts (optional)" "External"

        // Relationships - Users
        dataScientist -> dashboard "Manages pipelines via UI"
        dataScientist -> workbenches "Submits pipelines from notebooks"
        platformAdmin -> dspo "Creates DSPA CRs via kubectl"

        // Relationships - Deployment
        rhodsOperator -> dspo "Deploys via kustomize overlays"

        // Relationships - External access
        dashboard -> openshiftRouter "Pipeline API calls" "HTTPS/443"
        openshiftRouter -> kubeRBACProxy "Reencrypt TLS" "HTTPS/8443"
        kubeRBACProxy -> apiServer "Proxied authenticated request" "HTTPS/8888"
        workbenches -> apiServer "Pipeline submissions" "HTTPS/8888"

        // Relationships - Internal
        controller -> kubernetesAPI "Watches DSPA CRs, applies templates" "HTTPS/443"
        controller -> mariaDB "Health check" "MySQL/3306"
        controller -> minio "Health check" "HTTP/9000"

        apiServer -> mariaDB "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores pipeline artifacts" "HTTP/9000"
        apiServer -> kubernetesAPI "Creates Workflow CRs" "HTTPS/443"

        persistenceAgent -> apiServer "Updates run status" "HTTPS/8888"
        workflowController -> kubernetesAPI "Manages pods for pipeline tasks" "HTTPS/443"
        mlmdEnvoy -> mlmdGRPC "Proxies gRPC requests" "gRPC/8080"

        // Relationships - Platform
        openshiftServiceCA -> dspo "Provisions TLS certificates"
        prometheus -> controller "Scrapes metrics" "HTTP/8080"
        prometheus -> apiServer "Scrapes metrics" "HTTP(S)/8888"

        // Relationships - Integration
        apiServer -> kserve "Creates InferenceService CRs" "HTTPS/443"
        apiServer -> codeflare "Creates AppWrappers, RayClusters" "HTTPS/443"

        // Relationships - External services
        apiServer -> externalDB "Pipeline metadata (optional)" "MySQL/3306 TLS"
        apiServer -> externalS3 "Pipeline artifacts (optional)" "HTTPS/443"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #85bbf0
                color #000000
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
