// C4 Context Diagram - Data Science Pipelines Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs ML pipelines"
        platformAdmin = person "Platform Admin" "Manages DSP infrastructure via DSPA CRs"

        dspo = softwareSystem "Data Science Pipelines Operator" "Kubernetes operator managing the lifecycle of Kubeflow Pipelines v2 backend on OpenShift" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, reconciles DSP sub-components via templated manifests" "Go Operator (controller-runtime)"
            webhook = container "DS Pipelines Webhook" "Validates and mutates PipelineVersion CRs for Kubernetes pipeline store" "Go Webhook (conditional)"
            apiServer = container "DS Pipelines API Server" "Kubeflow Pipelines v2 API; REST (8888) and gRPC (8887)" "Go Service"
            kubeRBACProxy = container "kube-rbac-proxy" "Authenticates external API requests via OpenShift RBAC (8443)" "Sidecar"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo Workflows to pipeline DB" "Go Service"
            scheduledWFCtrl = container "Scheduled Workflow Controller" "Manages cron-based scheduled pipeline runs" "Go Service"
            argoWFCtrl = container "Argo Workflow Controller" "Orchestrates pipeline DAG execution (conditional)" "Go Controller"
            mlmdServer = container "MLMD gRPC Server" "ML Metadata for artifact and execution lineage tracking (8080)" "gRPC Service"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD with kube-rbac-proxy for auth (9090)" "Envoy Proxy"
        }

        mariaDB = softwareSystem "MariaDB" "Pipeline metadata storage (managed or external)" "Storage"
        s3Storage = softwareSystem "S3 Object Store" "Pipeline artifact storage (Minio managed or external)" "Storage"
        argoWorkflows = softwareSystem "Argo Workflows" "Workflow execution engine for pipeline DAGs" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "External ingress via Routes with reencrypt TLS" "External"
        serviceCa = softwareSystem "OpenShift service-ca" "Automatic TLS certificate generation" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "CR management, status updates, leader election" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection via ServiceMonitor" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "Workbenches access pipeline APIs" "Internal ODH"
        kserve = softwareSystem "KServe" "Model serving from pipeline steps" "Internal ODH"
        ray = softwareSystem "Ray" "Distributed compute from pipeline steps" "Internal ODH"
        codeflare = softwareSystem "CodeFlare / AppWrapper" "Distributed workload management" "Internal ODH"

        // User interactions
        dataScientist -> dspo "Submits pipeline runs via API or Dashboard"
        platformAdmin -> dspo "Creates DSPA CRs via kubectl"

        // Controller interactions
        controller -> k8sAPI "Manages CRs, Deployments, Services, Routes, RBAC" "HTTPS/443"
        controller -> mariaDB "Health check before deploying components" "MySQL/3306"
        controller -> s3Storage "Health check before deploying components" "S3 API"
        controller -> serviceCa "Requests TLS certificates via annotations"

        // API Server interactions
        kubeRBACProxy -> apiServer "Proxies authenticated requests" "HTTPS/8888"
        apiServer -> mariaDB "Pipeline metadata persistence" "MySQL/3306 TLS"
        apiServer -> s3Storage "Pipeline artifact storage" "S3 API TLS"

        // Pipeline execution
        argoWFCtrl -> k8sAPI "Creates and monitors Workflow CRs" "HTTPS/443"
        persistenceAgent -> apiServer "Syncs workflow status" "HTTPS/8888"

        // MLMD
        mlmdEnvoy -> mlmdServer "Proxies gRPC requests" "gRPC/8080"
        mlmdServer -> mariaDB "Metadata storage" "MySQL/3306 TLS"

        // External access
        openshiftRouter -> kubeRBACProxy "Reencrypt TLS" "HTTPS/8443"
        openshiftRouter -> mlmdEnvoy "Reencrypt TLS" "HTTPS/8443"

        // Integration points
        dspo -> kserve "Creates InferenceService from pipeline steps" "CRD API/443"
        dspo -> ray "Creates RayCluster/RayJob from pipeline steps" "CRD API/443"
        dspo -> codeflare "Creates AppWrapper from pipeline steps" "CRD API/443"
        odhDashboard -> apiServer "Notebook access to pipeline APIs" "HTTP/8888"
        prometheus -> dspo "Scrapes metrics" "HTTP/8080"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Storage" {
                background #f5a623
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
