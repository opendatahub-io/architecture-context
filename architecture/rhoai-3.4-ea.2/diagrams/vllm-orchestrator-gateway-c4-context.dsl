/*
 * C4 Context Diagram: vllm-orchestrator-gateway
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/vllm-orchestrator-gateway.md
 */

workspace {
    model {
        client = person "API Client" "Application or user sending chat completion requests"

        gateway = softwareSystem "vllm-orchestrator-gateway" "OpenAI-compatible HTTP gateway with configurable detector-based content filtering pipelines" {
            configLoader = container "Configuration Loader" "Reads YAML config defining orchestrator host, detectors, and routes" "Rust (config.rs)"
            routeHandler = container "Route Handler" "Dynamically registers POST endpoints per route, dispatches to streaming/non-streaming handlers" "Rust (main.rs, axum)"
            apiTypes = container "API Types" "Request/response structs for orchestrator communication" "Rust (api.rs)"
            tlsBuilder = container "TLS Client Builder" "Builds reqwest HTTP client with optional mTLS" "Rust (main.rs)"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Performs chat completions with detector-based content analysis" "Internal ODH"
        detectors = softwareSystem "Guardrails Detectors" "Content detection services (PII, regex, etc.)" "Internal ODH"
        vllm = softwareSystem "vLLM / LLM Backend" "Language model serving endpoint for chat completions" "Internal ODH"
        certManager = softwareSystem "cert-manager / service-ca-operator" "TLS certificate provisioning" "External"

        client -> gateway "POST /{route}/v1/chat/completions" "HTTP/8090, Authorization header"
        gateway -> orchestrator "POST /api/v2/chat/completions-detection" "HTTP or HTTPS/8085, Optional mTLS"
        orchestrator -> detectors "Runs configured detectors" "Internal"
        orchestrator -> vllm "Generates chat completions" "Internal"
        certManager -> gateway "Provisions TLS certificates" "kubernetes.io/tls"
    }

    views {
        systemContext gateway "SystemContext" {
            include *
            autoLayout
        }

        container gateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
