/*
 * KServe C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/kserve.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist / ML Engineer" "Creates and deploys ML inference services and LLM workloads"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform and cluster configuration"

        kserve = softwareSystem "KServe" "Kubernetes-native model serving platform for ML inference and LLM workloads" {
            kserveController = container "kserve-controller-manager" "Reconciles InferenceService, InferenceGraph, TrainedModel, LocalModel CRDs; creates Deployments, Services, HTTPRoutes, VirtualServices" "Go Operator (controller-runtime)"
            llmisvcController = container "llmisvc-controller-manager" "Manages LLMInferenceService/LLMInferenceServiceConfig CRDs; creates LeaderWorkerSets, InferencePools, DestinationRules" "Go Operator (controller-runtime)"
            kserveWebhook = container "Webhook Server (kserve)" "Mutating/validating webhooks for InferenceService, TrainedModel, InferenceGraph, ServingRuntime" "Admission Webhook, 9443/TCP HTTPS"
            llmisvcWebhook = container "Webhook Server (llmisvc)" "Validating webhooks for LLMInferenceService, LLMInferenceServiceConfig" "Admission Webhook, 9443/TCP HTTPS"
            storageInitializer = container "kserve-storage-initializer" "Downloads model artifacts from cloud storage into model serving containers" "Go init container"
            kserveAgent = container "kserve-agent" "Batcher/logger sidecar that intercepts inference requests" "Go sidecar"
            kserveRouter = container "kserve-router" "Routes requests across multiple InferenceServices based on InferenceGraph DAG topology" "Go service"
            localmodelController = container "localmodel-controller" "Manages LocalModelCache CRDs for pre-caching models on nodes" "Go controller"
            localmodelAgent = container "localmodel-node-agent" "Node-level agent managing local model cache downloads" "Go DaemonSet agent"
            kubeRbacProxy = container "kube-rbac-proxy" "Authentication sidecar enforcing SubjectAccessReview-based authorization" "Go sidecar, 8443/TCP HTTPS"
        }

        # External Dependencies
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for traffic routing, VirtualServices, DestinationRules, mTLS" "External"
        knativeServing = softwareSystem "Knative Serving" "Serverless autoscaling platform for InferenceService serverless mode" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute-based ingress routing for inference endpoints" "External"
        gatewayInferenceExt = softwareSystem "Gateway API Inference Extension" "InferencePool and InferenceModel for intelligent LLM request routing" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management for webhooks (upstream mode)" "External"
        leaderWorkerSet = softwareSystem "LeaderWorkerSet" "Multi-node LLM workload orchestration" "External"
        keda = softwareSystem "KEDA" "Custom metrics-based autoscaling via ScaledObjects" "External"
        otelOperator = softwareSystem "OpenTelemetry Operator" "Distributed tracing for inference requests" "External"
        prometheusOperator = softwareSystem "Prometheus Operator" "Metrics collection via PodMonitor/ServiceMonitor" "External"

        # Internal RHOAI Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Platform lifecycle management, component enablement via DataScienceCluster" "Internal RHOAI"
        vllm = softwareSystem "vLLM (CUDA/ROCm/Spyre)" "LLM serving runtime images" "Internal RHOAI"
        llmdScheduler = softwareSystem "llm-d-inference-scheduler" "Inference request scheduler for InferencePool routing" "Internal RHOAI"
        llmdRoutingSidecar = softwareSystem "llm-d-routing-sidecar" "Routing sidecar for prefill/decode disaggregation" "Internal RHOAI"
        kubeAuthProxy = softwareSystem "odh-kube-auth-proxy" "kube-rbac-proxy sidecar image for RawDeployment auth" "Internal RHOAI"

        # External Services
        modelStorage = softwareSystem "Model Storage (S3/GCS/Azure)" "Cloud storage for ML model artifacts" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster resource management and CRD operations" "External Service"

        # Relationships - Users
        dataScientist -> kserve "Creates InferenceService / LLMInferenceService via kubectl/dashboard"
        platformAdmin -> rhodsOperator "Configures RHOAI platform via DataScienceCluster"

        # Relationships - Internal
        kserveController -> kserveWebhook "Registers webhooks" "HTTPS/9443"
        llmisvcController -> llmisvcWebhook "Registers webhooks" "HTTPS/9443"
        kserveController -> storageInitializer "Injects as init container"
        kserveController -> kserveAgent "Injects as sidecar"
        kserveController -> kubeRbacProxy "Injects as sidecar" "HTTPS/8443"

        # Relationships - External Dependencies
        kserve -> istio "Uses for VirtualService routing, DestinationRules, mTLS" "HTTPS/6443"
        kserve -> knativeServing "Creates Knative Services for serverless mode" "HTTPS/443"
        kserve -> gatewayAPI "Creates HTTPRoutes for ingress routing" "HTTPS/6443"
        kserve -> gatewayInferenceExt "Creates InferencePools for LLM scheduling" "HTTPS/6443"
        kserve -> leaderWorkerSet "Creates LWS for multi-node LLM workloads" "HTTPS/6443"
        kserve -> keda "Creates ScaledObjects for custom autoscaling" "HTTPS/6443"
        kserve -> otelOperator "Creates OpenTelemetryCollectors for tracing" "HTTPS/6443"
        kserve -> prometheusOperator "Creates PodMonitors/ServiceMonitors for metrics" "HTTPS/6443"

        # Relationships - Internal RHOAI
        rhodsOperator -> kserve "Manages lifecycle via DataScienceCluster"
        kserve -> vllm "Uses as LLM serving runtime images"
        kserve -> llmdScheduler "Uses for InferencePool request routing"
        kserve -> llmdRoutingSidecar "Uses for prefill/decode disaggregation"
        kserve -> kubeAuthProxy "Uses as auth sidecar image"

        # Relationships - External Services
        storageInitializer -> modelStorage "Downloads model artifacts" "HTTPS/443"
        kserve -> k8sAPI "CRD CRUD, resource management, leader election" "HTTPS/6443"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "External Service" {
                background #f5a623
                color #000000
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
