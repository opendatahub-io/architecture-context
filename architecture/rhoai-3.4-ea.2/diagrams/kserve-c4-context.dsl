// KServe C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/kserve.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and deploys ML models and LLM inference services"
        mlEngineer = person "ML Engineer" "Configures serving runtimes and inference pipelines"

        kserve = softwareSystem "KServe" "Kubernetes-native platform for serving ML models and LLM inference workloads on OpenShift AI" {
            kserveController = container "kserve-controller-manager" "Reconciles InferenceService, InferenceGraph, TrainedModel CRDs; creates Deployments, Services, HTTPRoutes, VirtualServices, HPA, ScaledObjects" "Go Operator (controller-runtime)"
            llmisvcController = container "llmisvc-controller-manager" "Reconciles LLMInferenceService CRD; creates Deployments, LeaderWorkerSets, InferencePools, DestinationRules, self-signed TLS certs" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates and defaults InferenceService, TrainedModel, InferenceGraph, ServingRuntime CRs" "Go Service (9443/TCP TLS)"
            storageInitializer = container "Storage Initializer" "Downloads model artifacts from S3, GCS, Azure Blob, PVC, OCI sources" "Python Init Container"
            kserveAgent = container "KServe Agent" "Model logging, batching, and agent capabilities" "Go Sidecar"
            inferenceRouter = container "Inference Router" "Routes requests across InferenceGraph DAG nodes" "Go Container"
            schedulerEPP = container "llm-d Inference Scheduler" "Gateway API InferencePool endpoint picker with KV-cache-aware scheduling" "Go Container (gRPC 9002/TCP)"
        }

        // External Dependencies
        istio = softwareSystem "Istio / Service Mesh" "Service mesh for traffic routing, mTLS, VirtualServices, DestinationRules" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute/Gateway CRDs for ingress routing" "External"
        gatewayInference = softwareSystem "Gateway API Inference Extension" "InferencePool/InferenceModel CRDs for LLM scheduling" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform (optional)" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling via ScaledObjects (optional)" "External"
        otel = softwareSystem "OpenTelemetry Operator" "Distributed tracing for inference requests (optional)" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "PodMonitor/ServiceMonitor for metrics collection" "External"
        leaderWorkerSet = softwareSystem "LeaderWorkerSet" "Multi-node LLM inference coordination (optional)" "External"
        certManager = softwareSystem "cert-manager / service-ca" "TLS certificate provisioning" "External"

        // Internal RHOAI Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys KServe manifests via Kustomize overlays" "Internal RHOAI"
        openshiftIngress = softwareSystem "OpenShift Ingress" "Default ingress gateway for inference endpoints" "Internal RHOAI"

        // External Services
        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, MinIO, etc.)" "External Service"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External Service"
        azureBlob = softwareSystem "Azure Blob Storage" "Model artifact storage" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "CR watch/update, RBAC, webhook calls" "Infrastructure"

        // Relationships - Users
        dataScientist -> kserve "Creates InferenceService / LLMInferenceService via kubectl/Dashboard"
        mlEngineer -> kserve "Configures ServingRuntimes and InferenceGraphs"

        // Relationships - KServe internal
        kserveController -> webhookServer "Webhook validation/defaulting"
        llmisvcController -> schedulerEPP "Creates InferencePool with scheduler"

        // Relationships - External Dependencies
        kserve -> istio "Uses for traffic routing, VirtualServices, DestinationRules, mTLS" "HTTPS/443"
        kserve -> gatewayAPI "Uses for HTTPRoute-based ingress" "HTTPS/443"
        kserve -> gatewayInference "Uses for InferencePool/InferenceModel LLM routing" "gRPC/9002"
        kserve -> knative "Uses for serverless deployment mode (optional)" "HTTP/80, HTTPS/443"
        kserve -> keda "Uses for event-driven autoscaling (optional)"
        kserve -> otel "Uses for distributed tracing (optional)"
        kserve -> prometheusOp "Creates PodMonitors/ServiceMonitors" "HTTP/9090, HTTPS/8000"
        kserve -> leaderWorkerSet "Uses for multi-node inference (optional)"
        kserve -> certManager "Obtains TLS certificates for webhooks"

        // Relationships - Internal RHOAI
        rhodsOperator -> kserve "Deploys via Kustomize overlays/odh"
        kserve -> openshiftIngress "Routes inference traffic via Gateway"

        // Relationships - External Services
        kserve -> s3 "Downloads model artifacts" "HTTPS/443, AWS credentials/IRSA"
        kserve -> gcs "Downloads model artifacts" "HTTPS/443, GCP SA"
        kserve -> azureBlob "Downloads model artifacts" "HTTPS/443, Azure AD"
        kserve -> k8sAPI "Watches CRs, creates resources, RBAC" "HTTPS/6443, SA token"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
