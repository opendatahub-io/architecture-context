    Route -.->|"HTTPS/8443<br/>TLS reencrypt"| RBAC
    RBAC -->|"HTTP/8080<br/>localhost<br/>X-Auth-Request headers"| Dashboard
    RBAC -->|"TokenReview +<br/>SubjectAccessReview"| K8sAPI

    Dashboard -->|"HTTPS/443<br/>SA + User token"| K8sAPI
    Dashboard -->|"HTTPS/9091<br/>SA token"| Prometheus
    Dashboard -->|"HTTPS/8443<br/>User token"| Pipelines
    Dashboard -->|"HTTPS/8443<br/>User token"| ModelReg
    Dashboard -->|"HTTPS/443<br/>User token"| TrustyAI
    Dashboard -->|"HTTPS/8443<br/>User token"| MLMD
    Dashboard -->|"HTTPS/8443<br/>User token"| LlamaStack
    Dashboard -->|"HTTP/8080<br/>User token"| Perses

    Browser -->|"HTTPS/8043-8743<br/>X-Forwarded-Access-Token"| MR

