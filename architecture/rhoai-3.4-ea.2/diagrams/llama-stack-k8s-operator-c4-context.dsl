// C4 Context Diagram: Llama Stack K8s Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Platform User" "Deploys and manages Llama Stack distributions on Kubernetes/OpenShift"
        admin = person "Cluster Admin" "Configures operator feature flags and image mappings"

        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Kubernetes operator that manages the lifecycle of Llama Stack server distributions on OpenShift/Kubernetes" {
            controller = container "LlamaStackDistribution Controller" "Reconciles LlamaStackDistribution CRs; manages Deployments, Services, PVCs, NetworkPolicies, HPAs, PDBs" "Go Operator (controller-runtime)"
            kustomizeRenderer = container "Kustomize Renderer" "Renders base manifests through kustomize with custom transformer plugins" "Go Library (pkg/deploy)"
            clusterInfo = container "ClusterInfo" "Detects operator namespace, loads distribution image mappings" "Go Library (pkg/cluster)"
            featureFlags = container "Feature Flags" "Controls operator behavior via ConfigMap-based feature flags" "Go Library (pkg/featureflags)"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Meta Llama Stack inference server distribution (starter, remote-vllm, meta-reference-gpu, postgres-demo)" "Managed"

        kubernetesAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane API" "External"
        containerRegistry = softwareSystem "Container Registry" "Container image registry (docker.io/llamastack/*)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        odhPlatform = softwareSystem "ODH/RHOAI Platform" "Open Data Hub / Red Hat OpenShift AI platform providing trusted CA bundles" "Internal ODH"
        openshiftSCC = softwareSystem "OpenShift SCC" "Security Context Constraints for pod security" "External"

        // User interactions
        user -> llamaStackOperator "Creates LlamaStackDistribution CRs via kubectl"
        admin -> llamaStackOperator "Configures operator via llama-stack-operator-config ConfigMap"
        user -> llamaStackServer "Sends inference requests via /v1/* API" "HTTP/8321"

        // Operator interactions
        llamaStackOperator -> kubernetesAPI "Reconciles resources, watches CRDs" "HTTPS/443"
        llamaStackOperator -> llamaStackServer "Health checks, provider status polling" "HTTP/8321"
        llamaStackOperator -> containerRegistry "Validates container image references" "HTTPS/443"
        llamaStackOperator -> odhPlatform "Auto-detects trusted CA bundles" "ConfigMap watch"
        llamaStackOperator -> openshiftSCC "Uses anyuid SCC for server pods" "RBAC"

        // Monitoring
        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTPS/8443"

        // Internal container relationships
        controller -> kustomizeRenderer "Uses for manifest rendering"
        controller -> clusterInfo "Uses for cluster detection"
        controller -> featureFlags "Uses for feature flag evaluation"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
