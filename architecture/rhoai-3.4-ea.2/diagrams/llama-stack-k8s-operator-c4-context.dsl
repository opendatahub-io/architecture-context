/*
 * C4 Context Diagram: Llama Stack K8s Operator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/llama-stack-k8s-operator.md
 */

workspace {
    model {
        user = person "Platform Admin / Data Scientist" "Creates and manages LlamaStackDistribution custom resources"

        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Kubernetes operator that manages lifecycle of Llama Stack AI inference server deployments" {
            controller = container "LlamaStackDistribution Controller" "Reconciles LLSD CRs; creates Deployment, Service, SA, PVC, NetworkPolicy, Ingress, PDB, HPA" "Go (controller-runtime)"
            kustomizer = container "Kustomize Manifest Renderer" "Renders base manifests via kustomize with field transformations and plugins" "Go Library"
            clusterInfo = container "ClusterInfo Manager" "Detects operator namespace, resolves distribution images, handles upgrades" "Go Library"
            featureFlags = container "Feature Flags" "Controls operator features like NetworkPolicy creation" "Go Library"
            npTransformer = container "NetworkPolicy Transformer" "Dynamically configures NetworkPolicy ingress rules based on CR spec" "Go Plugin"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "AI inference server instances managed by the operator" "Managed"

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane API" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys the Llama Stack operator via kustomize overlays" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        odhCABundle = softwareSystem "ODH Trusted CA Bundle" "ConfigMap providing trusted CA certificates" "Internal RHOAI"

        # Relationships - External
        user -> llamaStackOperator "Creates LlamaStackDistribution CRs via kubectl/oc"
        rhodsOperator -> llamaStackOperator "Deploys via overlays/rhoai kustomization"

        # Relationships - Operator to dependencies
        llamaStackOperator -> k8sAPI "Resource reconciliation, watch, CRUD operations" "HTTPS/443, TLS 1.2+"
        llamaStackOperator -> llamaStackServer "Health checks, lifecycle management" "HTTP/8321"
        llamaStackOperator -> odhCABundle "Watches for CA bundle changes" "Kubernetes Watch"
        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTP/8080"

        # Internal relationships
        controller -> kustomizer "Renders manifests"
        controller -> clusterInfo "Queries cluster info"
        controller -> featureFlags "Reads feature flags"
        kustomizer -> npTransformer "Applies NetworkPolicy transformations"

        # Managed server relationships
        user -> llamaStackServer "Sends inference requests" "HTTP/8321"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
