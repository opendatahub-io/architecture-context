/*
 * Argo Workflows - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/argo-workflows.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines"
        admin = person "Platform Admin" "Manages RHOAI platform"

        argoWorkflows = softwareSystem "Argo Workflows" "Kubernetes-native workflow engine for orchestrating parallel jobs, used as execution backend for Data Science Pipelines" {
            workflowController = container "Workflow Controller" "Watches Workflow CRDs, reconciles workflow state, creates/manages pods for workflow steps, handles DAG scheduling, cron workflows, and garbage collection" "Go Controller (client-go informers)"
            argoexec = container "Argo Executor (argoexec)" "Runs within workflow pods using emissary executor pattern; manages artifact upload/download, output parameter capture, container wait/lifecycle" "Go Sidecar Binary"
            argoServer = container "Argo Server" "Provides REST API (gRPC-gateway) and Web UI for workflow CRUD operations, log streaming, artifact serving, and SSO authentication" "Go API Server (gRPC + HTTP)"
            workflowUI = container "Workflow UI" "Browser-based dashboard for workflow visualization, log viewing, and management" "TypeScript/React"
            crdController = container "CRD Controller" "Manages CronWorkflow scheduling, WorkflowTaskSet agent execution, and WorkflowArtifactGCTask cleanup" "Go (client-go)"
        }

        kubernetesAPI = softwareSystem "Kubernetes API Server" "Core platform for pod scheduling, CRD management, RBAC" "External"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and configures workflow-controller and argoexec images" "Internal RHOAI"
        dspAPIServer = softwareSystem "DSP API Server" "Creates Workflow CRs that the controller processes" "Internal RHOAI"
        s3Storage = softwareSystem "S3-compatible Object Storage" "Artifact repository for workflow artifacts (MinIO, AWS S3, GCS, Azure Blob)" "External"
        postgresql = softwareSystem "PostgreSQL" "Workflow archiving and node status offloading persistence" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for Argo Server" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection from workflow controller" "External"

        # Relationships - People
        datascientist -> dspAPIServer "Submits pipeline runs"
        admin -> argoServer "Manages workflows via API/UI" "HTTPS/2746"

        # Relationships - Internal
        dspAPIServer -> kubernetesAPI "Creates Workflow CRs" "HTTPS/6443"
        dspOperator -> argoWorkflows "Deploys and configures"
        workflowController -> kubernetesAPI "Watches CRDs, creates pods, updates status" "HTTPS/6443"
        argoexec -> kubernetesAPI "Reports task status" "HTTPS/6443"
        argoServer -> kubernetesAPI "Queries workflows, pods, logs" "HTTPS/6443"
        argoServer -> workflowUI "Serves UI assets"
        workflowController -> crdController "Delegates CronWorkflow, TaskSet management"

        # Relationships - External
        argoexec -> s3Storage "Uploads/downloads artifacts" "HTTPS/443"
        argoServer -> s3Storage "Serves artifacts to clients" "HTTPS/443"
        workflowController -> postgresql "Archives workflow data" "TCP/5432"
        argoServer -> postgresql "Reads archived workflows" "TCP/5432"
        argoServer -> oidcProvider "Validates SSO tokens" "HTTPS/443"
        prometheus -> workflowController "Scrapes metrics" "HTTP/9090"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
