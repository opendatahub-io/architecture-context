// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.2/argo-workflows.md

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines via Data Science Pipelines"

        argoWorkflows = softwareSystem "Argo Workflows" "Kubernetes-native workflow engine for Data Science Pipelines execution" {
            workflowController = container "workflow-controller" "Watches Workflow CRs and orchestrates pod creation/lifecycle for each workflow step. Leader election for HA." "Go Binary (Deployment)" "Component"
            argoexec = container "argoexec" "Executor sidecar injected into each workflow pod. Manages artifact collection, script execution, resource monitoring." "Go Binary (Sidecar)" "Component"
            argoServer = container "argo-server" "REST API + gRPC server + Web UI. Provides workflow management API with SSO/Bearer/Server auth modes." "Go Binary (Deployment)" "Component"
            argoUI = container "argo-ui" "Web-based UI for workflow visualization, submission, and management." "React/TypeScript SPA" "Component"
        }

        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages workflow-controller and argoexec images" "Internal RHOAI"
        dspAPIServer = softwareSystem "Data Science Pipelines API Server" "Submits Workflow CRs for pipeline execution" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for pod management, CRD storage, RBAC" "External"
        s3Storage = softwareSystem "S3/MinIO Object Storage" "Pipeline step artifact storage and retrieval" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        postgresql = softwareSystem "PostgreSQL" "Workflow archive persistence (optional)" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication via OpenID Connect (optional)" "External"

        // Relationships - External
        datascientist -> dspAPIServer "Submits ML pipelines"
        dspAPIServer -> argoWorkflows "Submits Workflow CRs" "Kubernetes API/HTTPS/443"
        dspOperator -> argoWorkflows "Deploys and manages"

        // Relationships - Argo to dependencies
        argoWorkflows -> k8sAPI "CRD management, pod lifecycle, RBAC" "HTTPS/443, SA Token"
        argoWorkflows -> s3Storage "Artifact upload/download" "HTTPS/443, AWS/S3 credentials"
        argoWorkflows -> postgresql "Workflow archive persistence" "TCP/5432, Username/Password"
        argoWorkflows -> oidcProvider "SSO authentication" "HTTPS/443, OAuth2"
        prometheus -> argoWorkflows "Scrapes metrics" "HTTP/9090"

        // Container-level relationships
        dspAPIServer -> workflowController "Creates Workflow CRs via K8s API"
        workflowController -> k8sAPI "Creates pods, watches CRDs, updates status" "HTTPS/443"
        argoexec -> k8sAPI "Patches workflow status" "HTTPS/443"
        argoexec -> s3Storage "Uploads artifacts" "HTTPS/443"
        argoServer -> k8sAPI "Manages CRDs, reads pod logs" "HTTPS/443"
        argoServer -> s3Storage "Retrieves artifacts" "HTTPS/443"
        argoServer -> postgresql "Archives workflows" "TCP/5432"
        argoServer -> oidcProvider "SSO authentication" "HTTPS/443"
        prometheus -> workflowController "Scrapes /metrics" "HTTP/9090"
        argoUI -> argoServer "Bundled into server binary"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
