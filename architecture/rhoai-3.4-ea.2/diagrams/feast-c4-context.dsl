// Feast Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates FeatureStore CRs, retrieves features for ML training and inference"
        admin = person "Platform Admin" "Deploys and configures the Feast Operator via RHOAI"

        feastOperator = softwareSystem "Feast Operator" "Manages lifecycle of Feast feature store deployments on Kubernetes/OpenShift" {
            controller = container "Feast Operator Controller Manager" "Reconciles FeatureStore CRs; creates Deployments, Services, ConfigMaps, PVCs, RBAC, CronJobs, Routes" "Go 1.22, controller-runtime"
            featureStoreReconciler = container "FeatureStoreReconciler" "Watches FeatureStore CRs and owned resources; deploys Feast services" "Go Controller"
            notebookReconciler = container "NotebookConfigMapReconciler" "Watches Kubeflow Notebooks with feast-integration label; creates per-notebook ConfigMaps" "Go Controller"
            feastServices = container "FeastServices" "Manages online/offline/registry/UI server deployment, TLS, PVCs, CronJobs" "Go Service Logic"
            feastAuth = container "FeastAuthorization" "Deploys Kubernetes RBAC or OIDC authorization for Feast services" "Go Auth Logic"
            featureServer = container "Feature Server" "Feast online/offline/registry/UI servers deployed as containers" "Python 3.11"
            cronJob = container "CronJob" "Runs feast apply and feast materialize-incremental" "origin-cli"
        }

        kubernetesAPI = softwareSystem "Kubernetes API Server" "Container orchestration platform" "External"
        openShift = softwareSystem "OpenShift Platform" "Provides Routes, service serving certs, OCP-specific features" "External"
        kubeflowNotebooks = softwareSystem "Kubeflow Notebook Controller" "Manages Jupyter Notebook instances for data science" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys Feast operator via kustomize overlay" "Internal RHOAI"
        odhTrustedCA = softwareSystem "ODH Trusted CA Bundle" "Custom CA certificate bundle for TLS trust" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and monitoring" "External"

        postgresql = softwareSystem "PostgreSQL" "Relational database for feature store persistence" "External"
        snowflake = softwareSystem "Snowflake" "Cloud data warehouse for feature store persistence" "External"
        cassandra = softwareSystem "Cassandra" "NoSQL database for online store persistence" "External"
        s3 = softwareSystem "S3/GCS Object Store" "Object storage for registry and offline store persistence" "External"
        gitRepo = softwareSystem "Git Repository" "Source for feature definitions" "External"

        // Relationships
        user -> feastOperator "Creates FeatureStore CR via kubectl/API" "HTTPS/443"
        user -> featureServer "Retrieves features for ML applications" "gRPC/80,443"
        admin -> rhoaiOperator "Configures RHOAI deployment"

        feastOperator -> kubernetesAPI "Watches CRDs, creates resources" "HTTPS/443"
        feastOperator -> openShift "Creates Routes, uses service serving certs" "HTTPS/443"
        feastOperator -> kubeflowNotebooks "Watches Notebooks with feast-integration label" "Watch API"
        feastOperator -> odhTrustedCA "Mounts custom CA bundle into Feast pods" "ConfigMap"
        rhoaiOperator -> feastOperator "Deploys via kustomize overlay" "Kustomize"

        featureServer -> postgresql "Stores/retrieves features" "TCP/5432"
        featureServer -> snowflake "Stores/retrieves features" "HTTPS/443"
        featureServer -> cassandra "Stores/retrieves features" "TCP/9042"
        featureServer -> s3 "Persists registry/offline store data" "HTTPS/443"
        cronJob -> gitRepo "Initializes feature repo" "HTTPS/443, SSH/22"

        prometheus -> feastOperator "Scrapes metrics" "HTTPS/8443"
    }

    views {
        systemContext feastOperator "SystemContext" {
            include *
            autoLayout
        }

        container feastOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
