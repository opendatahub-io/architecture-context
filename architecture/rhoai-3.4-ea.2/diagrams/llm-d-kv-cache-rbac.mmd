    subgraph "Secrets Access"
        HFToken["HuggingFace Token<br/>(Opaque)<br/>Private model access<br/>No auto-rotation"]
        RedisCreds["Redis/Valkey Credentials<br/>(Opaque, URL-embedded)<br/>Index backend auth<br/>No auto-rotation"]
    end

