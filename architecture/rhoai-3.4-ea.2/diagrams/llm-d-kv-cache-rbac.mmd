        UDSAuth["UDS gRPC Socket<br/>Auth: None<br/>Isolation: Filesystem perms (UID 65532)<br/>Scope: Pod-local"]
        HealthAuth["Health Endpoint (8082/TCP)<br/>Auth: None<br/>Scope: Pod network"]
        ZMQAuth["ZMQ Subscribers<br/>Auth: None<br/>Enforcement: Network Policy"]
        K8sAuth["Kubernetes API<br/>Auth: ServiceAccount Token<br/>Encryption: TLS 1.2+"]
    end

    SA -.->|mounts| HFToken
    SA -.->|mounts| RedisCreds

