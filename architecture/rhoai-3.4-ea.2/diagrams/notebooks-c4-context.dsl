/*
 * C4 Context Diagram for Notebooks (Workbench & Runtime Images)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/notebooks.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Develops and runs ML experiments using interactive workbenches"

        notebooks = softwareSystem "Notebooks (Workbench & Runtime Images)" "Pre-built workbench (IDE) and pipeline runtime container images for data science workflows" {
            jupyterImages = container "JupyterLab Images" "Interactive notebook IDEs (Minimal, Data Science, PyTorch, TensorFlow, TrustYAI, ROCm variants)" "Container Images"
            codeServerImage = container "Code Server Image" "VS Code in browser via code-server v4.106 with NGINX proxy" "Container Image"
            rstudioImage = container "RStudio Server Image" "RStudio Server 2025.09 with R 4.5" "Container Image"
            runtimeImages = container "Pipeline Runtime Images" "Minimal execution environments for Elyra pipeline steps" "Container Images"
            kustomizeManifests = container "Kustomize Manifests" "OpenShift ImageStream definitions for image registration" "YAML/Kustomize"
            tektonPipelines = container "Tekton Pipelines" "94 Konflux/Tekton build pipeline definitions (hermetic, cachi2)" "CI/CD"
        }

        notebookController = softwareSystem "ODH Notebook Controller" "Creates and manages workbench pods from container images" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "Discovers available workbench images via ImageStream annotations" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Deploys ImageStream manifests to register images on cluster" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "Uses runtime images as execution environments for pipeline steps" "Internal RHOAI"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication proxy sidecar injected alongside workbench containers" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Training SDK pre-installed in data science workbenches" "Internal RHOAI"

        openshiftGateway = softwareSystem "OpenShift Gateway (data-science-gateway)" "Gateway API ingress for workbench access" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Red Hat container image registry" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for data and pipeline artifacts" "External"
        pypi = softwareSystem "PyPI / Package Registries" "Python package repositories" "External"
        gitRepos = softwareSystem "Git Repositories" "Source code repositories" "External"
        k8sAPI = softwareSystem "Kubernetes API" "OpenShift/Kubernetes API server" "External"

        # User interactions
        dataScientist -> notebooks "Develops ML experiments using workbench IDEs"
        dataScientist -> openshiftGateway "Accesses workbenches via browser" "HTTPS/443"

        # Internal RHOAI interactions
        notebookController -> notebooks "Creates workbench pods from images" "Notebook CR / K8s API"
        dashboard -> notebooks "Discovers images via ImageStream labels" "K8s API"
        rhoaiOperator -> notebooks "Deploys ImageStream manifests" "Kustomize / K8s API"
        dsp -> notebooks "Executes pipeline steps using runtime images" "K8s API"
        kubeRBACProxy -> notebooks "Injected as auth sidecar (8443/TCP)" "HTTPS"

        # External interactions
        notebooks -> s3Storage "Data access and pipeline artifacts" "HTTPS/443"
        notebooks -> pypi "Python package installation" "HTTPS/443"
        notebooks -> gitRepos "Git operations" "HTTPS/443"
        notebooks -> k8sAPI "oc CLI commands" "HTTPS/6443"
        notebooks -> registryRedHat "Image source (SHA256 digest pinning)" "HTTPS/443"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container Image" {
                background #4a90e2
                color #ffffff
            }
            element "Container Images" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
