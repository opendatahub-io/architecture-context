/*
 * C4 Context Diagram: Notebooks (Workbench Images)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and uses data science workbenches for experimentation and model development"
        mlEngineer = person "ML Engineer" "Builds and runs ML pipelines using runtime images"
        clusterAdmin = person "Cluster Admin" "Manages RHOAI platform and workbench image deployment"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images for data science workbenches (Jupyter, Code Server, RStudio) and Elyra pipeline runtimes" {
            jupyterImages = container "Jupyter Workbench Images" "Jupyter Minimal, Data Science, PyTorch, TensorFlow, TrustyAI, LLM Compressor" "Container Images"
            codeServerImages = container "Code Server Images" "VS Code-based workbench with data science libraries" "Container Image"
            rstudioImages = container "RStudio Images" "RStudio Server for R programming (CPU/CUDA)" "Container Image + BuildConfig"
            runtimeImages = container "Pipeline Runtime Images" "Minimal, Data Science, PyTorch, TensorFlow runtimes for Elyra" "Container Images"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream definitions referencing pre-built images" "Kustomize YAML"
            tektonPipelines = container "Tekton Pipelines" "94 Konflux build pipeline definitions" "Tekton PipelineRun"
        }

        rhodsOperator = softwareSystem "rhods-operator" "RHOAI platform operator that deploys and manages components" "Internal RHOAI"
        odhNotebookController = softwareSystem "ODH Notebook Controller" "Creates and manages workbench pods from ImageStreams" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects and workbenches" "Internal RHOAI"
        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Creates notebook pods using image references" "Internal RHOAI"
        elyraPipelineEditor = softwareSystem "Elyra Pipeline Editor" "Pipeline editor using runtime images for node execution" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "ML pipeline orchestration using runtime images" "Internal RHOAI"
        codeflareMCAD = softwareSystem "Codeflare/MCAD" "Distributed computing framework" "Internal RHOAI"

        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Authentication/authorization sidecar for workbenches" "Internal RHOAI"
        openshiftGateway = softwareSystem "OpenShift Gateway" "Envoy-based ingress gateway with TLS" "Platform"
        kubernetesAPI = softwareSystem "Kubernetes API" "OpenShift API server" "Platform"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for data and model artifacts" "External"
        gitRepos = softwareSystem "Git Repositories" "Source control (GitHub, GitLab)" "External"
        containerRegistries = softwareSystem "Container Registries" "registry.redhat.io, quay.io" "External"
        konflux = softwareSystem "Konflux" "Red Hat CI/CD build system (Tekton-based)" "External"

        /* Relationships */
        dataScientist -> odhDashboard "Selects and launches workbench" "HTTPS/443"
        dataScientist -> openshiftGateway "Accesses workbench UI" "HTTPS/443, OIDC"
        mlEngineer -> kubeflowPipelines "Runs pipelines using runtime images"
        clusterAdmin -> rhodsOperator "Deploys RHOAI platform"

        rhodsOperator -> kustomizeManifests "Reads and applies ImageStream manifests" "Kustomize render"
        odhNotebookController -> kubernetesAPI "Reads ImageStreams, creates workbench pods" "HTTPS/6443"
        odhDashboard -> kubernetesAPI "Queries ImageStream annotations" "HTTPS/6443"
        kubeflowPipelines -> containerRegistries "Pulls runtime images" "HTTPS/443"

        openshiftGateway -> kubeRbacProxy "TLS passthrough" "HTTPS/8443"
        kubeRbacProxy -> jupyterImages "Proxies to workbench (localhost)" "HTTP/8888"
        kubeRbacProxy -> codeServerImages "Proxies to workbench (localhost)" "HTTP/8080"
        kubeRbacProxy -> rstudioImages "Proxies to workbench (localhost)" "HTTP/8787"

        jupyterImages -> kubernetesAPI "oc CLI and SDK calls" "HTTPS/6443"
        jupyterImages -> s3Storage "Data access via boto3" "HTTPS/443"
        jupyterImages -> gitRepos "Version control" "HTTPS/443"

        konflux -> tektonPipelines "Executes build pipelines"
        tektonPipelines -> containerRegistries "Pushes built images" "HTTPS/443"

        elyraPipelineEditor -> runtimeImages "References runtime ImageStreams for pipeline nodes"
        codeflareMCAD -> kubernetesAPI "Distributed job submission from workbench" "HTTPS/6443"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Platform" {
                background #326ce5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
