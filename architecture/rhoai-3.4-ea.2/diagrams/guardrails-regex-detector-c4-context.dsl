/*
 * C4 Context Diagram: Guardrails Regex Detector
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/guardrails-regex-detector.md
 */

workspace {
    model {
        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Routes text content to detector services for scanning as part of AI guardrails infrastructure" "Internal RHOAI"

        regexDetector = softwareSystem "Guardrails Regex Detector" "Lightweight Rust-based HTTP service that detects PII (email, SSN, credit card) and custom patterns in text using regular expressions" {
            httpServer = container "HTTP Server" "Axum-based REST API server listening on port 8080" "Rust / Axum 0.7.9"
            emailDetector = container "Email Detector" "Built-in regex pattern for email address detection" "Rust regex"
            ssnDetector = container "SSN Detector" "Built-in regex pattern for US Social Security Number detection" "Rust regex"
            ccDetector = container "Credit Card Detector" "Built-in regex pattern for credit card number detection" "Rust regex"
            customEngine = container "Custom Regex Engine" "Compiles and matches arbitrary user-supplied regex patterns" "Rust regex"
        }

        kubelet = softwareSystem "Kubernetes Kubelet" "Node agent performing readiness/health checks" "Platform"

        # Relationships
        orchestrator -> regexDetector "Sends text for PII detection" "HTTP/8080 plaintext"
        kubelet -> regexDetector "Health check probe" "HTTP/8080 GET /health"

        # Internal container relationships
        orchestrator -> httpServer "POST /api/v1/text/contents" "HTTP/8080 plaintext"
        httpServer -> emailDetector "Routes email detection requests"
        httpServer -> ssnDetector "Routes SSN detection requests"
        httpServer -> ccDetector "Routes credit card detection requests"
        httpServer -> customEngine "Routes custom regex requests"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
        }

        container regexDetector "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
