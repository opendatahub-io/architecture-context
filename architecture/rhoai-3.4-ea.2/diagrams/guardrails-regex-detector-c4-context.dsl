workspace {
    model {
        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestrates guardrails pipeline for LLM inference, calling multiple detectors" "Internal RHOAI"

        regexDetector = softwareSystem "Guardrails Regex Detector" "Lightweight Rust-based HTTP service that detects PII and custom regex patterns in text content" {
            httpServer = container "HTTP Server" "Axum-based REST API accepting text detection requests" "Rust 1.84.0 / Axum 0.7.9"
            ssnDetector = container "SSN Detector" "Built-in US Social Security Number detection" "Regex Module"
            creditCardDetector = container "Credit Card Detector" "Built-in credit card number detection (Visa, MC, Amex, Discover)" "Regex Module"
            emailDetector = container "Email Detector" "Built-in email address detection" "Regex Module"
            customRegexEngine = container "Custom Regex Engine" "Applies user-supplied regex patterns" "Regex Module"
        }

        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform" "External"

        // Relationships
        orchestrator -> regexDetector "Sends text detection requests" "HTTP/8080 plaintext"
        kubernetes -> regexDetector "Health check probes" "HTTP/8080 plaintext"

        // Internal container relationships
        orchestrator -> httpServer "POST /api/v1/text/contents" "HTTP/8080"
        kubernetes -> httpServer "GET /health" "HTTP/8080"
        httpServer -> ssnDetector "Routes SSN detection"
        httpServer -> creditCardDetector "Routes credit card detection"
        httpServer -> emailDetector "Routes email detection"
        httpServer -> customRegexEngine "Routes custom regex detection"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
        }

        container regexDetector "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Regex Module" {
                background #7ed321
                color #ffffff
                shape Hexagon
            }
        }
    }
}
