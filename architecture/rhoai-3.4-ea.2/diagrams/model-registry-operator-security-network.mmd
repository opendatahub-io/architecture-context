    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| CatalogRoute

    %% Ingress to Auth Proxy
    RegistryRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OpenShift Serving Cert"| RegistryProxy
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OpenShift Serving Cert"| CatalogProxy

    %% Auth Proxy to K8s API (RBAC check)
    RegistryProxy -->|"HTTPS/6443<br/>SubjectAccessReview<br/>Bearer Token"| K8sAPI
    CatalogProxy -->|"HTTPS/6443<br/>SubjectAccessReview<br/>Bearer Token"| K8sAPI

    %% Auth Proxy to App (localhost)
    RegistryProxy -->|"HTTP/8080<br/>plaintext localhost<br/>No Auth (authorized)"| RegistryREST
    CatalogProxy -->|"HTTP/8080<br/>plaintext localhost<br/>No Auth (authorized)"| CatalogREST

    %% App to Data
    RegistryREST -->|"PostgreSQL/5432<br/>configurable SSL<br/>Password"| RegistryDB
    RegistryREST -.->|"MySQL/3306<br/>configurable SSL<br/>Password"| ExternalDB
    CatalogREST -->|"PostgreSQL/5432<br/>plaintext<br/>Password"| CatalogDB

    %% Operator to K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Serving Cert
    ServingCert -.->|"auto-provision<br/>TLS certs"| RegistryProxy
    ServingCert -.->|"auto-provision<br/>TLS certs"| CatalogProxy

