%% ML Metadata (MLMD) - RBAC & Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: MLMD defines no RBAC resources itself. This diagram shows
%% the security model including authentication and container security.

graph TD
    subgraph "Container Security"
        Container["odh-mlmd-grpc-server-rhel9<br/>Base: UBI9-minimal"]
        RuntimeUser["Runtime User<br/>UID: 65534 (nobody)<br/>GID: 65534 (nogroup)"]
        Binary["/bin/metadata_store_server<br/>C++17 compiled binary"]
        Container --> RuntimeUser
        Container --> Binary
    end

    subgraph "Authentication Model"
        direction TB
        DefaultAuth["Default Mode<br/>No Authentication<br/>(insecure gRPC channel)"]
        TLSAuth["TLS Mode<br/>SSLConfig with<br/>server_cert + server_key"]
        mTLSAuth["mTLS Mode<br/>SSLConfig with<br/>client_verify=true<br/>Requires client certificate"]
    end

    subgraph "Secrets (Deployment-Specific)"
        DBCreds["Database Credentials<br/>(Opaque)<br/>host, port, user, password<br/>Provisioned by: DSP Operator"]
        TLSCerts["TLS Certificates<br/>(kubernetes.io/tls)<br/>Server cert/key, client cert<br/>Provisioned by: Admin/cert-manager"]
        DBSSLCerts["DB SSL Certificates<br/>(Opaque)<br/>sslcert, sslkey, sslrootcert<br/>Provisioned by: Admin"]
    end

    subgraph "RBAC (Managed by DSP Operator)"
        DSPOperator["DSP Operator<br/>manages pod RBAC"]
        SA["ServiceAccount<br/>(deployment-specific)"]
        DSPOperator -->|creates| SA
        SA -->|assigned to| Container
    end

    %% Connections
    TLSAuth -->|encrypts| Binary
    mTLSAuth -->|authenticates clients| Binary
    DBCreds -->|mounted to| Container
    TLSCerts -->|mounted to| Container
    DBSSLCerts -->|mounted to| Container

    style Container fill:#4a90e2,color:#fff
    style RuntimeUser fill:#5b9bd5,color:#fff
    style Binary fill:#5b9bd5,color:#fff
    style DefaultAuth fill:#ff6b6b,color:#fff
    style TLSAuth fill:#ffd93d,color:#333
    style mTLSAuth fill:#7ed321,color:#fff
    style DBCreds fill:#f5a623,color:#fff
    style TLSCerts fill:#f5a623,color:#fff
    style DBSSLCerts fill:#f5a623,color:#fff
    style DSPOperator fill:#7ed321,color:#fff
    style SA fill:#dae8fc
