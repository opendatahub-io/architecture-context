/*
 * vLLM Gaudi - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/vllm-gaudi.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM inference endpoints"

        vllmGaudi = softwareSystem "vLLM Gaudi" "Intel Gaudi HPU plugin for vLLM enabling optimized LLM inference as an OpenAI-compatible API server" {
            apiServer = container "vLLM OpenAI API Server" "OpenAI-compatible REST API for chat completions, completions, embeddings" "Python / vLLM v0.14.1" "Web Server"
            hpuPlatform = container "HpuPlatform" "vLLM Platform plugin for Intel Gaudi — device management, attention backend selection, config validation" "Python Plugin"
            hpuWorker = container "HPUWorker" "Per-device model execution, KV-cache management, and distributed communication on HPU" "Python Worker"
            hpuModelRunner = container "HPUModelRunner" "Model forward passes, input batching/bucketing, warmup, profiling on HPU" "Python (6325 lines)"
            hpuCommunicator = container "HpuCommunicator" "All-reduce, all-gather for tensor/expert parallelism via HCCL" "Python / HCCL"
            nixlConnector = container "HPU NIXL Connector" "KV-cache transfer for disaggregated prefill/decode" "Python / UCX" "Optional"
            customOps = container "Custom Ops" "HPU-optimized FP8, rotary embedding, fused MoE, LayerNorm, GPTQ, AWQ" "Python / Habana"
            attentionBackends = container "Attention Backends" "HPUAttentionV1, HPUUnifiedAttention, HPUMLA, HPUUnifiedMLA" "Python / Habana"
        }

        kserve = softwareSystem "KServe" "Serving framework that deploys and routes to inference containers" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic routing, and auth enforcement" "External"
        ray = softwareSystem "Ray" "Distributed computing framework for multi-HPU worker orchestration" "External"
        synapseAI = softwareSystem "Intel Synapse AI" "Gaudi hardware drivers and runtime (v1.23.0)" "External"
        pytorchHabana = softwareSystem "PyTorch Habana" "Deep learning framework with HPU support (v2.9.0)" "External"
        s3 = softwareSystem "Model Storage (S3/PVC)" "Stores model weight artifacts" "External"
        hfHub = softwareSystem "Hugging Face Hub" "Model and tokenizer repository" "External"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata, models loaded from storage configured by serving platform" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "Management UI for configuring and deploying inference services" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection for inference monitoring" "External"

        user -> kserve "Deploys InferenceService via Dashboard/kubectl"
        user -> vllmGaudi "POST /v1/chat/completions (via KServe route)" "HTTPS/443"
        kserve -> vllmGaudi "Deploys and routes inference traffic" "HTTP/8000"
        istio -> vllmGaudi "mTLS sidecar proxy" "HTTP/15006"
        vllmGaudi -> synapseAI "Uses Gaudi drivers for HPU execution"
        vllmGaudi -> pytorchHabana "Model execution on HPU" "Device API"
        vllmGaudi -> ray "Distributed worker orchestration" "TCP/6379"
        vllmGaudi -> s3 "Downloads model weights at startup" "HTTPS/443"
        vllmGaudi -> hfHub "Downloads models/tokenizers if not cached" "HTTPS/443"
        dashboard -> kserve "Creates InferenceService resources"
        modelRegistry -> kserve "Provides model metadata"
        prometheus -> vllmGaudi "Scrapes /metrics endpoint" "HTTP/8000"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Web Server" {
                shape WebBrowser
            }
            element "Optional" {
                background #cccccc
                color #333333
                border dashed
            }
        }
    }
}
