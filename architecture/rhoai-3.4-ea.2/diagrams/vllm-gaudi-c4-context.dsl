// C4 Context Diagram for vllm-gaudi
// Generated by: Claude Opus 4.6
workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries LLM inference services on Intel Gaudi hardware"
        mlEngineer = person "ML Engineer" "Configures model serving runtimes and quantization"

        vllmGaudi = softwareSystem "vLLM Gaudi" "Hardware plugin enabling vLLM LLM inference on Intel Gaudi AI accelerators" {
            apiServer = container "OpenAI API Server" "vLLM OpenAI-compatible API server serving completions, chat, embeddings" "Python / vLLM"
            hpuPlatform = container "HpuPlatform Plugin" "Core platform class registering Gaudi HPU as vLLM device target" "Python Plugin"
            attentionBackends = container "HPU Attention Backends" "HPU-optimized attention: V1, Unified, MLA" "Python Module"
            customOps = container "HPU Custom Ops" "Fused MoE, rotary embedding, LayerNorm, quantization ops" "Python Module"
            modelRunner = container "HPU Model Runner" "Batch scheduling, graph capture, memory management" "Python Module"
            hpuWorker = container "HPU Worker" "Per-device model loading, KV-cache allocation, inference execution" "Python Module"
            communicator = container "HPU Communicator" "HCCL distributed communication (all-reduce, all-gather)" "Python Module"
            nixlConnector = container "NIXL KV Connector" "Disaggregated KV-cache transfer between prefill/decode instances" "Python Module"
            eagleDecoding = container "EAGLE Speculative Decoding" "HPU-specific speculative decoding for faster inference" "Python Module"
        }

        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Authentication sidecar with SubjectAccessReview" "Sidecar"
        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle and routing" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages ServingRuntime resources and platform configuration" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "User interface for configuring inference services" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact resolution and metadata" "Internal RHOAI"
        dsGateway = softwareSystem "Data Science Gateway" "Platform ingress via Gateway API HTTPRoute" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"
        gaudiDevicePlugin = softwareSystem "Intel Gaudi Device Plugin" "Allocates HPU devices to pods" "External"
        ray = softwareSystem "Ray" "Distributed execution for multi-node inference" "External"
        s3Storage = softwareSystem "Model Storage (S3/PVC)" "Model weight and artifact storage" "External"
        hfHub = softwareSystem "Hugging Face Hub" "Model weights and tokenizer downloads" "External"

        // Relationships
        datascientist -> dsGateway "Sends inference requests" "HTTPS/443"
        datascientist -> rhoaiDashboard "Configures serving runtimes" "HTTPS"
        mlEngineer -> rhoaiDashboard "Deploys inference services" "HTTPS"

        dsGateway -> kubeRbacProxy "Forwards authenticated requests" "HTTPS/8443"
        kubeRbacProxy -> vllmGaudi "Proxies to API server" "HTTP/8000"

        kserve -> vllmGaudi "Manages pod lifecycle and scaling" "Kubernetes API"
        rhoaiOperator -> kserve "Manages ServingRuntime resources" "Kubernetes API"

        vllmGaudi -> s3Storage "Downloads model weights" "HTTPS/443"
        vllmGaudi -> hfHub "Downloads models and tokenizers" "HTTPS/443"
        vllmGaudi -> ray "Multi-node distributed execution" "Ray/6379,10001"

        gaudiDevicePlugin -> vllmGaudi "Allocates habana.ai/gaudi resources" "Kubernetes API"
        prometheus -> vllmGaudi "Scrapes inference metrics" "HTTP/8000"
        vllmGaudi -> modelRegistry "Optional model metadata resolution" "API"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Sidecar" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
