%% RBAC Visualization: vllm-orchestrator-gateway
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        Note["No RBAC resources defined<br/>in this repository"]
    end

    subgraph "Authentication Model"
        direction TB
        ClientAuth["Client Authentication"]
        PassThrough["Pass-Through Model"]
        OrchestratorAuth["FMS Guardrails Orchestrator<br/>(Enforcement Point)"]

        ClientAuth -->|"Authorization header<br/>forwarded verbatim"| PassThrough
        PassThrough -->|"delegated to"| OrchestratorAuth
    end

    subgraph "Header Forwarding Policy"
        direction TB
        AuthHeader["Authorization Header<br/>Status: FORWARDED"]
        XForwarded["X-Forwarded-* Headers<br/>Status: FORWARDED"]
        OtherHeaders["All Other Headers<br/>Status: DROPPED"]
    end

    subgraph "TLS Identity (Optional)"
        direction TB
        ClientCert["Client Certificate<br/>/etc/tls/private/tls.crt"]
        PrivateKey["Private Key<br/>/etc/tls/private/tls.key"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt"]
        CertProvisioner["Provisioned By:<br/>cert-manager / service-ca-operator"]

        CertProvisioner -->|"provisions"| ClientCert
        CertProvisioner -->|"provisions"| PrivateKey
        CertProvisioner -->|"provisions"| CACert
    end

    subgraph "Deployment RBAC (Expected)"
        DeployNote["RBAC managed by deploying<br/>operator or platform<br/>(not defined in this repo)"]
    end

    style Note fill:#fff3cd,stroke:#d6a700,color:#333
    style PassThrough fill:#4a90e2,stroke:#333,color:#fff
    style OrchestratorAuth fill:#7ed321,stroke:#333,color:#fff
    style AuthHeader fill:#d4edda,stroke:#28a745
    style XForwarded fill:#d4edda,stroke:#28a745
    style OtherHeaders fill:#f8d7da,stroke:#dc3545
    style ClientCert fill:#fff3cd,stroke:#d6a700
    style PrivateKey fill:#fff3cd,stroke:#d6a700
    style CACert fill:#fff3cd,stroke:#d6a700
    style DeployNote fill:#e8e8e8,stroke:#999
