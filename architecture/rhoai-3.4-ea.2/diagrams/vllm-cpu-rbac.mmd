---
title: "vLLM CPU - RBAC and Security Visualization"
---
graph TD
    subgraph ContainerSecurity["Container Security"]
        Container["vLLM CPU Container<br/>Image: rhoai/odh-vllm-cpu-rhel9<br/>Base: UBI9 Minimal<br/>User: 2000 (non-root)<br/>Group: 0 (root group)"]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

        subgraph PlatformAuth["Platform-Level Auth<br/>(Managed by RHOAI)"]
            KubeRBAC["kube-rbac-proxy<br/>Sidecar injection<br/>by KServe"]
            IstioMTLS["Istio mTLS<br/>Service mesh auth"]
            GatewayTLS["Gateway TLS<br/>TLS 1.2+ termination"]
        end

        subgraph AppAuth["Application-Level Auth<br/>(Optional)"]
            APIKeyAuth["API Key Auth<br/>--api-key / VLLM_API_KEY<br/>FastAPI middleware"]
        end

        subgraph NoAuth["Unauthenticated Endpoints"]
            HealthEndpoints["/health, /ping<br/>/metrics, /load<br/>/version, /server_info"]
            GRPCEndpoints["gRPC VllmEngine.*<br/>No built-in auth<br/>Network-level only"]
        end
    end

    subgraph Secrets["Secrets"]
        HFToken["HF_TOKEN<br/>Type: Opaque<br/>Purpose: HuggingFace auth<br/>Provisioned by: User<br/>Auto-rotate: No"]
        SSLCerts["SSL Certs<br/>Type: kubernetes.io/tls<br/>Purpose: Optional HTTPS<br/>Provisioned by: User/cert-manager<br/>Auto-rotate: No"]
        APIKey["API Key<br/>Type: Opaque<br/>Purpose: Request auth<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    subgraph KServeManaged["KServe-Managed RBAC"]
        KServeSA["ServiceAccount<br/>(created by KServe)"]
        KServeRoles["Roles & Bindings<br/>(managed by KServe<br/>& RHOAI operator)"]
    end

    %% Connections
    Container -->|"protected by"| PlatformAuth
    Container -->|"optionally uses"| AppAuth
    Container -->|"exposes"| NoAuth
    Container -->|"uses"| Secrets
    KServeSA -->|"bound to"| KServeRoles
    KServeSA -->|"runs"| Container

