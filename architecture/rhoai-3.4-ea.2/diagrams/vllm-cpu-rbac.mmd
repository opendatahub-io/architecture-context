%% vLLM CPU - RBAC & Authentication Visualization
%% Generated by: Claude Opus 4.6
%% Note: vLLM CPU defines no RBAC resources directly.
%% RBAC is managed by the deploying operator (KServe/RHOAI operator).
%% This diagram shows the authentication and authorization model.

graph TD
    subgraph "Container Security"
        Pod["vLLM CPU Pod<br/>UID: 2000 (non-root)<br/>GID: 0 (root group)<br/>Umask: 002<br/>Base: UBI 9 minimal"]
    end

    subgraph "Authentication Mechanisms"
        APIKeyAuth["API Key Auth<br/>(--api-key flag)<br/>Header: Authorization Bearer"]
        NoAuth["No Auth Required<br/>Health/Status Endpoints"]
        GRPCNoAuth["No Built-in Auth<br/>gRPC Endpoints<br/>Relies on NetworkPolicy"]
    end

    subgraph "HTTP Endpoints (Port 8000)"
        AuthEndpoints["Authenticated Endpoints<br/>(when --api-key set)<br/>/v1/chat/completions<br/>/v1/completions<br/>/v1/embeddings<br/>/v1/models<br/>/v1/responses<br/>/v1/messages<br/>/tokenize, /detokenize<br/>/classify, /score, /rerank"]
        UnAuthEndpoints["Unauthenticated Endpoints<br/>/health<br/>/version<br/>/load<br/>/server_info<br/>/ping<br/>/tokenizer_info"]
    end

    subgraph "gRPC Endpoints (Port 50051)"
        GRPCEndpoints["VllmEngine RPCs<br/>Generate, Embed<br/>HealthCheck, Abort<br/>GetModelInfo, GetServerInfo<br/>plaintext, no auth"]
    end

    subgraph "Secrets"
        TLSKey["ssl-keyfile<br/>(File mount)<br/>TLS private key<br/>Auto-rotate: SSLCertRefresher"]
        TLSCert["ssl-certfile<br/>(File mount)<br/>TLS certificate<br/>Auto-rotate: SSLCertRefresher"]
        TLSCA["ssl-ca-certs<br/>(File mount)<br/>CA certificates<br/>Auto-rotate: SSLCertRefresher"]
        APIKeySecret["api-key<br/>(Env var)<br/>API auth key(s)<br/>No auto-rotate"]
        HFToken["hf-token<br/>(Env var)<br/>HuggingFace token<br/>No auto-rotate"]
    end

    subgraph "External RBAC (Managed by KServe/RHOAI)"
        KServeRBAC["KServe Operator RBAC<br/>Manages InferenceService CRs<br/>Creates Deployments, Services"]
        GatewayAuth["KServe Gateway Auth<br/>RHOAI 3.x: kube-rbac-proxy<br/>RHOAI 2.x: oauth-proxy"]
    end

    %% Connections
    APIKeyAuth -->|"protects"| AuthEndpoints
    NoAuth -->|"allows"| UnAuthEndpoints
    GRPCNoAuth -->|"allows"| GRPCEndpoints

    Pod --> AuthEndpoints
    Pod --> UnAuthEndpoints
    Pod --> GRPCEndpoints

    TLSKey -->|"mounted to"| Pod
    TLSCert -->|"mounted to"| Pod
    TLSCA -->|"mounted to"| Pod
    APIKeySecret -->|"env var"| Pod
    HFToken -->|"env var"| Pod

    KServeRBAC -->|"deploys"| Pod
    GatewayAuth -->|"fronts"| Pod

    %% Styling
    style Pod fill:#4a90e2,color:#fff
    style APIKeyAuth fill:#e74c3c,color:#fff
    style NoAuth fill:#27ae60,color:#fff
    style GRPCNoAuth fill:#f39c12,color:#fff
    style AuthEndpoints fill:#e74c3c,color:#fff
    style UnAuthEndpoints fill:#27ae60,color:#fff
    style GRPCEndpoints fill:#f39c12,color:#fff
    style TLSKey fill:#9b59b6,color:#fff
    style TLSCert fill:#9b59b6,color:#fff
    style TLSCA fill:#9b59b6,color:#fff
    style APIKeySecret fill:#9b59b6,color:#fff
    style HFToken fill:#9b59b6,color:#fff
    style KServeRBAC fill:#7ed321,color:#fff
    style GatewayAuth fill:#7ed321,color:#fff
