/*
 * C4 Context Diagram: Distributed Workloads
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.2/distributed-workloads.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates distributed training jobs and manages GPU workloads"
        ciSystem = person "CI/CD System" "Runs E2E integration tests and builds container images"

        distributedWorkloads = softwareSystem "Distributed Workloads" "Container runtime images and E2E tests for distributed AI/ML training on RHOAI" {
            trainingImagesCUDA = container "Training Runtime Images (CUDA)" "PyTorch training images with NVIDIA CUDA 12.1-13.0 on UBI9" "Container Image"
            trainingImagesROCm = container "Training Runtime Images (ROCm)" "PyTorch training images with AMD ROCm 6.2-6.4 on UBI9" "Container Image"
            rayImagesCUDA = container "Ray Runtime Images (CUDA)" "Ray cluster images with NVIDIA CUDA on UBI9" "Container Image"
            rayImagesROCm = container "Ray Runtime Images (ROCm)" "Ray cluster images with AMD ROCm on UBI9" "Container Image"
            universalImages = container "Universal Training Images (th06)" "Combined Jupyter + ML runtime for interactive and batch training" "Container Image"
            e2eTests = container "E2E Test Suites" "Go-based integration tests for KFTO, Trainer, ODH, FMS" "Go Test Framework"
        }

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Orchestrates distributed PyTorch training via PyTorchJob CRD" "Internal RHOAI"
        trainerV2 = softwareSystem "Kubeflow Trainer v2" "Next-gen training orchestration via TrainJob and ClusterTrainingRuntime" "Internal RHOAI"
        kubeRay = softwareSystem "KubeRay Operator" "Ray cluster lifecycle management via RayCluster and RayJob CRDs" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing, admission control, and resource fairness" "Internal RHOAI"
        kueueOperator = softwareSystem "Kueue Operator" "Manages Kueue deployment lifecycle on OpenShift" "Internal RHOAI"
        jobSetController = softwareSystem "JobSet Controller" "Coordinated multi-job execution via JobSet CRD" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Platform component lifecycle via DataScienceCluster CRD" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for notebook spawning and workload management" "Internal RHOAI"
        jupyterWorkbench = softwareSystem "Jupyter Minimal Workbench" "Base container image for universal training images" "Internal RHOAI"

        s3Storage = softwareSystem "S3-compatible Storage" "Model artifact and training dataset storage (AWS/MinIO)" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Pre-trained model repository" "External"
        konflux = softwareSystem "Konflux Central" "Tekton-based CI/CD pipeline for container image builds" "External"
        prometheus = softwareSystem "Prometheus" "Monitoring system for GPU utilization (DCGM metrics)" "External"
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform" "External"

        # User interactions
        user -> distributedWorkloads "Creates PyTorchJob, TrainJob, RayJob via kubectl/oc"
        user -> odhDashboard "Launches notebooks with training images"
        ciSystem -> distributedWorkloads "Runs E2E tests"
        ciSystem -> konflux "Triggers image builds"

        # Internal RHOAI dependencies
        distributedWorkloads -> trainingOperator "Runtime images run in PyTorchJob pods" "CRD API / 6443 HTTPS"
        distributedWorkloads -> trainerV2 "Runtime images run in TrainJob pods" "CRD API / 6443 HTTPS"
        distributedWorkloads -> kubeRay "Runtime images run in RayCluster/RayJob pods" "CRD API / 6443 HTTPS"
        distributedWorkloads -> kueue "Training jobs queued via ClusterQueue/LocalQueue" "CRD API / 6443 HTTPS"
        distributedWorkloads -> kueueOperator "Tests verify Kueue Operator CR" "CRD API / 6443 HTTPS"
        distributedWorkloads -> jobSetController "TrainJob creates coordinated JobSets" "CRD API / 6443 HTTPS"
        distributedWorkloads -> rhoaiOperator "Tests verify DataScienceCluster state" "CRD API / 6443 HTTPS"
        universalImages -> jupyterWorkbench "Built on Jupyter Minimal base images" "Container base"

        # External dependencies
        distributedWorkloads -> s3Storage "Upload/download training data and models" "HTTPS/443"
        distributedWorkloads -> huggingFace "Download pre-trained models" "HTTPS/443"
        distributedWorkloads -> kubernetes "Creates/manages training pods" "HTTPS/6443"
        konflux -> distributedWorkloads "Builds container images via Tekton pipelines"
        prometheus -> distributedWorkloads "Scrapes GPU utilization metrics" "HTTP/9090"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container Image" {
                background #4a90e2
                color #ffffff
            }
            element "Go Test Framework" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
