// C4 Context Diagram: Model Metadata Collection
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Views available AI models in the RHOAI Dashboard"
        platformengineer = person "Platform Engineer" "Deploys and configures RHOAI platform"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Extracts, enriches, and catalogs metadata from Red Hat AI container model images, producing structured YAML catalogs shipped as a static data container" {
            modelExtractor = container "model-extractor" "Main CLI application that extracts metadata from OCI container images, enriches with HuggingFace data, and generates model catalogs" "Go CLI Binary"
            metadataReport = container "metadata-report" "Generates metadata completeness reports analyzing field population and data sources" "Go CLI Binary"
            dataContainer = container "Data Container" "Ships pre-generated catalog YAML files as a static data volume via sleep infinity" "UBI9-minimal Container"
            huggingfaceClient = container "HuggingFace Client" "Discovers Red Hat AI validated model collections and fetches model details/READMEs from HuggingFace API" "Go Package"
            registryClient = container "Registry Client" "Fetches OCI manifest metadata, timestamps, and architecture information from container registries" "Go Package"
            enrichmentEngine = container "Enrichment Engine" "Matches registry models to HuggingFace models using similarity scoring and merges metadata" "Go Package"
            catalogGenerator = container "Catalog Generator" "Aggregates individual model metadata files into unified YAML catalogs with deduplication" "Go Package"
            metadataParser = container "Metadata Parser" "Extracts structured metadata from model card markdown files using YAML frontmatter and regex patterns" "Go Package"
        }

        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Red Hat OpenShift AI Dashboard - displays AI model catalog to users" "Internal RHOAI"
        konflux = softwareSystem "Konflux CI/CD" "Build system that builds multi-arch container images using Tekton pipelines" "Internal"
        huggingface = softwareSystem "HuggingFace" "AI model hub - provides model collections, model details, and README/model cards" "External"
        redhatRegistry = softwareSystem "Red Hat Container Registry" "registry.redhat.io - hosts OCI container images for Red Hat AI models" "External"
        quay = softwareSystem "Quay.io" "Container image registry for built images" "External"

        // Build-time relationships
        konflux -> modelMetadataCollection "Triggers build pipeline via Tekton"
        modelExtractor -> huggingfaceClient "Uses for model discovery"
        modelExtractor -> registryClient "Uses for image inspection"
        modelExtractor -> enrichmentEngine "Uses for metadata enrichment"
        modelExtractor -> catalogGenerator "Uses for catalog generation"
        modelExtractor -> metadataParser "Uses for model card parsing"
        huggingfaceClient -> huggingface "Fetches model collections and details" "HTTPS/443 TLS 1.2+"
        registryClient -> redhatRegistry "Fetches OCI manifests and image layers" "HTTPS/443 TLS 1.2+"
        catalogGenerator -> dataContainer "Generates catalog YAML files into /app/data"
        konflux -> quay "Pushes built multi-arch container image" "HTTPS/443"

        // Runtime relationships
        rhoaiDashboard -> dataContainer "Reads catalog YAML files via volume mount" "Filesystem (read-only)"
        datascientist -> rhoaiDashboard "Views available AI models"
        platformengineer -> konflux "Manages build pipelines"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #f5a623
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
