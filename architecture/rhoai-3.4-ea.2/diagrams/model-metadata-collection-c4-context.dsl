/*
 * C4 Context Diagram: Model Metadata Collection
 * Generated by: Claude Opus 4.6
 *
 * View with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 */

workspace {
    model {
        dataScienceTeam = person "Data Science Team" "Browses and selects AI models for deployment"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform and model catalogs"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time tool and data container that collects, enriches, and packages AI model metadata into structured YAML catalogs" {
            modelExtractor = container "model-extractor" "Extracts metadata from OCI modelcar images, enriches with HuggingFace data, generates YAML catalogs" "Go CLI Tool"
            metadataReport = container "metadata-report" "Generates metadata completeness reports analyzing catalog data quality" "Go CLI Tool"
            dataContainer = container "odh-model-metadata-collection" "Ships pre-generated model catalog YAML files via volume mount" "Data Container (ubi9-minimal)"
            huggingfaceClient = container "internal/huggingface" "HuggingFace API client for collections, model details, READMEs" "Go Package"
            registryClient = container "internal/registry" "OCI container registry client for manifests and artifacts" "Go Package"
            catalogPackage = container "internal/catalog" "Merges, deduplicates, and generates final YAML catalogs" "Go Package"
            enrichmentPackage = container "internal/enrichment" "Metadata enrichment pipeline matching registry to HuggingFace models" "Go Package"
        }

        huggingFaceAPI = softwareSystem "HuggingFace API" "Public REST API for AI model metadata, collections, and READMEs" "External"
        ociRegistries = softwareSystem "OCI Container Registries" "Container registries hosting Red Hat AI modelcar images (registry.redhat.io, quay.io)" "External"
        modelRegistry = softwareSystem "Model Registry" "Stores and serves model metadata for discovery and registration" "Internal ODH"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "User-facing dashboard for browsing and managing AI models" "Internal ODH"
        redHatModelcars = softwareSystem "Red Hat AI Modelcar Images" "OCI container images containing AI models and model cards" "External"
        konflux = softwareSystem "Konflux" "Tekton-based CI/CD platform for building and publishing containers" "External"

        # Build-time relationships
        modelExtractor -> huggingFaceAPI "Fetches model collections, details, READMEs" "HTTPS/443, TLS 1.2+, No Auth"
        modelExtractor -> ociRegistries "Pulls image manifests, layers, config blobs" "HTTPS/443, TLS 1.2+, Bearer Token"
        modelExtractor -> redHatModelcars "Inspects model containers for metadata" "Docker Registry v2 API"
        huggingfaceClient -> huggingFaceAPI "REST API calls" "HTTPS"
        registryClient -> ociRegistries "Registry v2 API calls" "HTTPS"
        modelExtractor -> catalogPackage "Generates catalogs"
        modelExtractor -> enrichmentPackage "Enriches metadata"
        modelExtractor -> huggingfaceClient "Uses"
        modelExtractor -> registryClient "Uses"
        metadataReport -> catalogPackage "Analyzes catalog data"
        konflux -> modelMetadataCollection "Builds and publishes container image" "Tekton Pipelines"

        # Runtime relationships
        modelRegistry -> dataContainer "Reads model catalog YAML files" "Volume mount, File I/O"
        rhoaiDashboard -> dataContainer "Reads model catalog data for browsing" "Volume mount, File I/O"
        dataScienceTeam -> rhoaiDashboard "Browses model catalog" "HTTPS"
        platformAdmin -> modelMetadataCollection "Configures model index and families" "YAML configuration"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #6baed6
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
