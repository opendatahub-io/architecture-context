    style JupyterDataScience fill:#7ed321,stroke:#333,stroke-width:2px
    style JupyterTensorFlow fill:#7ed321,stroke:#333,stroke-width:2px
    style JupyterPyTorch fill:#7ed321,stroke:#333,stroke-width:2px
    style JupyterTrustyAI fill:#7ed321,stroke:#333,stroke-width:2px

    style CUDAJupyter fill:#f5a623,stroke:#333,stroke-width:2px
    style HabanaJupyter fill:#f5a623,stroke:#333,stroke-width:2px
    style IntelJupyter fill:#f5a623,stroke:#333,stroke-width:2px
    style AMDJupyter fill:#f5a623,stroke:#333,stroke-width:2px

    style CodeServer fill:#bd10e0,stroke:#333,stroke-width:2px
    style RStudio fill:#bd10e0,stroke:#333,stroke-width:2px

    style RuntimeMinimal fill:#50e3c2,stroke:#333,stroke-width:2px
    style RuntimeDataScience fill:#50e3c2,stroke:#333,stroke-width:2px
    style RuntimePyTorch fill:#50e3c2,stroke:#333,stroke-width:2px
    style RuntimeTensorFlow fill:#50e3c2,stroke:#333,stroke-width:2px

