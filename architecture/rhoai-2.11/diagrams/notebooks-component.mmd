graph TB
    subgraph "Notebook Workbench Images"
        direction TB

        subgraph BaseImages["Base Images"]
            BaseUBI9[Base UBI9 Python 3.9]
            BaseUBI8[Base UBI8 Python 3.8]
            CUDABase[CUDA UBI9 Python 3.9]
            HabanaBase[Habana UBI8 Python 3.8]
            IntelBase[Intel Base GPU UBI9]
            AMDBase[AMD RHEL9 Python 3.9]
        end

        subgraph JupyterWorkbenches["Jupyter Workbenches"]
            JupyterMinimal[Jupyter Minimal<br/>JupyterLab 3.6.x]
            JupyterDataScience[Jupyter Data Science<br/>Pandas, NumPy, Scikit-learn]
            JupyterTensorFlow[Jupyter TensorFlow<br/>TF 2.x]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.x]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Model Explainability]
        end

        subgraph GPUWorkbenches["GPU-Accelerated Workbenches"]
            CUDAJupyter[CUDA Jupyter<br/>NVIDIA CUDA 11.8/12.x]
            HabanaJupyter[Habana Jupyter<br/>Intel Gaudi SynapseAI]
            IntelJupyter[Intel ML Jupyter<br/>oneAPI]
            AMDJupyter[AMD Jupyter<br/>ROCm PyTorch/TF]
        end

        subgraph OtherWorkbenches["Other IDEs"]
            CodeServer[Code Server<br/>VS Code Browser]
            RStudio[RStudio Server<br/>R 4.3]
        end

        subgraph RuntimeImages["Runtime Images"]
            RuntimeMinimal[Runtime Minimal<br/>No JupyterLab UI]
            RuntimeDataScience[Runtime Data Science]
            RuntimePyTorch[Runtime PyTorch]
            RuntimeTensorFlow[Runtime TensorFlow]
        end
    end

    subgraph Kubernetes["Kubernetes Resources"]
        ImageStreams[ImageStream Manifests<br/>Image metadata & tags]
        BuildConfigs[BuildConfig Manifests<br/>RStudio builds]
    end

    subgraph ExternalComponents["External Components"]
        NotebookController[ODH Notebook Controller<br/>Pod Lifecycle Manager]
        Dashboard[ODH Dashboard<br/>Workbench Catalog UI]
        OAuthProxy[OAuth Proxy<br/>Authentication Sidecar]
        QuayRegistry[Quay.io Registry<br/>Image Storage]
    end

    %% Build Hierarchy
    BaseUBI9 -->|extends| JupyterMinimal
    JupyterMinimal -->|extends| JupyterDataScience
    JupyterDataScience -->|extends| JupyterTensorFlow
    JupyterDataScience -->|extends| JupyterPyTorch
    JupyterMinimal -->|extends| JupyterTrustyAI

    BaseUBI9 -->|extends| CUDABase
    CUDABase -->|extends| CUDAJupyter

    BaseUBI8 -->|extends| HabanaBase
    HabanaBase -->|extends| HabanaJupyter

    IntelBase -->|extends| IntelJupyter
    AMDBase -->|extends| AMDJupyter

    BaseUBI9 -->|extends| CodeServer
    BaseUBI9 -->|extends| RStudio

    BaseUBI9 -->|extends| RuntimeMinimal
    RuntimeMinimal -->|extends| RuntimeDataScience
    RuntimeDataScience -->|extends| RuntimePyTorch
    RuntimeDataScience -->|extends| RuntimeTensorFlow

    %% Kubernetes Integration
    JupyterWorkbenches -.->|referenced by| ImageStreams
    GPUWorkbenches -.->|referenced by| ImageStreams
    OtherWorkbenches -.->|referenced by| ImageStreams
    RuntimeImages -.->|referenced by| ImageStreams

    RStudio -.->|built by| BuildConfigs

    %% External Interactions
    ImageStreams -->|read by| NotebookController
    ImageStreams -->|queried by| Dashboard
    NotebookController -->|pulls images from| QuayRegistry
    NotebookController -->|creates pods with| OAuthProxy

    %% Styling
    style BaseUBI9 fill:#4a90e2,stroke:#333,stroke-width:2px
    style BaseUBI8 fill:#4a90e2,stroke:#333,stroke-width:2px
    style CUDABase fill:#76b900,stroke:#333,stroke-width:2px
    style HabanaBase fill:#76b900,stroke:#333,stroke-width:2px
    style IntelBase fill:#76b900,stroke:#333,stroke-width:2px
    style AMDBase fill:#76b900,stroke:#333,stroke-width:2px

