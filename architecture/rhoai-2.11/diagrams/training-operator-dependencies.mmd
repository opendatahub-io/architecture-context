graph LR
    TrainingOp["Kubeflow Training Operator<br/>(rhoai-2.11)"]

    %% External Dependencies (Required)
    TrainingOp -->|"platform<br/>v1.25+"| K8s[Kubernetes 1.25+]
    TrainingOp -->|"controller framework<br/>v0.14.0"| ControllerRuntime[controller-runtime]

    %% External Dependencies (Optional)
    TrainingOp -.->|"gang scheduling<br/>v1beta1"| Volcano[Volcano Scheduler]
    TrainingOp -.->|"coscheduling<br/>v1alpha1"| SchedulerPlugins[Scheduler Plugins]
    TrainingOp -.->|"metrics collection"| Prometheus[Prometheus]

    %% Internal ODH Dependencies
    ODHOperator[opendatahub-operator] -->|"deploys & manages"| TrainingOp
    TrainingOp -->|"PodMonitor CRD"| ODHPrometheus[Prometheus ODH]

    %% Integration Points
    TrainingOp -->|"Watch & Manage<br/>CRDs, Pods, Services<br/>HTTPS/443"| K8sAPI[Kubernetes API]
    TrainingOp -->|"Pull images<br/>HTTPS/443"| ContainerRegistry[Container Registry]
    TrainingOp -.->|"elastic training<br/>HPA integration"| HPA[Horizontal Pod Autoscaler]

    %% Training Job Dependencies (User-provided)
    TrainingJobs[Training Job Pods<br/>PyTorch/TF/MPI/etc.] -->|"created by"| TrainingOp
    TrainingJobs -.->|"training data<br/>HTTPS/443"| ObjectStorage[Object Storage S3/etc.]
    TrainingJobs -->|"pod-to-pod comms<br/>TCP/23456"| TrainingJobs

    %% CRDs Managed
    PyTorchJobCRD[PyTorchJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp
    TFJobCRD[TFJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp
    MPIJobCRD[MPIJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp
    XGBoostJobCRD[XGBoostJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp
    MXJobCRD[MXJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp
    PaddleJobCRD[PaddleJob CRD<br/>kubeflow.org/v1] -.->|watched by| TrainingOp

    %% Styling
    style TrainingOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (required)
    style K8s fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style ContainerRegistry fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% External dependencies (optional)
    style Volcano fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style SchedulerPlugins fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Prometheus fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style HPA fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style ObjectStorage fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5

    %% Internal ODH
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHPrometheus fill:#7ed321,stroke:#333,stroke-width:2px

    %% CRDs
    style PyTorchJobCRD fill:#f5a623,stroke:#333,stroke-width:2px
    style TFJobCRD fill:#f5a623,stroke:#333,stroke-width:2px
    style MPIJobCRD fill:#f5a623,stroke:#333,stroke-width:2px
    style XGBoostJobCRD fill:#f5a623,stroke:#333,stroke-width:2px
    style MXJobCRD fill:#f5a623,stroke:#333,stroke-width:2px
    style PaddleJobCRD fill:#f5a623,stroke:#333,stroke-width:2px

    %% Training jobs
    style TrainingJobs fill:#e8f5e9,stroke:#333,stroke-width:2px
