graph TD
    subgraph "Controller Service Account"
        SA[ServiceAccount: manager<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager[ClusterRoleBinding:<br/>manager-rolebinding]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_Leader[RoleBinding:<br/>leader-election-rolebinding<br/>Namespace: controller namespace]
    end

    subgraph "Cluster Roles"
        CR_Manager[ClusterRole: manager-role]
        CR_Edit[ClusterRole: notebooks-edit<br/>USER-FACING]
        CR_View[ClusterRole: notebooks-view<br/>USER-FACING]
    end

    subgraph "Roles (Namespace-scoped)"
        R_Leader[Role: leader-election-role<br/>Namespace: controller namespace]
    end

    subgraph "API Resources - kubeflow.org"
        Notebooks_CRD[notebooks<br/>notebooks/status<br/>notebooks/finalizers]
    end

    subgraph "API Resources - route.openshift.io"
        Routes[routes]
    end

    subgraph "API Resources - core"
        Core_Resources[services<br/>serviceaccounts<br/>secrets<br/>configmaps]
        Leader_Resources[configmaps<br/>events]
    end

    subgraph "API Resources - networking.k8s.io"
        NetworkPolicies[networkpolicies]
    end

    subgraph "API Resources - config.openshift.io"
        Proxies[proxies]
    end

    subgraph "API Resources - coordination.k8s.io"
        Leases[leases]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| RB_Leader

    %% Cluster Role Bindings
    CRB_Manager -->|grants| CR_Manager

    %% Role Bindings
    RB_Leader -->|grants| R_Leader

    %% Manager Role Permissions
    CR_Manager -->|"get, list, watch, patch"| Notebooks_CRD
    CR_Manager -->|"get, list, watch, create,<br/>update, patch"| Routes
    CR_Manager -->|"get, list, watch, create,<br/>update, patch"| Core_Resources
    CR_Manager -->|"get, list, watch, create,<br/>update, patch"| NetworkPolicies
    CR_Manager -->|"get, list, watch"| Proxies

    %% User-facing Roles
    CR_Edit -->|"get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"| Notebooks_CRD
    CR_View -->|"get, list, watch"| Notebooks_CRD

    %% Leader Election Role
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Leader_Resources
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style RB_Leader fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style CR_Edit fill:#7ed321,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5,color:#fff
    style CR_View fill:#7ed321,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5,color:#fff
    style R_Leader fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Notebooks_CRD fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style Routes fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style Core_Resources fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style NetworkPolicies fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style Proxies fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style Leader_Resources fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
    style Leases fill:#e1bee7,stroke:#8e24aa,stroke-width:2px,color:#333
