graph TD
    subgraph "Service Accounts"
        SA1[controller-manager<br/>Namespace: opendatahub/redhat-ods-applications]
        SA2["{instance-name}-proxy<br/>Namespace: {user-namespace}<br/>(created per instance)"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3["{instance-name}-proxy<br/>(per instance)"]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[leader-election-role]
        CR3["cluster-admin<br/>(for OAuth SAR)"]
        CR4[trustyaiservice-editor-role]
        CR5[trustyaiservice-viewer-role]
    end

    subgraph "API Resources - Core"
        Core1[core/configmaps]
        Core2[core/events]
        Core3[core/pods]
        Core4[core/secrets]
        Core5[core/serviceaccounts]
        Core6[core/services]
        Core7[core/persistentvolumeclaims]
        Core8[core/persistentvolumes]
    end

    subgraph "API Resources - Apps"
        Apps1[apps/deployments]
        Apps2[apps/deployments/status]
        Apps3[apps/deployments/finalizers]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAI1[trustyai.opendatahub.io<br/>TrustyAIService]
        TrustyAI2[trustyai.opendatahub.io<br/>TrustyAIService/status]
        TrustyAI3[trustyai.opendatahub.io<br/>TrustyAIService/finalizers]
    end

    subgraph "API Resources - KServe"
        KServe1[serving.kserve.io<br/>InferenceService]
        KServe2[serving.kserve.io<br/>InferenceService/finalizers]
        KServe3[serving.kserve.io<br/>ServingRuntime]
        KServe4[serving.kserve.io<br/>ServingRuntime/status]
    end

    subgraph "API Resources - Other"
        Other1[route.openshift.io<br/>routes]
        Other2[monitoring.coreos.com<br/>servicemonitors]
        Other3[rbac.authorization.k8s.io<br/>clusterrolebindings]
        Other4[coordination.k8s.io<br/>leases]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| CRB3

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% manager-role permissions (Core)
    CR1 -->|create,delete,get,list,patch,update,watch| Core1
    CR1 -->|create,patch,update| Core2
    CR1 -->|create,delete,get,list,patch,update,watch| Core3
    CR1 -->|create,delete,get,list,patch,update,watch| Core4
    CR1 -->|create,delete,get,list,update,watch| Core5
    CR1 -->|create,delete,get,list,patch,update,watch| Core6
    CR1 -->|create,delete,get,list,patch,update,watch| Core7
    CR1 -->|get,list,watch| Core8

    %% manager-role permissions (Apps)
    CR1 -->|create,delete,get,list,patch,update,watch| Apps1
    CR1 -->|get,patch,update| Apps2
    CR1 -->|update| Apps3

    %% manager-role permissions (TrustyAI)
    CR1 -->|create,delete,get,list,patch,update,watch| TrustyAI1
    CR1 -->|get,patch,update| TrustyAI2
    CR1 -->|update| TrustyAI3

    %% manager-role permissions (KServe)
    CR1 -->|get,list,patch,update,watch| KServe1
    CR1 -->|delete,get,list,patch,update,watch| KServe2
    CR1 -->|create,delete,get,list,patch,update,watch| KServe3
    CR1 -->|get,patch,update| KServe4

    %% manager-role permissions (Other)
    CR1 -->|create,delete,get,list,patch,update,watch| Other1
    CR1 -->|create,list,watch| Other2
    CR1 -->|create,delete,get,list,update,watch| Other3
    CR1 -->|create,get,update| Other4

    %% editor-role permissions
    CR4 -->|create,delete,get,list,patch,update,watch| TrustyAI1

    %% viewer-role permissions
    CR5 -->|get,list,watch| TrustyAI1

    %% cluster-admin for OAuth proxy
    CR3 -.->|full cluster access<br/>for SAR checks| SA2

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR5 fill:#f5a623,stroke:#333,stroke-width:2px

    style TrustyAI1 fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAI2 fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAI3 fill:#7ed321,stroke:#333,stroke-width:2px

    style KServe1 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe2 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe3 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe4 fill:#7ed321,stroke:#333,stroke-width:2px
