graph LR
    TrustyAI[TrustyAI Service Operator]

    %% External Dependencies (Required)
    TrustyAI -->|"platform<br/>(required)"| K8s[Kubernetes 1.19+]
    TrustyAI -->|"metrics CRD<br/>(required)"| PrometheusOp[Prometheus Operator]
    TrustyAI -->|"certificates<br/>(required)"| CertMgmt[cert-manager or<br/>service-ca]

    %% External Dependencies (Optional)
    TrustyAI -.->|"Routes, OAuth<br/>(optional)"| OpenShift[OpenShift 4.6+]

    %% Internal ODH Dependencies
    TrustyAI -->|"API calls<br/>patch CRs"| KServe[KServe]
    TrustyAI -->|"env vars<br/>MM_PAYLOAD_PROCESSORS"| ModelMesh[ModelMesh Serving]
    TrustyAI -->|"ServiceMonitor"| Prometheus[Prometheus]

    %% Integration Points
    Dashboard[ODH Dashboard] -->|"UI management<br/>create CRs"| TrustyAI
    KServe -->|"payload data<br/>HTTP/80"| TrustyAI
    ModelMesh -->|"inference data<br/>payload processor"| TrustyAI
    Prometheus -->|"scrapes metrics<br/>HTTP/80"| TrustyAI

    %% External Services
    TrustyAI -->|"CRD management<br/>HTTPS/6443"| K8sAPI[Kubernetes API]
    TrustyAI -->|"TLS certs<br/>auto-rotate"| ServiceCA[OpenShift Service CA]
    TrustyAI -->|"user auth<br/>OAuth 2.0"| OAuthServer[OpenShift OAuth]

    %% Storage
    TrustyAI -->|"persistent data<br/>PVC"| Storage[Persistent Storage]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (gray)
    style K8s fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style OpenShift fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style PrometheusOp fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style CertMgmt fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH (green)
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px

    %% External services (orange)
    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px
