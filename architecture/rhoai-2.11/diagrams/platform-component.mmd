graph TB
    subgraph "Red Hat OpenShift AI Platform 2.11"
        subgraph "Platform Management"
            RHODS[RHODS Operator<br/>v1.6.0-641]
            DSC[DataScienceCluster CR]
            DSCI[DSCInitialization CR]

            RHODS -->|manages| DSC
            RHODS -->|configures| DSCI
        end

        subgraph "User Interface Layer"
            Dashboard[ODH Dashboard<br/>v1.21.0-18<br/>2 replicas HA]
            DashboardRoute[Dashboard Route<br/>HTTPS/443 OAuth]
        end

        subgraph "Workbench Management"
            NotebookController[ODH Notebook Controller<br/>1.27.0-rhods-318]
            NotebookCR[Notebook CR]
            JupyterLab[JupyterLab]
            RStudio[RStudio]
            VSCode[VS Code]
            NotebookRoute[Notebook Routes<br/>HTTPS/443 OAuth]

            NotebookController -->|creates| NotebookCR
            NotebookCR -->|launches| JupyterLab
            NotebookCR -->|launches| RStudio
            NotebookCR -->|launches| VSCode
            NotebookController -->|creates| NotebookRoute
        end

        subgraph "Model Serving"
            KServe[KServe Controller<br/>v0.12.1]
            ModelController[ODH Model Controller<br/>v1.27.0-rhods-427<br/>3 replicas HA]
            ModelMesh[ModelMesh Serving<br/>v1.27.0-rhods-254]

            InferenceService[InferenceService CR]
            ServingRuntime[ServingRuntime CR]
            Predictor[Predictor Pod]

            KServe -->|watches| InferenceService
            ModelController -->|watches| InferenceService
            KServe -->|creates| Predictor
            InferenceService -->|uses| ServingRuntime
        end

        subgraph "ML Pipelines"
            DSPO[Data Science Pipelines Operator<br/>8d084e4]
            DSPApp[DataSciencePipelinesApplication CR]
            Argo[Argo Workflows]
            MariaDB[MariaDB]

            DSPO -->|creates| DSPApp
            DSPApp -->|deploys| Argo
            DSPApp -->|deploys| MariaDB
        end

        subgraph "Distributed Training"
            TrainingOp[Training Operator<br/>20c6ede9]
            PyTorchJob[PyTorchJob CR]
            TFJob[TFJob CR]
            MPIJob[MPIJob CR]

            TrainingOp -->|manages| PyTorchJob
            TrainingOp -->|manages| TFJob
            TrainingOp -->|manages| MPIJob
        end

        subgraph "Distributed Computing"
            KubeRay[KubeRay Operator<br/>v1.1.0]
            CodeFlare[CodeFlare Operator<br/>7460aa9]
            RayCluster[RayCluster CR]
            AppWrapper[AppWrapper CR]

            KubeRay -->|manages| RayCluster
            CodeFlare -->|creates| AppWrapper
            CodeFlare -->|enhances| RayCluster
        end

        subgraph "Resource Management"
            Kueue[Kueue<br/>ae90a64c9]
            ClusterQueue[ClusterQueue CR]
            LocalQueue[LocalQueue CR]

            Kueue -->|manages| ClusterQueue
            Kueue -->|manages| LocalQueue
        end

        subgraph "Model Monitoring"
            TrustyAI[TrustyAI Service Operator<br/>1.17.0]
            TrustyAIService[TrustyAIService CR]

            TrustyAI -->|creates| TrustyAIService
        end

        subgraph "Monitoring Infrastructure"
            Prometheus[Prometheus]
            Alertmanager[Alertmanager]
            ServiceMonitor[ServiceMonitors]

            Prometheus -->|scrapes| ServiceMonitor
        end
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh]
        Knative[Knative Serving]
        OAuth[OpenShift OAuth]
        Routes[OpenShift Routes]
        S3[S3 Storage]
        Registry[Container Registry]
    end

    %% Platform orchestration
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| NotebookController
    RHODS -->|deploys| KServe
    RHODS -->|deploys| ModelController
    RHODS -->|deploys| ModelMesh
    RHODS -->|deploys| DSPO
    RHODS -->|deploys| TrainingOp
    RHODS -->|deploys| KubeRay
    RHODS -->|deploys| CodeFlare
    RHODS -->|deploys| Kueue
    RHODS -->|deploys| TrustyAI

    %% Dashboard integrations
    Dashboard -->|API calls| NotebookController
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| DSPO
    Dashboard -->|queries| Prometheus

    %% Model serving integrations
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    ModelController -->|creates| Routes
    ModelController -->|creates VirtualServices| Istio
    Predictor -->|loads from| S3

    %% Training integrations
    TrainingOp -->|queued by| Kueue

    %% Ray integrations
    CodeFlare -->|queues| Kueue
    CodeFlare -->|integrates| OAuth

    %% Monitoring integrations
    TrustyAI -->|monitors| InferenceService
    TrustyAI -->|exports to| Prometheus

    %% Authentication
    Dashboard -->|uses| OAuth
    NotebookRoute -->|uses| OAuth
    DashboardRoute -->|uses| OAuth

    %% Image pulls
    JupyterLab -->|pulls from| Registry
    Predictor -->|pulls from| Registry

