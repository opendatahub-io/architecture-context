graph TD
    subgraph "Service Accounts"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[training-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        ConfigMaps[ConfigMaps<br/>create, list, update, watch]
        Events[Events<br/>create, delete, get, list,<br/>patch, update, watch]
        Pods[Pods<br/>create, delete, get, list,<br/>patch, update, watch]
        PodsExec[Pods/exec<br/>create]
        ServiceAccounts[ServiceAccounts<br/>create, get, list, watch]
        Services[Services<br/>create, delete, get,<br/>list, watch]
    end

    subgraph "kubeflow.org API Resources"
        PyTorchJobs[PyTorchJobs<br/>pytorchjobs, pytorchjobs/status,<br/>pytorchjobs/finalizers<br/>ALL verbs]
        TFJobs[TFJobs<br/>tfjobs, tfjobs/status,<br/>tfjobs/finalizers<br/>ALL verbs]
        MPIJobs[MPIJobs<br/>mpijobs, mpijobs/status,<br/>mpijobs/finalizers<br/>ALL verbs]
        XGBoostJobs[XGBoostJobs<br/>xgboostjobs, xgboostjobs/status,<br/>xgboostjobs/finalizers<br/>ALL verbs]
        MXJobs[MXJobs<br/>mxjobs, mxjobs/status,<br/>mxjobs/finalizers<br/>ALL verbs]
        PaddleJobs[PaddleJobs<br/>paddlejobs, paddlejobs/status,<br/>paddlejobs/finalizers<br/>ALL verbs]
    end

    subgraph "Other API Resources"
        HPA[HorizontalPodAutoscalers<br/>autoscaling<br/>ALL verbs]
        RBAC[Roles & RoleBindings<br/>rbac.authorization.k8s.io<br/>create, list, update, watch]
        VolcanoPG[PodGroups<br/>scheduling.volcano.sh<br/>ALL verbs]
        SchedulerPG[PodGroups<br/>scheduling.x-k8s.io<br/>ALL verbs]
    end

    subgraph "User-Facing Roles"
        TrainingEdit[training-edit<br/>ClusterRole<br/>ALL training jobs<br/>ALL verbs]
        TrainingView[training-view<br/>ClusterRole<br/>ALL training jobs<br/>get, list, watch]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - Core API
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Events
    CR -->|permissions| Pods
    CR -->|permissions| PodsExec
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Services

    %% Permissions - kubeflow.org
    CR -->|permissions| PyTorchJobs
    CR -->|permissions| TFJobs
    CR -->|permissions| MPIJobs
    CR -->|permissions| XGBoostJobs
    CR -->|permissions| MXJobs
    CR -->|permissions| PaddleJobs

    %% Permissions - Other
    CR -->|permissions| HPA
    CR -->|permissions| RBAC
    CR -->|permissions| VolcanoPG
    CR -->|permissions| SchedulerPG

    %% User roles (separate from operator)
    TrainingEdit -.->|user role<br/>for editing| PyTorchJobs
    TrainingEdit -.->|user role<br/>for editing| TFJobs
    TrainingView -.->|user role<br/>for viewing| PyTorchJobs
    TrainingView -.->|user role<br/>for viewing| TFJobs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:3px

    style ConfigMaps fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333

    style PyTorchJobs fill:#7ed321,stroke:#333
    style TFJobs fill:#7ed321,stroke:#333
    style MPIJobs fill:#7ed321,stroke:#333
    style XGBoostJobs fill:#7ed321,stroke:#333
    style MXJobs fill:#7ed321,stroke:#333
    style PaddleJobs fill:#7ed321,stroke:#333

    style HPA fill:#7ed321,stroke:#333
    style RBAC fill:#7ed321,stroke:#333
    style VolcanoPG fill:#7ed321,stroke:#333
    style SchedulerPG fill:#7ed321,stroke:#333

    style TrainingEdit fill:#ddd,stroke:#333,stroke-dasharray: 5 5
    style TrainingView fill:#ddd,stroke:#333,stroke-dasharray: 5 5
