graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User/<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>{instance-name}<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph ServiceLayer["SERVICE LAYER (Cluster Internal)"]
        ServiceTLS["ClusterIP Service<br/>{instance-name}-tls<br/>443/TCP → 8443/TCP<br/>TLS (service-ca)"]
        ServiceHTTP["ClusterIP Service<br/>{instance-name}<br/>80/TCP → 8080/TCP<br/>HTTP"]
    end

    subgraph ApplicationPod["APPLICATION POD (Trusted)"]
        direction TB

        subgraph Pod["TrustyAI Deployment Pod"]
            OAuthProxy["oauth-proxy<br/>Container<br/>8443/TCP HTTPS<br/>OAuth + SAR"]
            TrustyAIContainer["trustyai-service<br/>Container<br/>8080/TCP HTTP<br/>/q/metrics<br/>/apis/v1beta1/healthz"]
            PVC["PVC Storage<br/>{storage.folder}"]
        end

        OAuthProxy -->|"HTTP/8080<br/>Internal Pod"| TrustyAIContainer
        TrustyAIContainer -.->|mounts| PVC
    end

    subgraph AuthServices["AUTHENTICATION SERVICES"]
        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth 2.0 Flow"]
        ServiceCA["OpenShift Service CA<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Cert Provisioning"]
    end

    subgraph OperatorLayer["OPERATOR LAYER (System)"]
        Operator["TrustyAI Operator<br/>Namespace: opendatahub<br/>SA: controller-manager"]
        OperatorMetrics["Operator Endpoints<br/>/metrics: 8080/TCP HTTP<br/>/healthz: 8081/TCP HTTP<br/>/readyz: 8081/TCP HTTP"]

        Operator -->|exposes| OperatorMetrics
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph MonitoringIntegration["MONITORING & INTEGRATION"]
        Prometheus["Prometheus<br/>Metrics Scraping<br/>HTTP (ServiceAccount)"]
        ServiceMonitor["ServiceMonitor<br/>{instance-name}"]
        KServeIS["KServe<br/>InferenceServices<br/>MM_PAYLOAD_PROCESSORS"]
        ModelMesh["ModelMesh Serving<br/>Payload Processor"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| Route

    %% Ingress to Service
    Route -->|"HTTPS/443<br/>TLS 1.2+ Reencrypt"| ServiceTLS

    %% Service to Pod
    ServiceTLS -->|"HTTPS/8443<br/>TLS 1.2+<br/>OAuth Token"| OAuthProxy
    ServiceHTTP -->|"HTTP/80"| TrustyAIContainer

    %% OAuth Flow
    OAuthProxy <-->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Flow"| OAuthServer

    %% Service CA
    ServiceCA -->|"Provision Certs"| OAuthProxy
    ServiceCA -->|"Provision Certs"| TrustyAIContainer

    %% Operator to K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator creates resources
    Operator -.->|creates| Pod
    Operator -.->|creates| ServiceTLS
    Operator -.->|creates| ServiceHTTP
    Operator -.->|creates| Route
    Operator -.->|creates| ServiceMonitor

    %% Operator patches KServe
    Operator -->|"Patch CRs<br/>HTTPS/6443"| KServeIS

    %% Prometheus scraping
    Prometheus -->|"HTTP/80<br/>SA Token"| ServiceHTTP
    Prometheus -->|"HTTPS/8443<br/>SA Token"| OperatorMetrics
    ServiceMonitor -.->|enables| Prometheus

    %% KServe integration
    KServeIS -->|"HTTP/80<br/>Payload Data"| ServiceHTTP
    ModelMesh -->|"Forwards Payloads"| KServeIS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class User external
    class Route ingress
    class ServiceTLS,ServiceHTTP service
    class OAuthProxy,TrustyAIContainer,PVC,Pod pod
    class OAuthServer,ServiceCA auth
    class Operator,OperatorMetrics operator
    class K8sAPI k8s
    class Prometheus,ServiceMonitor,KServeIS,ModelMesh monitoring
