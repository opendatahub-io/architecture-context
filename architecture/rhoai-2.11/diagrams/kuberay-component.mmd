graph TB
    subgraph "KubeRay Operator"
        Operator[kuberay-operator<br/>Go Operator]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]

        Operator -->|manages| RayClusterCtrl
        Operator -->|manages| RayJobCtrl
        Operator -->|manages| RayServiceCtrl
    end

    subgraph "Optional API Server"
        APIServer[kuberay-apiserver<br/>gRPC/HTTP:8887,8888]
    end

    subgraph "Ray Cluster Resources"
        RayClusterCRD[RayCluster CRD<br/>ray.io/v1]
        RayJobCRD[RayJob CRD<br/>ray.io/v1]
        RayServiceCRD[RayService CRD<br/>ray.io/v1]
    end

    subgraph "Managed Ray Infrastructure"
        HeadPod[Ray Head Pod<br/>GCS:6379 Dashboard:8265 Client:10001]
        WorkerPods[Ray Worker Pods<br/>Distributed Compute]
        Autoscaler[Ray Autoscaler<br/>Sidecar Container]
        RedisCleanup[Redis Cleanup Job<br/>GCS Fault Tolerance]

        HeadPod -.->|manages| Autoscaler
        Autoscaler -->|scales| WorkerPods
        WorkerPods -->|register with| HeadPod
    end

    subgraph "Networking"
        HeadSvc[raycluster-head-svc<br/>ClusterIP 6379,8265,10001,8000]
        ServeSvc[rayservice-serve-svc<br/>ClusterIP 8000]
        Route[OpenShift Route<br/>External Access]
        Ingress[Kubernetes Ingress<br/>External Access]
    end

    User[User/CI] -->|creates| RayClusterCRD
    User -->|creates| RayJobCRD
    User -->|creates| RayServiceCRD

    RayClusterCRD -->|watched by| RayClusterCtrl
    RayJobCRD -->|watched by| RayJobCtrl
    RayServiceCRD -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadSvc
    RayClusterCtrl -->|creates| Autoscaler

    RayJobCtrl -->|creates| RayClusterCRD
    RayJobCtrl -->|submits jobs to| HeadPod

    RayServiceCtrl -->|creates| RayClusterCRD
    RayServiceCtrl -->|creates| ServeSvc
    RayServiceCtrl -->|manages zero-downtime upgrades| ServeSvc

    Operator -->|creates| Route
    Operator -->|creates| Ingress

    Operator -->|watches| K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
    Autoscaler -->|scales via| K8sAPI

    Operator -->|integrates with| Prometheus[Prometheus<br/>Metrics:8080]
    Operator -.->|optional| CertManager[cert-manager<br/>TLS Certificates]
    Operator -.->|optional| Volcano[Volcano<br/>Gang Scheduling]
    Operator -.->|optional| Kueue[Kueue<br/>Job Queueing]

    HeadPod -.->|GCS fault tolerance| ExternalRedis[External Redis<br/>Optional]

    WorkerPods -->|pull images from| ContainerRegistry[Container Registry<br/>443/TCP HTTPS]

    APIServer -.->|manages| RayClusterCRD
    APIServer -.->|manages| RayJobCRD
    APIServer -.->|manages| RayServiceCRD

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333
    style Autoscaler fill:#7ed321,stroke:#333
    style RayClusterCRD fill:#f5a623,stroke:#333
    style RayJobCRD fill:#f5a623,stroke:#333
    style RayServiceCRD fill:#f5a623,stroke:#333
    style APIServer fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ContainerRegistry fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style Volcano fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style Kueue fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style ExternalRedis fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
