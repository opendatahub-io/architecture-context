graph TB
    subgraph "Data Science Pipelines Operator (DSPO)"
        Controller[DSPO Controller Manager]
        Controller -->|reconciles| DSPA_CR[DataSciencePipelinesApplication CR]
    end

    subgraph "DSP Stack Components (per namespace)"
        direction TB

        subgraph "Core Services"
            APIServer[API Server<br/>REST/gRPC<br/>8888/8887]
            PersistenceAgent[Persistence Agent]
            ScheduledWorkflow[Scheduled Workflow Controller]
            WorkflowController[Workflow Controller<br/>Argo v2]
        end

        subgraph "Optional Components"
            MariaDB[(MariaDB<br/>3306/TCP)]
            Minio[Minio S3<br/>9000/TCP]
            UI[ML Pipelines UI<br/>8443/TCP]
            MLMD[ML Metadata<br/>Envoy + gRPC<br/>9090/TCP]
        end
    end

    subgraph "Custom Resources"
        DSPA_CR
        Workflow_CR[Workflow CR]
        WorkflowTemplate_CR[WorkflowTemplate CR]
        CronWorkflow_CR[CronWorkflow CR]
    end

    subgraph "External Dependencies"
        ArgoWorkflows[Argo Workflows 3.3.10]
        Tekton[OpenShift Pipelines<br/>Tekton 1.8+]
        ExternalS3[External S3 Storage]
        ExternalDB[External MySQL/MariaDB]
    end

    subgraph "ODH Integration"
        ODHDashboard[ODH Dashboard]
        ODHOperator[OpenDataHub Operator]
    end

    %% User interactions
    User[Data Scientist] -->|creates| DSPA_CR
    User -->|submits pipelines| APIServer

    %% Controller operations
    Controller -->|creates| APIServer
    Controller -->|creates| PersistenceAgent
    Controller -->|creates| ScheduledWorkflow
    Controller -->|creates| WorkflowController
    Controller -->|provisions| MariaDB
    Controller -->|provisions| Minio
    Controller -->|deploys| UI
    Controller -->|deploys| MLMD

    %% Component interactions
    APIServer -->|persists to| MariaDB
    APIServer -->|creates| Workflow_CR
    PersistenceAgent -->|syncs state to| MariaDB
    ScheduledWorkflow -->|creates| CronWorkflow_CR
    WorkflowController -->|executes| Workflow_CR
    WorkflowController -->|uses| ArgoWorkflows
    APIServer -->|stores artifacts| Minio
    APIServer -->|or uses| ExternalS3
    APIServer -->|or uses| ExternalDB
    MLMD -->|tracks metadata| MariaDB

    %% DSP v1 path
    APIServer -.->|DSP v1| Tekton

    %% ODH integration
    ODHOperator -->|deploys via DataScienceCluster| Controller
    ODHDashboard -->|UI integration| UI

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style APIServer fill:#4a90e2,stroke:#333
    style DSPA_CR fill:#f5a623,stroke:#333
    style MariaDB fill:#7ed321,stroke:#333
    style Minio fill:#7ed321,stroke:#333
    style ArgoWorkflows fill:#999,stroke:#333
    style Tekton fill:#999,stroke:#333
    style ExternalS3 fill:#e8e8e8,stroke:#333
    style ExternalDB fill:#e8e8e8,stroke:#333
    style ODHDashboard fill:#7ed321,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
