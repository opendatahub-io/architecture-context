graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: operator-ns"]
        SA_Argo["argo<br/>Namespace: dspa-ns"]
        SA_Pipeline["ds-pipeline-NAME<br/>Namespace: dspa-ns"]
        SA_Runner["pipeline-runner-NAME<br/>Namespace: dspa-ns"]
        SA_MetadataWriter["ds-pipeline-metadata-writer-NAME<br/>Namespace: dspa-ns"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Argo[argo-binding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Argo[argo-cluster-role<br/>ClusterRole]
    end

    subgraph "Roles (Namespace-scoped)"
        R_Pipeline[ds-pipeline-role<br/>Role]
        R_Runner[pipeline-runner-role<br/>Role]
        R_MetadataWriter[metadata-writer-role<br/>Role]
    end

    subgraph "API Resources - DSPA Operations"
        API_DSPA[datasciencepipelinesapplications<br/>opendatahub.io<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
        API_DSPA_Status[datasciencepipelinesapplications/status<br/>Verbs: get, patch, update]
        API_DSPA_Finalizers[datasciencepipelinesapplications/finalizers<br/>Verbs: update]
    end

    subgraph "API Resources - Kubernetes Core"
        API_Deployments[apps/deployments<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
        API_Core[Core Resources<br/>services, configmaps, secrets,<br/>serviceaccounts, pvcs<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
        API_Routes[route.openshift.io/routes<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
        API_RBAC[rbac.authorization.k8s.io<br/>roles, rolebindings<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
        API_ServiceMonitors[monitoring.coreos.com<br/>servicemonitors<br/>Verbs: create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "API Resources - Argo Workflows"
        API_Workflows[argoproj.io/workflows<br/>Verbs: all]
        API_WorkflowTemplates[argoproj.io/workflowtemplates<br/>Verbs: all]
        API_CronWorkflows[argoproj.io/cronworkflows<br/>Verbs: all]
    end

    subgraph "API Resources - Batch"
        API_Jobs[batch/jobs<br/>Verbs: all]
    end

    subgraph "API Resources - Auth"
        API_TokenReviews[authentication.k8s.io<br/>tokenreviews<br/>Verbs: create]
        API_SubjectAccessReviews[authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create]
    end

    subgraph "API Resources - Pipeline Runner"
        API_Pods[Core Resources<br/>pods, services<br/>Verbs: get, list, create,<br/>delete, patch]
        API_Runner_Routes[route.openshift.io/routes<br/>Verbs: get, list, watch]
        API_Runner_Workflows[argoproj.io/workflows<br/>Verbs: get, list, watch,<br/>create, patch]
    end

    subgraph "API Resources - Argo Cluster"
        API_Argo_Pods[Core Resources<br/>pods, pods/log, configmaps<br/>Verbs: get, list, watch]
        API_Argo_PodsExec[pods, pods/exec<br/>Verbs: create, delete, patch]
    end

    %% Service Account to ClusterRoleBinding
    SA_Controller -->|bound via| CRB_Manager
    SA_Argo -->|bound via| CRB_Argo

    %% ClusterRoleBinding to ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Argo -->|grants| CR_Argo

    %% ClusterRole manager-role permissions
    CR_Manager -->|manages| API_DSPA
    CR_Manager -->|manages| API_DSPA_Status
    CR_Manager -->|manages| API_DSPA_Finalizers
    CR_Manager -->|manages| API_Deployments
    CR_Manager -->|manages| API_Core
    CR_Manager -->|manages| API_Routes
    CR_Manager -->|manages| API_RBAC
    CR_Manager -->|manages| API_ServiceMonitors
    CR_Manager -->|manages| API_Workflows
    CR_Manager -->|manages| API_Jobs
    CR_Manager -->|authenticates| API_TokenReviews
    CR_Manager -->|authorizes| API_SubjectAccessReviews

    %% ClusterRole argo-cluster-role permissions
    CR_Argo -->|manages| API_WorkflowTemplates
    CR_Argo -->|manages| API_CronWorkflows
    CR_Argo -->|reads| API_Argo_Pods
    CR_Argo -->|executes| API_Argo_PodsExec

    %% Namespace-scoped Roles
    SA_Pipeline -->|bound via| R_Pipeline
    SA_Runner -->|bound via| R_Runner
    SA_MetadataWriter -->|bound via| R_MetadataWriter

    R_Runner -->|manages| API_Pods
    R_Runner -->|reads| API_Runner_Routes
    R_Runner -->|manages| API_Runner_Workflows

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef api fill:#7ed321,stroke:#333,stroke-width:1px
    classDef apiCore fill:#50b5e9,stroke:#333,stroke-width:1px
    classDef apiArgo fill:#9b59b6,stroke:#333,stroke-width:1px

    class SA_Controller,SA_Argo,SA_Pipeline,SA_Runner,SA_MetadataWriter serviceaccount
    class CRB_Manager,CRB_Argo binding
    class CR_Manager,CR_Argo,R_Pipeline,R_Runner,R_MetadataWriter role
    class API_DSPA,API_DSPA_Status,API_DSPA_Finalizers api
    class API_Deployments,API_Core,API_Routes,API_RBAC,API_ServiceMonitors,API_Pods,API_Runner_Routes,API_Argo_Pods,API_Argo_PodsExec apiCore
    class API_Workflows,API_WorkflowTemplates,API_CronWorkflows,API_Runner_Workflows apiArgo
    class API_Jobs,API_TokenReviews,API_SubjectAccessReviews api
