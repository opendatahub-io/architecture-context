graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>redhat-ods-operator]
        SA_Prometheus[prometheus<br/>redhat-ods-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[controller-manager-rolebinding]
        CRB_Prometheus[prometheus-rolebinding-scraper]
        CRB_RHODSProm[rhods-prometheus-rolebinding]
    end

    subgraph "ClusterRoles"
        CR_Controller[controller-manager-role]
        CR_AuthProxy[auth-proxy-client]
        CR_PrometheusRole[prometheus-role]
        CR_RHODSPrometheusRole[rhods-prometheus-role]
    end

    subgraph "Core API Resources"
        Core_NS[namespaces]
        Core_CM[configmaps]
        Core_Secrets[secrets]
        Core_Services[services]
        Core_SA[serviceaccounts]
        Core_Pods[pods]
        Core_PVC[persistentvolumeclaims]
    end

    subgraph "Apps API Resources"
        Apps_Deploy[deployments]
        Apps_STS[statefulsets]
        Apps_RS[replicasets]
    end

    subgraph "ODH Custom Resources"
        DSC[datascienceclusters<br/>datasciencecluster.opendatahub.io]
        DSCI[dscinitializations<br/>dscinitialization.opendatahub.io]
        FeatureTracker[featuretrackers<br/>features.opendatahub.io]
    end

    subgraph "RBAC Resources"
        RBAC_CR[clusterroles]
        RBAC_CRB[clusterrolebindings]
        RBAC_R[roles]
        RBAC_RB[rolebindings]
    end

    subgraph "OpenShift Resources"
        OCP_Routes[routes<br/>route.openshift.io]
    end

    subgraph "Service Mesh Resources"
        Istio_GW[gateways<br/>networking.istio.io]
        Istio_VS[virtualservices<br/>networking.istio.io]
        Istio_EF[envoyfilters<br/>networking.istio.io]
        Maistra_SMCP[servicemeshcontrolplanes<br/>maistra.io]
        Maistra_SMMR[servicemeshmemberrolls<br/>maistra.io]
        Maistra_SMM[servicemeshmembers<br/>maistra.io]
    end

    subgraph "Monitoring Resources"
        Mon_SM[servicemonitors<br/>monitoring.coreos.com]
        Mon_PM[podmonitors<br/>monitoring.coreos.com]
        Mon_PR[prometheusrules<br/>monitoring.coreos.com]
        Mon_Prom[prometheuses<br/>monitoring.coreos.com]
        Mon_AM[alertmanagers<br/>monitoring.coreos.com]
    end

    subgraph "KServe/Kubeflow Resources"
        KServe_All[all resources<br/>serving.kserve.io]
        Kubeflow_All[all resources<br/>kubeflow.org]
        Authorino_AC[authconfigs<br/>authorino.kuadrant.io]
    end

    subgraph "Other Resources"
        CRD[customresourcedefinitions<br/>apiextensions.k8s.io]
        Webhooks_M[mutatingwebhookconfigurations<br/>admissionregistration.k8s.io]
        Webhooks_V[validatingwebhookconfigurations<br/>admissionregistration.k8s.io]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Prometheus -->|bound via| CRB_Prometheus
    SA_Prometheus -->|bound via| CRB_RHODSProm

    CRB_Controller -->|grants| CR_Controller
    CRB_Prometheus -->|grants| CR_PrometheusRole
    CRB_RHODSProm -->|grants| CR_RHODSPrometheusRole

    %% Controller Manager Permissions
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_NS
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_CM
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_Secrets
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_Services
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_SA
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_Pods
    CR_Controller -->|create,delete,get,list,patch,update,watch| Core_PVC

    CR_Controller -->|all verbs| Apps_Deploy
    CR_Controller -->|all verbs| Apps_STS
    CR_Controller -->|all verbs| Apps_RS

    CR_Controller -->|create,delete,get,list,patch,update,watch| DSC
    CR_Controller -->|create,delete,get,list,patch,update,watch| DSCI
    CR_Controller -->|create,delete,get,list,patch,update,watch| FeatureTracker

    CR_Controller -->|all verbs| RBAC_CR
    CR_Controller -->|all verbs| RBAC_CRB
    CR_Controller -->|all verbs| RBAC_R
    CR_Controller -->|all verbs| RBAC_RB

    CR_Controller -->|create,delete,get,list,patch,update,watch| OCP_Routes

    CR_Controller -->|all verbs| Istio_GW
    CR_Controller -->|all verbs| Istio_VS
    CR_Controller -->|all verbs| Istio_EF
    CR_Controller -->|create,get,list,patch,update,use,watch| Maistra_SMCP
    CR_Controller -->|create,get,list,patch,update,use,watch| Maistra_SMMR
    CR_Controller -->|create,get,list,patch,update,use,watch| Maistra_SMM

    CR_Controller -->|create,delete,get,list,patch,update,watch| Mon_SM
    CR_Controller -->|create,delete,get,list,patch,update,watch| Mon_PM
    CR_Controller -->|create,delete,get,list,patch,update,watch| Mon_PR
    CR_Controller -->|create,delete,get,list,patch,update,watch| Mon_Prom
    CR_Controller -->|create,delete,get,list,patch,update,watch| Mon_AM

    CR_Controller -->|all verbs| KServe_All
    CR_Controller -->|all verbs| Kubeflow_All
    CR_Controller -->|all verbs| Authorino_AC

    CR_Controller -->|create,delete,get,list,patch,watch| CRD
    CR_Controller -->|create,delete,get,list,patch,update,watch| Webhooks_M
    CR_Controller -->|create,delete,get,list,patch,update,watch| Webhooks_V

    %% Auth Proxy Client Permissions
    CR_AuthProxy -->|get,list,watch| Core_Pods
    CR_AuthProxy -->|get,list,watch| Core_Services

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Prometheus fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_PrometheusRole fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_RHODSPrometheusRole fill:#f5a623,stroke:#333,stroke-width:2px

    style DSC fill:#7ed321,stroke:#333
    style DSCI fill:#7ed321,stroke:#333
    style FeatureTracker fill:#7ed321,stroke:#333
