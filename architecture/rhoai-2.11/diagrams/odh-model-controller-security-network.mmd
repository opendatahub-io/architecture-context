graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3<br/>AuthN: Bearer Token<br/>AuthZ: RBAC"]
    end

    subgraph ControllerNamespace["Namespace: opendatahub"]
        direction TB

        subgraph ControllerPod["ODH Model Controller Pod<br/>Replicas: 3 - Leader Election<br/>SA: odh-model-controller"]
            direction TB
            Manager["manager Container<br/>CPU: 10m-500m / Mem: 64Mi-2Gi"]

            subgraph Reconcilers["Reconcilers"]
                InferenceReconciler[InferenceService<br/>Reconciler]
                ServerlessReconciler[KServe Serverless<br/>Reconciler]
                RawReconciler[KServe Raw<br/>Reconciler]
                ModelMeshReconciler[ModelMesh<br/>Reconciler]
                StorageReconciler[StorageSecret<br/>Reconciler]
                MonitoringReconciler[Monitoring<br/>Reconciler]
            end

            subgraph Servers["Servers"]
                WebhookServer["Webhook Server<br/>9443/TCP HTTPS TLS 1.2+"]
                MetricsServer["Metrics Server<br/>8080/TCP HTTP"]
                HealthServer["Health Server<br/>8081/TCP HTTP"]
            end
        end

        WebhookService["Service: webhook-service<br/>ClusterIP 443→9443<br/>HTTPS TLS 1.2+<br/>mTLS - API Server only"]
        MetricsService["Service: metrics-service<br/>ClusterIP 8080→8080<br/>HTTP - internal only"]
    end

    subgraph UserNamespace["User Namespace: {namespace}"]
        direction TB
        InferenceService[InferenceService CR<br/>serving.kserve.io]
        ServingRuntime[ServingRuntime CR<br/>serving.kserve.io]
        KnativeService[Knative Service<br/>serving.knative.dev]

        subgraph CreatedResources["Created Resources"]
            Route[OpenShift Route<br/>route.openshift.io]
            VirtualService[VirtualService<br/>networking.istio.io]
            Gateway[Gateway<br/>networking.istio.io]
            AuthConfig[AuthConfig<br/>authorino.kuadrant.io]
            PeerAuth[PeerAuthentication<br/>security.istio.io<br/>Mode: STRICT mTLS]
            NetworkPolicy[NetworkPolicy<br/>networking.k8s.io]
            ServiceMonitor[ServiceMonitor<br/>monitoring.coreos.com]
        end
    end

    subgraph Monitoring["Namespace: openshift-monitoring"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        ModelRegistry["Model Registry<br/>9090/TCP gRPC mTLS<br/>Service Mesh Identity"]
    end

    subgraph Secrets["Secrets & Certificates"]
        WebhookCert["webhook-cert<br/>Type: kubernetes.io/tls<br/>Provisioned: service-ca/cert-manager<br/>Auto-rotate: 90d"]
        StorageSecrets["Storage Secrets<br/>Label: opendatahub.io/managed=true<br/>Type: Opaque<br/>Content: S3 credentials"]
    end

    %% Flows
    User -->|kubectl create<br/>6443/TCP HTTPS TLS 1.3<br/>Bearer Token| APIServer
    APIServer -.->|Watch Events<br/>ServiceAccount Token| InferenceReconciler

    InferenceReconciler -->|Reconcile<br/>6443/TCP HTTPS TLS 1.3<br/>ServiceAccount Token| APIServer
    ServerlessReconciler -->|Create Resources<br/>6443/TCP HTTPS TLS 1.3| APIServer
    ModelMeshReconciler -->|Create Resources<br/>6443/TCP HTTPS TLS 1.3| APIServer
    MonitoringReconciler -->|Create ServiceMonitor<br/>6443/TCP HTTPS TLS 1.3| APIServer

    APIServer -->|POST /validate<br/>9443/TCP HTTPS TLS 1.2+<br/>mTLS - API Server cert| WebhookService
    WebhookService -->|Forward| WebhookServer

    Prometheus -->|GET /metrics<br/>8080/TCP HTTP<br/>Bearer Token| MetricsService
    MetricsService -->|Forward| MetricsServer

    APIServer -.->|Creates| InferenceService
    InferenceReconciler -.->|Watches| InferenceService
    ServerlessReconciler -.->|Creates| Route
    ServerlessReconciler -.->|Creates| VirtualService
    ServerlessReconciler -.->|Creates| Gateway
    ServerlessReconciler -.->|Creates| AuthConfig
    ServerlessReconciler -.->|Creates| PeerAuth
    ServerlessReconciler -.->|Creates| NetworkPolicy
    MonitoringReconciler -.->|Creates| ServiceMonitor

    InferenceReconciler -->|gRPC API<br/>9090/TCP mTLS<br/>Service Identity| ModelRegistry

    WebhookServer -.->|Uses| WebhookCert
    InferenceReconciler -.->|Caches & Uses| StorageSecrets

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef usernamespace fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef monitoring fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef externalservice fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    classDef secrets fill:#ffebee,stroke:#c62828,stroke-width:2px

    class User external
    class APIServer controlplane
    class Manager,InferenceReconciler,ServerlessReconciler,RawReconciler,ModelMeshReconciler,StorageReconciler,MonitoringReconciler,WebhookServer,MetricsServer,HealthServer,WebhookService,MetricsService controller
    class InferenceService,ServingRuntime,KnativeService,Route,VirtualService,Gateway,AuthConfig,PeerAuth,NetworkPolicy,ServiceMonitor usernamespace
    class Prometheus monitoring
    class ModelRegistry externalservice
    class WebhookCert,StorageSecrets secrets
