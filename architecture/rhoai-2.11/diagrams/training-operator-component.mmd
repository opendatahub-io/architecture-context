graph TB
    subgraph "Training Operator Deployment"
        Operator[Training Operator<br/>Deployment]
        PyTorchCtrl[PyTorch Controller]
        TFCtrl[TensorFlow Controller]
        MPICtrl[MPI Controller]
        XGBoostCtrl[XGBoost Controller]
        MXNetCtrl[MXNet Controller]
        PaddleCtrl[Paddle Controller]
        MetricsServer[Metrics Server<br/>:8080/HTTP]
        HealthProbes[Health Probes<br/>:8081/HTTP]

        Operator --> PyTorchCtrl
        Operator --> TFCtrl
        Operator --> MPICtrl
        Operator --> XGBoostCtrl
        Operator --> MXNetCtrl
        Operator --> PaddleCtrl
        Operator --> MetricsServer
        Operator --> HealthProbes
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        MXJobCR[MXJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Training Jobs"
        PyTorchPods[PyTorch Pods<br/>Master + Workers]
        TFPods[TensorFlow Pods<br/>PS + Chief + Workers]
        MPIPods[MPI Pods<br/>Launcher + Workers]
        XGBoostPods[XGBoost Pods]
        MXNetPods[MXNet Pods]
        PaddlePods[Paddle Pods]
    end

    User[User/SDK] -->|creates| PyTorchJobCR
    User -->|creates| TFJobCR
    User -->|creates| MPIJobCR
    User -->|creates| XGBoostJobCR
    User -->|creates| MXJobCR
    User -->|creates| PaddleJobCR

    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MXJobCR -->|watched by| MXNetCtrl
    PaddleJobCR -->|watched by| PaddleCtrl

    PyTorchCtrl -->|creates| PyTorchPods
    TFCtrl -->|creates| TFPods
    MPICtrl -->|creates| MPIPods
    XGBoostCtrl -->|creates| XGBoostPods
    MXNetCtrl -->|creates| MXNetPods
    PaddleCtrl -->|creates| PaddlePods

    PyTorchCtrl -->|creates| Services[Kubernetes Services]
    PyTorchCtrl -->|creates| ConfigMaps[ConfigMaps]

    subgraph "Optional Dependencies"
        Volcano[Volcano Scheduler<br/>Gang Scheduling]
        SchedulerPlugins[Scheduler Plugins<br/>Coscheduling]
        HPA[Horizontal Pod Autoscaler<br/>Elastic Training]
    end

    PyTorchCtrl -.->|optional| Volcano
    PyTorchCtrl -.->|optional| SchedulerPlugins
    PyTorchCtrl -.->|elastic training| HPA

    Prometheus[Prometheus] -->|scrapes| MetricsServer
    K8sAPI[Kubernetes API] -->|watches| Operator

    ContainerRegistry[Container Registry] -.->|pulls images| PyTorchPods
    ContainerRegistry -.->|pulls images| TFPods
    ContainerRegistry -.->|pulls images| MPIPods

