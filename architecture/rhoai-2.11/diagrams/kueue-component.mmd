    style LocalQueueCR fill:#f5a623,stroke:#333
    style ClusterQueueCR fill:#f5a623,stroke:#333
    style ResourceFlavorCR fill:#f5a623,stroke:#333
    style AdmissionCheckCR fill:#f5a623,stroke:#333

    style K8sAPI fill:#999,stroke:#333
    style CertController fill:#999,stroke:#333
