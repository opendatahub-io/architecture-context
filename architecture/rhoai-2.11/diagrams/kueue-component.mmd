graph TB
    subgraph "Kueue Operator - Namespace: opendatahub"
        ControllerManager[kueue-controller-manager<br/>Deployment]

        subgraph "Controllers"
            AdmissionCheckCtrl[AdmissionCheck Controller]
            ClusterQueueCtrl[ClusterQueue Controller]
            LocalQueueCtrl[LocalQueue Controller]
            WorkloadCtrl[Workload Controller]
            ResourceFlavorCtrl[ResourceFlavor Controller]
        end

        WebhookServer[Webhook Server<br/>9443/TCP HTTPS TLS 1.2+]
        VisibilityServer[Visibility Server<br/>8082/TCP HTTPS TLS 1.2+]
        MetricsExporter[Metrics Exporter<br/>8080/TCP HTTP<br/>8443/TCP HTTPS]

        ControllerManager --> AdmissionCheckCtrl
        ControllerManager --> ClusterQueueCtrl
        ControllerManager --> LocalQueueCtrl
        ControllerManager --> WorkloadCtrl
        ControllerManager --> ResourceFlavorCtrl
        ControllerManager --> WebhookServer
        ControllerManager --> VisibilityServer
        ControllerManager --> MetricsExporter
    end

    subgraph "Kueue CRDs"
        WorkloadCR[Workload<br/>Namespaced]
        LocalQueueCR[LocalQueue<br/>Namespaced]
        ClusterQueueCR[ClusterQueue<br/>Cluster-scoped]
        ResourceFlavorCR[ResourceFlavor<br/>Cluster-scoped]
        AdmissionCheckCR[AdmissionCheck<br/>Cluster-scoped]
        WorkloadPriorityClassCR[WorkloadPriorityClass<br/>Cluster-scoped]
        ProvisioningRequestConfigCR[ProvisioningRequestConfig<br/>Cluster-scoped]
    end

    subgraph "Job Frameworks"
        BatchJob[Batch Job<br/>batch/v1]
        JobSet[JobSet<br/>jobset.x-k8s.io]
        TFJob[TFJob<br/>kubeflow.org]
        PyTorchJob[PyTorchJob<br/>kubeflow.org]
        MPIJob[MPIJob<br/>kubeflow.org]
        RayJob[RayJob<br/>ray.io]
        RayCluster[RayCluster<br/>ray.io]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
        CertController[cert-controller<br/>v0.10.1]
        Prometheus[Prometheus Operator]
        ClusterAutoscaler[Cluster Autoscaler]
    end

    %% User interactions
    User[User/Pipeline] -->|creates job| BatchJob
    User -->|creates| JobSet
    User -->|creates training jobs| TFJob
    User -->|creates training jobs| PyTorchJob
    User -->|creates training jobs| MPIJob
    User -->|creates Ray jobs| RayJob
    User -->|creates Ray clusters| RayCluster

    %% Webhook interactions
    K8sAPI -->|validates/mutates<br/>mTLS| WebhookServer

    %% CRD watching
    WorkloadCtrl -->|reconciles| WorkloadCR
    ClusterQueueCtrl -->|reconciles| ClusterQueueCR
    LocalQueueCtrl -->|reconciles| LocalQueueCR
    ResourceFlavorCtrl -->|reconciles| ResourceFlavorCR
    AdmissionCheckCtrl -->|reconciles| AdmissionCheckCR

    %% Job framework integration
    WorkloadCtrl -->|watches/updates| BatchJob
    WorkloadCtrl -->|watches/updates| JobSet
    WorkloadCtrl -->|watches/updates| TFJob
    WorkloadCtrl -->|watches/updates| PyTorchJob
    WorkloadCtrl -->|watches/updates| MPIJob
    WorkloadCtrl -->|watches/updates| RayJob
    WorkloadCtrl -->|watches/updates| RayCluster

    %% API Server integration
    ControllerManager -->|watches/reconciles<br/>HTTPS TLS 1.2+| K8sAPI

    %% Dependencies
    CertController -->|provisions cert| WebhookServer
    Prometheus -->|scrapes metrics<br/>HTTP/HTTPS| MetricsExporter
    WorkloadCtrl -->|creates ProvisioningRequests| ClusterAutoscaler

