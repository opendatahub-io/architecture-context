graph TD
    subgraph "Service Account"
        SA[odh-model-controller<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[odh-model-controller-rolebinding<br/>ClusterRoleBinding]
        RB[odh-model-controller-leader-election-rolebinding<br/>RoleBinding - controller namespace]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-model-controller-role<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "KServe API Resources"
        ISvc[serving.kserve.io<br/>InferenceService<br/>inferenceservices/finalizers]
        SRT[serving.kserve.io<br/>ServingRuntime<br/>servingruntimes/finalizers]
    end

    subgraph "Istio/Service Mesh API Resources"
        VS[networking.istio.io<br/>VirtualService<br/>virtualservices/finalizers]
        GW[networking.istio.io<br/>Gateway]
        PA[security.istio.io<br/>PeerAuthentication]
        AuthzPolicy[security.istio.io<br/>AuthorizationPolicy]
        Telemetry[telemetry.istio.io<br/>Telemetry]
        SMM[maistra.io<br/>ServiceMeshMember]
        SMMR[maistra.io<br/>ServiceMeshMemberRoll]
        SMCP[maistra.io<br/>ServiceMeshControlPlane]
    end

    subgraph "OpenShift API Resources"
        Route[route.openshift.io<br/>Route<br/>routes/custom-host]
    end

    subgraph "Networking API Resources"
        NP[networking.k8s.io<br/>NetworkPolicy]
        Ingress[networking.k8s.io<br/>Ingress]
    end

    subgraph "Monitoring API Resources"
        SM[monitoring.coreos.com<br/>ServiceMonitor]
        PM[monitoring.coreos.com<br/>PodMonitor]
    end

    subgraph "Authorization API Resources"
        AC[authorino.kuadrant.io<br/>AuthConfig]
    end

    subgraph "Core API Resources"
        Svc[core<br/>Service]
        Secret[core<br/>Secret]
        CM[core<br/>ConfigMap]
        SvcAcct[core<br/>ServiceAccount]
        NS[core<br/>Namespace]
        Pod[core<br/>Pod]
        Endpoint[core<br/>Endpoint]
    end

    subgraph "RBAC API Resources"
        CRBResource[rbac.authorization.k8s.io<br/>ClusterRoleBinding]
        RBResource[rbac.authorization.k8s.io<br/>RoleBinding]
    end

    subgraph "ODH Platform API Resources"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
    end

    subgraph "Knative API Resources"
        KnativeSvc[serving.knative.dev<br/>Service<br/>Validated via webhook]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Bindings to Roles
    CRB -->|grants cluster-wide| CR
    RB -->|grants namespace-scoped| LeaderRole

    %% ClusterRole to Resources - KServe
    CR -->|get, list, watch, update| ISvc
    CR -->|get, list, watch, create, update, patch, delete| SRT

    %% ClusterRole to Resources - Istio
    CR -->|get, list, watch, create, update, patch, delete| VS
    CR -->|get, list, watch, update, patch| GW
    CR -->|get, list, watch, create, update, patch, delete| PA
    CR -->|get, list| AuthzPolicy
    CR -->|get, list, watch, create, update, patch, delete| Telemetry
    CR -->|get, list, watch, create, update, patch, delete| SMM
    CR -->|get, list, watch, use| SMMR
    CR -->|get, list, watch, use| SMCP

    %% ClusterRole to Resources - OpenShift
    CR -->|get, list, watch, create, update, patch, delete| Route

    %% ClusterRole to Resources - Networking
    CR -->|get, list, watch, create, update, patch, delete| NP
    CR -->|get, list, watch, create, update, patch, delete| Ingress

    %% ClusterRole to Resources - Monitoring
    CR -->|get, list, watch, create, update, patch, delete| SM
    CR -->|get, list, watch, create, update, patch, delete| PM

    %% ClusterRole to Resources - Authorization
    CR -->|get, list, watch, create, update, patch, delete| AC

    %% ClusterRole to Resources - Core
    CR -->|get, list, watch, create, update, patch, delete| Svc
    CR -->|get, list, watch, create, update, patch, delete| Secret
    CR -->|get, list, watch, create, update, patch, delete| CM
    CR -->|get, list, watch, create, update, patch, delete| SvcAcct
    CR -->|get, list, watch, create, update, patch| NS
    CR -->|get, list, watch, create, update, patch| Pod
    CR -->|get, list, watch, create, update, patch| Endpoint

    %% ClusterRole to Resources - RBAC
    CR -->|get, list, watch, create, update, patch, delete| CRBResource
    CR -->|get, list, watch, create, update, patch, delete| RBResource

    %% ClusterRole to Resources - ODH Platform
    CR -->|get, list, watch| DSC
    CR -->|get, list, watch| DSCI

    %% Leader Election Role to Resources
    LeaderRole -->|get, update, create| LeaderElectionCM[ConfigMap/Lease<br/>Leader Election]

    %% Webhook Validation (not RBAC, but relevant)
    KnativeSvc -.->|validated by webhook| SA

