    style NotebookCRD fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Prometheus fill:#e8590c,stroke:#333,color:#fff

