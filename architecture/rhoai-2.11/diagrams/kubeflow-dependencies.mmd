graph LR
    ODHNotebookController[ODH Notebook Controller]

    %% External Dependencies - Required
    ODHNotebookController -->|"watches CRDs<br/>coordinates"| KubeflowController[Kubeflow Notebook Controller<br/>v1.x - REQUIRED]
    ODHNotebookController -->|"creates routes<br/>route.openshift.io/v1"| OpenShiftRoute[OpenShift Route API<br/>REQUIRED]
    ODHNotebookController -->|"injects sidecar<br/>registry.redhat.io/openshift4"| OAuthProxy[OpenShift OAuth Proxy<br/>CONDITIONAL - OAuth mode]
    ODHNotebookController -->|"provisions certs<br/>serving-cert annotation"| ServiceCA[OpenShift Service CA<br/>REQUIRED]

    %% External Dependencies - Optional
    ODHNotebookController -.->|"reads config<br/>config.openshift.io/v1"| ProxyConfig[OpenShift Proxy Config<br/>OPTIONAL]

    %% Internal ODH Dependencies
    ODHNotebookController -->|"watches<br/>kubeflow.org/v1"| NotebookCRD[Notebook CRD<br/>Kubeflow]
    ODHNotebookController -.->|"routes linked in UI"| Dashboard[ODH Dashboard<br/>Internal ODH]
    ODHNotebookController -.->|"mounts CA bundle"| TrustedCA[Trusted CA Bundle<br/>ConfigMap - Internal ODH]

    %% Integration Points
    Dashboard -->|"creates CRs"| ODHNotebookController
    Pipelines[Data Science Pipelines] -.->|"may create notebooks"| ODHNotebookController

    %% External Services Used
    ODHNotebookController -->|"authenticates users<br/>HTTPS/443"| OAuthServer[OpenShift OAuth Server<br/>Platform]
    ODHNotebookController -->|"manages resources<br/>HTTPS/443"| K8sAPI[Kubernetes API Server<br/>Platform]

    %% Observability
    Prometheus[Prometheus] -->|"scrapes metrics<br/>HTTP/8080"| ODHNotebookController

