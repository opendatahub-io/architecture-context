graph TD
    subgraph "Service Accounts"
        SA_Operator[kuberay-operator<br/>Namespace: opendatahub]
        SA_RayCluster["{raycluster-name}-sa<br/>Namespace: {user-namespace}<br/>(auto-created)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[kuberay-operator<br/>ClusterRoleBinding]
        CRB_LeaderElection[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Operator[kuberay-operator<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_RayJobEditor[kuberay-rayjob-editor<br/>ClusterRole]
        CR_RayJobViewer[kuberay-rayjob-viewer<br/>ClusterRole]
        CR_RayServiceEditor[kuberay-rayservice-editor<br/>ClusterRole]
        CR_RayServiceViewer[kuberay-rayservice-viewer<br/>ClusterRole]
    end

    subgraph "API Resources - Ray CRDs"
        RayCluster["ray.io/rayclusters<br/>ray.io/rayclusters/status<br/>ray.io/rayclusters/finalizers"]
        RayJob["ray.io/rayjobs<br/>ray.io/rayjobs/status<br/>ray.io/rayjobs/finalizers"]
        RayService["ray.io/rayservices<br/>ray.io/rayservices/status<br/>ray.io/rayservices/finalizers"]
    end

    subgraph "API Resources - Core Kubernetes"
        Pods["core/pods<br/>core/pods/status"]
        Services["core/services<br/>core/services/status"]
        ServiceAccounts["core/serviceaccounts"]
        Events["core/events"]
        Endpoints["core/endpoints"]
    end

    subgraph "API Resources - Batch & Networking"
        Jobs["batch/jobs"]
        Ingresses["networking.k8s.io/ingresses<br/>networking.k8s.io/ingressclasses<br/>extensions/ingresses"]
        Routes["route.openshift.io/routes"]
    end

    subgraph "API Resources - RBAC & Coordination"
        RolesRB["rbac.authorization.k8s.io/roles<br/>rbac.authorization.k8s.io/rolebindings"]
        Leases["coordination.k8s.io/leases"]
    end

    %% Service Account to Role Bindings
    SA_Operator -->|bound via| CRB_Operator
    SA_Operator -->|bound via| CRB_LeaderElection

    %% Role Bindings to Roles
    CRB_Operator -->|grants| CR_Operator
    CRB_LeaderElection -->|grants| CR_LeaderElection

    %% Operator ClusterRole Permissions
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| RayCluster
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| RayJob
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| RayService
    CR_Operator -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| Pods
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR_Operator -->|create, delete, get, list, watch| ServiceAccounts
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| Events
    CR_Operator -->|get, list| Endpoints
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| Jobs
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| Ingresses
    CR_Operator -->|create, delete, get, list,<br/>patch, update, watch| Routes
    CR_Operator -->|create, delete, get, list,<br/>update, watch| RolesRB

    %% Leader Election Role Permissions
    CR_LeaderElection -->|create, get, list, update| Leases

    %% User-facing RBAC Roles
    CR_RayJobEditor -->|create, delete, get, list,<br/>patch, update, watch| RayJob
    CR_RayJobViewer -->|get, list, watch| RayJob
    CR_RayServiceEditor -->|create, delete, get, list,<br/>patch, update, watch| RayService
    CR_RayServiceViewer -->|get, list, watch| RayService

    %% Autoscaler ServiceAccount (uses RayCluster SA)
    SA_RayCluster -->|autoscaler uses for scaling| Pods
    SA_RayCluster -.->|needs permissions| K8sAPI[Kubernetes API<br/>Pod creation/deletion]

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_RayCluster fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Operator fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333
    style CRB_Operator fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB_LeaderElection fill:#7ed321,stroke:#333
    style RayCluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RayJob fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RayService fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Pods fill:#d5e8d4,stroke:#82b366
    style Services fill:#d5e8d4,stroke:#82b366
    style ServiceAccounts fill:#d5e8d4,stroke:#82b366
    style Events fill:#d5e8d4,stroke:#82b366
    style Endpoints fill:#d5e8d4,stroke:#82b366
    style Jobs fill:#d5e8d4,stroke:#82b366
    style Ingresses fill:#d5e8d4,stroke:#82b366
    style Routes fill:#d5e8d4,stroke:#82b366
    style RolesRB fill:#d5e8d4,stroke:#82b366
    style Leases fill:#d5e8d4,stroke:#82b366
    style CR_RayJobEditor fill:#d3d3d3,stroke:#333
    style CR_RayJobViewer fill:#d3d3d3,stroke:#333
    style CR_RayServiceEditor fill:#d3d3d3,stroke:#333
    style CR_RayServiceViewer fill:#d3d3d3,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
