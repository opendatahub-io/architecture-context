graph TB
    subgraph "ODH Model Controller"
        Controller[InferenceService Reconciler<br/>Main Controller]
        KServeServerless[KServe Serverless Reconciler]
        KServeRaw[KServe Raw Reconciler]
        ModelMesh[ModelMesh Reconciler]
        Storage[StorageSecret Reconciler]
        CACert[KServeCustomCACert Reconciler]
        Monitoring[Monitoring Reconciler]
        ModelReg[ModelRegistry InferenceService Reconciler]
        Webhook[Knative Service Validator<br/>ValidatingWebhook]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS TLS 1.2+]
        MetricsServer[Metrics Server<br/>8080/TCP HTTP]
        HealthServer[Health Probe Server<br/>8081/TCP HTTP]

        Controller -->|delegates| KServeServerless
        Controller -->|delegates| KServeRaw
        Controller -->|delegates| ModelMesh
        Webhook -->|served by| WebhookServer
    end

    subgraph "Watched CRDs"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        KnativeServiceCR[Service<br/>serving.knative.dev/v1]
    end

    subgraph "Created Resources - Service Mesh"
        VirtualService[VirtualService<br/>networking.istio.io]
        Gateway[Gateway<br/>networking.istio.io]
        PeerAuth[PeerAuthentication<br/>security.istio.io]
        Telemetry[Telemetry<br/>telemetry.istio.io]
        ServiceMeshMember[ServiceMeshMember<br/>maistra.io]
    end

    subgraph "Created Resources - OpenShift"
        Route[Route<br/>route.openshift.io]
        NetworkPolicy[NetworkPolicy<br/>networking.k8s.io]
    end

    subgraph "Created Resources - Monitoring"
        ServiceMonitor[ServiceMonitor<br/>monitoring.coreos.com]
        PodMonitor[PodMonitor<br/>monitoring.coreos.com]
    end

    subgraph "Created Resources - Auth"
        AuthConfig[AuthConfig<br/>authorino.kuadrant.io]
    end

    subgraph "External Dependencies"
        KServe[KServe v0.12.1]
        Knative[Knative Serving v0.39.3]
        Istio[Istio/Maistra 1.19.x]
        Authorino[Authorino v0.15.0]
        PrometheusOp[Prometheus Operator v0.64.1]
    end

    subgraph "Internal ODH Dependencies"
        ModelRegistry[Model Registry]
        DSC[DataScienceCluster]
        DSCI[DSCInitialization]
    end

    %% Watches
    InferenceServiceCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    KnativeServiceCR -->|validated by| Webhook
    DSC -->|config read by| Controller
    DSCI -->|config read by| Controller

    %% Creates
    KServeServerless -->|creates| VirtualService
    KServeServerless -->|creates| Gateway
    KServeServerless -->|creates| Route
    KServeServerless -->|creates| AuthConfig
    KServeServerless -->|creates| PeerAuth
    KServeServerless -->|creates| Telemetry
    KServeServerless -->|creates| NetworkPolicy
    ModelMesh -->|creates| Route
    ModelMesh -->|creates| ServiceMeshMember
    Monitoring -->|creates| ServiceMonitor
    Monitoring -->|creates| PodMonitor

    %% Dependencies
    Controller -->|depends on| KServe
    KServeServerless -->|requires| Knative
    KServeServerless -->|integrates| Istio
    KServeServerless -->|integrates| Authorino
    Monitoring -->|integrates| PrometheusOp
    ModelReg -->|integrates| ModelRegistry

