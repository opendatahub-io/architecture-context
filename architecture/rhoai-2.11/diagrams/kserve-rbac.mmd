graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kserve-manager-rolebinding<br/>Scope: Cluster]
        CRB2[kserve-proxy-rolebinding<br/>Scope: Cluster]
        RB1[kserve-leader-election-rolebinding<br/>Scope: kserve namespace]
    end

    subgraph "Roles"
        CR1[kserve-manager-role<br/>ClusterRole]
        CR2[kserve-proxy-role<br/>ClusterRole]
        R1[kserve-leader-election-role<br/>Role]
    end

    subgraph "KServe API Resources"
        direction TB
        ISVC[serving.kserve.io<br/>InferenceService<br/>v1beta1]
        SR[serving.kserve.io<br/>ServingRuntime<br/>v1alpha1]
        CSR[serving.kserve.io<br/>ClusterServingRuntime<br/>v1alpha1]
        IG[serving.kserve.io<br/>InferenceGraph<br/>v1alpha1]
        TM[serving.kserve.io<br/>TrainedModel<br/>v1alpha1]
        CSC[serving.kserve.io<br/>ClusterStorageContainer<br/>v1alpha1]
    end

    subgraph "Knative API Resources"
        KS[serving.knative.dev<br/>Service]
    end

    subgraph "Istio API Resources"
        VS[networking.istio.io<br/>VirtualService]
    end

    subgraph "Kubernetes Core Resources"
        direction TB
        Deploy[apps<br/>Deployment]
        HPA[autoscaling<br/>HorizontalPodAutoscaler]
        Svc[core<br/>Service]
        Secret[core<br/>Secret]
        CM[core<br/>ConfigMap]
        Pod[core<br/>Pod]
        NS[core<br/>Namespace]
        Event[core<br/>Event]
        SvcAcc[core<br/>ServiceAccount]
        Ingress[networking.k8s.io<br/>Ingress]
        MWC[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration]
        VWC[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration]
    end

    subgraph "Leader Election Resources"
        LeaderCM[core<br/>ConfigMap<br/>Scope: kserve namespace]
        Lease[coordination.k8s.io<br/>Lease<br/>Scope: kserve namespace]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% Role Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% kserve-manager-role Permissions
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| ISVC
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| SR
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| CSR
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| IG
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| TM
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| CSC
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KS
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| VS
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Deploy
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| HPA
    CR1 -->|various| Svc
    CR1 -->|various| Secret
    CR1 -->|various| CM
    CR1 -->|various| Pod
    CR1 -->|various| NS
    CR1 -->|various| Event
    CR1 -->|various| SvcAcc
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Ingress
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| MWC
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| VWC

    %% Leader Election Permissions
    R1 -->|get, create, update| LeaderCM
    R1 -->|get, create, update| Lease

