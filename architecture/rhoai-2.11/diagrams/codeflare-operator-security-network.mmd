graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser[End User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>{raycluster}-route<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge Termination"]
    end

    subgraph ServiceMesh["SERVICE MESH (Trusted - Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: opendatahub"]
            direction TB
            OperatorMgr["CodeFlare Operator Manager<br/>SA: codeflare-operator-controller-manager<br/>SecurityContext: runAsNonRoot"]
            WebhookSvc["Webhook Service<br/>codeflare-operator-webhook-service<br/>443/TCP → 9443/TCP HTTPS<br/>TLS 1.2+ mTLS (cert-controller)"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>No encryption, No auth"]
            HealthSvc["Health Probe<br/>8081/TCP HTTP<br/>No encryption, No auth"]

            OperatorMgr --> WebhookSvc
            OperatorMgr --> MetricsSvc
            OperatorMgr --> HealthSvc
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            OAuthSvc["OAuth Proxy Service<br/>{raycluster}-oauth-proxy<br/>443/TCP → 8443/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>OAuth Bearer Token"]
            RayHeadSvc["Ray Head Service<br/>{raycluster}-head-svc<br/>8265/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Client cert required"]
            RayHeadPod["Ray Head Pod<br/>8265/TCP Ray Dashboard<br/>NetworkPolicy enforced"]

            OAuthSvc --> RayHeadPod
            RayHeadSvc --> RayHeadPod
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount tokens + mTLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        KubeRay["KubeRay Operator<br/>v1.1.0+<br/>Provides RayCluster CRD"]
        Kueue["Kueue<br/>v0.7.0+<br/>Workload queueing<br/>6443/TCP via K8s API"]
        CertController["cert-controller<br/>v0.10.1+<br/>Webhook cert rotation"]
        Prometheus["Prometheus<br/>Metrics scraping<br/>8080/TCP HTTP"]
        OSAuth["OpenShift OAuth<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth 2.0"]
    end

    %% External → Ingress
    Browser -->|HTTPS/443<br/>TLS 1.2+ Edge<br/>No auth| Route

    %% Ingress → Service Mesh
    Route -->|HTTPS/443<br/>TLS 1.2+ Reencrypt<br/>service-ca cert| OAuthSvc

    %% OAuth → Ray
    OAuthSvc -->|HTTPS/8265<br/>TLS 1.2+ mTLS<br/>Client cert| RayHeadPod

    %% Operator flows
    OperatorMgr -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>Client cert| WebhookSvc

    %% External services
    OperatorMgr -.->|CRD check| KubeRay
    OperatorMgr -->|HTTPS/6443<br/>via K8s API<br/>ServiceAccount Token| Kueue
    CertController -->|Manages| WebhookSvc
    Prometheus -->|HTTP/8080<br/>Scrape metrics<br/>No auth| MetricsSvc
    OAuthSvc -.->|OAuth flow<br/>HTTPS/443<br/>TLS 1.2+| OSAuth

    %% NetworkPolicy indication
    RayHeadPod -.->|NetworkPolicy:<br/>Ingress from Ray pods only<br/>Egress to K8s API, DNS| K8sAPI

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px

    class Browser external
    class Route ingress
    class OperatorMgr,WebhookSvc,MetricsSvc,HealthSvc,OAuthSvc,RayHeadSvc,RayHeadPod,K8sAPI servicemesh
    class KubeRay,Kueue,CertController,Prometheus,OSAuth externalservice
    class OperatorMgr operator
