graph TD
    subgraph "Note: Notebook Images Do Not Define RBAC"
        Note["This component provides container images only.<br/>RBAC resources are managed by ODH Notebook Controller.<br/>This diagram shows the runtime RBAC created by the controller."]
    end

    subgraph "Service Accounts"
        SA_NotebookController[odh-notebook-controller-manager<br/>Namespace: opendatahub]
        SA_Dashboard[odh-dashboard<br/>Namespace: opendatahub]
        SA_Notebook["{notebook-name}-sa<br/>Namespace: {user-namespace}<br/>Created per workbench instance"]
    end

    subgraph "Cluster-Level Permissions"
        CR_NotebookController[ClusterRole:<br/>odh-notebook-controller-role<br/>Manages Notebook CRs cluster-wide]
        CRB_NotebookController[ClusterRoleBinding:<br/>odh-notebook-controller-rolebinding]
    end

    subgraph "Namespace-Level Permissions"
        Role_Notebook["Role<br/>{notebook-name}-role<br/>Read own namespace resources"]
        RoleBinding_Notebook["RoleBinding<br/>{notebook-name}-rolebinding"]
    end

    subgraph "Kubernetes API Resources"
        direction TB

        subgraph CustomResources["Custom Resources"]
            NotebookCR[notebooks.kubeflow.org<br/>Notebook CR]
        end

        subgraph CoreResources["Core Resources"]
            StatefulSets[apps/v1<br/>StatefulSets]
            Services[core/v1<br/>Services]
            Routes[route.openshift.io/v1<br/>Routes]
            ConfigMaps[core/v1<br/>ConfigMaps]
            Secrets[core/v1<br/>Secrets]
            PVCs[core/v1<br/>PersistentVolumeClaims]
        end

        subgraph ImageResources["Image Resources"]
            ImageStreams[image.openshift.io/v1<br/>ImageStreams]
        end
    end

    subgraph "OAuth Proxy Authorization"
        OAuthPolicy["OAuth Proxy Policy<br/>Enforcement Point: Sidecar Container<br/>Policy: User must own notebook OR have admin role<br/>Auth Mechanism: OAuth2 Bearer Token"]
    end

    %% Service Account Bindings
    SA_NotebookController -->|bound via| CRB_NotebookController
    CRB_NotebookController -->|grants| CR_NotebookController

    SA_Notebook -->|bound via| RoleBinding_Notebook
    RoleBinding_Notebook -->|grants| Role_Notebook

    %% Notebook Controller Permissions
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| NotebookCR
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| StatefulSets
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| Services
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| Routes
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| ConfigMaps
    CR_NotebookController -->|get, list, watch, create,<br/>update, patch, delete| Secrets
    CR_NotebookController -->|get, list, watch| PVCs
    CR_NotebookController -->|get, list, watch| ImageStreams

    %% Dashboard Permissions
    SA_Dashboard -->|get, list, watch| ImageStreams
    SA_Dashboard -->|create, update, delete| NotebookCR

    %% Notebook Pod Permissions
    Role_Notebook -->|get, list| ConfigMaps
    Role_Notebook -->|get, list| Secrets
    Role_Notebook -->|get, list| PVCs

    %% OAuth Proxy
    OAuthPolicy -.->|protects access to| StatefulSets
    OAuthPolicy -.->|validates user identity via| SA_Notebook

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px

    style SA_NotebookController fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Dashboard fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Notebook fill:#4a90e2,stroke:#333,stroke-width:2px

    style CR_NotebookController fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_NotebookController fill:#f5a623,stroke:#333,stroke-width:2px
    style Role_Notebook fill:#f5a623,stroke:#333,stroke-width:2px
    style RoleBinding_Notebook fill:#f5a623,stroke:#333,stroke-width:2px

    style NotebookCR fill:#7ed321,stroke:#333,stroke-width:2px
    style StatefulSets fill:#7ed321,stroke:#333,stroke-width:2px
    style Services fill:#7ed321,stroke:#333,stroke-width:2px
    style Routes fill:#7ed321,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#7ed321,stroke:#333,stroke-width:2px
    style Secrets fill:#7ed321,stroke:#333,stroke-width:2px
    style PVCs fill:#7ed321,stroke:#333,stroke-width:2px
    style ImageStreams fill:#7ed321,stroke:#333,stroke-width:2px

    style OAuthPolicy fill:#bd10e0,stroke:#333,stroke-width:2px
