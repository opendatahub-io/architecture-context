graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-role-binding<br/>ClusterRoleBinding]
        CRB2[kueue-leader-election-role-binding<br/>RoleBinding in opendatahub]
        CRB3[kueue-auth-proxy-role-binding<br/>RoleBinding in opendatahub]
    end

    subgraph "ClusterRoles"
        CR_Manager[kueue-manager-role<br/>ClusterRole]
        CR_Leader[kueue-leader-election-role<br/>Role in opendatahub]
        CR_Proxy[kueue-auth-proxy-role<br/>Role in opendatahub]
    end

    subgraph "API Resources - Core"
        Core_Events[core/events<br/>create, get, list, watch,<br/>update, patch, delete]
        Core_Pods[core/pods<br/>create, get, list, watch,<br/>update, patch, delete]
        Core_Namespaces[core/namespaces<br/>create, get, list, watch,<br/>update, patch, delete]
        Core_Secrets[core/secrets<br/>create, get, list, watch,<br/>update, patch, delete]
        Core_LimitRanges[core/limitranges<br/>create, get, list, watch,<br/>update, patch, delete]
    end

    subgraph "API Resources - Batch"
        Batch_Jobs[batch/jobs<br/>get, list, watch,<br/>update, patch]
        Batch_Jobs_Finalizers[batch/jobs/finalizers<br/>get, update, patch]
        Batch_Jobs_Status[batch/jobs/status<br/>get, update, patch]
    end

    subgraph "API Resources - Kueue"
        Kueue_Workloads[kueue.x-k8s.io/workloads<br/>create, delete, get, list,<br/>patch, update, watch]
        Kueue_ClusterQueues[kueue.x-k8s.io/clusterqueues<br/>create, delete, get, list,<br/>patch, update, watch]
        Kueue_LocalQueues[kueue.x-k8s.io/localqueues<br/>create, delete, get, list,<br/>patch, update, watch]
        Kueue_AdmissionChecks[kueue.x-k8s.io/admissionchecks<br/>create, delete, get, list,<br/>patch, update, watch]
        Kueue_ResourceFlavors[kueue.x-k8s.io/resourceflavors<br/>create, delete, get, list,<br/>patch, update, watch]
        Kueue_Finalizers[kueue.x-k8s.io/*/finalizers<br/>get, update, patch]
        Kueue_Status[kueue.x-k8s.io/*/status<br/>get, update, patch]
    end

    subgraph "API Resources - Kubeflow Training"
        KF_TFJob[kubeflow.org/tfjobs<br/>get, list, watch, update, patch]
        KF_PyTorchJob[kubeflow.org/pytorchjobs<br/>get, list, watch, update, patch]
        KF_MPIJob[kubeflow.org/mpijobs<br/>get, list, watch, update, patch]
        KF_MXJob[kubeflow.org/mxjobs<br/>get, list, watch, update, patch]
        KF_PaddleJob[kubeflow.org/paddlejobs<br/>get, list, watch, update, patch]
        KF_XGBoostJob[kubeflow.org/xgboostjobs<br/>get, list, watch, update, patch]
        KF_Finalizers[kubeflow.org/*/finalizers<br/>get, update]
        KF_Status[kubeflow.org/*/status<br/>get, update]
    end

    subgraph "API Resources - Ray"
        Ray_RayJobs[ray.io/rayjobs<br/>get, list, watch, update, patch]
        Ray_RayClusters[ray.io/rayclusters<br/>get, list, watch, update, patch]
        Ray_Finalizers[ray.io/*/finalizers<br/>get, update]
        Ray_Status[ray.io/*/status<br/>get, update]
    end

    subgraph "API Resources - JobSet"
        JobSet_JobSets[jobset.x-k8s.io/jobsets<br/>get, list, watch, update, patch]
        JobSet_Finalizers[jobset.x-k8s.io/jobsets/finalizers<br/>get, update]
        JobSet_Status[jobset.x-k8s.io/jobsets/status<br/>get, update]
    end

    subgraph "API Resources - Autoscaling"
        Autoscaling_PR[autoscaling.x-k8s.io/<br/>provisioningrequests<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "API Resources - AdmissionRegistration"
        Admission_MWC[admissionregistration.k8s.io/<br/>mutatingwebhookconfigurations<br/>get, list, update, watch]
        Admission_VWC[admissionregistration.k8s.io/<br/>validatingwebhookconfigurations<br/>get, list, update, watch]
    end

    subgraph "User-Facing Roles - Pre-created"
        User_BatchAdmin[kueue-batch-admin-role<br/>Full CRUD on batch jobs]
        User_BatchUser[kueue-batch-user-role<br/>Create and update jobs only]
        User_CQ_Editor[kueue-clusterqueue-editor-role<br/>Full CRUD on ClusterQueues]
        User_CQ_Viewer[kueue-clusterqueue-viewer-role<br/>Read-only ClusterQueues]
        User_LQ_Editor[kueue-localqueue-editor-role<br/>Full CRUD on LocalQueues]
        User_LQ_Viewer[kueue-localqueue-viewer-role<br/>Read-only LocalQueues]
        User_WL_Editor[kueue-workload-editor-role<br/>Full CRUD on Workloads]
        User_WL_Viewer[kueue-workload-viewer-role<br/>Read-only Workloads]
    end

