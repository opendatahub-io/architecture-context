graph TB
    subgraph External["EXTERNAL (User Zone)"]
        User["User/Data Science Pipeline<br/>Submits batch jobs"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>https://kubernetes.default.svc:443<br/>RBAC enforcement"]
    end

    subgraph NS_Opendatahub["NAMESPACE: opendatahub (Kueue Operator)"]
        direction TB

        subgraph WebhookService["kueue-webhook-service (ClusterIP)"]
            WebhookEndpoint["Service: 443/TCP → Pod: 9443/TCP<br/>Endpoints:<br/>- /mutate-batch-v1-job<br/>- /mutate-jobset-x-k8s-io-v1alpha2-jobset<br/>- /validate-kueue-x-k8s-io-v1beta1-*<br/>Auth: mTLS (API Server client cert)<br/>TLS Cert: kueue-webhook-server-cert<br/>NetworkPolicy: Allow TCP/9443 from any"]
        end

        subgraph ControllerManager["kueue-controller-manager (Deployment)"]
            direction LR
            Controllers["Controllers:<br/>- AdmissionCheck<br/>- ClusterQueue<br/>- LocalQueue<br/>- Workload<br/>- ResourceFlavor<br/>- Webhook Server (9443)<br/>- Visibility Server (8082)<br/>- Metrics Exporter (8080/8443)<br/>- Health Probes (8081)<br/><br/>SA: kueue-controller-manager<br/>User: 65532:65532 (non-root)<br/>Security: runAsNonRoot=true"]
        end

        subgraph VisibilityService["kueue-visibility-server (ClusterIP)"]
            VisibilityEndpoint["Service: 443/TCP → Pod: 8082/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: API authentication<br/>Purpose: Extended APIs for pending workloads"]
        end

        subgraph MetricsService1["kueue-metrics-service (ClusterIP)"]
            MetricsHTTP["Service: 8080/TCP → Pod: metrics<br/>Protocol: HTTP<br/>Encryption: None<br/>Auth: None<br/>Endpoint: /metrics<br/>Exposure: Internal (Prometheus)"]
        end

        subgraph MetricsService2["kueue-controller-manager-metrics-service (ClusterIP)"]
            MetricsHTTPS["Service: 8443/TCP → Pod: https<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: Bearer Token (kube-rbac-proxy)<br/>Endpoint: /metrics<br/>Exposure: Internal (authenticated)"]
        end

        Controllers --> WebhookEndpoint
        Controllers --> VisibilityEndpoint
        Controllers --> MetricsHTTP
        Controllers --> MetricsHTTPS
    end

    subgraph Monitoring["MONITORING (Prometheus)"]
        Prometheus["Prometheus Server<br/>Namespace: openshift-monitoring<br/>SA: prometheus<br/>Scrapes:<br/>- kueue-metrics-service:8080 (HTTP)<br/>- kueue-...-metrics-service:8443 (HTTPS)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ClusterAutoscaler["Cluster Autoscaler<br/>Namespace: kube-system<br/>SA: cluster-autoscaler<br/>Watches ProvisioningRequests"]
        CloudAPI["Cloud Provider API<br/>AWS EC2 / GCP GCE / Azure VMSS<br/>Provisions new nodes"]
    end

    %% User to API Server
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Submit Jobs| APIServer

    %% API Server to Webhook
    APIServer -->|HTTPS/443 → 9443<br/>mTLS<br/>Client Cert<br/>Validate/Mutate| WebhookEndpoint

    %% Controller to API Server
    Controllers -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Watch/Reconcile CRDs, Jobs, Pods| APIServer

    %% Visibility API aggregation
    APIServer <-->|API Aggregation<br/>HTTPS/443 → 8082<br/>TLS 1.2+| VisibilityEndpoint

    %% Prometheus scraping
    Prometheus -->|HTTP/8080<br/>No Auth<br/>Scrape /metrics| MetricsHTTP
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token<br/>Scrape /metrics| MetricsHTTPS

    %% Cluster Autoscaler
    Controllers -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Create ProvisioningRequests| APIServer
    ClusterAutoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Watch ProvisioningRequests| APIServer
    ClusterAutoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials<br/>Provision nodes| CloudAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlPlane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kueue fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalService fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class APIServer controlPlane
    class WebhookEndpoint,Controllers,VisibilityEndpoint,MetricsHTTP,MetricsHTTPS kueue
    class Prometheus monitoring
    class ClusterAutoscaler,CloudAPI externalService

    %% Annotations
    linkStyle 0 stroke:#333,stroke-width:2px
    linkStyle 1 stroke:#e74c3c,stroke-width:2px
    linkStyle 2 stroke:#3498db,stroke-width:2px
    linkStyle 3 stroke:#9b59b6,stroke-width:2px
    linkStyle 4 stroke:#27ae60,stroke-width:2px
    linkStyle 5 stroke:#e67e22,stroke-width:2px
