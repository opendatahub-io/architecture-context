graph TB
    subgraph "RHODS Operator"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        SecretGen[SecretGenerator Controller]
        CertGen[CertConfigmapGenerator Controller]
        ManifestMgr[Manifest Manager]

        DSCController -->|uses| ManifestMgr
        DSCIController -->|initializes| ManifestMgr
    end

    subgraph "Component Reconcilers"
        Dashboard[Dashboard Reconciler]
        KServe[KServe Reconciler]
        ModelMesh[ModelMesh Reconciler]
        DSP[Data Science Pipelines]
        Workbenches[Workbenches Reconciler]
        CodeFlare[CodeFlare Reconciler]
        Ray[Ray Reconciler]
        Kueue[Kueue Reconciler]
        Training[Training Operator]
        TrustyAI[TrustyAI Reconciler]

        DSCController -->|delegates to| Dashboard
        DSCController -->|delegates to| KServe
        DSCController -->|delegates to| ModelMesh
        DSCController -->|delegates to| DSP
        DSCController -->|delegates to| Workbenches
        DSCController -->|delegates to| CodeFlare
        DSCController -->|delegates to| Ray
        DSCController -->|delegates to| Kueue
        DSCController -->|delegates to| Training
        DSCController -->|delegates to| TrustyAI
    end

    subgraph "Custom Resources"
        DSCCR[DataScienceCluster CR]
        DSCICR[DSCInitialization CR]
        FeatureTracker[FeatureTracker CR]

        User[Admin/User] -->|creates| DSCICR
        User -->|creates| DSCCR
        DSCIController -->|watches| DSCICR
        DSCController -->|watches| DSCCR
        DSCController -->|creates| FeatureTracker
    end

    subgraph "Platform Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ServiceMesh[Service Mesh<br/>Istio]
        Prometheus[Prometheus<br/>9091/TCP HTTPS]
        Alertmanager[Alertmanager<br/>9093/TCP HTTPS]
        CertManager[cert-manager]
    end

    subgraph "Monitoring Stack"
        MetricsEndpoint[Metrics Endpoint<br/>8080/TCP HTTP]
        ServiceMonitor[ServiceMonitors]
        PrometheusRules[PrometheusRules]

        DSCController -->|exposes| MetricsEndpoint
        DSCController -->|creates| ServiceMonitor
        DSCController -->|creates| PrometheusRules
        Prometheus -->|scrapes| MetricsEndpoint
    end

    DSCController -->|reconciles via| K8sAPI
    DSCIController -->|reconciles via| K8sAPI
    SecretGen -->|creates secrets via| K8sAPI
    CertGen -->|creates configmaps via| K8sAPI

    DSCIController -->|configures| ServiceMesh
    DSCIController -->|deploys| Prometheus
    DSCIController -->|deploys| Alertmanager

    KServe -->|requires| ServiceMesh
    DSCController -->|uses| CertManager

    ManifestMgr -->|fetches from| GitHub[GitHub Component Repos<br/>443/TCP HTTPS]

    style DSCController fill:#4a90e2,stroke:#333,stroke-width:3px
    style DSCIController fill:#4a90e2,stroke:#333,stroke-width:3px
    style SecretGen fill:#4a90e2,stroke:#333,stroke-width:2px
    style CertGen fill:#4a90e2,stroke:#333,stroke-width:2px
    style ManifestMgr fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCCR fill:#f5a623,stroke:#333,stroke-width:2px
    style DSCICR fill:#f5a623,stroke:#333,stroke-width:2px
    style FeatureTracker fill:#f5a623,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#999,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Alertmanager fill:#7ed321,stroke:#333
    style CertManager fill:#999,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style GitHub fill:#e8e8e8,stroke:#333
