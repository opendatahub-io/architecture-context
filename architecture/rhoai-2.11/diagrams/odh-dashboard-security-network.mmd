graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        Route["OpenShift Route<br/>odh-dashboard<br/>*.apps.cluster-domain"]
    end

    subgraph Application["APPLICATION LAYER"]
        direction TB

        subgraph DashboardNamespace["Namespace: odh-dashboard"]
            Service["Service: odh-dashboard<br/>ClusterIP<br/>8443/TCP"]

            subgraph DashboardPod["Dashboard Pod (2 replicas)"]
                OAuthProxy["OAuth Proxy<br/>Port: 8443/TCP HTTPS<br/>SA: odh-dashboard<br/>TLS: Service CA"]
                Backend["Dashboard Backend<br/>Port: 8080/TCP HTTP<br/>Node.js/Fastify<br/>SA: odh-dashboard"]
            end
        end
    end

    subgraph Platform["PLATFORM SERVICES (Internal)"]
        direction TB

        K8sAPI["Kubernetes API<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]

        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS TLS1.2+<br/>Auth: OAuth 2.0"]

        subgraph Monitoring["Namespace: openshift-monitoring"]
            Thanos["Thanos Querier<br/>9092/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
        end

        Pipelines["Data Science Pipelines<br/>8443/TCP HTTPS TLS1.2+<br/>Auth: Bearer Token"]

        ModelRegistry["Model Registry<br/>8080/TCP HTTPS TLS1.2+<br/>Auth: Bearer Token"]
    end

    subgraph Egress["EGRESS - EXTERNAL"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS Credentials"]
    end

    subgraph Secrets["SECRETS"]
        ProxyTLS["dashboard-proxy-tls<br/>TLS cert<br/>Service CA<br/>Auto-rotate"]
        OAuthConfig["dashboard-oauth-config<br/>Cookie secret<br/>Manual rotate"]
        OAuthClient["dashboard-oauth-client<br/>Client credentials<br/>Manual rotate"]
    end

    %% Traffic Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router --> Route
    Route -->|HTTPS/8443<br/>TLS 1.2+<br/>Service CA| Service
    Service --> OAuthProxy
    OAuthProxy -->|OAuth Flow<br/>HTTPS/443<br/>OAuth 2.0| OAuthServer
    OAuthProxy -->|HTTP/8080<br/>Localhost<br/>Bearer Token| Backend
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>SA Token| Thanos
    Backend -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| Pipelines
    Backend -->|HTTPS/8080<br/>TLS 1.2+<br/>Bearer Token| ModelRegistry
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Creds| S3

    %% Secret Mounts
    ProxyTLS -.->|mounted at<br/>/etc/tls/private| OAuthProxy
    OAuthConfig -.->|mounted at<br/>/etc/oauth/config| OAuthProxy
    OAuthClient -.->|mounted at<br/>/etc/oauth/client| OAuthProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router,Route ingress
    class Service,OAuthProxy,Backend application
    class K8sAPI,OAuthServer,Thanos,Pipelines,ModelRegistry platform
    class S3 egress
    class ProxyTLS,OAuthConfig,OAuthClient secrets
