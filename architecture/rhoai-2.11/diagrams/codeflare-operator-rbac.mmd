graph TD
    subgraph "Service Account"
        SA[codeflare-operator-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "Cluster Role Bindings"
        CRB[codeflare-operator-manager-rolebinding<br/>ClusterRoleBinding]
        NRB[codeflare-operator-leader-election-rolebinding<br/>RoleBinding in opendatahub]
    end

    subgraph "Cluster Roles"
        CR[codeflare-operator-manager-role<br/>ClusterRole]
        LER[codeflare-operator-leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Secrets[core/secrets<br/>get, list, watch, update, create, delete, patch]
        Services[core/services<br/>get, list, watch, create, update, patch, delete]
        ServiceAccounts[core/serviceaccounts<br/>get, list, watch, create, update, patch, delete]
        Pods[core/pods<br/>get, list, watch, create, update, patch, delete]
        Events[core/events<br/>create, patch, update, watch]
    end

    subgraph "Apps & Batch Resources"
        Deployments[apps/deployments<br/>get, list, watch, create, update, patch, delete]
        StatefulSets[apps/statefulsets<br/>get, list, watch, create, update, patch, delete]
        Jobs[batch/jobs<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "Ray CRDs (ray.io)"
        RayClusters[ray.io/rayclusters<br/>get, list, watch, create, update, patch, delete]
        RayClustersStatus[ray.io/rayclusters/status<br/>get, patch, update]
        RayClustersFinalizers[ray.io/rayclusters/finalizers<br/>update]
        RayJobs[ray.io/rayjobs<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "AppWrapper CRDs (workload.codeflare.dev)"
        AppWrappers[workload.codeflare.dev/appwrappers<br/>get, list, watch, create, update, patch, delete]
        AppWrappersStatus[workload.codeflare.dev/appwrappers/status<br/>get, patch, update]
        AppWrappersFinalizers[workload.codeflare.dev/appwrappers/finalizers<br/>update]
    end

    subgraph "Kueue CRDs (kueue.x-k8s.io)"
        KueueWorkloads[kueue.x-k8s.io/workloads<br/>get, list, watch, create, update, patch, delete]
        KueueWorkloadsStatus[kueue.x-k8s.io/workloads/status<br/>get, patch, update]
        KueueWorkloadsFinalizers[kueue.x-k8s.io/workloads/finalizers<br/>update]
        ResourceFlavors[kueue.x-k8s.io/resourceflavors<br/>get, list, watch]
        WorkloadPriorityClasses[kueue.x-k8s.io/workloadpriorityclasses<br/>get, list, watch]
    end

    subgraph "Networking Resources"
        Ingresses[networking.k8s.io/ingresses<br/>get, list, watch, create, update, patch, delete]
        NetworkPolicies[networking.k8s.io/networkpolicies<br/>get, list, watch, create, update, patch, delete]
        Routes[route.openshift.io/routes<br/>get, list, watch, create, update, patch, delete]
        RoutesCustomHost[route.openshift.io/routes/custom-host<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "RBAC & Webhooks"
        ClusterRoleBindings[rbac.authorization.k8s.io/clusterrolebindings<br/>get, list, watch, create, update, patch, delete]
        MutatingWebhooks[admissionregistration.k8s.io/mutatingwebhookconfigurations<br/>get, list, watch, update]
        ValidatingWebhooks[admissionregistration.k8s.io/validatingwebhookconfigurations<br/>get, list, watch, update]
    end

    subgraph "Discovery & Auth"
        CRDs[apiextensions.k8s.io/customresourcedefinitions<br/>get, list, watch]
        OSIngresses[config.openshift.io/ingresses<br/>get]
        DSCInit[dscinitialization.opendatahub.io/dscinitializations<br/>get, list, watch]
        TokenReviews[authentication.k8s.io/tokenreviews<br/>create]
        SubjectAccessReviews[authorization.k8s.io/subjectaccessreviews<br/>create]
    end

    subgraph "Scheduling Resources"
        PriorityClasses[scheduling.k8s.io/priorityclasses<br/>get, list, watch]
        PodGroupsSigs[scheduling.sigs.k8s.io/podgroups<br/>get, list, watch, create, update, patch, delete]
        PodGroupsXK8s[scheduling.x-k8s.io/podgroups<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "Kubeflow Resources"
        PyTorchJobs[kubeflow.org/pytorchjobs<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "Leader Election (Namespaced)"
        ConfigMaps[core/configmaps<br/>get, list, watch, create, update, patch, delete]
        Leases[coordination.k8s.io/leases<br/>get, list, watch, create, update, patch, delete]
        LeaderEvents[core/events<br/>create, patch]
    end

    %% Service Account bindings
    SA -->|bound via| CRB
    SA -->|bound via| NRB
    CRB -->|grants| CR
    NRB -->|grants| LER

