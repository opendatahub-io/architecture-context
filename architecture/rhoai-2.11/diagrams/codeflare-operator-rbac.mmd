    CR -->|permissions| AppWrappersFinalizers
    CR -->|permissions| KueueWorkloads
    CR -->|permissions| KueueWorkloadsStatus
    CR -->|permissions| KueueWorkloadsFinalizers
    CR -->|permissions| ResourceFlavors
    CR -->|permissions| WorkloadPriorityClasses
    CR -->|permissions| Ingresses
    CR -->|permissions| NetworkPolicies
    CR -->|permissions| Routes
    CR -->|permissions| RoutesCustomHost
    CR -->|permissions| ClusterRoleBindings
    CR -->|permissions| MutatingWebhooks
    CR -->|permissions| ValidatingWebhooks
    CR -->|permissions| CRDs
    CR -->|permissions| OSIngresses
    CR -->|permissions| DSCInit
