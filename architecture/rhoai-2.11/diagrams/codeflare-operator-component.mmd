graph TB
    subgraph "CodeFlare Operator"
        Manager[Operator Manager<br/>Go Binary]
        RayController[RayCluster Controller]
        AppWrapperController[AppWrapper Controller]
        RayWebhook[RayCluster Webhook<br/>Mutating/Validating]
        AppWrapperWebhook[AppWrapper Webhook<br/>Mutating/Validating]
        CertRotator[Certificate Rotator]
        MetricsServer[Metrics Server<br/>8080/TCP HTTP]
        HealthProbe[Health Probe Server<br/>8081/TCP HTTP]

        Manager --> RayController
        Manager --> AppWrapperController
        Manager --> RayWebhook
        Manager --> AppWrapperWebhook
        Manager --> CertRotator
        Manager --> MetricsServer
        Manager --> HealthProbe
    end

    subgraph "CRDs Watched"
        RayClusterCR[RayCluster<br/>ray.io/v1<br/>from KubeRay]
        AppWrapperCR[AppWrapper<br/>workload.codeflare.dev/v1beta2<br/>owned by operator]
    end

    subgraph "Resources Created"
        OAuthProxy[OAuth Proxy Sidecar<br/>OpenShift only]
        mTLSConfig[mTLS Configuration<br/>CA certificates]
        NetworkPolicies[Network Policies<br/>Ingress/Egress rules]
        Services[Services<br/>OAuth proxy, metrics]
        Routes[Routes/Ingresses<br/>Ray Dashboard access]
        Secrets[Secrets<br/>TLS certs, OAuth]
    end

    subgraph "External Dependencies"
        KubeRay[KubeRay Operator<br/>v1.1.0+]
        Kueue[Kueue<br/>v0.7.0+]
        CertManager[cert-controller<br/>v0.10.1+]
        K8sAPI[Kubernetes API<br/>1.29+]
        OpenShift[OpenShift 4.x<br/>optional]
    end

    subgraph "Internal RHOAI Dependencies"
        ODHOperator[ODH Operator<br/>DSCInitialization]
    end

    %% Watched resources
    RayClusterCR -->|watched by| RayController
    RayWebhook -->|mutates/validates| RayClusterCR
    AppWrapperCR -->|watched by| AppWrapperController
    AppWrapperWebhook -->|mutates/validates| AppWrapperCR

    %% Created resources
    RayController -->|injects| OAuthProxy
    RayController -->|configures| mTLSConfig
    RayController -->|creates| NetworkPolicies
    RayController -->|creates| Services
    RayController -->|creates| Routes
    RayController -->|creates| Secrets

    AppWrapperController -->|creates| KueueWorkload[Kueue Workload]

    %% External dependencies
    Manager -->|requires| KubeRay
    AppWrapperController -->|integrates| Kueue
    CertRotator -->|uses| CertManager
    Manager -->|calls| K8sAPI
    RayController -->|integrates| OpenShift

    %% Internal dependencies
    Manager -->|watches| ODHOperator

    %% Monitoring
    Prometheus[Prometheus] -->|scrapes| MetricsServer
    Monitoring[Monitoring Tools] -->|checks| HealthProbe

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayController fill:#4a90e2,stroke:#333
    style AppWrapperController fill:#4a90e2,stroke:#333
    style RayWebhook fill:#4a90e2,stroke:#333
    style AppWrapperWebhook fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style AppWrapperCR fill:#f5a623,stroke:#333,stroke-width:2px
    style KubeRay fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style OpenShift fill:#999,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
    style OAuthProxy fill:#d4a5ff,stroke:#333
    style mTLSConfig fill:#d4a5ff,stroke:#333
