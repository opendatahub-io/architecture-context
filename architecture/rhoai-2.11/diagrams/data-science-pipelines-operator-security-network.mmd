graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[Data Scientist /<br/>KFP SDK Client]
    end

    subgraph Ingress["INGRESS - DMZ"]
        direction TB
        RouteAPI["OpenShift Route<br/>ds-pipeline-NAME<br/>443/TCP HTTPS<br/>TLS 1.3<br/>Reencrypt"]
        RouteUI["OpenShift Route<br/>ds-pipeline-ui-NAME<br/>443/TCP HTTPS<br/>TLS 1.3<br/>Reencrypt"]
        RouteMLMD["OpenShift Route<br/>ds-pipeline-md-NAME<br/>443/TCP HTTPS<br/>TLS 1.3<br/>Reencrypt"]
    end

    subgraph AppTier["APPLICATION TIER Namespace dspa-ns"]
        direction TB

        subgraph ProxyLayer["OAuth Proxy Layer"]
            OAuthAPI["OAuth Proxy<br/>SA: ds-pipeline-NAME<br/>8443/TCP HTTPS TLS1.2+<br/>Secret: ds-pipelines-proxy-tls"]
            OAuthUI["OAuth Proxy UI<br/>8443/TCP HTTPS TLS1.2+<br/>Secret: ds-pipelines-ui-proxy-tls"]
            OAuthMLMD["OAuth Proxy MLMD<br/>8443/TCP HTTPS TLS1.2+<br/>Secret: ds-pipelines-envoy-proxy-tls"]
        end

        subgraph CoreServices["Core Services"]
            APIServer["KFP API Server<br/>SA: ds-pipeline-NAME<br/>8888/TCP HTTP<br/>8887/TCP gRPC TLS1.2+"]
            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-NAME"]
            WorkflowController["Workflow Controller<br/>SA: argo<br/>8887/TCP gRPC TLS1.2+"]
            UI["ML Pipelines UI<br/>8080/TCP HTTP"]
        end

        subgraph DataLayer["Data Layer"]
            MariaDB["MariaDB<br/>SA: mariadb-NAME<br/>3306/TCP MySQL<br/>TLS 1.2+ optional<br/>Secret: ds-pipeline-db-NAME"]
            Minio["Minio S3<br/>9000/TCP HTTP<br/>TLS 1.2+ optional<br/>Secret: ds-pipeline-s3-NAME"]
            MLMD["ML Metadata<br/>Envoy: 9090/TCP gRPC TLS1.2+<br/>metadata-grpc: 8080/TCP gRPC<br/>SA: metadata-writer"]
        end

        subgraph Runtime["Pipeline Execution"]
            K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.3<br/>ServiceAccount Token"]
            PipelinePod["Pipeline Pod<br/>SA: pipeline-runner-NAME"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        ExternalS3["External S3 Storage<br/>AWS/Compatible<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access Keys"]
        ExternalDB["External MySQL/MariaDB<br/>3306/TCP MySQL<br/>TLS 1.2+ optional<br/>Username/Password"]
        ContainerRegistry["Container Registries<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secret Token"]
    end

    subgraph ControlPlane["CONTROL PLANE Namespace operator-ns"]
        Controller["DSPO Controller Manager<br/>SA: controller-manager<br/>ClusterRole: manager-role"]
        Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth"]
        Health["Health Endpoints<br/>/healthz, /readyz<br/>8081/TCP HTTP"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| RouteAPI
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| RouteUI
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| RouteMLMD

    %% Ingress to OAuth Proxy
    RouteAPI -->|HTTPS/8443<br/>TLS 1.2+<br/>Reencrypt| OAuthAPI
    RouteUI -->|HTTPS/8443<br/>TLS 1.2+<br/>Reencrypt| OAuthUI
    RouteMLMD -->|HTTPS/8443<br/>TLS 1.2+<br/>Reencrypt| OAuthMLMD

    %% OAuth to Services
    OAuthAPI -->|HTTP/8888<br/>Internal<br/>OAuth Validated| APIServer
    OAuthUI -->|HTTP/8080<br/>Internal<br/>OAuth Validated| UI
    OAuthMLMD -->|gRPC/9090<br/>TLS 1.2+<br/>OAuth Validated| MLMD

    %% API Server interactions
    APIServer -->|MySQL/3306<br/>TLS 1.2+ opt<br/>Password Auth| MariaDB
    APIServer -->|gRPC/8887<br/>TLS 1.2+<br/>mTLS| WorkflowController
    APIServer -->|HTTP/9000<br/>Access Key/Secret| Minio
    APIServer -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Keys| ExternalS3
    APIServer -.->|MySQL/3306<br/>TLS 1.2+<br/>Password| ExternalDB

    %% Persistence Agent
    PersistenceAgent -->|MySQL/3306<br/>TLS 1.2+ opt<br/>Password Auth| MariaDB

    %% Workflow Controller
    WorkflowController -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    K8sAPI -->|Pod Creation| PipelinePod

    %% Pipeline Pod interactions
    PipelinePod -->|HTTP/9000 or HTTPS/443<br/>Access Key/Secret| Minio
    PipelinePod -.->|HTTPS/443<br/>AWS IAM / Keys| ExternalS3
    PipelinePod -->|gRPC/9090<br/>TLS 1.2+<br/>mTLS| MLMD
    PipelinePod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| ContainerRegistry

    %% MLMD to Database
    MLMD -->|MySQL/3306<br/>TLS 1.2+ opt<br/>Password Auth| MariaDB

    %% Controller Plane
    Controller -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token<br/>ClusterRole: manager-role| K8sAPI
    Metrics -.->|Scraped by| Prometheus[Prometheus<br/>ServiceMonitor]

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef oauth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class RouteAPI,RouteUI,RouteMLMD ingress
    class OAuthAPI,OAuthUI,OAuthMLMD oauth
    class APIServer,PersistenceAgent,WorkflowController,UI,PipelinePod service
    class MariaDB,Minio,MLMD,K8sAPI data
    class ExternalS3,ExternalDB,ContainerRegistry externalservice
    class Controller,Metrics,Health,Prometheus controlplane
