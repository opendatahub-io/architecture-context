graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>ServiceAccount<br/>Namespace: odh-dashboard]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>RoleBinding<br/>Namespace: kube-system]
        CRB3[odh-dashboard-cluster-monitoring<br/>RoleBinding<br/>Namespace: openshift-monitoring]
        CRB4[odh-dashboard-image-puller<br/>RoleBinding<br/>Namespace: openshift]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]
        CR_AuthDelegator[system:auth-delegator<br/>ClusterRole]
        CR_Monitoring[cluster-monitoring-view<br/>ClusterRole]
        CR_ImagePuller[odh-dashboard-image-puller<br/>ClusterRole]
    end

    subgraph "Core Resources"
        Nodes[nodes<br/>get, list]
        ConfigMaps[configmaps<br/>create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>create, delete, get, list, patch, update, watch]
        PVCs[persistentvolumeclaims<br/>create, delete, get, list, patch, update, watch]
        Namespaces[namespaces<br/>get, list, watch, create, update, patch, delete]
        Pods[pods<br/>get, list, watch]
        Services[services<br/>get, list, watch]
        ServiceAccounts[serviceaccounts<br/>get, list, watch]
    end

    subgraph "OpenShift Resources"
        ClusterVersions[clusterversions<br/>config.openshift.io<br/>get, watch, list]
        Routes[routes<br/>route.openshift.io<br/>get, list, watch]
        ConsoleLinks[consolelinks<br/>console.openshift.io<br/>get, list, watch]
        ImageStreams[imagestreams/layers<br/>image.openshift.io<br/>get]
        MachineAutoscalers[machineautoscalers, machinesets<br/>machine.openshift.io<br/>get, list]
        Users[users, groups<br/>user.openshift.io<br/>get, list, watch]
    end

    subgraph "RBAC Resources"
        RoleBindings[rolebindings, clusterrolebindings<br/>rbac.authorization.k8s.io<br/>get, list, watch, create, update, patch, delete]
        Roles[roles<br/>rbac.authorization.k8s.io<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "ODH/Kubeflow Resources"
        Notebooks_CR[notebooks<br/>kubeflow.org<br/>get, list, watch, create, update, patch, delete]
        DataScienceClusters[datascienceclusters<br/>datasciencecluster.opendatahub.io<br/>list, watch, get]
        DSCInit[dscinitializations<br/>dscinitialization.opendatahub.io<br/>list, watch, get]
        ModelRegistries[modelregistries<br/>modelregistry.opendatahub.io<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "Operator Resources"
        CSVs[clusterserviceversions, subscriptions<br/>operators.coreos.com<br/>get, list, watch]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4

    CRB1 -->|grants| CR
    CRB2 -->|grants| CR_AuthDelegator
    CRB3 -->|grants| CR_Monitoring
    CRB4 -->|grants| CR_ImagePuller

    %% ClusterRole Permissions
    CR -->|permissions| Nodes
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Secrets
    CR -->|permissions| PVCs
    CR -->|permissions| Namespaces
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| ClusterVersions
    CR -->|permissions| Routes
    CR -->|permissions| ConsoleLinks
    CR -->|permissions| ImageStreams
    CR -->|permissions| MachineAutoscalers
    CR -->|permissions| Users
    CR -->|permissions| RoleBindings
    CR -->|permissions| Roles
    CR -->|permissions| Notebooks_CR
    CR -->|permissions| DataScienceClusters
    CR -->|permissions| DSCInit
    CR -->|permissions| ModelRegistries
    CR -->|permissions| CSVs

    CR_AuthDelegator -->|delegates| TokenReviews[tokenreviews, subjectaccessreviews<br/>authorization.k8s.io<br/>create]
    CR_Monitoring -->|queries| Prometheus[Prometheus/Thanos<br/>openshift-monitoring<br/>namespace: get]
    CR_ImagePuller -->|pulls| ImagePull[imagestreams, imagestreamtags<br/>image.openshift.io<br/>get]

