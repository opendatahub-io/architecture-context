graph TB
    subgraph "TrustyAI Service Operator"
        Controller[TrustyAIServiceReconciler<br/>Controller]
        PVCMgr[PVC Manager]
        RouteMgr[Route Manager]
        SMgrMgr[ServiceMonitor Manager]
        ISIntegrator[InferenceService Integrator]

        Controller -->|manages| PVCMgr
        Controller -->|manages| RouteMgr
        Controller -->|manages| SMgrMgr
        Controller -->|manages| ISIntegrator
    end

    subgraph "Managed TrustyAI Service Instance"
        Deployment[TrustyAI Service<br/>Deployment]
        OAuthProxy[OAuth Proxy<br/>Sidecar]
        PVC[Persistent Volume<br/>Claim]
        Service[ClusterIP Service]
        Route[OpenShift Route]
        SM[ServiceMonitor]

        Deployment -->|includes| OAuthProxy
        Deployment -->|mounts| PVC
        Service -->|routes to| Deployment
        Route -->|exposes| Service
    end

    subgraph "Custom Resources"
        TrustyAICR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API]
        PrometheusOp[Prometheus Operator]
        ServiceCA[OpenShift Service CA]
        OAuthServer[OpenShift OAuth]
    end

    subgraph "Integration Points"
        KServeIS[KServe<br/>InferenceService CRs]
        ModelMesh[ModelMesh<br/>Deployments]
        Prometheus[Prometheus]
    end

    %% User interactions
    User[User/ODH Dashboard] -->|creates| TrustyAICR
    TrustyAICR -->|watched by| Controller

    %% Operator creates resources
    Controller -->|creates| Deployment
    Controller -->|creates| Service
    Controller -->|creates| Route
    Controller -->|creates| PVC
    Controller -->|creates| SM

    %% Operator integrations
    Controller -->|patches| KServeIS
    Controller -->|configures env| ModelMesh
    ISIntegrator -->|patches| KServeIS

    %% External dependencies
    Controller -->|API calls| K8sAPI
    SM -->|enables scraping| Prometheus
    ServiceCA -->|provisions certs| Deployment
    OAuthProxy -->|authenticates via| OAuthServer

    %% Prometheus integration
    Prometheus -->|scrapes metrics| Deployment
    Prometheus -->|scrapes metrics| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAICR fill:#f5a623,stroke:#333,stroke-width:2px
    style Deployment fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style PrometheusOp fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ServiceCA fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OAuthServer fill:#e8e8e8,stroke:#333,stroke-width:2px
    style KServeIS fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px
