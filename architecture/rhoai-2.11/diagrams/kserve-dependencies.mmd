graph LR
    KServe["KServe Operator<br/>v0.12.1"]

    %% External Dependencies (Required)
    KServe -->|"traffic routing<br/>VirtualServices<br/>mTLS"| Istio["Istio 1.19.4<br/>REQUIRED"]
    KServe -->|"serverless autoscaling<br/>Knative Services<br/>scale-to-zero"| Knative["Knative Serving 0.39.3<br/>REQUIRED"]
    KServe -->|"TLS certificates<br/>webhook certs<br/>auto-rotation"| CertManager["cert-manager<br/>REQUIRED"]
    KServe -->|"container orchestration<br/>CRDs, Deployments<br/>Services"| K8s["Kubernetes 1.25+<br/>REQUIRED"]

    %% External Dependencies (Optional)
    KServe -.->|"metrics collection<br/>scrapes /metrics"| Prometheus["Prometheus<br/>OPTIONAL"]

    %% Internal ODH/RHOAI Dependencies
    KServe -->|"VirtualService CRD<br/>creates routing rules<br/>canary deployments"| ServiceMesh["Service Mesh (Istio)<br/>INTERNAL ODH"]
    KServe -.->|"model metadata<br/>artifact references<br/>API calls"| ModelRegistry["Model Registry<br/>INTERNAL ODH"]
    KServe -->|"inference metrics<br/>latency, throughput<br/>Prometheus API"| Monitoring["Monitoring<br/>INTERNAL ODH"]

    %% External Services
    KServe -->|"S3 API<br/>model downloads<br/>AWS IAM/Access Keys"| S3["S3 Storage<br/>EXTERNAL SERVICE"]
    KServe -.->|"GCS API<br/>model downloads<br/>GCP Service Account"| GCS["GCS Storage<br/>EXTERNAL SERVICE"]
    KServe -.->|"Azure API<br/>model downloads<br/>Azure credentials"| Azure["Azure Blob Storage<br/>EXTERNAL SERVICE"]

    %% Integration Points (Components that use KServe)
    Dashboard["ODH Dashboard<br/>INTERNAL ODH"] -->|"UI for InferenceService<br/>create/manage/monitor"| KServe
    Pipelines["Data Science Pipelines<br/>INTERNAL ODH"] -.->|"auto-deploy models<br/>from pipeline outputs"| KServe
    Notebooks["Notebooks<br/>INTERNAL ODH"] -.->|"deploy models<br/>from Jupyter"| KServe

    %% Component Breakdown
    subgraph "KServe Components"
        direction TB
        Controller["kserve-controller-manager<br/>Go Operator"]
        Webhook["kserve-webhook-server<br/>Go Webhook"]
        Agent["kserve-agent<br/>Go Sidecar"]
        Router["kserve-router<br/>Go Router"]
        StorageInit["storage-initializer<br/>Python Init Container"]
        ModelServers["Model Servers<br/>Python (sklearn/xgboost/lgb)"]

        Controller -->|manages| ModelServers
        Webhook -->|validates| Controller
        StorageInit -->|initializes| ModelServers
        Agent -.->|enhances| ModelServers
        Router -->|routes to| ModelServers
    end

    KServe -.-> Controller

