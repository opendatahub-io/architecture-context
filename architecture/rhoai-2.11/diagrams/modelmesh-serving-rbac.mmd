graph TD
    subgraph "Service Accounts"
        SA1[modelmesh-controller<br/>Namespace: modelmesh-serving]
        SA2[modelmesh-serving<br/>Namespace: user namespaces]
    end

    subgraph "ClusterRole Bindings"
        CRB1[modelmesh-controller-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[restricted-scc-rolebinding]
    end

    subgraph "ClusterRole Permissions"
        CR1[modelmesh-controller-role]
        CR2[leader-election-role]
        CR3[restricted-scc-role]
    end

    subgraph "Core Resources"
        direction LR
        ConfigMaps[configmaps<br/>create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>create, delete, get, list, patch, update, watch]
        Services[services, services/finalizers<br/>create, delete, get, list, patch, update, watch]
        Namespaces[namespaces, namespaces/finalizers<br/>get, list, patch, update, watch]
        Endpoints[endpoints, persistentvolumeclaims<br/>get, list, watch]
    end

    subgraph "Apps Resources"
        Deployments[deployments, deployments/finalizers<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "KServe CRDs (serving.kserve.io)"
        direction TB
        InferenceServices[inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status<br/>create, delete, get, list, patch, update, watch]
        Predictors[predictors<br/>predictors/finalizers<br/>predictors/status<br/>create, delete, get, list, patch, update, watch]
        ServingRuntimes[servingruntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status<br/>create, delete, get, list, patch, update, watch]
        ClusterServingRuntimes[clusterservingruntimes<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Autoscaling Resources"
        HPAs[horizontalpodautoscalers<br/>horizontalpodautoscalers/status<br/>create, delete, get, list, watch, update]
    end

    subgraph "Monitoring Resources"
        ServiceMonitors[servicemonitors<br/>monitoring.coreos.com<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Coordination Resources"
        Leases[leases<br/>coordination.k8s.io<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account to Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| CRB3

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% modelmesh-controller-role permissions
    CR1 -->|full CRUD| ConfigMaps
    CR1 -->|full CRUD| Secrets
    CR1 -->|full CRUD| Services
    CR1 -->|read & update| Namespaces
    CR1 -->|read only| Endpoints
    CR1 -->|full CRUD| Deployments
    CR1 -->|full CRUD| InferenceServices
    CR1 -->|full CRUD| Predictors
    CR1 -->|full CRUD| ServingRuntimes
    CR1 -->|full CRUD| ClusterServingRuntimes
    CR1 -->|full CRUD| HPAs
    CR1 -->|full CRUD| ServiceMonitors

    %% leader-election-role permissions
    CR2 -->|leader election| ConfigMaps
    CR2 -->|leader election| Leases

    %% Annotations
    Note1[Purpose: Main controller<br/>managing ModelMesh lifecycle]
    Note2[Purpose: Leader election<br/>for HA deployments]
    Note3[Purpose: Runtime pod<br/>security constraints]

    Note1 -.->|describes| CR1
    Note2 -.->|describes| CR2
    Note3 -.->|describes| CR3

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB3 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style InferenceServices fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Predictors fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ClusterServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ConfigMaps fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Secrets fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Services fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Namespaces fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Endpoints fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Deployments fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style HPAs fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style ServiceMonitors fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Leases fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style Note1 fill:#fff9e6,stroke:#f5a623,stroke-width:1px,stroke-dasharray: 5 5,color:#000
    style Note2 fill:#fff9e6,stroke:#f5a623,stroke-width:1px,stroke-dasharray: 5 5,color:#000
    style Note3 fill:#fff9e6,stroke:#f5a623,stroke-width:1px,stroke-dasharray: 5 5,color:#000
