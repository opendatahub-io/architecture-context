graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: model-registry-operator-system]
        SA_Registry["{registry-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_AuthProxy[auth-proxy-client-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (Operator Namespace)"
        RB_Leader[leader-election-rolebinding<br/>RoleBinding]
        RB_AuthProxy[auth-proxy-rolebinding<br/>RoleBinding]
    end

    subgraph "Role Bindings (User Namespace)"
        RB_RegistryUser["registry-user-{registry-name}-binding<br/>RoleBinding<br/>Binds users/groups to registry access"]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_AuthProxy[auth-proxy-client-clusterrole<br/>ClusterRole]
    end

    subgraph "Role Permissions (Operator Namespace)"
        R_Leader[leader-election-role<br/>Role]
        R_AuthProxy[auth-proxy-role<br/>Role]
    end

    subgraph "Role Permissions (User Namespace)"
        R_RegistryUser["registry-user-{registry-name}<br/>Role<br/>GET on services"]
    end

    subgraph "API Resources - Core"
        API_Deployments["apps/Deployments<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_Services["Services<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_SA["ServiceAccounts<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_Pods["Pods, Pods/log<br/>get, list, watch"]
        API_Events["Events<br/>create, patch"]
    end

    subgraph "API Resources - CRDs"
        API_ModelRegistry["modelregistry.opendatahub.io/<br/>ModelRegistries<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_MR_Status["modelregistry.opendatahub.io/<br/>ModelRegistries/status<br/>get, patch, update"]
        API_MR_Finalizers["modelregistry.opendatahub.io/<br/>ModelRegistries/finalizers<br/>update"]
    end

    subgraph "API Resources - Istio"
        API_Istio_Net["networking.istio.io/<br/>Gateways, VirtualServices,<br/>DestinationRules<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_Istio_Sec["security.istio.io/<br/>AuthorizationPolicies<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Authorino"
        API_Authorino["authorino.kuadrant.io/<br/>AuthConfigs<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - RBAC"
        API_RBAC["rbac.authorization.k8s.io/<br/>Roles, RoleBindings<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - OpenShift"
        API_Routes["route.openshift.io/<br/>Routes, Routes/custom-host<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_Groups["user.openshift.io/<br/>Groups<br/>create, delete, get, list,<br/>patch, update, watch"]
        API_Ingresses["config.openshift.io/<br/>Ingresses<br/>get, list, watch"]
    end

    subgraph "API Resources - Auth Proxy"
        API_TokenReview["authentication.k8s.io/<br/>TokenReviews<br/>create"]
        API_SAR["authorization.k8s.io/<br/>SubjectAccessReviews<br/>create"]
    end

    subgraph "API Resources - Leader Election"
        API_ConfigMaps["ConfigMaps<br/>get, list, watch,<br/>create, update, patch, delete"]
        API_Leases["coordination.k8s.io/Leases<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph "API Resources - Registry User Access"
        API_Service_Get["Services<br/>get<br/>(for {registry-name})"]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_AuthProxy
    SA_Controller -->|bound via| RB_Leader
    SA_Controller -->|bound via| RB_AuthProxy

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_Leader -->|grants| R_Leader
    RB_AuthProxy -->|grants| R_AuthProxy
    RB_RegistryUser -->|grants| R_RegistryUser

    %% Manager Role to Resources
    CR_Manager -->|permissions| API_Deployments
    CR_Manager -->|permissions| API_Services
    CR_Manager -->|permissions| API_SA
    CR_Manager -->|permissions| API_Pods
    CR_Manager -->|permissions| API_Events
    CR_Manager -->|permissions| API_ModelRegistry
    CR_Manager -->|permissions| API_MR_Status
    CR_Manager -->|permissions| API_MR_Finalizers
    CR_Manager -->|permissions| API_Istio_Net
    CR_Manager -->|permissions| API_Istio_Sec
    CR_Manager -->|permissions| API_Authorino
    CR_Manager -->|permissions| API_RBAC
    CR_Manager -->|permissions| API_Routes
    CR_Manager -->|permissions| API_Groups
    CR_Manager -->|permissions| API_Ingresses

    %% Auth Proxy Role to Resources
    CR_AuthProxy -->|permissions| API_TokenReview
    CR_AuthProxy -->|permissions| API_SAR

    %% Leader Election Role to Resources
    R_Leader -->|permissions| API_ConfigMaps
    R_Leader -->|permissions| API_Leases
    R_Leader -->|permissions| API_Events

    %% Auth Proxy Role (namespace) to Resources
    R_AuthProxy -->|permissions| API_ConfigMaps

    %% Registry User Role to Resources
    R_RegistryUser -->|permissions| API_Service_Get

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#7ed321,stroke:#333,stroke-width:1px

    class SA_Controller,SA_Registry sa
    class CRB_Manager,CRB_AuthProxy,RB_Leader,RB_AuthProxy,RB_RegistryUser binding
    class CR_Manager,CR_AuthProxy,R_Leader,R_AuthProxy,R_RegistryUser role
    class API_Deployments,API_Services,API_SA,API_Pods,API_Events,API_ModelRegistry,API_MR_Status,API_MR_Finalizers,API_Istio_Net,API_Istio_Sec,API_Authorino,API_RBAC,API_Routes,API_Groups,API_Ingresses,API_TokenReview,API_SAR,API_ConfigMaps,API_Leases,API_Service_Get resource
