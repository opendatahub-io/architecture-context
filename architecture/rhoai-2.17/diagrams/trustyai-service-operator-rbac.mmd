graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: redhat-ods-applications]
        SA_Proxy["{name}-proxy<br/>Namespace: {user-namespace}<br/>(per TrustyAIService)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Leader[leader-election-rolebinding<br/>RoleBinding]
        CRB_Auth[auth-proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Leader[leader-election-role]
        CR_Auth[auth-proxy-role]
        CR_View[view<br/>Built-in ClusterRole]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[ConfigMaps<br/>create, delete, get, list, patch, update, watch]
        Core_PVC[PersistentVolumeClaims<br/>create, delete, get, list, patch, update, watch]
        Core_Pods[Pods<br/>create, delete, get, list, patch, update, watch]
        Core_PodsExec[Pods/exec<br/>create, delete, get, list, watch]
        Core_Secrets[Secrets<br/>create, delete, get, list, patch, update, watch]
        Core_Services[Services<br/>create, delete, get, list, patch, update, watch]
        Core_SA[ServiceAccounts<br/>create, delete, get, list, patch, update, watch]
        Core_Events[Events<br/>create, patch, update, watch]
        Core_PV[PersistentVolumes<br/>get, list, watch]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[Deployments<br/>create, delete, get, list, patch, update, watch]
        Apps_DeploymentsFinalizers[Deployments/finalizers<br/>get, patch, update]
        Apps_DeploymentsStatus[Deployments/status<br/>get, patch, update]
    end

    subgraph "API Resources - KServe"
        KServe_IS[InferenceServices<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_ISFinalizers[InferenceServices/finalizers<br/>delete, get, list, patch, update, watch]
        KServe_SR[ServingRuntimes<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_SM[ServiceMonitors<br/>monitoring.coreos.com<br/>create, list, watch]
    end

    subgraph "API Resources - Istio"
        Istio_DR[DestinationRules<br/>networking.istio.io<br/>create, delete, get, list, patch, update, watch]
        Istio_VS[VirtualServices<br/>networking.istio.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - OpenShift"
        Route_Route[Routes<br/>route.openshift.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Kueue"
        Kueue_Workloads[Workloads<br/>kueue.x-k8s.io<br/>create, delete, get, list, patch, update, watch]
        Kueue_RF[ResourceFlavors<br/>kueue.x-k8s.io<br/>create, delete, get, list, patch, update, watch]
        Kueue_WPC[WorkloadPriorityClasses<br/>kueue.x-k8s.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - TrustyAI CRDs"
        TrustyAI_Service[TrustyAIServices<br/>trustyai.opendatahub.io<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_ServiceStatus[TrustyAIServices/status<br/>get, patch, update]
        TrustyAI_ServiceFinalizers[TrustyAIServices/finalizers<br/>get, patch, update]
        TrustyAI_LMEval[LMEvalJobs<br/>trustyai.opendatahub.io<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_LMEvalStatus[LMEvalJobs/status<br/>get, patch, update]
        TrustyAI_LMEvalFinalizers[LMEvalJobs/finalizers<br/>get, patch, update]
    end

    subgraph "API Resources - RBAC"
        RBAC_CRB[ClusterRoleBindings<br/>rbac.authorization.k8s.io<br/>create, delete, get, list, update, watch]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[Leases<br/>coordination.k8s.io<br/>create, get, update, list, watch, delete]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReview[TokenReviews<br/>authentication.k8s.io<br/>create]
        Auth_SAR[SubjectAccessReviews<br/>authorization.k8s.io<br/>create]
    end

    %% Service Account to ClusterRole Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Leader
    SA_Controller -->|bound via| CRB_Auth
    SA_Proxy -.->|bound via RoleBinding| CR_View

    %% ClusterRole Bindings to ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Auth -->|grants| CR_Auth

    %% manager-role permissions
    CR_Manager -->|full CRUD| Core_ConfigMaps
    CR_Manager -->|full CRUD| Core_PVC
    CR_Manager -->|full CRUD| Core_Pods
    CR_Manager -->|exec access| Core_PodsExec
    CR_Manager -->|full CRUD| Core_Secrets
    CR_Manager -->|full CRUD| Core_Services
    CR_Manager -->|full CRUD| Core_SA
    CR_Manager -->|create/patch| Core_Events
    CR_Manager -->|read-only| Core_PV
    CR_Manager -->|full CRUD| Apps_Deployments
    CR_Manager -->|update| Apps_DeploymentsFinalizers
    CR_Manager -->|update| Apps_DeploymentsStatus
    CR_Manager -->|full CRUD| KServe_IS
    CR_Manager -->|manage| KServe_ISFinalizers
    CR_Manager -->|full CRUD| KServe_SR
    CR_Manager -->|create/list/watch| Monitoring_SM
    CR_Manager -->|full CRUD| Istio_DR
    CR_Manager -->|full CRUD| Istio_VS
    CR_Manager -->|full CRUD| Route_Route
    CR_Manager -->|full CRUD| Kueue_Workloads
    CR_Manager -->|full CRUD| Kueue_RF
    CR_Manager -->|full CRUD| Kueue_WPC
    CR_Manager -->|full CRUD| TrustyAI_Service
    CR_Manager -->|update status| TrustyAI_ServiceStatus
    CR_Manager -->|manage finalizers| TrustyAI_ServiceFinalizers
    CR_Manager -->|full CRUD| TrustyAI_LMEval
    CR_Manager -->|update status| TrustyAI_LMEvalStatus
    CR_Manager -->|manage finalizers| TrustyAI_LMEvalFinalizers
    CR_Manager -->|manage| RBAC_CRB
    CR_Manager -->|leader election| Coord_Leases

    %% leader-election-role permissions
    CR_Leader -->|manage| Core_ConfigMaps
    CR_Leader -->|manage| Coord_Leases
    CR_Leader -->|create/patch| Core_Events

    %% auth-proxy-role permissions
    CR_Auth -->|create| Auth_TokenReview
    CR_Auth -->|create| Auth_SAR

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Proxy fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#000
    style CR_Leader fill:#f5a623,stroke:#333,color:#000
    style CR_Auth fill:#f5a623,stroke:#333,color:#000
    style CR_View fill:#f5a623,stroke:#333,color:#000
    style CRB_Manager fill:#bd10e0,stroke:#333,color:#fff
    style CRB_Leader fill:#bd10e0,stroke:#333,color:#fff
    style CRB_Auth fill:#bd10e0,stroke:#333,color:#fff

    style TrustyAI_Service fill:#7ed321,stroke:#333,color:#000
    style TrustyAI_ServiceStatus fill:#7ed321,stroke:#333,color:#000
    style TrustyAI_ServiceFinalizers fill:#7ed321,stroke:#333,color:#000
    style TrustyAI_LMEval fill:#7ed321,stroke:#333,color:#000
    style TrustyAI_LMEvalStatus fill:#7ed321,stroke:#333,color:#000
    style TrustyAI_LMEvalFinalizers fill:#7ed321,stroke:#333,color:#000

    style KServe_IS fill:#50e3c2,stroke:#333,color:#000
    style KServe_ISFinalizers fill:#50e3c2,stroke:#333,color:#000
    style KServe_SR fill:#50e3c2,stroke:#333,color:#000
