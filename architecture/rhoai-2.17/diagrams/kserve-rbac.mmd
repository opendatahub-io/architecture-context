graph TD
    subgraph "Service Accounts"
        SA_Manager[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kserve-manager-rolebinding<br/>Scope: Cluster-wide]
        CRB_Leader[kserve-leader-election-rolebinding<br/>Scope: kserve namespace]
        CRB_Proxy[kserve-proxy-rolebinding<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRoles"
        CR_Manager[kserve-manager-role<br/>Full CRD management]
        CR_Leader[kserve-leader-election-role<br/>Leader election]
        CR_Proxy[kserve-proxy-role<br/>Token/Access reviews]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[configmaps<br/>create, get, update]
        Core_Events[events<br/>create, delete, get, list, patch, update, watch]
        Core_Services[services<br/>create, delete, get, list, patch, update, watch]
        Core_Namespaces[namespaces<br/>get, list, watch]
        Core_Pods[pods<br/>get, list, watch]
        Core_Secrets[secrets<br/>get]
        Core_SA[serviceaccounts<br/>get]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[deployments<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Autoscaling"
        Autoscaling_HPA[horizontalpodautoscalers<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Networking"
        Network_Ingresses[ingresses<br/>networking.k8s.io<br/>create, delete, get, list, patch, update, watch]
        Network_VS[virtualservices<br/>networking.istio.io<br/>create, delete, get, list, patch, update, watch]
        Network_Routes[routes<br/>route.openshift.io<br/>get, list, watch]
    end

    subgraph "API Resources - Knative"
        Knative_Services[services<br/>serving.knative.dev<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - KServe CRDs"
        KServe_IS[inferenceservices<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_IG[inferencegraphs<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_SR[servingruntimes<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_CSR[clusterservingruntimes<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_TM[trainedmodels<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
        KServe_CLM[clusterlocalmodels<br/>serving.kserve.io<br/>get, list]
        KServe_CSC[clusterstoragecontainers<br/>serving.kserve.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Admission"
        Admission_MWC[mutatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>create, delete, get, list, patch, update, watch]
        Admission_VWC[validatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[leases<br/>coordination.k8s.io<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReviews[tokenreviews<br/>authentication.k8s.io<br/>create]
        Auth_SAR[subjectaccessreviews<br/>authorization.k8s.io<br/>create]
    end

    %% Service Account to ClusterRoleBindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Leader
    SA_Manager -->|bound via| CRB_Proxy

    %% ClusterRoleBindings to ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Proxy -->|grants| CR_Proxy

    %% ClusterRole to Resources - Manager Role
    CR_Manager -->|permissions| Core_ConfigMaps
    CR_Manager -->|permissions| Core_Events
    CR_Manager -->|permissions| Core_Services
    CR_Manager -->|permissions| Core_Namespaces
    CR_Manager -->|permissions| Core_Pods
    CR_Manager -->|permissions| Core_Secrets
    CR_Manager -->|permissions| Core_SA
    CR_Manager -->|permissions| Apps_Deployments
    CR_Manager -->|permissions| Autoscaling_HPA
    CR_Manager -->|permissions| Network_Ingresses
    CR_Manager -->|permissions| Network_VS
    CR_Manager -->|permissions| Network_Routes
    CR_Manager -->|permissions| Knative_Services
    CR_Manager -->|permissions| KServe_IS
    CR_Manager -->|permissions| KServe_IG
    CR_Manager -->|permissions| KServe_SR
    CR_Manager -->|permissions| KServe_CSR
    CR_Manager -->|permissions| KServe_TM
    CR_Manager -->|permissions| KServe_CLM
    CR_Manager -->|permissions| KServe_CSC
    CR_Manager -->|permissions| Admission_MWC
    CR_Manager -->|permissions| Admission_VWC

    %% ClusterRole to Resources - Leader Election Role
    CR_Leader -->|permissions| Core_ConfigMaps
    CR_Leader -->|permissions| Core_Events
    CR_Leader -->|permissions| Coord_Leases

    %% ClusterRole to Resources - Proxy Role
    CR_Proxy -->|permissions| Auth_TokenReviews
    CR_Proxy -->|permissions| Auth_SAR

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Leader fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Proxy fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style CR_Leader fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style CR_Proxy fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServe_IS fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style KServe_IG fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style KServe_SR fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style KServe_CSR fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style KServe_TM fill:#d5e8d4,stroke:#82b366,stroke-width:2px
