graph TB
    subgraph "RHOAI 2.17 Platform"
        subgraph "Platform Orchestration"
            RHODS[rhods-operator<br/>Central Platform Orchestrator<br/>DataScienceCluster CRD]
        end

        subgraph "User Interface & Management"
            Dashboard[odh-dashboard<br/>React/Node.js Web UI<br/>2 replicas]
        end

        subgraph "Development Environments"
            NotebookController[odh-notebook-controller<br/>Extends Kubeflow Notebooks<br/>OAuth, Routes, Network Policies]
            WorkbenchImages[Workbench Images<br/>Jupyter, RStudio, Code Server<br/>PyTorch, TensorFlow, CUDA]
        end

        subgraph "Model Serving"
            KServe[kserve<br/>Serverless Model Serving<br/>Multi-framework Support]
            ModelMesh[modelmesh-serving<br/>Multi-model Serving<br/>Intelligent Placement]
            ModelController[odh-model-controller<br/>OpenShift Integration<br/>Routes, Istio, Authorino]
        end

        subgraph "ML Pipelines & Registry"
            DSPOperator[data-science-pipelines-operator<br/>Kubeflow Pipelines v2<br/>Argo Workflows Backend]
            ModelRegistry[model-registry-operator<br/>Model Metadata & Lineage<br/>PostgreSQL/MySQL Backend]
        end

        subgraph "Distributed Computing"
            KubeRay[kuberay<br/>Ray Cluster Lifecycle<br/>RayCluster, RayJob, RayService]
            CodeFlare[codeflare-operator<br/>Ray Security<br/>OAuth, mTLS, NetworkPolicy]
            Kueue[kueue<br/>Job Queueing<br/>Fair Sharing & Preemption]
        end

        subgraph "Training & AI Trust"
            TrainingOperator[training-operator<br/>Distributed Training<br/>PyTorch, TensorFlow, MPI]
            TrustyAI[trustyai-service-operator<br/>AI Explainability<br/>Fairness Metrics]
        end
    end

    subgraph "OpenShift Services"
        Istio[Istio Service Mesh<br/>mTLS, Traffic Management]
        Authorino[Authorino<br/>Authentication/Authorization]
        OAuth[OpenShift OAuth<br/>User Authentication]
        Prometheus[Prometheus<br/>Monitoring & Metrics]
        Knative[Knative Serving<br/>Serverless Autoscaling]
    end

    subgraph "External Services"
        S3[S3-compatible Storage<br/>Model Artifacts]
        DB[PostgreSQL/MySQL<br/>Metadata Storage]
        Registry[Container Registries<br/>registry.redhat.io]
    end

    %% Platform orchestration
    RHODS -->|manages lifecycle| Dashboard
    RHODS -->|manages lifecycle| NotebookController
    RHODS -->|manages lifecycle| KServe
    RHODS -->|manages lifecycle| ModelMesh
    RHODS -->|manages lifecycle| ModelController
    RHODS -->|manages lifecycle| DSPOperator
    RHODS -->|manages lifecycle| ModelRegistry
    RHODS -->|manages lifecycle| KubeRay
    RHODS -->|manages lifecycle| CodeFlare
    RHODS -->|manages lifecycle| Kueue
    RHODS -->|manages lifecycle| TrainingOperator
    RHODS -->|manages lifecycle| TrustyAI

    %% Dashboard integrations
    Dashboard -->|API calls| NotebookController
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| ModelRegistry
    Dashboard -->|API calls| DSPOperator
    Dashboard -->|metrics queries| Prometheus

    %% Model serving integrations
    KServe -->|serverless| Knative
    KServe -->|traffic mgmt| Istio
    KServe -->|extended by| ModelController
    KServe -->|model metadata| ModelRegistry
    ModelController -->|creates| Istio
    ModelController -->|creates| Authorino
    ModelMesh -->|uses CRDs| KServe
    ModelMesh -->|coordination| etcd[etcd<br/>Distributed State]

    %% Distributed computing
    CodeFlare -->|watches| KubeRay
    CodeFlare -->|workload scheduling| Kueue
    CodeFlare -->|auth| OAuth
    Kueue -->|queues| TrainingOperator
    Kueue -->|queues| KubeRay

    %% ML pipelines
    DSPOperator -->|executes via| ArgoWorkflows[Argo Workflows<br/>Pipeline Backend]
    DSPOperator -->|optional deploy| KServe
    DSPOperator -->|optional storage| ModelRegistry

    %% Model registry
    ModelRegistry -->|storage| DB
    ModelRegistry -->|gateway| Istio
    ModelRegistry -->|auth| Authorino

    %% AI Trust
    TrustyAI -->|monitors| KServe
    TrustyAI -->|monitors| ModelMesh
    TrustyAI -->|metrics| Prometheus
    TrustyAI -->|queue| Kueue

    %% Workbenches
    NotebookController -->|creates| WorkbenchImages
    WorkbenchImages -->|saves models| S3

    %% External dependencies
    KServe -->|download models| S3
    ModelMesh -->|download models| S3
    DSPOperator -->|artifacts| S3
    ModelRegistry -->|metadata| DB
    DSPOperator -->|metadata| DB

    %% Authentication
    Dashboard -->|user auth| OAuth
    NotebookController -->|user auth| OAuth
    KServe -->|external auth| Authorino

    %% Pull images
    RHODS -.->|pulls| Registry
    Dashboard -.->|pulls| Registry

