graph LR
    ODHDashboard[ODH Dashboard<br/>Web UI & API]

    subgraph "External Dependencies"
        NodeJS[Node.js >=18.0.0<br/>JavaScript Runtime]
        Fastify[Fastify ^4.28.1<br/>Web Framework]
        React[React ^18.2.0<br/>UI Framework]
        PatternFly[PatternFly ^6.0.0<br/>Design System]
        K8sClient[kubernetes/client-node ^0.12.2<br/>K8s API Client]
        OAuthProxy[oauth-proxy<br/>OpenShift OAuth Sidecar]
    end

    subgraph "Internal ODH Dependencies"
        ODHOperator[opendatahub-operator<br/>Platform Operator]
        NotebookController[kubeflow/notebooks<br/>Notebook Controller]
        KServe[KServe<br/>Model Serving]
        ModelRegistry[Model Registry<br/>Model Versioning]
        ODHModelController[odh-model-controller<br/>Serving Runtime Mgmt]
        NIMOperator[NVIDIA NIM Operator<br/>NIM Accounts]
        GPUOperator[NVIDIA GPU Operator<br/>GPU Availability]
    end

    subgraph "OpenShift/K8s Services"
        K8sAPI[Kubernetes API Server<br/>Resource Management]
        OAuthServer[OpenShift OAuth Server<br/>Authentication]
        ImageRegistry[OpenShift Image Registry<br/>Container Images]
        Monitoring[OpenShift Monitoring<br/>Thanos/Prometheus]
    end

    subgraph "External Services"
        S3[S3 Storage<br/>Model Artifacts]
    end

    %% External Dependencies
    ODHDashboard -->|runtime| NodeJS
    ODHDashboard -->|web server| Fastify
    ODHDashboard -->|UI framework| React
    ODHDashboard -->|UI components| PatternFly
    ODHDashboard -->|K8s API calls| K8sClient
    ODHDashboard -->|authentication| OAuthProxy

    %% Internal ODH Dependencies
    ODHDashboard -->|queries DSC/DSCI| ODHOperator
    ODHDashboard -->|creates/manages| NotebookController
    ODHDashboard -->|queries status| KServe
    ODHDashboard -->|manages registries| ModelRegistry
    ODHDashboard -->|manages runtimes| ODHModelController
    ODHDashboard -->|manages NIM accounts| NIMOperator
    ODHDashboard -->|queries GPU info| GPUOperator

    %% OpenShift/K8s Services
    ODHDashboard -->|resource CRUD| K8sAPI
    OAuthProxy -->|OAuth flow| OAuthServer
    ODHDashboard -->|image metadata| ImageRegistry
    ODHDashboard -->|metrics queries| Monitoring

    %% External Services
    ODHDashboard -.->|indirectly via workloads| S3

    %% Integration Points (reverse dependencies)
    Dashboard2[ODH Dashboard] -->|integrates into| OpenShiftConsole[OpenShift Console<br/>ConsoleLink]
    DSPipelines[Data Science Pipelines] -.->|may interact with| ODHDashboard

