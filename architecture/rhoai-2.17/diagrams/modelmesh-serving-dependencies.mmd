graph LR
    ModelMesh[ModelMesh Serving<br/>Operator]

    %% External Dependencies (Required)
    ModelMesh -->|"state coordination<br/>REQUIRED"| etcd[etcd v3.5.x<br/>StatefulSet<br/>2379/TCP HTTP]
    ModelMesh -->|"model storage<br/>REQUIRED"| S3[S3-compatible Storage<br/>AWS S3/MinIO/IBM COS<br/>443/TCP HTTPS]
    ModelMesh -->|"orchestration<br/>REQUIRED"| K8s[Kubernetes v1.25+<br/>6443/TCP HTTPS]

    %% External Dependencies (Optional)
    ModelMesh -.->|"webhook certs<br/>OPTIONAL"| CertManager[cert-manager v1.x<br/>Auto TLS provisioning]
    ModelMesh -.->|"metrics CRD<br/>OPTIONAL"| PromOperator[Prometheus Operator v0.55+<br/>ServiceMonitor]

    %% Internal ODH/RHOAI Dependencies
    ModelMesh -->|"CRD schema<br/>API definitions"| KServe[KServe<br/>InferenceService/ServingRuntime]
    ModelMesh -.->|"mTLS & traffic mgmt<br/>OPTIONAL"| ServiceMesh[OpenShift Service Mesh<br/>Istio]
    ModelMesh -.->|"metrics federation<br/>OPTIONAL"| Monitoring[OpenShift Monitoring<br/>Prometheus]

    %% ModelMesh Component Dependencies
    ModelMesh -->|"uses container"| ModelMeshCore["kserve/modelmesh v0.11.2<br/>Model router (Java)"]
    ModelMesh -->|"uses container"| RuntimeAdapter["kserve/modelmesh-runtime-adapter v0.11.2<br/>Puller & protocol adapter"]
    ModelMesh -->|"uses container"| RESTProxy["kserve/rest-proxy v0.11.2<br/>REST to gRPC translation"]

    %% Supported Model Server Runtimes (Optional - user chooses)
    ModelMesh -.->|"runtime option"| Triton[Triton Inference Server 2.x<br/>NVIDIA multi-framework]
    ModelMesh -.->|"runtime option"| MLServer[MLServer 1.x<br/>Seldon Python-based]
    ModelMesh -.->|"runtime option"| OVMS[OpenVINO Model Server 1.x<br/>Intel optimized]
    ModelMesh -.->|"runtime option"| TorchServe[TorchServe 0.x<br/>PyTorch native]

    %% Integration Points
    Dashboard[ODH Dashboard] -.->|"UI management"| ModelMesh
    Pipelines[Data Science Pipelines] -.->|"auto-deploy models"| ModelMesh

