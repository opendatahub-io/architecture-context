graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User / ODH Dashboard]
    end

    subgraph Ingress["INGRESS (DMZ) - OpenShift"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt<br/>Auto-generated host"]
    end

    subgraph AppTier["APPLICATION TIER (Namespace: {user-namespace})"]
        direction TB

        subgraph Pod["Pod: {name}-deployment-xxxxx<br/>ServiceAccount: {name}-proxy"]
            direction LR
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS: service-ca cert<br/>Auth: TokenReview"]
            TrustyAIService["TrustyAI Service<br/>8080/TCP HTTP<br/>Metrics: /q/metrics<br/>Health: /q/health/*"]
            OAuthProxy -->|"8080/TCP HTTP<br/>Internal TLS"| TrustyAIService
        end

        Storage["PersistentVolumeClaim<br/>{name}-pvc<br/>ReadWriteOnce<br/>Model data storage"]
    end

    subgraph ClusterLocal["CLUSTER-LOCAL INTEGRATIONS"]
        direction TB

        subgraph InferenceNS["User Namespace"]
            InferenceService["KServe InferenceService<br/>8080/TCP HTTP<br/>Cluster-local"]
        end

        subgraph MonitoringNS["openshift-user-workload-monitoring"]
            Prometheus["Prometheus UWM<br/>Scrapes /q/metrics<br/>HTTP/8080<br/>ServiceMonitor token"]
        end
    end

    subgraph OperatorTier["OPERATOR TIER (Namespace: redhat-ods-applications)"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        Database["Database<br/>MySQL/PostgreSQL<br/>Varies/TCP JDBC<br/>TLS 1.2+ (optional)<br/>Username/Password"]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional - Istio)"]
        VirtualService["VirtualService<br/>{name}-tls<br/>443/TCP"]
        DestinationRule["DestinationRule<br/>TLS Mode: SIMPLE<br/>Port: 443"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token"| Route
    Route -->|"HTTPS/8443<br/>Reencrypt<br/>service-ca cert"| OAuthProxy

    TrustyAIService -->|"Filesystem I/O"| Storage
    TrustyAIService -.->|"JDBC/Varies<br/>TLS optional<br/>Credentials"| Database

    InferenceService -->|"POST /consumer/kserve/v2<br/>HTTP/8080<br/>Inference data"| TrustyAIService
    Prometheus -->|"GET /q/metrics<br/>HTTP/8080<br/>ServiceMonitor token"| TrustyAIService

    Operator -->|"HTTPS/6443<br/>TLS 1.3<br/>SA Token"| K8sAPI
    Operator -.->|"Watch/Patch<br/>via K8s API"| InferenceService
    Operator -.->|"Create/Manage<br/>via K8s API"| Pod

    VirtualService -.->|"Route to 8443"| OAuthProxy
    DestinationRule -.->|"TLS config"| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef mesh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cluster fill:#d5f5e3,stroke:#2ecc71,stroke-width:2px

    class Client external
    class Route ingress
    class OAuthProxy,TrustyAIService,Storage app
    class Operator,K8sAPI operator
    class Database externalservice
    class VirtualService,DestinationRule mesh
    class InferenceService,Prometheus cluster
