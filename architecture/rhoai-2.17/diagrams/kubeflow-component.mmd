graph TB
    subgraph "ODH Notebook Controller Component"
        Controller["OpenshiftNotebookReconciler<br/>Controller"]
        Webhook["NotebookWebhook<br/>Mutating Admission Webhook"]
        Metrics["Metrics Server<br/>Port 8080/TCP HTTP"]
        Health["Health/Readiness Probes<br/>Port 8081/TCP HTTP"]
        WebhookServer["Webhook Server<br/>Port 8443/TCP HTTPS TLS1.2+"]

        Controller -.->|exposes| Metrics
        Controller -.->|exposes| Health
        Webhook -.->|served by| WebhookServer
    end

    subgraph "Custom Resources"
        NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>Namespaced"]
    end

    subgraph "Resources Created by Controller"
        Route["Route<br/>OpenShift Route<br/>Edge TLS"]
        Service["Service<br/>notebook-name-tls<br/>443/TCP"]
        ServiceAccount["ServiceAccount<br/>notebook-name"]
        Secret1["Secret<br/>notebook-name-tls<br/>TLS Cert"]
        Secret2["Secret<br/>notebook-name-oauth-config<br/>Cookie Secret"]
        NetworkPolicy1["NetworkPolicy<br/>notebook-name-ctrl-np"]
        NetworkPolicy2["NetworkPolicy<br/>notebook-name-oauth-np"]
        RoleBinding["RoleBinding<br/>elyra-pipelines-notebook-name"]
    end

    subgraph "External Dependencies"
        KubeflowController["Kubeflow Notebook Controller<br/>Creates StatefulSets"]
        OSRoute["OpenShift Route API<br/>route.openshift.io/v1"]
        OAuthProxy["OAuth Proxy Sidecar<br/>ose-oauth-proxy:v4.14"]
        ServiceCA["OpenShift Service CA<br/>Auto TLS Provisioning"]
        OAuthServer["OpenShift OAuth Server<br/>User Authentication"]
        K8sAPI["Kubernetes API Server<br/>v1.29.0"]
    end

    subgraph "Optional Integrations"
        DSPA["Data Science Pipelines<br/>DSPA Role"]
        ServiceMesh["Service Mesh Istio<br/>mTLS"]
    end

    User["User/Data Scientist"] -->|creates| NotebookCR
    NotebookCR -->|watched by| Controller
    K8sAPI -->|webhook callback| Webhook
    Webhook -->|mutates spec| NotebookCR
    Webhook -->|injects| OAuthProxy

    Controller -->|creates| Route
    Controller -->|creates| Service
    Controller -->|creates| ServiceAccount
    Controller -->|creates| Secret1
    Controller -->|creates| Secret2
    Controller -->|creates| NetworkPolicy1
    Controller -->|creates| NetworkPolicy2
    Controller -->|creates if exists| RoleBinding

    ServiceCA -->|provisions cert| Secret1
    Route -->|exposes| Service
    Service -->|targets| OAuthProxy
    OAuthProxy -->|authenticates via| OAuthServer
    OAuthProxy -->|proxies to| NotebookPod["Jupyter Notebook Pod<br/>Port 8888"]

    NotebookCR -->|primary reconciliation| KubeflowController
    KubeflowController -->|creates| NotebookPod

    Controller -->|uses| OSRoute
    Controller -->|integrates with| ServiceCA
    Controller -.->|optional RBAC| DSPA
    Controller -.->|detects| ServiceMesh

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookCR fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333
    style KubeflowController fill:#e8e8e8,stroke:#333
    style OSRoute fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style DSPA fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
    style ServiceMesh fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
