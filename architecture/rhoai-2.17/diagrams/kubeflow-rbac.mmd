graph TD
    subgraph "Service Accounts"
        SA1["odh-notebook-controller-manager<br/>Namespace: Controller namespace"]
        SA2["notebook-name<br/>Namespace: Notebook namespace<br/>Per-notebook SA"]
    end

    subgraph "ClusterRole Bindings"
        CRB1["odh-notebook-controller-manager-rolebinding<br/>ClusterRoleBinding"]
    end

    subgraph "RoleBindings (Namespace-scoped)"
        RB1["odh-notebook-controller-leader-election-rolebinding<br/>Controller namespace"]
        RB2["elyra-pipelines-notebook-name<br/>Notebook namespace<br/>Optional - created if DSPA Role exists"]
    end

    subgraph "ClusterRoles (Controller Permissions)"
        CR1["odh-notebook-controller-manager-role<br/>ClusterRole"]
    end

    subgraph "ClusterRoles (User-facing - RBAC Aggregation)"
        CR2["notebooks-admin<br/>Aggregates from notebooks-edit"]
        CR3["notebooks-edit<br/>Full CRUD on Notebooks"]
        CR4["notebooks-view<br/>Read-only on Notebooks"]
    end

    subgraph "Roles (Namespace-scoped)"
        R1["odh-notebook-controller-leader-election-role<br/>Controller namespace<br/>Leader election permissions"]
        R2["ds-pipeline-user-access-dspa<br/>Notebook namespace<br/>Optional - if DSPA exists"]
    end

    subgraph "API Resources - Controller Permissions"
        direction TB
        API1["kubeflow.org<br/>notebooks, notebooks/status,<br/>notebooks/finalizers"]
        API2["route.openshift.io<br/>routes"]
        API3["core<br/>services, serviceaccounts,<br/>secrets, configmaps"]
        API4["config.openshift.io<br/>proxies"]
        API5["networking.k8s.io<br/>networkpolicies"]
        API6["rbac.authorization.k8s.io<br/>roles, rolebindings"]
    end

    subgraph "API Resources - User Permissions"
        API7["kubeflow.org<br/>notebooks, notebooks/status"]
    end

    subgraph "API Resources - Leader Election"
        API8["core<br/>configmaps, events"]
        API9["coordination.k8s.io<br/>leases"]
    end

    %% Controller ServiceAccount bindings
    SA1 -->|bound via| CRB1
    CRB1 -->|grants| CR1
    CR1 -->|get, list, watch, patch, update| API1
    CR1 -->|get, list, watch, create, update, patch| API2
    CR1 -->|get, list, watch, create, update, patch| API3
    CR1 -->|get, list, watch| API4
    CR1 -->|get, list, watch, create, update, patch| API5
    CR1 -->|get, list, watch, create, update, patch, delete| API6

    %% Leader election
    SA1 -->|bound via| RB1
    RB1 -->|grants| R1
    R1 -->|get, list, watch, create, update, patch, delete| API8
    R1 -->|get, list, watch, create, update, patch, delete| API9

    %% Per-notebook RBAC (optional)
    SA2 -.->|bound via| RB2
    RB2 -.->|grants| R2
    R2 -.->|pipeline access permissions| PipelineAPI["Data Science Pipelines API<br/>Elyra execution"]

    %% User-facing RBAC (aggregation)
    CR2 -.->|aggregates from| CR3
    CR3 -->|get, list, watch, create, delete,<br/>deletecollection, patch, update| API7
    CR4 -->|get, list, watch| API7

    Users["Users/Data Scientists"] -.->|use| CR3
    Users -.->|use| CR4
    Admins["Cluster Admins"] -.->|use| CR2

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA2 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px
    style RB1 fill:#f5a623,stroke:#333
    style RB2 fill:#f5a623,stroke:#333,stroke-dasharray: 5 5
    style CR1 fill:#ff6b6b,stroke:#333,stroke-width:2px
    style CR2 fill:#c7e8ac,stroke:#333
    style CR3 fill:#c7e8ac,stroke:#333
    style CR4 fill:#c7e8ac,stroke:#333
    style R1 fill:#ffd93d,stroke:#333
    style R2 fill:#ffd93d,stroke:#333,stroke-dasharray: 5 5
    style API1 fill:#e8e8e8,stroke:#333
    style API2 fill:#e8e8e8,stroke:#333
    style API3 fill:#e8e8e8,stroke:#333
    style API4 fill:#e8e8e8,stroke:#333
    style API5 fill:#e8e8e8,stroke:#333
    style API6 fill:#e8e8e8,stroke:#333
    style API7 fill:#e8e8e8,stroke:#333
    style API8 fill:#e8e8e8,stroke:#333
    style API9 fill:#e8e8e8,stroke:#333
    style PipelineAPI fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style Users fill:#dae8fc,stroke:#333
    style Admins fill:#dae8fc,stroke:#333

    %% Notes
    classDef required stroke:#333,stroke-width:2px
    classDef optional stroke:#333,stroke-dasharray: 5 5
