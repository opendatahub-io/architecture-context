graph TD
    subgraph "Operator Service Accounts"
        SAController["controller-manager<br/>NS: operator-namespace"]
    end

    subgraph "DSPA Service Accounts"
        SAAPI["ds-pipeline-name<br/>NS: dspa-namespace"]
        SARunner["pipeline-runner-name<br/>NS: dspa-namespace"]
        SAArgo["argo<br/>NS: dspa-namespace"]
        SAPersist["ds-pipeline-persistenceagent-name<br/>NS: dspa-namespace"]
        SAScheduled["ds-pipeline-scheduledworkflow-name<br/>NS: dspa-namespace"]
    end

    subgraph "ClusterRole Permissions"
        CRManager["manager-role<br/>ClusterRole"]
        CRArgoAdmin["argo-aggregate-to-admin<br/>ClusterRole"]
        CRArgoEdit["argo-aggregate-to-edit<br/>ClusterRole"]
        CRArgoView["argo-aggregate-to-view<br/>ClusterRole"]
    end

    subgraph "Namespace Role Permissions"
        RUserAccess["ds-pipeline-user-access-name<br/>Role"]
        RPipelineRunner["pipeline-runner-name<br/>Role"]
        RArgo["argo-role<br/>Role"]
        RPersist["ds-pipeline-persistenceagent-name<br/>Role"]
        RScheduled["ds-pipeline-scheduledworkflow-name<br/>Role"]
        RLeaderElection["leader-election-role<br/>Role"]
    end

    subgraph "API Resources - Operator Managed"
        DSPACR["datasciencepipelinesapplications<br/>opendatahub.io"]
        Deployments["apps<br/>Deployments, ReplicaSets"]
        CoreResources["core<br/>Pods, Services, ConfigMaps,<br/>Secrets, PVCs, ServiceAccounts"]
        Routes["route.openshift.io<br/>Routes"]
        NetworkPolicies["networking.k8s.io<br/>NetworkPolicies"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors"]
        RBAC["rbac.authorization.k8s.io<br/>Roles, RoleBindings,<br/>ClusterRoles, ClusterRoleBindings"]
    end

    subgraph "API Resources - Workflow Management"
        ArgoWorkflows["argoproj.io<br/>Workflows, WorkflowTemplates,<br/>CronWorkflows"]
        KFWorkflows["kubeflow.org<br/>ScheduledWorkflows"]
        Jobs["batch<br/>Jobs"]
    end

    subgraph "API Resources - ML Platform"
        RayClusters["ray.io<br/>RayClusters, RayJobs, RayServices"]
        Seldon["machinelearning.seldon.io<br/>SeldonDeployments"]
        AppWrappers["workload.codeflare.dev<br/>AppWrappers"]
    end

    subgraph "API Resources - Pipeline Execution"
        SecretsConfig["core<br/>Secrets, ConfigMaps"]
        WorkflowsExec["argoproj.io<br/>Workflows"]
        SubjectAccess["authorization.k8s.io<br/>SubjectAccessReviews"]
    end

    %% Operator Bindings
    SAController -->|"bound via<br/>manager-rolebinding"| CRManager
    SAController -->|"bound via<br/>leader-election-rolebinding"| RLeaderElection

    %% DSPA Instance Bindings
    SAAPI -->|"bound via<br/>ds-pipeline-name"| RUserAccess
    SARunner -->|"bound via<br/>pipeline-runner-name"| RPipelineRunner
    SAArgo -->|"bound via<br/>argo-binding"| RArgo
    SAPersist -->|"bound via<br/>ds-pipeline-persistenceagent-name"| RPersist
    SAScheduled -->|"bound via<br/>ds-pipeline-scheduledworkflow-name"| RScheduled

    %% ClusterRole Permissions to Resources
    CRManager -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| DSPACR
    CRManager -->|"all verbs"| Deployments
    CRManager -->|"create, delete, get,<br/>list, patch,<br/>update, watch"| CoreResources
    CRManager -->|"create, delete, get,<br/>list, patch,<br/>update, watch"| Routes
    CRManager -->|"create, delete, get,<br/>list, patch,<br/>update, watch"| NetworkPolicies
    CRManager -->|"create, delete, get,<br/>list, patch,<br/>update, watch"| ServiceMonitors
    CRManager -->|"create, delete, get,<br/>list, update,<br/>watch, patch"| RBAC
    CRManager -->|"all verbs"| ArgoWorkflows
    CRManager -->|"all verbs"| KFWorkflows
    CRManager -->|"all verbs"| Jobs
    CRManager -->|"create, delete, get,<br/>list, patch"| RayClusters
    CRManager -->|"all verbs"| Seldon
    CRManager -->|"all verbs"| AppWrappers

    %% Namespace Role Permissions
    RUserAccess -->|"create, get, list,<br/>watch, update,<br/>patch, delete"| ArgoWorkflows
    RPipelineRunner -->|"get, list, watch"| SecretsConfig
    RPipelineRunner -->|"get, list, watch,<br/>update, patch"| WorkflowsExec
    RUserAccess -->|"create"| SubjectAccess

    %% Argo ClusterRole Aggregation
    CRArgoAdmin -->|"create, delete,<br/>deletecollection,<br/>get, list, patch,<br/>update, watch"| ArgoWorkflows
    CRArgoEdit -->|"create, delete,<br/>deletecollection,<br/>get, list, patch,<br/>update, watch"| ArgoWorkflows
    CRArgoView -->|"get, list, watch"| ArgoWorkflows

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef cr fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef argoResource fill:#50e3c2,stroke:#333,stroke-width:2px,color:#000

    class SAController,SAAPI,SARunner,SAArgo,SAPersist,SAScheduled sa
    class CRManager,CRArgoAdmin,CRArgoEdit,CRArgoView cr
    class RUserAccess,RPipelineRunner,RArgo,RPersist,RScheduled,RLeaderElection role
    class DSPACR,Deployments,CoreResources,Routes,NetworkPolicies,ServiceMonitors,RBAC,Jobs,RayClusters,Seldon,AppWrappers resource
    class ArgoWorkflows,KFWorkflows,WorkflowsExec,SecretsConfig,SubjectAccess argoResource
