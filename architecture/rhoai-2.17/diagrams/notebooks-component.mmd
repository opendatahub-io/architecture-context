graph TB
    subgraph "Workbench Images (Notebooks)"
        direction TB

        subgraph "Base Images"
            BaseUBI9[Base UBI9/RHEL9<br/>Python 3.9/3.11]
        end

        subgraph "Jupyter Workbenches"
            JupyterMinimal[Jupyter Minimal<br/>JupyterLab 4.2]
            JupyterDS[Jupyter Data Science<br/>Pandas, NumPy, Elyra]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.x]
            JupyterTF[Jupyter TensorFlow<br/>TensorFlow 2.x]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainability Tools]
        end

        subgraph "GPU Workbenches"
            JupyterCUDA[Jupyter CUDA<br/>CUDA 11.8/12.x]
            JupyterROCm[Jupyter ROCm<br/>ROCm 6.x]
            JupyterIntel[Jupyter Intel<br/>Intel Extension]
        end

        subgraph "IDE Workbenches"
            CodeServer[Code Server<br/>VS Code Browser]
            RStudio[RStudio Server<br/>R 4.4 + Python 3.11]
        end

        subgraph "Runtime Images"
            RuntimeMinimal[Runtime Minimal<br/>Headless Python]
            RuntimeDS[Runtime Data Science<br/>Pipeline Execution]
        end

        BaseUBI9 --> JupyterMinimal
        BaseUBI9 --> JupyterDS
        BaseUBI9 --> JupyterPyTorch
        BaseUBI9 --> JupyterTF
        BaseUBI9 --> JupyterTrustyAI
        BaseUBI9 --> JupyterCUDA
        BaseUBI9 --> JupyterROCm
        BaseUBI9 --> JupyterIntel
        BaseUBI9 --> CodeServer
        BaseUBI9 --> RStudio
        BaseUBI9 --> RuntimeMinimal
        BaseUBI9 --> RuntimeDS
    end

    subgraph "Kubernetes Resources"
        ImageStreams[ImageStreams<br/>Image References]
        BuildConfigs[BuildConfigs<br/>RStudio Builds]
        ConfigMaps[ConfigMaps<br/>Image Metadata]
    end

    subgraph "External Registries"
        Quay[Quay.io<br/>Pre-built Images]
        InternalRegistry[OpenShift Registry<br/>Built Images]
    end

    subgraph "Consumers"
        NotebookController[odh-notebook-controller<br/>Spawns Workbenches]
        Dashboard[odh-dashboard<br/>Displays Options]
    end

    JupyterMinimal -.->|references| ImageStreams
    JupyterDS -.->|references| ImageStreams
    JupyterPyTorch -.->|references| ImageStreams
    JupyterTF -.->|references| ImageStreams
    JupyterCUDA -.->|references| ImageStreams
    JupyterROCm -.->|references| ImageStreams
    CodeServer -.->|references| ImageStreams

    RStudio -->|built by| BuildConfigs
    BuildConfigs -->|pushes to| InternalRegistry

    ImageStreams -->|pulls from| Quay
    ImageStreams -->|pulls from| InternalRegistry

    ImageStreams -->|metadata| ConfigMaps

    NotebookController -->|spawns pods from| ImageStreams
    Dashboard -->|reads annotations| ImageStreams

    style BaseUBI9 fill:#e8e8e8
    style JupyterMinimal fill:#4a90e2
    style JupyterDS fill:#4a90e2
    style JupyterPyTorch fill:#4a90e2
    style JupyterTF fill:#4a90e2
    style JupyterTrustyAI fill:#4a90e2
    style JupyterCUDA fill:#f5a623
    style JupyterROCm fill:#f5a623
    style JupyterIntel fill:#f5a623
    style CodeServer fill:#4a90e2
    style RStudio fill:#4a90e2
    style RuntimeMinimal fill:#7ed321
    style RuntimeDS fill:#7ed321
    style ImageStreams fill:#e8e8e8
    style BuildConfigs fill:#e8e8e8
    style NotebookController fill:#7ed321
    style Dashboard fill:#7ed321
