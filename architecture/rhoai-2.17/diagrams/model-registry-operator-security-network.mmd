graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>REST/gRPC API Consumer]
    end

    subgraph Ingress["INGRESS (DMZ) - Istio Service Mesh"]
        direction TB
        Gateway["Istio Gateway<br/>443/TCP → 8080/9090<br/>TLS 1.2+<br/>Modes: SIMPLE/MUTUAL/ISTIO_MUTUAL"]
        VirtualService["VirtualService<br/>Routing Rules"]
        AuthzPolicy["AuthorizationPolicy<br/>CUSTOM action<br/>Delegates to Authorino"]
        Authorino["Authorino<br/>External AuthZ Provider<br/>gRPC mTLS"]

        Gateway --> VirtualService
        VirtualService --> AuthzPolicy
        AuthzPolicy --> Authorino
    end

    subgraph K8sControl["Kubernetes Control Plane"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS ISTIO_MUTUAL)"]
        direction TB

        subgraph NS_Registry["Namespace: {user-specified}"]
            direction TB
            Service["Model Registry Service<br/>ClusterIP<br/>8080/TCP (REST)<br/>9090/TCP (gRPC)"]

            subgraph Pod["Model Registry Pod"]
                direction LR
                Envoy["Envoy Sidecar<br/>mTLS Termination<br/>ISTIO_MUTUAL"]
                RESTContainer["REST Proxy<br/>8080/TCP HTTP<br/>quay.io/opendatahub/<br/>model-registry"]
                GRPCContainer["gRPC Server<br/>9090/TCP gRPC<br/>quay.io/opendatahub/<br/>mlmd-grpc-server"]

                Envoy --> RESTContainer
                Envoy --> GRPCContainer
                RESTContainer -->|localhost:9090<br/>gRPC<br/>No encryption| GRPCContainer
            end

            Service --> Envoy
        end
    end

    subgraph Operator["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: model-registry-operator-system"]
            direction TB
            OpPod["Operator Manager Pod"]
            OpManager["Manager Container<br/>/manager (Go)<br/>Reconciles ModelRegistry CRs"]
            RBACProxy["Kube-RBAC Proxy<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token Auth"]
            MetricsService["controller-manager-metrics-service<br/>ClusterIP 8443/TCP"]

            OpPod --> OpManager
            OpPod --> RBACProxy
            MetricsService --> RBACProxy
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Database[("PostgreSQL/MySQL Database<br/>5432/3306 TCP<br/>TLS optional<br/>Username/Password")]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    subgraph OpenShift["OPENSHIFT (Optional)"]
        OSRouter["OpenShift Router<br/>443/TCP HTTPS<br/>Edge Termination"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Gateway
    Client -.->|HTTPS/443<br/>TLS Edge| OSRouter

    %% Authorino flows
    Authorino -->|TokenReview<br/>SubjectAccessReview<br/>HTTPS/6443<br/>SA Token| K8sAPI

    %% Service mesh flows
    VirtualService -->|mTLS<br/>ISTIO_MUTUAL| Service

    %% Database flows
    GRPCContainer -->|PostgreSQL/MySQL Protocol<br/>5432/3306 TCP<br/>TLS optional<br/>Username/Password| Database

    %% Operator flows
    OpManager -->|Reconcile CRs<br/>Create/Update Resources<br/>HTTPS/6443<br/>SA Token| K8sAPI
    OpManager -.->|Creates/Manages| Pod
    OpManager -.->|Creates/Manages<br/>Istio Resources| Gateway

    %% Monitoring flows
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MetricsService
    RBACProxy -->|TokenReview<br/>SubjectAccessReview<br/>HTTPS/6443| K8sAPI
    RBACProxy -->|HTTP/8080<br/>localhost| OpManager

    %% OpenShift Route flows
    OSRouter -.->|HTTP/8080 or 9090<br/>No mTLS| Service

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef openshift fill:#d0e0e3,stroke:#618896,stroke-width:2px

    class Client external
    class Gateway,VirtualService,AuthzPolicy,Authorino ingress
    class Service,Envoy,RESTContainer,GRPCContainer,Pod servicemesh
    class OpPod,OpManager,RBACProxy,MetricsService operator
    class Database externalservice
    class K8sAPI k8s
    class Prometheus monitoring
    class OSRouter openshift
