graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt"]
        Service["Service: odh-dashboard<br/>ClusterIP<br/>8443/TCP"]
    end

    subgraph PodNetwork["POD NETWORK (Cluster Internal)"]
        direction TB

        subgraph Pod["odh-dashboard Pod<br/>Namespace: {deployment-namespace}<br/>ServiceAccount: odh-dashboard"]
            direction TB
            OAuthProxy["Container: oauth-proxy<br/>Port: 8443/TCP HTTPS<br/>TLS 1.2+<br/>OpenShift OAuth<br/>Secrets: dashboard-proxy-tls<br/>dashboard-oauth-*"]
            Backend["Container: odh-dashboard<br/>Port: 8080/TCP HTTP<br/>Node.js 18 / Fastify<br/>Auth: x-forwarded-access-token"]
        end
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth 2.0 Flow<br/>Policy: List Projects"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Thanos["Thanos Querier<br/>thanos-querier.openshift-monitoring.svc<br/>9092/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
        ModelReg["Model Registry Services<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
        ImageReg["OpenShift Image Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph CRDs["CUSTOM RESOURCES MANAGED"]
        direction LR
        CRD1["dashboard.opendatahub.io:<br/>OdhApplication, OdhDocument,<br/>AcceleratorProfile, HardwareProfile"]
        CRD2["opendatahub.io:<br/>OdhDashboardConfig"]
        CRD3["kubeflow.org:<br/>Notebook"]
        CRD4["serving.kserve.io:<br/>InferenceService, ServingRuntime"]
        CRD5["modelregistry.opendatahub.io:<br/>ModelRegistry"]
    end

    %% External Access Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token or Redirect| Route
    Route -->|HTTPS/8443<br/>TLS 1.2+ reencrypt| Service
    Service -->|HTTPS/8443<br/>TLS 1.2+| OAuthProxy

    %% OAuth Authentication
    OAuthProxy <-->|HTTPS/443<br/>OAuth 2.0 Flow<br/>TLS 1.2+| OAuthServer

    %% Pod Internal Communication
    OAuthProxy -->|HTTP/8080<br/>localhost<br/>x-forwarded-access-token| Backend

    %% Backend to Kubernetes API
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Backend to External Services
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>ServiceAccount Token| Thanos
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| ModelReg
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| ImageReg

    %% CRD Management
    K8sAPI -.->|manages| CRD1
    K8sAPI -.->|manages| CRD2
    K8sAPI -.->|manages| CRD3
    K8sAPI -.->|manages| CRD4
    K8sAPI -.->|manages| CRD5

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sservices fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservices fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crds fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route,Service ingress
    class Pod,OAuthProxy,Backend podnetwork
    class K8sAPI,OAuthServer k8sservices
    class Thanos,ModelReg,ImageReg externalservices
    class CRD1,CRD2,CRD3,CRD4,CRD5 crds
