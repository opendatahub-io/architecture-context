graph TB
    subgraph "KServe Control Plane"
        Controller[kserve-controller-manager<br/>Go Operator]
        Webhook[Webhook Server<br/>Port 9443/TCP HTTPS]
        Controller -->|validates/mutates| Webhook
    end

    subgraph "Custom Resources"
        InferenceService[InferenceService CR<br/>v1beta1]
        InferenceGraph[InferenceGraph CR<br/>v1alpha1]
        ServingRuntime[ServingRuntime CR<br/>v1alpha1]
        TrainedModel[TrainedModel CR<br/>v1alpha1]
    end

    subgraph "KServe Data Plane"
        direction TB
        StorageInit[storage-initializer<br/>Python Init Container]
        Agent[kserve-agent<br/>Go Sidecar]
        Router[kserve-router<br/>Go Service]

        subgraph "Model Servers"
            SKLearn[sklearn-server<br/>V1/V2 Protocol]
            XGBoost[xgboost-server<br/>V1/V2 Protocol]
            HuggingFace[huggingface-server<br/>OpenAI/V1/V2]
            Custom[Custom Server<br/>User-provided]
        end

        subgraph "Explainers"
            ART[ART Explainer<br/>Adversarial Robustness]
            AIF360[AIF360 Explainer<br/>Fairness Metrics]
        end
    end

    subgraph "External Dependencies"
        Knative[Knative Serving 1.8+<br/>Autoscaling]
        Istio[Istio 1.16+<br/>Service Mesh]
        CertManager[cert-manager 1.9+<br/>TLS Certificates]
    end

    subgraph "Internal ODH/RHOAI"
        ServiceMesh[Service Mesh<br/>VirtualService/Gateway]
        Authorino[Authorino<br/>AuthZ]
        ModelRegistry[Model Registry<br/>Metadata]
        Dashboard[ODH Dashboard<br/>UI]
    end

    subgraph "Storage Backends"
        S3[S3-compatible Storage<br/>443/TCP HTTPS]
        GCS[Google Cloud Storage<br/>443/TCP HTTPS]
        Azure[Azure Blob Storage<br/>443/TCP HTTPS]
    end

    User[Data Scientist] -->|creates| InferenceService
    InferenceService -->|watched by| Controller
    Controller -->|creates| ServingRuntime
    Controller -->|creates| TrainedModel
    Controller -->|creates| InferenceGraph

    Controller -->|depends on| Knative
    Controller -->|depends on| Istio
    Controller -->|uses| CertManager

    Controller -->|integrates| ServiceMesh
    Controller -->|integrates| Authorino
    Controller -->|integrates| ModelRegistry
    Dashboard -->|manages| Controller

    StorageInit -->|downloads from| S3
    StorageInit -->|downloads from| GCS
    StorageInit -->|downloads from| Azure

    Agent -->|manages| SKLearn
    Agent -->|manages| XGBoost
    Agent -->|manages| HuggingFace
    Agent -->|manages| Custom

    Router -->|routes to| SKLearn
    Router -->|routes to| XGBoost
    Router -->|routes to| HuggingFace

    InferenceGraph -->|uses| Router

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style InferenceService fill:#f5a623,stroke:#333,stroke-width:2px
    style Knative fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Authorino fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px
