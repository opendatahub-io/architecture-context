graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User Browser / KFP SDK Client"]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Routes)"]
        Route["OpenShift Route API<br/>443 HTTPS TLS1.3"]
        RouteUI["OpenShift Route UI<br/>443 HTTPS TLS1.3"]
        OAuth["OpenShift OAuth Server<br/>443 HTTPS TLS1.3"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER (DSPA Namespace)"]
        direction TB

        subgraph APIServerPod["DS Pipelines API Server Pod"]
            OAuthProxy["OAuth2 Proxy Sidecar<br/>8443 HTTPS TLS1.2+"]
            APIServer["API Server Container<br/>8888 HTTP, 8887 gRPC mTLS"]
        end

        subgraph UIPod["ML Pipelines UI Pod"]
            OAuthProxyUI["OAuth2 Proxy<br/>8443 HTTPS TLS1.2+"]
            UI["UI Container<br/>3000 HTTP"]
        end

        WFC["Workflow Controller<br/>8080 HTTP"]

        PersistAgent["Persistence Agent"]

        ScheduledWF["Scheduled Workflow Controller"]

        subgraph MLMDPod["ML Metadata Pod"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090 gRPC/HTTP2 TLS1.2+"]
            MLMDGRPC["MLMD gRPC Service<br/>8080 gRPC mTLS"]
        end

        PipelinePod["Pipeline Execution Pod"]
    end

    subgraph DataLayer["DATA LAYER (DSPA Namespace)"]
        MariaDB["MariaDB StatefulSet<br/>3306 MySQL TLS"]

        Minio["Minio Deployment<br/>9000 HTTP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExternalS3["External S3 Storage<br/>443 HTTPS TLS1.2+"]

        ExternalDB["External MySQL Database<br/>3306 MySQL TLS1.2+"]

        Registry["Container Registry<br/>443 HTTPS TLS1.2+"]

        K8sAPI["OpenShift API Server<br/>6443 HTTPS TLS1.2+"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS1.3"| Route
    Client -->|"HTTPS/443<br/>TLS1.3"| RouteUI
    Route -.->|"Redirect"| OAuth
    OAuth -.->|"OAuth2 Token"| Client

    %% Ingress to Application
    Route -->|"HTTPS/8443<br/>Bearer Token"| OAuthProxy
    RouteUI -->|"HTTPS/8443<br/>Bearer Token"| OAuthProxyUI

    %% Within Application Layer
    OAuthProxy -->|"HTTP/8888<br/>Trusted"| APIServer
    OAuthProxyUI -->|"HTTP/3000<br/>Trusted"| UI

    APIServer -->|"HTTP/8080<br/>SA Token"| WFC
    WFC -->|"HTTPS/6443<br/>TLS1.2+<br/>SA Token"| K8sAPI
    K8sAPI -.->|"Creates"| PipelinePod

    PipelinePod -->|"gRPC/8887<br/>mTLS<br/>SA Token"| APIServer
    PipelinePod -->|"gRPC/8080<br/>mTLS<br/>SA Token"| MLMDGRPC

    PersistAgent -->|"gRPC/8887<br/>mTLS<br/>SA Token"| APIServer

    MLMDEnvoy -->|"gRPC/8080<br/>mTLS"| MLMDGRPC

    %% Application to Data Layer
    APIServer -->|"MySQL/3306<br/>TLS<br/>User/Pass"| MariaDB
    MLMDGRPC -->|"MySQL/3306<br/>TLS<br/>User/Pass"| MariaDB
    PersistAgent -->|"MySQL/3306<br/>TLS<br/>User/Pass"| MariaDB

    PipelinePod -->|"HTTP/9000<br/>Keys"| Minio

    %% Application to External Services
    PipelinePod -->|"HTTPS/443<br/>TLS1.2+<br/>AWS IAM"| ExternalS3
    APIServer -->|"MySQL/3306<br/>TLS1.2+<br/>User/Pass"| ExternalDB
    K8sAPI -->|"HTTPS/443<br/>TLS1.2+<br/>Pull Secrets"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,RouteUI,OAuth ingress
    class OAuthProxy,OAuthProxyUI,APIServer,WFC,PersistAgent,ScheduledWF,PipelinePod,MLMDGRPC,MLMDEnvoy,UI application
    class MariaDB,Minio data
    class ExternalS3,ExternalDB,Registry,K8sAPI externalservice
