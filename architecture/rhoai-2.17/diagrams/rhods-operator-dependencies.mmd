graph LR
    RHODSOp[RHODS Operator]

    %% External Platform Dependencies
    RHODSOp -->|"container platform"| K8s[Kubernetes 1.25+]
    RHODSOp -->|"enterprise platform"| OpenShift[OpenShift 4.11+]

    %% Conditional External Dependencies
    RHODSOp -.->|"traffic mgmt<br/>(conditional)"| ServiceMesh[Service Mesh Operator<br/>Istio]
    RHODSOp -.->|"autoscaling<br/>(conditional)"| Serverless[Serverless Operator<br/>Knative]
    RHODSOp -.->|"auth<br/>(conditional)"| Authorino[Authorino Operator]
    RHODSOp -.->|"certs<br/>(optional)"| CertManager[cert-manager]

    %% Internal Component Dependencies (Deploys and Manages)
    RHODSOp -->|"deploys & manages"| Dashboard[ODH Dashboard]
    RHODSOp -->|"deploys & manages"| KServe[KServe]
    RHODSOp -->|"deploys & manages"| ModelMesh[ModelMesh]
    RHODSOp -->|"deploys & manages"| DSP[Data Science Pipelines]
    RHODSOp -->|"deploys & manages"| Ray[Ray]
    RHODSOp -->|"deploys & manages"| CodeFlare[CodeFlare]
    RHODSOp -->|"deploys & manages"| TrustyAI[TrustyAI]
    RHODSOp -->|"deploys & manages"| Training[Training Operator]
    RHODSOp -->|"deploys & manages"| Kueue[Kueue]
    RHODSOp -->|"deploys & manages"| ModelReg[Model Registry]
    RHODSOp -->|"deploys & manages"| ModelCtrl[Model Controller]
    RHODSOp -->|"deploys & manages"| Workbenches[Workbenches]

    %% Monitoring Stack
    RHODSOp -->|"deploys"| Prometheus[Prometheus]
    RHODSOp -->|"deploys"| Alertmanager[Alertmanager]
    RHODSOp -->|"deploys"| BlackboxExporter[Blackbox Exporter]

    Prometheus -->|"scrapes metrics"| RHODSOp
    Prometheus -->|"scrapes metrics"| Dashboard
    Prometheus -->|"scrapes metrics"| KServe
    Prometheus -->|"scrapes metrics"| ModelMesh

    %% Platform Services Integration
    RHODSOp -->|"uses"| ServiceCA[OpenShift Service CA]
    RHODSOp -->|"registers"| Console[OpenShift Console]
    RHODSOp -->|"managed by"| OLM[Operator Lifecycle Manager]

    %% External Services
    RHODSOp -.->|"fetch manifests<br/>(devFlags)"| GitHub[GitHub API]
    RHODSOp -.->|"download manifests"| GitRepos[Component Git Repos]

    %% Component inter-dependencies
    KServe -.->|"requires"| ServiceMesh
    KServe -.->|"requires"| Serverless
    Dashboard -->|"manages"| KServe
    Dashboard -->|"manages"| DSP
    Dashboard -->|"manages"| Workbenches
    DSP -.->|"auto-deploy models"| KServe

