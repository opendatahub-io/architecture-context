graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Admin/User]
        EndUser[End User]
    end

    subgraph ControlPlane["CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Namespace: kube-system"]

        subgraph OperatorNS["Namespace: redhat-ods-operator"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS<br/>SA: redhat-ods-operator-controller-manager<br/>Endpoints: /mutate, /validate<br/>Secret: webhook-cert (TLS)"]

            Controllers["RHODS Operator Controllers<br/>SA: redhat-ods-operator-controller-manager<br/>- DSC Controller<br/>- DSCI Controller<br/>- 12 Component Controllers<br/>- 2 Service Controllers<br/>- Utility Controllers"]

            MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>/metrics"]
            HealthEndpoint["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end
    end

    subgraph ApplicationNS["APPLICATION NAMESPACES (Isolated)"]
        subgraph AppsNS["Namespace: redhat-ods-applications"]
            Dashboard[ODH Dashboard]
            Workbenches[Jupyter Workbenches]
            KServe[KServe Operator]
            ModelMesh[ModelMesh Serving]
            DSP[Data Science Pipelines]
            Ray[Ray Operator]
            CodeFlare[CodeFlare Operator]
            TrustyAI[TrustyAI Service]
            Training[Training Operator]
            Kueue[Kueue]
            ModelReg[Model Registry]
        end

        subgraph UserNS["User Namespaces<br/>opendatahub.io/generated-namespace=true"]
            UserWorkloads[User Workloads]
        end
    end

    subgraph MonitoringNS["MONITORING NAMESPACE (Trusted)"]
        subgraph MonNS["Namespace: redhat-ods-monitoring"]
            PromPod["Prometheus Pod<br/>SA: prometheus"]
            PromMetrics["Prometheus<br/>9090/TCP HTTP<br/>(internal)"]
            OAuthProxy["OAuth Proxy<br/>9091/TCP HTTPS TLS<br/>Secret: prometheus-tls<br/>Secret: prometheus-proxy"]
            PromRoute["Prometheus Route<br/>443/TCP HTTPS TLS1.2+<br/>Re-encrypt"]

            PromPod --> PromMetrics
            PromPod --> OAuthProxy
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub API<br/>api.github.com<br/>443/TCP HTTPS TLS1.2+"]
        GitRepos["Component Git Repositories<br/>443/TCP HTTPS"]
    end

    %% User to API Server
    Admin -->|"HTTPS/6443<br/>TLS 1.2+<br/>User Credentials"| K8sAPI

    %% API Server to Webhook
    K8sAPI -->|"HTTPS/9443<br/>mTLS (Service CA)<br/>POST /mutate, /validate"| Webhook

    %% API Server to Controllers (watch)
    K8sAPI -.->|"Watch API<br/>Internal"| Controllers

    %% Controllers to API Server
    Controllers -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token"| K8sAPI

    %% Controllers deploy to Application Namespaces
    Controllers -.->|"Deploy manifests<br/>via K8s API"| Dashboard
    Controllers -.->|"Deploy manifests<br/>via K8s API"| KServe
    Controllers -.->|"Deploy manifests<br/>via K8s API"| ModelMesh
    Controllers -.->|"Deploy manifests<br/>via K8s API"| DSP
    Controllers -.->|"Deploy manifests<br/>via K8s API"| Ray

    %% Prometheus metrics scraping
    PromMetrics -->|"HTTP/8080<br/>Plaintext<br/>Service Account Token"| MetricsEndpoint
    PromMetrics -.->|"Scrape metrics<br/>Service Account Token"| Dashboard
    PromMetrics -.->|"Scrape metrics<br/>Service Account Token"| KServe

    %% Kubelet health checks
    K8sAPI -.->|"HTTP/8081<br/>Plaintext<br/>No Auth"| HealthEndpoint

    %% User to Prometheus UI
    EndUser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Token"| PromRoute
    PromRoute -->|"HTTPS/9091<br/>TLS (Service CA)<br/>OAuth validated"| OAuthProxy
    OAuthProxy -->|"HTTP/9090<br/>Plaintext<br/>Internal"| PromMetrics
    OAuthProxy -.->|"Validate token<br/>HTTPS/6443"| K8sAPI

    %% External services
    Controllers -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| GitHub
    Controllers -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| GitRepos

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:3px
    classDef operator fill:#4a90e2,stroke:#1565c0,stroke-width:2px
    classDef applications fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f5f5f5,stroke:#999,stroke-width:2px

    class Admin,EndUser external
    class K8sAPI controlplane
    class Webhook,Controllers,MetricsEndpoint,HealthEndpoint operator
    class Dashboard,Workbenches,KServe,ModelMesh,DSP,Ray,CodeFlare,TrustyAI,Training,Kueue,ModelReg,UserWorkloads applications
    class PromPod,PromMetrics,OAuthProxy,PromRoute monitoring
    class GitHub,GitRepos externalservice
