            Perm_Batch["batch:<br/>jobs, cronjobs<br/>Verbs: *"]
        end
    end

    subgraph "Role Permissions"
        R_Prometheus["Role<br/>prometheus-role<br/>(Namespace: redhat-ods-monitoring)<br/><br/>Permissions: Read metrics<br/>from component endpoints"]
    end

    subgraph "API Resources"
        subgraph "Cluster-Scoped"
            DSC_CR["DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1"]
            DSCI_CR["DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1"]
            Component_CRs["Component CRs<br/>Dashboard, Workbenches, KServe,<br/>ModelMesh, DSP, Ray, CodeFlare,<br/>TrustyAI, Training, Kueue, etc."]
            Service_CRs["Service CRs<br/>Auth, Monitoring"]
            Feature_CR["FeatureTracker CR<br/>features.opendatahub.io/v1"]
        end

        subgraph "Namespace-Scoped"
            Deployments["Deployments<br/>apps/v1"]
            Services["Services<br/>v1"]
            ConfigMaps["ConfigMaps<br/>v1"]
            Secrets["Secrets<br/>v1"]
            Routes["Routes<br/>route.openshift.io/v1"]
            ServiceMonitors["ServiceMonitors<br/>monitoring.coreos.com/v1"]
        end
    end

    %% Service Account to Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Prometheus -->|"bound via"| RB_Prometheus

    %% Bindings to Roles
    CRB_Controller -->|"grants"| CR_Controller
    RB_Prometheus -->|"grants"| R_Prometheus

    %% ClusterRole to Permissions
    CR_Controller --> Perm_Apps
    CR_Controller --> Perm_Core
    CR_Controller --> Perm_RBAC
    CR_Controller --> Perm_DSC
    CR_Controller --> Perm_DSCI
    CR_Controller --> Perm_Components
    CR_Controller --> Perm_Services
    CR_Controller --> Perm_Features
    CR_Controller --> Perm_Routes
    CR_Controller --> Perm_Monitoring
    CR_Controller --> Perm_CRDs
    CR_Controller --> Perm_Webhooks
    CR_Controller --> Perm_Authorino
    CR_Controller --> Perm_NetPol
    CR_Controller --> Perm_Batch

    %% Permissions to Resources
    Perm_DSC -.->|"CRUD operations"| DSC_CR
    Perm_DSCI -.->|"CRUD operations"| DSCI_CR
    Perm_Components -.->|"create, delete, get,<br/>list, patch, update, watch"| Component_CRs
    Perm_Services -.->|"CRUD operations"| Service_CRs
    Perm_Features -.->|"CRUD operations"| Feature_CR
    Perm_Apps -.->|"all operations"| Deployments
    Perm_Core -.->|"all operations"| Services
    Perm_Core -.->|"all operations"| ConfigMaps
    Perm_Core -.->|"all operations"| Secrets
    Perm_Routes -.->|"all operations"| Routes
    Perm_Monitoring -.->|"all operations"| ServiceMonitors

    %% Prometheus Role to Resources
    R_Prometheus -.->|"read metrics"| Deployments
    R_Prometheus -.->|"read metrics"| Services

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#1565c0,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#c77e1a,stroke-width:2px
    classDef role fill:#7ed321,stroke:#5a9e18,stroke-width:2px
    classDef permission fill:#e8f5e9,stroke:#66bb6a,stroke-width:1px
    classDef resource fill:#fff3e0,stroke:#ffa726,stroke-width:1px

    class SA_Controller,SA_Prometheus serviceaccount
    class CRB_Controller,RB_Prometheus binding
    class CR_Controller,R_Prometheus role
    class Perm_Apps,Perm_Core,Perm_RBAC,Perm_DSC,Perm_DSCI,Perm_Components,Perm_Services,Perm_Features,Perm_Routes,Perm_Monitoring,Perm_CRDs,Perm_Webhooks,Perm_Authorino,Perm_NetPol,Perm_Batch permission
    class DSC_CR,DSCI_CR,Component_CRs,Service_CRs,Feature_CR,Deployments,Services,ConfigMaps,Secrets,Routes,ServiceMonitors resource
