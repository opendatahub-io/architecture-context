            Perm_RBAC["rbac.authorization.k8s.io:<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>Verbs: *"]
        end

        subgraph "ODH CRDs"
            Perm_DSC["datasciencecluster.opendatahub.io:<br/>datascienceclusters,<br/>datascienceclusters/status,<br/>datascienceclusters/finalizers<br/>Verbs: *"]
            Perm_DSCI["dscinitialization.opendatahub.io:<br/>dscinitializations,<br/>dscinitializations/status,<br/>dscinitializations/finalizers<br/>Verbs: *"]
            Perm_Components["components.platform.opendatahub.io:<br/>codeflares, dashboards,<br/>datasciencepipelines, kserves, kueues,<br/>modelcontrollers, modelmeshservings,<br/>modelregistries, rays,<br/>trainingoperators, trustyais, workbenches<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
            Perm_Services["services.platform.opendatahub.io:<br/>auths, monitorings<br/>Verbs: *"]
            Perm_Features["features.opendatahub.io:<br/>featuretrackers<br/>Verbs: *"]
        end

        subgraph "OpenShift/K8s Resources"
            Perm_Routes["route.openshift.io:<br/>routes<br/>Verbs: *"]
            Perm_Monitoring["monitoring.coreos.com:<br/>servicemonitors,<br/>prometheusrules<br/>Verbs: *"]
