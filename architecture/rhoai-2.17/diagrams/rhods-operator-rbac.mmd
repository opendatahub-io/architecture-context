graph TD
    subgraph "Service Accounts"
        SA_Controller["ServiceAccount<br/>redhat-ods-operator/<br/>redhat-ods-operator-controller-manager"]
        SA_Prometheus["ServiceAccount<br/>redhat-ods-monitoring/<br/>prometheus"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller["ClusterRoleBinding<br/>rhods-operator-rolebinding"]
    end

    subgraph "Role Bindings"
        RB_Prometheus["RoleBinding<br/>prometheus-rolebinding<br/>(Namespace: redhat-ods-monitoring)"]
    end

    subgraph "ClusterRole Permissions"
        CR_Controller["ClusterRole<br/>rhods-operator-role"]

        subgraph "Core Resources"
            Perm_Apps["apps:<br/>deployments, replicasets,<br/>statefulsets<br/>Verbs: *"]
