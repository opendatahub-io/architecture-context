graph TD
    subgraph "Service Accounts"
        SA_Operator[kuberay-operator<br/>Namespace: opendatahub]
        SA_RayWorker["{cluster-name}-ray-worker<br/>Namespace: {user-namespace}"]
        SA_APIServer["kuberay-apiserver<br/>Namespace: opendatahub<br/>(Optional)"]
    end

    subgraph "Cluster-Level RBAC"
        CRB_Operator[ClusterRoleBinding:<br/>kuberay-operator]
        CR_Operator[ClusterRole:<br/>kuberay-operator]
    end

    subgraph "Namespace-Level RBAC (opendatahub)"
        RB_LeaderElection[RoleBinding:<br/>kuberay-operator-leader-election]
        R_LeaderElection[Role:<br/>kuberay-operator-leader-election]
    end

    subgraph "Namespace-Level RBAC (user-namespace)"
        RB_RayCluster["RoleBinding:<br/>{cluster-name}-*<br/>(managed by operator)"]
        R_RayCluster["Role:<br/>{cluster-name}-*<br/>(managed by operator)"]
    end

    subgraph "API Resources - Core"
        Core_Pods[core/pods<br/>pods/status<br/>pods/proxy]
        Core_Services[core/services<br/>services/status<br/>services/proxy]
        Core_SA[core/serviceaccounts]
        Core_Endpoints[core/endpoints]
        Core_Events[core/events]
    end

    subgraph "API Resources - Batch"
        Batch_Jobs[batch/jobs]
    end

    subgraph "API Resources - Ray CRDs"
        Ray_Clusters[ray.io/rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers]
        Ray_Jobs[ray.io/rayjobs<br/>rayjobs/status<br/>rayjobs/finalizers]
        Ray_Services[ray.io/rayservices<br/>rayservices/status<br/>rayservices/finalizers]
    end

    subgraph "API Resources - RBAC"
        RBAC_Roles[rbac.authorization.k8s.io/roles]
        RBAC_RoleBindings[rbac.authorization.k8s.io/rolebindings]
    end

    subgraph "API Resources - Networking"
        Network_Ingresses[networking.k8s.io/ingresses<br/>ingressclasses]
        Network_Ingresses_Ext[extensions/ingresses]
        OpenShift_Routes[route.openshift.io/routes]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[coordination.k8s.io/leases]
    end

    %% Service Account to Bindings
    SA_Operator -->|bound via| CRB_Operator
    SA_Operator -->|bound via| RB_LeaderElection

    %% Bindings to Roles
    CRB_Operator -->|grants| CR_Operator
    RB_LeaderElection -->|grants| R_LeaderElection

    %% Cluster Role Permissions
    CR_Operator -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| Core_Pods
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Core_Services
    CR_Operator -->|create, delete,<br/>get, list, watch| Core_SA
    CR_Operator -->|get, list, watch| Core_Endpoints
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Core_Events

    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Batch_Jobs

    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Ray_Clusters
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Ray_Jobs
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Ray_Services

    CR_Operator -->|create, delete,<br/>get, list, update, watch| RBAC_Roles
    CR_Operator -->|create, delete,<br/>get, list, update, watch| RBAC_RoleBindings

    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Network_Ingresses
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| Network_Ingresses_Ext
    CR_Operator -->|create, delete,<br/>get, list, patch, update, watch| OpenShift_Routes

    %% Leader Election Role Permissions
    R_LeaderElection -->|create, get, list, update| Coord_Leases

    %% Ray Cluster RBAC (managed by operator)
    SA_RayWorker -->|bound via| RB_RayCluster
    RB_RayCluster -->|grants| R_RayCluster

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef resource fill:#e8e8e8,stroke:#666,stroke-width:1px,color:#000
    classDef rayCRD fill:#cfe2f3,stroke:#3d85c6,stroke-width:2px,color:#000

    class SA_Operator,SA_RayWorker,SA_APIServer serviceAccount
    class CRB_Operator,RB_LeaderElection,RB_RayCluster binding
    class CR_Operator,R_LeaderElection,R_RayCluster role
    class Core_Pods,Core_Services,Core_SA,Core_Endpoints,Core_Events,Batch_Jobs,RBAC_Roles,RBAC_RoleBindings,Network_Ingresses,Network_Ingresses_Ext,OpenShift_Routes,Coord_Leases resource
    class Ray_Clusters,Ray_Jobs,Ray_Services rayCRD
