graph TD
    subgraph "RBAC Overview"
        Note1["No ClusterRoles/RoleBindings defined<br/>in Workbench Images component"]
        Note2["RBAC managed by:<br/>odh-notebook-controller<br/>OpenShift RBAC system"]
    end

    subgraph "Runtime ServiceAccounts"
        SA_Workbench["Workbench ServiceAccount<br/>Created per workbench instance"]
        SA_Build["Builder ServiceAccount<br/>For RStudio BuildConfigs"]
    end

    subgraph "Image Access Permissions"
        ImagePull[Image Pull Permissions]
        RegistryAccess[Registry Access]
    end

    subgraph "Build Permissions (RStudio)"
        BuildRole["Builder Role<br/>OpenShift Default"]
        BuildPermissions["Build Permissions:<br/>Create builds<br/>Push images to internal registry<br/>Pull base images"]
    end

    subgraph "Secrets Access"
        SecretRHEL["rhel-subscription-secret<br/>RHEL subscription"]
        SecretAWS["aws-connection-*<br/>S3 credentials"]
        SecretGit["git-credentials<br/>Git access"]
        SecretOAuth["notebook-oauth-config<br/>OAuth config"]
    end

    subgraph "User Authentication Flow"
        UserAuth["User Identity<br/>OpenShift OAuth/OIDC"]
        WorkbenchAuth["Workbench Auth<br/>Token/OAuth Proxy"]
    end

    SA_Workbench -->|requires| ImagePull
    ImagePull -->|grants access to| RegistryAccess

    SA_Build -->|bound to| BuildRole
    BuildRole -->|grants| BuildPermissions

    SA_Build -->|accesses| SecretRHEL
    SA_Workbench -.->|may access| SecretAWS
    SA_Workbench -.->|may access| SecretGit
    SA_Workbench -.->|uses| SecretOAuth

    UserAuth -->|configures| WorkbenchAuth
    WorkbenchAuth -->|enforced by| SA_Workbench

    Note1 -.->|managed by| SA_Workbench
    Note2 -.->|controls| SA_Workbench

    style Note1 fill:#ffe6cc,stroke:#d79b00
    style Note2 fill:#ffe6cc,stroke:#d79b00
    style SA_Workbench fill:#4a90e2
    style SA_Build fill:#4a90e2
    style BuildRole fill:#f5a623
    style SecretRHEL fill:#e8e8e8
    style SecretAWS fill:#e8e8e8
    style SecretGit fill:#e8e8e8
    style SecretOAuth fill:#e8e8e8
    style UserAuth fill:#7ed321
    style WorkbenchAuth fill:#7ed321
