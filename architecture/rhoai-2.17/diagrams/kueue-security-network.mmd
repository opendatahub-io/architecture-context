graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/System]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    subgraph ControlPlane["KUBERNETES API SERVER (Control Plane)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>RBAC AuthN/AuthZ"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (kueue-system)"]
        direction TB

        subgraph WebhookServer["Webhook Server Pod"]
            Webhook["Kueue Webhook<br/>Service: webhook-service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+<br/>SA: controller-manager"]
        end

        subgraph ControllerPod["Controller Manager Pod"]
            Controller["Kueue Controller<br/>SA: controller-manager<br/>Namespace: kueue-system<br/>Security: runAsNonRoot<br/>allowPrivilegeEscalation: false"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end

        subgraph VisibilityPod["Visibility Server Pod"]
            VisAPI["Visibility API<br/>Service: visibility-server<br/>443/TCP → 8082/TCP<br/>HTTPS TLS 1.2+<br/>API: visibility.kueue.x-k8s.io/v1alpha1"]
        end

        MetricsService["Metrics Service<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph Secrets["Secrets (kueue-system)"]
        WebhookCert["webhook-server-cert<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-rotate: Yes"]
    end

    subgraph NetworkPolicy["Network Policies"]
        NP["webhook-server<br/>Allow: TCP/9443 from any"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        RemoteK8s["Remote Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: Kubeconfig<br/>Purpose: MultiKueue"]
    end

    subgraph JobFrameworks["Job Frameworks (CRDs)"]
        BatchJob[Batch Jobs<br/>batch/v1]
        PyTorch[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v2beta1]
        RayJob[RayJob<br/>ray.io/v1]
    end

    subgraph KueueCRDs["Kueue CRDs"]
        ClusterQueue[ClusterQueue<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue<br/>kueue.x-k8s.io/v1beta1]
        Workload[Workload<br/>kueue.x-k8s.io/v1beta1]
    end

    %% External to API Server
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% API Server to Webhook
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s API mTLS| Webhook

    %% Webhook uses cert
    WebhookCert -.->|TLS cert| Webhook

    %% Webhook to API Server
    Webhook -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Controller to API Server
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Visibility to API Server
    VisAPI -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% User to Visibility via API Server
    K8sAPI -->|HTTPS/8082<br/>TLS 1.2+<br/>Delegated Auth| VisAPI

    %% Prometheus to Metrics
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MetricsService
    MetricsService -.->|exposes| Controller

    %% Health probes (internal)
    HealthProbes -.->|HTTP/8081<br/>No auth<br/>Local only| Controller

    %% Controller to Remote K8s (MultiKueue)
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>Kubeconfig| RemoteK8s

    %% Job submissions
    User -->|creates| BatchJob
    User -->|creates| PyTorch
    User -->|creates| TFJob
    User -->|creates| RayJob

    %% Jobs watched by webhook
    BatchJob -.->|watched/mutated by| Webhook
    PyTorch -.->|watched/mutated by| Webhook
    TFJob -.->|watched/mutated by| Webhook
    MPIJob -.->|watched/mutated by| Webhook
    RayJob -.->|watched/mutated by| Webhook

    %% Controller manages CRDs
    Controller -.->|reconciles| ClusterQueue
    Controller -.->|reconciles| LocalQueue
    Controller -.->|reconciles| Workload

    %% Network policy applies to webhook
    NP -.->|applies to| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kueue fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crd fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User,Prometheus external
    class K8sAPI controlplane
    class Webhook,Controller,VisAPI,MetricsService,HealthProbes kueue
    class WebhookCert secret
    class RemoteK8s externalservice
    class BatchJob,PyTorch,TFJob,MPIJob,RayJob,ClusterQueue,LocalQueue,Workload crd
