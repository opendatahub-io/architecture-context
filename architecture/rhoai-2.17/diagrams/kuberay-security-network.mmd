graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>User/CI]
    end

    subgraph Ingress["INGRESS/ROUTE (DMZ)"]
        IngressController["Kubernetes Ingress /<br/>OpenShift Route<br/>443/TCP → 8265/10001<br/>TLS 1.2+ Termination<br/>Auth: OAuth/OIDC (recommended)"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: opendatahub (Operator)"]
            Operator["kuberay-operator<br/>Deployment<br/>SA: kuberay-operator<br/>UID: 65532<br/>Port: 8080/TCP HTTP"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>RBAC: ClusterRole kuberay-operator"]
        end

        subgraph NS_User["Namespace: {user-namespace} (Ray Cluster)"]
            direction TB

            RayClusterCR["RayCluster CR<br/>ray.io/v1"]
            RayJobCR["RayJob CR<br/>ray.io/v1"]
            RayServiceCR["RayService CR<br/>ray.io/v1"]

            subgraph RayCluster["Ray Cluster Components"]
                HeadPod["Ray Head Pod<br/>SA: {cluster-name}-ray-worker<br/>UID: 1000<br/>Containers: ray-head, autoscaler"]
                HeadService["Service: {cluster-name}-head-svc<br/>6379/TCP (GCS)<br/>8265/TCP (Dashboard)<br/>10001/TCP (Client)<br/>8080/TCP (Metrics)"]
                WorkerPods["Ray Worker Pods (1-N)<br/>SA: {cluster-name}-ray-worker<br/>UID: 1000<br/>Autoscaling: min-max replicas"]
            end
        end

        subgraph NS_APIServer["Optional: KubeRay API Server"]
            APIServer["kuberay-apiserver<br/>Deployment<br/>8888/TCP HTTP REST<br/>8887/TCP gRPC<br/>Auth: Bearer Token (optional)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        ContainerRegistry["Container Registry<br/>quay.io / registry.access.redhat.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Image pull secrets"]
        S3["S3/Object Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM / Access Keys"]
        ExternalRedis["External Redis (Optional HA)<br/>6379/TCP<br/>TLS (optional)<br/>Auth: Password"]
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>Metrics Collection"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Auth: OAuth/OIDC| IngressController

    %% Ingress to Ray Services
    IngressController -->|HTTP/8265<br/>Dashboard Access<br/>Plaintext| HeadService
    IngressController -->|TCP/10001<br/>Client API<br/>Plaintext| HeadService

    %% Operator Flows
    Operator <-->|Watch/Reconcile<br/>HTTPS/443 TLS1.2+<br/>SA Token| K8sAPI
    Operator -->|Create/Manage| RayClusterCR
    Operator -->|Create/Manage| RayJobCR
    Operator -->|Create/Manage| RayServiceCR
    Operator -->|Create/Manage| HeadPod
    Operator -->|Create/Manage| WorkerPods
    Operator -->|Create/Manage| HeadService

    %% Ray Cluster Internal
    HeadPod -->|Exposes| HeadService
    WorkerPods -->|Connect GCS<br/>6379/TCP plaintext<br/>Auth: None| HeadPod
    WorkerPods -->|Task Execution<br/>Dynamic/TCP plaintext| HeadPod

    %% Optional API Server
    APIServer -->|REST/gRPC calls<br/>HTTPS/443 TLS1.2+<br/>SA Token| K8sAPI

    %% External Service Access
    Operator -->|Pull Images<br/>HTTPS/443 TLS1.2+| ContainerRegistry
    HeadPod -->|Data Access<br/>HTTPS/443 TLS1.2+<br/>AWS IAM| S3
    WorkerPods -->|Data Access<br/>HTTPS/443 TLS1.2+<br/>AWS IAM| S3
    HeadPod -.->|Optional HA<br/>6379/TCP TLS<br/>Password Auth| ExternalRedis

    %% Monitoring
    Prometheus -->|Scrape /metrics<br/>HTTP/8080<br/>Plaintext| Operator
    Prometheus -->|Scrape /metrics<br/>HTTP/8080<br/>Plaintext| HeadPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef raycomponent fill:#cfe2f3,stroke:#3d85c6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef crd fill:#f4cccc,stroke:#cc0000,stroke-width:2px

    class Client external
    class IngressController ingress
    class Operator,K8sAPI,APIServer operator
    class HeadPod,WorkerPods,HeadService raycomponent
    class RayClusterCR,RayJobCR,RayServiceCR crd
    class ContainerRegistry,S3,ExternalRedis externalservice
    class Prometheus monitoring
