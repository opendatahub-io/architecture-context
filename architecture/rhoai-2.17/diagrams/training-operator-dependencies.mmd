graph LR
    TrainingOperator[Training Operator<br/>v1.8.0-rc.0]

    %% External Dependencies - Required
    TrainingOperator -->|platform| K8s[Kubernetes 1.25+<br/>Required]
    TrainingOperator -->|framework| ControllerRuntime[controller-runtime v0.17.2<br/>Required]
    TrainingOperator -->|API calls| K8sAPI[Kubernetes API Server<br/>Required]
    TrainingOperator -->|image pull| Registry[Container Registry<br/>quay.io, registry.redhat.io<br/>Required]

    %% External Dependencies - Optional
    TrainingOperator -.->|gang scheduling| Volcano[Volcano v1.8.0<br/>Optional]
    TrainingOperator -.->|alt gang scheduling| SchedulerPlugins[Scheduler-Plugins v0.26.7<br/>Optional]
    TrainingOperator -.->|metrics| Prometheus[Prometheus<br/>Optional]
    TrainingOperator -.->|webhook certs| CertManager[cert-manager<br/>Optional]

    %% Internal ODH Dependencies
    TrainingOperator -.->|model pipeline| ModelController[odh-model-controller<br/>Internal ODH]
    TrainingOperator -.->|metrics scraping| PrometheusODH[Prometheus - ODH<br/>Internal ODH]
    TrainingOperator -.->|network policy| ServiceMesh[Service Mesh - Istio<br/>Internal ODH<br/>Sidecar disabled]

    %% Integration Points - Outbound
    subgraph "Outbound API Calls"
        TrainingOperator -->|watch/create| CRDs[Custom Resources<br/>PyTorchJob/TFJob/MPIJob]
        TrainingOperator -->|create/manage| Pods[Pods]
        TrainingOperator -->|create| Services[Services]
        TrainingOperator -->|create| ConfigMaps[ConfigMaps]
        TrainingOperator -->|create| RoleBindings[RoleBindings]
        TrainingOperator -->|create| HPA[HorizontalPodAutoscaler<br/>PyTorch Elastic]
        TrainingOperator -.->|optional| PodGroups[PodGroups<br/>Gang Scheduling]
    end

    %% Integration Points - Inbound
    subgraph "Inbound API Calls"
        K8sAPI -->|webhook validation| TrainingOperator
        Prometheus -->|scrape /metrics:8080| TrainingOperator
        Kubelet[Kubelet] -->|health checks :8081| TrainingOperator
        User[Data Scientist] -->|submit jobs| K8sAPI
        SDK[Python SDK] -->|create jobs| K8sAPI
    end

    %% Runtime Dependencies
    subgraph "Training Job Runtime"
        Pods -->|framework-specific| PyTorchDDP[PyTorch DDP<br/>Distributed training]
        Pods -->|framework-specific| TensorFlowPS[TensorFlow ParameterServer<br/>Parameter server]
        Pods -->|framework-specific| MPIABI[MPI AllReduce<br/>Message passing]
        Pods -->|framework-specific| XGBoostRabit[XGBoost Rabit<br/>Collective comm]
        Pods -->|service discovery| DNS[Kubernetes DNS<br/>CoreDNS]
        Pods -->|storage| PVC[PersistentVolumeClaims<br/>Model artifacts]
    end

