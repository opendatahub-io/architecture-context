graph TD
    subgraph "Service Account"
        SA[kueue-system/<br/>controller-manager]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>cluster-wide]
        CRB2[metrics-auth-rolebinding<br/>cluster-wide]
    end

    subgraph "RoleBinding (Namespace)"
        RB1[leader-election-rolebinding<br/>kueue-system namespace]
    end

    subgraph "ClusterRole: manager-role"
        CR1[manager-role]

        subgraph "Kueue CRDs (kueue.x-k8s.io)"
            KueueCRDs["clusterqueues, localqueues,<br/>workloads, admissionchecks,<br/>resourceflavors, workloadpriorityclasses,<br/>multikueueclusters, multikueueconfigs,<br/>provisioningrequestconfigs<br/><br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
            KueueStatus["*/status subresources<br/><br/>Verbs: get, patch, update"]
            KueueFinalizers["*/finalizers subresources<br/><br/>Verbs: update"]
        end

        subgraph "Batch Jobs (batch)"
            BatchResources["jobs, jobs/status,<br/>jobs/finalizers<br/><br/>Verbs: get, list, watch,<br/>patch, update"]
        end

        subgraph "Kubeflow Training (kubeflow.org)"
            KubeflowResources["mpijobs, pytorchjobs, tfjobs,<br/>xgboostjobs, mxjobs, paddlejobs<br/>(+ /status, /finalizers)<br/><br/>Verbs: get, list, watch,<br/>patch, update"]
        end

        subgraph "Ray (ray.io)"
            RayResources["rayjobs, rayclusters<br/>(+ /status, /finalizers)<br/><br/>Verbs: get, list, watch,<br/>patch, update"]
        end

        subgraph "JobSet (jobset.x-k8s.io)"
            JobSetResources["jobsets, jobsets/status,<br/>jobsets/finalizers<br/><br/>Verbs: get, list, watch,<br/>patch, update"]
        end

        subgraph "Core Resources"
            CoreResources["pods, pods/status, pods/finalizers,<br/>podtemplates, secrets, namespaces,<br/>limitranges, events<br/><br/>Verbs: get, list, watch, patch,<br/>update, delete, create"]
        end

        subgraph "Autoscaling (autoscaling.x-k8s.io)"
            AutoscalingResources["provisioningrequests,<br/>provisioningrequests/status<br/><br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Admission Registration"
            AdmissionResources["mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations<br/><br/>Verbs: get, list, watch, update"]
        end

        subgraph "Other Kubernetes Resources"
            OtherResources["priorityclasses (scheduling.k8s.io)<br/>Verbs: get, list, watch<br/><br/>runtimeclasses (node.k8s.io)<br/>Verbs: get, list, watch<br/><br/>flowschemas, prioritylevelconfigurations<br/>(flowcontrol.apiserver.k8s.io)<br/>Verbs: list, watch<br/><br/>flowschemas/status<br/>Verbs: patch"]
        end
    end

    subgraph "ClusterRole: metrics-auth-role"
        CR2[metrics-auth-role<br/><br/>pods, services<br/>Verbs: get, list]
    end

    subgraph "Role: leader-election-role"
        R1[leader-election-role<br/><br/>configmaps, leases<br/>Verbs: get, create, update]
    end

    subgraph "User Roles (Viewers/Editors)"
        UserRoles["clusterqueue-viewer-role<br/>clusterqueue-editor-role<br/>localqueue-viewer-role<br/>localqueue-editor-role<br/>workload-viewer-role<br/>workload-editor-role<br/>batch-user-role<br/>batch-admin-role<br/>job-editor-role<br/>pytorchjob-editor-role<br/>tfjob-editor-role<br/>mpijob-editor-role<br/>rayjob-editor-role<br/>raycluster-editor-role<br/>metrics-reader-role"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| RB1

    %% System:authenticated to metrics
    SystemAuth[system:authenticated] -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% ClusterRole contains permissions
    CR1 -.->|manages| KueueCRDs
    CR1 -.->|manages| KueueStatus
    CR1 -.->|manages| KueueFinalizers
    CR1 -.->|manages| BatchResources
    CR1 -.->|manages| KubeflowResources
    CR1 -.->|manages| RayResources
    CR1 -.->|manages| JobSetResources
    CR1 -.->|manages| CoreResources
    CR1 -.->|manages| AutoscalingResources
    CR1 -.->|manages| AdmissionResources
    CR1 -.->|manages| OtherResources

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style KueueCRDs fill:#dae8fc,stroke:#333
    style KueueStatus fill:#dae8fc,stroke:#333
    style KueueFinalizers fill:#dae8fc,stroke:#333
    style BatchResources fill:#dae8fc,stroke:#333
    style KubeflowResources fill:#dae8fc,stroke:#333
    style RayResources fill:#dae8fc,stroke:#333
    style JobSetResources fill:#dae8fc,stroke:#333
    style CoreResources fill:#dae8fc,stroke:#333
    style AutoscalingResources fill:#dae8fc,stroke:#333
    style AdmissionResources fill:#dae8fc,stroke:#333
    style OtherResources fill:#dae8fc,stroke:#333
    style UserRoles fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style SystemAuth fill:#e8e8e8,stroke:#333
