graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist / CI System]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph ControllerNamespace["APPLICATION LAYER (Controller Namespace: redhat-ods-applications)"]
        direction TB

        subgraph WebhookServer["Webhook Server"]
            Webhook["odh-model-controller-webhook-service<br/>9443/TCP HTTPS TLS 1.2+<br/>K8s API Server mTLS<br/><br/>POST /mutate-...-inferencegraph<br/>POST /mutate-...-inferenceservice<br/>POST /validate-nim-...-account<br/>POST /validate-...-service<br/>POST /validate-...-inferenceservice"]
        end

        subgraph Reconcilers["Reconcilers"]
            Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>ClusterRole: odh-model-controller-role"]
        end

        subgraph Metrics["Monitoring Layer"]
            MetricsSvc["odh-model-controller-metrics-service<br/>8080/TCP HTTP<br/>⚠️  No Encryption<br/>⚠️  No Auth<br/><br/>GET /metrics"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/><br/>GET /healthz<br/>GET /readyz"]
        end
    end

    subgraph ServiceMesh["SERVICE MESH LAYER"]
        IstioCP["Istio Control Plane (Pilot)<br/>Namespace: istio-system<br/>15010/TCP gRPC<br/>mTLS Service Identity"]
    end

    subgraph Monitoring["MONITORING LAYER"]
        Prometheus["Prometheus<br/>Namespace: openshift-monitoring<br/>SA: prometheus-k8s<br/>ClusterRole: kserve-prometheus-k8s"]
        Kubelet["Kubelet<br/>Local Health Checks"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>NGC API Key Auth"]
        ModelRegistry["Model Registry (Optional)<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token Auth"]
    end

    %% External to Control Plane
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>kubectl credentials| APIServer

    %% API Server to Webhooks
    APIServer -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s API mTLS| Webhook

    %% Webhooks to API Server
    Webhook -->|Response| APIServer

    %% Reconcilers to API Server
    APIServer -->|Watch Events| Controller
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token| APIServer

    %% Controller to Istio
    Controller -->|gRPC/15010<br/>mTLS<br/>Service Identity| IstioCP

    %% Controller to External Services
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>NGC API Key| NGC
    Controller -.->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| ModelRegistry

    %% Metrics Collection
    MetricsSvc -->|Expose Endpoint| MetricsSvc
    Prometheus -->|HTTP/8080<br/>⚠️  No Auth| MetricsSvc

    %% Health Probes
    Kubelet -->|HTTP/8081| HealthProbes

    %% Styling by Trust Zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef servicemesh fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:3px
    classDef externalservice fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef insecure fill:#f8cecc,stroke:#b85450,stroke-width:3px

    class User external
    class APIServer controlplane
    class Webhook,Controller application
    class MetricsSvc insecure
    class HealthProbes application
    class IstioCP servicemesh
    class Prometheus,Kubelet monitoring
    class NGC,ModelRegistry externalservice
