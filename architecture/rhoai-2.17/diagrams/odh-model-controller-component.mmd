graph TB
    %% Core Controller Components
    InfSvcRec[InferenceService Reconciler<br/>Main Controller]
    ServRtRec[ServingRuntime Reconciler<br/>Monitoring Dashboards]
    InfGraphRec[InferenceGraph Reconciler<br/>Multi-Model Pipelines]
    AcctRec[Account Reconciler<br/>NIM Management]
    CMRec[ConfigMap Reconciler<br/>Config Watcher]
    SecRec[Secret Reconciler<br/>Secret Watcher]
    Webhook[Webhook Server<br/>9443/TCP HTTPS]
    Metrics[Metrics Server<br/>8080/TCP HTTP]
    Health[Health Probes<br/>8081/TCP HTTP]

    %% Custom Resources
    NIMAcct[nim.opendatahub.io/v1<br/>Account CRD]

    %% Watched KServe CRDs
    InfSvc[InferenceService<br/>serving.kserve.io/v1beta1]
    ServRt[ServingRuntime<br/>serving.kserve.io/v1alpha1]
    InfGraph[InferenceGraph<br/>serving.kserve.io/v1alpha1]
    Predictor[Predictor<br/>serving.kserve.io/v1beta1]
    KnativeSvc[Knative Service<br/>serving.knative.dev/v1]

    %% External Dependencies (Required)
    KServe[KServe v0.14.0<br/>Required]
    K8sAPI[Kubernetes API v1.31.0<br/>Required]
    OSRoute[OpenShift Route v1<br/>Required]

    %% External Dependencies (Conditional)
    Istio[Istio v1.23.0<br/>Conditional]
    Authorino[Authorino v0.18.1<br/>Conditional]
    PrometheusOp[Prometheus Operator v0.64.1<br/>Conditional]
    Knative[Knative Serving v0.42.2<br/>Conditional]

    %% Internal ODH Dependencies
    DSC[DataScienceCluster CRD<br/>Internal ODH]
    DSCI[DSCInitialization CRD<br/>Internal ODH]
    ModelReg[Model Registry<br/>Internal ODH]

    %% Created Resources
    SA[ServiceAccount]
    IstioGW[Istio Gateway]
    IstioVS[Istio VirtualService]
    PeerAuth[PeerAuthentication<br/>mTLS STRICT]
    AuthCfg[Authorino AuthConfig]
    Route[OpenShift Route]
    NetPol[NetworkPolicy]
    RoleB[RoleBinding]
    PodMon[PodMonitor]
    Templates[ServingRuntime Template]
    NIMConfigMap[NIM ConfigMap]
    PullSecret[NIM Pull Secret]
    NVIDIAAPI[NVIDIA NGC API<br/>443/TCP HTTPS]

    %% User
    User[Data Scientist]

    %% Reconciler connections
    InfSvcRec -.->|uses| Webhook
    InfGraphRec -.->|uses| Webhook
    AcctRec -.->|uses| Webhook

    %% User Interactions
    User -->|creates| InfSvc
    User -->|creates| NIMAcct

    %% CRD Watches
    InfSvc -->|watched by| InfSvcRec
    ServRt -->|watched by| ServRtRec
    InfGraph -->|watched by| InfGraphRec
    Predictor -->|watched by| InfSvcRec
    KnativeSvc -->|validated by| Webhook
    NIMAcct -->|reconciled by| AcctRec

    %% Resource Creation (InferenceService)
    InfSvcRec -->|creates| SA
    InfSvcRec -->|creates| Route
    InfSvcRec -->|creates| IstioGW
    InfSvcRec -->|creates| IstioVS
    InfSvcRec -->|creates| PeerAuth
    InfSvcRec -->|creates| AuthCfg
    InfSvcRec -->|creates| NetPol
    InfSvcRec -->|creates| RoleB
    InfSvcRec -->|creates| PodMon

    %% External Dependencies
    InfSvcRec -->|uses| KServe
    InfSvcRec -->|API calls| K8sAPI
    InfSvcRec -->|creates Routes| OSRoute
    InfSvcRec -->|if mesh enabled| Istio
    InfSvcRec -->|if auth enabled| Authorino
    InfSvcRec -->|if serverless| Knative
    ServRtRec -->|creates monitors| PrometheusOp

    %% Internal Dependencies
    InfSvcRec -->|reads config| DSC
    InfSvcRec -->|reads refs| DSCI
    InfSvcRec -.->|optional| ModelReg

    %% NIM Account Flow
    AcctRec -->|creates| Templates
    AcctRec -->|creates| NIMConfigMap
    AcctRec -->|creates| PullSecret
    AcctRec -->|validates| NVIDIAAPI

    %% Metrics Collection
    Metrics -->|scraped by| PrometheusOp

    %% Styling - Controllers
    style InfSvcRec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ServRtRec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style InfGraphRec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style AcctRec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CMRec fill:#4a90e2,stroke:#333,stroke-width:2px
    style SecRec fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Metrics fill:#f5a623,stroke:#333,stroke-width:2px

    %% Styling - CRDs
    style InfSvc fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style ServRt fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style InfGraph fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style NIMAcct fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Predictor fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style KnativeSvc fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff

    %% Styling - External (Required)
    style KServe fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style K8sAPI fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style OSRoute fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff

    %% Styling - External (Conditional)
    style Istio fill:#f39c12,stroke:#333,stroke-width:2px
    style Authorino fill:#f39c12,stroke:#333,stroke-width:2px
    style PrometheusOp fill:#f39c12,stroke:#333,stroke-width:2px
    style Knative fill:#f39c12,stroke:#333,stroke-width:2px

    %% Styling - Internal ODH
    style DSC fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style DSCI fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style ModelReg fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff

    %% Styling - Created Resources
    style SA fill:#ecf0f1,stroke:#333,stroke-width:1px
    style Route fill:#ecf0f1,stroke:#333,stroke-width:1px
    style IstioGW fill:#ecf0f1,stroke:#333,stroke-width:1px
    style IstioVS fill:#ecf0f1,stroke:#333,stroke-width:1px
    style PeerAuth fill:#ecf0f1,stroke:#333,stroke-width:1px
    style AuthCfg fill:#ecf0f1,stroke:#333,stroke-width:1px
    style NetPol fill:#ecf0f1,stroke:#333,stroke-width:1px
    style RoleB fill:#ecf0f1,stroke:#333,stroke-width:1px
    style PodMon fill:#ecf0f1,stroke:#333,stroke-width:1px
    style Templates fill:#ecf0f1,stroke:#333,stroke-width:1px
    style NIMConfigMap fill:#ecf0f1,stroke:#333,stroke-width:1px
    style PullSecret fill:#ecf0f1,stroke:#333,stroke-width:1px
