graph TD
    subgraph "Service Accounts"
        SA_Manager[controller-manager<br/>Namespace: operator-ns]
        SA_OAuth["(cluster)-oauth-proxy<br/>Namespace: user-ns<br/>Per RayCluster"]
    end

    subgraph "Role Bindings"
        CRB_Manager[manager-role-binding<br/>ClusterRoleBinding]
        CRB_OAuth["(cluster)-(ns)-auth<br/>ClusterRoleBinding<br/>Per RayCluster"]
        RB_Leader[leader-election-role-binding<br/>RoleBinding in operator-ns]
    end

    subgraph "Roles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_SystemAuth[system:auth-delegator<br/>ClusterRole]
        R_Leader[leader-election-role<br/>Role]
    end

    subgraph "API Resources - workload.codeflare.dev"
        AppWrapper[AppWrapper<br/>appwrappers, appwrappers/status,<br/>appwrappers/finalizers]
    end

    subgraph "API Resources - ray.io"
        RayCluster[RayCluster<br/>rayclusters, rayclusters/status,<br/>rayclusters/finalizers, rayjobs]
    end

    subgraph "API Resources - Core & Apps"
        CoreRes["Core Resources<br/>pods, services, secrets,<br/>serviceaccounts, events,<br/>nodes - read-only"]
        AppsRes["Apps Resources<br/>deployments, statefulsets"]
        BatchRes["Batch Resources<br/>jobs"]
    end

    subgraph "API Resources - Networking"
        NetworkRes[Networking<br/>ingresses, networkpolicies]
    end

    subgraph "API Resources - RBAC"
        RBACRes[RBAC<br/>clusterrolebindings]
    end

    subgraph "API Resources - OpenShift"
        RouteRes["Routes<br/>routes, routes/custom-host"]
        ConfigRes["Config<br/>ingresses - config.openshift.io"]
    end

    subgraph "API Resources - Kueue"
        KueueWorkload[Kueue Workloads<br/>workloads, workloads/status,<br/>workloads/finalizers]
        KueueQueues[Kueue Queues<br/>clusterqueues, resourceflavors,<br/>workloadpriorityclasses]
        PodGroups[Pod Groups<br/>scheduling.sigs.k8s.io,<br/>scheduling.x-k8s.io]
    end

    subgraph "API Resources - ML Frameworks"
        PyTorchJob[PyTorchJob<br/>kubeflow.org]
        PriorityClass[PriorityClass<br/>scheduling.k8s.io]
    end

    subgraph "API Resources - ODH"
        DSCInit[DSCInitialization<br/>dscinitialization.opendatahub.io]
    end

    subgraph "API Resources - Admission"
        Webhooks[Webhooks<br/>mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations]
        CRDs[CRDs<br/>customresourcedefinitions]
    end

    subgraph "API Resources - Auth"
        TokenReview[TokenReview<br/>authentication.k8s.io]
        SubjectAccessReview[SubjectAccessReview<br/>authorization.k8s.io]
    end

    %% Service Account to Role Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| RB_Leader
    SA_OAuth -->|bound via| CRB_OAuth

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_Leader -->|grants| R_Leader
    CRB_OAuth -->|grants| CR_SystemAuth

    %% Manager Role Permissions
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| AppWrapper
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| RayCluster
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| CoreRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| AppsRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| BatchRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| NetworkRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| RBACRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| RouteRes
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| KueueWorkload
    CR_Manager -->|get, list, watch,<br/>update, patch| KueueQueues
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| PodGroups
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| PyTorchJob
    CR_Manager -->|get, list, watch| PriorityClass
    CR_Manager -->|get, list, watch| DSCInit
    CR_Manager -->|get, list, watch,<br/>update| Webhooks
    CR_Manager -->|get, list, watch| CRDs
    CR_Manager -->|get| ConfigRes
    CR_Manager -->|create| TokenReview
    CR_Manager -->|create| SubjectAccessReview

    %% OAuth Proxy Permissions
    CR_SystemAuth -->|delegate auth| SA_OAuth

    %% Styling
    style SA_Manager fill:#4a90e2,color:#fff
    style SA_OAuth fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623
    style CR_SystemAuth fill:#f5a623
    style R_Leader fill:#f5a623
    style AppWrapper fill:#7ed321
    style RayCluster fill:#7ed321
    style KueueWorkload fill:#7ed321
    style PyTorchJob fill:#7ed321
    style DSCInit fill:#7ed321
