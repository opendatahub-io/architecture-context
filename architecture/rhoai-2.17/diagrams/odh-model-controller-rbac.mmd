graph TD
    subgraph "Service Accounts"
        SA[ServiceAccount:<br/>odh-model-controller<br/>Namespace: redhat-ods-applications]
        PromSA[ServiceAccount:<br/>prometheus-k8s<br/>Namespace: openshift-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB1[ClusterRoleBinding:<br/>odh-model-controller-rolebinding]
        CRB2[ClusterRoleBinding:<br/>kserve-prometheus-k8s]
    end

    subgraph "ClusterRoles"
        CR1[ClusterRole:<br/>odh-model-controller-role]
        CR2[ClusterRole:<br/>kserve-prometheus-k8s]
    end

    subgraph "API Resources - Core (v1)"
        Core1[configmaps, secrets<br/>serviceaccounts, services]
        Core2[endpoints, namespaces, pods]
        Core3[events]
    end

    subgraph "API Resources - KServe"
        KServe1[serving.kserve.io/v1beta1<br/>InferenceService]
        KServe2[serving.kserve.io/v1alpha1<br/>ServingRuntime, InferenceGraph]
    end

    subgraph "API Resources - Istio"
        Istio1[networking.istio.io<br/>Gateway, VirtualService]
        Istio2[security.istio.io<br/>PeerAuthentication,<br/>AuthorizationPolicy]
        Istio3[telemetry.istio.io<br/>Telemetry]
    end

    subgraph "API Resources - Service Mesh (Maistra)"
        Maistra1[maistra.io<br/>ServiceMeshControlPlane,<br/>ServiceMeshMemberRoll,<br/>ServiceMeshMember]
    end

    subgraph "API Resources - OpenShift"
        OpenShift1[route.openshift.io<br/>Route]
        OpenShift2[template.openshift.io<br/>Template]
    end

    subgraph "API Resources - Auth & Monitoring"
        Auth1[authorino.kuadrant.io<br/>AuthConfig]
        Mon1[monitoring.coreos.com<br/>ServiceMonitor, PodMonitor]
    end

    subgraph "API Resources - NIM"
        NIM1[nim.opendatahub.io/v1<br/>Account]
    end

    subgraph "API Resources - ODH Platform"
        ODH1[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        ODH2[dscinitialization.opendatahub.io<br/>DSCInitialization]
    end

    subgraph "API Resources - RBAC & Network"
        RBAC1[rbac.authorization.k8s.io<br/>ClusterRoleBinding, RoleBinding]
        Net1[networking.k8s.io<br/>NetworkPolicy, Ingress]
    end

    subgraph "API Resources - Knative"
        Knative1[serving.knative.dev/v1<br/>Service]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    PromSA -->|bound via| CRB2

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% Controller Role Permissions
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core1
    CR1 -->|create, get, list,<br/>patch, update, watch| Core2
    CR1 -->|create, patch| Core3
    CR1 -->|get, list, update,<br/>watch, finalizers| KServe1
    CR1 -->|create, get, list,<br/>update, watch, finalizers| KServe2
    CR1 -->|get, list, patch,<br/>update, watch| Istio1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Istio2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Istio3
    CR1 -->|get, list, use, watch<br/>create, delete, patch, update| Maistra1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| OpenShift1
    CR1 -->|create, delete, get,<br/>list, update, watch| OpenShift2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Auth1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Mon1
    CR1 -->|get, list, update,<br/>watch, finalizers| NIM1
    CR1 -->|get, list, watch| ODH1
    CR1 -->|get, list, watch| ODH2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| RBAC1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Net1

    %% Prometheus Role Permissions
    CR2 -->|get, list, watch| Core2
    CR2 -->|get, list, watch| Net1

    %% Special Permissions
    CR1 -->|routes/custom-host<br/>create| OpenShift1

