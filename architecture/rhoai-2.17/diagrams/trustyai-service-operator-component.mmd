graph TB
    subgraph "TrustyAI Service Operator Component"
        Operator[TrustyAI Service Operator<br/>Go/Kubebuilder v4]
        LeaderElection[Leader Election<br/>coordination.k8s.io/leases]
        Operator -.->|manages| LeaderElection
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
        LMEvalJobCR[LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    subgraph "TrustyAI Service Deployment"
        TrustyAIService[TrustyAI Service<br/>Quarkus/8080]
        OAuthProxy[OAuth Proxy Sidecar<br/>8443/HTTPS]
        TrustyAIService ---|sidecar| OAuthProxy
    end

    subgraph "LMEvalJob Execution"
        LMESDriver[LMES Driver<br/>Job Controller]
        LMESJobPod[LMES Job Pod<br/>lm-eval-harness]
        LMESDriver -->|creates| LMESJobPod
    end

    subgraph "Kubernetes Resources Created"
        Deployment[Deployment]
        Service[Service<br/>ClusterIP]
        ServiceAccount[ServiceAccount]
        PVC[PersistentVolumeClaim]
        ConfigMap[ConfigMap]
        Secret[Secret<br/>TLS/DB credentials]
        ServiceMonitor[ServiceMonitor<br/>monitoring.coreos.com]
        Route[Route<br/>route.openshift.io]
        VirtualService[VirtualService<br/>networking.istio.io]
    end

    %% Operator watches and creates
    User[User] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR

    TrustyAIServiceCR -->|watched by| Operator
    LMEvalJobCR -->|watched by| Operator

    Operator -->|creates/manages| Deployment
    Operator -->|creates| Service
    Operator -->|creates| ServiceAccount
    Operator -->|creates| PVC
    Operator -->|creates| ConfigMap
    Operator -->|creates| Secret
    Operator -->|creates| ServiceMonitor
    Operator -->|creates| Route
    Operator -->|creates| VirtualService
    Operator -->|creates| LMESDriver

    Deployment -->|runs| TrustyAIService
    Deployment -->|runs| OAuthProxy

    %% External integrations
    Operator -->|watches/patches| InferenceService[KServe InferenceService<br/>serving.kserve.io]
    Operator -->|discovers| ModelMesh[ModelMesh Deployment]
    Operator -->|integrates| Kueue[Kueue Workloads<br/>kueue.x-k8s.io]

    %% Storage backends
    TrustyAIService -->|stores data| PVC
    TrustyAIService -.->|optional| Database[(Database<br/>MySQL/PostgreSQL)]

    %% Monitoring
    ServiceMonitor -->|configures| Prometheus[Prometheus UWM]
    Prometheus -->|scrapes| TrustyAIService

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style LMEvalJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style InferenceService fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style Database fill:#bd10e0,stroke:#333
    style Prometheus fill:#50e3c2,stroke:#333
