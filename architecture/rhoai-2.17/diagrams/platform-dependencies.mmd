graph LR
    subgraph "RHOAI 2.17 Platform Components"
        RHODS[rhods-operator<br/>Platform Orchestrator]
        Dashboard[odh-dashboard<br/>Web UI]
        NotebookCtl[odh-notebook-controller<br/>Notebook Manager]
        KServe[kserve<br/>Model Serving]
        ModelMesh[modelmesh-serving<br/>Multi-Model Serving]
        ModelCtl[odh-model-controller<br/>OpenShift Integration]
        DSP[data-science-pipelines<br/>ML Pipelines]
        ModelReg[model-registry<br/>Model Metadata]
        KubeRay[kuberay<br/>Ray Lifecycle]
        CodeFlare[codeflare<br/>Ray Security]
        Kueue[kueue<br/>Job Queue]
        Training[training-operator<br/>Distributed Training]
        TrustyAI[trustyai<br/>AI Trust]
    end

    subgraph "OpenShift Platform Services"
        K8sAPI[Kubernetes API<br/>Core Platform]
        OAuth[OpenShift OAuth<br/>User AuthN]
        Router[OpenShift Router<br/>Ingress]
        ServiceCA[Service CA<br/>Certificate Mgmt]
    end

    subgraph "Service Mesh & Serverless"
        Istio[Istio Service Mesh<br/>mTLS & Traffic Mgmt<br/>v1.20+]
        Authorino[Authorino<br/>External AuthZ<br/>Kubernetes-native]
        Knative[Knative Serving<br/>Serverless Autoscaling<br/>v1.12+]
        CertManager[cert-manager<br/>Certificate Automation<br/>v1.13+]
    end

    subgraph "Observability"
        Prometheus[Prometheus<br/>Metrics Collection]
        Thanos[Thanos Querier<br/>Metrics Federation]
    end

    subgraph "Execution Backends"
        ArgoWorkflows[Argo Workflows<br/>Pipeline Execution]
        Volcano[Volcano/Scheduler-Plugins<br/>Gang Scheduling<br/>Optional]
    end

    subgraph "External Storage & Services"
        S3[S3-compatible Storage<br/>Model & Pipeline Artifacts]
        DB[PostgreSQL/MySQL<br/>Metadata Storage]
        etcd[etcd<br/>ModelMesh State]
        Registry[Container Registries<br/>registry.redhat.io]
        NGC[NVIDIA NGC API<br/>NIM Validation]
        PyPI[PyPI/Conda<br/>Python Packages]
    end

    %% Platform orchestration - rhods-operator manages all
    RHODS ==>|manages lifecycle| Dashboard
    RHODS ==>|manages lifecycle| NotebookCtl
    RHODS ==>|manages lifecycle| KServe
    RHODS ==>|manages lifecycle| ModelMesh
    RHODS ==>|manages lifecycle| ModelCtl
    RHODS ==>|manages lifecycle| DSP
    RHODS ==>|manages lifecycle| ModelReg
    RHODS ==>|manages lifecycle| KubeRay
    RHODS ==>|manages lifecycle| CodeFlare
    RHODS ==>|manages lifecycle| Kueue
    RHODS ==>|manages lifecycle| Training
    RHODS ==>|manages lifecycle| TrustyAI

    %% Dashboard dependencies (extensive integrations)
    Dashboard -->|API calls| NotebookCtl
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| ModelReg
    Dashboard -->|API calls| DSP
    Dashboard -->|metrics queries| Thanos
    Dashboard -->|user auth| OAuth
    Dashboard -->|API access| K8sAPI

    %% Notebook Controller
    NotebookCtl -->|extends| KubeflowNotebook[Kubeflow Notebook<br/>Controller]
    NotebookCtl -->|creates routes| Router
    NotebookCtl -->|oauth integration| OAuth
    NotebookCtl -->|optional RoleBinding| DSP

    %% KServe dependencies (serverless model serving)
    KServe -->|serverless autoscaling| Knative
    KServe -->|traffic management| Istio
    KServe -->|extended by| ModelCtl
    KServe -->|optional metadata| ModelReg
    KServe -->|storage| S3
    KServe -->|certificates| CertManager

    %% Model Controller (OpenShift integration layer)
    ModelCtl -->|watches & extends| KServe
    ModelCtl -->|creates gateways| Istio
    ModelCtl -->|creates routes| Router
    ModelCtl -->|creates authconfigs| Authorino
    ModelCtl -->|creates servicemonitors| Prometheus
    ModelCtl -->|NIM validation| NGC
    ModelCtl -->|API access| K8sAPI

    %% ModelMesh dependencies
    ModelMesh -->|uses CRD schemas| KServe
    ModelMesh -->|state coordination| etcd
    ModelMesh -->|optional mTLS| Istio
    ModelMesh -->|storage| S3
    ModelMesh -->|routes| Router

    %% Data Science Pipelines
    DSP -->|execution backend| ArgoWorkflows
    DSP -->|optional deployment| KServe
    DSP -->|optional registration| ModelReg
    DSP -->|metadata storage| DB
    DSP -->|artifact storage| S3
    DSP -->|routes| Router
    DSP -->|oauth| OAuth

    %% Model Registry
    ModelReg -->|metadata storage| DB
    ModelReg -->|gateway & mTLS| Istio
    ModelReg -->|authentication| Authorino
    ModelReg -->|routes| Router
    ModelReg -->|API access| K8sAPI

    %% Distributed Computing - Ray ecosystem
    CodeFlare -->|watches & reconciles| KubeRay
    CodeFlare -->|workload scheduling| Kueue
    CodeFlare -->|dashboard auth| OAuth
    CodeFlare -->|routes| Router
    CodeFlare -->|cert generation| ServiceCA
    KubeRay -->|metrics export| Prometheus
    KubeRay -->|API access| K8sAPI
    KubeRay -->|storage| S3

    %% Job Queue (Kueue)
    Kueue -->|queues| Training
    Kueue -->|queues| KubeRay
    Kueue -->|queues| CodeFlare
    Kueue -->|queues| K8sBatch[Kubernetes<br/>Batch Jobs]
    Kueue -->|API access| K8sAPI

    %% Training Operator
    Training -->|optional gang scheduling| Volcano
    Training -->|queue integration| Kueue
    Training -->|storage| S3
    Training -->|API access| K8sAPI

    %% TrustyAI
    TrustyAI -->|monitors| KServe
    TrustyAI -->|monitors| ModelMesh
    TrustyAI -->|metrics export| Prometheus
    TrustyAI -->|queue LMEvalJobs| Kueue
    TrustyAI -->|data storage| DB
    TrustyAI -->|oauth| OAuth
    TrustyAI -->|routes| Router

    %% All components depend on Kubernetes API
    RHODS -->|API access| K8sAPI

    %% External dependencies shared by multiple components
    NotebookCtl -.->|workbench pods pull packages| PyPI
    Dashboard -.->|pulls images| Registry
    KServe -.->|pulls images| Registry
    ModelMesh -.->|pulls images| Registry

