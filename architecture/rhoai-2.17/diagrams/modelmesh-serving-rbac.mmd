graph TD
    subgraph "Service Accounts"
        SA_Controller["modelmesh-controller<br/>Namespace: redhat-ods-applications"]
        SA_Runtime["modelmesh-serving-sa<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole: modelmesh-controller-role"
        CR_Controller[modelmesh-controller-role]

        CR_Core["Core API<br/>────────<br/>configmaps: *<br/>secrets: *<br/>services, services/finalizers: *<br/>namespaces, namespaces/finalizers: get,list,patch,update,watch<br/>endpoints, persistentvolumeclaims: get,list,watch"]

        CR_Apps["apps<br/>────────<br/>deployments, deployments/finalizers: *"]

        CR_KServe["serving.kserve.io<br/>────────<br/>inferenceservices: *<br/>inferenceservices/status: get,patch,update<br/>inferenceservices/finalizers: get,patch,update<br/>predictors: *<br/>predictors/status: get,patch,update<br/>predictors/finalizers: get,patch,update<br/>servingruntimes: *<br/>servingruntimes/status: get,patch,update<br/>servingruntimes/finalizers: get,patch,update<br/>clusterservingruntimes: *<br/>clusterservingruntimes/status: get,patch,update<br/>clusterservingruntimes/finalizers: get,patch,update"]

        CR_AutoScaling["autoscaling<br/>────────<br/>horizontalpodautoscalers: create,delete,get,list,update,watch<br/>horizontalpodautoscalers/status: create,delete,get,list,update,watch"]

        CR_Monitoring["monitoring.coreos.com<br/>────────<br/>servicemonitors: *"]

        CR_Controller --> CR_Core
        CR_Controller --> CR_Apps
        CR_Controller --> CR_KServe
        CR_Controller --> CR_AutoScaling
        CR_Controller --> CR_Monitoring
    end

    subgraph "ClusterRole: leader-election-role"
        CR_LeaderElection[leader-election-role<br/>Namespace-scoped]

        CR_LE_Core["Core API<br/>────────<br/>configmaps: get,list,watch,create,update,patch"]

        CR_LE_Coordination["coordination.k8s.io<br/>────────<br/>leases: get,list,watch,create,update,patch"]

        CR_LeaderElection --> CR_LE_Core
        CR_LeaderElection --> CR_LE_Coordination
    end

    subgraph "ClusterRole: auth-proxy-client-clusterrole"
        CR_AuthProxy[auth-proxy-client-clusterrole]

        CR_AP_Auth["authentication.k8s.io<br/>────────<br/>tokenreviews: create"]

        CR_AP_Authz["authorization.k8s.io<br/>────────<br/>subjectaccessreviews: create"]

        CR_AuthProxy --> CR_AP_Auth
        CR_AuthProxy --> CR_AP_Authz
    end

    subgraph "Role Bindings"
        CRB_Controller[ClusterRoleBinding:<br/>modelmesh-controller-role-binding<br/>Cluster-wide]

        RB_Controller[RoleBinding:<br/>modelmesh-controller-role-binding<br/>Per-namespace]

        RB_LeaderElection[RoleBinding:<br/>leader-election-role-binding<br/>Namespace: redhat-ods-applications]

        RB_AuthProxy[RoleBinding:<br/>auth-proxy-role-binding<br/>Namespace: redhat-ods-applications]

        RB_RestrictedSCC["RoleBinding:<br/>restricted-scc-role-binding<br/>Namespace: user-namespace"]
    end

    subgraph "API Resources"
        API_Core["Core API Resources<br/>────────<br/>ConfigMaps<br/>Secrets<br/>Services<br/>Namespaces<br/>Endpoints<br/>PVCs"]

        API_Apps["apps<br/>────────<br/>Deployments"]

        API_KServe["serving.kserve.io<br/>────────<br/>InferenceService<br/>Predictor<br/>ServingRuntime<br/>ClusterServingRuntime"]

        API_AutoScaling["autoscaling<br/>────────<br/>HorizontalPodAutoscaler"]

        API_Monitoring["monitoring.coreos.com<br/>────────<br/>ServiceMonitor"]

        API_Coordination["coordination.k8s.io<br/>────────<br/>Lease"]

        API_Auth["authentication.k8s.io<br/>────────<br/>TokenReview"]

        API_Authz["authorization.k8s.io<br/>────────<br/>SubjectAccessReview"]
    end

    %% Service Account to Role Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Controller
    SA_Controller -->|bound via| RB_LeaderElection
    SA_Controller -->|bound via| RB_AuthProxy
    SA_Runtime -->|bound via| RB_RestrictedSCC

    %% Role Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    RB_Controller -->|grants| CR_Controller
    RB_LeaderElection -->|grants| CR_LeaderElection
    RB_AuthProxy -->|grants| CR_AuthProxy

    %% Cluster Role to API Resources
    CR_Core -->|"create,delete,get,list,patch,update,watch"| API_Core
    CR_Apps -->|"create,delete,get,list,patch,update,watch"| API_Apps
    CR_KServe -->|"create,delete,get,list,patch,update,watch"| API_KServe
    CR_AutoScaling -->|"create,delete,get,list,update,watch"| API_AutoScaling
    CR_Monitoring -->|"create,delete,get,list,patch,update,watch"| API_Monitoring
    CR_LE_Core -->|"get,list,watch,create,update,patch"| API_Core
    CR_LE_Coordination -->|"get,list,watch,create,update,patch"| API_Coordination
    CR_AP_Auth -->|"create"| API_Auth
    CR_AP_Authz -->|"create"| API_Authz

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Runtime fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CR_Core fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_Apps fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_KServe fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_AutoScaling fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_Monitoring fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_LE_Core fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_LE_Coordination fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_AP_Auth fill:#fff,stroke:#333,stroke-width:1px,color:#000
    style CR_AP_Authz fill:#fff,stroke:#333,stroke-width:1px,color:#000

    style CRB_Controller fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB_Controller fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB_LeaderElection fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB_AuthProxy fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB_RestrictedSCC fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    style API_Core fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_Apps fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_KServe fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_AutoScaling fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_Monitoring fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_Coordination fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_Auth fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style API_Authz fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
