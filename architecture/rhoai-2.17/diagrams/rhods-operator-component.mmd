graph TB
    subgraph "RHODS Operator"
        MainController[rhods-operator<br/>Main Controller]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS]

        subgraph "Core Controllers"
            DSCController[DataScienceCluster<br/>Controller]
            DSCIController[DSCInitialization<br/>Controller]
        end

        subgraph "Component Controllers (12)"
            DashboardCtrl[Dashboard Controller]
            WorkbenchesCtrl[Workbenches Controller]
            KServeCtrl[KServe Controller]
            ModelMeshCtrl[ModelMesh Controller]
            DSPCtrl[DSP Controller]
            RayCtrl[Ray Controller]
            CodeFlareCtrl[CodeFlare Controller]
            TrustyAICtrl[TrustyAI Controller]
            TrainingCtrl[Training Operator Controller]
            KueueCtrl[Kueue Controller]
            ModelRegCtrl[ModelRegistry Controller]
            ModelControllerCtrl[ModelController Controller]
        end

        subgraph "Service Controllers"
            AuthCtrl[Auth Service Controller]
            MonitoringCtrl[Monitoring Service Controller]
        end

        subgraph "Utility Controllers"
            SecretGen[SecretGenerator Controller]
            CertGen[CertConfigmapGenerator Controller]
            SetupCtrl[Setup Controller]
        end

        MainController --> DSCController
        MainController --> DSCIController
        MainController --> WebhookServer
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        ComponentCRs[Component CRs<br/>Dashboard, Workbenches, KServe, etc.]
        ServiceCRs[Service CRs<br/>Auth, Monitoring]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ServiceMesh[Service Mesh Operator<br/>Istio]
        Serverless[Serverless Operator<br/>Knative]
        Authorino[Authorino Operator]
    end

    subgraph "Deployed Components"
        Dashboard[ODH Dashboard]
        Workbenches[Jupyter Workbenches]
        KServe[KServe Operator]
        ModelMesh[ModelMesh Serving]
        DSP[Data Science Pipelines]
        Ray[Ray Operator]
        CodeFlare[CodeFlare Operator]
        TrustyAI[TrustyAI Service]
        Training[Training Operator]
        Kueue[Kueue]
        ModelReg[Model Registry]
    end

    subgraph "Monitoring Stack"
        Prometheus[Prometheus<br/>9091/TCP HTTPS]
        Alertmanager[Alertmanager<br/>9093/TCP HTTPS]
        BlackboxExporter[Blackbox Exporter<br/>9115/TCP HTTP]
    end

    %% User interactions
    User[Admin/User] -->|creates| DSC
    User -->|creates| DSCI

    %% CRD watch
    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController

    %% Webhook validation
    DSC -.->|validates/mutates| WebhookServer
    DSCI -.->|validates| WebhookServer

    %% Component deployments
    DSCController -->|creates| ComponentCRs
    DSCIController -->|creates| ServiceCRs

    ComponentCRs -->|watched by| DashboardCtrl
    ComponentCRs -->|watched by| WorkbenchesCtrl
    ComponentCRs -->|watched by| KServeCtrl
    ComponentCRs -->|watched by| ModelMeshCtrl
    ComponentCRs -->|watched by| DSPCtrl
    ComponentCRs -->|watched by| RayCtrl
    ComponentCRs -->|watched by| CodeFlareCtrl
    ComponentCRs -->|watched by| TrustyAICtrl
    ComponentCRs -->|watched by| TrainingCtrl
    ComponentCRs -->|watched by| KueueCtrl
    ComponentCRs -->|watched by| ModelRegCtrl
    ComponentCRs -->|watched by| ModelControllerCtrl

    ServiceCRs -->|watched by| AuthCtrl
    ServiceCRs -->|watched by| MonitoringCtrl

    %% Component controllers deploy components
    DashboardCtrl -->|deploys| Dashboard
    WorkbenchesCtrl -->|deploys| Workbenches
    KServeCtrl -->|deploys| KServe
    ModelMeshCtrl -->|deploys| ModelMesh
    DSPCtrl -->|deploys| DSP
    RayCtrl -->|deploys| Ray
    CodeFlareCtrl -->|deploys| CodeFlare
    TrustyAICtrl -->|deploys| TrustyAI
    TrainingCtrl -->|deploys| Training
    KueueCtrl -->|deploys| Kueue
    ModelRegCtrl -->|deploys| ModelReg

    %% Service controllers
    MonitoringCtrl -->|deploys| Prometheus
    MonitoringCtrl -->|deploys| Alertmanager
    MonitoringCtrl -->|deploys| BlackboxExporter

    %% K8s API interactions
    MainController -->|CRUD operations| K8sAPI
    SecretGen -->|creates secrets| K8sAPI
    CertGen -->|creates configmaps| K8sAPI

    %% External dependencies
    KServeCtrl -.->|requires| ServiceMesh
    KServeCtrl -.->|requires| Serverless
    AuthCtrl -.->|requires| Authorino

    %% Monitoring
    Prometheus -->|scrapes metrics| MainController
    Prometheus -->|scrapes metrics| Dashboard
    Prometheus -->|scrapes metrics| KServe

