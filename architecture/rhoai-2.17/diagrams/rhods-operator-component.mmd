    style DSCController fill:#4a90e2,stroke:#333
    style DSCIController fill:#4a90e2,stroke:#333
    style WebhookServer fill:#4a90e2,stroke:#333
    style DSC fill:#f5a623,stroke:#333
    style DSCI fill:#f5a623,stroke:#333
    style ServiceMesh fill:#999,stroke:#333
    style Serverless fill:#999,stroke:#333
    style Authorino fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Alertmanager fill:#e8e8e8,stroke:#333
