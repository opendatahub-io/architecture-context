graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRoleBinding"
        CRB[training-operator<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRole"
        CR[training-operator<br/>Permissions across all namespaces]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR

    subgraph "Core Resources (API Group: '')"
        ConfigMaps[ConfigMaps<br/>Verbs: create, list, update, watch]
        Events[Events<br/>Verbs: create, delete, get, list, patch, update, watch]
        Pods[Pods<br/>Verbs: create, delete, get, list, patch, update, watch]
        PodsExec[Pods/exec<br/>Verbs: create]
        ServiceAccounts[ServiceAccounts<br/>Verbs: create, get, list, watch]
        Services[Services<br/>Verbs: create, delete, get, list, watch]
    end

    CR -->|manages| ConfigMaps
    CR -->|manages| Events
    CR -->|full control| Pods
    CR -->|exec into| PodsExec
    CR -->|manages| ServiceAccounts
    CR -->|manages| Services

    subgraph "Autoscaling Resources"
        HPA[HorizontalPodAutoscalers<br/>API Group: autoscaling<br/>Verbs: create, delete, get, list, patch, update, watch<br/>Used for: PyTorch Elastic]
    end

    CR -->|full control| HPA

    subgraph "Training Job CRDs (API Group: kubeflow.org)"
        PyTorchJobs[PyTorchJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        TFJobs[TFJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        MPIJobs[MPIJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        XGBoostJobs[XGBoostJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        MXJobs[MXJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        PaddleJobs[PaddleJobs<br/>+ status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    CR -->|full lifecycle| PyTorchJobs
    CR -->|full lifecycle| TFJobs
    CR -->|full lifecycle| MPIJobs
    CR -->|full lifecycle| XGBoostJobs
    CR -->|full lifecycle| MXJobs
    CR -->|full lifecycle| PaddleJobs

    subgraph "RBAC Resources (API Group: rbac.authorization.k8s.io)"
        Roles[Roles<br/>Verbs: create, list, update, watch]
        RoleBindings[RoleBindings<br/>Verbs: create, list, update, watch]
    end

    CR -->|manages| Roles
    CR -->|manages| RoleBindings

    subgraph "Gang Scheduling Resources (Optional)"
        VolcanoPodGroups[PodGroups<br/>API Group: scheduling.volcano.sh<br/>Verbs: create, delete, get, list, patch, update, watch]
        SchedulerPluginsPodGroups[PodGroups<br/>API Group: scheduling.x-k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    CR -.->|optional gang scheduling| VolcanoPodGroups
    CR -.->|optional gang scheduling| SchedulerPluginsPodGroups

    subgraph "Scope & Limitations"
        Scope[Scope: Cluster-wide<br/>All namespaces<br/><br/>Limitations:<br/>- No cluster-admin privileges<br/>- No node/namespace management<br/>- No custom resource definition creation<br/>- Read-only for most cluster resources]
    end

    CR -.->|applies to| Scope

    subgraph "Security Context"
        SecContext[Pod Security Context:<br/>- Non-root user UID 65532<br/>- No privilege escalation<br/>- No special capabilities<br/>- ServiceAccount token auto-mounted<br/>- Token auto-rotated by kubelet]
    end

    SA -.->|runs with| SecContext

    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff

    style ConfigMaps fill:#7ed321,stroke:#333,stroke-width:1px
    style Events fill:#7ed321,stroke:#333,stroke-width:1px
    style Pods fill:#7ed321,stroke:#333,stroke-width:1px
    style PodsExec fill:#7ed321,stroke:#333,stroke-width:1px
    style ServiceAccounts fill:#7ed321,stroke:#333,stroke-width:1px
    style Services fill:#7ed321,stroke:#333,stroke-width:1px

    style HPA fill:#9c27b0,stroke:#333,stroke-width:1px,color:#fff

    style PyTorchJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff
    style TFJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff
    style MPIJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff
    style XGBoostJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff
    style MXJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff
    style PaddleJobs fill:#2196f3,stroke:#333,stroke-width:1px,color:#fff

    style Roles fill:#ff9800,stroke:#333,stroke-width:1px
    style RoleBindings fill:#ff9800,stroke:#333,stroke-width:1px

    style VolcanoPodGroups fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style SchedulerPluginsPodGroups fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    style Scope fill:#e8e8e8,stroke:#333,stroke-width:1px
    style SecContext fill:#fce4ec,stroke:#e91e63,stroke-width:1px
