graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Browser[User Browser]
        KubectlUser[User kubectl/oc]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router /<br/>Ingress Controller<br/>443/TCP to 443/TCP<br/>TLS 1.3 to TLS 1.2+ re-encrypt"]
    end

    subgraph UserNamespace["USER NAMESPACE - Application Layer"]
        direction TB

        subgraph RayCluster["RayCluster: (cluster)"]
            OAuthProxy["OAuth Proxy Sidecar<br/>SA: (cluster)-oauth-proxy<br/>Port: 443/TCP<br/>TLS 1.2+"]
            RayHead["Ray Head Pod<br/>SA: default<br/>Label: ray.io/node-type=head"]
            RayWorker["Ray Worker Pods<br/>Label: ray.io/node-type=worker"]
        end

        OAuthService["Service: (cluster)-oauth<br/>443/TCP"]
        RayClientService["Service: (cluster)-head<br/>10001/TCP"]
        NetworkPolicyHead["NetworkPolicy: (cluster)-head<br/>Allow: same cluster, namespace, KubeRay, monitoring"]
        NetworkPolicyWorker["NetworkPolicy: (cluster)-workers<br/>Allow: same cluster only"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE - Control Plane<br/>Namespace: redhat-ods-applications"]
        direction TB

        Operator["CodeFlare Operator Manager<br/>SA: controller-manager<br/>runAsNonRoot=true<br/>Replicas: 1"]
        WebhookService["Service: codeflare-operator-webhook-service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+"]
        MetricsService["Service: codeflare-operator-manager-metrics<br/>8080/TCP HTTP"]

        Operator -->|provides| WebhookService
        Operator -->|exposes| MetricsService
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP<br/>HTTPS TLS 1.2+"]
        Prometheus["Prometheus<br/>Namespace: openshift-monitoring"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        KubeRay["KubeRay Operator<br/>Namespace: opendatahub/<br/>redhat-ods-applications<br/>8265/TCP HTTP"]
        Kueue["Kueue - Optional<br/>API: kueue.x-k8s.io<br/>6443/TCP HTTPS TLS 1.2+"]
    end

    %% External to Ingress
    Browser -->|HTTPS/443<br/>TLS 1.3<br/>Session Token| Router

    %% Ingress to OAuth Proxy
    Router -->|HTTPS/443<br/>TLS 1.2+ re-encrypt<br/>Session Cookie| OAuthService
    OAuthService --> OAuthProxy

    %% OAuth Proxy to OAuth Server
    OAuthProxy -->|HTTPS/443<br/>TLS 1.2+<br/>Token Validation| OAuthServer

    %% OAuth Proxy to Ray Dashboard
    OAuthProxy -->|HTTP/8265<br/>Localhost<br/>No Auth| RayHead

    %% Ray Internal Communication
    RayHead -->|All ports<br/>NetworkPolicy allowed| RayWorker

    %% User to API
    KubectlUser -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% API to Webhook
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>API Server client cert| WebhookService

    %% Operator to API
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token| K8sAPI

    %% Operator creates resources
    Operator -.->|creates| OAuthProxy
    Operator -.->|creates| OAuthService
    Operator -.->|creates| NetworkPolicyHead
    Operator -.->|creates| NetworkPolicyWorker
    Operator -.->|creates| RayClientService

    %% Operator to Kueue
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token<br/>Create Workload| Kueue

    %% KubeRay to Ray Head
    KubeRay -->|HTTP/8265<br/>10001/TCP<br/>NetworkPolicy allowed| RayHead

    %% Prometheus to Metrics
    Prometheus -->|HTTP/8080<br/>Bearer Token| MetricsService

    %% Ray Client API
    RayClientService -->|gRPC/10001<br/>mTLS - optional<br/>Client cert| RayHead

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef usernamespace fill:#e1f5e1,stroke:#4caf50,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externaldep fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser,KubectlUser external
    class Router ingress
    class OAuthProxy,RayHead,RayWorker,OAuthService,RayClientService,NetworkPolicyHead,NetworkPolicyWorker usernamespace
    class Operator,WebhookService,MetricsService operator
    class K8sAPI,OAuthServer,Prometheus platform
    class KubeRay,Kueue externaldep
