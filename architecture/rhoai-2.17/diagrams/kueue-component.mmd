graph TB
    subgraph "Kueue Component"
        Controller[Controller Manager<br/>Deployment]
        Webhook[Webhook Server<br/>Port 9443/TCP]
        Visibility[Visibility API Server<br/>Port 8082/TCP]

        Controller -->|includes| Webhook
        Controller -->|includes| Visibility

        subgraph "Core Controllers"
            CQController[ClusterQueue Controller]
            LQController[LocalQueue Controller]
            WLController[Workload Controller]
            RFController[ResourceFlavor Controller]
            ACController[AdmissionCheck Controller]
        end

        Controller -->|manages| CQController
        Controller -->|manages| LQController
        Controller -->|manages| WLController
        Controller -->|manages| RFController
        Controller -->|manages| ACController
    end

    subgraph "Custom Resources"
        ClusterQueue[ClusterQueue CR<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue CR<br/>kueue.x-k8s.io/v1beta1]
        Workload[Workload CR<br/>kueue.x-k8s.io/v1beta1]
        ResourceFlavor[ResourceFlavor CR<br/>kueue.x-k8s.io/v1beta1]
        AdmissionCheck[AdmissionCheck CR<br/>kueue.x-k8s.io/v1beta1]
        WorkloadPriorityClass[WorkloadPriorityClass CR<br/>kueue.x-k8s.io/v1beta1]
    end

    subgraph "Job Frameworks"
        BatchJob[Batch Jobs<br/>batch/v1]
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v2beta1]
        RayJob[RayJob<br/>ray.io/v1]
        RayCluster[RayCluster<br/>ray.io/v1]
        JobSet[JobSet<br/>jobset.x-k8s.io/v1alpha2]
        Pod[Pod<br/>v1]
    end

    User[User/System] -->|creates job| BatchJob
    User -->|creates job| PyTorchJob
    User -->|creates job| TFJob
    User -->|creates job| RayJob

    BatchJob -->|watched/mutated by| Webhook
    PyTorchJob -->|watched/mutated by| Webhook
    TFJob -->|watched/mutated by| Webhook
    MPIJob -->|watched/mutated by| Webhook
    RayJob -->|watched/mutated by| Webhook
    RayCluster -->|watched/mutated by| Webhook
    JobSet -->|watched/mutated by| Webhook
    Pod -->|watched/mutated by| Webhook

    Webhook -->|creates| Workload

    CQController -->|reconciles| ClusterQueue
    LQController -->|reconciles| LocalQueue
    WLController -->|reconciles| Workload
    RFController -->|reconciles| ResourceFlavor
    ACController -->|reconciles| AdmissionCheck

    LocalQueue -->|references| ClusterQueue
    Workload -->|queued in| LocalQueue
    ClusterQueue -->|uses| ResourceFlavor
    Workload -->|requires| AdmissionCheck
    Workload -->|has priority| WorkloadPriorityClass

    WLController -->|admits/suspends| BatchJob
    WLController -->|admits/suspends| PyTorchJob
    WLController -->|admits/suspends| TFJob
    WLController -->|admits/suspends| MPIJob
    WLController -->|admits/suspends| RayJob

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP]
        TrainingOp[Training Operator<br/>Kubeflow]
        KubeRay[KubeRay Operator]
        CodeFlare[CodeFlare Operator]
        Autoscaler[Cluster Autoscaler]
    end

    Controller -->|watches/updates| K8sAPI
    Webhook -->|validates via| K8sAPI
    Visibility -->|queries via| K8sAPI

    TrainingOp -->|provides CRDs| PyTorchJob
    TrainingOp -->|provides CRDs| TFJob
    TrainingOp -->|provides CRDs| MPIJob
    KubeRay -->|provides CRDs| RayJob
    KubeRay -->|provides CRDs| RayCluster
    CodeFlare -->|provides AppWrapper| Controller

    Controller -->|creates ProvisioningRequests| Autoscaler

    subgraph "Monitoring"
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    Prometheus -->|scrapes /metrics<br/>8443/TCP HTTPS| Controller

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style Visibility fill:#4a90e2,stroke:#333,stroke-width:2px
    style ClusterQueue fill:#f5a623,stroke:#333
    style LocalQueue fill:#f5a623,stroke:#333
    style Workload fill:#f5a623,stroke:#333
    style ResourceFlavor fill:#f5a623,stroke:#333
    style AdmissionCheck fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style TrainingOp fill:#7ed321,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333
    style CodeFlare fill:#7ed321,stroke:#333
    style Autoscaler fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
