graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ Edge<br/>OAuth Proxy (optional)"]
        Route["Workbench Route<br/>Edge TLS Termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod Network)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            Service["Workbench Service<br/>ClusterIP<br/>8888/8787/8080 TCP"]

            subgraph WorkbenchPod["Workbench Pod"]
                JupyterLab["JupyterLab<br/>8888/TCP<br/>Token Auth"]
                RStudio["RStudio Server<br/>8787/TCP<br/>Basic/OAuth"]
                CodeServer["Code Server<br/>8080/TCP<br/>Token Auth"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        PyPI["PyPI/Conda<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Keys"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>22/TCP SSH<br/>Git Credentials"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth/Bearer| Router
    Router -->|TLS Termination| Route
    Route -->|HTTP/8888<br/>Token forwarded| Service
    Service -->|HTTP| JupyterLab
    Service -->|HTTP| RStudio
    Service -->|HTTP| CodeServer

    JupyterLab -->|HTTPS/443<br/>TLS 1.2+| PyPI
    JupyterLab -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    JupyterLab -->|HTTPS/443<br/>SSH/22<br/>Credentials| Git
    JupyterLab -->|HTTPS/443<br/>Pull Secrets| Registry

    RStudio -->|HTTPS/443| PyPI
    RStudio -->|HTTPS/443| S3
    RStudio -->|HTTPS/443| Git

    CodeServer -->|HTTPS/443| PyPI
    CodeServer -->|HTTPS/443| Git

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workbench fill:#cce5ff,stroke:#0066cc,stroke-width:2px

    class User external
    class Router,Route ingress
    class Service internal
    class JupyterLab,RStudio,CodeServer workbench
    class PyPI,S3,Git,Registry externalservice
