graph TB
    subgraph "Service Account"
        SA[odh-dashboard<br/>ServiceAccount]
    end

    subgraph "Cluster-Level Permissions"
        direction TB

        CRB1[ClusterRoleBinding:<br/>odh-dashboard]
        CRB2[ClusterRoleBinding:<br/>odh-dashboard-auth-delegator]
        CRB3[ClusterRoleBinding:<br/>odh-dashboard-cluster-monitoring-view]

        CR1[ClusterRole:<br/>odh-dashboard]
        CR2[ClusterRole:<br/>system:auth-delegator]
        CR3[ClusterRole:<br/>cluster-monitoring-view]
    end

    subgraph "Namespace-Level Permissions"
        direction TB

        RB1[RoleBinding:<br/>odh-dashboard]
        RB2[RoleBinding:<br/>odh-dashboard-model-serving]
        RB3[RoleBinding:<br/>odh-dashboard-image-puller]

        R1[Role:<br/>odh-dashboard]
        R2[Role:<br/>odh-dashboard-model-serving]
        CR4[ClusterRole:<br/>system:image-puller]
    end

    subgraph "ClusterRole: odh-dashboard Permissions"
        direction LR

        CP1["storage.k8s.io/storageclasses:<br/>update, patch"]
        CP2["core/nodes:<br/>get, list"]
        CP3["machine.openshift.io/*:<br/>get, list"]
        CP4["operators.coreos.com/*:<br/>get, list, watch"]
        CP5["core/configmaps,secrets,pvcs:<br/>create, delete, get, list, patch, update, watch"]
        CP6["route.openshift.io/routes:<br/>get, list, watch"]
        CP7["console.openshift.io/consolelinks:<br/>get, list, watch"]
        CP8["user.openshift.io/groups,users:<br/>get, list, watch"]
        CP9["core/pods,services,serviceaccounts:<br/>get, list, watch"]
        CP10["core/namespaces:<br/>patch"]
        CP11["rbac.authorization.k8s.io/*:<br/>get, list, watch, create, update, patch, delete"]
        CP12["kubeflow.org/notebooks:<br/>get, list, watch, create, update, patch, delete"]
        CP13["datasciencecluster.opendatahub.io/*:<br/>list, watch, get"]
        CP14["serving.kserve.io/inferenceservices:<br/>get, list, watch"]
        CP15["modelregistry.opendatahub.io/modelregistries:<br/>get, list, watch, create, update, patch, delete"]
        CP16["nim.opendatahub.io/accounts:<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Role: odh-dashboard Permissions (Namespace)"
        direction LR

        NP1["dashboard.opendatahub.io/acceleratorprofiles:<br/>create, get, list, update, patch, delete"]
        NP2["batch/cronjobs,jobs:<br/>create, delete, get, list, patch, update, watch"]
        NP3["image.openshift.io/imagestreams:<br/>create, get, list, update, patch, delete"]
        NP4["build.openshift.io/builds,buildconfigs:<br/>get, list, watch, create, patch, delete"]
        NP5["apps/deployments:<br/>patch, update"]
        NP6["opendatahub.io/odhdashboardconfigs:<br/>get, list, watch, create, update, patch, delete"]
        NP7["kubeflow.org/notebooks:<br/>get, list, watch, create, update, patch, delete"]
        NP8["template.openshift.io/templates:<br/>* (all verbs)"]
        NP9["serving.kserve.io/servingruntimes:<br/>* (all verbs)"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    SA -->|bound via| RB2
    SA -->|bound via| RB3

    %% Cluster Role Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% Role Bindings to Roles
    RB1 -->|grants| R1
    RB2 -->|grants| R2
    RB3 -->|grants| CR4

    %% ClusterRole to Permissions
    CR1 -->|allows| CP1
    CR1 -->|allows| CP2
    CR1 -->|allows| CP3
    CR1 -->|allows| CP4
    CR1 -->|allows| CP5
    CR1 -->|allows| CP6
    CR1 -->|allows| CP7
    CR1 -->|allows| CP8
    CR1 -->|allows| CP9
    CR1 -->|allows| CP10
    CR1 -->|allows| CP11
    CR1 -->|allows| CP12
    CR1 -->|allows| CP13
    CR1 -->|allows| CP14
    CR1 -->|allows| CP15
    CR1 -->|allows| CP16

    %% Role to Permissions
    R1 -->|allows| NP1
    R1 -->|allows| NP2
    R1 -->|allows| NP3
    R1 -->|allows| NP4
    R1 -->|allows| NP5
    R1 -->|allows| NP6
    R1 -->|allows| NP7
    R1 -->|allows| NP8
    R1 -->|allows| NP9

    %% Special Roles
    CR2 -.->|enables| AuthDelegation[Token Review<br/>SubjectAccessReview]
    CR3 -.->|enables| MonitoringAccess[Thanos/Prometheus<br/>Metrics Access]
    CR4 -.->|enables| ImagePull[Pull Images from<br/>Internal Registry]

