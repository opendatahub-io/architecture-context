graph TB
    subgraph "CodeFlare Operator"
        Manager[Operator Manager<br/>Deployment]
        RayController[RayCluster Controller]
        AppWrapperController[AppWrapper Controller<br/>Embedded]
        MutatingWebhook[Mutating Webhook<br/>9443/TCP HTTPS]
        ValidatingWebhook[Validating Webhook<br/>9443/TCP HTTPS]
        MetricsExporter[Metrics Exporter<br/>8080/TCP HTTP]
        CertController[Certificate Controller]

        Manager --> RayController
        Manager --> AppWrapperController
        Manager --> MutatingWebhook
        Manager --> ValidatingWebhook
        Manager --> MetricsExporter
        Manager --> CertController
    end

    subgraph "Custom Resources"
        AppWrapperCR[AppWrapper CR<br/>workload.codeflare.dev/v1beta2]
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
    end

    subgraph "Created Resources per RayCluster"
        OAuthProxy[OAuth Proxy Sidecar]
        ServiceAccount["ServiceAccount<br/>(cluster)-oauth-proxy"]
        ClusterRoleBinding["ClusterRoleBinding<br/>(cluster)-(ns)-auth"]
        CASecret["CA Secret<br/>ca-secret-(cluster)"]
        OAuthService["Service<br/>(cluster)-oauth"]
        Route["Route/Ingress<br/>ray-dashboard-(cluster)"]
        NetworkPolicy["NetworkPolicy<br/>(cluster)-head/workers"]
    end

    subgraph "External Dependencies"
        KubeRay[KubeRay Operator<br/>v1.1.0]
        Kueue[Kueue<br/>v0.8.3<br/>Optional]
        K8sAPI[Kubernetes API Server<br/>6443/TCP]
        OpenShiftOAuth[OpenShift OAuth Server<br/>Optional]
    end

    User[User] -->|creates| AppWrapperCR
    User -->|creates| RayClusterCR

    AppWrapperCR -->|watched by| AppWrapperController
    RayClusterCR -->|watched by| RayController

    RayController -->|creates| OAuthProxy
    RayController -->|creates| ServiceAccount
    RayController -->|creates| ClusterRoleBinding
    RayController -->|creates| CASecret
    RayController -->|creates| OAuthService
    RayController -->|creates| Route
    RayController -->|creates| NetworkPolicy

    AppWrapperController -->|integrates with| Kueue
    RayController -->|depends on| KubeRay

    Manager -->|watches| K8sAPI
    OAuthProxy -->|authenticates via| OpenShiftOAuth

    Prometheus[Prometheus] -->|scrapes| MetricsExporter

