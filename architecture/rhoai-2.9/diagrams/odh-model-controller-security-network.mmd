graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → varies<br/>TLS 1.3 Edge Termination<br/>Route: per ISVC"]
        Gateway["Istio Ingress Gateway<br/>istio-system NS"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph AuthProvider["Auth Provider NS"]
            Authorino["Authorino Service<br/>50051/TCP gRPC mTLS<br/>JWT Validation<br/>AuthConfig per ISVC"]
        end

        subgraph UserNS["User Namespace"]
            ISVC["InferenceService Pod<br/>SA: default-editor<br/>Sidecar: Istio proxy<br/>mTLS STRICT<br/>NetworkPolicy: Controller-managed"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph ControllerNS["redhat-ods-applications"]
            Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>Replicas: 3 (HA)<br/>User: 65532 (non-root)"]
            WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>mTLS from API Server"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>No auth"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Auth: ServiceAccount Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>{monitoring-namespace}<br/>SA: prometheus-custom<br/>RoleBinding: prometheus-ns-access"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Storage["Model Storage<br/>S3: 443/TCP HTTPS TLS1.2+<br/>Auth: Storage Secret<br/>PVC: Local filesystem"]
    end

    %% External Request Flow
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token JWT<br/>optional per ISVC| Router
    Router -->|HTTP/HTTPS<br/>TLS mesh<br/>VirtualService routing| Gateway
    Gateway -->|gRPC/50051<br/>mTLS STRICT<br/>Service Identity<br/>if auth enabled| Authorino
    Gateway -->|HTTP/gRPC<br/>mTLS STRICT<br/>Service Identity<br/>PeerAuthentication| ISVC

    %% Model Loading
    ISVC -->|HTTPS/443 S3<br/>TLS 1.2+<br/>Storage credentials<br/>or local PVC| Storage

    %% Control Plane
    Controller -->|Watch CRDs<br/>Manage resources<br/>HTTPS/6443 TLS1.3<br/>ServiceAccount Token| K8sAPI
    K8sAPI -.->|Webhook validation<br/>HTTPS/9443<br/>mTLS client cert| WebhookSvc

    %% Controller creates resources
    Controller -.->|Creates| Routes["Routes<br/>AuthConfigs<br/>NetworkPolicies<br/>VirtualServices<br/>PeerAuthentication<br/>Telemetry<br/>ServiceMonitors<br/>ServiceMeshMemberRoll"]

    %% Monitoring
    Prometheus -->|Scrape metrics<br/>HTTP/HTTPS<br/>TLS mesh<br/>ServiceAccount Token<br/>ServiceMonitor/PodMonitor| ISVC
    Prometheus -->|Scrape metrics<br/>HTTP/8080<br/>No auth| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router,Gateway ingress
    class Authorino,ISVC servicemesh
    class Controller,WebhookSvc,MetricsSvc,K8sAPI controlplane
    class Prometheus monitoring
    class Storage externalservice
