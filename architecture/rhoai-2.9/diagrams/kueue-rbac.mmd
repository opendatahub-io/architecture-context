graph TD
    subgraph "Service Accounts"
        SA1[kueue-controller-manager<br/>Namespace: opendatahub]
        SA2[default<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kueue-leader-election-rolebinding<br/>RoleBinding<br/>Namespace: opendatahub]
        CRB3[kueue-batch-user-rolebinding<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRoles"
        CR1[kueue-manager-role<br/>ClusterRole]
        CR2[kueue-leader-election-role<br/>Role]
        CR3[kueue-batch-admin-role<br/>ClusterRole]
        CR4[kueue-batch-user-role<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Core1[events, limitranges, namespaces<br/>Verbs: get, list, watch]
        Core2[pods<br/>Verbs: delete, get, list, patch, update, watch]
        Core3[pods/finalizers<br/>Verbs: get, update]
        Core4[pods/status<br/>Verbs: get, patch]
        Core5[secrets<br/>Verbs: get, list, update, watch]
    end

    subgraph "Batch API Resources"
        Batch1[jobs<br/>Verbs: get, list, patch, update, watch]
        Batch2[jobs/finalizers<br/>Verbs: get, patch, update]
        Batch3[jobs/status<br/>Verbs: get, update]
    end

    subgraph "Kueue API Resources"
        Kueue1[admissionchecks<br/>kueue.x-k8s.io<br/>Verbs: * all]
        Kueue2[clusterqueues<br/>kueue.x-k8s.io<br/>Verbs: * all]
        Kueue3[localqueues<br/>kueue.x-k8s.io<br/>Verbs: * all]
        Kueue4[workloads<br/>kueue.x-k8s.io<br/>Verbs: * all]
        Kueue5[resourceflavors<br/>kueue.x-k8s.io<br/>Verbs: * all]
        Kueue6[workloadpriorityclasses<br/>kueue.x-k8s.io<br/>Verbs: * all]
    end

    subgraph "Kubeflow API Resources"
        Kubeflow1[mpijobs, pytorchjobs, tfjobs<br/>mxjobs, paddlejobs, xgboostjobs<br/>kubeflow.org<br/>Verbs: get, list, patch, update, watch]
        Kubeflow2[*/finalizers<br/>kubeflow.org<br/>Verbs: get, update]
        Kubeflow3[*/status<br/>kubeflow.org<br/>Verbs: get, update]
    end

    subgraph "Ray API Resources"
        Ray1[rayclusters, rayjobs<br/>ray.io<br/>Verbs: get, list, patch, update, watch]
        Ray2[*/finalizers<br/>ray.io<br/>Verbs: get, update]
        Ray3[*/status<br/>ray.io<br/>Verbs: get, update]
    end

    subgraph "JobSet API Resources"
        JobSet1[jobsets<br/>jobset.x-k8s.io<br/>Verbs: get, list, patch, update, watch]
        JobSet2[jobsets/finalizers<br/>jobset.x-k8s.io<br/>Verbs: get, update]
        JobSet3[jobsets/status<br/>jobset.x-k8s.io<br/>Verbs: get, update]
    end

    subgraph "Autoscaling API Resources"
        Autoscaling1[provisioningrequests<br/>autoscaling.x-k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Admission Registration Resources"
        Admission1[mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>Verbs: get, list, update, watch]
    end

    subgraph "Flow Control Resources"
        FlowControl1[flowschemas<br/>prioritylevelconfigurations<br/>flowcontrol.apiserver.k8s.io<br/>Verbs: list, watch]
    end

    %% Service Account to Role Binding connections
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| CRB3

    %% Role Binding to Role connections
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR4

    %% kueue-manager-role permissions
    CR1 -->|permissions| Core1
    CR1 -->|permissions| Core2
    CR1 -->|permissions| Core3
    CR1 -->|permissions| Core4
    CR1 -->|permissions| Core5
    CR1 -->|permissions| Batch1
    CR1 -->|permissions| Batch2
    CR1 -->|permissions| Batch3
    CR1 -->|permissions| Kueue1
    CR1 -->|permissions| Kueue2
    CR1 -->|permissions| Kueue3
    CR1 -->|permissions| Kueue4
    CR1 -->|permissions| Kueue5
    CR1 -->|permissions| Kueue6
    CR1 -->|permissions| Kubeflow1
    CR1 -->|permissions| Kubeflow2
    CR1 -->|permissions| Kubeflow3
    CR1 -->|permissions| Ray1
    CR1 -->|permissions| Ray2
    CR1 -->|permissions| Ray3
    CR1 -->|permissions| JobSet1
    CR1 -->|permissions| JobSet2
    CR1 -->|permissions| JobSet3
    CR1 -->|permissions| Autoscaling1
    CR1 -->|permissions| Admission1
    CR1 -->|permissions| FlowControl1

    %% kueue-batch-admin-role permissions
    CR3 -->|permissions| Kueue2
    CR3 -->|permissions| Kueue5
    CR3 -->|permissions| Kueue6

    %% kueue-batch-user-role permissions
    CR4 -->|get, list, watch| Core2
    CR4 -->|get, list, watch, create, delete, patch, update| Batch1

