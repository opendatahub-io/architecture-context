graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        DashboardRoute["Dashboard Route<br/>443/TCP → 8265/TCP<br/>TLS Termination<br/>No Auth"]
        ServeRoute["Serve Route<br/>443/TCP → 8000/TCP<br/>TLS Termination<br/>Optional API Key"]
    end

    subgraph Cluster["KUBERNETES CLUSTER (opendatahub namespace)"]
        direction TB

        subgraph Operator["kuberay-operator"]
            OpPod["Operator Pod<br/>SA: kuberay-operator<br/>UID: 65532<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Webhook: 443/TCP HTTPS"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        subgraph RayCluster["Ray Cluster (User Namespace)"]
            direction TB
            HeadPod["Ray Head Pod<br/>SA: {raycluster}-sa<br/>UID: 1000<br/>━━━━━━━━━━━━━━━━━━━━<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP HTTP<br/>Client: 10001/TCP<br/>Metrics: 8080/TCP HTTP"]

            WorkerPods["Ray Worker Pods<br/>SA: {raycluster}-sa<br/>UID: 1000<br/>Autoscaling<br/>━━━━━━━━━━━━━━━━━━━━<br/>Agent: 52365/TCP HTTP"]

            ServePods["Ray Serve Pods<br/>8000/TCP HTTP<br/>Optional API Key"]
        end

        HeadSvc["Head Service<br/>ClusterIP<br/>6379, 8265, 10001, 8080"]
        ServeSvc["Serve Service<br/>ClusterIP<br/>8000/TCP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Registry["Container Registry<br/>quay.io/gcr.io<br/>443/TCP HTTPS<br/>Pull Secrets"]
        Storage["S3/GCS/Azure Blob<br/>443/TCP HTTPS<br/>Cloud IAM"]
        ExternalRedis["External Redis<br/>6379/TCP<br/>Optional Password<br/>GCS Fault Tolerance"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP"]
    end

    subgraph Optional["OPTIONAL INTEGRATIONS"]
        direction LR
        ServiceMesh["Service Mesh (Istio)<br/>mTLS STRICT<br/>Sidecar Injection"]
        Volcano["Volcano Scheduler<br/>Gang Scheduling<br/>K8s API 443/TCP"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| DashboardRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Optional API Key| ServeRoute

    %% Ingress to services
    DashboardRoute -->|HTTP/8265<br/>No Encryption| HeadSvc
    ServeRoute -->|HTTP/8000<br/>No Encryption| ServeSvc

    %% Operator flows
    OpPod -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    K8sAPI -->|Watch Events| OpPod
    K8sAPI -->|Creates/Manages| HeadPod
    K8sAPI -->|Creates/Manages| WorkerPods
    K8sAPI -->|Creates/Manages| ServePods

    %% Service routing
    HeadSvc -->|Routes to| HeadPod
    ServeSvc -->|Routes to| ServePods

    %% Ray internal communication
    WorkerPods -->|TCP/6379<br/>Plaintext<br/>Optional Password| HeadPod
    WorkerPods -->|TCP/10001<br/>Plaintext| HeadPod
    ServePods -->|TCP/10001<br/>Plaintext| HeadPod

    %% External service flows
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry
    HeadPod -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| Storage
    WorkerPods -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| Storage
    HeadPod -.->|TCP/6379<br/>Optional TLS<br/>Password| ExternalRedis

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Scrape| OpPod
    Prometheus -->|HTTP/8080<br/>Scrape| HeadPod

    %% Optional integrations
    HeadPod -.->|mTLS| ServiceMesh
    WorkerPods -.->|mTLS| ServiceMesh
    OpPod -.->|K8s API| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:3px
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:2px
    classDef raypod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class DashboardRoute,ServeRoute ingress
    class OpPod operator
    class K8sAPI k8s
    class HeadPod,WorkerPods,ServePods raypod
    class HeadSvc,ServeSvc service
    class Registry,Storage,ExternalRedis,Prometheus externalservice
    class ServiceMesh,Volcano optional
