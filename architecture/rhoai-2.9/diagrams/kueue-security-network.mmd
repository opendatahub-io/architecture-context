graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User/CI System]
    end

    subgraph APIGateway["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Certificates/Tokens/OIDC<br/>AuthZ: RBAC"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (opendatahub)"]
        direction TB

        subgraph WebhookSvc["Webhook Service"]
            Webhook["Kueue Webhook Server<br/>Service: kueue-webhook-service<br/>Port: 443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+ mTLS<br/>Secret: kueue-webhook-server-cert<br/>NetworkPolicy: kueue-webhook-server"]
        end

        subgraph ControllerMgr["Controller Manager"]
            Controller["Kueue Controller Manager<br/>Deployment<br/>SA: kueue-controller-manager<br/>User: 65532:65532<br/>runAsNonRoot: true<br/>CPU: 500m, Mem: 512Mi"]
        end

        subgraph MetricsSvcs["Metrics & Visibility Services"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>No Auth<br/>Prometheus scraping"]
            VisibilitySvc["Visibility Server<br/>443/TCP → 8082/TCP<br/>HTTPS TLS 1.2+<br/>No Auth (read-only)"]
            ControllerMetricsSvc["Controller Metrics Service<br/>8443/TCP HTTPS TLS 1.2+"]
        end

        subgraph Health["Health Endpoints"]
            HealthCheck["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz<br/>No Auth (Kubelet)"]
        end

        Controller -->|exposes| Webhook
        Controller -->|exposes| MetricsSvc
        Controller -->|exposes| VisibilitySvc
        Controller -->|exposes| ControllerMetricsSvc
        Controller -->|exposes| HealthCheck
    end

    subgraph Monitoring["MONITORING (Internal - Trusted)"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    subgraph HealthMonitoring["HEALTH CHECKS (Internal - Kubelet)"]
        Kubelet["Kubelet<br/>Liveness/Readiness Probes"]
    end

    subgraph AutoscalingIntegration["AUTOSCALING INTEGRATION"]
        ClusterAutoscaler["cluster-autoscaler<br/>Namespace: kube-system<br/>Processes ProvisioningRequests"]
    end

    subgraph CertManagement["CERTIFICATE MANAGEMENT"]
        CertManager["cert-manager or internal-cert<br/>TLS Certificate Provider<br/>Auto-rotation: Yes"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>API Server client cert| Webhook
    Webhook -->|Validates/Mutates<br/>Job resources| K8sAPI

    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>RBAC: kueue-manager-role| K8sAPI

    K8sAPI -->|Watch/Reconcile<br/>CRDs, Jobs, Pods| Controller

    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create ProvisioningRequest| ClusterAutoscaler

    Prometheus -->|HTTP/8080<br/>No encryption<br/>No auth<br/>NetworkPolicy enforced| MetricsSvc

    Kubelet -->|HTTP/8081<br/>No encryption<br/>No auth| HealthCheck

    CertManager -->|Provisions TLS cert<br/>kueue-webhook-server-cert<br/>kubernetes.io/tls<br/>90d rotation| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef apigateway fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef autoscaling fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef certmgmt fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI apigateway
    class Webhook,Controller,MetricsSvc,VisibilitySvc,ControllerMetricsSvc,HealthCheck kueuens
    class Prometheus,Kubelet monitoring
    class ClusterAutoscaler autoscaling
    class CertManager certmgmt
