graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
        JupyterHub[JupyterHub/<br/>ODH Dashboard]
        ExternalUsers[External Users<br/>via Browser]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC"]
    end

    subgraph ControllerNamespace["CONTROLLER NAMESPACE (kubeflow)"]
        direction TB

        subgraph Controller["Notebook Controller Pod<br/>SA: notebook-controller-service-account"]
            NotebookReconciler["NotebookReconciler<br/>Watches: notebooks.kubeflow.org<br/>Creates: StatefulSets, Services"]
            CullingReconciler["CullingReconciler<br/>Timer: IDLENESS_CHECK_PERIOD=1m<br/>Timeout: CULL_IDLE_TIME=1440m"]
            MetricsCollector["Metrics Collector<br/>8080/TCP HTTP<br/>⚠️ No Auth"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        Prometheus[Prometheus]
        Kubelet[Kubelet]
    end

    subgraph UserNamespace["USER NAMESPACE ({user-namespace})"]
        direction TB

        StatefulSet["StatefulSet: {notebook-name}<br/>Replicas: 1 (0 if stopped)<br/>fsGroup: 100"]

        NotebookPod["Notebook Pod<br/>Port: 8888/TCP HTTP<br/>Image: {notebook-image}"]

        Service["Service: {notebook-name}<br/>Type: ClusterIP<br/>80/TCP → 8888/TCP<br/>HTTP plaintext"]

        VirtualService["VirtualService: {notebook-name}<br/>(if USE_ISTIO=true)<br/>Gateway: {ISTIO_GATEWAY}"]

        StatefulSet -->|creates| NotebookPod
        NotebookPod -->|exposed by| Service
        Service -.->|routes to| VirtualService
    end

    subgraph Ingress["INGRESS (DMZ) - Optional"]
        IstioGateway["Istio Gateway<br/>443/TCP HTTPS<br/>TLS 1.3<br/>TLS Termination"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Auth: ImagePullSecrets"]
    end

    %% External to Control Plane
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI
    JupyterHub -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% Control Plane to Controller
    K8sAPI -->|Watch events<br/>TLS 1.2+<br/>ServiceAccount Token JWT| NotebookReconciler

    %% Controller to Control Plane
    NotebookReconciler -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>CRUD: StatefulSets, Services, VirtualServices| K8sAPI

    %% Culling to Notebook Pod
    CullingReconciler -->|HTTP/8888<br/>⚠️ Plaintext<br/>⚠️ No Auth<br/>/api/kernels, /api/terminals| Service

    %% Culler updates CR
    CullingReconciler -->|HTTPS/6443<br/>TLS 1.2+<br/>Update Notebook CR<br/>ServiceAccount Token| K8sAPI

    %% Metrics scraping
    Prometheus -->|HTTP/8080<br/>⚠️ No Auth<br/>/metrics| MetricsCollector

    %% Health probes
    Kubelet -->|HTTP/8081<br/>/healthz, /readyz| HealthProbes

    %% Ingress to User Namespace
    ExternalUsers -->|HTTPS/443<br/>TLS 1.3| IstioGateway
    IstioGateway -->|HTTP/80<br/>Plaintext after TLS termination| VirtualService
    VirtualService -->|HTTP/80| Service
    Service -->|HTTP/8888| NotebookPod

    %% Image pull
    StatefulSet -->|HTTPS/443<br/>TLS 1.2+<br/>Auth: ImagePullSecrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e6f2ff,stroke:#4a90e2,stroke-width:3px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef usernamespace fill:#fff4e6,stroke:#d79b00,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px

    class User,JupyterHub,ExternalUsers external
    class K8sAPI controlplane
    class Controller,NotebookReconciler,CullingReconciler,MetricsCollector,HealthProbes,Prometheus,Kubelet controller
    class StatefulSet,NotebookPod,Service,VirtualService usernamespace
    class IstioGateway ingress
    class Registry externalservice
    class CullingReconciler,MetricsCollector warning
