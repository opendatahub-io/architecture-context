graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Users<br/>Data Scientists, API Clients]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ (Edge/Reencrypt)"]
        IstioGW["Istio Ingress Gateway<br/>knative-ingress-gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.2+"]
    end

    subgraph PlatformServices["PLATFORM SERVICES (redhat-ods-applications)"]
        direction TB

        Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>8080/TCP (app)<br/>8443/TCP (OAuth proxy)<br/>Auth: Bearer Token<br/>Secrets: dashboard-oauth-client, dashboard-proxy-tls"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth<br/>RBAC Enforcement"]

        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS<br/>JWT Bearer Tokens<br/>LDAP/GitHub/SAML/OIDC"]
    end

    subgraph OperatorLayer["OPERATOR LAYER (redhat-ods-operator, redhat-ods-applications)"]
        direction TB

        RHODSOp["RHODS Operator<br/>SA: controller-manager<br/>ClusterRole: controller-manager-role<br/>Metrics: 8080/metrics"]

        ComponentOps["Component Operators<br/>KServe, ModelMesh, DSP, KubeRay,<br/>CodeFlare, Kueue, TrustyAI,<br/>Notebook Controller, ODH Model Controller"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph IstioControl["Istio Control Plane (istio-system)"]
            Citadel["Istio Citadel<br/>PeerAuthentication: STRICT<br/>Certificate Rotation<br/>SPIFFE Identity"]
        end
    end

    subgraph UserWorkloads["USER WORKLOADS (User Namespaces)"]
        direction TB

        subgraph NotebooksNS["Notebook Workloads"]
            Notebooks["Notebook Pods<br/>SA: {notebook}-sa<br/>StatefulSet + OAuth sidecar<br/>8888/TCP (JupyterLab)<br/>Secrets: {notebook}-oauth-config, {notebook}-tls<br/>mTLS via Service Mesh"]
        end

        subgraph InferenceNS["Model Serving"]
            KServe["KServe InferenceServices<br/>SA: {isvc-name}-sa<br/>Knative Service<br/>8080/TCP (predictor)<br/>15001/TCP (Envoy)<br/>mTLS STRICT<br/>Secrets: storage-config"]

            ModelMesh["ModelMesh Serving<br/>SA: modelmesh-serving-sa<br/>8033/TCP (gRPC), 8008/TCP (REST)<br/>OAuth proxy TLS<br/>Secrets: model-serving-proxy-tls"]
        end

        subgraph PipelinesNS["ML Pipelines"]
            DSP["DSP Components<br/>API: 8888/TCP (OAuth)<br/>MariaDB: 3306/TCP<br/>MinIO: 9000/TCP<br/>Secrets: ds-pipelines-proxy-tls, db-secret"]
        end

        subgraph RayNS["Distributed Computing"]
            Ray["Ray Clusters<br/>SA: {cluster}-sa<br/>6379/TCP (Redis)<br/>8265/TCP (Dashboard)<br/>mTLS (CodeFlare CA)<br/>NetworkPolicies<br/>Secrets: {cluster}-oauth-config, ca-secret"]
        end

        subgraph TrustyAINS["Model Monitoring"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-service-sa<br/>8080/TCP (API)<br/>9090/TCP (metrics)<br/>Passthrough TLS<br/>PVC storage"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        S3["S3 Storage<br/>AWS S3/MinIO/IBM COS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Auth"]

        Registry["Container Registries<br/>Quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>Pull Secrets"]

        ExternalDB["External Database<br/>MariaDB/PostgreSQL<br/>3306/5432 TCP<br/>TLS (optional)"]

        PackageRepos["Package Repos<br/>PyPI, Conda, GitHub<br/>443/TCP HTTPS"]
    end

    subgraph Monitoring["MONITORING (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>9092/TCP HTTPS<br/>ServiceMonitor scraping<br/>Metrics aggregation"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Client -->|HTTPS/443<br/>TLS 1.2+| IstioGW

    %% Ingress to Platform
    Router -->|HTTPS/8443<br/>Reencrypt TLS<br/>OAuth Proxy| Dashboard
    Router -->|Edge TLS<br/>OAuth Proxy| Notebooks
    IstioGW -->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity| KServe
    Router -->|Edge TLS<br/>OAuth Proxy| ModelMesh
    Router -->|Reencrypt TLS<br/>OAuth Proxy| DSP
    Router -->|Reencrypt TLS<br/>OAuth Proxy| Ray

    %% Platform to K8s API
    Dashboard -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    RHODSOp -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    ComponentOps -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Operator Layer
    RHODSOp -->|Deploys/Manages| ComponentOps
    ComponentOps -->|Creates Pods| Notebooks
    ComponentOps -->|Creates Pods| KServe
    ComponentOps -->|Creates Pods| ModelMesh
    ComponentOps -->|Creates Pods| DSP
    ComponentOps -->|Creates Pods| Ray
    ComponentOps -->|Creates Pods| TrustyAI

    %% Service Mesh
    Citadel -->|mTLS Certs<br/>SPIFFE Identity| KServe
    Citadel -->|mTLS Certs<br/>SPIFFE Identity| ModelMesh
    Citadel -->|mTLS Certs<br/>SPIFFE Identity| Notebooks

    %% Authentication
    Dashboard -->|Auth Validation<br/>HTTPS/443| OAuthServer
    Notebooks -->|Auth Validation<br/>HTTPS/443| OAuthServer
    DSP -->|Auth Validation<br/>HTTPS/443| OAuthServer
    Ray -->|Auth Validation<br/>HTTPS/443| OAuthServer

    %% Workloads to Storage
    KServe -->|Model Artifacts<br/>HTTPS/443<br/>AWS IAM| S3
    ModelMesh -->|Model Artifacts<br/>HTTPS/443<br/>AWS IAM| S3
    DSP -->|Pipeline Data<br/>HTTPS/443<br/>AWS IAM| S3
    Notebooks -->|Datasets<br/>HTTPS/443<br/>AWS IAM| S3
    Ray -->|Checkpoints<br/>HTTPS/443<br/>AWS IAM| S3

    %% External Services
    RHODSOp -->|Pull Images<br/>HTTPS/443| Registry
    Notebooks -->|Pull Images<br/>HTTPS/443| Registry
    KServe -->|Pull Images<br/>HTTPS/443| Registry

    DSP -->|Pipeline Metadata<br/>TCP/3306<br/>TLS optional| ExternalDB

    Notebooks -->|Package Install<br/>HTTPS/443| PackageRepos

    %% Monitoring
    Prometheus -->|Scrape Metrics<br/>HTTP/8080<br/>/metrics| RHODSOp
    Prometheus -->|Scrape Metrics<br/>HTTP/8080<br/>/metrics| ComponentOps
    Prometheus -->|Scrape Metrics<br/>HTTP/8080<br/>/metrics| KServe
    Prometheus -->|Scrape Metrics<br/>HTTP/8080<br/>/metrics| ModelMesh
    Prometheus -->|Scrape Metrics<br/>HTTP/9090<br/>/q/metrics| TrustyAI
    Dashboard -->|Query Metrics<br/>HTTPS/9092| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef servicemesh fill:#e1d5e7,stroke:#9673a6,stroke-width:3px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d0e8d8,stroke:#16a085,stroke-width:2px

    class Client external
    class Router,IstioGW ingress
    class Dashboard,K8sAPI,OAuthServer platform
    class RHODSOp,ComponentOps platform
    class Citadel servicemesh
    class Notebooks,KServe,ModelMesh,DSP,Ray,TrustyAI workload
    class S3,Registry,ExternalDB,PackageRepos externalservice
    class Prometheus monitoring
