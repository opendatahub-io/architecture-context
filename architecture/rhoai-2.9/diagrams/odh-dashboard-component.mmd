graph TB
    subgraph "ODH Dashboard Pod"
        OAuthProxy[OAuth Proxy Container<br/>Port: 8443/TCP HTTPS]
        Backend[Dashboard Backend<br/>Fastify/Node.js<br/>Port: 8080/TCP HTTP]
        Frontend[React Frontend<br/>Static Assets]

        OAuthProxy -->|localhost| Backend
        Backend -->|serves| Frontend
    end

    subgraph "Custom Resources"
        OdhDashboardConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhApplication[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhDocument[OdhDocument<br/>dashboard.opendatahub.io/v1]
        OdhQuickStart[OdhQuickStart<br/>console.openshift.io/v1]
        AcceleratorProfile[AcceleratorProfile<br/>dashboard.opendatahub.io/v1]
        NotebookCR[Notebook<br/>kubeflow.org/v1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io]
    end

    subgraph "External Access"
        User[User Browser]
        Route[OpenShift Route<br/>443/TCP HTTPS<br/>TLS Reencrypt]
    end

    subgraph "Platform Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        OAuthServer[OpenShift OAuth Server<br/>443/TCP HTTPS]
        ThanosQuerier[Thanos Querier<br/>9092/TCP HTTPS]
        ImageRegistry[OpenShift Image Registry<br/>443/TCP HTTPS]
        DSPipelines[Data Science Pipelines API<br/>8443/TCP HTTPS]
    end

    subgraph "Controllers"
        NotebookController[Kubeflow Notebook Controller]
        KServeController[KServe Controller]
    end

    %% User flow
    User -->|HTTPS/443| Route
    Route -->|HTTPS/8443<br/>TLS Reencrypt| OAuthProxy

    %% OAuth flow
    OAuthProxy -->|validates tokens| OAuthServer

    %% Backend interactions
    Backend -->|Service Account Token| K8sAPI
    Backend -->|User Bearer Token| ThanosQuerier
    Backend -->|Service Account Token| ImageRegistry
    Backend -->|Bearer Token| DSPipelines

    %% CRD management
    Backend -->|manages via K8s API| OdhDashboardConfig
    Backend -->|reads via K8s API| OdhApplication
    Backend -->|reads via K8s API| OdhDocument
    Backend -->|reads via K8s API| OdhQuickStart
    Backend -->|manages via K8s API| AcceleratorProfile
    Backend -->|manages via K8s API| NotebookCR
    Backend -->|manages via K8s API| ServingRuntime

    %% Controller watches
    NotebookCR -->|watched by| NotebookController
    ServingRuntime -->|watched by| KServeController

    %% Styling
    style Backend fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style Frontend fill:#4a90e2,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OAuthServer fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ThanosQuerier fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ImageRegistry fill:#e8e8e8,stroke:#333,stroke-width:2px
    style DSPipelines fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookController fill:#7ed321,stroke:#333,stroke-width:2px
    style KServeController fill:#7ed321,stroke:#333,stroke-width:2px
    style OdhDashboardConfig fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style OdhApplication fill:#d5e8d4,stroke:#82b366,stroke-width:2px
