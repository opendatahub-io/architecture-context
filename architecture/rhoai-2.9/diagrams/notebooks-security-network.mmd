graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>{notebook-name}-route<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ Edge<br/>Host: *.apps.{cluster-domain}"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace: {user-namespace})"]
        direction TB

        OAuthProxy["OAuth Proxy Sidecar<br/>SA: {notebook-name}-sa<br/>Validates OAuth2 Bearer Token<br/>Secret: {notebook-name}-oauth-config"]

        subgraph Workbenches["Workbench Containers"]
            Jupyter["JupyterLab Container<br/>8888/TCP<br/>Image: quay.io/modh/jupyter-*<br/>SA: {notebook-name}-sa"]
            RStudio["RStudio Container<br/>8787/TCP<br/>Image: quay.io/modh/rstudio-*<br/>SA: {notebook-name}-sa"]
            CodeServer["Code Server Container<br/>8443/TCP<br/>Image: quay.io/modh/code-server-*<br/>SA: {notebook-name}-sa"]
        end

        OAuthProxy -->|HTTP<br/>localhost<br/>no encryption| Jupyter
        OAuthProxy -->|HTTP<br/>localhost<br/>no encryption| RStudio
        OAuthProxy -->|HTTP<br/>localhost<br/>no encryption| CodeServer
    end

    subgraph K8sControlPlane["KUBERNETES API SERVER (Control Plane)"]
        K8sAPI["Kubernetes API<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph InternalODH["INTERNAL ODH COMPONENTS (Service Mesh - mTLS)"]
        direction TB

        subgraph NS_ModelReg["Namespace: odh-model-registry"]
            ModelReg["Model Registry<br/>8080/TCP<br/>HTTP + mTLS<br/>ServiceAccount Token"]
        end

        subgraph NS_Pipelines["Namespace: odh-pipelines"]
            KFP["Kubeflow Pipelines API<br/>8888/TCP<br/>HTTP + mTLS<br/>ServiceAccount Token"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM SigV4<br/>Secret: aws-credentials"]

        Quay["Container Registry<br/>quay.io/modh/*<br/>443/TCP HTTPS TLS 1.2+<br/>Image Pull Secret"]

        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS TLS 1.2+<br/>Public (no auth)"]

        GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS TLS 1.2+<br/>Git credentials<br/>Secret: git-credentials"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Bearer Token| Route
    Route -->|HTTP/8888<br/>TLS terminated<br/>OAuth2 validated| OAuthProxy

    Jupyter -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4| S3
    Jupyter -->|HTTP/8080<br/>mTLS<br/>ServiceAccount Token| ModelReg
    Jupyter -->|HTTP/8888<br/>mTLS<br/>ServiceAccount Token| KFP
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>None| PyPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>Git credentials| GitHub

    K8sAPI -.->|Image pull<br/>HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secret| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internalodh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class OAuthProxy,Jupyter,RStudio,CodeServer workbench
    class K8sAPI k8s
    class ModelReg,KFP internalodh
    class S3,Quay,PyPI,GitHub externalservice
