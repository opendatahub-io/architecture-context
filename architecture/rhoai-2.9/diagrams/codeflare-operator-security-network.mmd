graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router /<br/>Kubernetes Ingress Controller<br/>Route: ray-dashboard-{'{cluster}'}<br/>443/TCP → 8443/TCP<br/>TLS Re-encrypt/TLS"]
    end

    subgraph UserNamespace["WORKLOAD PODS (Namespace: user-namespace)"]
        direction TB

        subgraph RayHeadPod["Ray Head Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+ (service-serving-cert)<br/>SA: {'{cluster}'}-oauth-proxy"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>localhost"]
            RayHead["Ray Head<br/>10001/TCP mTLS<br/>8265/TCP HTTP"]
        end

        RayWorkers["Ray Worker Pods<br/>10001/TCP mTLS<br/>SA: default<br/>CA Secret: ca-secret-{'{cluster}'}"]
    end

    subgraph OperatorNS["OPERATOR (Namespace: redhat-ods-applications)"]
        Operator["CodeFlare Operator Manager<br/>SA: controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Webhook: 9443/TCP HTTPS TLS1.2+"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+"]
        WebhookService["CodeFlare Webhook Service<br/>codeflare-operator-webhook-service<br/>443/TCP → 9443/TCP<br/>TLS Secret: webhook-server-cert"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        KubeRay["KubeRay Operator<br/>Namespace: opendatahub/redhat-ods-applications<br/>NetworkPolicy: 8265/TCP, 10001/TCP"]
        OSAuth["OpenShift OAuth Server<br/>User Authentication<br/>OpenShift RBAC"]
        CertCtrl["cert-controller<br/>Webhook cert rotation<br/>Auto-rotate: Yes"]
        Prometheus["Prometheus<br/>Namespace: openshift-monitoring<br/>8080/TCP HTTPS<br/>Bearer token"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth redirect| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>OAuth Token| OAuthProxy
    OAuthProxy -->|HTTP/8265<br/>localhost<br/>no auth| Dashboard

    Router -.->|authenticates via| OSAuth

    Dashboard -.->|same pod| RayHead
    RayHead <-->|mTLS/10001<br/>Ray cluster CA| RayWorkers
    RayHead <-->|HTTP/8265<br/>internal cluster| RayWorkers

    KubeRay -->|NetworkPolicy allowed<br/>8265/TCP, 10001/TCP| RayHead

    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>Service Account Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s API Server mTLS| WebhookService
    WebhookService -.->|served by| Operator

    CertCtrl -.->|manages cert for| WebhookService
    Prometheus -->|scrape/8080<br/>Bearer token| Operator

    Operator -->|creates/manages| OAuthProxy
    Operator -->|creates/manages| RayWorkers
    Operator -->|watches CRD from| KubeRay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,Dashboard,RayHead,RayWorkers workload
    class Operator operator
    class K8sAPI,WebhookService controlplane
    class KubeRay,OSAuth,CertCtrl,Prometheus externalservice
