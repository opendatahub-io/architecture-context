graph TB
    subgraph "KubeRay Operator Component"
        Operator[kuberay-operator<br/>Deployment]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        Webhook[Validating Webhook<br/>443/TCP HTTPS]

        Operator -->|manages| RayClusterCtrl
        Operator -->|manages| RayJobCtrl
        Operator -->|manages| RayServiceCtrl
        Operator -->|serves| Webhook
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Resources"
        HeadPod[Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard]
        WorkerPods[Ray Worker Pods<br/>Autoscaling]
        HeadSvc[Head Service<br/>ClusterIP]
        ServeSvc[Serve Service<br/>8000/TCP HTTP]
        Route[OpenShift Route<br/>External Access]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Volcano[Volcano Scheduler<br/>Optional Gang Scheduling]
        CertMgr[cert-manager<br/>Webhook Certs]
        Prometheus[Prometheus<br/>8080/TCP Metrics]
    end

    subgraph "Optional Components"
        ExternalRedis[External Redis<br/>6379/TCP<br/>GCS Fault Tolerance]
        ServiceMesh[Service Mesh<br/>mTLS Integration]
    end

    %% User interactions
    User[Data Scientist] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CR to Controller
    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Controller creates resources
    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadSvc
    RayServiceCtrl -->|creates| ServeSvc
    RayClusterCtrl -->|creates| Route

    %% Dependencies
    Operator -->|API calls| K8sAPI
    Operator -.->|optional| Volcano
    Operator -.->|webhook certs| CertMgr
    Prometheus -->|scrapes| Operator
    HeadPod -.->|optional| ExternalRedis
    HeadSvc -.->|optional| ServiceMesh

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style CertMgr fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
