graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External User]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route: trustyai-instance<br/>443/TCP HTTPS<br/>TLS 1.2+ Passthrough"]
    end

    subgraph ServiceLayer["SERVICE LAYER (ClusterIP)"]
        ServiceTLS["Service: trustyai-instance-tls<br/>ClusterIP<br/>443/TCP → 8443/TCP"]
        ServiceInternal["Service: trustyai-instance<br/>ClusterIP<br/>80/TCP → 8080/TCP"]
    end

    subgraph TrustyAIPod["TrustyAI Service Pod (Namespace: model-namespace)"]
        direction TB

        subgraph Containers["Pod Containers"]
            OAuthProxy["oauth-proxy<br/>SA: trustyai-instance-proxy<br/>8443/TCP HTTPS<br/>TLS Cert: trustyai-instance-tls<br/>AuthZ: SubjectAccessReview"]
            TrustyAIContainer["trustyai-service<br/>SA: default<br/>8080/TCP HTTP<br/>Endpoints:<br/>/q/metrics<br/>/consumer/kserve/v2<br/>/apis/v1beta1/healthz"]
        end

        PVC["PersistentVolumeClaim<br/>trustyai-instance-pvc<br/>ReadWriteOnce<br/>Storage: inference data"]

        OAuthProxy -->|localhost 8080/TCP<br/>HTTP, no auth| TrustyAIContainer
        TrustyAIContainer -->|Filesystem I/O| PVC
    end

    subgraph InternalClients["INTERNAL CLUSTER TRAFFIC"]
        direction TB
        KServe["KServe InferenceService<br/>Predictor Pods<br/>Logger.URL configured"]
        ModelMesh["ModelMesh Serving<br/>Runtime Pods<br/>MM_PAYLOAD_PROCESSORS env"]
        Prometheus["Prometheus<br/>Metrics Scraping<br/>SA Token Auth"]
    end

    subgraph Operator["OPERATOR (Control Plane)"]
        direction TB
        Controller["controller-manager<br/>SA: controller-manager<br/>Ports: 8081/healthz, 8080/metrics<br/>Leader Election Enabled"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OAuthService["OpenShift OAuth<br/>443/TCP HTTPS<br/>Token Validation"]
    end

    %% External User Flow
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Route
    Route -->|TLS Passthrough<br/>443/TCP| ServiceTLS
    ServiceTLS -->|HTTPS/8443<br/>TLS 1.2+| OAuthProxy
    OAuthProxy -->|Validate Token| OAuthService

    %% Internal Payload Logging
    KServe -->|HTTP/80<br/>POST /consumer/kserve/v2<br/>No Auth| ServiceInternal
    ModelMesh -->|HTTP/80<br/>POST /consumer/kserve/v2<br/>No Auth| ServiceInternal
    ServiceInternal -->|HTTP/8080| TrustyAIContainer

    %% Prometheus Scraping
    Prometheus -->|HTTP/80<br/>GET /q/metrics<br/>SA Token| ServiceInternal

    %% Operator Control Plane
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>RBAC: manager-role| K8sAPI
    Controller -.->|Creates/Manages| TrustyAIPod
    Controller -.->|Creates/Manages| ServiceTLS
    Controller -.->|Creates/Manages| ServiceInternal
    Controller -.->|Creates/Manages| Route
    Controller -.->|Creates/Manages| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class ServiceTLS,ServiceInternal service
    class OAuthProxy,TrustyAIContainer,PVC pod
    class KServe,ModelMesh,Prometheus internal
    class Controller operator
    class K8sAPI,OAuthService externalservice
