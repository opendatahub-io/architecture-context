graph TD
    subgraph "Service Accounts"
        SA1[odh-model-controller<br/>redhat-ods-applications]
        SA2[prometheus-custom<br/>monitoring-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-rolebinding<br/>Cluster-wide]
        CRB2[odh-model-controller-leader-election<br/>Deployment namespace]
    end

    subgraph "RoleBindings (per ISVC namespace)"
        RB[prometheus-ns-access<br/>Created by MonitoringReconciler]
    end

    subgraph "ClusterRoles"
        CR1[odh-model-controller-role]
        CR2[odh-model-controller-leader-election-role]
        CR3[prometheus-ns-access]
    end

    subgraph "API Resources - KServe"
        KServe1[serving.kserve.io<br/>InferenceService<br/>get, list, watch, update]
        KServe2[serving.kserve.io<br/>ServingRuntime<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - Networking"
        Net1[networking.istio.io<br/>VirtualService<br/>get, list, watch, create, update, patch, delete]
        Net2[networking.k8s.io<br/>NetworkPolicy<br/>get, list, watch, create, update, patch, delete]
        Net3[route.openshift.io<br/>Route<br/>get, list, watch, create, update, patch, delete]
        Net4[route.openshift.io<br/>Route/custom-host<br/>create]
    end

    subgraph "API Resources - Security"
        Sec1[security.istio.io<br/>PeerAuthentication<br/>get, list, watch, create, update, patch, delete]
        Sec2[security.istio.io<br/>AuthorizationPolicy<br/>get, list]
        Sec3[authorino.kuadrant.io<br/>AuthConfig<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - Service Mesh"
        Mesh1[maistra.io<br/>ServiceMeshMember<br/>get, list, watch, create, update, patch, delete]
        Mesh2[maistra.io<br/>ServiceMeshMemberRoll<br/>get, list, watch, create, update, patch, delete]
        Mesh3[maistra.io<br/>ServiceMeshControlPlane<br/>get, list, watch, create, update, patch, use]
        Mesh4[telemetry.istio.io<br/>Telemetry<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - Monitoring"
        Mon1[monitoring.coreos.com<br/>ServiceMonitor<br/>get, list, watch, create, update, patch, delete]
        Mon2[monitoring.coreos.com<br/>PodMonitor<br/>get, list, watch, create, update, patch, delete]
        Mon3["" core<br/>Services, Endpoints, Pods<br/>get, list, watch]
    end

    subgraph "API Resources - Core"
        Core1["" core<br/>Namespaces, Pods, Services, Endpoints<br/>get, list, watch, create, update, patch]
        Core2["" core<br/>Secrets, ConfigMaps, ServiceAccounts<br/>get, list, watch, create, update, patch, delete]
        Core3[rbac.authorization.k8s.io<br/>ClusterRoleBinding, RoleBinding<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - ODH Platform"
        ODH1[datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>get, list, watch]
        ODH2[dscinitialization.opendatahub.io<br/>DSCInitialization<br/>get, list, watch]
    end

    subgraph "API Resources - Leader Election"
        LE1["" core<br/>ConfigMap<br/>get, list, watch, create, update, patch, delete]
        LE2[coordination.k8s.io<br/>Lease<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account to ClusterRoleBinding
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| RB

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB -->|grants| CR3

    %% ClusterRole to Resources - Main Controller
    CR1 -->|manages| KServe1
    CR1 -->|manages| KServe2
    CR1 -->|manages| Net1
    CR1 -->|manages| Net2
    CR1 -->|manages| Net3
    CR1 -->|manages| Net4
    CR1 -->|manages| Sec1
    CR1 -->|manages| Sec2
    CR1 -->|manages| Sec3
    CR1 -->|manages| Mesh1
    CR1 -->|manages| Mesh2
    CR1 -->|manages| Mesh3
    CR1 -->|manages| Mesh4
    CR1 -->|manages| Mon1
    CR1 -->|manages| Mon2
    CR1 -->|manages| Core1
    CR1 -->|manages| Core2
    CR1 -->|manages| Core3
    CR1 -->|manages| ODH1
    CR1 -->|manages| ODH2

    %% Leader Election
    CR2 -->|manages| LE1
    CR2 -->|manages| LE2

    %% Prometheus Access
    CR3 -->|reads| Mon3

