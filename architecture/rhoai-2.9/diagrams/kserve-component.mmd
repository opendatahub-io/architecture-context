graph TB
    subgraph "KServe Platform"
        subgraph "Control Plane (kserve namespace)"
            Controller[kserve-controller-manager<br/>Go Operator]
            Webhook[Webhook Server<br/>Mutating & Validating]
            Controller -->|manages| Webhook
        end

        subgraph "Runtime Components"
            Agent[kserve-agent<br/>Sidecar: Logger/Batcher/Puller]
            Router[kserve-router<br/>InferenceGraph routing]
            StorageInit[storage-initializer<br/>Init Container: Model download]
        end

        subgraph "Serving Runtimes"
            SKLearn[sklearn-server<br/>Python Runtime]
            XGBoost[xgboost-server<br/>Python Runtime]
            LightGBM[lightgbm-server<br/>Python Runtime]
            MLServer[mlserver<br/>Multi-framework Runtime]
            Paddle[paddle-server<br/>Python Runtime]
            PMML[pmml-server<br/>Python Runtime]
        end
    end

    subgraph "Custom Resources"
        InferenceService[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntime[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        ClusterServingRuntime[ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        InferenceGraph[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
        TrainedModel[TrainedModel CR<br/>serving.kserve.io/v1alpha1]
        ClusterStorageContainer[ClusterStorageContainer CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "External Dependencies"
        Knative[Knative Serving 1.x<br/>Serverless platform]
        Istio[Istio 1.x<br/>Service mesh]
        CertManager[cert-manager 1.x<br/>Certificate management]
        Kubernetes[Kubernetes 1.23+<br/>Container orchestration]
    end

    subgraph "Internal ODH Dependencies"
        ModelMesh[model-mesh<br/>High-density serving]
        ODHModelController[odh-model-controller<br/>Model registry]
        Authorino[authorino<br/>OAuth/OIDC validation]
    end

    subgraph "Storage Backends"
        S3[S3 Storage<br/>AWS/Minio]
        GCS[GCS Storage<br/>Google Cloud]
        Azure[Azure Blob Storage]
        PVC[Kubernetes PVC]
    end

    %% User interactions
    User[User/CI Pipeline] -->|creates| InferenceService
    User -->|creates| ServingRuntime
    User -->|creates| InferenceGraph

    %% CR relationships
    InferenceService -->|watched by| Controller
    ServingRuntime -->|watched by| Controller
    ClusterServingRuntime -->|watched by| Controller
    InferenceGraph -->|watched by| Controller
    TrainedModel -->|watched by| Controller
    ClusterStorageContainer -->|watched by| Controller

    %% Webhook validation
    InferenceService -.->|validates/mutates| Webhook
    ServingRuntime -.->|validates| Webhook
    InferenceGraph -.->|validates| Webhook
    TrainedModel -.->|validates| Webhook

    %% Controller creates resources
    Controller -->|creates| KnativeService[Knative Service]
    Controller -->|creates| Deployment[K8s Deployment]
    Controller -->|creates| VirtualService[Istio VirtualService]

    %% Runtime injection
    Deployment -->|injects| Agent
    Deployment -->|injects| StorageInit
    KnativeService -->|injects| Agent
    KnativeService -->|injects| StorageInit

    %% Model loading
    StorageInit -->|downloads from| S3
    StorageInit -->|downloads from| GCS
    StorageInit -->|downloads from| Azure
    StorageInit -->|mounts| PVC
    StorageInit -->|writes to| LocalVolume["Local Volume<br/>(mnt/models)"]

    %% Runtime serving
    Agent -->|routes to| SKLearn
    Agent -->|routes to| XGBoost
    Agent -->|routes to| LightGBM
    Agent -->|routes to| MLServer
    SKLearn -->|reads| LocalVolume
    XGBoost -->|reads| LocalVolume
    LightGBM -->|reads| LocalVolume
    MLServer -->|reads| LocalVolume

    %% InferenceGraph routing
    Router -->|routes to| InferenceService

    %% External dependencies
    Controller -->|depends on| Knative
    Controller -->|depends on| Istio
    Controller -->|depends on| CertManager
    Controller -->|runs on| Kubernetes
    Webhook -->|certs from| CertManager

    %% Internal integrations
    Controller -.->|integrates with| ModelMesh
    Controller -.->|integrates with| ODHModelController
    InferenceService -.->|auth via| Authorino

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Agent fill:#5bc0de,stroke:#333,stroke-width:2px
    style Router fill:#5bc0de,stroke:#333,stroke-width:2px
    style StorageInit fill:#5bc0de,stroke:#333,stroke-width:2px

    style InferenceService fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntime fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterServingRuntime fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceGraph fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainedModel fill:#f5a623,stroke:#333,stroke-width:2px

    style Knative fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
    style Kubernetes fill:#999,stroke:#333,stroke-width:2px

    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHModelController fill:#7ed321,stroke:#333,stroke-width:2px
    style Authorino fill:#7ed321,stroke:#333,stroke-width:2px

    style S3 fill:#f39c12,stroke:#333,stroke-width:2px
    style GCS fill:#f39c12,stroke:#333,stroke-width:2px
    style Azure fill:#f39c12,stroke:#333,stroke-width:2px
    style PVC fill:#f39c12,stroke:#333,stroke-width:2px

    style SKLearn fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style XGBoost fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style LightGBM fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style MLServer fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
