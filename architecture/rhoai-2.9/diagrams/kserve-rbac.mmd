graph TB
    subgraph "Service Accounts"
        SA_Controller[ServiceAccount<br/>kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[ClusterRoleBinding<br/>kserve-manager-rolebinding<br/>Scope: Cluster-wide]
        CRB_LeaderElection[ClusterRoleBinding<br/>kserve-leader-election-rolebinding<br/>Scope: Cluster-wide]
        CRB_Proxy[ClusterRoleBinding<br/>kserve-proxy-rolebinding<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRoles"
        CR_Manager[ClusterRole<br/>kserve-manager-role]
        CR_LeaderElection[ClusterRole<br/>kserve-leader-election-role]
        CR_Proxy[ClusterRole<br/>kserve-proxy-role]
    end

    subgraph "API Resources - serving.kserve.io"
        direction TB
        InferenceService[InferenceService<br/>inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status]
        ServingRuntime[ServingRuntime<br/>servingruntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status]
        ClusterServingRuntime[ClusterServingRuntime<br/>clusterservingruntimes<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status]
        InferenceGraph[InferenceGraph<br/>inferencegraphs<br/>inferencegraphs/finalizers<br/>inferencegraphs/status]
        TrainedModel[TrainedModel<br/>trainedmodels<br/>trainedmodels/status]
        ClusterStorageContainer[ClusterStorageContainer<br/>clusterstoragecontainers]
    end

    subgraph "API Resources - serving.knative.dev"
        KnativeService[Service<br/>services<br/>services/finalizers<br/>services/status]
    end

    subgraph "API Resources - networking.istio.io"
        VirtualService[VirtualService<br/>virtualservices<br/>virtualservices/finalizers<br/>virtualservices/status]
    end

    subgraph "API Resources - apps"
        Deployment[Deployment<br/>deployments]
    end

    subgraph "API Resources - autoscaling"
        HPA[HorizontalPodAutoscaler<br/>horizontalpodautoscalers]
    end

    subgraph "API Resources - core"
        Services[Service<br/>services]
        ConfigMaps[ConfigMap<br/>configmaps]
        Secrets[Secret<br/>secrets]
        Namespaces[Namespace<br/>namespaces]
        Pods[Pod<br/>pods]
        ServiceAccounts[ServiceAccount<br/>serviceaccounts]
        Events[Event<br/>events]
    end

    subgraph "API Resources - networking.k8s.io"
        Ingress[Ingress<br/>ingresses]
    end

    subgraph "API Resources - admissionregistration.k8s.io"
        MutatingWebhook[MutatingWebhookConfiguration<br/>mutatingwebhookconfigurations]
        ValidatingWebhook[ValidatingWebhookConfiguration<br/>validatingwebhookconfigurations]
    end

    subgraph "Leader Election Resources"
        ConfigMapLE[ConfigMap<br/>configmaps<br/>For leader election]
    end

    %% Service Account to Role Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_Proxy

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_Proxy -->|grants| CR_Proxy

    %% Manager Role Permissions
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| InferenceService
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ServingRuntime
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ClusterServingRuntime
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| InferenceGraph
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| TrainedModel
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ClusterStorageContainer

    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| KnativeService
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| VirtualService
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Deployment
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| HPA

    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ConfigMaps
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Secrets
    CR_Manager -->|get, list, watch| Namespaces
    CR_Manager -->|get, list, watch| Pods
    CR_Manager -->|get, list, watch| ServiceAccounts
    CR_Manager -->|get, list, watch| Events

    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Ingress
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| MutatingWebhook
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ValidatingWebhook

    %% Leader Election Role Permissions
    CR_LeaderElection -->|get, list, watch,<br/>create, update| ConfigMapLE

