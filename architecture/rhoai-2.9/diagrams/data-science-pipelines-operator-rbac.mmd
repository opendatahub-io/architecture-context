graph TD
    subgraph "Operator Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: operator-namespace"]
    end

    subgraph "DSPA Instance Service Accounts"
        SA_Pipeline["ds-pipeline-{name}<br/>Namespace: dspa-namespace"]
        SA_Runner["pipeline-runner-{name}<br/>Namespace: dspa-namespace"]
        SA_WFC["ds-pipeline-workflow-controller-{name}<br/>Namespace: dspa-namespace"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager["manager-rolebinding<br/>ClusterRoleBinding"]
    end

    subgraph "Role Bindings"
        RB_Leader["leader-election-rolebinding<br/>RoleBinding"]
        RB_Pipeline["ds-pipeline-{name}<br/>RoleBinding"]
        RB_Runner["pipeline-runner-{name}<br/>RoleBinding"]
        RB_WFC["ds-pipeline-argo-{name}<br/>RoleBinding"]
        RB_UserAccess["ds-pipeline-user-access-{name}<br/>ClusterRoleBinding"]
    end

    subgraph "Cluster Roles"
        CR_Manager["manager-role<br/>ClusterRole"]
        CR_Leader["leader-election-role<br/>Role"]
        CR_Pipeline["ds-pipeline-{name}<br/>ClusterRole"]
        CR_Runner["pipeline-runner-{name}<br/>Role"]
        CR_WFC["ds-pipeline-argo-{name}<br/>Role"]
        CR_UserAccess["ds-pipeline-user-access-{name}<br/>ClusterRole"]
    end

    subgraph "API Resources - Operator Permissions"
        DSPA_Resources["DSPA Resources<br/>datasciencepipelinesapplications.opendatahub.io<br/>Verbs: create, delete, get, list, patch, update, watch"]

        K8s_Resources["Core Resources<br/>deployments, services, configmaps, secrets, pods, PVCs<br/>Verbs: create, delete, get, list, patch, update, watch"]

        OpenShift_Resources["OpenShift Resources<br/>routes, imagestreamtags<br/>Verbs: create, delete, get, list, patch, update, watch"]

        RBAC_Resources["RBAC Resources<br/>roles, rolebindings, clusterroles, clusterrolebindings<br/>Verbs: create, delete, get, list, patch, update, watch"]

        Network_Resources["Network Resources<br/>networkpolicies<br/>Verbs: create, delete, get, list, patch, update, watch"]

        Workflow_Resources["Workflow Resources<br/>Argo workflows, workflowtaskresults<br/>Tekton resources<br/>Verbs: all"]

        Monitoring_Resources["Monitoring Resources<br/>servicemonitors<br/>Verbs: create, delete, get, list, patch, update, watch"]

        Auth_Resources["Auth Resources<br/>tokenreviews, subjectaccessreviews<br/>Verbs: create"]
    end

    subgraph "API Resources - DSPA Instance Permissions"
        Argo_Resources["Argo Workflows<br/>workflows, workflowtaskresults<br/>Verbs: create, get, list, watch, update, patch, delete"]

        Pod_Resources["Pod Resources<br/>pods, pods/exec, pods/log, services<br/>Verbs: create, get, list, watch, update, patch, delete"]

        Pipeline_Runner_Resources["Pipeline Runner<br/>workflows: get, list, watch<br/>pods, pods/log: get, list"]

        User_Access_Resources["User Access<br/>datasciencepipelinesapplications<br/>Verbs: get"]
    end

    %% Operator Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    CRB_Manager -->|grants| CR_Manager
    RB_Leader -->|grants| CR_Leader

    %% DSPA Instance Service Account Bindings
    SA_Pipeline -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| CR_Pipeline

    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| CR_Runner

    SA_WFC -->|bound via| RB_WFC
    RB_WFC -->|grants| CR_WFC

    %% User Access Binding
    RB_UserAccess -->|grants| CR_UserAccess

    %% Operator Permissions
    CR_Manager -->|manages| DSPA_Resources
    CR_Manager -->|manages| K8s_Resources
    CR_Manager -->|manages| OpenShift_Resources
    CR_Manager -->|manages| RBAC_Resources
    CR_Manager -->|manages| Network_Resources
    CR_Manager -->|manages| Workflow_Resources
    CR_Manager -->|manages| Monitoring_Resources
    CR_Manager -->|creates| Auth_Resources

    %% DSPA Instance Permissions
    CR_Pipeline -->|manages| Argo_Resources
    CR_Pipeline -->|manages| Pod_Resources
    CR_Runner -->|reads| Pipeline_Runner_Resources
    CR_UserAccess -->|reads| User_Access_Resources

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Pipeline fill:#50c878,stroke:#333,stroke-width:2px
    style SA_Runner fill:#50c878,stroke:#333,stroke-width:2px
    style SA_WFC fill:#50c878,stroke:#333,stroke-width:2px

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Pipeline fill:#ffa500,stroke:#333,stroke-width:2px
    style CR_Runner fill:#ffa500,stroke:#333,stroke-width:2px
    style CR_WFC fill:#ffa500,stroke:#333,stroke-width:2px
    style CR_UserAccess fill:#ffa500,stroke:#333,stroke-width:2px

    style CRB_Manager fill:#9673a6,stroke:#333,stroke-width:2px
    style RB_Leader fill:#9673a6,stroke:#333,stroke-width:2px
    style RB_Pipeline fill:#b19cd9,stroke:#333,stroke-width:2px
    style RB_Runner fill:#b19cd9,stroke:#333,stroke-width:2px
    style RB_WFC fill:#b19cd9,stroke:#333,stroke-width:2px
    style RB_UserAccess fill:#9673a6,stroke:#333,stroke-width:2px

    style DSPA_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style K8s_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style OpenShift_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style RBAC_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style Network_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style Workflow_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style Monitoring_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style Auth_Resources fill:#e1d5e7,stroke:#333,stroke-width:1px
    style Argo_Resources fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Pod_Resources fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Pipeline_Runner_Resources fill:#d5e8d4,stroke:#333,stroke-width:1px
    style User_Access_Resources fill:#d5e8d4,stroke:#333,stroke-width:1px
