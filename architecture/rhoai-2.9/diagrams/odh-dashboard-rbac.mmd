graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[odh-dashboard-cluster-monitoring<br/>ClusterRoleBinding]
    end

    subgraph "RoleBindings"
        RB1[odh-dashboard<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
        RB2[image-puller<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]
        CR_AuthDelegator[system:auth-delegator<br/>ClusterRole]
        CR_Monitoring[cluster-monitoring-view<br/>ClusterRole]
        CR_ImagePuller[system:image-puller<br/>ClusterRole]
    end

    subgraph "Namespaced Role Permissions"
        NR[odh-dashboard<br/>Role<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Cluster-Scoped API Resources"
        Nodes[Core: nodes<br/>Verbs: get, list]
        Namespaces[Core: namespaces<br/>Verbs: get, list, watch,<br/>create, update, patch, delete]
        ClusterVersions[config.openshift.io<br/>ClusterVersions<br/>Verbs: get, watch, list]
        CSV[operators.coreos.com<br/>ClusterServiceVersions<br/>Subscriptions<br/>Verbs: get, list, watch]
        Users[user.openshift.io<br/>Users, Groups<br/>Verbs: get, list, watch]
        Routes[route.openshift.io<br/>Routes<br/>Verbs: get, list, watch]
        ConsoleLinks[console.openshift.io<br/>ConsoleLinks<br/>Verbs: get, list, watch]
        RBACResources[rbac.authorization.k8s.io<br/>RoleBindings, ClusterRoleBindings, Roles<br/>Verbs: get, list, watch,<br/>create, update, patch, delete]
        Notebooks_Cluster[kubeflow.org<br/>Notebooks<br/>Verbs: get, list, watch,<br/>create, update, patch, delete]
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceClusters<br/>Verbs: list, watch, get]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitializations<br/>Verbs: list, watch, get]
    end

    subgraph "Namespace-Scoped API Resources"
        ConfigMaps[Core: configmaps,<br/>secrets, persistentvolumeclaims,<br/>pods, serviceaccounts, services<br/>Verbs: create, delete, get,<br/>list, patch, update, watch]
        AcceleratorProfiles[dashboard.opendatahub.io<br/>AcceleratorProfiles<br/>Verbs: create, get, list,<br/>update, patch, delete]
        OdhApps[dashboard.opendatahub.io<br/>OdhApplications, OdhDocuments<br/>Verbs: get, list]
        QuickStarts[console.openshift.io<br/>OdhQuickStarts<br/>Verbs: get, list]
        DashboardConfigs[opendatahub.io<br/>OdhDashboardConfigs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete]
        Templates[template.openshift.io<br/>Templates<br/>Verbs: all]
        ServingRuntimes[serving.kserve.io<br/>ServingRuntimes<br/>Verbs: all]
        Notebooks_NS[kubeflow.org<br/>Notebooks<br/>Verbs: get, list, watch,<br/>create, update, patch, delete]
        ImageStreams[image.openshift.io<br/>ImageStreams<br/>Verbs: create, get, list,<br/>update, patch, delete]
        Builds[build.openshift.io<br/>Builds, BuildConfigs<br/>Verbs: get, list, watch,<br/>create, patch, delete]
        Jobs[batch<br/>CronJobs, Jobs<br/>Verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    SA -->|bound via| RB2

    %% Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| CR_AuthDelegator
    CRB3 -->|grants| CR_Monitoring
    RB1 -->|grants| NR
    RB2 -->|grants| CR_ImagePuller

    %% ClusterRole to Resources
    CR -->|permissions| Nodes
    CR -->|permissions| Namespaces
    CR -->|permissions| ClusterVersions
    CR -->|permissions| CSV
    CR -->|permissions| Users
    CR -->|permissions| Routes
    CR -->|permissions| ConsoleLinks
    CR -->|permissions| RBACResources
    CR -->|permissions| Notebooks_Cluster
    CR -->|permissions| DSC
    CR -->|permissions| DSCI

    %% Namespaced Role to Resources
    NR -->|permissions| ConfigMaps
    NR -->|permissions| AcceleratorProfiles
    NR -->|permissions| OdhApps
    NR -->|permissions| QuickStarts
    NR -->|permissions| DashboardConfigs
    NR -->|permissions| Templates
    NR -->|permissions| ServingRuntimes
    NR -->|permissions| Notebooks_NS
    NR -->|permissions| ImageStreams
    NR -->|permissions| Builds
    NR -->|permissions| Jobs

    %% Special cluster permissions
    CR_AuthDelegator -->|delegates| AuthDelegation[Authentication Delegation<br/>to kube-system]
    CR_Monitoring -->|allows| MonitoringAccess[Prometheus/Thanos Query Access<br/>in openshift-monitoring]
    CR_ImagePuller -->|allows| ImagePull[Pull Images from Registry]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style NR fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR_AuthDelegator fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR_Monitoring fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR_ImagePuller fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff

    style CRB1 fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style CRB2 fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style CRB3 fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style RB1 fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style RB2 fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

