    style AcceleratorProfiles fill:#d5e8d4,stroke:#82b366,color:#000
    style OdhApps fill:#d5e8d4,stroke:#82b366,color:#000
    style QuickStarts fill:#d5e8d4,stroke:#82b366,color:#000
    style DashboardConfigs fill:#d5e8d4,stroke:#82b366,color:#000
    style Templates fill:#d5e8d4,stroke:#82b366,color:#000
    style ServingRuntimes fill:#d5e8d4,stroke:#82b366,color:#000
    style Notebooks_NS fill:#d5e8d4,stroke:#82b366,color:#000
