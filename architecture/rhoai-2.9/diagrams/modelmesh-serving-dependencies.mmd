graph LR
    ModelMesh[ModelMesh Serving]

    %% External Dependencies (Required)
    ModelMesh -->|"model metadata<br/>gRPC/2379"| etcd[etcd v3.2.32+<br/>REQUIRED]
    ModelMesh -->|"model artifacts<br/>HTTPS/443"| S3[S3-compatible Storage<br/>REQUIRED]
    ModelMesh -->|"CRD management<br/>HTTPS/6443"| K8sAPI[Kubernetes API<br/>REQUIRED]

    %% External Dependencies (Optional)
    ModelMesh -.->|"TLS certs<br/>optional"| CertManager[cert-manager<br/>OPTIONAL]
    ModelMesh -.->|"metrics<br/>HTTP/2112,8443"| Prometheus[Prometheus Operator<br/>OPTIONAL]

    %% Model Server Runtimes (Optional - at least one needed)
    ModelMesh -.->|"inference<br/>gRPC/8001"| Triton[Triton Inference Server 2.x<br/>OPTIONAL]
    ModelMesh -.->|"inference<br/>gRPC/8001"| MLServer[MLServer 1.x<br/>OPTIONAL]
    ModelMesh -.->|"inference<br/>gRPC/8001"| OpenVINO[OpenVINO Model Server 1.x<br/>OPTIONAL]
    ModelMesh -.->|"inference<br/>gRPC/8001"| TorchServe[TorchServe 0.x<br/>OPTIONAL]

    %% Internal ODH/RHOAI Dependencies
    ModelMesh -->|"user auth<br/>OAuth 2.0"| OSAuth[OpenShift OAuth<br/>INTERNAL]
    ModelMesh -.->|"UI integration"| Dashboard[RHOAI Dashboard<br/>INTERNAL]
    ModelMesh -.->|"ServiceMonitor"| OSMonitoring[OpenShift Monitoring<br/>INTERNAL]

    %% Integration Points
    Dashboard -->|"manages via UI"| ModelMesh
    Pipelines[Data Science Pipelines] -.->|"auto deploy models"| ModelMesh

