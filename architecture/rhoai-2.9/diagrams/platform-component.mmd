graph TB
    subgraph "Red Hat OpenShift AI 2.9 Platform"
        subgraph "Core Platform (redhat-ods-operator)"
            RHODSOp[RHODS Operator<br/>v1.6.0-556]
        end

        subgraph "Application Services (redhat-ods-applications)"
            Dashboard[ODH Dashboard<br/>v1.21.0-18<br/>2 replicas HA]
            NotebookCtrl[Notebook Controller<br/>v1.27.0]
            DSPOp[Data Science Pipelines<br/>cf823f3]
            KServeOp[KServe Operator<br/>69cb9fee0]
            ModelMeshOp[ModelMesh Operator<br/>v1.27.0-188]
            ODHModelCtrl[ODH Model Controller<br/>v1.27.0-297<br/>3 replicas HA]
            KubeRayOp[KubeRay Operator<br/>v1.1.0]
            CodeFlareOp[CodeFlare Operator<br/>v-2160]
            KueueOp[Kueue Operator<br/>v0.6.2]
            TrustyAIOp[TrustyAI Operator<br/>f6fd5aa]
        end

        subgraph "Monitoring (redhat-ods-monitoring)"
            Prometheus[Prometheus]
            Grafana[Grafana]
            Alertmanager[Alertmanager]
        end

        subgraph "User Workloads (User Namespaces)"
            Notebooks[Jupyter/VS Code/RStudio<br/>Notebook Pods]
            InferenceServices[KServe/ModelMesh<br/>InferenceServices]
            Pipelines[Argo/Tekton<br/>Pipeline Runs]
            RayClusters[Ray Clusters<br/>Distributed Computing]
            TrustyAI[TrustyAI Services<br/>Model Monitoring]
        end
    end

    subgraph "Infrastructure (istio-system)"
        ServiceMesh[Service Mesh<br/>Istio 2.x]
        IngressGW[Knative Ingress Gateway]
    end

    subgraph "External Dependencies"
        OAuth[OpenShift OAuth<br/>Authentication]
        K8sAPI[Kubernetes API<br/>6443/TCP]
        S3[S3 Storage<br/>AWS/MinIO/IBM COS]
        Registry[Container Registry<br/>Quay.io/RedHat]
    end

    %% Core relationships
    RHODSOp -->|deploys/manages| Dashboard
    RHODSOp -->|deploys/manages| NotebookCtrl
    RHODSOp -->|deploys/manages| DSPOp
    RHODSOp -->|deploys/manages| KServeOp
    RHODSOp -->|deploys/manages| ModelMeshOp
    RHODSOp -->|deploys/manages| ODHModelCtrl
    RHODSOp -->|deploys/manages| KubeRayOp
    RHODSOp -->|deploys/manages| CodeFlareOp
    RHODSOp -->|deploys/manages| KueueOp
    RHODSOp -->|deploys/manages| TrustyAIOp
    RHODSOp -->|configures| ServiceMesh

    %% Dashboard interactions
    Dashboard -->|creates CRs| NotebookCtrl
    Dashboard -->|creates CRs| DSPOp
    Dashboard -->|creates CRs| KServeOp
    Dashboard -->|queries metrics| Prometheus

    %% Workload creation
    NotebookCtrl -->|creates| Notebooks
    KServeOp -->|creates| InferenceServices
    ODHModelCtrl -->|creates Routes/VirtualServices| InferenceServices
    DSPOp -->|creates| Pipelines
    KubeRayOp -->|creates| RayClusters
    CodeFlareOp -->|secures| RayClusters
    KueueOp -->|manages resources| RayClusters
    TrustyAIOp -->|creates| TrustyAI

    %% Service Mesh integration
    ServiceMesh -->|provides mTLS| InferenceServices
    ServiceMesh -->|traffic management| InferenceServices
    IngressGW -->|routes traffic| InferenceServices

    %% Monitoring
    Prometheus -->|scrapes metrics| Dashboard
    Prometheus -->|scrapes metrics| RHODSOp
    Prometheus -->|scrapes metrics| InferenceServices
    Prometheus -->|scrapes metrics| TrustyAI
    Grafana -->|visualizes| Prometheus

    %% External dependencies
    Dashboard -->|authenticates| OAuth
    Notebooks -->|authenticates| OAuth
    InferenceServices -->|authenticates| OAuth
    RayClusters -->|authenticates| OAuth

    RHODSOp -->|watches CRDs| K8sAPI
    Dashboard -->|API calls| K8sAPI
    NotebookCtrl -->|API calls| K8sAPI
    KServeOp -->|API calls| K8sAPI

    InferenceServices -->|model artifacts| S3
    Pipelines -->|pipeline data| S3
    Notebooks -->|datasets| S3

    RHODSOp -->|pulls images| Registry
    Notebooks -->|pulls images| Registry
    InferenceServices -->|pulls images| Registry

