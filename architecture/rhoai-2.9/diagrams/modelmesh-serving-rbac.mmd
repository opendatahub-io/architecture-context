graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>Namespace: modelmesh-serving]
        SA_Runtime[modelmesh-serving-sa<br/>Namespace: user-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        RB_Leader[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR_Controller[modelmesh-controller-role<br/>ClusterRole]
        CR_Leader[leader-election-role<br/>Role]
    end

    subgraph "User Roles"
        CR_ISVCEditor[inferenceservice-editor-role]
        CR_ISVCViewer[inferenceservice-viewer-role]
        CR_PredEditor[predictor-editor-role]
        CR_PredViewer[predictor-viewer-role]
        CR_SREditor[servingruntime-editor-role]
        CR_SRViewer[servingruntime-viewer-role]
    end

    subgraph "API Resources - serving.kserve.io"
        InferenceService["InferenceService<br/>(v1beta1)"]
        Predictor["Predictor<br/>(v1alpha1)"]
        ServingRuntime["ServingRuntime<br/>(v1alpha1)"]
        ClusterServingRuntime["ClusterServingRuntime<br/>(v1alpha1)"]
    end

    subgraph "API Resources - Core & Apps"
        ConfigMaps[ConfigMaps]
        Secrets[Secrets]
        Services[Services]
        Namespaces[Namespaces]
        Deployments[Deployments]
        HPA[HorizontalPodAutoscalers]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Leader
    CRB_Controller -->|grants| CR_Controller
    RB_Leader -->|grants| CR_Leader

    %% Controller Permissions
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| ConfigMaps
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| Secrets
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| Services
    CR_Controller -->|"get,list,watch"| Namespaces
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| Deployments
    CR_Controller -->|"create,delete,get,list,watch,update"| HPA
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| ServiceMonitors

    CR_Controller -->|"create,delete,get,list,patch,update,watch"| InferenceService
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| Predictor
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| ServingRuntime
    CR_Controller -->|"create,delete,get,list,patch,update,watch"| ClusterServingRuntime

    CR_Controller -->|"get,patch,update (status)"| InferenceService
    CR_Controller -->|"get,patch,update (status)"| Predictor
    CR_Controller -->|"get,patch,update (status)"| ServingRuntime
    CR_Controller -->|"get,patch,update (status)"| ClusterServingRuntime

    CR_Controller -->|"get,patch,update (finalizers)"| InferenceService
    CR_Controller -->|"get,patch,update (finalizers)"| Predictor
    CR_Controller -->|"get,patch,update (finalizers)"| ServingRuntime
    CR_Controller -->|"get,patch,update (finalizers)"| ClusterServingRuntime

    %% User Role Permissions
    CR_ISVCEditor -->|"create,delete,get,list,patch,update,watch"| InferenceService
    CR_ISVCViewer -->|"get,list,watch"| InferenceService
    CR_PredEditor -->|"create,delete,get,list,patch,update,watch"| Predictor
    CR_PredViewer -->|"get,list,watch"| Predictor
    CR_SREditor -->|"create,delete,get,list,patch,update,watch"| ServingRuntime
    CR_SRViewer -->|"get,list,watch"| ServingRuntime

    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Runtime fill:#4a90e2,color:#fff
    style CR_Controller fill:#f5a623,color:#000
    style CR_Leader fill:#f5a623,color:#000
    style InferenceService fill:#7ed321
    style Predictor fill:#7ed321
    style ServingRuntime fill:#7ed321
    style ClusterServingRuntime fill:#7ed321
    style ConfigMaps fill:#e8e8e8
    style Secrets fill:#e8e8e8
    style Services fill:#e8e8e8
    style Deployments fill:#e8e8e8
