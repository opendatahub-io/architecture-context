graph TD
    subgraph "Notebook Pod Context"
        SA["{notebook-name}-sa<br/>(ServiceAccount)"]
    end

    subgraph "RBAC Inheritance"
        Note1["Notebook pods run with<br/>user-provided ServiceAccounts"]
        Note2["Permissions scoped to<br/>user namespace"]
        Note3["Inherited RBAC from<br/>Notebook Controller component"]
    end

    subgraph "OAuth Proxy Authorization"
        OAuthPolicy["OAuth2 Bearer Token<br/>Validation Policy"]
    end

    subgraph "Kubernetes API Permissions"
        direction TB
        K8sSecrets["Secrets<br/>get, list<br/>(aws-credentials, git-credentials)"]
        K8sConfigMaps["ConfigMaps<br/>get, list"]
        K8sPods["Pods<br/>get, list, watch"]
        K8sServices["Services<br/>get, list"]
    end

    subgraph "OpenShift RBAC Roles"
        ViewerRole["Namespace Viewer Role<br/>(for /api endpoint access)"]
        EditorRole["Namespace Editor Role<br/>(optional - for advanced users)"]
    end

    subgraph "Accessible Resources"
        direction TB
        JupyterEndpoint["/notebook/{namespace}/{user}/<br/>GET, POST, WebSocket<br/>OAuth2 required"]
        APIEndpoint["/notebook/{namespace}/{user}/api<br/>GET<br/>Namespace viewer role"]
        S3Access["S3 Storage Access<br/>via aws-credentials secret"]
        GitAccess["Git Repository Access<br/>via git-credentials secret"]
    end

    %% Relationships
    SA -->|authenticated via| OAuthPolicy
    SA -->|bound to| ViewerRole
    SA -.->|optionally bound to| EditorRole

    ViewerRole -->|grants access| K8sSecrets
    ViewerRole -->|grants access| K8sConfigMaps
    ViewerRole -->|grants access| K8sPods
    ViewerRole -->|grants access| K8sServices

    SA -->|accesses| K8sSecrets
    K8sSecrets -->|provides credentials| S3Access
    K8sSecrets -->|provides credentials| GitAccess

    OAuthPolicy -->|enforces| JupyterEndpoint
    ViewerRole -->|required for| APIEndpoint

    Note1 -.->|applies to| SA
    Note2 -.->|scopes| ViewerRole
    Note3 -.->|inherits from| Note1

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style OAuthPolicy fill:#f5a623
    style ViewerRole fill:#7ed321
    style EditorRole fill:#7ed321
    style K8sSecrets fill:#50e3c2
    style K8sConfigMaps fill:#50e3c2
    style K8sPods fill:#50e3c2
    style K8sServices fill:#50e3c2
    style JupyterEndpoint fill:#bd10e0,color:#fff
    style APIEndpoint fill:#bd10e0,color:#fff
    style S3Access fill:#9013fe,color:#fff
    style GitAccess fill:#9013fe,color:#fff
    style Note1 fill:#e8e8e8
    style Note2 fill:#e8e8e8
    style Note3 fill:#e8e8e8
