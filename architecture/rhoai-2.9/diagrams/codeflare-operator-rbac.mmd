graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: operator-ns]
        SA_OAuth["{cluster}-oauth-proxy<br/>Namespace: user-ns<br/>per RayCluster"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_OAuth["{cluster}-{namespace}-auth<br/>ClusterRoleBinding<br/>per RayCluster"]
    end

    subgraph "ClusterRole Bindings - Leader Election"
        RB_Leader[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: operator-ns]
    end

    subgraph "Cluster Roles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_SystemAuth[system:auth-delegator<br/>ClusterRole<br/>K8s built-in]
        R_Leader[leader-election-role<br/>Role<br/>Namespace: operator-ns]
    end

    subgraph "API Resources - Core"
        R_Secrets[core/secrets<br/>get, list, watch, update, create, patch, delete]
        R_Services[core/services<br/>get, create, update, patch, delete]
        R_SA[core/serviceaccounts<br/>get, create, update, patch, delete]
    end

    subgraph "API Resources - Admission"
        R_MutatingWH[admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>get, list, watch, update]
        R_ValidatingWH[admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get, list, watch, update]
    end

    subgraph "API Resources - CRDs"
        R_CRD[apiextensions.k8s.io<br/>customresourcedefinitions<br/>get, list, watch]
        R_RayCluster[ray.io/rayclusters<br/>get, list, watch, create, update, patch, delete]
        R_RayStatus[ray.io/rayclusters/status<br/>get, update, patch]
        R_RayFinalizers[ray.io/rayclusters/finalizers<br/>update]
        R_DSCInit[dscinitialization.opendatahub.io<br/>dscinitializations<br/>get, list, watch]
    end

    subgraph "API Resources - Networking"
        R_Ingress[networking.k8s.io/ingresses<br/>get, create, update, patch, delete]
        R_NetPol[networking.k8s.io/networkpolicies<br/>get, create, update, patch, delete]
    end

    subgraph "API Resources - RBAC"
        R_CRB[rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get, create, update, patch, delete]
    end

    subgraph "API Resources - OpenShift"
        R_Routes[route.openshift.io/routes<br/>get, create, update, patch, delete]
        R_RoutesCustomHost[route.openshift.io/routes/custom-host<br/>get, create, update, patch, delete]
        R_ConfigIngress[config.openshift.io/ingresses<br/>get]
    end

    subgraph "API Resources - Auth"
        R_TokenReview[authentication.k8s.io/tokenreviews<br/>create]
        R_SubjectAccessReview[authorization.k8s.io/subjectaccessreviews<br/>create]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    SA_OAuth -->|bound via| CRB_OAuth

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_Leader -->|grants| R_Leader
    CRB_OAuth -->|grants| CR_SystemAuth

    %% ClusterRole to Resources - Core
    CR_Manager -->|permissions| R_Secrets
    CR_Manager -->|permissions| R_Services
    CR_Manager -->|permissions| R_SA

    %% ClusterRole to Resources - Admission
    CR_Manager -->|permissions| R_MutatingWH
    CR_Manager -->|permissions| R_ValidatingWH

    %% ClusterRole to Resources - CRDs
    CR_Manager -->|permissions| R_CRD
    CR_Manager -->|permissions| R_RayCluster
    CR_Manager -->|permissions| R_RayStatus
    CR_Manager -->|permissions| R_RayFinalizers
    CR_Manager -->|permissions| R_DSCInit

    %% ClusterRole to Resources - Networking
    CR_Manager -->|permissions| R_Ingress
    CR_Manager -->|permissions| R_NetPol

    %% ClusterRole to Resources - RBAC
    CR_Manager -->|permissions| R_CRB

    %% ClusterRole to Resources - OpenShift
    CR_Manager -->|permissions| R_Routes
    CR_Manager -->|permissions| R_RoutesCustomHost
    CR_Manager -->|permissions| R_ConfigIngress

    %% ClusterRole to Resources - Auth
    CR_Manager -->|permissions| R_TokenReview
    CR_Manager -->|permissions| R_SubjectAccessReview

    %% system:auth-delegator purpose
    CR_SystemAuth -.->|allows OAuth proxy to<br/>delegate authentication| K8sAuth[Kubernetes Authentication]

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_OAuth fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_SystemAuth fill:#999,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_Manager fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB_OAuth fill:#7ed321,stroke:#333,stroke-width:2px
    style RB_Leader fill:#7ed321,stroke:#333,stroke-width:2px

    style R_Secrets fill:#dae8fc,stroke:#333,stroke-width:1px
    style R_Services fill:#dae8fc,stroke:#333,stroke-width:1px
    style R_SA fill:#dae8fc,stroke:#333,stroke-width:1px
    style R_MutatingWH fill:#d5e8d4,stroke:#333,stroke-width:1px
    style R_ValidatingWH fill:#d5e8d4,stroke:#333,stroke-width:1px
    style R_RayCluster fill:#ffe6cc,stroke:#333,stroke-width:1px
    style R_RayStatus fill:#ffe6cc,stroke:#333,stroke-width:1px
    style R_RayFinalizers fill:#ffe6cc,stroke:#333,stroke-width:1px
    style R_NetPol fill:#e1d5e7,stroke:#333,stroke-width:1px
    style R_Ingress fill:#e1d5e7,stroke:#333,stroke-width:1px
    style R_Routes fill:#fff2cc,stroke:#333,stroke-width:1px
    style R_RoutesCustomHost fill:#fff2cc,stroke:#333,stroke-width:1px
