graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (OpenShift Router - HAProxy)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>TLS 1.2+"]
    end

    subgraph AppPod["APPLICATION POD<br/>Namespace: redhat-ods-applications<br/>ServiceAccount: odh-dashboard"]
        direction TB

        subgraph OAuthContainer["OAuth Proxy Container"]
            OAuthProxy["OAuth Proxy<br/>Port: 8443/TCP HTTPS<br/>TLS Cert: dashboard-proxy-tls<br/>Cookie: dashboard-oauth-config<br/>Client: dashboard-oauth-client"]
        end

        subgraph BackendContainer["Dashboard Backend Container"]
            Backend["Dashboard Backend<br/>Port: 8080/TCP HTTP<br/>Runtime: Node.js 18 / Fastify<br/>Image: odh-dashboard (UBI8)"]
        end

        OAuthProxy -->|HTTP/8080<br/>localhost<br/>x-forwarded-access-token| Backend
    end

    subgraph Egress["EGRESS DESTINATIONS"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: OAuth Client Creds"]

        Thanos["Thanos Querier<br/>Namespace: openshift-monitoring<br/>9092/TCP HTTPS<br/>TLS 1.2+<br/>Auth: User Bearer Token"]

        ImageRegistry["OpenShift Image Registry<br/>Namespace: openshift-image-registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]

        DSPipelines["Data Science Pipelines API<br/>Namespace: {user-namespace}<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
    end

    subgraph PublicEndpoints["PUBLIC ENDPOINTS (No Auth)"]
        HealthOAuth["/oauth/healthz<br/>HTTPS/8443"]
        Metrics["/metrics<br/>HTTPS/8443<br/>Prometheus scraping"]
    end

    %% External flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Session Cookie| Route
    Route -->|HTTPS/8443<br/>TLS Reencrypt<br/>Service Cert| OAuthProxy

    %% OAuth validation
    OAuthProxy -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Client Creds| OAuthServer

    %% Backend to external services
    Backend -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token: odh-dashboard| K8sAPI
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>User Bearer Token forwarded| Thanos
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| ImageRegistry
    Backend -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| DSPipelines

    %% Public endpoints
    OAuthProxy -.->|Public| HealthOAuth
    OAuthProxy -.->|Public<br/>Skip Auth| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef oauth fill:#f5a623,stroke:#d79b00,stroke-width:2px
    classDef backend fill:#4a90e2,stroke:#2e5f8a,stroke-width:2px
    classDef egress fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef public fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route ingress
    class OAuthProxy oauth
    class Backend backend
    class K8sAPI,OAuthServer,Thanos,ImageRegistry,DSPipelines egress
    class HealthOAuth,Metrics public
