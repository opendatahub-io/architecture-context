graph TB
    subgraph "RHODS Operator Pod"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        SecretGen[SecretGenerator Controller]
        CertGen[CertConfigmapGenerator Controller]
        ComponentRecon[Component Reconcilers]
        ManifestLoader[Manifest Loader]
        UpgradeMgr[Upgrade Manager]

        DSCController -->|uses| ComponentRecon
        DSCController -->|uses| ManifestLoader
        DSCIController -->|creates| SecretGen
        DSCIController -->|creates| CertGen
        DSCController -->|uses| UpgradeMgr
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FeatureTracker[FeatureTracker CR<br/>features.opendatahub.io/v1]
        KfDef[KfDef CR<br/>kfdef.apps.kubeflow.org/v1<br/><i>Legacy</i>]
    end

    subgraph "Component Deployments"
        Dashboard[ODH Dashboard]
        Workbenches[Workbenches<br/>Notebooks]
        DSP[Data Science Pipelines<br/>Tekton/Argo]
        KServe[KServe<br/>Model Serving]
        ModelMesh[ModelMesh Serving<br/>Seldon-based]
        CodeFlare[CodeFlare<br/>MCAD/InstaScale]
        Ray[Ray<br/>Distributed Computing]
        Kueue[Kueue<br/>Job Queueing]
    end

    subgraph "Platform Infrastructure"
        ServiceMesh[Service Mesh<br/>Istio/Maistra]
        Knative[Knative Serving<br/>Serverless]
        Authorino[Authorino<br/>Authorization]
        Monitoring[Monitoring<br/>Prometheus/Grafana]
    end

    User[Platform Admin] -->|creates/updates| DSC
    User -->|creates/updates| DSCI

    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController
    KfDef -->|migrated by| UpgradeMgr

    DSCController -->|deploys| Dashboard
    DSCController -->|deploys| Workbenches
    DSCController -->|deploys| DSP
    DSCController -->|deploys| KServe
    DSCController -->|deploys| ModelMesh
    DSCController -->|deploys| CodeFlare
    DSCController -->|deploys| Ray
    DSCController -->|deploys| Kueue

    DSCIController -->|configures| ServiceMesh
    DSCIController -->|integrates| Knative
    DSCIController -->|integrates| Authorino
    DSCIController -->|configures| Monitoring

    DSCController -->|creates| FeatureTracker

    KServe -.->|requires| ServiceMesh
    KServe -.->|requires| Knative
    KServe -.->|requires| Authorino

    K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+] -->|watch events| DSCController
    K8sAPI -->|watch events| DSCIController

    DSCController -->|CRUD operations<br/>ServiceAccount Token| K8sAPI
    DSCIController -->|CRUD operations<br/>ServiceAccount Token| K8sAPI

    Prometheus[Prometheus<br/>Monitoring] -->|scrapes /metrics<br/>8080/TCP HTTP| DSCController

    style DSCController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCIController fill:#4a90e2,stroke:#333,stroke-width:2px
    style SecretGen fill:#4a90e2,stroke:#333,stroke-width:2px
    style CertGen fill:#4a90e2,stroke:#333,stroke-width:2px
    style ComponentRecon fill:#4a90e2,stroke:#333,stroke-width:2px
    style ManifestLoader fill:#4a90e2,stroke:#333,stroke-width:2px
    style UpgradeMgr fill:#4a90e2,stroke:#333,stroke-width:2px

    style DSC fill:#f5a623,stroke:#333,stroke-width:2px
    style DSCI fill:#f5a623,stroke:#333,stroke-width:2px
    style FeatureTracker fill:#f5a623,stroke:#333,stroke-width:2px
    style KfDef fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Workbenches fill:#7ed321,stroke:#333,stroke-width:2px
    style DSP fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style CodeFlare fill:#7ed321,stroke:#333,stroke-width:2px
    style Ray fill:#7ed321,stroke:#333,stroke-width:2px
    style Kueue fill:#7ed321,stroke:#333,stroke-width:2px

    style ServiceMesh fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Knative fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Authorino fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Monitoring fill:#e8e8e8,stroke:#333,stroke-width:2px

    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px
