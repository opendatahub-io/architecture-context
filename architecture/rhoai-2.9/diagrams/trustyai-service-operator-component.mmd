graph TB
    subgraph "TrustyAI Service Operator"
        Controller["controller-manager<br/>Deployment<br/>Ports: 8081/healthz, 8080/metrics"]
    end

    subgraph "Managed TrustyAI Service Instance (per CR)"
        direction TB
        TrustyAIDeployment[TrustyAI Service<br/>Deployment]

        subgraph "Containers"
            TrustyAIContainer[trustyai-service container<br/>8080/TCP]
            OAuthProxy[oauth-proxy sidecar<br/>8443/TCP HTTPS]
        end

        TrustyAIDeployment --> TrustyAIContainer
        TrustyAIDeployment --> OAuthProxy

        OAuthProxy -->|proxies to| TrustyAIContainer

        PVC[PersistentVolumeClaim<br/>ReadWriteOnce]
        ServiceMonitor[ServiceMonitor<br/>Prometheus metrics]
        Route[OpenShift Route<br/>TLS Passthrough]
        ServiceInternal[Service: trustyai-instance<br/>80/TCP HTTP]
        ServiceTLS[Service: trustyai-instance-tls<br/>443/TCP HTTPS]

        TrustyAIContainer -->|mounts| PVC
        TrustyAIDeployment -->|exposed by| ServiceInternal
        TrustyAIDeployment -->|exposed by| ServiceTLS
        ServiceMonitor -->|scrapes| ServiceInternal
        Route -->|routes to| ServiceTLS
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    User[User] -->|creates| TrustyAIServiceCR
    TrustyAIServiceCR -->|watched by| Controller
    Controller -->|creates/manages| TrustyAIDeployment
    Controller -->|creates| PVC
    Controller -->|creates| ServiceInternal
    Controller -->|creates| ServiceTLS
    Controller -->|creates| ServiceMonitor
    Controller -->|creates| Route

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        PrometheusOp[Prometheus Operator]
        CertManager[cert-manager /<br/>service-ca]
    end

    Controller -->|reconciles via| K8sAPI
    ServiceMonitor -.->|requires| PrometheusOp
    OAuthProxy -.->|TLS cert from| CertManager

    subgraph "Integration Points"
        KServe[KServe<br/>InferenceServices]
        ModelMesh[ModelMesh<br/>Serving Runtime]
        Prometheus[Prometheus<br/>Metrics Collection]
        OpenShiftOAuth[OpenShift OAuth<br/>Authentication]
    end

    Controller -->|patches Logger.URL| KServe
    Controller -->|injects MM_PAYLOAD_PROCESSORS| ModelMesh
    KServe -->|sends payloads to| TrustyAIContainer
    ModelMesh -->|sends payloads to| TrustyAIContainer
    Prometheus -->|scrapes metrics from| ServiceInternal
    OAuthProxy -->|validates tokens via| OpenShiftOAuth

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style TrustyAIContainer fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PrometheusOp fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style OpenShiftOAuth fill:#7ed321,stroke:#333
