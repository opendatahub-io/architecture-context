graph TD
    subgraph "Service Accounts"
        SA[notebook-controller-service-account<br/>Namespace: kubeflow]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding]
        CRB2[leader-election-role-binding]
    end

    subgraph "ClusterRoles"
        CR1[notebook-controller-role<br/>Main permissions]
        CR2[leader-election-role<br/>HA coordination]
        CR3[kubeflow-notebooks-edit<br/>User edit role]
        CR4[kubeflow-notebooks-view<br/>User view role]
    end

    subgraph "API Resources - apps"
        R1[StatefulSets<br/>Verbs: *]
    end

    subgraph "API Resources - core"
        R2[Services<br/>Verbs: *]
        R3[Pods<br/>Verbs: delete, get, list, watch]
        R4[Events<br/>Verbs: create, get, list, patch, watch]
        R5[ConfigMaps<br/>Verbs: get, list, watch, create, update, patch, delete]
        R6[ConfigMaps/status<br/>Verbs: get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - kubeflow.org"
        R7[Notebooks<br/>Verbs: *]
        R8[Notebooks/finalizers<br/>Verbs: *]
        R9[Notebooks/status<br/>Verbs: *]
    end

    subgraph "API Resources - networking.istio.io"
        R10[VirtualServices<br/>Verbs: *]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% notebook-controller-role permissions
    CR1 -->|all operations| R1
    CR1 -->|all operations| R2
    CR1 -->|delete, get, list, watch| R3
    CR1 -->|create, get, list, patch, watch| R4
    CR1 -->|all operations| R7
    CR1 -->|all operations| R8
    CR1 -->|all operations| R9
    CR1 -->|all operations| R10

    %% leader-election-role permissions
    CR2 -->|full access| R5
    CR2 -->|full access| R6
    CR2 -->|create| R4

    %% User roles (aggregated roles for end users)
    Users[Users/Data Scientists] -.->|can be granted| CR3
    Users -.->|can be granted| CR4

    CR3 -->|get, list, watch, create, delete, deletecollection, patch, update| R7
    CR3 -->|get, list, watch, create, delete, deletecollection, patch, update| R9

    CR4 -->|get, list, watch| R7
    CR4 -->|get, list, watch| R9

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR4 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#50c8ff,stroke:#333,stroke-width:2px
    style CRB2 fill:#50c8ff,stroke:#333,stroke-width:2px

    %% Resources with broad permissions (security concern)
    style R1 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px
    style R2 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px
    style R7 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px
    style R8 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px
    style R9 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px
    style R10 fill:#ffe6e6,stroke:#d32f2f,stroke-width:2px

    %% Other resources
    style R3 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style R4 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style R5 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style R6 fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    style Users fill:#999,stroke:#333,stroke-width:2px
