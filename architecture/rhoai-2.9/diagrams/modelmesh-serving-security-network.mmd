graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Inference Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.3<br/>Edge Termination"]
    end

    subgraph RuntimePod["RUNTIME POD (Trusted - Internal Network)"]
        direction TB

        OAuthProxy["OAuth Proxy<br/>Port: 8443/TCP<br/>TLS 1.2+<br/>Auth: OpenShift OAuth"]
        RESTProxy["REST Proxy<br/>Port: 8008/TCP<br/>HTTP (no encryption)<br/>HTTP→gRPC translation"]
        ModelMesh["ModelMesh<br/>Ports: 8033 (gRPC inference)<br/>8080 (inter-pod)<br/>2112 (metrics)<br/>8089 (probes)"]
        Adapter["Runtime Adapter<br/>Port: 8085/TCP<br/>gRPC"]
        Server["Model Server<br/>Triton/MLServer/OpenVINO<br/>Port: 8001/TCP<br/>gRPC"]

        OAuthProxy -->|"HTTP/8008<br/>No Encryption"| RESTProxy
        RESTProxy -->|"gRPC/8033<br/>No Encryption"| ModelMesh
        ModelMesh -->|"gRPC/8085<br/>No Encryption"| Adapter
        Adapter -->|"gRPC/8001<br/>No Encryption"| Server
    end

    subgraph Controller["CONTROLLER (Management Plane)"]
        direction TB

        ControllerPod["modelmesh-controller<br/>SA: modelmesh-controller<br/>Replicas: 1-3 (HA)"]
        WebhookServer["Webhook Server<br/>Port: 9443/TCP<br/>HTTPS TLS 1.2+<br/>mTLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        etcd["etcd<br/>Port: 2379/TCP<br/>gRPC<br/>No Encryption"]
        S3["S3 Storage<br/>Port: 443/TCP<br/>HTTPS TLS 1.2+<br/>S3 Credentials"]
        OSAuth["OpenShift OAuth<br/>Port: 6443/TCP<br/>HTTPS TLS 1.3<br/>OAuth 2.0"]
        K8sAPI["Kubernetes API<br/>Port: 6443/TCP<br/>HTTPS TLS 1.3<br/>ServiceAccount Token"]
        Prometheus["Prometheus<br/>Scrape: 2112/TCP (runtime)<br/>8443/TCP (controller)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>No Auth"| Router
    Router -->|"HTTPS/8443<br/>TLS 1.2+"| OAuthProxy
    OAuthProxy -->|"HTTPS/6443<br/>TLS 1.3<br/>OAuth Token"| OSAuth

    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials"| S3
    ModelMesh -->|"gRPC/2379<br/>No Encryption"| etcd
    ControllerPod -->|"gRPC/2379<br/>No Encryption"| etcd
    ControllerPod -->|"HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>mTLS"| WebhookServer

    Prometheus -->|"HTTP/2112<br/>No Auth"| ModelMesh
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>ServiceAccount Token"| ControllerPod

    %% Inter-pod communication
    ModelMesh -.->|"gRPC/8080<br/>Inter-pod<br/>No Encryption"| ModelMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class OAuthProxy,RESTProxy,ModelMesh,Adapter,Server trusted
    class ControllerPod,WebhookServer controller
    class etcd,S3,OSAuth,K8sAPI,Prometheus externalservice
