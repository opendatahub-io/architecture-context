graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[Webhook Server<br/>Port 9443]
        Visibility[Visibility Server<br/>Port 8082]
        Metrics[Metrics Server<br/>Port 8080]

        Controller -->|exposes| Webhook
        Controller -->|exposes| Visibility
        Controller -->|exposes| Metrics
    end

    subgraph "Core Controllers"
        CQController[ClusterQueue Controller]
        LQController[LocalQueue Controller]
        WLController[Workload Controller]
        ACController[AdmissionCheck Controller]
        RFController[ResourceFlavor Controller]

        Controller -->|runs| CQController
        Controller -->|runs| LQController
        Controller -->|runs| WLController
        Controller -->|runs| ACController
        Controller -->|runs| RFController
    end

    subgraph "Job Integration Controllers"
        JobController[Job Controller]
        JobSetController[JobSet Controller]
        PodController[Pod Controller]
        PyTorchController[PyTorchJob Controller]
        TFController[TFJob Controller]
        MPIController[MPIJob Controller]
        RayJobController[RayJob Controller]
        RayClusterController[RayCluster Controller]

        Controller -->|runs| JobController
        Controller -->|runs| JobSetController
        Controller -->|runs| PodController
        Controller -->|runs| PyTorchController
        Controller -->|runs| TFController
        Controller -->|runs| MPIController
        Controller -->|runs| RayJobController
        Controller -->|runs| RayClusterController
    end

    subgraph "Custom Resources"
        ClusterQueue[ClusterQueue CRD]
        LocalQueue[LocalQueue CRD]
        Workload[Workload CRD]
        AdmissionCheck[AdmissionCheck CRD]
        ResourceFlavor[ResourceFlavor CRD]
        WorkloadPriorityClass[WorkloadPriorityClass CRD]
        ProvisioningRequestConfig[ProvisioningRequestConfig CRD]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Certificate Provider]
        Prometheus[Prometheus<br/>Metrics Scraper]
    end

    subgraph "Job Frameworks"
        BatchJob[Kubernetes batch/v1 Jobs]
        JobSet[JobSet Resources]
        KubeflowJobs[Kubeflow Training Jobs<br/>TFJob, PyTorchJob, MPIJob]
        RayWorkloads[Ray Workloads<br/>RayJob, RayCluster]
        Pods[Plain Pods]
    end

    subgraph "Integration Points"
        KubeflowOperator[Kubeflow Training Operator]
        RayOperator[Ray Operator]
        ClusterAutoscaler[cluster-autoscaler]
    end

    User[User/CI] -->|creates| BatchJob
    User -->|creates| KubeflowJobs
    User -->|creates| RayWorkloads

    BatchJob -->|watched by| Webhook
    KubeflowJobs -->|watched by| Webhook
    RayWorkloads -->|watched by| Webhook
    Pods -->|watched by| Webhook

    Webhook -->|validates/mutates| BatchJob
    Webhook -->|validates/mutates| KubeflowJobs
    Webhook -->|validates/mutates| Pods

    CQController -->|manages| ClusterQueue
    LQController -->|manages| LocalQueue
    WLController -->|manages| Workload
    ACController -->|manages| AdmissionCheck
    RFController -->|manages| ResourceFlavor

    JobController -->|creates| Workload
    PyTorchController -->|creates| Workload
    TFController -->|creates| Workload
    MPIController -->|creates| Workload
    RayJobController -->|creates| Workload
    RayClusterController -->|creates| Workload

    Controller -->|watches/reconciles| K8sAPI
    CertManager -->|provides certs| Webhook
    Prometheus -->|scrapes| Metrics

    Controller -->|integrates with| KubeflowOperator
    Controller -->|integrates with| RayOperator
    Controller -->|creates ProvisioningRequests| ClusterAutoscaler

