graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: system]
        SA_LeaderElection[controller-manager<br/>Namespace: system<br/>For: Leader Election]
        SA_Proxy["{cr-name}-proxy<br/>Namespace: {instance-namespace}<br/>Per TrustyAI Instance"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Cluster Scope]
    end

    subgraph "Role Bindings"
        RB_LeaderElection[leader-election-rolebinding<br/>Namespace: system]
        RB_Proxy["{cr-name}-proxy<br/>Namespace: {instance-namespace}<br/>SAR Delegation"]
    end

    subgraph "ClusterRole Permissions: manager-role"
        direction TB
        Perm1[trustyai.opendatahub.io<br/>trustyaiservices, status, finalizers<br/>get, list, watch, create, update, patch, delete]
        Perm2[apps<br/>deployments, deployments/status, finalizers<br/>get, list, watch, create, update, patch, delete]
        Perm3[core<br/>services, configmaps, pods, secrets,<br/>serviceaccounts, persistentvolumeclaims<br/>get, list, watch, create, update, patch, delete]
        Perm4[core<br/>persistentvolumes, events<br/>get, list, watch]
        Perm5[monitoring.coreos.com<br/>servicemonitors<br/>list, watch, create]
        Perm6[route.openshift.io<br/>routes<br/>get, list, watch, create, update, patch, delete]
        Perm7[serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>finalizers, status<br/>get, list, watch, create, update, patch, delete]
        Perm8[rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get, list, watch, create, update, delete]
        Perm9[coordination.k8s.io<br/>leases<br/>get, create, update]
    end

    subgraph "Role Permissions: leader-election-role"
        direction TB
        LEPerm1[core<br/>configmaps<br/>get, list, watch, create, update, patch, delete]
        LEPerm2[coordination.k8s.io<br/>leases<br/>get, list, watch, create, update, patch, delete]
        LEPerm3[core<br/>events<br/>create, patch]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAIResources[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    subgraph "API Resources - Kubernetes"
        K8sResources[Deployments, Services,<br/>ConfigMaps, Pods, Secrets,<br/>ServiceAccounts, PVCs, PVs, Events]
    end

    subgraph "API Resources - Monitoring"
        MonitoringResources[ServiceMonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - OpenShift"
        OpenShiftResources[Routes<br/>route.openshift.io]
    end

    subgraph "API Resources - KServe"
        KServeResources[InferenceServices<br/>ServingRuntimes<br/>serving.kserve.io]
    end

    subgraph "API Resources - RBAC"
        RBACResources[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - Coordination"
        CoordResources[Leases<br/>coordination.k8s.io<br/>For: Leader Election]
    end

    %% Service Account to Role Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_LeaderElection -->|bound via| RB_LeaderElection
    SA_Proxy -->|bound via| RB_Proxy

    %% Role Bindings to Roles
    CRB_Manager -->|grants ClusterRole| Perm1
    CRB_Manager -->|grants ClusterRole| Perm2
    CRB_Manager -->|grants ClusterRole| Perm3
    CRB_Manager -->|grants ClusterRole| Perm4
    CRB_Manager -->|grants ClusterRole| Perm5
    CRB_Manager -->|grants ClusterRole| Perm6
    CRB_Manager -->|grants ClusterRole| Perm7
    CRB_Manager -->|grants ClusterRole| Perm8
    CRB_Manager -->|grants ClusterRole| Perm9

    RB_LeaderElection -->|grants Role| LEPerm1
    RB_LeaderElection -->|grants Role| LEPerm2
    RB_LeaderElection -->|grants Role| LEPerm3

    %% Permissions to Resources
    Perm1 -->|manages| TrustyAIResources
    Perm2 -->|manages| K8sResources
    Perm3 -->|manages| K8sResources
    Perm4 -->|reads| K8sResources
    Perm5 -->|manages| MonitoringResources
    Perm6 -->|manages| OpenShiftResources
    Perm7 -->|manages| KServeResources
    Perm8 -->|manages| RBACResources
    Perm9 -->|manages| CoordResources

    LEPerm1 -->|manages| CoordResources
    LEPerm2 -->|manages| CoordResources
    LEPerm3 -->|creates| K8sResources

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_LeaderElection fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Proxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style Perm1 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm2 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm3 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm4 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm5 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm6 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm7 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm8 fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm9 fill:#7ed321,stroke:#333,stroke-width:1px
    style LEPerm1 fill:#7ed321,stroke:#333,stroke-width:1px
    style LEPerm2 fill:#7ed321,stroke:#333,stroke-width:1px
    style LEPerm3 fill:#7ed321,stroke:#333,stroke-width:1px
    style TrustyAIResources fill:#dae8fc,stroke:#6c8ebf
    style K8sResources fill:#dae8fc,stroke:#6c8ebf
    style MonitoringResources fill:#dae8fc,stroke:#6c8ebf
    style OpenShiftResources fill:#dae8fc,stroke:#6c8ebf
    style KServeResources fill:#dae8fc,stroke:#6c8ebf
    style RBACResources fill:#dae8fc,stroke:#6c8ebf
    style CoordResources fill:#dae8fc,stroke:#6c8ebf
