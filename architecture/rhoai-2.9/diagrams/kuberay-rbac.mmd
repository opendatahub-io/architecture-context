    style Pods fill:#7ed321,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style RayCRDs fill:#7ed321,stroke:#333,stroke-width:2px
    style Networking fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
