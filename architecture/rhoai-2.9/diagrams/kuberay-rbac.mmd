graph TD
    subgraph "Service Account"
        SA[kuberay-operator<br/>Namespace: opendatahub<br/>UID: 65532]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Pods["Core API (v1)<br/>━━━━━━━━━━━━━━━━━<br/>pods, pods/status<br/>services, services/status<br/>serviceaccounts<br/>events<br/>endpoints"]
    end

    subgraph "Batch API Resources"
        Jobs["Batch API (batch)<br/>━━━━━━━━━━━━━━━━━<br/>jobs"]
    end

    subgraph "Ray CRDs"
        RayCRDs["Ray API (ray.io)<br/>━━━━━━━━━━━━━━━━━<br/>rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers<br/>━━━━━━━━━━━━━━━━━<br/>rayjobs<br/>rayjobs/status<br/>rayjobs/finalizers<br/>━━━━━━━━━━━━━━━━━<br/>rayservices<br/>rayservices/status<br/>rayservices/finalizers"]
    end

    subgraph "Networking Resources"
        Networking["Networking API<br/>(networking.k8s.io, extensions)<br/>━━━━━━━━━━━━━━━━━<br/>ingresses<br/>ingressclasses"]
    end

    subgraph "OpenShift Resources"
        Routes["OpenShift API<br/>(route.openshift.io)<br/>━━━━━━━━━━━━━━━━━<br/>routes"]
    end

    subgraph "RBAC Resources"
        RBACResources["RBAC API<br/>(rbac.authorization.k8s.io)<br/>━━━━━━━━━━━━━━━━━<br/>roles<br/>rolebindings"]
    end

    subgraph "Coordination Resources"
        Leases["Coordination API<br/>(coordination.k8s.io)<br/>━━━━━━━━━━━━━━━━━<br/>leases<br/>(for leader election)"]
    end

    subgraph "OpenShift SCC"
        SCC["run-as-ray-user<br/>Custom SCC<br/>━━━━━━━━━━━━━━━━━<br/>runAsUser: MustRunAs (1000)<br/>seLinuxContext: MustRunAs<br/>Applied to: Ray Pods"]
    end

    subgraph "Secrets"
        WebhookSecret["webhook-server-cert<br/>Type: kubernetes.io/tls<br/>━━━━━━━━━━━━━━━━━<br/>Managed by: cert-manager<br/>Auto-Rotate: Yes"]
        RedisSecret["{raycluster}-redis-secret<br/>Type: Opaque<br/>━━━━━━━━━━━━━━━━━<br/>Purpose: GCS Redis Password<br/>Managed by: User"]
    end

    %% Relationships
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - Full CRUD
    CR -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| Pods
    CR -->|create, delete,<br/>get, list, patch, update, watch| Jobs
    CR -->|create, delete,<br/>get, list, patch, update, watch| RayCRDs
    CR -->|create, delete,<br/>get, list, patch, update, watch| Networking
    CR -->|create, delete,<br/>get, list, patch, update, watch| Routes
    CR -->|create, delete,<br/>get, list, update, watch| RBACResources

    %% Permissions - Limited
    CR -->|create, get, list, update| Leases

    %% Security Context
    SA -.->|runs with SCC| SCC
    SA -.->|accesses| WebhookSecret
    SA -.->|creates/manages| RedisSecret

    %% Verbs Legend
    VerbsLegend["PERMISSIONS LEGEND<br/>━━━━━━━━━━━━━━━━━<br/>Full Control:<br/>create, delete, get, list,<br/>patch, update, watch<br/>━━━━━━━━━━━━━━━━━<br/>deletecollection: pods only<br/>finalizers: Ray CRDs only<br/>━━━━━━━━━━━━━━━━━<br/>Leader Election:<br/>leases (create, get, list, update)"]

