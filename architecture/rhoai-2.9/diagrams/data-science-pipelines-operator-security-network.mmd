graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist /<br/>ODH Dashboard]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>service-serving-cert<br/>Bearer Token Validation"]
    end

    subgraph AppTier["APPLICATION TIER (Service Mesh - Internal)"]
        direction TB

        subgraph NS_DSPA["Namespace: {user-namespace}"]
            direction TB

            APIServer["API Server<br/>SA: ds-pipeline-{name}<br/>8888/TCP HTTP (REST)<br/>8887/TCP gRPC"]

            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-{name}"]

            ScheduledWF["Scheduled Workflow Controller<br/>SA: ds-pipeline-{name}"]

            WorkflowController["Workflow Controller<br/>SA: ds-pipeline-workflow-controller-{name}<br/>Argo v2 only"]

            MariaDB["MariaDB (built-in)<br/>3306/TCP<br/>Auth: DB credentials"]

            Minio["Minio (built-in)<br/>9000/TCP HTTP<br/>Auth: Access Key"]

            MLMD["ML Metadata gRPC<br/>8080/TCP gRPC"]

            MLMDEnvoy["ML Metadata Envoy<br/>9090/TCP gRPC mTLS<br/>8443/TCP HTTPS OAuth2<br/>service-serving-cert"]

            PipelinePod["Pipeline Pod<br/>SA: pipeline-runner-{name}"]
        end
    end

    subgraph OperatorTier["OPERATOR TIER (Cluster-scoped)"]
        direction TB

        subgraph NS_Operator["Namespace: datasciencepipelinesapplications-controller"]
            Controller["DSPO Controller Manager<br/>SA: controller-manager<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (health)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3Ext["External S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access Keys"]

        DBExt["External Database<br/>3306/5432 TCP<br/>TLS optional<br/>Username/Password"]

        Registry["Container Registry<br/>quay.io/registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secrets"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>Service Account Token"]

        Prometheus["Prometheus<br/>Metrics scrape<br/>8080/TCP HTTP"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Route
    Route -->|HTTPS/8443<br/>TLS 1.2+<br/>service-serving-cert| OAuthProxy

    %% Ingress to Application
    OAuthProxy -->|HTTP/8888<br/>Token validated| APIServer

    %% Application Internal Flows
    APIServer -->|TCP/3306<br/>DB credentials| MariaDB
    APIServer -->|gRPC/8080| MLMD
    MLMD -->|TCP/3306<br/>DB credentials| MariaDB
    MLMDEnvoy -->|gRPC/8080<br/>Internal| MLMD

    PersistenceAgent -->|HTTP/8888<br/>SA Token| APIServer
    PersistenceAgent -->|TCP/3306<br/>DB credentials| MariaDB

    ScheduledWF -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    ScheduledWF -->|HTTP/8888<br/>SA Token| APIServer

    WorkflowController -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    APIServer -->|HTTP/8080<br/>Service Account| WorkflowController

    PipelinePod -->|gRPC/8887<br/>SA Token| APIServer
    PipelinePod -->|HTTP/9000<br/>Access Key| Minio
    PipelinePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3Ext

    %% Operator Tier
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% External Services
    APIServer -.->|TCP/3306<br/>TLS optional<br/>Username/Password| DBExt
    PipelinePod -.->|HTTPS/443<br/>TLS 1.2+<br/>Access Keys| S3Ext
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>ServiceMonitor| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef apptier fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route,OAuthProxy ingress
    class APIServer,PersistenceAgent,ScheduledWF,WorkflowController,MariaDB,Minio,MLMD,MLMDEnvoy,PipelinePod apptier
    class Controller operator
    class S3Ext,DBExt,Registry externalservice
    class K8sAPI,Prometheus platform
