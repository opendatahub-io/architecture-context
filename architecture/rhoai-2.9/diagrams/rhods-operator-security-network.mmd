graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Platform Administrator]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforcement"]
    end

    subgraph OperatorNamespace["NAMESPACE: redhat-ods-operator"]
        direction TB

        subgraph OperatorPod["RHODS Operator Pod"]
            direction TB
            Controller["Controller Manager<br/>SA: controller-manager<br/>UID: 1001 (non-root)<br/>Capabilities: None<br/>SELinux: Enforced"]
            MetricsEndpoint["/metrics<br/>8080/TCP HTTP"]
            HealthEndpoint["/healthz<br/>8081/TCP HTTP"]
            ReadyEndpoint["/readyz<br/>8081/TCP HTTP"]

            Controller --- MetricsEndpoint
            Controller --- HealthEndpoint
            Controller --- ReadyEndpoint
        end

        MetricsService["controller-manager-metrics-service<br/>ClusterIP<br/>8443/TCP → 8080/TCP"]
    end

    subgraph Monitoring["MONITORING (openshift-monitoring)"]
        Prometheus["Prometheus<br/>SA: prometheus-k8s"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        GitRepos["Component Git Repositories<br/>github.com/opendatahub-io<br/>443/TCP HTTPS TLS1.2+"]
        Registries["Container Registries<br/>registry.redhat.io, quay.io<br/>443/TCP HTTPS TLS1.2+"]
    end

    subgraph ManagedNamespaces["MANAGED NAMESPACES"]
        direction LR
        AppsNS["redhat-ods-applications<br/>(Components)"]
        MonNS["redhat-ods-monitoring<br/>(Monitoring Stack)"]
        UserNS["User Namespaces<br/>(Workbenches, Inference)"]
    end

    %% Flows
    Admin -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token or X.509| K8sAPI

    K8sAPI -->|Watch Events<br/>In-process| Controller
    Controller -->|CRUD Operations<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount Token| K8sAPI

    K8sAPI -->|Manage Resources<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount Token| AppsNS
    K8sAPI -->|Manage Resources<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount Token| MonNS
    K8sAPI -->|Manage Resources<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount Token| UserNS

    Prometheus -->|Scrape Metrics<br/>HTTP/8443<br/>ServiceAccount Token| MetricsService
    MetricsService -->|Forward<br/>HTTP/8080| MetricsEndpoint

    Controller -.->|Build-time only<br/>HTTPS/443 TLS1.2+<br/>No Auth - public repos| GitRepos
    Controller -.->|Image Pull<br/>HTTPS/443 TLS1.2+<br/>Pull Secrets| Registries

    %% Health checks (internal to pod)
    K8sAPI -.->|Kubelet Probes<br/>HTTP/8081<br/>No Auth| HealthEndpoint
    K8sAPI -.->|Kubelet Probes<br/>HTTP/8081<br/>No Auth| ReadyEndpoint

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef managed fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Admin external
    class K8sAPI controlplane
    class Controller,MetricsEndpoint,HealthEndpoint,ReadyEndpoint,MetricsService operator
    class Prometheus monitoring
    class GitRepos,Registries externalservice
    class AppsNS,MonNS,UserNS managed
