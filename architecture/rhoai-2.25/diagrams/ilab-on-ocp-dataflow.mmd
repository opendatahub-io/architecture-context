sequenceDiagram
    participant User as Data Scientist
    participant DSP as Data Science Pipelines<br/>(Argo/KFP)
    participant PreReq as Prerequisites Check Pod
    participant K8sAPI as Kubernetes API<br/>443/TCP HTTPS
    participant GitRepo as Git Repository<br/>443/TCP HTTPS
    participant SDGPod as SDG Pod
    participant Teacher as Teacher Model (Mixtral)<br/>443/TCP HTTPS TLS 1.2+
    participant PVC as ReadWriteMany PVC
    participant DataProc as Data Processing Pod
    participant TrainPod as Training Pod<br/>(PyTorchJob Launcher)
    participant Workers as PyTorchJob Workers<br/>MASTER_PORT/TCP NCCL
    participant Judge as Judge Model (Prometheus)<br/>443/TCP HTTPS TLS 1.2+
    participant MTBPod as MT-Bench Eval Pod
    participant FinalPod as Final Eval Pod
    participant vLLM as Local vLLM (in-pod)<br/>dynamic/TCP HTTP
    participant UploadPod as Upload Model Pod
    participant OCI as OCI Registry<br/>443/TCP HTTPS
    participant MR as Model Registry<br/>443/TCP HTTPS

    User->>DSP: Submit InstructLab Pipeline Run
    DSP->>PreReq: Stage 1: Prerequisites Check

    rect rgb(240, 248, 255)
        Note over PreReq,MR: Prerequisites Validation
        PreReq->>K8sAPI: GET secrets<br/>Auth: SA Bearer Token
        K8sAPI-->>PreReq: Secret values
        PreReq->>Teacher: POST /v1/chat/completions<br/>Auth: Bearer Token
        Teacher-->>PreReq: Health OK
        PreReq->>Judge: POST /v1/chat/completions<br/>Auth: Bearer Token
        Judge-->>PreReq: Health OK
        PreReq->>MR: GET models<br/>Auth: SA Bearer Token
        MR-->>PreReq: Registry OK
    end

    DSP->>SDGPod: Stage 2: Synthetic Data Generation

    rect rgb(255, 248, 240)
        Note over SDGPod,PVC: SDG Stage
        SDGPod->>GitRepo: Clone taxonomy<br/>Auth: basic-auth/ssh-auth
        GitRepo-->>SDGPod: Taxonomy files
        SDGPod->>Teacher: POST /v1/chat/completions<br/>Auth: Bearer Token
        Teacher-->>SDGPod: Generated synthetic data
        SDGPod->>PVC: Write SDG data
    end

    DSP->>DataProc: Stage 3a: Data Processing

    rect rgb(240, 255, 240)
        Note over DataProc,Workers: Training Stage
        DataProc->>PVC: Read SDG data
        DataProc->>PVC: Write processed training data
        DSP->>TrainPod: Stage 3b: Launch Training
        TrainPod->>K8sAPI: CREATE PyTorchJob (Phase 1: Knowledge)<br/>Auth: SA Bearer Token
        K8sAPI-->>TrainPod: PyTorchJob created
        Workers->>PVC: Read training data
        Workers->>Workers: NCCL/Gloo distributed training<br/>plaintext (Istio sidecar disabled)
        Workers->>PVC: Write model checkpoints
        TrainPod->>K8sAPI: CREATE PyTorchJob (Phase 2: Skills)<br/>Auth: SA Bearer Token
        Workers->>PVC: Read Phase 1 checkpoint
        Workers->>Workers: NCCL/Gloo distributed training
        Workers->>PVC: Write final model
    end

    DSP->>MTBPod: Stage 4: MT-Bench Evaluation

    rect rgb(255, 240, 255)
        Note over MTBPod,Judge: Evaluation Stage
        MTBPod->>PVC: Read trained model
        MTBPod->>Judge: POST /v1/chat/completions<br/>Auth: Bearer Token
        Judge-->>MTBPod: MT-Bench scores
    end

    DSP->>FinalPod: Stage 5: Final Evaluation

    rect rgb(255, 255, 240)
        Note over FinalPod,Judge: Final Evaluation
        FinalPod->>PVC: Read trained model
        FinalPod->>vLLM: Launch candidate model server
        vLLM-->>FinalPod: Model loaded
        FinalPod->>Judge: POST /v1/chat/completions<br/>Auth: Bearer Token
        Judge-->>FinalPod: MMLU + MT-Bench Branch scores
    end

    DSP->>UploadPod: Stage 6: Model Upload & Registration

    rect rgb(240, 255, 255)
        Note over UploadPod,MR: Output Stage
        UploadPod->>PVC: Read final model
        UploadPod->>OCI: Push OCI ModelCar<br/>Auth: Docker auth
        OCI-->>UploadPod: Push complete
        UploadPod->>MR: POST register model<br/>Auth: SA Bearer Token
        MR-->>UploadPod: Registration confirmed
    end

    DSP-->>User: Pipeline Complete
