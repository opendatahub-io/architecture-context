graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ds-pipeline"]
        SA_PA["ds-pipeline-persistenceagent"]
        SA_SWF["ds-pipeline-scheduledworkflow"]
        SA_Runner["pipeline-runner<br/>⚠ PRIVILEGED"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_PA["ds-pipeline-persistenceagent<br/>-clusterrolebinding"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_API["ds-pipeline"]
        RB_SWF["ds-pipeline-scheduledworkflow<br/>-binding"]
        RB_Runner["pipeline-runner-binding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_PA["ds-pipeline-persistenceagent<br/>-clusterrole"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        R_API["ds-pipeline"]
        R_SWF["ds-pipeline-scheduledworkflow<br/>-role"]
        R_Runner["pipeline-runner"]
    end

    subgraph APIResources_PA["Persistence Agent Resources"]
        PA_Workflows["argoproj.io<br/>workflows<br/>get, list, watch"]
        PA_SWF["kubeflow.org<br/>scheduledworkflows<br/>get, list, watch"]
        PA_Tekton["tekton.dev<br/>pipelineruns, taskruns,<br/>conditions<br/>create, get, list, watch,<br/>update, patch, delete"]
    end

    subgraph APIResources_API["API Server Resources"]
        API_Pods["core<br/>pods, pods/log<br/>get, list, delete"]
        API_Workflows["argoproj.io<br/>workflows<br/>full CRUD"]
        API_Tekton["tekton.dev<br/>pipelineruns, taskruns,<br/>conditions, runs, tasks<br/>full CRUD"]
        API_KF["kubeflow.org<br/>scheduledworkflows<br/>full CRUD"]
        API_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        API_TR["authentication.k8s.io<br/>tokenreviews<br/>create"]
        API_Loop["custom.tekton.dev<br/>pipelineloops<br/>full CRUD"]
    end

    subgraph APIResources_SWF["Scheduled Workflow Resources"]
        SWF_Workflows["argoproj.io<br/>workflows<br/>full CRUD"]
        SWF_KF["kubeflow.org<br/>scheduledworkflows<br/>full CRUD"]
        SWF_Events["core<br/>events<br/>create, patch"]
        SWF_Tekton["tekton.dev<br/>pipelineruns, taskruns,<br/>conditions, runs, tasks<br/>full CRUD"]
        SWF_Loop["custom.tekton.dev<br/>pipelineloops<br/>full CRUD"]
    end

    subgraph APIResources_Runner["Pipeline Runner Resources ⚠"]
        Run_Secrets["core<br/>secrets<br/>get"]
        Run_CM["core<br/>configmaps<br/>get, watch, list"]
        Run_PV["core<br/>PVs, PVCs<br/>* (wildcard)"]
        Run_Pods["core<br/>pods, pods/exec,<br/>pods/log, services<br/>* (wildcard)"]
        Run_Apps["apps, extensions<br/>deployments, replicasets<br/>* (wildcard)"]
        Run_KF["kubeflow.org<br/>* (all resources)<br/>* (wildcard)"]
        Run_Batch["batch<br/>jobs<br/>* (wildcard)"]
        Run_Seldon["machinelearning.seldon.io<br/>seldondeployments<br/>* (wildcard)"]
        Run_Tekton["tekton.dev<br/>pipelineruns, taskruns,<br/>conditions, runs, tasks<br/>full CRUD"]
        Run_Snap["snapshot.storage.k8s.io<br/>volumesnapshots<br/>create, delete, get"]
    end

    %% Persistence Agent chain
    SA_PA -->|"bound via"| CRB_PA
    CRB_PA -->|"grants"| CR_PA
    CR_PA --> PA_Workflows
    CR_PA --> PA_SWF
    CR_PA --> PA_Tekton

    %% API Server chain
    SA_API -->|"bound via"| RB_API
    RB_API -->|"grants"| R_API
    R_API --> API_Pods
    R_API --> API_Workflows
    R_API --> API_Tekton
    R_API --> API_KF
    R_API --> API_SAR
    R_API --> API_TR
    R_API --> API_Loop

    %% Scheduled Workflow chain
    SA_SWF -->|"bound via"| RB_SWF
    RB_SWF -->|"grants"| R_SWF
    R_SWF --> SWF_Workflows
    R_SWF --> SWF_KF
    R_SWF --> SWF_Events
    R_SWF --> SWF_Tekton
    R_SWF --> SWF_Loop

    %% Pipeline Runner chain
    SA_Runner -->|"bound via"| RB_Runner
    RB_Runner -->|"grants"| R_Runner
    R_Runner --> Run_Secrets
    R_Runner --> Run_CM
    R_Runner --> Run_PV
    R_Runner --> Run_Pods
    R_Runner --> Run_Apps
    R_Runner --> Run_KF
    R_Runner --> Run_Batch
    R_Runner --> Run_Seldon
    R_Runner --> Run_Tekton
    R_Runner --> Run_Snap

