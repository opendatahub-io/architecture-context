graph TB
    subgraph External["EXTERNAL CONSUMERS (Internal Platform)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Calls detectors for<br/>text content analysis"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio Sidecar Injection)"]
        direction TB

        subgraph BuiltInZone["Built-In Detector (Standalone Pod)"]
            BuiltIn["Built-In Detector<br/>8080/TCP HTTP<br/>Image: rhoai/odh-built-in-detector-rhel9<br/>Auth: None (app-level)"]
        end

        subgraph HFZone["HuggingFace Detector (KServe InferenceService)"]
            HF["HuggingFace Detector<br/>8000/TCP HTTP<br/>Image: rhoai/odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>Auth: detector_id header (unverified)"]
            StorageInit["KServe Storage Initializer<br/>(init container)<br/>Downloads to /mnt/models"]
        end

        subgraph JudgeZone["LLM Judge Detector (KServe InferenceService)"]
            Judge["LLM Judge Detector<br/>8000/TCP HTTP<br/>Image: quay.io/trustyai/<br/>guardrails-detector-llm-judge<br/>Auth: detector_id header (unverified)"]
        end

        subgraph InternalService["Internal Service"]
            vLLM["vLLM Server<br/>8080/TCP HTTP<br/>OpenAI-compatible API"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO Model Storage<br/>9000/TCP HTTP<br/>Auth: AWS IAM credentials<br/>(Secret: aws-connection-minio-<br/>data-connection-guardrails-guardian)"]
        Prom["Prometheus<br/>Scrapes /metrics<br/>8080/TCP HTTP"]
    end

    %% Flows from Orchestrator
    Orchestrator -->|"HTTP/8080<br/>Plaintext (intra-mesh)<br/>Auth: None"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS (ISTIO_MUTUAL)<br/>Auth: detector_id header"| HF
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS (ISTIO_MUTUAL)<br/>Auth: detector_id header"| Judge

    %% Judge to vLLM
    Judge -->|"HTTP/8080<br/>Plaintext (intra-mesh)<br/>Auth: None"| vLLM

    %% Storage Init to S3
    StorageInit -->|"HTTP/9000<br/>No encryption<br/>Auth: AWS IAM creds"| S3

    %% Prometheus scraping
    Prom -.->|"HTTP/8080<br/>Scrape /metrics"| BuiltIn
    Prom -.->|"HTTP/8080<br/>Scrape /metrics"| HF
    Prom -.->|"HTTP/8080<br/>Scrape /metrics"| Judge

    %% Styling
    classDef external fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kserve fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Orchestrator external
    class BuiltIn servicemesh
    class HF,StorageInit kserve
    class Judge kserve
    class vLLM internalservice
    class S3,Prom externalservice
