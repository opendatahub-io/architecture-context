graph TB
    subgraph "ML Metadata (MLMD) Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Server)<br/>Port: 8080/TCP"]
        ServiceImpl["MetadataStoreServiceImpl<br/>Per-RPC DB connection pattern"]
        Server -->|"implements"| ServiceImpl
    end

    subgraph "Client Libraries"
        PythonClient["ml_metadata<br/>(Python Client Library)<br/>gRPC + Direct DB modes"]
        PybindExt["pywrap/metadata_store_extension<br/>(C++ pybind11 Module)<br/>Direct DB access"]
        GoBindings["Go SWIG Bindings<br/>(metadata_store.go)"]
        PythonClient -->|"uses for direct mode"| PybindExt
    end

    subgraph "Database Backends"
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(embedded / in-memory)"]
    end

    DSPController["DSP Pipeline Controller<br/>(gRPC Client)"] -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    DSPUI["DSP UI / Pipeline SDK<br/>(gRPC Client)"] -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    PythonClient -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    GoBindings -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    ServiceImpl -->|"MySQL protocol<br/>3306/TCP"| MySQL
    ServiceImpl -->|"PostgreSQL protocol<br/>5432/TCP"| PostgreSQL
    ServiceImpl -->|"embedded"| SQLite

    PybindExt -.->|"direct connection<br/>(no network hop)"| MySQL
    PybindExt -.->|"direct connection<br/>(no network hop)"| PostgreSQL
    PybindExt -.->|"direct connection"| SQLite

    DSPOperator["data-science-pipelines-operator"] -.->|"deploys & configures"| Server

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style ServiceImpl fill:#4a90e2,stroke:#333,color:#fff
    style PythonClient fill:#7ed321,stroke:#333,color:#fff
    style PybindExt fill:#7ed321,stroke:#333,color:#fff
    style GoBindings fill:#7ed321,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333,color:#fff
