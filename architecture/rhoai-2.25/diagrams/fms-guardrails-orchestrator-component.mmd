graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph "API Layer (axum)"
            HealthServer["Health Server<br/>:8034/TCP HTTP"]
            GuardrailsServer["Guardrails Server<br/>:8033/TCP HTTP/HTTPS"]
        end

        subgraph "Route Handlers"
            V1Routes["V1 API Routes<br/>/api/v1/task/*"]
            V2Routes["V2 API Routes<br/>/api/v2/text/*"]
            ChatRoutes["OpenAI-Compatible Routes<br/>/api/v2/chat/completions-detection"]
        end

        subgraph "Orchestrator Core"
            Orchestrator["Orchestrator<br/>Handle&lt;Task&gt; dispatch"]
            DetectionBatcher["Detection Batcher<br/>CompletionBatcher /<br/>MaxProcessedIndexBatcher"]
        end

        subgraph "Client Layer"
            ClientMap["ClientMap<br/>(heterogeneous store)"]
            GenClient["GenerationClient<br/>(unified TGIS/NLP)"]
            DetectorClient["DetectorClient<br/>(HTTP)"]
            ChunkerClient["ChunkerClient<br/>(gRPC)"]
            OpenAiClient["OpenAiClient<br/>(HTTP)"]
        end

        GuardrailsServer --> V1Routes
        GuardrailsServer --> V2Routes
        GuardrailsServer --> ChatRoutes
        V1Routes --> Orchestrator
        V2Routes --> Orchestrator
        ChatRoutes --> Orchestrator
        Orchestrator --> DetectionBatcher
        Orchestrator --> ClientMap
        ClientMap --> GenClient
        ClientMap --> DetectorClient
        ClientMap --> ChunkerClient
        ClientMap --> OpenAiClient
    end

    Client[Client / Inference Pipeline] -->|"HTTP/HTTPS :8033<br/>Header passthrough"| GuardrailsServer
    Probes[K8s Probes] -->|"HTTP :8034"| HealthServer

    GenClient -->|"gRPC :8033<br/>Optional TLS"| TGIS["TGIS Server"]
    GenClient -->|"gRPC :8085<br/>Optional TLS"| CaikitNLP["Caikit NLP"]
    OpenAiClient -->|"HTTP :8080<br/>Optional TLS"| vLLM["OpenAI-compatible<br/>(vLLM)"]
    ChunkerClient -->|"gRPC :8085<br/>Optional TLS"| Chunkers["Chunker Services<br/>(Caikit)"]
    DetectorClient -->|"HTTP :8080<br/>Optional TLS"| Detectors["Detector Services"]
    Orchestrator -.->|"gRPC/HTTP :4317/:4318"| OTel["OpenTelemetry<br/>Collector"]

