graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>RequestAuthentication"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Knative Serving"]
            QueueProxy["Queue-Proxy / Activator<br/>Request buffering & scaling"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph InferenceServicePod["InferenceService Pod<br/>SA: {infer-service-sa}<br/>Istio sidecar injected"]
                direction LR
                CaikitRuntime["Caikit Runtime<br/>(transformer-container)<br/>:8080 HTTP | :8085 gRPC<br/>:8086 Metrics<br/>Python 3.12 / UBI 9"]
                TGISBackend["TGIS Backend<br/>(kserve-container)<br/>:8033 gRPC (localhost only)<br/>GPU-accelerated inference"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>User Workload Monitoring"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>Model artifacts<br/>TLS 1.2+<br/>AWS IAM / AccessKey"]
        HuggingFace["HuggingFace Hub<br/>(dev/conversion only)<br/>TLS 1.2+<br/>Token (optional)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| IstioGW

    %% Ingress → Service Mesh
    IstioGW -->|"HTTP/8012<br/>mTLS STRICT<br/>Istio Service Identity"| QueueProxy

    %% Queue-Proxy → Caikit (HTTP)
    QueueProxy -->|"HTTP/8080 or gRPC/8085<br/>No encryption (pod-local)<br/>No auth"| CaikitRuntime

    %% Caikit → TGIS (localhost)
    CaikitRuntime -->|"gRPC/8033<br/>localhost (no encryption)<br/>No auth"| TGISBackend

    %% Prometheus → Caikit Metrics
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>NetworkPolicy gated"| CaikitRuntime

    %% Egress to External Services
    InferenceServicePod -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    InferenceServicePod -.->|"HTTPS/443<br/>TLS 1.2+<br/>Token"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class IstioGW ingress
    class QueueProxy servicemesh
    class CaikitRuntime,TGISBackend pod
    class Prometheus monitoring
    class S3,HuggingFace externalservice
