graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(HTTP or gRPC)"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IstioGW["Istio Ingress Gateway<br/>(knative-ingress-gateway)<br/>443/TCP -> 8080|8085/TCP<br/>TLS SIMPLE (wildcard-certs)"]
        KnativeLocalGW["Knative Local Gateway<br/>8081/TCP HTTP<br/>Cluster-local only"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
