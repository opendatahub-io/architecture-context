                TGIS["TGIS Sidecar<br/>Port: 8033/TCP gRPC<br/>LLM Inference Engine"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>Metrics Scraper"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS SIMPLE<br/>Bearer Token (optional)"| IstioGW

    %% Ingress to Service Mesh
    IstioGW -->|"HTTP/8080 or gRPC/8085<br/>Istio mTLS STRICT<br/>PeerAuthentication"| QueueProxy

    %% Queue-Proxy to Caikit
    QueueProxy -->|"HTTP/8080 or gRPC/8085<br/>plaintext (pod-local)"| Caikit

    %% Caikit to TGIS (intra-pod)
    Caikit -->|"gRPC/8033<br/>plaintext (localhost)<br/>No auth"| TGIS

    %% Prometheus metrics
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>No auth"| Caikit

    %% Model storage (via KServe init)
    S3 -.->|"Model artifacts<br/>HTTPS/443 TLS 1.2+<br/>Downloaded at init"| TGIS

    %% Cluster-local access
    KnativeLocalGW -.->|"HTTP/8081<br/>plaintext<br/>Cluster-local"| QueueProxy

