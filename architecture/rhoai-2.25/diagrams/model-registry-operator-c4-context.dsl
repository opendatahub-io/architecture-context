// Model Registry Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/model-registry-operator.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Model Registry instances for ML model metadata"
        admin = person "Platform Admin" "Deploys and configures the Model Registry Operator via rhods-operator"

        modelRegistryOperator = softwareSystem "Model Registry Operator" "Kubernetes operator managing ModelRegistry CRs, provisioning REST/gRPC model registry stacks with OAuth, RBAC, and network isolation" {
            reconciler = container "ModelRegistryReconciler" "Watches ModelRegistry CRs; creates Deployment, Service, Route, NetworkPolicy, RBAC per instance" "Go Controller (controller-runtime v0.16.3)"
            catalogReconciler = container "ModelCatalogReconciler" "Manages singleton model-catalog instance with init container, oauth-proxy, and catalog sources" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating + validating webhooks for ModelRegistry CRs; handles v1alpha1/v1beta1 conversion" "Go Admission Webhook, 9443/TCP HTTPS"
            migrationManager = container "StorageMigrationManager" "Monitors CRD storage versions; performs v1alpha1 to v1beta1 migration" "Background Process"
            templateEngine = container "Template Engine" "Renders Go templates into Kubernetes resource manifests" "Internal Utility"
        }

        registryInstance = softwareSystem "Model Registry Instance" "Per-instance REST API with OAuth proxy for ML model metadata CRUD" {
            oauthProxy = container "OAuth Proxy Sidecar" "Authenticates users via OpenShift OAuth + SubjectAccessReview" "ose-oauth-proxy, 8443/TCP HTTPS"
            restContainer = container "Model Registry REST" "REST API for ML model metadata; embeds MLMD gRPC server" "odh-model-registry, 8080/TCP HTTP"
        }

        catalogInstance = softwareSystem "Model Catalog" "Centralized catalog of model metadata from configurable sources" {
            catalogInit = container "Catalog Data Init" "Loads default catalog data to shared volume" "odh-model-metadata-collection (init container)"
            catalogOAuth = container "Catalog OAuth Proxy" "Authenticates users for catalog access" "ose-oauth-proxy, 8443/TCP HTTPS"
            catalogContainer = container "Catalog REST API" "Serves catalog data from volume and ConfigMap sources" "model-catalog, 8080/TCP HTTP"
        }

        // External systems
        rhodsOperator = softwareSystem "rhods-operator" "Deploys model-registry-operator via kustomize overlays" "Internal RHOAI"
        openShiftOAuth = softwareSystem "OpenShift OAuth" "User authentication and token management" "External"
        openShiftRouter = softwareSystem "OpenShift Router" "Ingress controller providing Route-based external access" "External"
        openShiftServingCerts = softwareSystem "OpenShift Serving Cert Controller" "Auto-provisions TLS certificates for annotated Services" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource CRUD, TokenReview, SubjectAccessReview" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for ML Metadata storage" "External"
        mysql = softwareSystem "MySQL" "Relational database for ML Metadata storage (alternative)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        platformCR = softwareSystem "ODH Platform (components.platform)" "Provides default-modelregistry CR as catalog owner reference" "Internal RHOAI"
        storageMigration = softwareSystem "Storage Version Migration API" "Kubernetes CRD storage version migration" "External"

        // Relationships
        admin -> rhodsOperator "Configures RHOAI components"
        rhodsOperator -> modelRegistryOperator "Deploys via kustomize overlays (config/overlays/odh)"
        user -> registryInstance "Creates/queries ML models via REST API" "HTTPS/443 (via Route)"
        user -> catalogInstance "Browses model catalog" "HTTPS/443 (via Route)"
        user -> k8sAPI "Creates ModelRegistry CR via kubectl" "HTTPS/443"

        modelRegistryOperator -> k8sAPI "CRUD operations for Deployments, Services, Routes, RBAC, NetworkPolicies" "HTTPS/443"
        modelRegistryOperator -> registryInstance "Provisions and manages lifecycle"
        modelRegistryOperator -> catalogInstance "Provisions and manages lifecycle"
        modelRegistryOperator -> platformCR "Reads default-modelregistry for catalog owner ref" "HTTPS/443"
        modelRegistryOperator -> storageMigration "Creates StorageVersionMigration resources" "HTTPS/443"

        registryInstance -> openShiftOAuth "Authenticates users via OAuth + SAR" "HTTPS/443"
        registryInstance -> postgresql "Stores ML Metadata" "TCP/5432 (configurable SSL)"
        registryInstance -> mysql "Stores ML Metadata (alternative)" "TCP/3306 (configurable SSL)"

        catalogInstance -> openShiftOAuth "Authenticates users via OAuth + SAR" "HTTPS/443"

        openShiftRouter -> registryInstance "Routes external traffic (reencrypt TLS)" "HTTPS/8443"
        openShiftRouter -> catalogInstance "Routes external traffic (reencrypt TLS)" "HTTPS/8443"
        openShiftServingCerts -> registryInstance "Provisions TLS certificates"
        openShiftServingCerts -> modelRegistryOperator "Provisions TLS certificates for metrics and webhooks"

        prometheus -> modelRegistryOperator "Scrapes operator metrics" "HTTPS/8443"

        // Internal container relationships
        reconciler -> templateEngine "Renders resource manifests"
        catalogReconciler -> templateEngine "Renders catalog resource manifests"
        oauthProxy -> restContainer "Proxies authenticated requests" "HTTP/8080 localhost"
        catalogInit -> catalogContainer "Loads default data" "File I/O (shared volume)"
        catalogOAuth -> catalogContainer "Proxies authenticated requests" "HTTP/8080 localhost"
    }

    views {
        systemContext modelRegistryOperator "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistryOperator "OperatorContainers" {
            include *
            autoLayout
        }

        container registryInstance "RegistryContainers" {
            include *
            autoLayout
        }

        container catalogInstance "CatalogContainers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
