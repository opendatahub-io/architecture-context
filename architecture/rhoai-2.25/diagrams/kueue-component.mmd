graph TB
    subgraph KueueOperator["Kueue Controller Manager"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            WLCtrl["Workload<br/>Reconciler"]
            CQCtrl["ClusterQueue<br/>Reconciler"]
            LQCtrl["LocalQueue<br/>Reconciler"]
            RFCtrl["ResourceFlavor<br/>Reconciler"]
            ACCtrl["AdmissionCheck<br/>Reconciler"]
            CohortCtrl["Cohort<br/>Reconciler"]
        end

        subgraph Scheduler["Scheduler (goroutine)"]
            SchedEngine["Scheduler Engine"]
            Cache["In-Memory Cache<br/>(pkg/cache)"]
            QueueMgr["Queue Manager<br/>(pkg/queue)"]
            SchedEngine -->|queries| Cache
            SchedEngine -->|pulls pending| QueueMgr
        end

        subgraph FeatureControllers["Feature Controllers (behind feature gates)"]
            ProvCtrl["Provisioning<br/>Controller"]
            MKCtrl["MultiKueue<br/>Controller"]
            TASCtrl["TAS<br/>Controller"]
        end

        subgraph JobFramework["Job Framework Controllers (Generic Reconciler)"]
            BatchJob["batch/Job"]
            PyTorch["PyTorchJob"]
            TFJob["TFJob"]
            MPIJob["MPIJob"]
            RayJob["RayJob"]
            RayCluster["RayCluster"]
            JobSet["JobSet"]
            AppWrapper["AppWrapper"]
            LWS["LeaderWorkerSet"]
            PodCtrl["Pod/Deployment/<br/>StatefulSet"]
        end

        subgraph Webhooks["Webhook Server (9443/TCP TLS)"]
            MutatingWH["15 Mutating<br/>Webhooks"]
            ValidatingWH["18 Validating<br/>Webhooks"]
        end

        subgraph CertMgmt["Certificate Management"]
            InternalCert["Internal Cert<br/>(self-signed rotation)"]
            ExtCertMgr["cert-manager<br/>(optional)"]
        end

        CQCtrl -->|updates| Cache
        LQCtrl -->|updates| QueueMgr
        WLCtrl -->|enqueues| QueueMgr
    end

    %% CRDs
    User["User / Job Controller"] -->|creates| JobCR["Job / Training Job /<br/>RayJob CR"]
    JobCR -->|watched by| JobFramework
    JobFramework -->|creates| WorkloadCR["Workload CR"]
    WorkloadCR -->|watched by| WLCtrl

    Admin["Platform Admin"] -->|creates| CQ_CR["ClusterQueue CR"]
    Admin -->|creates| LQ_CR["LocalQueue CR"]
    Admin -->|creates| RF_CR["ResourceFlavor CR"]

    CQ_CR -->|watched by| CQCtrl
    LQ_CR -->|watched by| LQCtrl
    RF_CR -->|watched by| RFCtrl

    %% Scheduler admission flow
    SchedEngine -->|admits workload| WLCtrl
    WLCtrl -->|unsuspends| JobCR

    %% External integrations
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"] -->|webhook calls| Webhooks
    KueueOperator -->|CRUD operations| K8sAPI

    Prometheus["Prometheus<br/>8443/TCP HTTPS"] -->|scrapes /metrics| KueueOperator

    ProvCtrl -->|creates| ProvReq["ProvisioningRequest<br/>(cluster-autoscaler)"]

    MKCtrl -->|syncs workloads| WorkerCluster["Worker Clusters<br/>443/TCP HTTPS"]

    %% Styling
    style KueueOperator fill:#e8f4f8,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Scheduler fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style FeatureControllers fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style JobFramework fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Webhooks fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style CertMgmt fill:#f5f5f5,stroke:#666666,stroke-width:1px

    style User fill:#f9f9f9,stroke:#333
    style Admin fill:#f9f9f9,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style WorkerCluster fill:#999,stroke:#333
    style ProvReq fill:#f5a623,stroke:#333
    style WorkloadCR fill:#f5a623,stroke:#333
    style JobCR fill:#f5a623,stroke:#333
    style CQ_CR fill:#f5a623,stroke:#333
    style LQ_CR fill:#f5a623,stroke:#333
    style RF_CR fill:#f5a623,stroke:#333
