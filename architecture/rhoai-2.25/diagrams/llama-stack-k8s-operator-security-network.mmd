graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressController["Ingress Controller<br/>443/TCP → 8321/TCP<br/>TLS 1.2+ (if configured)<br/>spec.network.exposeRoute=true"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: llama-stack-k8s-operator-system"]
            Operator["Operator Controller Manager<br/>SA: controller-manager<br/>Replicas: 1 (leader election)<br/>8443/TCP HTTPS (metrics)<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (health)"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount JWT / User credentials"]

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            LlamaService["Llama Stack Service<br/>Type: ClusterIP<br/>8321/TCP → 8321/TCP<br/>Optional TLS (spec.tlsConfig)"]
            LlamaPod["Llama Stack Pod<br/>Image: llamastack/distribution-{type}<br/>SA: {instance-name}-sa<br/>PVC: /opt/app-root/src/.llama/"]
            LlamaService --> LlamaPod
        end

        subgraph InferenceProviders["Inference Provider Services"]
            Ollama["Ollama<br/>11434/TCP HTTP"]
            vLLM["vLLM<br/>8000/TCP HTTP"]
            TGI["TGI<br/>8080/TCP HTTP"]
        end

        LlamaPod --> Ollama
        LlamaPod --> vLLM
        LlamaPod --> TGI
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Registry["Container Registry<br/>docker.io / quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Image pull secrets"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token (hf-token-secret)"]
        Prometheus["Prometheus<br/>OpenShift Monitoring<br/>8443/TCP HTTPS TLS<br/>Bearer Token"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Optional Auth| IngressController
    IngressController -->|HTTP/8321<br/>Internal| LlamaService

    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount JWT| K8sAPI
    K8sAPI -->|Reconciliation| NS_User

    LlamaPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image pull secrets| Registry
    LlamaPod -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HuggingFace

    Prometheus -->|HTTPS/8443<br/>TLS<br/>Bearer Token| Operator

    %% NetworkPolicy (when enabled)
    subgraph NetworkPolicyRules["NetworkPolicy (when enableNetworkPolicy=true)"]
        direction LR
        NPRule1["Allow: app.kubernetes.io/part-of=llama-stack<br/>(same namespace)"]
        NPRule2["Allow: llama-stack-k8s-operator-system<br/>(operator namespace)"]
        NPRule3["Allow: spec.network.allowedFrom.namespaces<br/>(user-specified)"]
        NPRule4["Allow: spec.network.allowedFrom.labels<br/>(namespace selector)"]
    end

    NetworkPolicyRules -.->|Protects| LlamaPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8sinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:3px
    classDef networkpolicy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class IngressController ingress
    class Operator operator
    class K8sAPI,LlamaService,LlamaPod,Ollama,vLLM,TGI k8sinternal
    class Registry,HuggingFace,Prometheus externalservice
    class NetworkPolicyRules,NPRule1,NPRule2,NPRule3,NPRule4 networkpolicy
