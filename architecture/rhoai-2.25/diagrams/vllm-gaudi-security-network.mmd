graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS)"]
        KServeGW["KServe Ingress / Route<br/>TLS Termination<br/>kube-rbac-proxy sidecar<br/>Bearer Token validation"]
    end

    subgraph Application["APPLICATION (Non-Root UID 2000)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            APIServer["vLLM API Server<br/>odh-vllm-gaudi-rhel9<br/>FastAPI/uvicorn<br/>Listen: 8000/TCP<br/>UID: 2000, GID: 0"]
            HPUWorker["HPUWorker + HPUModelRunner<br/>In-process Python<br/>Graph compilation<br/>128-token KV blocks"]
            GaudiDevice["Gaudi HPU Device<br/>Gaudi2 / Gaudi3<br/>SynapseAI 1.24.0"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        NIXLPeers["Other vLLM Instances<br/>(NIXL KV Transfer)<br/>RDMA/TCP<br/>No Auth (trust-based)"]
        RayHead["Ray Head Node<br/>6379/TCP Redis<br/>8265/TCP Dashboard<br/>No Encryption"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer: HF_TOKEN"]
        HabanaAF["Habana Artifactory<br/>vault.habana.ai<br/>443/TCP HTTPS<br/>(build-time only)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS (platform)<br/>Bearer Token"| KServeGW
    KServeGW -->|"HTTP/8000<br/>Plaintext<br/>TLS terminated"| APIServer
    APIServer -->|"In-process<br/>Python"| HPUWorker
    HPUWorker -->|"HPU API<br/>habana-frameworks"| GaudiDevice

    HPUWorker -->|"RDMA or TCP<br/>dynamic port<br/>No encryption<br/>Trust-based"| NIXLPeers
    HPUWorker -->|"TCP/6379<br/>No encryption<br/>No auth"| RayHead

    HPUWorker -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internalservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KServeGW ingress
    class APIServer,HPUWorker application
    class GaudiDevice hardware
    class NIXLPeers,RayHead internalservice
    class HFHub,HabanaAF externalservice
