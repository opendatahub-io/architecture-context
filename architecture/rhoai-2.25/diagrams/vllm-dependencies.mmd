graph LR
    VLLM["vLLM Inference Runtime<br/>(odh-vllm-cuda-rhel9)"]

    %% External Dependencies (Required)
    VLLM -->|"base image<br/>v3.2.2"| RHAIIS["RHAIIS vllm-cuda-rhel9<br/>registry.redhat.io/rhaiis/<br/>vllm-cuda-rhel9"]
