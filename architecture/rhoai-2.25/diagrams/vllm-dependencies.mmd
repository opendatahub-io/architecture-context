    VLLM -->|"inference engine"| VLLMLib["vLLM Library<br/>v0.10.0.0 lineage<br/>(inherited from RHAIIS)"]
    VLLM -->|"gRPC adapter"| TGISLib["vllm_tgis_adapter<br/>(inherited from RHAIIS)"]

