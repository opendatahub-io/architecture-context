graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>ServiceAccount<br/>Namespace: ${NAMESPACE}"]
        Group_Auth["system:authenticated<br/>(Group)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["${EPP_NAME}-binding<br/>RoleBinding"]
        RB_Exec["exec-rolebinding<br/>RoleBinding"]
    end

    subgraph Roles["Roles"]
        Role_EPP["${EPP_NAME}<br/>Role"]
        Role_Exec["exec-role<br/>Role"]
    end

    subgraph APIResources_GIE["API Resources — inference.networking.x-k8s.io"]
        InferencePools["inference.networking.x-k8s.io<br/>inferencepools"]
        InferenceModels["inference.networking.x-k8s.io<br/>inferencemodels"]
    end

    subgraph APIResources_Core["API Resources — Core"]
        Pods["core ('')<br/>pods"]
        PodsExec["core ('')<br/>pods/exec"]
    end

    subgraph APIResources_Discovery["API Resources — Discovery"]
        EndpointSlices["discovery.k8s.io<br/>endpointslices"]
    end

    subgraph APIResources_Auth["API Resources — Authentication/Authorization"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB_EPP
    RB_EPP -->|"grants"| Role_EPP
    Group_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| Role_Exec

    %% EPP Role permissions
    Role_EPP -->|"get, watch, list"| InferencePools
    Role_EPP -->|"get, watch, list"| InferenceModels
    Role_EPP -->|"get, watch, list"| Pods
    Role_EPP -->|"get, watch, list"| EndpointSlices
    Role_EPP -->|"create"| TokenReviews
    Role_EPP -->|"create"| SubjectAccessReviews

    %% Exec Role permissions
    Role_Exec -->|"create"| PodsExec

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style Group_Auth fill:#4a90e2,stroke:#333,color:#fff
    style RB_EPP fill:#9b59b6,stroke:#333,color:#fff
    style RB_Exec fill:#9b59b6,stroke:#333,color:#fff
    style Role_EPP fill:#f5a623,stroke:#333,color:#fff
    style Role_Exec fill:#f5a623,stroke:#333,color:#fff
    style InferencePools fill:#7ed321,stroke:#333
    style InferenceModels fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#e74c3c,stroke:#333,color:#fff
    style EndpointSlices fill:#7ed321,stroke:#333
    style TokenReviews fill:#e67e22,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e67e22,stroke:#333,color:#fff
