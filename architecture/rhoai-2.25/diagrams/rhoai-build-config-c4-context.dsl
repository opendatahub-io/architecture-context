// RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/RHOAI-Build-Config.md

workspace {
    model {
        releaseEngineer = person "Release Engineer" "Manages RHOAI operator builds, releases, and catalog updates"
        developer = person "Component Developer" "Develops RHOAI sub-components and submits image updates"

        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration repository defining the RHOAI operator bundle, OLM catalog (FBC), image registries, and release artifacts for RHOAI 2.25" {
            operatorBundle = container "Operator Bundle" "Packages rhods-operator CSV, 21 CRDs, RBAC, and service definitions for OLM" "OLM Bundle (YAML)"
            fbcCatalog = container "FBC Catalog Fragments" "File-Based Catalog entries per OCP version (v4.16-v4.20) defining the operator upgrade graph" "OLM FBC (YAML)"
            tektonPipelines = container "Tekton Pipelines" "Konflux pipelines for building operator bundle and FBC fragment container images" "Tekton YAML"
            githubWorkflows = container "GitHub Actions Workflows" "Automate CSV patching, bundle processing, and FBC fragment generation" "GitHub Actions YAML"
            buildConfig = container "Build Configuration" "Image registry mappings, OCP version support matrix, and image replacement rules" "YAML Configuration"
            releaseArtifacts = container "Release Artifacts" "Konflux Release CRs for staging and production releases with CVE/issue tracking" "Kubernetes CRs"
            pncConfigs = container "PNC Build Configs" "Maven-based build configurations for ModelMesh and TrustyAI Java components" "PNC YAML"
            imageDigestMirror = container "ImageDigestMirrorSet" "Registry mirror mappings for disconnected/air-gapped installations" "Kubernetes CR"
        }

        // External Dependencies
        ocp = softwareSystem "OpenShift Container Platform" "Target platform for operator deployment (v4.16-v4.20)" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and lifecycle management" "External"
        konflux = softwareSystem "Konflux / App Studio" "CI/CD build system for container images" "External"
        github = softwareSystem "GitHub" "Source code repository and CI/CD triggers" "External"
        pnc = softwareSystem "PNC (Project Newcastle)" "Maven build system for Java artifacts" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Production container image registry" "External"
        quayIO = softwareSystem "quay.io/rhoai" "Pre-production / CI container image registry" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Container image provenance and compliance verification" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "The actual RHOAI operator binary deployed by this bundle" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Dashboard web UI (RELATED_IMAGE)" "Internal RHOAI"
        dspOperator = softwareSystem "DSP Operator" "Data Science Pipelines controller (RELATED_IMAGE)" "Internal RHOAI"
        kserveController = softwareSystem "KServe Controller" "Inference controller (RELATED_IMAGE)" "Internal RHOAI"
        modelmeshController = softwareSystem "ModelMesh Controller" "Multi-model serving controller (RELATED_IMAGE)" "Internal RHOAI"
        otherComponents = softwareSystem "60+ Other Components" "Notebook, CodeFlare, KubeRay, Kueue, TrustyAI, Model Registry, Feast, Llama Stack, etc." "Internal RHOAI"

        // Relationships
        releaseEngineer -> rhoaiBuildConfig "Manages builds, releases, and catalog updates"
        developer -> rhoaiBuildConfig "Submits component image updates via patches"

        rhoaiBuildConfig -> olm "Provides operator bundle and FBC catalog for installation"
        rhoaiBuildConfig -> konflux "Uses for CI/CD pipeline execution" "HTTPS/443"
        rhoaiBuildConfig -> github "Source repository, webhooks, Actions" "HTTPS/443"
        rhoaiBuildConfig -> pnc "Builds Java artifacts for ModelMesh and TrustyAI" "HTTPS/443"
        rhoaiBuildConfig -> registryRedHat "Pushes production images via release pipeline" "HTTPS/443"
        rhoaiBuildConfig -> quayIO "Pushes CI/pre-production images" "HTTPS/443"
        rhoaiBuildConfig -> enterpriseContract "Validates image compliance" "Tekton Task"
        rhoaiBuildConfig -> ocp "Targets for operator deployment" "v4.16-v4.20"

        operatorBundle -> rhodsOperator "References as operator image (RELATED_IMAGE)"
        operatorBundle -> odhDashboard "References as RELATED_IMAGE"
        operatorBundle -> dspOperator "References as RELATED_IMAGE"
        operatorBundle -> kserveController "References as RELATED_IMAGE"
        operatorBundle -> modelmeshController "References as RELATED_IMAGE"
        operatorBundle -> otherComponents "References 76 total RELATED_IMAGEs"

        tektonPipelines -> quayIO "Pushes bundle and FBC images" "HTTPS/443"
        githubWorkflows -> operatorBundle "Updates CSV with latest patches"
        githubWorkflows -> fbcCatalog "Generates FBC fragments"
        releaseArtifacts -> registryRedHat "Triggers production release" "HTTPS/443"

        olm -> fbcCatalog "Discovers operator via FBC catalog"
        olm -> operatorBundle "Installs operator from bundle"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
