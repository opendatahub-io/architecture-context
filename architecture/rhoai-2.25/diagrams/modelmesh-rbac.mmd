graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["ModelMesh does not define its own RBAC resources.<br/>All RBAC is managed by the modelmesh-serving controller.<br/>This diagram shows the authentication/authorization<br/>model used at the application level."]
    end

    subgraph AuthModel["Application-Level Authentication & Authorization"]
        direction TB

        subgraph ExternalGRPC["External gRPC API (:8033)"]
            direction LR
            APIEndpoint["All gRPC RPCs<br/>registerModel, unregisterModel,<br/>getModelStatus, ensureLoaded,<br/>setVModel, deleteVModel,<br/>inference pass-through"]
            TLSConfig["TLS Configuration<br/>via MM_TLS_* env vars"]
            ClientAuth["Client Auth Policy<br/>MM_TLS_CLIENT_AUTH"]
            ClientAuthValues["NONE — No client cert required<br/>OPTIONAL — Client cert validated if provided<br/>REQUIRE — Client cert mandatory (mTLS)"]

            APIEndpoint --> TLSConfig
            TLSConfig --> ClientAuth
            ClientAuth --> ClientAuthValues
        end

        subgraph InterPod["Inter-Pod Litelinks (:8080)"]
            direction LR
            LitelinksRPCs["Internal RPCs<br/>Model routing, replication,<br/>cache coordination"]
            LitelinksSSL["SSL Configuration<br/>Litelinks SSL framework"]
            IntraClusterAuth["Intra-Cluster Client Auth<br/>MM_INTRACLUSTER_CLIENTAUTH"]
            IntraValues["true — mTLS required<br/>false — No client auth"]

            LitelinksRPCs --> LitelinksSSL
            LitelinksSSL --> IntraClusterAuth
            IntraClusterAuth --> IntraValues
        end

        subgraph OpenEndpoints["Open Endpoints (No Auth)"]
            direction LR
            HealthProbe["Health Probes :8089<br/>/ready, /live<br/>HTTP, No Auth"]
            Metrics["Prometheus :2112<br/>/metrics<br/>HTTPS (self-signed), No Auth"]
            PreStop["Pre-Stop :8090<br/>/prestop<br/>HTTP, No Auth"]
        end
    end

    subgraph Secrets["Secrets Used"]
        direction LR
        TLSSecret["model-mesh-tls-secret<br/>(kubernetes.io/tls)<br/>TLS cert/key for gRPC + Litelinks<br/>Manual / cert-manager<br/>No Auto-Rotate"]
        etcdSecret["model-mesh-icd-etcd<br/>(Opaque)<br/>etcd connection config (JSON)<br/>Manual<br/>No Auto-Rotate"]
    end

    subgraph FIPSWarning["⚠ FIPS Compliance Warning"]
        FIPSInfo["Java FIPS DISABLED: -Dcom.redhat.fips=false<br/>SunPKCS11 provider reconfigured<br/>Netty tcnative-boringssl-static (NOT FIPS-validated)<br/>Known gap for FIPS-enabled clusters"]
    end

    ExternalGRPC -->|"uses"| TLSSecret
    InterPod -->|"uses"| TLSSecret

    style Info fill:#fff3cd,stroke:#ffc107,color:#333
    style APIEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style TLSConfig fill:#dae8fc,stroke:#6c8ebf
    style ClientAuth fill:#dae8fc,stroke:#6c8ebf
    style ClientAuthValues fill:#d5e8d4,stroke:#82b366
    style LitelinksRPCs fill:#4a90e2,stroke:#333,color:#fff
    style LitelinksSSL fill:#dae8fc,stroke:#6c8ebf
    style IntraClusterAuth fill:#dae8fc,stroke:#6c8ebf
    style IntraValues fill:#d5e8d4,stroke:#82b366
    style HealthProbe fill:#e8e8e8,stroke:#333
    style Metrics fill:#e8e8e8,stroke:#333
    style PreStop fill:#e8e8e8,stroke:#333
    style TLSSecret fill:#f5a623,stroke:#333,color:#fff
    style etcdSecret fill:#f5a623,stroke:#333,color:#fff
    style FIPSInfo fill:#f8d7da,stroke:#dc3545,color:#333
