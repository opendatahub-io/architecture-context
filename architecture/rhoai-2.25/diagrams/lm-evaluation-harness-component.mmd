graph TB
    subgraph "lm-evaluation-harness (Batch Job)"
        direction TB

        subgraph "Core Framework"
            CLI["CLI Entry Point<br/>lm_eval/__main__.py"]
            Evaluator["Evaluator Engine<br/>lm_eval/evaluator.py"]
            CLI -->|invokes| Evaluator
        end

        subgraph "Plugin Registries"
            ModelRegistry["MODEL_REGISTRY<br/>@register_model"]
            TaskRegistry["TASK_REGISTRY<br/>YAML-based tasks"]
            MetricRegistry["METRIC_REGISTRY<br/>HF Evaluate + custom"]
            FilterRegistry["FILTER_REGISTRY<br/>Post-processing filters"]
        end

        subgraph "Model Backends"
            HF["HuggingFace<br/>Transformers"]
            VLLM["vLLM<br/>GPU-optimized"]
            OpenAI["OpenAI-compatible<br/>API"]
            WatsonX["IBM WatsonX<br/>AI"]
            AnthropicModel["Anthropic<br/>API"]
            TextSynth["TextSynth<br/>API"]
            SGLang["SGLang<br/>Structured Gen"]
        end

        subgraph "Caching Layer"
            TaskCache["Task/Request Cache<br/>dill + pickle"]
            ResponseCache["Response Cache<br/>SQLite + SHA-256"]
        end

        Evaluator -->|loads from| ModelRegistry
        Evaluator -->|loads from| TaskRegistry
        Evaluator -->|computes via| MetricRegistry
        Evaluator -->|applies| FilterRegistry

        ModelRegistry --- HF
        ModelRegistry --- VLLM
        ModelRegistry --- OpenAI
        ModelRegistry --- WatsonX
        ModelRegistry --- AnthropicModel
        ModelRegistry --- TextSynth
        ModelRegistry --- SGLang

        Evaluator -->|caches tasks| TaskCache
        Evaluator -->|caches responses| ResponseCache
    end

    subgraph "Orchestration"
        Operator["trustyai-service-operator"]
        K8sAPI["Kubernetes API"]
    end

    Operator -->|creates Job via| K8sAPI
    K8sAPI -->|runs| CLI

    subgraph "External Services"
        HFHub["HuggingFace Hub<br/>huggingface.co"]
        S3["S3-compatible Storage"]
        WandB["Weights & Biases<br/>wandb.ai"]
    end

    HF -->|downloads models/datasets| HFHub
    Evaluator -->|stores/retrieves| S3
    Evaluator -.->|optional logging| WandB

    subgraph "Local Storage"
        PVC["PVC / Local Filesystem<br/>Models, outputs, cache"]
        UnitxtCatalog["Unitxt Catalog<br/>Custom task definitions"]
    end

    Evaluator -->|reads/writes| PVC
    TaskRegistry -->|loads from| UnitxtCatalog

    style CLI fill:#4a90e2,stroke:#333,color:#fff
    style Evaluator fill:#4a90e2,stroke:#333,color:#fff
    style ModelRegistry fill:#f5a623,stroke:#333
    style TaskRegistry fill:#f5a623,stroke:#333
    style MetricRegistry fill:#f5a623,stroke:#333
    style FilterRegistry fill:#f5a623,stroke:#333
    style HF fill:#7ed321,stroke:#333
    style VLLM fill:#7ed321,stroke:#333
    style OpenAI fill:#7ed321,stroke:#333
    style WatsonX fill:#7ed321,stroke:#333
    style AnthropicModel fill:#7ed321,stroke:#333
    style TextSynth fill:#7ed321,stroke:#333
    style SGLang fill:#7ed321,stroke:#333
    style Operator fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style HFHub fill:#ddd,stroke:#333
    style S3 fill:#ddd,stroke:#333
