// C4 Context Diagram: guardrails-regex-detector
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/guardrails-regex-detector.md

workspace {
    model {
        // Actors
        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Coordinates multiple guardrails detectors to ensure AI model outputs comply with safety and privacy policies" "Internal RHOAI"

        k8s = softwareSystem "Kubernetes" "Container orchestration platform providing health probes and service discovery" "Platform"

        llm = softwareSystem "LLM Service" "Large Language Model service whose input/output is scanned for sensitive content" "Internal RHOAI"

        // Main system
        regexDetector = softwareSystem "guardrails-regex-detector" "Lightweight regex-based text detection service for identifying PII patterns in text content" {
            httpService = container "regex-detector" "Rust HTTP microservice providing REST API for regex-based text content detection" "Rust/Axum on UBI 9 Minimal"
            builtinDetectors = container "Built-in Detectors" "Pre-configured regex patterns for email, SSN, and credit card detection" "Rust Modules"
            customEngine = container "Custom Regex Engine" "Accepts arbitrary user-defined regex patterns for flexible content scanning" "Rust Module"
        }

        // Relationships - System level
        orchestrator -> regexDetector "Sends text for PII/regex scanning" "HTTP/8080 POST /api/v1/text/contents"
        k8s -> regexDetector "Health checks" "HTTP/8080 GET /health"
        llm -> orchestrator "LLM input/output sent for guardrails checking"
        orchestrator -> llm "Returns filtered/flagged content"

        // Relationships - Container level
        orchestrator -> httpService "POST /api/v1/text/contents" "HTTP/8080 plaintext"
        k8s -> httpService "GET /health" "HTTP/8080 plaintext"
        httpService -> builtinDetectors "Routes built-in regex requests (email, ssn, credit-card)"
        httpService -> customEngine "Routes custom regex pattern requests"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
            description "System context showing guardrails-regex-detector in the RHOAI guardrails ecosystem"
        }

        container regexDetector "Containers" {
            include *
            autoLayout
            description "Container view showing internal structure of the regex detector"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
