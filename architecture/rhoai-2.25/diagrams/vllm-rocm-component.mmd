graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        subgraph "RHAIIS Base Image"
            VLLMEngine["vLLM Inference Engine<br/>ROCm/HIP Backend"]
            TGISAdapter["TGIS Adapter<br/>(vllm_tgis_adapter)"]
            OpenAIServer["OpenAI-Compatible API Server<br/>Port 8000/TCP"]
            GRPCServer["gRPC Server<br/>Port 8033/TCP"]

            VLLMEngine -->|in-process| OpenAIServer
            VLLMEngine -->|in-process| TGISAdapter
            TGISAdapter -->|exposes| GRPCServer
        end
    end

    subgraph "Platform Security Layer"
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>Port 8443/TCP<br/>TLS 1.2+ / Bearer Token"]
    end

    Client[Client / KServe Router] -->|HTTPS/8443| KubeRBACProxy
    KubeRBACProxy -->|HTTP/8000<br/>localhost| OpenAIServer

    Client -->|gRPC/8033<br/>Platform Auth| GRPCServer

    subgraph "APIs (Port 8000)"
        CompletionsAPI["/v1/completions<br/>POST"]
        ChatAPI["/v1/chat/completions<br/>POST"]
        ModelsAPI["/v1/models<br/>GET"]
        HealthAPI["/health<br/>GET"]
    end

    OpenAIServer --- CompletionsAPI
    OpenAIServer --- ChatAPI
    OpenAIServer --- ModelsAPI
    OpenAIServer --- HealthAPI

    subgraph "gRPC (Port 8033)"
        TGISService["TGIS GenerationService"]
    end

    GRPCServer --- TGISService

    VLLMEngine -->|HIP Runtime| GPU["AMD GPU<br/>ROCm"]
    VLLMEngine -->|model loading| ModelStorage["Model Storage<br/>(PVC / S3)"]

    KServeRT["KServe ServingRuntime"] -->|deploys| VLLMEngine
    Prometheus["Prometheus"] -->|scrapes /metrics<br/>8000/TCP| OpenAIServer

    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style OpenAIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#f5a623,stroke:#333,color:#fff
    style GPU fill:#e74c3c,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333
    style KServeRT fill:#7ed321,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
