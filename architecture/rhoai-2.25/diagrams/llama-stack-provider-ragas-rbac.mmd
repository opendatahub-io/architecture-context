graph TD
    subgraph "Authentication Model"
        direction TB

        subgraph "Remote Provider Auth"
            OSToken["OpenShift Token<br/>(via oc login / kube_config)"]
            AWSCreds["aws-credentials Secret<br/>(Opaque)"]
        end

        subgraph "Secrets"
            AWSKey["AWS_ACCESS_KEY_ID"]
            AWSSecret["AWS_SECRET_ACCESS_KEY"]
            AWSRegion["AWS_DEFAULT_REGION"]
        end

        subgraph "Protected Resources"
            KFPApi["Kubeflow Pipelines API<br/>443/TCP HTTPS"]
            S3Store["S3/MinIO Storage<br/>443/TCP HTTPS"]
            LLSServer["Llama Stack Server<br/>8321/TCP HTTP<br/>No Auth (configurable)"]
        end

        subgraph "Managed By (External)"
            LLSOp["Llama Stack K8s Operator<br/>Manages server RBAC"]
            KFPController["KFP Controller<br/>Manages pipeline RBAC"]
            OSAuth["OpenShift RBAC<br/>Manages cluster access"]
        end
    end

    %% Auth flows
    OSToken -->|"Bearer Token<br/>OpenShift RBAC"| KFPApi
    AWSCreds --> AWSKey
    AWSCreds --> AWSSecret
    AWSCreds --> AWSRegion
    AWSKey -->|"AWS IAM Auth"| S3Store
    AWSSecret -->|"AWS IAM Auth"| S3Store

    %% External RBAC management
    LLSOp -.->|manages| LLSServer
    KFPController -.->|manages| KFPApi
    OSAuth -.->|enforces| OSToken

    %% Secret provisioning
    UserAdmin["User/Admin"] -->|"provisions"| AWSCreds
    OCLogin["oc login"] -->|"creates session"| OSToken

    %% Styling
    style OSToken fill:#4a90e2,color:#fff
    style AWSCreds fill:#4a90e2,color:#fff
    style KFPApi fill:#f5a623,color:#fff
    style S3Store fill:#f5a623,color:#fff
    style LLSServer fill:#f5a623,color:#fff
    style LLSOp fill:#7ed321,color:#fff
    style KFPController fill:#7ed321,color:#fff
    style OSAuth fill:#7ed321,color:#fff
    style AWSKey fill:#e8e8e8
    style AWSSecret fill:#e8e8e8
    style AWSRegion fill:#e8e8e8
    style UserAdmin fill:#f9f9f9
    style OCLogin fill:#f9f9f9
