// rhods-operator C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/rhods-operator.md

workspace {
    model {
        admin = person "Platform Admin" "Configures and manages the RHOAI platform on OpenShift"
        datascientist = person "Data Scientist" "Uses AI/ML platform components for model development and serving"

        rhodsOperator = softwareSystem "rhods-operator" "Central lifecycle management operator for Red Hat OpenShift AI platform" {
            dsciController = container "DSCInitialization Controller" "Manages platform initialization: namespace, monitoring, mesh, auth" "Go Controller"
            dscController = container "DataScienceCluster Controller" "Reconciles DSC CR to provision/deprovision component CRs" "Go Controller"
            componentControllers = container "Component Controllers" "14 sub-controllers managing individual AI/ML components via kustomize" "Go Controllers"
            serviceControllers = container "Service Controllers" "Auth, Monitoring, ServiceMesh, SecretGenerator, CertConfigmap, Setup" "Go Controllers"
            webhookServer = container "Webhook Server" "Validates/mutates DSC, DSCI, HardwareProfile, InferenceService, Notebook, Kueue" "Go HTTPS Server"
        }

        // Internal ODH Components (managed by operator)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform" "Managed Component"
        kserve = softwareSystem "KServe" "Serverless ML model serving" "Managed Component"
        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving infrastructure" "Managed Component"
        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Managed Component"
        modelRegistry = softwareSystem "Model Registry" "Model metadata and artifact registry" "Managed Component"
        ray = softwareSystem "KubeRay" "Distributed computing framework" "Managed Component"
        codeflare = softwareSystem "CodeFlare" "Distributed workload orchestration" "Managed Component"
        kueue = softwareSystem "Kueue" "Job scheduling and queue management" "Managed Component"
        trustyai = softwareSystem "TrustyAI" "AI explainability service" "Managed Component"
        trainingOperator = softwareSystem "Training Operator" "Distributed training jobs" "Managed Component"
        feast = softwareSystem "Feast Operator" "Feature store operator" "Managed Component"
        llamastack = softwareSystem "LlamaStack Operator" "LLM inference operator" "Managed Component"

        // External Dependencies
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane" "External"
        istio = softwareSystem "Istio / Maistra" "Service mesh for traffic management and mTLS" "External"
        authorino = softwareSystem "Authorino" "External authorization service" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling runtime" "External"
        prometheus = softwareSystem "Prometheus Operator" "Monitoring and alerting" "External"
        observabilityOp = softwareSystem "Observability Operator" "MonitoringStack deployment" "External"
        tempo = softwareSystem "Tempo Operator" "Distributed tracing backend" "External"
        otel = softwareSystem "OpenTelemetry Operator" "Telemetry collection pipeline" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager" "External"
        certManager = softwareSystem "cert-manager" "Certificate management" "External"
        registries = softwareSystem "Container Registries" "Container image storage" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "Platform authentication" "External"

        // Relationships - Users
        admin -> rhodsOperator "Creates DSCInitialization and DataScienceCluster CRs via kubectl"
        datascientist -> dashboard "Accesses AI/ML platform via web UI"

        // Relationships - Operator to managed components
        rhodsOperator -> dashboard "Deploys and manages" "kustomize manifests"
        rhodsOperator -> kserve "Deploys and manages" "kustomize manifests"
        rhodsOperator -> modelmesh "Deploys and manages" "kustomize manifests"
        rhodsOperator -> dsp "Deploys and manages" "kustomize manifests"
        rhodsOperator -> modelRegistry "Deploys and manages" "kustomize manifests"
        rhodsOperator -> ray "Deploys and manages" "kustomize manifests"
        rhodsOperator -> codeflare "Deploys and manages" "kustomize manifests"
        rhodsOperator -> kueue "Deploys and manages" "kustomize manifests"
        rhodsOperator -> trustyai "Deploys and manages" "kustomize manifests"
        rhodsOperator -> trainingOperator "Deploys and manages" "kustomize manifests"
        rhodsOperator -> feast "Deploys and manages" "kustomize manifests"
        rhodsOperator -> llamastack "Deploys and manages" "kustomize manifests"

        // Relationships - Operator to external dependencies
        rhodsOperator -> k8sAPI "All reconciliation operations" "HTTPS/6443"
        rhodsOperator -> istio "Manages ServiceMeshControlPlane, mTLS" "CRD/API"
        rhodsOperator -> authorino "Creates Authorino instances, AuthConfigs" "CRD/API"
        rhodsOperator -> knative "Manages KnativeServing for KServe" "CRD/API"
        rhodsOperator -> prometheus "Deploys PrometheusRules, ServiceMonitors" "CRD/API"
        rhodsOperator -> observabilityOp "Deploys MonitoringStack" "CRD/API"
        rhodsOperator -> tempo "Deploys TempoMonolithic/TempoStack" "CRD/API"
        rhodsOperator -> otel "Deploys Collectors, Instrumentation" "CRD/API"
        rhodsOperator -> olm "Manages operator dependencies" "API"
        rhodsOperator -> certManager "Certificate management (optional)" "CRD/API"
        rhodsOperator -> registries "Pulls component images" "HTTPS/443"
        rhodsOperator -> openshiftOAuth "Manages OAuthClients" "HTTPS/443"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Managed Component" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
