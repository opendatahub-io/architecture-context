graph LR
    VLLMGaudi["vllm-gaudi<br/><i>HPU Plugin for vLLM</i>"]

    %% External Dependencies (Required)
    VLLMGaudi -->|"extends via<br/>entry points"| vLLM["vLLM v0.19.0"]
    VLLMGaudi -->|"HPU drivers<br/>& runtime"| SynapseAI["Intel Gaudi<br/>SynapseAI 1.24.0"]
    VLLMGaudi -->|"deep learning<br/>framework"| PyTorch["PyTorch 2.10.0<br/>(HPU backend)"]
    VLLMGaudi -->|"HPU integration<br/>htorch, hpu graphs"| HabanaFW["habana-frameworks<br/>1.24.0"]
    VLLMGaudi -->|"distributed<br/>multi-HPU"| Ray["Ray >=2.48.0"]
    VLLMGaudi -->|"model loading<br/>& tokenization"| Transformers["HuggingFace<br/>Transformers >=4.56"]
    VLLMGaudi -->|"API framework"| FastAPI["FastAPI"]
    VLLMGaudi -->|"async event loop"| uvloop["uvloop"]
    VLLMGaudi -->|"audio models<br/>(Qwen3.5)"| torchaudio["torchaudio 2.10.0"]

    %% External Dependencies (Optional)
    VLLMGaudi -.->|"KV cache<br/>transfer"| NIXL["NIXL<br/>(optional)"]
    VLLMGaudi -.->|"external KV<br/>cache sharing"| LMCache["LMCache<br/>(optional)"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe /<br/>ModelMesh"] -->|"deploys as<br/>ServingRuntime"| VLLMGaudi
    Dashboard["RHOAI<br/>Dashboard"] -->|"UI config<br/>reference"| KServe
    ModelCtrl["Model<br/>Controller"] -->|"InferenceService<br/>CR lifecycle"| KServe

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTP/8000"| VLLMGaudi

    %% External Services
    VLLMGaudi -->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    VLLMGaudi -->|"HPU device<br/>access"| GaudiHW["Gaudi HPU<br/>Gaudi2 / Gaudi3"]

    %% Styling
    style VLLMGaudi fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style vLLM fill:#999,stroke:#333,color:#fff
    style SynapseAI fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style HabanaFW fill:#999,stroke:#333,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style uvloop fill:#999,stroke:#333,color:#fff
    style torchaudio fill:#999,stroke:#333,color:#fff

    style NIXL fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style LMCache fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style GaudiHW fill:#7b68ee,stroke:#333,color:#fff
