graph TB
    subgraph "CodeFlare SDK (Python Client Library)"
        direction TB

        subgraph "Ray Cluster Management"
            Cluster["Cluster Class<br/>(cluster.py)"]
            ClusterConfig["ClusterConfiguration<br/>(config.py)"]
            BuildRC["build_ray_cluster<br/>(build_ray_cluster.py)"]
            StatusModule["ClusterStatus<br/>(status.py)"]
            ClusterConfig -->|configures| Cluster
            Cluster -->|uses| BuildRC
            Cluster -->|reports| StatusModule
        end

        subgraph "Ray Job Management"
            RayJob["RayJob Class<br/>(rayjob.py)"]
            RayJobConfig["RayJobConfiguration<br/>(config.py)"]
            RuntimeEnv["RuntimeEnv<br/>(runtime_env.py)"]
            RayJobClient["RayJobClient<br/>(ray_jobs.py)"]
            RayJobConfig -->|configures| RayJob
            RayJob -->|uses| RuntimeEnv
        end

        subgraph "Common Utilities"
            AuthModule["Authentication Module<br/>(kube-authkit)"]
            TLSGen["TLS Certificate Generator<br/>(generate_cert.py)"]
            KueueInteg["Kueue Integration<br/>(kueue.py)"]
            Widgets["Jupyter Widgets<br/>(widgets.py)"]
        end

        subgraph "Vendored Dependencies"
            VendoredKubeRay["Vendored KubeRay Client<br/>(python_client/)"]
        end

        Cluster -->|authenticates via| AuthModule
        RayJob -->|authenticates via| AuthModule
        Cluster -->|generates certs| TLSGen
        Cluster -->|validates queues| KueueInteg
        RayJob -->|validates queues| KueueInteg
        RayJob -->|uses| VendoredKubeRay
        RayJobClient -->|wraps| RayJobSubmissionClient["Ray JobSubmissionClient"]
        Widgets -->|displays| Cluster
    end

    %% External CRDs Consumed
    User["Data Scientist / Notebook User"] -->|creates clusters| Cluster
    User -->|submits jobs| RayJob
    User -->|submits jobs directly| RayJobClient

    Cluster -->|creates/manages| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJob -->|creates/manages| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    KueueInteg -->|reads| LocalQueueCR["LocalQueue CR<br/>(kueue.x-k8s.io/v1beta1)"]
    KueueInteg -->|reads| WorkloadCR["Workload CR<br/>(kueue.x-k8s.io/v1beta1)"]

    %% External Systems
    RayClusterCR -->|reconciled by| KubeRayOp["KubeRay Operator"]
    RayJobCR -->|reconciled by| KubeRayOp
    AuthModule -->|authenticates to| K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    TLSGen -->|reads CA from| CASecret["CA Secret<br/>(KubeRay-generated)"]
    Cluster -->|discovers URL via| HTTPRoute["HTTPRoute / Route<br/>(Gateway API / OpenShift)"]
    RayJobClient -->|connects to| RayDashboard["Ray Dashboard<br/>8265/TCP"]

    %% Styling
    style Cluster fill:#4a90e2,stroke:#333,color:#fff
    style RayJob fill:#4a90e2,stroke:#333,color:#fff
    style RayJobClient fill:#4a90e2,stroke:#333,color:#fff
    style AuthModule fill:#50c878,stroke:#333,color:#fff
    style TLSGen fill:#50c878,stroke:#333,color:#fff
    style KueueInteg fill:#50c878,stroke:#333,color:#fff
    style Widgets fill:#50c878,stroke:#333,color:#fff
    style VendoredKubeRay fill:#9b59b6,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333,color:#fff
    style RayJobCR fill:#f5a623,stroke:#333,color:#fff
    style LocalQueueCR fill:#f5a623,stroke:#333
    style WorkloadCR fill:#f5a623,stroke:#333
    style KubeRayOp fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CASecret fill:#e8e8e8,stroke:#333
    style HTTPRoute fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
