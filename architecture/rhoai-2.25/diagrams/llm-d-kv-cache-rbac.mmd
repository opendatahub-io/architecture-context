graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/>(ServiceAccount)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["kv-cache-manager<br/>(RoleBinding or ClusterRoleBinding)"]
    end

    subgraph Roles["Roles"]
        Role["kv-cache-manager<br/>(Role or ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Pods["core (&quot;&quot;)<br/>pods"]
    end

    subgraph Verbs["Permitted Verbs"]
        Get["get"]
        List["list"]
        Watch["watch"]
    end

    SA -->|bound via| RB
    RB -->|grants| Role
    Role -->|applies to| Pods
    Pods --- Get
    Pods --- List
    Pods --- Watch

    subgraph Scope["Scope"]
        direction LR
        NSScoped["Namespace-scoped Role<br/>(when podNamespace is set)"]
        ClusterScoped["ClusterRole<br/>(when watching all namespaces)"]
    end

    Role -.->|scope depends on config| Scope

    subgraph Secrets["Secrets"]
        HFSecret["vllm-p2p-secrets<br/>Type: Opaque<br/>Contains: HuggingFace API token<br/>Provisioned: Manual (Helm)<br/>Auto-rotate: No"]
    end

    subgraph AuthEndpoints["Endpoint Authentication"]
        ScoreAPI["/score_completions<br/>POST - No Auth"]
        ChatAPI["/score_chat_completions<br/>POST - No Auth"]
        MetricsAPI["/metrics<br/>GET - No Auth"]
        GRPCIdx["gRPC IndexerService<br/>GetPodScores - No Auth"]
        GRPCTok["gRPC TokenizationService<br/>All methods - No Auth<br/>(Unix Domain Socket only)"]
    end

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style RB fill:#f5a623,color:#fff
    style Role fill:#f5a623,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Watch fill:#d5e8d4,stroke:#82b366
    style NSScoped fill:#dae8fc,stroke:#6c8ebf
    style ClusterScoped fill:#dae8fc,stroke:#6c8ebf
    style HFSecret fill:#f8cecc,stroke:#b85450
    style ScoreAPI fill:#e8e8e8,stroke:#999
    style ChatAPI fill:#e8e8e8,stroke:#999
    style MetricsAPI fill:#e8e8e8,stroke:#999
    style GRPCIdx fill:#e8e8e8,stroke:#999
    style GRPCTok fill:#e8e8e8,stroke:#999
