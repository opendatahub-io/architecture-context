graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op["training-operator<br/>Namespace: opendatahub"]
        SA_Launcher["{mpijob}-launcher<br/>Namespace: {job-ns}<br/>(dynamically created per MPI job)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Op["training-operator<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Webhook["training-operator-webhook<br/>Namespace: opendatahub"]
        RB_Launcher["{mpijob}-launcher<br/>Namespace: {job-ns}<br/>(dynamic)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Op["training-operator"]
        CR_Edit["training-edit<br/>(RHOAI, aggregated to edit/admin)"]
        CR_View["training-view<br/>(RHOAI, aggregated to view)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Webhook["training-operator-webhook<br/>Namespace: opendatahub"]
        R_Launcher["{mpijob}-launcher<br/>Namespace: {job-ns}<br/>(dynamic)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core/v1<br/>Pods"]
        PodsExec["core/v1<br/>Pods/exec"]
        Services["core/v1<br/>Services"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
        Events["core/v1<br/>Events"]
        ServiceAccounts_R["core/v1<br/>ServiceAccounts"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        PyTorchJobs["PyTorchJobs<br/>+ /status + /finalizers"]
        TFJobs["TFJobs<br/>+ /status + /finalizers"]
        XGBoostJobs["XGBoostJobs<br/>+ /status + /finalizers"]
        MPIJobs["MPIJobs<br/>+ /status + /finalizers"]
        JAXJobs["JAXJobs<br/>+ /status + /finalizers"]
        PaddleJobs["PaddleJobs<br/>+ /status + /finalizers"]
    end

    subgraph OtherResources["Other API Resources"]
        VWC["admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations"]
        HPAs["autoscaling<br/>HorizontalPodAutoscalers"]
        RBAC_Res["rbac.authorization.k8s.io<br/>Roles, RoleBindings"]
        VolcanoPG["scheduling.volcano.sh<br/>PodGroups"]
        SchedPG["scheduling.x-k8s.io<br/>PodGroups"]
        NetPol["networking.k8s.io<br/>NetworkPolicies"]
    end

    subgraph SecretResources["Secrets (namespace-scoped)"]
        WebhookSecret["kubeflow-training-operator-webhook-cert<br/>TLS cert (OPA cert-controller)"]
    end

    %% Operator SA bindings
    SA_Op -->|"bound via"| CRB_Op
    CRB_Op -->|"grants"| CR_Op
    SA_Op -->|"bound via"| RB_Webhook
    RB_Webhook -->|"grants"| R_Webhook

    %% ClusterRole permissions
    CR_Op -->|"create,delete,get,list,<br/>patch,update,watch"| Pods
    CR_Op -->|"create"| PodsExec
    CR_Op -->|"create,delete,get,list,watch"| Services
    CR_Op -->|"create,list,update,watch"| ConfigMaps
    CR_Op -->|"full CRUD"| Events
    CR_Op -->|"create,get,list,watch"| ServiceAccounts_R
    CR_Op -->|"full CRUD +<br/>status + finalizers"| PyTorchJobs
    CR_Op -->|"full CRUD +<br/>status + finalizers"| TFJobs
    CR_Op -->|"full CRUD +<br/>status + finalizers"| XGBoostJobs
    CR_Op -->|"full CRUD +<br/>status + finalizers"| MPIJobs
    CR_Op -->|"full CRUD +<br/>status + finalizers"| JAXJobs
    CR_Op -->|"full CRUD +<br/>status + finalizers"| PaddleJobs
    CR_Op -->|"get,list,update,watch"| VWC
    CR_Op -->|"full CRUD"| HPAs
    CR_Op -->|"create,list,update,watch"| RBAC_Res
    CR_Op -->|"full CRUD"| VolcanoPG
    CR_Op -->|"full CRUD"| SchedPG
    CR_Op -->|"full CRUD"| NetPol

    %% Webhook Role
    R_Webhook -->|"get,update"| WebhookSecret

    %% Dynamic MPI RBAC
    SA_Launcher -->|"bound via"| RB_Launcher
    RB_Launcher -->|"grants"| R_Launcher
    R_Launcher -->|"get,list,watch"| Pods
    R_Launcher -->|"create<br/>(resourceNames: worker pods)"| PodsExec

    %% RHOAI aggregated roles
    CR_Edit -->|"full CRUD"| PyTorchJobs
    CR_Edit -->|"full CRUD"| TFJobs
    CR_Edit -->|"full CRUD"| XGBoostJobs
    CR_Edit -->|"full CRUD"| MPIJobs
    CR_Edit -->|"full CRUD"| PaddleJobs
    CR_View -->|"get,list,watch"| PyTorchJobs
    CR_View -->|"get,list,watch"| TFJobs
    CR_View -->|"get,list,watch"| XGBoostJobs
    CR_View -->|"get,list,watch"| MPIJobs
    CR_View -->|"get,list,watch"| PaddleJobs

    %% Styles
    style SA_Op fill:#4a90e2,color:#fff
    style SA_Launcher fill:#4a90e2,color:#fff
    style CR_Op fill:#f5a623,color:#fff
    style CR_Edit fill:#f5a623,color:#fff
    style CR_View fill:#f5a623,color:#fff
    style R_Webhook fill:#e8a040,color:#fff
    style R_Launcher fill:#e8a040,color:#fff
    style PyTorchJobs fill:#7ed321,color:#fff
    style TFJobs fill:#7ed321,color:#fff
    style XGBoostJobs fill:#7ed321,color:#fff
    style MPIJobs fill:#7ed321,color:#fff
    style JAXJobs fill:#7ed321,color:#fff
    style PaddleJobs fill:#7ed321,color:#fff
    style WebhookSecret fill:#e74c3c,color:#fff
