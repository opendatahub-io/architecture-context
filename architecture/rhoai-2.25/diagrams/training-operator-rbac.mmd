graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kubeflow-training-operator<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB[kubeflow-training-operator-webhook-secret<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Permissions"
        CR[training-operator<br/>ClusterRole]
    end

    subgraph "Namespace-Scoped Role"
        NSRole[training-operator-webhook-secret<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph "Core API Resources"
        Pods[core/pods<br/>create, delete, get, list, patch, update, watch]
        PodsExec[core/pods/exec<br/>create]
        Services[core/services<br/>create, delete, get, list, watch]
        ServiceAccounts[core/serviceaccounts<br/>create, get, list, watch]
        ConfigMaps[core/configmaps<br/>create, list, update, watch]
        Events[core/events<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Kubeflow Training CRDs"
        PyTorchJobs[kubeflow.org/pytorchjobs<br/>Full CRUD + status + finalizers]
        TFJobs[kubeflow.org/tfjobs<br/>Full CRUD + status + finalizers]
        MPIJobs[kubeflow.org/mpijobs<br/>Full CRUD + status + finalizers]
        XGBoostJobs[kubeflow.org/xgboostjobs<br/>Full CRUD + status + finalizers]
        PaddleJobs[kubeflow.org/paddlejobs<br/>Full CRUD + status + finalizers]
        JAXJobs[kubeflow.org/jaxjobs<br/>Full CRUD + status + finalizers]
    end

    subgraph "Autoscaling Resources"
        HPA[autoscaling/horizontalpodautoscalers<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPG[scheduling.volcano.sh/podgroups<br/>create, delete, get, list, patch, update, watch]
        SchedulerPG[scheduling.x-k8s.io/podgroups<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Networking Resources"
        NetworkPolicies[networking.k8s.io/networkpolicies<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "RBAC Resources"
        Roles[rbac.authorization.k8s.io/roles<br/>create, list, update, watch]
        RoleBindings[rbac.authorization.k8s.io/rolebindings<br/>create, list, update, watch]
    end

    subgraph "Admission Resources"
        WebhookConfigs[admissionregistration.k8s.io/<br/>validatingwebhookconfigurations<br/>get, list, update, watch]
    end

    subgraph "Secrets (Namespace-Scoped)"
        Secrets[core/secrets<br/>get, list, watch, create, update, patch<br/>RESTRICTED to opendatahub namespace]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% ClusterRole Binding
    CRB -->|grants| CR

    %% RoleBinding
    RB -->|grants| NSRole

    %% ClusterRole Permissions
    CR -->|manages| Pods
    CR -->|exec into| PodsExec
    CR -->|manages| Services
    CR -->|manages| ServiceAccounts
    CR -->|manages| ConfigMaps
    CR -->|creates| Events

    CR -->|full lifecycle| PyTorchJobs
    CR -->|full lifecycle| TFJobs
    CR -->|full lifecycle| MPIJobs
    CR -->|full lifecycle| XGBoostJobs
    CR -->|full lifecycle| PaddleJobs
    CR -->|full lifecycle| JAXJobs

    CR -->|elastic training| HPA

    CR -->|gang scheduling| VolcanoPG
    CR -->|gang scheduling| SchedulerPG

    CR -->|network isolation| NetworkPolicies

    CR -->|job RBAC| Roles
    CR -->|job RBAC| RoleBindings

    CR -->|webhook config| WebhookConfigs

    %% Namespace-Scoped Role Permissions
    NSRole -->|webhook certs<br/>opendatahub only| Secrets

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style NSRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style RB fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff

    style PyTorchJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style TFJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style MPIJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style XGBoostJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style PaddleJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style JAXJobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    style Secrets fill:#d5008f,stroke:#333,stroke-width:2px,color:#fff
    style WebhookConfigs fill:#d5008f,stroke:#333,stroke-width:2px,color:#fff
