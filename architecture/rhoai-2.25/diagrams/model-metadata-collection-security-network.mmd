graph TB
    subgraph CICD["CI/CD BUILD TIME (Konflux Pipeline)"]
        direction TB

        subgraph Pipeline["Tekton Pipeline (hermetic=true)"]
            Extractor["model-extractor CLI<br/>Go 1.24 (CGO_ENABLED=0)<br/>NOT in production image<br/>Max concurrency: 5"]
        end

        subgraph Artifacts["Generated Artifacts"]
            Catalog["models-catalog.yaml"]
            Index["models-index.yaml"]
        end

        Extractor -->|generates| Catalog
        Extractor -->|reads| Index
    end

    subgraph ExternalServices["EXTERNAL SERVICES (CI/CD Egress Only)"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>OCI Distribution v2<br/>TLS 1.2+<br/>Auth: Registry credentials"]
        HuggingFace["huggingface.co<br/>443/TCP HTTPS<br/>REST API<br/>TLS 1.2+<br/>Auth: None (public)"]
    end

    subgraph ImageRegistry["IMAGE REGISTRY"]
        Quay["quay.io/rhoai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Quay push credentials<br/>Multi-arch: x86_64, ppc64le,<br/>s390x, arm64"]
    end

    subgraph Runtime["RUNTIME (Cluster Internal - NO Network Activity)"]
        direction TB

        subgraph DataPod["Data Container Pod"]
            Container["odh-model-metadata-collection-rhel9<br/>Base: ubi9-micro<br/>CMD: sleep infinity<br/>Ports: NONE<br/>Services: NONE<br/>Ingress: NONE<br/>Egress: NONE"]
            DataFiles["Static YAML Data Files<br/>(volume mount source)"]
            Container --- DataFiles
        end

        subgraph Consumer["Platform Consumer"]
            Dashboard["RHOAI Dashboard<br/>Reads catalog via<br/>volume mount / sidecar"]
        end

        DataFiles -->|File I/O<br/>Volume mount<br/>No network| Dashboard
    end

    %% CI/CD egress flows
    Extractor -->|HTTPS/443<br/>OCI v2<br/>TLS 1.2+<br/>Registry credentials| Registry
    Extractor -->|HTTPS/443<br/>REST API<br/>TLS 1.2+<br/>No auth (public)| HuggingFace

    %% Build flow
    Pipeline -->|Container build<br/>COPY data files<br/>into ubi9-micro| Quay

    %% Deploy flow
    Quay -.->|Image pull<br/>at deploy time| Container

    %% Styling
    classDef cicd fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef runtime fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef nonetwork fill:#c8e6c9,stroke:#1b5e20,stroke-width:3px
    classDef registry fill:#fff9c4,stroke:#f57f17,stroke-width:2px

    class Extractor cicd
    class Registry,HuggingFace external
    class Container,DataFiles nonetwork
    class Dashboard runtime
    class Quay registry
