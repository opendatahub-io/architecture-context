    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"metrics scraping<br/>8080/TCP HTTP"| CFOp
    OSHCertSigner["OpenShift<br/>serving-cert-signer"] -->|"annotation-triggered<br/>TLS cert generation"| CFOp
    TrainingOp["Training Operator<br/>(kubeflow.org)"] -.->|"PyTorchJob CRD<br/>(AppWrapper wraps)"| CFOp

    %% Kubernetes platform
    CFOp -->|"watches, CRUD, SAR,<br/>TokenReview<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Injected container images (runtime dependencies)
    CFOp -->|"injected sidecar"| OAuthProxyImg["ose-oauth-proxy image<br/>registry.redhat.io"]
    CFOp -->|"injected init container"| CertGenImg["ubi9 cert-gen image<br/>registry.redhat.io"]

