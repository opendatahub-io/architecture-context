graph TB
    subgraph MonitoringStack["Monitoring Infrastructure (redhat-ods-monitoring)"]
        direction TB
        Prometheus["MonitoringStack<br/>(Prometheus + Alertmanager)<br/>PrometheusRules: platform alerts"]
        Tempo["Tempo<br/>Trace backend<br/>Distributed trace storage"]
        OTELCollector["OpenTelemetry Collector<br/>OTLP/gRPC receive<br/>→ Tempo export"]
    end

    subgraph MetricsEndpoints["Prometheus Scrape Targets"]
        direction TB

        subgraph MetricsProtected["Protected Metrics (kube-rbac-proxy)"]
            M_Kueue["Kueue Controller<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>ServiceMonitor: yes"]
            M_Training["Training Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>ServiceMonitor: yes"]
        end

        subgraph MetricsStandard["Standard Metrics Endpoints"]
            M_Dashboard["odh-dashboard<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: yes"]
            M_KServe["KServe Controller<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: created by odh-model-ctrl"]
            M_ODHModel["odh-model-controller<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: yes"]
            M_DSPO["DSPO Controller<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: yes"]
            M_CodeFlare["CodeFlare Operator<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: yes"]
            M_ModelMesh["ModelMesh Serving<br/>Port: 8080/TCP<br/>Auth: None (cluster-internal)<br/>ServiceMonitor: yes"]
        end

        subgraph MetricsWorkload["Workload Metrics (User Namespaces)"]
            M_ISVC["InferenceService Pods<br/>kserve-agent sidecar metrics<br/>ServiceMonitor: per-ISVC"]
            M_TrustyAI["TrustyAI Instances<br/>Model fairness/bias metrics<br/>ServiceMonitor: per-instance"]
            M_Ray["Ray Clusters<br/>Ray head dashboard metrics<br/>Port: 8265/TCP"]
            M_DSPAapi["DSPA API Server<br/>Pipeline execution metrics<br/>ServiceMonitor: per-DSPA"]
        end
    end

    subgraph HealthProbes["Health Probes"]
        direction TB

        subgraph ProbesOperators["Operator Health Probes"]
            H_rhods["rhods-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_KServe["KServe Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_Kueue["Kueue Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_ODHModel["odh-model-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_CodeFlare["CodeFlare Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_KubeRay["KubeRay Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_DSPO["DSPO Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_Training["Training Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_TrustyAI["TrustyAI Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_ModelReg["Model Registry Op<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_Feast["Feast Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_LlamaStack["LlamaStack Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
        end

        subgraph ProbesServices["Service Health Probes"]
            H_Dashboard["odh-dashboard<br/>L: :8080 healthz<br/>R: :8080 readyz"]
            H_ModelMesh["ModelMesh Serving<br/>L: :8080 healthz<br/>R: :8080 readyz"]
        end

        subgraph ProbesWorkloads["Workload Probes (User NS)"]
            H_ISVCpod["InferenceService Pods<br/>L: runtime-specific<br/>R: model-loaded check"]
            H_Notebook["Notebook Pods<br/>L: :8888 HTTP<br/>R: :8888 HTTP"]
            H_DSPApod["DSPA Components<br/>L: per-component<br/>R: per-component"]
        end
    end

    subgraph DistTracing["Distributed Tracing"]
        direction TB
        T_OTEL["OpenTelemetry Instrumentation<br/>OTLP/gRPC protocol"]
        T_KServe2["KServe Inference<br/>Request tracing"]
        T_Pipelines["Pipeline Execution<br/>Workflow step tracing"]
        T_llmd["llm-d EPP<br/>Routing decision tracing"]
    end

    subgraph Alerting["Alerting (PrometheusRules)"]
        direction TB
        A_Kueue["Kueue Alerts<br/>Queue depth, quota utilization,<br/>admission latency"]
        A_KServe2["KServe Alerts<br/>Inference latency, error rate,<br/>autoscaling events"]
        A_Platform["Platform Alerts<br/>Component health, webhook<br/>latency, leader election"]
    end

    %% Prometheus scraping
    Prometheus -->|scrapes| M_Kueue
    Prometheus -->|scrapes| M_Training
    Prometheus -->|scrapes| M_Dashboard
    Prometheus -->|scrapes| M_KServe
    Prometheus -->|scrapes| M_ODHModel
    Prometheus -->|scrapes| M_DSPO
    Prometheus -->|scrapes| M_CodeFlare
    Prometheus -->|scrapes| M_ModelMesh
    Prometheus -->|scrapes| M_ISVC
    Prometheus -->|scrapes| M_TrustyAI
    Prometheus -->|scrapes| M_Ray
    Prometheus -->|scrapes| M_DSPAapi

    %% Tracing flow
    T_KServe2 -->|OTLP/gRPC| OTELCollector
    T_Pipelines -->|OTLP/gRPC| OTELCollector
    T_llmd -->|OTLP/gRPC| OTELCollector
    OTELCollector -->|export| Tempo

    %% Alerting
    Prometheus -->|evaluates| A_Kueue
    Prometheus -->|evaluates| A_KServe2
    Prometheus -->|evaluates| A_Platform

    %% Styling
    classDef monitoring fill:#9b59b6,stroke:#6c3483,color:#fff
    classDef prom fill:#e8d5b7,stroke:#b8860b
    classDef promProtected fill:#f5cba7,stroke:#e67e22
    classDef promWorkload fill:#fadbd8,stroke:#e74c3c
    classDef probe fill:#d5e8d4,stroke:#82b366
    classDef probeWorkload fill:#abebc6,stroke:#27ae60
    classDef trace fill:#dae8fc,stroke:#6c8ebf
    classDef alert fill:#f9e79f,stroke:#f1c40f

    class Prometheus,Tempo,OTELCollector monitoring
    class M_Kueue,M_Training promProtected
    class M_Dashboard,M_KServe,M_ODHModel,M_DSPO,M_CodeFlare,M_ModelMesh prom
    class M_ISVC,M_TrustyAI,M_Ray,M_DSPAapi promWorkload
    class H_rhods,H_KServe,H_Kueue,H_ODHModel,H_CodeFlare,H_KubeRay,H_DSPO,H_Training,H_TrustyAI,H_ModelReg,H_Feast,H_LlamaStack,H_Dashboard,H_ModelMesh probe
    class H_ISVCpod,H_Notebook,H_DSPApod probeWorkload
    class T_OTEL,T_KServe2,T_Pipelines,T_llmd trace
    class A_Kueue,A_KServe2,A_Platform alert
