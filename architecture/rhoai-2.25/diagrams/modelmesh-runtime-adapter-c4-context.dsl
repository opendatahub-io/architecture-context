// C4 Context Diagram: modelmesh-runtime-adapter
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        modelMeshContainer = softwareSystem "ModelMesh" "Main ModelMesh container that orchestrates model serving lifecycle" "Internal RHOAI"

        // Primary System
        runtimeAdapter = softwareSystem "ModelMesh Runtime Adapter" "Multi-purpose sidecar providing model storage pulling and runtime-specific adapters" {
            puller = container "Model Serving Puller" "Intercepts ModelRuntime gRPC calls, pulls model artifacts from storage, forwards to adapter" "Go gRPC Server, Port 8084"
            pullmanLib = container "PullMan Library" "Pluggable storage provider framework for downloading model artifacts" "Go Library"
            tritonAdapter = container "Triton Adapter" "Adapts ModelRuntime API to NVIDIA Triton gRPC API" "Go gRPC Server, Port 8085"
            ovmsAdapter = container "OVMS Adapter" "Adapts ModelRuntime API to OpenVINO Model Server via config file management" "Go gRPC Server, Port 8085"
            mlserverAdapter = container "MLServer Adapter" "Adapts ModelRuntime API to Seldon MLServer gRPC API" "Go gRPC Server, Port 8085"
            torchserveAdapter = container "TorchServe Adapter" "Adapts ModelRuntime API to TorchServe Management/Inference APIs" "Go gRPC Server, Port 8085"
        }

        // Internal Dependencies
        modelMeshServing = softwareSystem "ModelMesh Serving Controller" "Configures and deploys runtime adapter as sidecar" "Internal RHOAI"

        // Model Runtimes (in same Pod)
        tritonRuntime = softwareSystem "NVIDIA Triton Inference Server" "Model serving runtime" "Internal Runtime"
        ovmsRuntime = softwareSystem "OpenVINO Model Server" "Model serving runtime" "Internal Runtime"
        mlserverRuntime = softwareSystem "Seldon MLServer" "Model serving runtime" "Internal Runtime"
        torchserveRuntime = softwareSystem "TorchServe" "Model serving runtime" "Internal Runtime"

        // External Storage
        s3Storage = softwareSystem "S3 / IBM COS" "S3-compatible object storage for model artifacts" "External Storage"
        gcsStorage = softwareSystem "Google Cloud Storage" "GCP object storage for model artifacts" "External Storage"
        azureStorage = softwareSystem "Azure Blob Storage" "Azure object storage for model artifacts" "External Storage"
        httpStorage = softwareSystem "HTTP/HTTPS Endpoints" "Model artifact download via HTTP" "External Storage"

        // Relationships
        modelMeshContainer -> runtimeAdapter "Sends ModelRuntime gRPC calls (loadModel, unloadModel, runtimeStatus)" "gRPC/8084 plaintext"
        modelMeshServing -> runtimeAdapter "Deploys and configures as sidecar" "Pod spec"

        // Internal container relationships
        puller -> pullmanLib "Uses for storage downloads"
        puller -> tritonAdapter "Forwards ModelRuntime calls" "gRPC/8085 plaintext"
        puller -> ovmsAdapter "Forwards ModelRuntime calls" "gRPC/8085 plaintext"
        puller -> mlserverAdapter "Forwards ModelRuntime calls" "gRPC/8085 plaintext"
        puller -> torchserveAdapter "Forwards ModelRuntime calls" "gRPC/8085 plaintext"

        // Adapter to runtime
        tritonAdapter -> tritonRuntime "Model load/unload/inference" "gRPC/8001 plaintext"
        ovmsAdapter -> ovmsRuntime "Config file management + status" "gRPC/8001 plaintext"
        mlserverAdapter -> mlserverRuntime "Model load/unload" "gRPC/8001 plaintext"
        torchserveAdapter -> torchserveRuntime "Management/Inference" "gRPC/7070-7071 plaintext"

        // Storage egress
        pullmanLib -> s3Storage "Downloads model artifacts" "HTTPS/443 TLS 1.2+ IAM/AccessKey"
        pullmanLib -> gcsStorage "Downloads model artifacts" "HTTPS/443 TLS 1.2+ GCP SA"
        pullmanLib -> azureStorage "Downloads model artifacts" "HTTPS/443 TLS 1.2+ Azure AD/SAS"
        pullmanLib -> httpStorage "Downloads model artifacts" "HTTP(S)/80-443"
    }

    views {
        systemContext runtimeAdapter "SystemContext" {
            include *
            autoLayout
        }

        container runtimeAdapter "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Internal RHOAI" {
                background #4a90e2
                color #ffffff
            }
            element "Internal Runtime" {
                background #f5a623
                color #ffffff
            }
            element "External Storage" {
                background #999999
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
