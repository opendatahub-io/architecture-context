graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)<br/>Port 8090/TCP"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>/{route_name}/v1/chat/completions"]
        TLSClient["HTTP/mTLS Client<br/>(reqwest + native-tls)"]
        FallbackLogic["Fallback Logic<br/>(Detection Response Handler)"]
        HeaderForwarder["Header Forwarder<br/>(Authorization + X-Forwarded-*)"]

        ConfigLoader -->|"loads routes<br/>& detectors"| RouteHandler
        RouteHandler -->|"injects detector config"| TLSClient
        TLSClient -->|"response"| FallbackLogic
        RouteHandler -->|"extracts"| HeaderForwarder
        HeaderForwarder -->|"forwards to"| TLSClient
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| RouteHandler
    FallbackLogic -->|"response<br/>(or fallback message)"| Client

    TLSClient -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"invokes"| Detectors["Guardrails Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -->|"forwards inference"| vLLM["vLLM / LLM Server"]

    ConfigFile["Gateway Config<br/>(YAML ConfigMap)"] -->|"GATEWAY_CONFIG env"| ConfigLoader

    subgraph "TLS Certificates (Volume Mounts)"
        TLSCert["/etc/tls/private/tls.crt"]
        TLSKey["/etc/tls/private/tls.key"]
        CACert["/etc/tls/ca/service-ca.crt"]
    end

    TLSCert -->|"client cert"| TLSClient
    TLSKey -->|"private key"| TLSClient
    CACert -->|"CA validation"| TLSClient

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style TLSClient fill:#4a90e2,stroke:#333,color:#fff
    style FallbackLogic fill:#4a90e2,stroke:#333,color:#fff
    style HeaderForwarder fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style Detectors fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style ConfigFile fill:#f5a623,stroke:#333
    style TLSCert fill:#f5a623,stroke:#333
    style TLSKey fill:#f5a623,stroke:#333
    style CACert fill:#f5a623,stroke:#333
