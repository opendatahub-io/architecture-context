graph TB
    subgraph FeastOperator["Feast Operator (Control Plane)"]
        Controller["feast-operator<br/>Go Operator<br/>(controller-runtime)"]
        Controller -->|"health: 8081/TCP"| HealthProbe["Health Probes<br/>/healthz, /readyz"]
        Controller -->|"metrics: 8443/TCP"| Metrics["Metrics Server<br/>/metrics (HTTPS)"]
    end

    subgraph FeatureServerStack["Feature Server Stack (Data Plane)"]
        direction TB
        OnlineServer["feature-server (online)<br/>Python FastAPI<br/>Port: 6566/TCP"]
        OfflineServer["feature-server (offline)<br/>Python FastAPI<br/>Port: 8815/TCP"]
        RegistryServer["feature-server (registry)<br/>Python FastAPI<br/>Port: 6570/TCP"]
        UIServer["feast-ui<br/>React/TypeScript<br/>Port: 8888/TCP"]
        GoServer["go-feature-server<br/>Go (embedded)<br/>gRPC/HTTP: 6566/TCP"]
    end

    User["Data Scientist / ML App"] -->|"creates"| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1alpha1)"]
    FeatureStoreCR -->|"watched by"| Controller

    Controller -->|"creates/manages"| Deployment["Deployments"]
    Controller -->|"creates/manages"| Service["Services"]
    Controller -->|"creates/manages"| ConfigMap["ConfigMaps"]
    Controller -->|"creates/manages"| PVC["PVCs"]
    Controller -->|"creates/manages"| RBAC["Roles & RoleBindings"]
    Controller -->|"creates/manages"| CronJob["CronJobs<br/>(materialization)"]
    Controller -->|"creates/manages"| Route["OpenShift Routes"]

    Deployment --> OnlineServer
    Deployment --> OfflineServer
    Deployment --> RegistryServer
    Deployment --> UIServer

    CronJob -->|"kubectl exec"| OnlineServer

    subgraph ExternalStores["External Stores"]
        Redis["Redis<br/>6379/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        DynamoDB["AWS DynamoDB<br/>443/TCP"]
    end

    subgraph ExternalStorage["External Storage"]
        S3["AWS S3<br/>443/TCP"]
        GCS["Google Cloud Storage<br/>443/TCP"]
    end

    OnlineServer -->|"read/write features"| Redis
    OnlineServer -->|"read/write features"| PostgreSQL
    OnlineServer -->|"read/write features"| DynamoDB
    RegistryServer -->|"registry storage"| S3
    RegistryServer -->|"registry storage"| GCS
    OfflineServer -->|"offline store"| PostgreSQL

    Controller -->|"API calls"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    subgraph PlatformIntegration["Platform Integration"]
        ServingCerts["OpenShift Service<br/>Serving Certs"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
        NamespaceRegistry["Feast Namespace<br/>Registry ConfigMap"]
    end

    Controller -->|"TLS provisioning"| ServingCerts
    Controller -->|"CA trust"| CABundle
    Controller -->|"cross-namespace discovery"| NamespaceRegistry

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style OnlineServer fill:#4a90e2,stroke:#333,color:#fff
    style OfflineServer fill:#4a90e2,stroke:#333,color:#fff
    style RegistryServer fill:#4a90e2,stroke:#333,color:#fff
    style UIServer fill:#4a90e2,stroke:#333,color:#fff
    style GoServer fill:#4a90e2,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#333
    style Redis fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style DynamoDB fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ServingCerts fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333
    style NamespaceRegistry fill:#7ed321,stroke:#333
