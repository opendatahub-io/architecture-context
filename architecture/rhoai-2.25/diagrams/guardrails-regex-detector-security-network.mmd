graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph GuardrailsNS["Namespace: guardrails"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Role: Content Router"]
            RegexDetector["Regex Detector Service<br/>ClusterIP 8080/TCP<br/>HTTP Plaintext<br/>No Auth<br/>Image: guardrails-regex-detector<br/>Runtime: Rust/Axum<br/>Base: ubi9/ubi-minimal"]
        end
    end

    subgraph Endpoints["Exposed Endpoints"]
        Health["GET /health<br/>Auth: None<br/>Purpose: Health check"]
        Detection["POST /api/v1/text/contents<br/>Auth: None<br/>Purpose: PII/pattern detection"]
    end

    subgraph SecurityNotes["Security Posture"]
        NoTLS["No TLS<br/>Plaintext HTTP only"]
        NoAuth["No Authentication<br/>No Authorization"]
        NoCrypto["No Crypto Operations<br/>Pure regex processing"]
        NetworkIsolation["Security: Network-level<br/>isolation only<br/>(pod-to-pod in cluster)"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>Plaintext<br/>No Auth<br/>No Encryption"| RegexDetector
    RegexDetector -->|"HTTP Response<br/>Plaintext<br/>Detection Results"| Orchestrator

    RegexDetector --- Health
    RegexDetector --- Detection

    %% Styling
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef endpoint fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Orchestrator cluster
    class RegexDetector service
    class Health,Detection endpoint
    class NoTLS,NoAuth,NoCrypto,NetworkIsolation security
