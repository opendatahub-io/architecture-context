graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: opendatahub / redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard]
        CRB2[odh-dashboard-image-puller]
        CRB3[odh-dashboard-auth-delegator]
        CRB4[odh-dashboard-monitoring]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard ClusterRole]
        CR_Aggregate1[aggregate-hardware-profiles-permissions]
        CR_Aggregate2[aggregate-accelerator-profiles-permissions]
        CR_ImagePuller[system:image-puller]
        CR_AuthDelegator[system:auth-delegator]
        CR_Monitoring[cluster-monitoring-view]
    end

    subgraph "Storage Resources"
        StorageClass[storage.k8s.io<br/>storageclasses<br/>update, patch]
    end

    subgraph "Core Resources"
        Nodes[core<br/>nodes<br/>get, list]
        ConfigMaps[core<br/>configmaps<br/>create, delete, get, list, patch, update, watch]
        PVCs[core<br/>persistentvolumeclaims<br/>create, delete, get, list, patch, update, watch]
        Secrets[core<br/>secrets<br/>create, delete, get, list, patch, update, watch]
        Pods[core<br/>pods<br/>get, list, watch]
        ServiceAccounts[core<br/>serviceaccounts<br/>get, list, watch]
        Services[core<br/>services<br/>get, list, watch]
        Namespaces[core<br/>namespaces<br/>patch]
        Endpoints[core<br/>endpoints<br/>get]
        Events[events.k8s.io<br/>events<br/>get, list, watch]
    end

    subgraph "Machine Resources"
        MachineAutoscalers[machine.openshift.io<br/>autoscaling.openshift.io<br/>machineautoscalers, machinesets<br/>get, list]
    end

    subgraph "OpenShift Config"
        ClusterVersions[config.openshift.io<br/>clusterversions<br/>get, watch, list]
        CSVs[operators.coreos.com<br/>clusterserviceversions, subscriptions<br/>get, list, watch]
        ImageStreams[image.openshift.io<br/>imagestreams/layers<br/>get]
        Routes[route.openshift.io<br/>routes<br/>get, list, watch]
        ConsoleLinks[console.openshift.io<br/>consolelinks<br/>get, list, watch]
        Consoles[operator.openshift.io<br/>consoles<br/>get, list, watch]
        RHMIS[integreatly.org<br/>rhmis<br/>get, watch, list]
    end

    subgraph "User Management"
        Users[user.openshift.io<br/>groups, users<br/>get, list, watch]
    end

    subgraph "RBAC Resources"
        RoleBindings[rbac.authorization.k8s.io<br/>rolebindings, clusterrolebindings, roles<br/>list, get, create, patch, delete]
    end

    subgraph "Kubeflow Resources"
        Notebooks[kubeflow.org<br/>notebooks<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "ODH Platform Resources"
        DataScienceClusters[datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>list, watch, get]
        DSCInitializations[dscinitialization.opendatahub.io<br/>dscinitializations<br/>list, watch, get]
        HardwareProfiles[infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get, list, watch]
        AcceleratorProfiles[dashboard.opendatahub.io<br/>acceleratorprofiles<br/>get, list, watch]
        Auths[services.platform.opendatahub.io<br/>auths<br/>get]
    end

    subgraph "Model Serving Resources"
        InferenceServices[serving.kserve.io<br/>inferenceservices<br/>get, list, watch]
        ModelRegistries[modelregistry.opendatahub.io<br/>modelregistries<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "LLM Resources"
        LlamaStackDists[llamastack.io<br/>llamastackdistributions<br/>get, list, watch]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| CR_ImagePuller
    CRB3 -->|grants| CR_AuthDelegator
    CRB4 -->|grants| CR_Monitoring

    %% ClusterRole to Storage Resources
    CR -->|update, patch| StorageClass

    %% ClusterRole to Core Resources
    CR -->|get, list| Nodes
    CR -->|create, delete, get, list, patch, update, watch| ConfigMaps
    CR -->|create, delete, get, list, patch, update, watch| PVCs
    CR -->|create, delete, get, list, patch, update, watch| Secrets
    CR -->|get, list, watch| Pods
    CR -->|get, list, watch| ServiceAccounts
    CR -->|get, list, watch| Services
    CR -->|patch| Namespaces
    CR -->|get| Endpoints
    CR -->|get, list, watch| Events

    %% ClusterRole to Machine Resources
    CR -->|get, list| MachineAutoscalers

    %% ClusterRole to OpenShift Config
    CR -->|get, watch, list| ClusterVersions
    CR -->|get, list, watch| CSVs
    CR -->|get| ImageStreams
    CR -->|get, list, watch| Routes
    CR -->|get, list, watch| ConsoleLinks
    CR -->|get, list, watch| Consoles
    CR -->|get, watch, list| RHMIS

    %% ClusterRole to User Management
    CR -->|get, list, watch| Users

    %% ClusterRole to RBAC
    CR -->|list, get, create, patch, delete| RoleBindings

    %% ClusterRole to Kubeflow
    CR -->|get, list, watch, create, update, patch, delete| Notebooks

    %% ClusterRole to ODH Platform
    CR -->|list, watch, get| DataScienceClusters
    CR -->|list, watch, get| DSCInitializations
    CR_Aggregate1 -->|get, list, watch| HardwareProfiles
    CR_Aggregate2 -->|get, list, watch| AcceleratorProfiles
    CR -->|get| Auths

    %% ClusterRole to Model Serving
    CR -->|get, list, watch| InferenceServices
    CR -->|get, list, watch, create, update, patch, delete| ModelRegistries

    %% ClusterRole to LLM
    CR -->|get, list, watch| LlamaStackDists

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CRB1 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB2 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB4 fill:#e8e8e8,stroke:#333,stroke-width:1px

