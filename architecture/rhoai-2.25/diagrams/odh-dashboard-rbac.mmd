graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Dashboard["odh-dashboard<br/>(Namespace: redhat-ods-applications)"]
        SA_Authenticated["system:authenticated<br/>(All authenticated users)"]
        SA_AllSAs["system:serviceaccounts<br/>(All service accounts)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Dashboard["odh-dashboard<br/>(ClusterRoleBinding)"]
        CRB_Monitoring["odh-dashboard-monitoring<br/>(ClusterRoleBinding)"]
        CRB_AuthDelegator["odh-dashboard-auth-delegator<br/>(ClusterRoleBinding)"]
        CRB_ImagePullers["cluster-image-pullers<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["RoleBindings (application-ns)"]
        RB_Dashboard["odh-dashboard<br/>(RoleBinding)"]
        RB_Accelerators["accelerators<br/>(RoleBinding)"]
        RB_Builds["builds-and-images<br/>(RoleBinding)"]
        RB_Hardware["hardware-profile-role-binding<br/>(RoleBinding)"]
        RB_NIM["nim-account-access-binding<br/>(RoleBinding)"]
        RB_ServingRT["servingruntimes-config-updater<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Dashboard["odh-dashboard<br/>(ClusterRole)"]
        CR_Monitoring["cluster-monitoring-view<br/>(ClusterRole)"]
        CR_AuthDeleg["system:auth-delegator<br/>(ClusterRole)"]
        CR_ImagePull["system:image-puller<br/>(ClusterRole)"]
        CR_DSG["dsg-cluster-roles<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (application-ns)"]
        R_Dashboard["odh-dashboard<br/>(Role)"]
        R_Accelerators["fetch-accelerators-role<br/>(Role)"]
        R_Hardware["fetch-hardware-profiles-role<br/>(Role)"]
        R_NIM["nim-account-access<br/>(Role)"]
        R_ServingRT["servingruntimes-config-updater<br/>(Role)"]
    end

    subgraph Resources_ReadWrite["Resources (Read/Write)"]
        RW_ConfigMaps["configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        RW_Secrets["secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        RW_PVCs["persistentvolumeclaims<br/>create,delete,get,list,<br/>patch,update,watch"]
        RW_Notebooks["kubeflow.org/notebooks<br/>get,list,watch,create,<br/>update,patch,delete"]
        RW_ModelReg["modelregistry.opendatahub.io<br/>get,list,watch,create,<br/>update,patch,delete"]
        RW_RBAC["rbac.authorization.k8s.io<br/>rolebindings,roles<br/>list,get,create,patch,delete"]
        RW_StorageClass["storageclasses<br/>update,patch"]
        RW_Namespaces["namespaces<br/>patch"]
    end

    subgraph Resources_ReadOnly["Resources (Read-Only)"]
        RO_Nodes["nodes<br/>get,list"]
        RO_Machines["machineautoscalers,machinesets<br/>get,list"]
        RO_ClusterVer["clusterversions<br/>get,watch,list"]
        RO_CSV["clusterserviceversions,<br/>subscriptions<br/>get,list,watch"]
        RO_Users["users,groups<br/>get,list,watch"]
        RO_Pods["pods,serviceaccounts,services<br/>get,list,watch"]
        RO_Events["events<br/>get,list,watch"]
        RO_Routes["routes<br/>get,list,watch"]
        RO_ConsoleLinks["consolelinks<br/>get,list,watch"]
        RO_InferSvc["inferenceservices<br/>get,list,watch"]
        RO_DSC["datascienceclusters<br/>list,watch,get"]
        RO_DSCI["dscinitializations<br/>list,watch,get"]
        RO_LlamaStack["llamastackdistributions<br/>get,list,watch"]
        RO_Images["imagestreams,imagestreams/layers<br/>get,list,watch"]
        RO_Builds["builds,buildconfigs<br/>get,list,watch"]
    end

    %% SA to ClusterRoleBinding connections
    SA_Dashboard -->|bound via| CRB_Dashboard
    SA_Dashboard -->|bound via| CRB_Monitoring
    SA_Dashboard -->|bound via| CRB_AuthDelegator
    SA_AllSAs -->|bound via| CRB_ImagePullers

    %% SA to RoleBinding connections
    SA_Dashboard -->|bound via| RB_Dashboard
    SA_Authenticated -->|bound via| RB_Accelerators
    SA_Authenticated -->|bound via| RB_Builds
    SA_Authenticated -->|bound via| RB_Hardware
    SA_Authenticated -->|bound via| RB_NIM
    SA_Authenticated -->|bound via| RB_ServingRT

    %% ClusterRoleBinding to ClusterRole
    CRB_Dashboard -->|grants| CR_Dashboard
    CRB_Monitoring -->|grants| CR_Monitoring
    CRB_AuthDelegator -->|grants| CR_AuthDeleg
    CRB_ImagePullers -->|grants| CR_ImagePull

    %% RoleBinding to Role/ClusterRole
    RB_Dashboard -->|grants| R_Dashboard
    RB_Accelerators -->|grants| R_Accelerators
    RB_Builds -->|grants| CR_DSG
    RB_Hardware -->|grants| R_Hardware
    RB_NIM -->|grants| R_NIM
    RB_ServingRT -->|grants| R_ServingRT

    %% ClusterRole to Resources (Read/Write)
    CR_Dashboard -->|read/write| RW_ConfigMaps
    CR_Dashboard -->|read/write| RW_Secrets
    CR_Dashboard -->|read/write| RW_PVCs
    CR_Dashboard -->|read/write| RW_Notebooks
    CR_Dashboard -->|read/write| RW_ModelReg
    CR_Dashboard -->|read/write| RW_RBAC
    CR_Dashboard -->|write| RW_StorageClass
    CR_Dashboard -->|write| RW_Namespaces

    %% ClusterRole to Resources (Read-Only)
    CR_Dashboard -->|read-only| RO_Nodes
    CR_Dashboard -->|read-only| RO_Machines
    CR_Dashboard -->|read-only| RO_ClusterVer
    CR_Dashboard -->|read-only| RO_CSV
    CR_Dashboard -->|read-only| RO_Users
    CR_Dashboard -->|read-only| RO_Pods
    CR_Dashboard -->|read-only| RO_Events
    CR_Dashboard -->|read-only| RO_Routes
    CR_Dashboard -->|read-only| RO_ConsoleLinks
    CR_Dashboard -->|read-only| RO_InferSvc
    CR_Dashboard -->|read-only| RO_DSC
    CR_Dashboard -->|read-only| RO_DSCI
    CR_Dashboard -->|read-only| RO_LlamaStack

    %% DSG ClusterRole to Resources
    CR_DSG -->|read-only| RO_Images
    CR_DSG -->|read-only| RO_Builds

    %% Styling
    style SA_Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style SA_Authenticated fill:#4a90e2,stroke:#333,color:#fff
    style SA_AllSAs fill:#4a90e2,stroke:#333,color:#fff

    style CR_Dashboard fill:#f5a623,stroke:#333
    style CR_Monitoring fill:#f5a623,stroke:#333
    style CR_AuthDeleg fill:#f5a623,stroke:#333
    style CR_ImagePull fill:#f5a623,stroke:#333
    style CR_DSG fill:#f5a623,stroke:#333

    style R_Dashboard fill:#e8a838,stroke:#333
    style R_Accelerators fill:#e8a838,stroke:#333
    style R_Hardware fill:#e8a838,stroke:#333
    style R_NIM fill:#e8a838,stroke:#333
    style R_ServingRT fill:#e8a838,stroke:#333

    style RW_ConfigMaps fill:#f8cecc,stroke:#b85450
    style RW_Secrets fill:#f8cecc,stroke:#b85450
    style RW_PVCs fill:#f8cecc,stroke:#b85450
    style RW_Notebooks fill:#f8cecc,stroke:#b85450
    style RW_ModelReg fill:#f8cecc,stroke:#b85450
    style RW_RBAC fill:#f8cecc,stroke:#b85450
    style RW_StorageClass fill:#f8cecc,stroke:#b85450
    style RW_Namespaces fill:#f8cecc,stroke:#b85450

