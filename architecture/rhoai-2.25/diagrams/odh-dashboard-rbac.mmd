    style RO_Machines fill:#d5e8d4,stroke:#82b366
    style RO_ClusterVer fill:#d5e8d4,stroke:#82b366
    style RO_CSV fill:#d5e8d4,stroke:#82b366
    style RO_Users fill:#d5e8d4,stroke:#82b366
    style RO_Pods fill:#d5e8d4,stroke:#82b366
    style RO_Events fill:#d5e8d4,stroke:#82b366
    style RO_Routes fill:#d5e8d4,stroke:#82b366
    style RO_ConsoleLinks fill:#d5e8d4,stroke:#82b366
    style RO_InferSvc fill:#d5e8d4,stroke:#82b366
    style RO_DSC fill:#d5e8d4,stroke:#82b366
    style RO_DSCI fill:#d5e8d4,stroke:#82b366
    style RO_LlamaStack fill:#d5e8d4,stroke:#82b366
