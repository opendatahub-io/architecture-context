    style CR_Aggregate1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_Aggregate2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_ImagePuller fill:#999,stroke:#333,stroke-width:1px,color:#fff
    style CR_AuthDelegator fill:#999,stroke:#333,stroke-width:1px,color:#fff
    style CR_Monitoring fill:#999,stroke:#333,stroke-width:1px,color:#fff

