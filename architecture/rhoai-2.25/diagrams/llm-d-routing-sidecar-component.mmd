graph TB
    subgraph External["External Clients"]
        Client["Client<br/>(Gateway / EPP)"]
    end

    subgraph Sidecar["llm-d-routing-sidecar (Port 8000)"]
        direction TB
        ProxyServer["Proxy Server<br/>Go HTTP/TLS Server<br/>8000/TCP"]

        subgraph Routing["Request Routing"]
            ChatHandler["/v1/chat/completions<br/>Handler"]
            CompHandler["/v1/completions<br/>Handler"]
            HealthHandler["/health<br/>Handler"]
            CatchAll["/* Catch-All<br/>Passthrough"]
        end

        subgraph Connectors["P/D Connector Protocols"]
            NIXLv2["NIXL v2 Connector<br/>(current)"]
            NIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            LMCache["LMCache Connector<br/>(deprecated)"]
        end

        subgraph Security["Security"]
            AllowlistValidator["Allowlist Validator<br/>SSRF Protection"]
            TLSConfig["TLS Configuration<br/>TLS 1.2+ / AES-GCM<br/>CHACHA20-POLY1305"]
        end

        ProxyCache["Prefiller Proxy Cache<br/>LRU (max 16 entries)"]
    end

    subgraph LocalPod["Local Pod"]
        Decoder["vLLM Decoder<br/>8001/TCP"]
    end

    subgraph RemotePods["Remote Pods"]
        Prefiller1["vLLM Prefiller Pod 1"]
        Prefiller2["vLLM Prefiller Pod 2"]
        PrefillerN["vLLM Prefiller Pod N"]
    end

    subgraph K8sControl["Kubernetes Control Plane"]
        APIServer["Kubernetes API Server<br/>443/TCP"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        Pods["Pod Resources"]
    end

    %% Client to Proxy
    Client -->|"HTTPS/8000<br/>TLS 1.2+"| ProxyServer

    %% Proxy routing
    ProxyServer --> ChatHandler
    ProxyServer --> CompHandler
    ProxyServer --> HealthHandler
    ProxyServer --> CatchAll

    %% SSRF validation
    ChatHandler -->|"validate prefiller<br/>target"| AllowlistValidator
    CompHandler -->|"validate prefiller<br/>target"| AllowlistValidator

    %% Connector selection (at startup)
    ChatHandler --> NIXLv2
    CompHandler --> NIXLv2

    %% Prefiller routing
    NIXLv2 -->|"uses cached proxy"| ProxyCache
    ProxyCache -->|"HTTP(S)/dynamic port<br/>x-prefiller-host-port"| Prefiller1
    ProxyCache -.-> Prefiller2
    ProxyCache -.-> PrefillerN

    %% Decoder routing
    NIXLv2 -->|"HTTP(S)/8001<br/>with kv_transfer_params"| Decoder
    CatchAll -->|"HTTP(S)/8001<br/>passthrough"| Decoder

    %% SSRF allowlist watches
    AllowlistValidator -->|"watch"| APIServer
    APIServer --> InferencePool
    APIServer --> Pods

    %% Styling
    style ProxyServer fill:#4a90e2,stroke:#333,color:#fff
    style NIXLv2 fill:#4a90e2,stroke:#333,color:#fff
    style NIXLv1 fill:#999,stroke:#333,color:#fff
    style LMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#e74c3c,stroke:#333,color:#fff
    style TLSConfig fill:#e74c3c,stroke:#333,color:#fff
    style Decoder fill:#7ed321,stroke:#333
    style Prefiller1 fill:#f5a623,stroke:#333
    style Prefiller2 fill:#f5a623,stroke:#333
    style PrefillerN fill:#f5a623,stroke:#333
    style ProxyCache fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style APIServer fill:#e8e8e8,stroke:#333
    style InferencePool fill:#e8e8e8,stroke:#333
    style Pods fill:#e8e8e8,stroke:#333
    style ChatHandler fill:#5dade2,stroke:#333,color:#fff
    style CompHandler fill:#5dade2,stroke:#333,color:#fff
    style HealthHandler fill:#5dade2,stroke:#333,color:#fff
    style CatchAll fill:#5dade2,stroke:#333,color:#fff
