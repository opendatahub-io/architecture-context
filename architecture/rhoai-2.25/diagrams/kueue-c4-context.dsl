/*
 * Kueue C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/kueue.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits ML training jobs and batch workloads to Kubernetes"

        kueue = softwareSystem "Kueue" "Kubernetes-native job queueing system that manages workload admission based on quota and resource availability" {
            controllerManager = container "Kueue Controller Manager" "Main controller managing ClusterQueues, LocalQueues, Workloads, ResourceFlavors, Cohorts, AdmissionChecks, and Topologies" "Go Operator (controller-runtime v0.19.4)"
            scheduler = container "Scheduler" "Core scheduling engine that admits Workloads to ClusterQueues based on quotas, fair sharing, and priorities" "Go Component"
            webhookServer = container "Webhook Server" "Mutating and validating admission webhooks for Kueue CRDs and integrated job types" "HTTPS/9443"
            internalCertManager = container "Internal Cert Manager" "Self-managed TLS certificate rotation for webhook and metrics endpoints" "Go Component"
            jobFrameworkControllers = container "Job Framework Controllers" "Per-integration controllers for batch/Job, Kubeflow jobs, Ray jobs, JobSet, AppWrapper, and more" "Go Controllers"
        }

        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (OpenShift 4.16-4.20)" "External" {
            apiServer = container "API Server" "Kubernetes API server handling all cluster operations" "HTTPS/6443"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages RHOAI components via kustomize overlays" "Internal RHOAI"

        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages AppWrapper CRDs for distributed workload orchestration" "Internal RHOAI"
        kubeflowTraining = softwareSystem "Kubeflow Training Operator" "Manages PyTorchJob, TFJob, MPIJob, PaddleJob, XGBoostJob CRDs" "Internal RHOAI"
        kuberayOperator = softwareSystem "KubeRay Operator" "Manages RayJob and RayCluster CRDs" "Internal RHOAI"

        prometheus = softwareSystem "Prometheus (OpenShift Monitoring)" "Metrics collection and alerting platform" "External"

        /* Relationships */
        user -> kubernetes "Submits jobs via kubectl" "HTTPS/6443"
        kubernetes -> kueue "Calls admission webhooks" "HTTPS/443->9443"
        kueue -> kubernetes "CRUD on CRDs, Jobs, Pods" "HTTPS/443, SA token"

        rhodsOperator -> kueue "Deploys via kustomize overlay"

        codeflareOperator -> kueue "Provides AppWrapper CRD" "CRD watch + webhook"
        kubeflowTraining -> kueue "Provides training job CRDs" "CRD watch + webhook"
        kuberayOperator -> kueue "Provides Ray CRDs" "CRD watch + webhook"

        prometheus -> kueue "Scrapes metrics" "HTTPS/8443, Bearer Token"

        /* Internal relationships */
        controllerManager -> scheduler "Submits workloads for scheduling"
        scheduler -> controllerManager "Returns admission decisions"
        controllerManager -> webhookServer "Serves admission requests"
        internalCertManager -> webhookServer "Provides TLS certificates"
        jobFrameworkControllers -> controllerManager "Creates Workload CRs for managed jobs"
    }

    views {
        systemContext kueue "SystemContext" {
            include *
            autoLayout
        }

        container kueue "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
