graph TB
    subgraph "RHOAI Platform 2.25"
        subgraph "Platform Orchestration"
            RHODS[rhods-operator<br/>Platform Orchestrator]
            DSC[DataScienceCluster CR]
            DSCI[DSCInitialization CR]
        end

        subgraph "User Interface & Management"
            Dashboard[odh-dashboard<br/>Web UI]
            Prometheus[Prometheus<br/>Monitoring]
        end

        subgraph "Model Serving Layer"
            KServe[kserve<br/>Serverless Serving]
            ModelMesh[modelmesh-serving<br/>Multi-Model Serving]
            ModelController[odh-model-controller<br/>OpenShift Integration]
            ModelRegistry[model-registry<br/>Model Metadata]
        end

        subgraph "ML Development & Training"
            Notebooks[notebook-controller<br/>Interactive Workbenches]
            Training[training-operator<br/>Distributed Training]
            Pipelines[data-science-pipelines<br/>ML Workflows]
        end

        subgraph "Distributed Computing"
            CodeFlare[codeflare-operator<br/>Workload Orchestration]
            KubeRay[kuberay<br/>Ray Clusters]
            Kueue[kueue<br/>Job Queueing]
        end

        subgraph "AI Safety & Features"
            TrustyAI[trustyai-operator<br/>Explainability & Guardrails]
            Feast[feast-operator<br/>Feature Store]
        end

        subgraph "LLM Serving"
            LlamaStack[llama-stack-operator<br/>LLM Inference]
        end
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh<br/>mTLS, Traffic Mgmt]
        Knative[Knative Serving<br/>Autoscaling]
        S3[S3 Storage<br/>Model Artifacts]
        OAuth[OpenShift OAuth<br/>Authentication]
        K8sAPI[Kubernetes API<br/>Resource Management]
    end

    %% Platform orchestration
    DSC -->|manages| RHODS
    DSCI -->|configures| RHODS
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| KServe
    RHODS -->|deploys| ModelMesh
    RHODS -->|deploys| ModelController
    RHODS -->|deploys| Notebooks
    RHODS -->|deploys| Training
    RHODS -->|deploys| Pipelines
    RHODS -->|deploys| CodeFlare
    RHODS -->|deploys| KubeRay
    RHODS -->|deploys| Kueue
    RHODS -->|deploys| TrustyAI
    RHODS -->|deploys| Feast
    RHODS -->|deploys| LlamaStack
    RHODS -->|deploys| ModelRegistry

    %% Dashboard integrations
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| ModelRegistry
    Dashboard -->|creates| Notebooks
    Dashboard -->|manages| Pipelines
    Dashboard -->|queries| Prometheus

    %% Model serving integrations
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    KServe -->|extended by| ModelController
    KServe -->|loads from| S3
    KServe -.->|optional| ModelRegistry
    ModelMesh -->|loads from| S3
    ModelController -->|creates Routes| K8sAPI
    ModelController -->|creates VirtualServices| Istio

    %% Training & Pipelines
    Training -->|saves to| S3
    Training -.->|registers| ModelRegistry
    Pipelines -->|stores artifacts| S3
    Pipelines -->|deploys via| KServe
    Pipelines -->|registers| ModelRegistry
    Notebooks -->|submits| Training
    Notebooks -->|submits| KServe
    Notebooks -->|accesses| S3

    %% Distributed computing
    CodeFlare -->|manages| KubeRay
    CodeFlare -->|queues via| Kueue
    Kueue -->|admits| Training
    Kueue -->|admits| TrustyAI
    KubeRay -->|accesses| S3

    %% AI Safety
    TrustyAI -->|monitors| KServe
    TrustyAI -->|monitors| ModelMesh
    TrustyAI -->|queues via| Kueue

    %% Feature store
    Feast -->|serves features| KServe
    Feast -->|serves features| Training

    %% Authentication
    Dashboard -->|authenticates via| OAuth
    ModelRegistry -->|authenticates via| OAuth
    Pipelines -->|authenticates via| OAuth
    Notebooks -->|authenticates via| OAuth

    %% Common dependencies
    RHODS -->|manages via| K8sAPI
    Dashboard -->|API calls| K8sAPI
    KServe -->|API calls| K8sAPI
    Training -->|API calls| K8sAPI

    %% Styling
    style RHODS fill:#e74c3c,stroke:#c0392b,stroke-width:3px,color:#fff
    style Dashboard fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style KServe fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style ModelMesh fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style ModelController fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style Notebooks fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff
    style Training fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff
    style Pipelines fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff
    style CodeFlare fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style KubeRay fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style Kueue fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style TrustyAI fill:#27ae60,stroke:#1e8449,stroke-width:2px,color:#fff
    style Feast fill:#27ae60,stroke:#1e8449,stroke-width:2px,color:#fff
    style LlamaStack fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style ModelRegistry fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff

    style Istio fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style Knative fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style S3 fill:#f8c471,stroke:#f39c12,stroke-width:2px
    style OAuth fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style K8sAPI fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
