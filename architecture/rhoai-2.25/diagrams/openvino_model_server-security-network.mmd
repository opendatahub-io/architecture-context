graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist / Application"]
    end

    subgraph AuthLayer["AUTH PROXY LAYER (TLS Termination)"]
        AuthProxy["kube-rbac-proxy (RHOAI 3.x)<br/>oauth-proxy (RHOAI 2.x)<br/>8443/TCP<br/>TLS termination<br/>AuthN: SubjectAccessReview / OAuth"]
    end

    subgraph OVMSPod["OVMS POD (No Auth, No TLS)"]
        direction TB

        subgraph RESTListener["REST Listener"]
            REST["OVMS REST Server<br/>rest_port/TCP<br/>HTTP (plaintext)<br/>No Auth"]
        end

        subgraph gRPCListener["gRPC Listener"]
            GRPC["OVMS gRPC Server<br/>grpc_port/TCP<br/>gRPC (InsecureCredentials)<br/>No Auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure Connection String"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP Credentials"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+ (CURLSSLOPT_NATIVE_CA)<br/>HF Token (optional)"]
        ToolEndpoints["External Tool Endpoints<br/>Configurable Port HTTPS<br/>TLS (native CA)<br/>Bearer Token"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS (platform-managed)<br/>Bearer Token / OAuth"| AuthProxy
    AuthProxy -->|"HTTP rest_port (plaintext)<br/>Pod-local loopback<br/>Pre-authenticated"| REST
    AuthProxy -->|"gRPC grpc_port (plaintext)<br/>Pod-local loopback<br/>Pre-authenticated"| GRPC

    %% Egress flows
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Creds"| Azure
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP Creds"| GCS
    REST -->|"HTTPS/443<br/>TLS 1.2+ (git/curl)<br/>HF Token"| HFHub
    REST -->|"HTTPS/Configurable<br/>TLS (native CA)<br/>Bearer Token"| ToolEndpoints

    %% Monitoring
    Prometheus -->|"HTTP rest_port<br/>Plaintext<br/>No Auth<br/>GET /metrics"| REST

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authproxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef ovms fill:#ffcccc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class AuthProxy authproxy
    class REST,GRPC ovms
    class S3,Azure,GCS,HFHub,ToolEndpoints externalservice
    class Prometheus monitoring
