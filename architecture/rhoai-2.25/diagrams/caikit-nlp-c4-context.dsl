/*
 * C4 Context Diagram for caikit-nlp
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/caikit-nlp.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys and queries NLP models for text generation, embedding, and classification"
        mlEngineer = person "ML Engineer" "Configures model serving runtimes and fine-tuning jobs"

        caikitNlp = softwareSystem "caikit-nlp" "Python NLP library providing text generation, embedding, reranking, classification, and tokenization modules via Caikit AI framework" {
            httpServer = container "Caikit HTTP Server" "Serves NLP task endpoints via REST API on port 8080" "Python / FastAPI" "Service"
            grpcServer = container "Caikit gRPC Server" "Serves NLP task endpoints via gRPC on port 8085" "Python / grpcio" "Service"
            textGenModules = container "Text Generation Modules" "PeftPromptTuning, TextGeneration, TextGenerationTGIS - local and remote text generation" "Python / HuggingFace / PEFT"
            embeddingModules = container "Embedding & Reranking Modules" "EmbeddingModule, CrossEncoderModule - sentence embedding and reranking" "Python / sentence-transformers"
            classificationModules = container "Classification Modules" "SequenceClassification, FilteredSpanClassification - text and token classification" "Python / HuggingFace"
            tgisClient = container "TGIS Generation Client" "gRPC client for remote LLM inference via TGIS backend" "Python / grpcio"
            modelResources = container "Model Resources" "HFAutoCausalLM, HFAutoSeq2SeqLM, HFAutoSequenceClassifier - HuggingFace model wrappers" "Python / transformers"
        }

        tgis = softwareSystem "TGIS (caikit-tgis-serving)" "Text Generation Inference Server providing remote LLM inference" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving platform that orchestrates caikit-nlp container deployments" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Multi-model serving platform for efficient model hosting" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact storage and metadata retrieval" "Internal RHOAI"
        huggingFaceHub = softwareSystem "HuggingFace Hub" "Public model repository for downloading pretrained models" "External"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic management, and auth enforcement" "External"

        # Person interactions
        dataScientist -> caikitNlp "Sends inference requests (text generation, embedding, reranking)" "HTTP/gRPC"
        mlEngineer -> kserve "Deploys InferenceService with caikit-nlp runtime"

        # Internal container relationships
        httpServer -> textGenModules "Routes text generation requests"
        httpServer -> embeddingModules "Routes embedding/rerank requests"
        httpServer -> classificationModules "Routes classification requests"
        grpcServer -> textGenModules "Routes gRPC task requests"
        grpcServer -> embeddingModules "Routes gRPC embedding requests"
        grpcServer -> classificationModules "Routes gRPC classification requests"
        textGenModules -> tgisClient "Delegates remote inference"
        textGenModules -> modelResources "Loads HuggingFace models"
        classificationModules -> modelResources "Loads HuggingFace models"

        # External relationships
        tgisClient -> tgis "gRPC inference requests" "gRPC/configurable port, mTLS optional"
        kserve -> caikitNlp "Deploys and routes to caikit-nlp containers" "HTTP/8080, gRPC/8085"
        modelMesh -> caikitNlp "Routes multi-model inference requests" "gRPC/8085"
        caikitNlp -> modelRegistry "Fetches model metadata" "API"
        modelResources -> huggingFaceHub "Downloads model artifacts (when enabled)" "HTTPS/443"
        istio -> caikitNlp "Enforces auth and mTLS via sidecar proxy"
    }

    views {
        systemContext caikitNlp "SystemContext" {
            include *
            autoLayout
            description "System context showing caikit-nlp in the RHOAI model serving ecosystem"
        }

        container caikitNlp "Containers" {
            include *
            autoLayout
            description "Container view showing caikit-nlp internal modules and external integrations"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Service" {
                shape RoundedBox
                background #4a90e2
                color #ffffff
            }
        }
    }
}
