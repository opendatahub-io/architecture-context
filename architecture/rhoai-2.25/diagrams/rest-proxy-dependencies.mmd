graph LR
    RestProxy["rest-proxy<br/>gRPC-Gateway Reverse Proxy"]

    %% Internal Platform Dependencies
    RestProxy -->|"gRPC client<br/>localhost:8033"| ModelMesh["ModelMesh Serving<br/>(gRPC Inference Service)"]
    RestProxy -.->|"image config<br/>restProxy.image"| ConfigMap["model-serving-config<br/>ConfigMap"]

    %% External Library Dependencies
    RestProxy -->|"HTTP↔gRPC translation"| GRPCGateway["grpc-gateway/v2<br/>v2.15.0"]
    RestProxy -->|"gRPC client"| GRPC["google.golang.org/grpc<br/>v1.79.3"]
    RestProxy -->|"protobuf serialization"| Protobuf["google.golang.org/protobuf<br/>v1.36.10"]
    RestProxy -->|"structured logging"| ControllerRuntime["controller-runtime<br/>v0.14.1<br/>(zap logger only)"]

    %% Infrastructure Dependencies
    RestProxy -.->|"TLS certificates"| CertManager["cert-manager<br/>(via ModelMesh)"]

    %% Styling
    style RestProxy fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style ConfigMap fill:#7ed321,stroke:#333,color:#fff
    style GRPCGateway fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertManager fill:#f5a623,stroke:#333,color:#fff
