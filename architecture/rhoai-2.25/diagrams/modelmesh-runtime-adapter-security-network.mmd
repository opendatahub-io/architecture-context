graph TB
    subgraph PodBoundary["POD TRUST BOUNDARY (localhost only)"]
        direction TB

        subgraph MMeshContainer["ModelMesh Container"]
            ModelMesh["ModelMesh Orchestrator<br/>SA: model-serving pod SA"]
        end

        subgraph AdapterSidecar["Runtime Adapter Sidecar"]
            direction TB
            TritonAdapter["triton-adapter<br/>8085/TCP gRPC plaintext"]
            MLServerAdapter["mlserver-adapter<br/>8085/TCP gRPC plaintext"]
            OVMSAdapter["ovms-adapter<br/>8085/TCP gRPC plaintext"]
            TorchServeAdapter["torchserve-adapter<br/>8085/TCP gRPC plaintext"]
            PullmanFW["pullman Framework<br/>(embedded puller)"]
        end

        subgraph RuntimeContainer["Inference Runtime Container"]
            Triton["Triton Inference Server<br/>8001/TCP gRPC plaintext"]
            MLServer["Seldon MLServer<br/>8001/TCP gRPC plaintext"]
            OVMS["OpenVINO Model Server<br/>8001/TCP HTTP plaintext"]
            TorchServeMgmt["TorchServe Management<br/>7071/TCP gRPC plaintext"]
            TorchServeInfer["TorchServe Inference<br/>7070/TCP gRPC plaintext"]
        end
    end

    subgraph ExternalStorage["EXTERNAL SERVICES (Egress)"]
        S3["AWS S3 / IBM COS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Access Key Auth"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account OAuth2"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection String / SPN"]
        HTTPExt["Custom HTTP Endpoints<br/>configurable port<br/>HTTP/HTTPS<br/>TLS optional, mTLS supported"]
    end

    subgraph LocalStorage["LOCAL STORAGE"]
        PVC["/pvc_mounts/{name}/<br/>Filesystem symlink<br/>No network"]
    end

    %% ModelMesh → Adapters (inbound, localhost)
    ModelMesh -->|"gRPC/8085<br/>plaintext localhost<br/>No Auth"| TritonAdapter
    ModelMesh -->|"gRPC/8085<br/>plaintext localhost<br/>No Auth"| MLServerAdapter
    ModelMesh -->|"gRPC/8085<br/>plaintext localhost<br/>No Auth"| OVMSAdapter
    ModelMesh -->|"gRPC/8085<br/>plaintext localhost<br/>No Auth"| TorchServeAdapter

    %% Adapters → Runtimes (outbound, localhost)
    TritonAdapter -->|"gRPC/8001<br/>plaintext localhost"| Triton
    MLServerAdapter -->|"gRPC/8001<br/>plaintext localhost"| MLServer
    OVMSAdapter -->|"HTTP/8001<br/>plaintext localhost"| OVMS
    TorchServeAdapter -->|"gRPC/7071<br/>plaintext localhost"| TorchServeMgmt
    TorchServeAdapter -->|"gRPC/7070<br/>plaintext localhost"| TorchServeInfer

    %% Puller → External Storage (egress, encrypted)
    PullmanFW -->|"HTTPS/443<br/>TLS 1.2+<br/>Access Key/Secret"| S3
    PullmanFW -->|"HTTPS/443<br/>TLS 1.2+<br/>SA OAuth2"| GCS
    PullmanFW -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn String/SPN"| Azure
    PullmanFW -->|"HTTP/HTTPS<br/>TLS optional<br/>Headers/mTLS cert"| HTTPExt
    PullmanFW -->|"symlink<br/>no network"| PVC

    %% Styling
    classDef podinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef adapter fill:#7ed321,stroke:#333,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef local fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class ModelMesh podinternal
    class TritonAdapter,MLServerAdapter,OVMSAdapter,TorchServeAdapter,PullmanFW adapter
    class Triton,MLServer,OVMS,TorchServeMgmt,TorchServeInfer runtime
    class S3,GCS,Azure,HTTPExt external
    class PVC local
