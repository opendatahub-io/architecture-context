graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    subgraph CoreRuntime["Core Runtime (Required)"]
        OpenVINO["OpenVINO Runtime<br/>2025.3 (built from source)"]
        OVTokenizers["OpenVINO Tokenizers<br/>2025.3 (57f278c)"]
        OVGenAI["OpenVINO GenAI<br/>(bundled)"]
    end

    OVMS -->|"inference engine"| OpenVINO
    OVMS -->|"tokenizer support"| OVTokenizers
    OVMS -->|"LLM continuous batching"| OVGenAI

    %% Build & Framework Dependencies
    subgraph BuildFramework["Build & Framework"]
        Bazel["Bazel 6.1.1"]
        gRPCLib["gRPC<br/>(Bazel managed)"]
        MediaPipeLib["MediaPipe<br/>(Bazel managed)"]
        Boost["Boost 1.68.0"]
        OpenCV["OpenCV<br/>(third_party)"]
    end

    OVMS -->|"build system"| Bazel
    OVMS -->|"gRPC server"| gRPCLib
    OVMS -->|"graph pipelines"| MediaPipeLib
    OVMS -->|"C++ utilities"| Boost
    OVMS -->|"image processing"| OpenCV

    %% Cloud Storage SDKs
    subgraph CloudSDKs["Cloud Storage SDKs"]
        AzureSDK["Azure Storage C++ SDK<br/>7.5.0"]
        cpprestsdk["cpprestsdk 2.10.16"]
        libcurl["libcurl (system)"]
    end

    OVMS -->|"Azure Blob access"| AzureSDK
    AzureSDK -->|"HTTP client"| cpprestsdk
    OVMS -->|"HTTP/HTTPS client"| libcurl

    %% Model Pulling
    subgraph ModelPulling["Model Pulling"]
        libgit2["libgit2 (bundled)"]
    end

    OVMS -->|"HuggingFace git clone"| libgit2

    %% System Libraries
    subgraph SystemLibs["System Libraries (UBI 9)"]
        OpenSSL["OpenSSL<br/>(UBI 9 system)"]
        Python3["Python 3<br/>(optional)"]
    end

    OVMS -->|"crypto/TLS"| OpenSSL
    OVMS -.->|"Python nodes"| Python3

    %% Optional Dependencies
    subgraph Optional["Optional"]
        Jinja2["Jinja2 3.1.6"]
        numpy["numpy <2.0.0"]
        Drogon["Drogon<br/>(alt HTTP server)"]
        pugixml["pugixml 1.13"]
    end

    OVMS -.->|"chat templates"| Jinja2
    OVMS -.->|"Python numerics"| numpy
    OVMS -.->|"alt HTTP server"| Drogon
    OVMS -->|"XML parsing"| pugixml

    %% Internal RHOAI Platform Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        KServe["KServe<br/>(InferenceService)"]
        ModelMesh["ModelMesh Serving"]
        CaikitTGIS["Caikit-TGIS-Serving<br/>(peer runtime)"]
    end

    KServe -->|"deploys as runtime"| OVMS
    ModelMesh -->|"deploys as runtime"| OVMS
    CaikitTGIS -.->|"alternative to"| OVMS

    %% External Services
    subgraph ExternalServices["External Services"]
        S3["S3-Compatible Storage<br/>(AWS S3, Ceph, MinIO)"]
        AzureBlob["Azure Blob Storage"]
        GCS["Google Cloud Storage"]
        HFHub["HuggingFace Hub"]
    end

    OVMS -->|"model loading<br/>HTTPS/443"| S3
    OVMS -->|"model loading<br/>HTTPS/443"| AzureBlob
    OVMS -->|"model loading<br/>HTTPS/443"| GCS
    OVMS -->|"model download<br/>HTTPS/443"| HFHub

    %% Platform Infrastructure
    subgraph PlatformInfra["Platform Infrastructure"]
        AuthProxy["kube-rbac-proxy /<br/>oauth-proxy"]
        Prometheus["Prometheus"]
        Istio["Istio Service Mesh"]
    end

    AuthProxy -->|"auth + TLS termination<br/>8443/TCP"| OVMS
    Prometheus -->|"scrapes /metrics<br/>rest_port/TCP"| OVMS
    Istio -.->|"mTLS sidecar"| OVMS

