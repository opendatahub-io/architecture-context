graph LR
    VLLM["vllm-rocm<br/>(odh-vllm-rocm-rhel9)"]

    %% External Dependencies (Required)
    VLLM -->|"base image<br/>FROM directive"| RHAIIS["RHAIIS vllm-rocm-rhel9<br/>v3.2.2-1772160625"]
    VLLM -->|"GPU acceleration<br/>HIP runtime"| ROCm["AMD ROCm GPU Driver"]

    %% Internal Platform Dependencies
    VLLM -->|"deployed as<br/>ServingRuntime"| KServe["KServe"]
    VLLM -->|"deployed as<br/>ServingRuntime"| ModelMesh["ModelMesh"]
    VLLM -->|"model weights<br/>volume mount"| PVC["PVC Storage"]
    VLLM -->|"model weights<br/>HTTPS/443"| S3["S3-Compatible Storage"]

    %% Integration Points (inbound)
    KubeRBAC["kube-rbac-proxy<br/>(sidecar)"] -->|"auth proxy<br/>8443/TCP HTTPS"| VLLM
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8000/TCP HTTP"| VLLM

    %% Optional Dependencies
    VLLM -.->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]

    %% Supply Chain
    subgraph "Supply Chain"
        direction TB
        UpstreamVLLM["Upstream vLLM"] --> RHAIIS
        RHAIIS -->|"base image"| VLLM_Build["odh-vllm-rocm-rhel9<br/>(Konflux build)"]
    end

    style VLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RHAIIS fill:#e74c3c,stroke:#333,color:#fff
    style ROCm fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style KubeRBAC fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style UpstreamVLLM fill:#999,stroke:#333,color:#fff
    style VLLM_Build fill:#4a90e2,stroke:#333,color:#fff
