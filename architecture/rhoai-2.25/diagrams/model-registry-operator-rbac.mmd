graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Operator SA"]
        SA_Registry["name<br/>Registry Instance SA<br/>per ModelRegistry CR"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader["leader-election-rolebinding<br/>RoleBinding<br/>operator namespace"]
        RB_Registry["registry-user-name-binding<br/>RoleBinding<br/>registry namespace"]
    end

    subgraph "ClusterRoles"
        CR_Manager["manager-role<br/>ClusterRole"]
        CR_Proxy["proxy-role<br/>ClusterRole"]
    end

    subgraph "Roles"
        R_Leader["leader-election-role<br/>Role<br/>operator namespace"]
        R_Registry["registry-user-name<br/>Role<br/>registry namespace"]
    end

    subgraph "Manager Role Permissions"
        direction TB

        subgraph Core_Resources["Core API Group"]
            P_ConfigMaps["configmaps, secrets<br/>Verbs: create, get, list, watch"]
            P_Services["services, serviceaccounts<br/>Verbs: create, delete, get, list, patch, update, watch"]
            P_Pods["endpoints, pods, pods/log<br/>Verbs: get, list, watch"]
            P_Events["events<br/>Verbs: create, patch"]
        end

        subgraph Apps_Resources["apps API Group"]
            P_Deployments["deployments<br/>Verbs: create, delete, get, list, patch, update, watch"]
        end

        subgraph MR_Resources["modelregistry.opendatahub.io API Group"]
            P_MR["modelregistries<br/>Verbs: create, delete, get, list, patch, update, watch"]
            P_MR_Status["modelregistries/status<br/>Verbs: get, patch, update"]
            P_MR_Finalizers["modelregistries/finalizers<br/>Verbs: update"]
        end

        subgraph Route_Resources["route.openshift.io API Group"]
            P_Routes["routes, routes/custom-host<br/>Verbs: create, delete, get, list, patch, update, watch"]
        end

        subgraph RBAC_Resources["rbac.authorization.k8s.io API Group"]
            P_RBAC["roles, rolebindings, clusterrolebindings<br/>Verbs: create, delete, get, list, patch, update, watch"]
        end

        subgraph Network_Resources["networking.k8s.io API Group"]
            P_NetPol["networkpolicies<br/>Verbs: create, delete, get, list, patch, update, watch"]
        end

        subgraph Auth_Resources["authentication.k8s.io / authorization.k8s.io"]
            P_TokenReviews["tokenreviews<br/>Verbs: create"]
            P_SAR["subjectaccessreviews<br/>Verbs: create"]
        end

        subgraph Other_Resources["Other API Groups"]
            P_Ingress["config.openshift.io/ingresses<br/>Verbs: get, list, watch"]
            P_Platform["components.platform.opendatahub.io/modelregistries<br/>Verbs: get, list, watch"]
            P_Migration["migration.k8s.io/storageversionmigrations<br/>Verbs: create, delete, get, list, patch, update, watch"]
            P_CRD["apiextensions.k8s.io/customresourcedefinitions<br/>Verbs: get, list, watch"]
        end
    end

    subgraph "Proxy Role Permissions"
        direction TB
        PP_TokenReviews["tokenreviews<br/>Verbs: create"]
        PP_SAR["subjectaccessreviews<br/>Verbs: create"]
    end

    subgraph "Leader Election Role Permissions"
        direction TB
        L_ConfigMaps["configmaps<br/>Verbs: get, list, watch, create, update, patch, delete"]
        L_Leases["coordination.k8s.io/leases<br/>Verbs: get, list, watch, create, update, patch, delete"]
        L_Events["events<br/>Verbs: create, patch"]
    end

    subgraph "Registry User Role Permissions"
        direction TB
        RU_Service["service/name<br/>Verbs: GET<br/>(for OAuth authorization)"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    SA_Registry -->|bound via| RB_Registry
    RB_Registry -->|grants| R_Registry

    %% Permissions
    CR_Manager -.->|grants| Core_Resources
    CR_Manager -.->|grants| Apps_Resources
    CR_Manager -.->|grants| MR_Resources
    CR_Manager -.->|grants| Route_Resources
    CR_Manager -.->|grants| RBAC_Resources
    CR_Manager -.->|grants| Network_Resources
    CR_Manager -.->|grants| Auth_Resources
    CR_Manager -.->|grants| Other_Resources

    CR_Proxy -.->|grants| Proxy_Role_Permissions

    R_Leader -.->|grants| Leader_Election_Role_Permissions

    R_Registry -.->|grants| Registry_User_Role_Permissions

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef permission fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000

    class SA_Controller,SA_Registry sa
    class CRB_Manager,CRB_Proxy,RB_Leader,RB_Registry binding
    class CR_Manager,CR_Proxy,R_Leader,R_Registry role
    class Core_Resources,Apps_Resources,MR_Resources,Route_Resources,RBAC_Resources,Network_Resources,Auth_Resources,Other_Resources,Proxy_Role_Permissions,Leader_Election_Role_Permissions,Registry_User_Role_Permissions permission
