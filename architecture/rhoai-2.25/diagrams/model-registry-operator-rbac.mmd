graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Instance["{name}<br/>(instance namespace)<br/>per ModelRegistry"]
        SA_Catalog["model-catalog<br/>(catalog namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster)"]
        CRB_Proxy["proxy-rolebinding<br/>(Cluster)"]
        CRB_AuthDelegator["{name}-auth-delegator<br/>(Cluster, per instance)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_LeaderElection["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Users["{name}-users<br/>(instance namespace)"]
        RB_CatalogAuth["model-catalog-authenticated<br/>(catalog namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_MetricsReader["metrics-reader"]
        CR_Admin["modelregistry-admin-role"]
        CR_Editor["modelregistry-editor-role"]
        CR_Viewer["modelregistry-viewer-role"]
        CR_AuthDelegator["system:auth-delegator"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_LeaderElection["leader-election-role<br/>(operator namespace)"]
        R_RegistryUser["registry-user-{name}<br/>(instance namespace)"]
        R_Catalog["model-catalog<br/>(catalog namespace)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        MR_ModelRegistries["modelregistry.opendatahub.io<br/>modelregistries<br/>+ /status + /finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Apps["apps<br/>deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Core["core ('')<br/>pods, pods/log, services,<br/>serviceaccounts, endpoints,<br/>configmaps, secrets, events<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Routes["route.openshift.io<br/>routes, routes/custom-host<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Groups["user.openshift.io<br/>groups<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Auth["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        MR_NetPol["networking.k8s.io<br/>networkpolicies<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_Migration["migration.k8s.io<br/>storageversionmigrations<br/>get,list,watch,create,<br/>update,patch,delete"]
        MR_CRD["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get,list,watch"]
        MR_Ingress["config.openshift.io<br/>ingresses<br/>get,list,watch"]
        MR_Platform["components.platform.<br/>opendatahub.io<br/>modelregistries<br/>get,list,watch"]
    end

    subgraph ProxyResources["proxy-role Resources"]
        PR_Auth["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph MetricsResources["metrics-reader Resources"]
        MetR_Metrics["(non-resource)<br/>/metrics<br/>get"]
    end

    subgraph AggregatedResources["Aggregated Role Resources"]
        Agg_Admin["modelregistries<br/>* (all verbs)"]
        Agg_Editor["modelregistries<br/>create,delete,get,list,<br/>watch,update,patch"]
        Agg_Viewer["modelregistries<br/>get,list,watch"]
    end

    %% SA → CRB → CR flows
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|permissions on| ManagerResources

    SA_Controller -->|bound via| CRB_Proxy
    CRB_Proxy -->|grants| CR_Proxy
    CR_Proxy -->|permissions on| ProxyResources

    SA_Controller -->|bound via| RB_LeaderElection
    RB_LeaderElection -->|grants| R_LeaderElection

    %% Per-instance bindings
    SA_Instance -->|bound via| CRB_AuthDelegator
    CRB_AuthDelegator -->|grants| CR_AuthDelegator

    %% User groups
    GroupUsers["Group/{name}-users"] -->|bound via| RB_Users
    RB_Users -->|grants| R_RegistryUser

    GroupAuth["Group/system:authenticated"] -->|bound via| RB_CatalogAuth
    RB_CatalogAuth -->|grants| R_Catalog

    %% Aggregated roles
    CR_Admin -->|permissions on| Agg_Admin
    CR_Editor -->|permissions on| Agg_Editor
    CR_Viewer -->|permissions on| Agg_Viewer

    %% Metrics reader
    CR_MetricsReader -->|permissions on| MetricsResources

