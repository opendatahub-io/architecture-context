    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style SA_Catalog fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#000
    style CR_Proxy fill:#f5a623,stroke:#333,color:#000
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#000
    style CR_Admin fill:#f5a623,stroke:#333,color:#000
    style CR_Editor fill:#f5a623,stroke:#333,color:#000
    style CR_Viewer fill:#f5a623,stroke:#333,color:#000
    style CR_AuthDelegator fill:#f5a623,stroke:#333,color:#000
    style R_LeaderElection fill:#e8c96e,stroke:#333,color:#000
    style R_RegistryUser fill:#e8c96e,stroke:#333,color:#000
    style R_Catalog fill:#e8c96e,stroke:#333,color:#000
    style GroupUsers fill:#cc99ff,stroke:#333,color:#000
    style GroupAuth fill:#cc99ff,stroke:#333,color:#000

    style MR_ModelRegistries fill:#7ed321,stroke:#333,color:#000
    style MR_Apps fill:#7ed321,stroke:#333,color:#000
    style MR_Core fill:#7ed321,stroke:#333,color:#000
    style MR_Routes fill:#7ed321,stroke:#333,color:#000
    style MR_Groups fill:#7ed321,stroke:#333,color:#000
    style MR_RBAC fill:#7ed321,stroke:#333,color:#000
    style MR_Auth fill:#7ed321,stroke:#333,color:#000
    style MR_NetPol fill:#7ed321,stroke:#333,color:#000
    style MR_Migration fill:#7ed321,stroke:#333,color:#000
    style MR_CRD fill:#7ed321,stroke:#333,color:#000
    style MR_Ingress fill:#7ed321,stroke:#333,color:#000
    style MR_Platform fill:#7ed321,stroke:#333,color:#000
    style PR_Auth fill:#7ed321,stroke:#333,color:#000
    style MetR_Metrics fill:#7ed321,stroke:#333,color:#000
