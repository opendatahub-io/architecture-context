%% TrustyAI Explainability - Component Structure Diagram
%% Generated by: Claude Opus 4.6
graph TB
    subgraph "TrustyAI Explainability Service"
        direction TB
        subgraph "Quarkus REST Service (8080/TCP)"
            FairnessAPI[Fairness Endpoints<br/>/metrics/group/fairness/*]
            DriftAPI[Drift Endpoints<br/>/metrics/drift/*]
            ExplainerAPI[Explainer Endpoints<br/>/explainers/*<br/>disabled in RHOAI]
            ConsumerAPI[Consumer Endpoint<br/>/consumer/kserve/v2]
            DataAPI[Data Endpoints<br/>/data/upload, /data/download]
            InfoAPI[Info Endpoints<br/>/info/*]
            MetricsAPI[Prometheus Metrics<br/>/q/metrics]
            HealthAPI[Health Checks<br/>/q/health/*]
        end

        subgraph "Core Engine"
            ExplainabilityCore[explainability-core<br/>Fairness, XAI Algorithms<br/>LIME, SHAP, CF]
            Connectors[explainability-connectors<br/>KServe v1/v2, ModelMesh]
            ArrowBridge[explainability-arrow<br/>Apache Arrow Bridge]
        end

        subgraph "Internal Components"
            PrometheusScheduler[PrometheusScheduler<br/>Scheduled Metric Computation]
            MMReconciler[InferencePayload<br/>Reconciler<br/>ModelMesh]
            KSReconciler[KServeInferencePayload<br/>Reconciler<br/>KServe]
            CloudEventConsumer[CloudEventConsumer<br/>Knative CloudEvents]
        end

        subgraph "Storage Backends"
            PVCStorage[PVCStorage<br/>Flat File /inputs]
            HibernateStorage[HibernateStorage<br/>MariaDB/MySQL]
            MinioStorage[MinioStorage<br/>S3/MinIO]
        end
    end

    %% External Inputs
    ModelMesh[ModelMesh Serving] -->|HTTP POST /consumer/kserve/v2| ConsumerAPI
    KServeEvents[KServe via Knative<br/>CloudEvents] -->|org.kubeflow.serving.*| CloudEventConsumer
    Client[Client / Dashboard] -->|REST API| FairnessAPI
    Client -->|REST API| DriftAPI
    Client -->|REST API| ExplainerAPI

    %% Internal flows
    ConsumerAPI --> MMReconciler
    CloudEventConsumer --> KSReconciler
    MMReconciler --> PVCStorage
    MMReconciler --> HibernateStorage
    MMReconciler --> MinioStorage
    KSReconciler --> PVCStorage
    KSReconciler --> HibernateStorage
    KSReconciler --> MinioStorage

    FairnessAPI --> ExplainabilityCore
    DriftAPI --> ExplainabilityCore
    ExplainerAPI --> ExplainabilityCore
    ExplainabilityCore --> Connectors

    PrometheusScheduler -->|reads data| PVCStorage
    PrometheusScheduler -->|publishes| MetricsAPI

    %% Egress
    Connectors -->|gRPC KServe v2| ModelServers[KServe/ModelMesh<br/>Model Servers]
    HibernateStorage -->|JDBC 3306/TCP| MariaDB[(MariaDB/MySQL)]
    MinioStorage -->|S3 API 443/9000| S3[(MinIO/S3)]

    %% Monitoring
    Prometheus[Prometheus] -->|scrape /q/metrics| MetricsAPI

    %% Operator
    Operator[TrustyAI Service Operator] -.->|manages deployment| FairnessAPI

