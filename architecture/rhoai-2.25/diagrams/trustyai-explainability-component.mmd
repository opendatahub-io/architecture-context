graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus 3.8.5)"]
            direction LR
            MetricsEndpoints["Metrics Endpoints<br/>/metrics/group/fairness/*<br/>/metrics/drift/*"]
            ExplainerEndpoints["Explainer Endpoints<br/>/explainers/local/{lime,shap,cf,tssaliency}<br/>/explainers/global/{lime,pdp}"]
            ConsumerEndpoints["Consumer Endpoints<br/>/consumer/kserve/v2<br/>CloudEventConsumer"]
            DataEndpoints["Data Endpoints<br/>/data/upload<br/>/data/download"]
            InfoEndpoints["Info Endpoints<br/>/info, /info/tags<br/>/info/names"]

            subgraph Reconcilers["Payload Reconcilers"]
                KServeReconciler["KServe Payload<br/>Reconciler"]
                ModelMeshReconciler["ModelMesh Payload<br/>Reconciler"]
            end

            subgraph Storage["Pluggable Storage Backends"]
                PVCStorage["PVC Storage<br/>(flat-file CSV)"]
                MinIOStorage["MinIO Storage<br/>(S3-compatible)"]
                HibernateStorage["Hibernate Storage<br/>(MariaDB/MySQL)"]
            end

            PrometheusScheduler["Prometheus Scheduler<br/>(cron: every 5s)"]
            PrometheusPublisher["Prometheus Publisher<br/>(Micrometer gauges)"]
        end

        subgraph CoreLib["explainability-core (Library)"]
            direction LR
            FairnessMetrics["Fairness Metrics<br/>SPD, DIR"]
            DriftMetrics["Drift Metrics<br/>KS Test, Fourier MMD,<br/>Meanshift"]
            Explainers["XAI Algorithms<br/>LIME, SHAP,<br/>Counterfactual, PDP,<br/>TS Saliency"]
            Dataframes["Dataframe<br/>Data Structures"]
        end

        subgraph ConnectorsLib["explainability-connectors (Library)"]
            GRPCClient["KServe V2 gRPC<br/>Inference Client<br/>(protobuf)"]
            PayloadParsers["Payload Parsers<br/>KServe v1/v2,<br/>ModelMesh"]
        end

        subgraph ArrowLib["explainability-arrow (Library)"]
            ArrowIPC["Apache Arrow IPC<br/>Java-Python Bridge"]
        end
    end

    %% External integrations
    ModelMesh["ModelMesh Serving"] -->|"POST /consumer/kserve/v2<br/>8080/TCP HTTP"| ConsumerEndpoints
    KServeIS["KServe InferenceService"] -->|"CloudEvents<br/>8080/TCP HTTP"| ConsumerEndpoints
    Client["API Client / Dashboard"] -->|"REST API<br/>8080/TCP HTTP<br/>4443/TCP HTTPS"| MetricsEndpoints
    Client -->|"REST API"| ExplainerEndpoints
    Client -->|"REST API"| DataEndpoints
    Client -->|"REST API"| InfoEndpoints

    ConsumerEndpoints --> KServeReconciler
    ConsumerEndpoints --> ModelMeshReconciler
    KServeReconciler --> Storage
    ModelMeshReconciler --> Storage

    ExplainerEndpoints --> Explainers
    ExplainerEndpoints --> GRPCClient
    MetricsEndpoints --> FairnessMetrics
    MetricsEndpoints --> DriftMetrics

    PrometheusScheduler --> FairnessMetrics
    PrometheusScheduler --> DriftMetrics
    PrometheusScheduler --> PrometheusPublisher

    GRPCClient -->|"gRPC/HTTP2<br/>V2 Inference Protocol"| KServeModel["KServe Model Endpoint"]

    Prometheus["Prometheus<br/>ServiceMonitor"] -->|"GET /q/metrics<br/>8080/TCP HTTP<br/>Bearer Token"| PrometheusPublisher

    PVCStorage -->|"Volume mount<br/>/inputs"| PVC["PVC Volume"]
    MinIOStorage -->|"S3 API<br/>HTTP/HTTPS"| MinIO["MinIO"]
    HibernateStorage -->|"JDBC"| MariaDB["MariaDB/MySQL"]

    TrustyAIOp["TrustyAI Operator"] -.->|"deploys & configures<br/>TrustyAIService CR"| TrustyAI

    %% Styling
    style TrustyAI fill:#e8f4f8,stroke:#2196F3,stroke-width:2px
    style ServiceLayer fill:#e3f2fd,stroke:#1976D2,stroke-width:1px
    style CoreLib fill:#e8f5e9,stroke:#388E3C,stroke-width:1px
    style ConnectorsLib fill:#fff3e0,stroke:#F57C00,stroke-width:1px
    style ArrowLib fill:#fce4ec,stroke:#C62828,stroke-width:1px
    style Storage fill:#f3e5f5,stroke:#7B1FA2,stroke-width:1px
    style Reconcilers fill:#e0f2f1,stroke:#00796B,stroke-width:1px

    style ModelMesh fill:#e8e8e8,stroke:#333
    style KServeIS fill:#e8e8e8,stroke:#333
    style KServeModel fill:#e8e8e8,stroke:#333
    style Client fill:#fff9c4,stroke:#F9A825
    style Prometheus fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
    style MinIO fill:#e8e8e8,stroke:#333
    style MariaDB fill:#e8e8e8,stroke:#333
    style TrustyAIOp fill:#c8e6c9,stroke:#2E7D32
