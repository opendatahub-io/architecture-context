// C4 Context Diagram - Data Science Pipelines Operator
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/data-science-pipelines-operator.md

workspace {
    model {
        user = person "Data Scientist" "Creates and runs ML pipelines via Dashboard or SDK"
        admin = person "Platform Admin" "Configures DSPA CRs and manages pipeline infrastructure"

        dspo = softwareSystem "Data Science Pipelines Operator" "Manages lifecycle of Kubeflow Pipelines v2 infrastructure on OpenShift via DSPA custom resources" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, reconciles pipeline infrastructure, performs health checks" "Go Operator (controller-runtime)"
            webhook = container "DS Pipelines Webhook" "Validates/mutates Pipeline and PipelineVersion CRs for kubernetes-native pipeline storage" "Go Webhook Server"
            apiServer = container "DS Pipelines API Server" "Kubeflow Pipelines v2 REST/gRPC API for pipeline CRUD, run management" "Go Service"
            oauthProxy = container "OAuth Proxy Sidecar" "OpenShift oauth-proxy for authentication on API server Route" "oauth-proxy"
            persistenceAgent = container "Persistence Agent" "Records pipeline run status and metadata to database" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow" "Manages cron-scheduled pipeline runs" "Go Service"
            workflowController = container "Argo Workflow Controller" "Orchestrates pipeline step execution via Argo Workflows" "Go Service"
            mlmdGrpc = container "MLMD gRPC Server" "ML Metadata gRPC server for artifact/execution lineage tracking" "gRPC Service"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD gRPC with OAuth proxy for external access" "Envoy"
            mariadb = container "MariaDB" "Default database backend for pipeline metadata (optional internal)" "MariaDB 10.x"
            minio = container "Minio" "Default S3-compatible object storage for pipeline artifacts (optional internal)" "Minio"
        }

        // External systems
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys DSPO via kustomize overlay" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Creates DSPA CRs and queries pipeline APIs" "Internal RHOAI"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller exposing Routes externally" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Generates TLS certificates for inter-pod communication" "External"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Core Kubernetes resource management and CR watches" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection for operator and pipeline component readiness" "External"
        kserve = softwareSystem "KServe" "Inference service integration for pipeline tasks" "Internal RHOAI"
        ray = softwareSystem "Ray (KubeRay)" "Distributed computing for pipeline tasks" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare" "Distributed workload management for pipeline tasks" "Internal RHOAI"
        externalDB = softwareSystem "External MySQL/MariaDB" "External database for pipeline metadata (optional)" "External"
        externalS3 = softwareSystem "External S3 Storage" "External S3-compatible storage for pipeline artifacts (optional)" "External"

        // Relationships - Users
        user -> odhDashboard "Manages pipelines via UI"
        user -> dspo "Submits pipelines via KFP SDK" "HTTPS/443"
        admin -> dspo "Creates DSPA CRs via kubectl"

        // Relationships - Deployment
        rhodsOperator -> dspo "Deploys via kustomize overlay, injects RELATED_IMAGE_* env vars"

        // Relationships - Internal
        controller -> kubernetesAPI "Watches DSPA CRs, manages resources" "HTTPS/6443"
        controller -> mariadb "Health checks" "MySQL/3306"
        controller -> minio "Health checks" "HTTP/9000"
        oauthProxy -> apiServer "Proxies authenticated requests" "HTTP(S)/8888"
        apiServer -> mariadb "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores pipeline artifacts" "HTTP/9000"
        persistenceAgent -> mariadb "Records run status" "MySQL/3306"
        mlmdEnvoy -> mlmdGrpc "Proxies gRPC" "gRPC/8080"
        workflowController -> kubernetesAPI "Creates/manages pipeline pods" "HTTPS/6443"

        // Relationships - External integrations
        odhDashboard -> dspo "Creates DSPA CRs, queries pipelines" "HTTPS/8443"
        openshiftRouter -> oauthProxy "Routes external traffic" "HTTPS/8443"
        openshiftServiceCA -> dspo "Injects TLS certificates"
        prometheus -> controller "Scrapes metrics" "HTTP/8080"
        dspo -> kserve "Pipeline tasks create InferenceServices" "API"
        dspo -> ray "Pipeline tasks create RayClusters/RayJobs" "API"
        dspo -> codeflare "Pipeline tasks manage AppWrappers" "API"

        // External backing services
        apiServer -> externalDB "Stores metadata (when external)" "MySQL/3306 TLS"
        apiServer -> externalS3 "Stores artifacts (when external)" "HTTPS/443"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #50b5e9
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
