/* C4 Context Diagram: Distributed Workloads
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/distributed-workloads.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Runs distributed ML training workloads on OpenShift"
        mlEngineer = person "ML Engineer" "Develops and tunes distributed training jobs"
        ciSystem = person "CI/CD System" "Konflux CI pipeline runner"

        distributedWorkloads = softwareSystem "Distributed Workloads" "Container runtime images and E2E test suite for distributed ML workloads (Ray, PyTorch, Kueue) in RHOAI" {
            rayImages = container "Ray Runtime Images" "GPU-accelerated Ray cluster images with CUDA 12.1/12.8 and ROCm 6.1/6.2" "Container Image (UBI9)"
            trainingImages = container "Training Runtime Images" "PyTorch training images with CUDA 12.1/12.4 and ROCm 6.2" "Container Image (UBI9)"
            e2eTestSuite = container "E2E Test Suite" "Go-based integration tests for KFTO, FMS, ODH workloads" "Go Test Framework"
            testLibrary = container "Test Support Library" "Shared utilities for K8s/OpenShift API interactions" "Go Library"
            tektonPipelines = container "Tekton PipelineRuns" "Konflux build pipelines for all container images" "Tekton CI/CD"
        }

        kuberayOperator = softwareSystem "KubeRay Operator" "Manages Ray cluster lifecycle on Kubernetes" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages distributed PyTorch training jobs" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and resource quota management" "Internal RHOAI"
        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages AppWrapper resources for batch workloads" "Internal RHOAI"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys distributed workload components" "Internal RHOAI"

        openshift = softwareSystem "OpenShift" "Container platform v4.16-v4.20" "External"
        prometheus = softwareSystem "Prometheus (OpenShift Monitoring)" "GPU utilization metrics collection (DCGM)" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Model artifacts and datasets" "External"
        pypi = softwareSystem "PyPI" "Python package repository" "External"
        nvidiaRepos = softwareSystem "NVIDIA Repos" "CUDA and cuDNN packages" "External"
        konflux = softwareSystem "Konflux" "CI/CD platform for image builds" "External"

        # Relationships - Users
        dataScientist -> distributedWorkloads "Runs training workloads using runtime images"
        mlEngineer -> distributedWorkloads "Develops and tests distributed training pipelines"
        ciSystem -> distributedWorkloads "Builds container images and runs E2E tests"

        # Relationships - Internal containers
        e2eTestSuite -> testLibrary "Uses for K8s API interactions"
        tektonPipelines -> rayImages "Builds"
        tektonPipelines -> trainingImages "Builds"

        # Relationships - Downstream consumers
        kuberayOperator -> rayImages "Uses as Ray cluster runtime" "Container Image Pull"
        trainingOperator -> trainingImages "Uses as training runtime" "Container Image Pull"

        # Relationships - Test interactions
        e2eTestSuite -> kuberayOperator "Creates RayCluster/RayJob CRs" "HTTPS/6443"
        e2eTestSuite -> trainingOperator "Creates PyTorchJob CRs" "HTTPS/6443"
        e2eTestSuite -> kueue "Configures queues, verifies admission" "HTTPS/6443"
        e2eTestSuite -> codeflareOperator "Creates AppWrapper CRs" "HTTPS/6443"
        e2eTestSuite -> prometheus "Queries GPU metrics" "HTTPS/443"

        # Relationships - External
        distributedWorkloads -> openshift "Runs on" "HTTPS/6443"
        distributedWorkloads -> s3Storage "Downloads/uploads models and datasets" "HTTPS/443"
        rayImages -> pypi "Installs Python packages" "HTTPS/443"
        rayImages -> nvidiaRepos "Installs CUDA/cuDNN" "HTTPS/443"
        trainingImages -> pypi "Installs Python packages" "HTTPS/443"
        trainingImages -> nvidiaRepos "Installs CUDA/cuDNN" "HTTPS/443"
        tektonPipelines -> konflux "Runs build pipelines" "Tekton PipelineRun"
        rhodsOperator -> distributedWorkloads "Deploys components"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container Image (UBI9)" {
                background #f5a623
                color #ffffff
            }
            element "Go Test Framework" {
                background #4a90e2
                color #ffffff
            }
            element "Go Library" {
                background #4a90e2
                color #ffffff
            }
            element "Tekton CI/CD" {
                background #9b59b6
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
