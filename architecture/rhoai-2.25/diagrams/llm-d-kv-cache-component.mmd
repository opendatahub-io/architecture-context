graph TB
    subgraph KVCacheManager["KV-Cache Manager (Go binary)"]
        direction TB
        Indexer["KV-Cache Indexer<br/>(Go Library)"]
        EventsPool["KV-Events Pool<br/>(Sharded ZMQ Workers)"]
        TokenProcessor["Token Processor<br/>(FNV-1a Hash Chain)"]
        BlockIndex["Block Index<br/>(InMemory LRU / Ristretto)"]
        Scorer["KVBlock Scorer"]
        HTTPApi["HTTP API<br/>8080/TCP"]
        GRPCApi["gRPC IndexerService<br/>50051/TCP"]
        MetricsEndpoint["Prometheus Metrics<br/>/metrics"]

        EventsPool -->|updates| BlockIndex
        Indexer -->|uses| TokenProcessor
        Indexer -->|queries| BlockIndex
        Indexer -->|delegates| Scorer
        HTTPApi -->|calls| Indexer
        GRPCApi -->|calls| Indexer
        HTTPApi --> MetricsEndpoint
    end

    subgraph UDSTokenizer["UDS Tokenizer (Python Sidecar)"]
        TokenizerGRPC["gRPC TokenizationService<br/>Unix Domain Socket"]
        HealthCheck["Health Check<br/>8082/TCP"]
    end

    subgraph FSBackend["LLMD FS Backend (vLLM Plugin)"]
        GPUHandler["GPUToStorageHandler"]
        StorageHandler["StorageToGPUHandler"]
        FileMapper["File Mapper"]
        StagingBuffer["CPU Staging Buffer"]
    end

    subgraph PVCEvictor["PVC Evictor (Python Daemon)"]
        Activator["Activator Process"]
        Crawlers["N Crawler Processes"]
        Deleter["Deleter Process"]
        Activator -->|triggers| Crawlers
        Crawlers -->|queue| Deleter
    end

    %% External interactions
    EPP["llm-d Inference Scheduler<br/>(EPP)"] -->|embeds library| Indexer
    EPP -->|POST /score_completions| HTTPApi
    EPP -->|GetPodScores RPC| GRPCApi

    vLLMPods["vLLM Model Server Pods"] -->|ZMQ PUB 5557/TCP| EventsPool
    SGLangPods["SGLang Model Server Pods"] -->|ZMQ PUB 5557/TCP| EventsPool

    Indexer -->|gRPC via UDS| TokenizerGRPC
    TokenizerGRPC -->|downloads| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]

    RedisBackend["Redis / Valkey<br/>6379/TCP"] -.->|optional backend| BlockIndex

    GPUHandler -->|CUDA memcpy| StagingBuffer
    StagingBuffer -->|POSIX I/O| SharedFS["Shared Filesystem<br/>(PVC)"]
    StagingBuffer -->|HTTPS via NIXL| S3["S3 Object Store<br/>443/TCP"]

    PVCEvictor -->|evicts files| SharedFS

    vLLMEngine["vLLM Engine Process"] -->|plugin API| GPUHandler
    vLLMEngine -->|plugin API| StorageHandler

    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"] -->|pod watch/list| EventsPool

    Prometheus["Prometheus"] -->|scrape /metrics| MetricsEndpoint
    OTELCollector["OTLP Collector<br/>4317/TCP gRPC"] -.->|traces| KVCacheManager

