%% Data Flow Diagram: llama-stack-provider-ragas
%% Generated by: Claude Opus 4.6

sequenceDiagram
    participant Client as Client
    participant LLS as Llama Stack Server<br/>8321/TCP HTTP
    participant Inline as RagasEvaluatorInline
    participant DatasetIO as DatasetIO API<br/>(in-process)
    participant InfAPI as Inference API<br/>(in-process)
    participant Ollama as Ollama Server<br/>11434/TCP HTTP

    rect rgb(220, 240, 255)
        Note over Client, Ollama: Flow 1: Inline Evaluation
        Client->>LLS: POST /eval/run_eval<br/>benchmark_id, benchmark_config
        LLS->>Inline: run_eval()
        Inline->>DatasetIO: get_rows_paginated()
        DatasetIO-->>Inline: Dataset rows
        Inline->>InfAPI: Ragas LLM calls via<br/>LlamaStackInlineLLM wrapper
        InfAPI->>Ollama: HTTP/11434<br/>Inference request
        Ollama-->>InfAPI: LLM response
        InfAPI-->>Inline: Generation result
        Inline->>InfAPI: Ragas Embeddings via<br/>LlamaStackInlineEmbeddings wrapper
        InfAPI->>Ollama: HTTP/11434<br/>Embedding request
        Ollama-->>InfAPI: Embeddings
        InfAPI-->>Inline: Embedding result
        Inline-->>LLS: Job completed (stored in-memory)
        Client->>LLS: GET /eval/job_result
        LLS-->>Client: Evaluation scores<br/>(relevancy, faithfulness, etc.)
    end

    participant Remote as RagasEvaluatorRemote
    participant KFP as Kubeflow Pipelines API<br/>443/TCP HTTPS TLS
    participant RetrievePod as KFP: retrieve_data pod
    participant EvalPod as KFP: run_ragas pod
    participant S3 as S3 Storage<br/>443/TCP HTTPS TLS

    rect rgb(255, 240, 220)
        Note over Client, S3: Flow 2: Remote Evaluation (Kubeflow Pipelines)
        Client->>LLS: POST /eval/run_eval<br/>benchmark_id, benchmark_config
        LLS->>Remote: run_eval()
        Remote->>KFP: Submit pipeline run<br/>HTTPS/443 Bearer Token
        KFP-->>Remote: pipeline_run_id
        Remote-->>LLS: job_id = pipeline_run_id
        LLS-->>Client: job_id

        Note over KFP, S3: Asynchronous Pipeline Execution
        KFP->>RetrievePod: Create pod
        RetrievePod->>LLS: GET /datasets/*<br/>HTTP (configurable)
        LLS-->>RetrievePod: Dataset JSONL
        RetrievePod-->>KFP: Output artifact

        KFP->>EvalPod: Create pod (with dataset artifact)
        EvalPod->>LLS: Inference calls via<br/>LlamaStackRemoteLLM
        LLS-->>EvalPod: LLM responses
        EvalPod->>S3: Write results<br/>HTTPS/443 AWS IAM
        EvalPod-->>KFP: Pipeline complete

        Client->>LLS: GET /eval/job_status
        LLS->>Remote: job_status()
        Remote->>KFP: Check run status<br/>HTTPS/443 Bearer Token
        KFP-->>Remote: Status: completed
        Remote-->>LLS: completed
        LLS-->>Client: completed

        Client->>LLS: GET /eval/job_result
        LLS->>Remote: job_result()
        Remote->>S3: Read results<br/>HTTPS/443 AWS IAM
        S3-->>Remote: Evaluation scores JSON
        Remote-->>LLS: Scores
        LLS-->>Client: Evaluation scores
    end
