graph TB
    subgraph Pod["ODH Dashboard Pod"]
        direction TB

        subgraph OAuthProxy["oauth-proxy Sidecar"]
            OAuth["oauth-proxy<br/>Port: 8443/TCP<br/>OpenShift OAuth<br/>TLS Termination"]
        end

        subgraph MainDashboard["odh-dashboard (main)"]
            Backend["Node.js/Fastify Backend<br/>Port: 8080/TCP<br/>API Gateway + K8s Proxy"]
            Frontend["React/TypeScript SPA<br/>PatternFly 6<br/>Module Federation Host"]
            Backend -->|serves static files| Frontend
        end

        subgraph ModelRegistryUI["model-registry-ui Sidecar"]
            MRBFF["Go BFF<br/>Port: 8043/TCP (HTTPS)<br/>SAR/SSAR Auth"]
            MRFrontend["React Module<br/>Module Federation Remote"]
            MRBFF -->|serves| MRFrontend
        end

        subgraph GenAI["gen-ai Module (future)"]
            GenAIBFF["Go BFF<br/>Port: TBD<br/>LlamaStack + MCP"]
            GenAIFrontend["React Module<br/>Module Federation Remote"]
            GenAIBFF -->|serves| GenAIFrontend
        end
    end

    %% External Access
    Browser[Browser] -->|HTTPS/443<br/>OAuth| Route["OpenShift Route<br/>TLS Reencrypt"]
    Route -->|HTTPS/8443| OAuth
    OAuth -->|HTTP/8080<br/>x-forwarded-access-token| Backend

    %% Module Federation
    Backend -->|/_mf/modelRegistry/*<br/>HTTPS/8043| MRBFF
    Frontend -.->|Module Federation<br/>Runtime Loading| MRFrontend
    Frontend -.->|Module Federation<br/>Runtime Loading| GenAIFrontend

    %% Backend to CRDs
    Backend -->|watches/manages| CRDs["CRDs<br/>OdhDashboardConfig<br/>AcceleratorProfile<br/>HardwareProfile<br/>OdhApplication"]

    %% Backend to K8s API
    Backend -->|HTTPS/443<br/>Bearer Token| K8sAPI["Kubernetes API"]

    %% Backend to Upstream Services
    Backend -->|proxy| UpstreamServices["Upstream Services<br/>Pipelines, TrustyAI,<br/>MLMD, Feast, LlamaStack"]

    %% Model Registry BFF to upstream
    MRBFF -->|HTTP/HTTPS| ModelRegistryAPI["Model Registry API"]
    MRBFF -->|HTTPS/443<br/>SAR checks| K8sAPI

    %% Metrics
    Backend -->|HTTPS/9092| Thanos["Thanos/Prometheus"]

    %% Styling
    style OAuth fill:#e8a838,stroke:#333,stroke-width:2px
    style Backend fill:#4a90e2,stroke:#333,stroke-width:2px
    style Frontend fill:#4a90e2,stroke:#333,stroke-width:1px
    style MRBFF fill:#7ed321,stroke:#333,stroke-width:2px
    style MRFrontend fill:#7ed321,stroke:#333,stroke-width:1px
    style GenAIBFF fill:#9b59b6,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style GenAIFrontend fill:#9b59b6,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Route fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style ModelRegistryAPI fill:#7ed321,stroke:#333
    style Thanos fill:#f5a623,stroke:#333
    style CRDs fill:#f5a623,stroke:#333
    style UpstreamServices fill:#f5a623,stroke:#333
    style Browser fill:#f9f9f9,stroke:#999
