graph TB
    subgraph "ODH Dashboard Pod"
        Frontend[Frontend SPA<br/>React 18, PatternFly 6<br/>Port: 8080]
        Backend[Backend API Server<br/>Fastify, Node.js 20<br/>Port: 8080]
        OAuthProxy[OAuth Proxy<br/>OpenShift OAuth<br/>Port: 8443]
        ModuleFed[Module Federation<br/>Webpack Dynamic Plugins]
        K8sClient[Kubernetes Client<br/>@kubernetes/client-node]
        WebSocketServer[WebSocket Server<br/>Real-time Updates]

        OAuthProxy -->|proxies to| Backend
        Frontend -->|API calls| Backend
        Backend -->|uses| K8sClient
        Backend -->|uses| WebSocketServer
        Frontend -->|loads| ModuleFed
    end

    subgraph "Custom Resources"
        OdhApplication[OdhApplication CR<br/>dashboard.opendatahub.io/v1]
        OdhDashboardConfig[OdhDashboardConfig CR<br/>opendatahub.io/v1alpha]
        OdhDocument[OdhDocument CR<br/>dashboard.opendatahub.io/v1]
        OdhQuickStart[OdhQuickStart CR<br/>console.openshift.io/v1]
        HardwareProfile[HardwareProfile CR<br/>infrastructure.opendatahub.io/v1]
        AcceleratorProfile[AcceleratorProfile CR<br/>dashboard.opendatahub.io/v1]
    end

    subgraph "External Access"
        User[User Browser]
        OSRouter[OpenShift Router<br/>443/TCP HTTPS]
        OSRoute[OpenShift Route<br/>odh-dashboard]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        OSAuth[OpenShift OAuth Server<br/>6443/TCP HTTPS]
        Prometheus[Prometheus/Thanos<br/>9092/TCP HTTPS]
    end

    subgraph "Internal ODH Components"
        ODHOperator[opendatahub-operator<br/>DataScienceCluster, DSCInitialization]
        KubeflowNotebooks[Kubeflow Notebooks<br/>Notebook CR]
        KServe[KServe<br/>InferenceService CR]
        ModelRegistry[Model Registry<br/>ModelRegistry CR]
        ODHModelController[ODH Model Controller<br/>Serving Runtimes]
        DSPipelines[Data Science Pipelines<br/>Pipeline Runs]
        TrustyAI[TrustyAI Service<br/>Bias Metrics]
        Kueue[Kueue<br/>Workload Queues]
        CodeFlare[CodeFlare Operator<br/>Distributed Training]
    end

    subgraph "Module Federation Plugins"
        GenAI[Gen AI Plugin]
        ModelRegPlugin[Model Registry Plugin]
        FeatureStore[Feature Store Plugin]
        LMEval[LM Eval Plugin]
        KServePlugin[KServe Plugin]
        ModelServing[Model Serving Plugin]
        ModelTraining[Model Training Plugin]
    end

    %% User flow
    User -->|HTTPS/443| OSRouter
    OSRouter -->|routes via| OSRoute
    OSRoute -->|HTTPS/8443| OAuthProxy

    %% Authentication
    OAuthProxy -->|OAuth flow| OSAuth

    %% Backend to external systems
    Backend -->|ServiceAccount Token| K8sAPI
    Backend -->|queries metrics| Prometheus

    %% CRD interactions
    Backend -->|reads/writes| OdhApplication
    Backend -->|reads/writes| OdhDashboardConfig
    Backend -->|reads| OdhDocument
    Backend -->|reads| OdhQuickStart
    Backend -->|reads| HardwareProfile
    Backend -->|reads| AcceleratorProfile

    %% Internal component interactions
    Backend -->|reads| ODHOperator
    Backend -->|manages| KubeflowNotebooks
    Backend -->|reads status| KServe
    Backend -->|manages| ModelRegistry
    Backend -->|interacts| ODHModelController
    Backend -->|integrates| DSPipelines
    Backend -->|displays metrics| TrustyAI
    Backend -->|manages queues| Kueue
    Backend -->|manages workloads| CodeFlare

    %% Plugin loading
    ModuleFed -->|loads| GenAI
    ModuleFed -->|loads| ModelRegPlugin
    ModuleFed -->|loads| FeatureStore
    ModuleFed -->|loads| LMEval
    ModuleFed -->|loads| KServePlugin
    ModuleFed -->|loads| ModelServing
    ModuleFed -->|loads| ModelTraining

