graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["This component does not define its own RBAC resources.<br/>RBAC is managed by KServe and the platform operator."]
    end

    subgraph KServeManaged["KServe-Managed RBAC"]
        direction TB

        subgraph SA["Service Accounts"]
            InferSA["InferenceService SA<br/>(user-defined in ISVC spec)<br/>Namespace: {user-namespace}"]
        end

        subgraph Roles["Platform Roles (KServe-managed)"]
            KServeRole["KServe Controller Role<br/>Manages ServingRuntime &<br/>InferenceService lifecycle"]
        end
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        subgraph Endpoints["Endpoint Auth"]
            HTTP_Auth["HTTP Inference :8080<br/>Auth: mTLS (Istio sidecar)<br/>+ Knative passthrough<br/>Policy: PeerAuthentication STRICT"]
            GRPC_Auth["gRPC Inference :8085<br/>Auth: mTLS (Istio sidecar)<br/>+ Knative passthrough<br/>Policy: PeerAuthentication STRICT"]
            Metrics_Auth["Metrics :8086<br/>Auth: PERMISSIVE mTLS<br/>PeerAuthentication port-level override<br/>Allows Prometheus without client certs"]
        end
    end

    subgraph NetworkPolicies["Network Policies"]
        NP["NetworkPolicy: uwm-ingress<br/>Ingress to port 8086<br/>Allowed from: openshift-user-workload-monitoring"]
    end

    subgraph Secrets["Secrets"]
        S3Creds["(S3 credentials)<br/>Type: Opaque<br/>Purpose: Model storage access<br/>Provisioned by: User / operator<br/>Auto-rotate: No"]
        GitAuth["(git-auth)<br/>Type: Opaque<br/>Purpose: Konflux pipeline auth<br/>Provisioned by: Pipelines-as-Code<br/>Auto-rotate: No"]
    end

    InferSA -->|"runs pods as"| HTTP_Auth
    InferSA -->|"runs pods as"| GRPC_Auth
    InferSA -->|"runs pods as"| Metrics_Auth

    NP -->|"controls access to"| Metrics_Auth

    S3Creds -->|"mounted in"| InferSA

    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style InferSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333
    style HTTP_Auth fill:#d5e8d4,stroke:#82b366
    style GRPC_Auth fill:#d5e8d4,stroke:#82b366
    style Metrics_Auth fill:#ffe6cc,stroke:#d79b00
    style NP fill:#e1d5e7,stroke:#9673a6
    style S3Creds fill:#f8cecc,stroke:#b85450
    style GitAuth fill:#f8cecc,stroke:#b85450
