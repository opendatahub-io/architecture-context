/*
 * Feast Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/feast.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist / ML Engineer" "Creates FeatureStore CRs and consumes features for ML models"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform and Feast operator deployment"

        feastOperator = softwareSystem "Feast Operator" "Kubernetes operator that manages the lifecycle of Feast feature store deployments on OpenShift" {
            controller = container "FeatureStore Controller" "Reconciles FeatureStore CRs; creates Deployments, Services, ConfigMaps, PVCs, RBAC, CronJobs, Routes" "Go Operator (controller-runtime)"
            authzModule = container "Authorization Module" "Deploys Kubernetes RBAC Roles/RoleBindings for Feast permission model; supports OIDC auth" "Go Reconciler Logic"
            namespaceRegistry = container "Namespace Registry" "Cross-namespace ConfigMap tracking all deployed FeatureStore instances" "ConfigMap: feast-configs-registry"
        }

        feastServices = softwareSystem "Feast Services" "Dynamically created per FeatureStore CR - serves features to ML applications" {
            onlineStore = container "Feature Server (Online Store)" "Serves online features via HTTP/HTTPS" "Python 3.11, port 6566/6567"
            offlineStore = container "Offline Store Server" "Serves offline features via gRPC" "Python 3.11, port 8815/8816"
            registryServer = container "Registry Server" "Feature registry via gRPC and REST API" "Python 3.11, gRPC 6570/6571, REST 6572/6573"
            uiServer = container "UI Server" "Web UI for browsing feature store" "Python 3.11, port 8888/8443"
            cronJob = container "CronJob" "Executes feast apply and materialization commands" "Kubernetes CronJob, ose-cli"
        }

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys feast-operator via kustomize overlay" "Internal RHOAI"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        openshiftCerts = softwareSystem "OpenShift Service Serving Certificates" "Automatic TLS certificate provisioning" "External"
        trustedCABundle = softwareSystem "OpenShift Trusted CA Bundle" "Custom CA bundle for disconnected environments" "External"
        externalDB = softwareSystem "External Database" "PostgreSQL, Redis, Snowflake - persistence backends" "External"
        objectStorage = softwareSystem "S3/GCS Object Storage" "Registry file persistence" "External"
        gitRepos = softwareSystem "Git Repositories" "Feature store repository sources" "External"
        mlApplication = softwareSystem "ML Application" "Consumes features for inference and training" "Internal"

        # User interactions
        dataScientist -> feastOperator "Creates FeatureStore CR via kubectl/API"
        dataScientist -> feastServices "Queries features for ML models" "HTTP/gRPC"
        dataScientist -> uiServer "Browses feature store" "HTTPS/443 via OpenShift Route"
        platformAdmin -> rhodsOperator "Deploys Feast operator"

        # Operator dependencies
        rhodsOperator -> feastOperator "Deploys via kustomize overlays/rhoai"
        feastOperator -> kubernetesAPI "CRUD operations on resources" "HTTPS/443"
        feastOperator -> openshiftCerts "Auto-provisions TLS certs" "Service annotation"
        feastOperator -> trustedCABundle "Mounts custom CA bundle" "ConfigMap mount"
        controller -> authzModule "Delegates authorization setup"
        controller -> namespaceRegistry "Updates cross-namespace registry"

        # Feast service dependencies
        feastOperator -> feastServices "Creates and manages service deployments"
        onlineStore -> registryServer "Fetches feature metadata" "gRPC/80 or 443"
        offlineStore -> registryServer "Fetches feature metadata" "gRPC/80 or 443"
        cronJob -> onlineStore "kubectl exec: feast apply + materialize"
        mlApplication -> onlineStore "Feature serving requests" "HTTP/HTTPS 80/443"

        # External service connections
        onlineStore -> externalDB "Query/store features" "Various ports, TLS configurable"
        offlineStore -> externalDB "Query offline features" "Various ports, TLS configurable"
        registryServer -> objectStorage "Registry file persistence" "HTTPS/443"
        feastServices -> gitRepos "Clone feature repositories" "HTTPS/443"
    }

    views {
        systemContext feastOperator "FeastSystemContext" {
            include *
            autoLayout
        }

        container feastOperator "FeastOperatorContainers" {
            include *
            autoLayout
        }

        container feastServices "FeastServicesContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
