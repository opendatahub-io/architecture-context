                CacheWebhook["cache-server<br/>8443/TCP HTTPS TLS<br/>Mutating Admission Webhook"]
            end

            subgraph AgentsGroup["Controllers & Agents"]
                PA["ds-pipeline-persistenceagent<br/>SA: ds-pipeline-persistenceagent"]
                SW["ds-pipeline-scheduledworkflow<br/>SA: ds-pipeline-scheduledworkflow"]
                ViewerCtrl["ds-pipeline-viewer-crd-controller"]
            end

            subgraph MetadataGroup["ML Metadata"]
                MetaWriter["metadata-writer<br/>(Python)"]
