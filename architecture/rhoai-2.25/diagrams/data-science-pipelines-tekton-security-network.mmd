                MetaGRPC["metadata-grpc-server<br/>8080/TCP gRPC"]
            end

            subgraph VizGroup["Visualization"]
                VizServer["ds-pipeline-visualizationserver<br/>8888/TCP HTTP"]
            end

            subgraph DataStores["Data Stores"]
                MySQL["MariaDB/MySQL<br/>3306/TCP<br/>Auth: Username/Password"]
