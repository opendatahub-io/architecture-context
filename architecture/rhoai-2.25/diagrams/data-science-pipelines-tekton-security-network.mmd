            end
        end
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        Tekton["Tekton Pipelines<br/>>= 0.41.0"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>8888/TCP HTTP /metrics"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OpenShift OAuth"| Route

    %% Ingress to UI
    Route -->|"HTTPS/8443<br/>TLS serving-cert<br/>OAuth validated"| OAuthProxy
    OAuthProxy -->|"HTTP/3000<br/>Authenticated"| DSPUI

    %% UI to API
    DSPUI -->|"HTTP/8888<br/>No encryption<br/>kubeflow-userid header"| APIServer

    %% API to data stores
    APIServer -->|"MySQL/3306<br/>No encryption<br/>Username/Password"| MySQL
    APIServer -->|"HTTP/9000<br/>No encryption<br/>AccessKey/SecretKey"| MinIO

    %% API to K8s
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Agents to K8s and API
    PA -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Watch PipelineRun"| K8sAPI
    PA -->|"HTTP/8888<br/>Sync status"| APIServer
    SW -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Watch/Create"| K8sAPI

    %% Metadata flow
    MetaWriter -->|"gRPC/9090<br/>No encryption"| MetaEnvoy
    MetaEnvoy -->|"gRPC/8080<br/>No encryption"| MetaGRPC
    MetaGRPC -->|"MySQL/3306<br/>Username/Password"| MySQL

    %% Pipeline pods
    K8sAPI -->|"Reconcile"| Tekton
    Prometheus -->|"HTTP/8888<br/>/metrics"| APIServer

    %% Cache webhook
    K8sAPI -->|"HTTPS/8443<br/>TLS<br/>Webhook cert"| CacheWebhook

