graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(UI / SDK / CLI)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES (Internal - ClusterIP)"]
        direction TB

        subgraph NS_DSPT["Namespace: (deployment namespace)"]
            APIServer["ds-pipeline API Server<br/>SA: ds-pipeline<br/>8888/TCP HTTP | 8887/TCP gRPC<br/>AuthN: TokenReview + Header<br/>AuthZ: SubjectAccessReview"]

            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent<br/>No listener (gRPC client)<br/>Scope: Cluster-wide"]

            SWController["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow<br/>No listener (controller)"]

            CacheServer["Cache Server<br/>8443/TCP HTTPS<br/>POST /mutate<br/>Auth: TLS cert (webhook)<br/>Image: alpine (non-FIPS)"]

            VizServer["Visualization Server<br/>8888/TCP HTTP<br/>Auth: None<br/>Internal only"]

            LoopWebhook["Pipeline-Loops Webhook<br/>8443/TCP HTTPS<br/>/defaulting, /resource-validation<br/>Auth: TLS cert (Knative)"]

            PipelineRunner["Pipeline Runner Pod<br/>SA: pipeline-runner<br/>RBAC: wildcard perms"]
        end
    end

    subgraph DataStores["DATA STORES"]
        MySQL[("MySQL 5.7+<br/>3306/TCP<br/>Plaintext<br/>Username/Password")]
        MinIO[("MinIO / S3<br/>Configurable port<br/>HTTP or HTTPS<br/>Access Key/Secret")]
    end

    subgraph ExternalServices["EXTERNAL INTEGRATIONS"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount tokens"]
        Tekton["Tekton Pipelines<br/>(via K8s API)"]
        MLMD["ML Metadata<br/>gRPC<br/>No encryption"]
        Prometheus["Prometheus<br/>GET /metrics<br/>HTTP 8888/TCP"]
    end

    %% Client to API Server
    Client -->|"HTTP 8888/TCP or gRPC 8887/TCP<br/>No encryption (plaintext)<br/>Auth: Bearer Token<br/>+ Header identity"| APIServer

    %% API Server outbound
    APIServer -->|"MySQL 3306/TCP<br/>Plaintext<br/>Username/Password"| MySQL
    APIServer -->|"HTTP/HTTPS configurable<br/>Access Key/Secret"| MinIO
    APIServer -->|"HTTPS 443/TCP<br/>TLS, SA token<br/>PipelineRun CRUD + SAR + TR"| K8sAPI
    APIServer -->|"HTTP 8888/TCP<br/>No auth"| VizServer

    %% Persistence Agent outbound
    PersistenceAgent -->|"gRPC 8887/TCP<br/>No encryption<br/>No auth (internal)"| APIServer
    PersistenceAgent -->|"HTTPS 443/TCP<br/>TLS, SA token<br/>Watch PipelineRuns"| K8sAPI

    %% Scheduled Workflow Controller
    SWController -->|"HTTPS 443/TCP<br/>TLS, SA token<br/>Watch SWF, Create PR"| K8sAPI

    %% Cache Server
    K8sAPI -->|"HTTPS 8443/TCP<br/>TLS cert<br/>MutatingWebhook"| CacheServer
    CacheServer -->|"MySQL 3306/TCP<br/>Plaintext<br/>Username/Password"| MySQL

    %% Pipeline-Loops Webhook
    K8sAPI -->|"HTTPS 8443/TCP<br/>TLS cert<br/>ValidatingWebhook"| LoopWebhook

    %% Pipeline Runner
    PipelineRunner -->|"HTTPS 443/TCP<br/>TLS, SA token<br/>Resource CRUD"| K8sAPI
    PipelineRunner -->|"HTTP/HTTPS<br/>Access Key/Secret"| MinIO

    %% Prometheus scraping
    Prometheus -->|"HTTP 8888/TCP<br/>GET /metrics<br/>No auth"| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class APIServer,PersistenceAgent,SWController,CacheServer,VizServer,LoopWebhook platform
    class PipelineRunner warning
    class MySQL,MinIO datastore
    class K8sAPI,Tekton,MLMD,Prometheus extservice
