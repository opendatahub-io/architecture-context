// vLLM (CUDA TGIS Adapter) - C4 Context Diagram
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/vllm.md

workspace {
    model {
        user = person "Data Scientist / Application" "Sends inference requests to deployed LLM models"

        vllm = softwareSystem "vLLM CUDA TGIS Adapter" "GPU-accelerated LLM inference runtime with OpenAI-compatible HTTP and TGIS-compatible gRPC APIs" {
            tgisAdapter = container "vllm_tgis_adapter" "Python entrypoint that wraps vLLM engine with TGIS gRPC and OpenAI HTTP interfaces" "Python Module"
            httpServer = container "HTTP API Server" "OpenAI-compatible completions API on port 8000" "HTTP/REST"
            grpcServer = container "TGIS gRPC Server" "TGIS GenerationService on port 8033" "gRPC"
            vllmEngine = container "vLLM Engine" "High-performance LLM inference engine with CUDA support" "Python/C++ (from RHAIIS base image)"
        }

        kserve = softwareSystem "KServe" "Manages inference service lifecycle and deploys ServingRuntime pods" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Alternative multi-model serving deployment path" "Internal RHOAI"
        istio = softwareSystem "Istio / Gateway API" "Provides ingress gateway, mTLS, and AuthorizationPolicy" "External"
        prometheus = softwareSystem "Prometheus" "Collects inference metrics from vLLM" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage" "S3 or PVC providing model weight artifacts" "External"
        nvidiaGPU = softwareSystem "NVIDIA GPU" "GPU hardware for CUDA-accelerated inference" "Infrastructure"
        konflux = softwareSystem "Konflux CI/CD" "Builds container images via Tekton pipelines" "External"

        // User interactions
        user -> vllm "Sends inference requests" "HTTPS/443"

        // Internal container relationships
        tgisAdapter -> httpServer "Starts and manages"
        tgisAdapter -> grpcServer "Starts and manages"
        tgisAdapter -> vllmEngine "Wraps"

        // External dependencies
        kserve -> vllm "Deploys as ServingRuntime" "Kubernetes API"
        modelmesh -> vllm "Deploys as ServingRuntime" "Kubernetes API"
        vllm -> modelStorage "Downloads model weights at startup" "HTTPS/443 or PVC volume"
        vllm -> nvidiaGPU "Executes model inference" "CUDA"
        prometheus -> vllm "Scrapes metrics" "HTTP/8000"
        konflux -> vllm "Builds container image" "Tekton Pipeline"
    }

    views {
        systemContext vllm "SystemContext" {
            include *
            autoLayout
        }

        container vllm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
