graph TB
    subgraph KServe["KServe Platform (v0.14.0)"]
        direction TB

        subgraph ControlPlane["Control Plane"]
            ControllerMgr["kserve-controller-manager<br/>(Go Operator)<br/>Ports: 9443, 8080, 8081"]
            Webhook["Admission Webhooks<br/>/mutate-pods<br/>/validate-*, /mutate-*"]
            ControllerMgr --- Webhook
        end

        subgraph Controllers["Controllers (in controller-manager)"]
            ISvcCtrl["InferenceService<br/>Controller"]
            IGCtrl["InferenceGraph<br/>Controller"]
            TMCtrl["TrainedModel<br/>Controller"]
            LLMCtrl["LLMInferenceService<br/>Controller"]
        end

        subgraph LocalModelSubsystem["Local Model Caching Subsystem"]
            LMController["kserve-localmodel-controller<br/>(Go Controller)<br/>Ports: 8080, 8081"]
            LMNodeAgent["kserve-localmodelnode-agent<br/>(Go DaemonSet)<br/>Ports: 8080, 8081"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            Agent["kserve-agent<br/>(Go Sidecar)<br/>Port: 9081"]
            Router["kserve-router<br/>(Go Sidecar)<br/>Port: 80"]
            StorageInit["kserve-storage-initializer<br/>(Python Init Container)<br/>No ports"]
        end

        ControllerMgr --> ISvcCtrl
        ControllerMgr --> IGCtrl
        ControllerMgr --> TMCtrl
        ControllerMgr --> LLMCtrl
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>(v1beta1, Namespaced)"]
        SR["ServingRuntime<br/>(v1alpha1, Namespaced)"]
        CSR["ClusterServingRuntime<br/>(v1alpha1, Cluster)"]
        IG["InferenceGraph<br/>(v1alpha1, Namespaced)"]
        TM["TrainedModel<br/>(v1alpha1, Namespaced)"]
        LLMISVC["LLMInferenceService<br/>(v1alpha1, Namespaced)"]
        LMC["LocalModelCache<br/>(v1alpha1, Cluster)"]
    end

    %% User interactions
    User[Data Scientist / User] -->|creates| ISVC
    User -->|creates| LLMISVC
    User -->|creates| IG
    User -->|creates| LMC

    %% Controller watches
    ISvcCtrl -->|watches & reconciles| ISVC
    IGCtrl -->|watches & reconciles| IG
    TMCtrl -->|watches & reconciles| TM
    LLMCtrl -->|watches & reconciles| LLMISVC
    LMController -->|watches & reconciles| LMC

    %% What controllers create
    ISvcCtrl -->|creates| KnativeService["Knative Service<br/>(Serverless mode)"]
    ISvcCtrl -->|creates| K8sDeploy["Kubernetes Deployment<br/>(Raw mode)"]
    ISvcCtrl -->|creates| HTTPRoute["HTTPRoute / VirtualService"]
    LLMCtrl -->|creates| LWS["LeaderWorkerSet<br/>(Multi-node LLM)"]
    LLMCtrl -->|creates| InfPool["InferencePool +<br/>InferenceModel"]
    LMController -->|creates| PVPVC["PV / PVC"]
    LMNodeAgent -->|creates| DownloadJob["Download Jobs"]

    %% Webhook injection
    Webhook -->|injects into pods| Agent
    Webhook -->|injects into pods| StorageInit

    %% External dependencies
    ISvcCtrl -->|depends on| Knative["Knative Serving"]
    ISvcCtrl -->|depends on| Istio["Istio"]
    LLMCtrl -->|depends on| GatewayAPI["Gateway API"]
    LLMCtrl -->|depends on| KEDA["KEDA"]

    StorageInit -->|downloads from| CloudStorage["S3 / GCS / Azure / HF"]

    %% Styling
    style ControllerMgr fill:#4a90e2,stroke:#333,color:#fff
    style LMController fill:#4a90e2,stroke:#333,color:#fff
    style LMNodeAgent fill:#4a90e2,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style Router fill:#50c878,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#fff
    style LLMISVC fill:#f5a623,stroke:#333,color:#fff
    style IG fill:#f5a623,stroke:#333,color:#fff
    style LMC fill:#f5a623,stroke:#333,color:#fff
    style TM fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333
    style CSR fill:#f5a623,stroke:#333
    style Knative fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style CloudStorage fill:#e8e8e8,stroke:#333
