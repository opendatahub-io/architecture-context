    style KEDA fill:#999,stroke:#333,stroke-width:1px
    style CertManager fill:#999,stroke:#333,stroke-width:1px
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
