graph LR
    EPP["llm-d-inference-scheduler<br/>(EPP)"]

    %% Core External Dependencies (Required)
    EPP -->|"core framework<br/>v0.5.1-rc.1"| GIE["gateway-api-inference-extension<br/>(GIE) v0.5.1-rc.1"]
    EPP -->|"controller framework<br/>v0.21.0"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    EPP -->|"Gateway API types<br/>v1.3.0"| GatewayAPI["gateway-api<br/>v1.3.0"]
    EPP -->|"ext-proc protobuf<br/>v1.32.4"| EnvoyCP["envoy-go-control-plane<br/>v1.32.4"]
    EPP -->|"metrics<br/>v1.22.0"| PromClient["prometheus/client_golang<br/>v1.22.0"]
    EPP -->|"tracing<br/>v1.35.0"| OTEL["OpenTelemetry SDK<br/>v1.35.0"]

    %% Optional External Dependencies (cache_tracking mode)
    EPP -.->|"KV-cache indexer<br/>v0.2.0 (optional)"| KVCacheManager["llm-d-kv-cache-manager<br/>v0.2.0"]
    EPP -.->|"tokenizer FFI<br/>v1.20.2 (optional)"| Tokenizers["daulet/tokenizers<br/>v1.20.2 (Rust FFI)"]
    EPP -.->|"ZMQ bindings<br/>v1.4.0 (optional)"| ZMQ4["pebbe/zmq4<br/>v1.4.0"]
    KVCacheManager -.->|"KV state<br/>(indirect)"| GoRedis["redis/go-redis<br/>v9.11.0"]

    %% Internal Platform Dependencies
    EPP -->|"gRPC ext-proc<br/>9002/TCP"| EnvoyGW["Envoy Gateway<br/>(Gateway API impl)"]
    EPP -->|"pod metrics<br/>+ ZMQ events"| vLLMPods["vLLM Model-Serving Pods"]
    EPP -->|"CRD watch"| InferencePool["InferencePool CR"]
    EPP -->|"CRD watch"| InferenceModel["InferenceModel CR"]

    %% Integration Points (other components that interact with EPP)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>9090/TCP"| EPP
    OTELCollector["OTEL Collector"] -.->|"receives traces<br/>4317/TCP"| EPP
    HFHub["HuggingFace Hub"] -.->|"tokenizer download<br/>443/TCP"| EPP

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

