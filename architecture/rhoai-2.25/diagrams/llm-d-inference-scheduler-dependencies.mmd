    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style EnvoyCP fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff

    %% Optional dependencies
    style KVCacheManager fill:#b0bec5,stroke:#333,stroke-dasharray: 5 5
    style Tokenizers fill:#b0bec5,stroke:#333,stroke-dasharray: 5 5
    style ZMQ4 fill:#b0bec5,stroke:#333,stroke-dasharray: 5 5
    style GoRedis fill:#b0bec5,stroke:#333,stroke-dasharray: 5 5

    %% Internal platform
    style EnvoyGW fill:#7ed321,stroke:#333
    style vLLMPods fill:#7ed321,stroke:#333
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceModel fill:#f5a623,stroke:#333

    %% External services
    style Prometheus fill:#f5a623,stroke:#333
