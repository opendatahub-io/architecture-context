graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        Controller["ModelRegistry Controller<br/>(controller-runtime)<br/>Reconciles ModelRegistry CRs"]
        CatalogCtrl["ModelCatalog Controller<br/>(optional, ENABLE_MODEL_CATALOG)<br/>Deploys singleton catalog service"]
        MigrationMgr["Storage Migration Manager<br/>(background goroutine)<br/>v1alpha1 → v1beta1 migration"]
        Webhooks["Admission Webhooks<br/>9443/TCP HTTPS<br/>Mutating + Validating + Conversion"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        Metrics["Metrics Endpoint<br/>8443/TCP HTTPS<br/>/metrics (Bearer Token)"]
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(modelregistry.opendatahub.io/v1beta1)<br/>Namespaced"]
    PlatformCR["Platform ModelRegistry CR<br/>(components.platform.opendatahub.io)"]

    %% Managed Resources per ModelRegistry instance
    subgraph ManagedResources["Managed Resources (per ModelRegistry)"]
        direction TB
        MRDeployment["Deployment<br/>REST + gRPC containers<br/>+ optional OAuth proxy sidecar"]
        MRService["Service (ClusterIP)<br/>REST API endpoint"]
        MRRoute["OpenShift Route<br/>(optional, HTTP or HTTPS reencrypt)"]
        MRRBAC["ServiceAccount + Role<br/>+ RoleBinding + Groups"]
        MRNetPol["NetworkPolicy<br/>(when OAuth enabled)"]
        MRSecrets["Secrets<br/>OAuth cookie + TLS certs"]
    end

    %% Catalog Resources
    subgraph CatalogResources["Model Catalog Resources (singleton)"]
        direction TB
        CatalogDeploy["Catalog Deployment<br/>+ init container (data image)"]
        CatalogService["Catalog Service<br/>8443/TCP HTTPS"]
        CatalogRoute["Catalog Route<br/>HTTPS reencrypt"]
    end

    %% Flows
    ModelRegistryCR -->|watched by| Controller
    Controller -->|creates/updates| ManagedResources
    PlatformCR -->|watched by| CatalogCtrl
    CatalogCtrl -->|creates/updates| CatalogResources

    %% K8s API interactions
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Controller -->|CRUD resources| K8sAPI
    MigrationMgr -->|StorageVersionMigration| K8sAPI
    Webhooks -->|called by| K8sAPI

    %% Backend
    MRDeployment -->|connects to| Database["PostgreSQL / MySQL<br/>Metadata Storage"]

