    subgraph OperatorPod["Model Registry Operator Pod"]
        direction TB
        Reconciler["ModelRegistryReconciler<br/>(Go Controller)"]
        CatalogReconciler["ModelCatalogReconciler<br/>(Go Controller)"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS"]
        MigrationMgr["StorageMigrationManager<br/>(Background Process)"]
        TemplateEngine["Template Engine<br/>(Internal Utility)"]

        Reconciler --> TemplateEngine
        CatalogReconciler --> TemplateEngine
    end

    subgraph RegistryInstance["Per Model Registry Instance"]
        direction TB
        OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS"]
        RESTContainer["model-registry REST<br/>8080/TCP HTTP"]
        OAuthProxy -->|localhost| RESTContainer
    end

    subgraph CatalogInstance["Model Catalog Instance"]
        direction TB
        CatalogInit["catalog-data-init<br/>(Init Container)"]
        CatalogOAuth["oauth-proxy sidecar<br/>8443/TCP HTTPS"]
        CatalogContainer["model-catalog<br/>8080/TCP HTTP"]
        CatalogInit -->|shared volume| CatalogContainer
        CatalogOAuth -->|localhost| CatalogContainer
    end

    %% CRDs
    User["User / rhods-operator"] -->|creates| ModelRegistryCR["ModelRegistry CR<br/>(v1beta1)"]
    ModelRegistryCR -->|watched by| Reconciler
    ModelRegistryCR -->|validated by| WebhookServer

    %% Operator creates resources
    Reconciler -->|creates| RegistryInstance
    Reconciler -->|creates| Route["OpenShift Route<br/>(reencrypt)"]
    Reconciler -->|creates| NetworkPolicy["NetworkPolicy"]
    Reconciler -->|creates| RBAC["Role/RoleBinding/<br/>ClusterRoleBinding"]

    CatalogReconciler -->|creates| CatalogInstance
    CatalogReconciler -->|reads| PlatformCR["components.platform<br/>ModelRegistry CR"]

    MigrationMgr -->|migrates| CRDVersions["CRD Storage Versions<br/>v1alpha1 -> v1beta1"]

    %% External dependencies
    RESTContainer -->|connects to| Database["PostgreSQL / MySQL"]
    Route -->|routes to| OAuthProxy
    OAuthProxy -->|authenticates via| OpenShiftOAuth["OpenShift OAuth"]

