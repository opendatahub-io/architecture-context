graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(not shipped in RHOAI)"]
        SA_Workflow["(workflow-specified SA)<br/>(argoexec in Pods)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Argo["argo-cluster-role-binding<br/>(cluster-wide)"]
        CRB_Server["argo-server-cluster-role-binding<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Argo["argo-role-binding<br/>(deployment namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/>(not shipped in RHOAI)"]
        CR_View["argo-aggregate-to-view"]
        CR_Edit["argo-aggregate-to-edit"]
        CR_Admin["argo-aggregate-to-admin"]
    end

    subgraph Roles["Namespace Roles"]
        R_Argo["argo-role<br/>(deployment namespace)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/exec"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims"]
        ServiceAcctsRes["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Secrets["core<br/>secrets<br/>(named: argo-workflows-agent-ca-certificates)"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph ArgoResources["Argo CRD Resources (argoproj.io)"]
        Workflows["workflows<br/>+ finalizers"]
        WorkflowTemplates["workflowtemplates<br/>+ finalizers"]
        ClusterWFTemplates["clusterworkflowtemplates<br/>+ finalizers"]
        CronWorkflows["cronworkflows<br/>+ finalizers"]
        TaskSets["workflowtasksets<br/>+ finalizers"]
        ArtifactGC["workflowartifactgctasks"]
        TaskResults["workflowtaskresults"]
        EventBindings["workfloweventbindings"]
    end

    %% Bindings
    SA_Argo -->|"bound via"| CRB_Argo
    SA_Argo -->|"bound via"| RB_Argo
    SA_Server -->|"bound via"| CRB_Server

    CRB_Argo -->|"grants"| CR_Argo
    CRB_Server -->|"grants"| CR_Server
    RB_Argo -->|"grants"| R_Argo

    %% argo-cluster-role permissions
    CR_Argo -->|"create, get, list, watch,<br/>update, patch, delete"| Pods
    CR_Argo -->|"get, watch, list"| ConfigMaps
    CR_Argo -->|"create, update, delete, get"| PVCs
    CR_Argo -->|"get, list"| ServiceAcctsRes
    CR_Argo -->|"create, patch"| Events
    CR_Argo -->|"get (named only)"| Secrets
    CR_Argo -->|"create, get, delete"| PDBs
    CR_Argo -->|"full CRUD"| Workflows
    CR_Argo -->|"get, list, watch"| WorkflowTemplates
    CR_Argo -->|"get, list, watch"| ClusterWFTemplates
    CR_Argo -->|"full CRUD"| CronWorkflows
    CR_Argo -->|"full CRUD"| TaskSets
    CR_Argo -->|"full CRUD"| ArtifactGC
    CR_Argo -->|"list, watch, deletecollection"| TaskResults

    %% Aggregate roles
    CR_View -->|"get, list, watch"| Workflows
    CR_View -->|"get, list, watch"| WorkflowTemplates
    CR_View -->|"get, list, watch"| CronWorkflows
    CR_Edit -->|"full CRUD"| Workflows
    CR_Edit -->|"full CRUD"| WorkflowTemplates
    CR_Edit -->|"full CRUD"| CronWorkflows
    CR_Admin -->|"full CRUD + TaskSets"| Workflows

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#999,stroke:#333,color:#fff
    style SA_Workflow fill:#4a90e2,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333,color:#fff
    style CR_Server fill:#999,stroke:#333,color:#fff
    style CR_View fill:#f5a623,stroke:#333,color:#fff
    style CR_Edit fill:#f5a623,stroke:#333,color:#fff
    style CR_Admin fill:#f5a623,stroke:#333,color:#fff
    style R_Argo fill:#f5a623,stroke:#333,color:#fff
    style Workflows fill:#7ed321,stroke:#333,color:#fff
    style WorkflowTemplates fill:#7ed321,stroke:#333,color:#fff
    style ClusterWFTemplates fill:#7ed321,stroke:#333,color:#fff
    style CronWorkflows fill:#7ed321,stroke:#333,color:#fff
    style TaskSets fill:#7ed321,stroke:#333,color:#fff
    style ArtifactGC fill:#7ed321,stroke:#333,color:#fff
    style TaskResults fill:#7ed321,stroke:#333,color:#fff
    style EventBindings fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#dae8fc,stroke:#6c8ebf
    style ConfigMaps fill:#dae8fc,stroke:#6c8ebf
    style PVCs fill:#dae8fc,stroke:#6c8ebf
    style ServiceAcctsRes fill:#dae8fc,stroke:#6c8ebf
    style Events fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#dae8fc,stroke:#6c8ebf
    style PDBs fill:#dae8fc,stroke:#6c8ebf
