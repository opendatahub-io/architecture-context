graph TB
    subgraph InternalClients["INTERNAL CLIENTS (Trusted - same cluster)"]
        DSPCtrl["DSP Pipeline Controller<br/>SA: managed by DSP operator"]
        DSPUI["DSP UI / Pipeline SDK"]
    end

    subgraph Service["SERVICE (Internal ClusterIP - No external ingress)"]
        MLMD["MLMD gRPC Server<br/>metadata_store_server<br/>Container: odh-mlmd-grpc-server<br/>Port: 8080/TCP gRPC/HTTP2<br/>UID: 65534 (non-root)<br/>TLS: Optional (SSLConfig)<br/>Auth: Optional mTLS (client_verify)<br/>No app-level token/RBAC"]
    end

    subgraph DatabaseBackends["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL protocol<br/>Optional TLS (SSLOptions)<br/>Auth: Username/password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL protocol<br/>Optional TLS (SSLOptions)<br/>Auth: Username/password"]
    end

    subgraph Operator["DEPLOYMENT MANAGEMENT"]
        DSPOp["data-science-pipelines-operator<br/>Deploys & configures MLMD"]
    end

    %% Client → MLMD flows
    DSPCtrl -->|"gRPC/HTTP2 | 8080/TCP<br/>Optional TLS<br/>Optional mTLS (client_verify)"| MLMD
    DSPUI -->|"gRPC/HTTP2 | 8080/TCP<br/>Optional TLS<br/>Optional mTLS (client_verify)"| MLMD

    %% MLMD → Database flows
    MLMD -->|"MySQL protocol | 3306/TCP<br/>Optional TLS (SSLOptions)<br/>Auth: Username/password"| MySQL
    MLMD -->|"PostgreSQL protocol | 5432/TCP<br/>Optional TLS (SSLOptions)<br/>Auth: Username/password"| PostgreSQL

    %% Operator management
    DSPOp -.->|"Deployment management<br/>No network traffic"| MLMD

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#f9f9f9,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class DSPCtrl,DSPUI internal
    class MLMD service
    class MySQL,PostgreSQL database
    class DSPOp operator
