graph LR
    Sidecar["llm-d-routing-sidecar<br/>Go HTTP Reverse Proxy"]

    %% Internal Platform Dependencies
    Sidecar -->|"HTTP(S) reverse proxy<br/>8001/TCP (localhost)"| Decoder["vLLM Decoder<br/>(co-located)"]
    Sidecar -->|"HTTP(S) reverse proxy<br/>dynamic port<br/>x-prefiller-host-port"| Prefillers["vLLM Prefiller Pods<br/>(remote)"]
    Sidecar -->|"K8s Watch<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io<br/>/v1alpha2"]
    Sidecar -->|"K8s Watch<br/>HTTPS/443"| K8sPods["Kubernetes Pods<br/>(matching selector)"]

    %% Integration: EPP sets headers
    EPP["Gateway API<br/>Inference Extension<br/>(EPP/Scheduler)"] -->|"sets x-prefiller-host-port<br/>and x-request-id headers"| Sidecar

    %% External Go Dependencies
    subgraph GoDeps["Go Dependencies"]
        logr["go-logr/logr<br/>v1.4.2"]
        uuid["google/uuid<br/>v1.6.0"]
        lru["hashicorp/golang-lru/v2<br/>v2.0.7"]
    end

    subgraph K8sDeps["Kubernetes Client Libraries"]
        apimachinery["k8s.io/apimachinery<br/>v0.31.3"]
        clientgo["k8s.io/client-go<br/>v0.31.3"]
        klog["k8s.io/klog/v2<br/>v2.130.1"]
        k8sutils["k8s.io/utils"]
    end

    Sidecar -.->|"logging"| logr
    Sidecar -.->|"request correlation"| uuid
    Sidecar -.->|"proxy caching<br/>(16 entries)"| lru
    Sidecar -.->|"unstructured types<br/>labels, watch"| apimachinery
    Sidecar -.->|"dynamic client<br/>informers"| clientgo
    Sidecar -.->|"structured logging"| klog
    Sidecar -.->|"set data structure<br/>(allowlist)"| k8sutils

    %% Platform Services
    Sidecar -->|"HTTPS/443<br/>SA Bearer Token"| K8sAPI["Kubernetes<br/>API Server"]

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#7ed321,stroke:#333
    style Prefillers fill:#f5a623,stroke:#333
    style InferencePool fill:#7ed321,stroke:#333
    style K8sPods fill:#7ed321,stroke:#333
    style EPP fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style logr fill:#ddd,stroke:#999
    style uuid fill:#ddd,stroke:#999
    style lru fill:#ddd,stroke:#999
    style apimachinery fill:#ddd,stroke:#999
    style clientgo fill:#ddd,stroke:#999
    style klog fill:#ddd,stroke:#999
    style k8sutils fill:#ddd,stroke:#999
