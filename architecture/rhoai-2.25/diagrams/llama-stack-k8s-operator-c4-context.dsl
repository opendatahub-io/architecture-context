/*
 * C4 Context Diagram - llama-stack-k8s-operator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/llama-stack-k8s-operator.md
 */

workspace {
    model {
        admin = person "Platform Admin" "Creates and manages LlamaStackDistribution CRs"
        datascientist = person "Data Scientist" "Consumes Llama Stack inference APIs"

        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Kubernetes operator that creates and manages Llama Stack server deployments for Meta Llama AI model inference" {
            reconciler = container "LlamaStackDistribution Reconciler" "Watches LlamaStackDistribution CRs and reconciles managed resources" "Go Controller (controller-runtime)"
            kustomizePipeline = container "Kustomize Manifest Pipeline" "Renders base manifests with custom Go plugins (NamePrefix, Namespace, FieldMutator, NetworkPolicyTransformer)" "Go / kustomize API"
            clusterInfo = container "ClusterInfo" "Detects operator namespace and resolves distribution name-to-image mappings" "Go"
            configMapWatcher = container "ConfigMap Watcher" "Watches referenced ConfigMaps and triggers rolling updates via hash annotations" "Go"
            metricsProxy = container "kube-rbac-proxy" "Provides authenticated metrics endpoint" "HTTPS/8443"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Managed Llama Stack distribution serving inference APIs" "Managed Resource" {
            serverPod = container "Llama Stack Server Pod" "Runs the Llama Stack distribution image" "Container / 8321/TCP HTTP"
            initPVC = container "Init: update-pvc-permissions" "Sets PVC ownership to 1001:0" "Init Container (root:0)"
            initCA = container "Init: ca-bundle-init" "Concatenates CA bundle files" "Init Container"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        openshift = softwareSystem "OpenShift Platform" "Container platform with SCC, Router, and ingress" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys this operator via kustomize overlays" "Internal RHOAI"
        odhCABundle = softwareSystem "ODH Trusted CA Bundle" "Platform CA certificate ConfigMap (auto-detected)" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        # Relationships
        admin -> llamaStackOperator "Creates LlamaStackDistribution CRs via kubectl"
        datascientist -> llamaStackServer "Sends inference requests" "HTTP/8321"

        llamaStackOperator -> k8sAPI "Watches CRs, creates/updates managed resources" "HTTPS/6443 TLS 1.2+"
        llamaStackOperator -> llamaStackServer "Queries health, providers, version" "HTTP/8321 plaintext"
        llamaStackOperator -> odhCABundle "Auto-detects and mounts CA certificates" "ConfigMap"

        rhodsOperator -> llamaStackOperator "Deploys via kustomize overlay" "kustomize"
        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTPS/8443 TLS"

        openshift -> llamaStackServer "Routes external traffic via Ingress" "HTTP/8321"
        llamaStackServer -> k8sAPI "Uses anyuid SCC via ClusterRoleBinding" "RBAC/SCC"

        # Internal container relationships
        reconciler -> kustomizePipeline "Renders manifests"
        reconciler -> clusterInfo "Resolves distribution images"
        reconciler -> configMapWatcher "Detects config changes"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "OperatorContainers" {
            include *
            autoLayout
        }

        container llamaStackServer "ServerContainers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed Resource" {
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
