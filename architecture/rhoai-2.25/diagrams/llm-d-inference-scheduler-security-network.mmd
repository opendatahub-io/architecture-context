graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        EnvoyGW["Envoy Gateway<br/>80/TCP (dev) / 443/TCP (prod)<br/>TLS edge (OpenShift Route)<br/>Auth: Model API key"]
    end

    subgraph Scheduler["SCHEDULER — Namespace: hc4ai-operator"]
        direction TB
        EPP["EPP ext-proc Server<br/>SA: $EPP_NAME<br/>StatefulSet (OpenShift)"]
        EPP_GRPC["gRPC ext-proc<br/>9002/TCP plaintext"]
        EPP_Health["gRPC Health<br/>9003/TCP plaintext"]
        EPP_Metrics["HTTP Metrics<br/>9090/TCP plaintext"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>SA token auth"]
    end

    subgraph ModelServing["MODEL-SERVING PODS — Namespace: hc4ai-operator"]
        direction TB
        vLLM["vLLM Pods<br/>8000/TCP HTTP plaintext<br/>(inference)"]
        vLLMZMQ["vLLM ZMQ PUB<br/>5557/TCP plaintext<br/>(KV-cache events)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>TLS 1.2+"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>Auth: HF_TOKEN"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP<br/>HTTP plaintext"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS<br/>80 or 443/TCP<br/>TLS if configured<br/>Model API key"| EnvoyGW
    EnvoyGW -->|"gRPC ext-proc<br/>9002/TCP<br/>plaintext<br/>No auth"| EPP_GRPC
    EPP_GRPC -->|"routing decision<br/>target pod IP:port"| EnvoyGW
    EnvoyGW -->|"HTTP<br/>8000/TCP<br/>plaintext<br/>No auth"| vLLM
    vLLM -->|"response"| EnvoyGW

    EPP -->|"HTTPS<br/>443/TCP<br/>TLS<br/>SA token"| K8sAPI
    vLLMZMQ -->|"ZMQ SUB<br/>5557/TCP<br/>plaintext<br/>No auth"| EPP

    EPP -->|"gRPC OTLP<br/>4317/TCP<br/>TLS 1.2+"| OTEL
    EPP -->|"HTTPS<br/>443/TCP<br/>HF_TOKEN"| HFHub
    Prometheus -->|"HTTP scrape<br/>9090/TCP<br/>plaintext"| EPP_Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef scheduler fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelserving fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class EnvoyGW ingress
    class EPP,EPP_GRPC,EPP_Health,EPP_Metrics scheduler
    class K8sAPI controlplane
    class vLLM,vLLMZMQ modelserving
    class OTEL,HFHub,Prometheus externalservice
