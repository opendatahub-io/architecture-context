// C4 Context Diagram: llm-d-inference-scheduler
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "ML Engineer / Client" "Sends inference requests to LLM models"

        llmDScheduler = softwareSystem "llm-d-inference-scheduler" "Endpoint Picker (EPP) that makes optimized routing decisions for LLM inference requests using Gateway API and Envoy ext-proc" {
            epp = container "EPP (Endpoint Picker)" "Main gRPC service handling Envoy ext-proc callbacks for routing decisions" "Go gRPC Service"
            filterPlugins = container "Filter Plugins" "Pluggable filters: by-label, by-label-selector, decode-filter, prefill-filter" "Go Plugin Framework"
            scorerPlugins = container "Scorer Plugins" "Pluggable scorers: load-aware, prefix-cache, session-affinity" "Go Plugin Framework"
            pdHandlers = container "P/D Handlers" "Profile handler and pre-request handler for disaggregated prefill/decode" "Go Plugin Framework"
            kvCacheTracking = container "KV-Cache Tracking" "Real-time KV-cache state tracking via ZMQ subscriptions" "Go Library"

            epp -> filterPlugins "Invokes filter pipeline"
            epp -> scorerPlugins "Invokes scorer pipeline"
            epp -> pdHandlers "Invokes P/D scheduling"
            epp -> kvCacheTracking "Queries cache state"
        }

        envoyGateway = softwareSystem "Envoy Gateway" "Gateway API implementation providing traffic routing and ext-proc support" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for watching CRDs, Pods, and EndpointSlices" "External"
        vllmPods = softwareSystem "vLLM Model-Serving Pods" "LLM inference backend pods in InferencePool" "Internal"
        vllmKVEvents = softwareSystem "vLLM KV-Events (ZMQ)" "ZMQ publisher for KV-cache events from vLLM instances" "Internal"
        vllmOrchestrator = softwareSystem "vLLM Orchestrator / Routing Sidecar" "Coordinates disaggregated prefill/decode across vLLM pods" "Internal"
        huggingface = softwareSystem "HuggingFace Hub" "Model and tokenizer artifact repository" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        user -> envoyGateway "Sends inference requests" "HTTP/80"
        envoyGateway -> llmDScheduler "Calls ext-proc for routing decisions" "gRPC/9002"
        llmDScheduler -> k8sAPI "Watches InferencePool, InferenceModel, Pods, EndpointSlices" "HTTPS/443"
        envoyGateway -> vllmPods "Routes inference requests to selected pod" "HTTP/8000"
        vllmKVEvents -> llmDScheduler "Streams KV-cache events" "ZMQ/5557"
        llmDScheduler -> huggingface "Downloads tokenizer models" "HTTPS/443"
        prometheus -> llmDScheduler "Scrapes metrics" "HTTP/9090"
        llmDScheduler -> vllmOrchestrator "Sets x-prefiller-host-port header for P/D" "HTTP header"
    }

    views {
        systemContext llmDScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmDScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
