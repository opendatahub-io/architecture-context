graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(NS: opendatahub)"]
        SA_MR["controller-manager-<br/>metrics-reader<br/>(NS: opendatahub)<br/>[RHOAI only]"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_MGR["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_METRICS["metrics-auth-rolebinding<br/>(cluster-scoped)"]
        CRB_READER["controller-manager-<br/>read-metrics<br/>(cluster-scoped)<br/>[RHOAI only]"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_LEADER["leader-election-rolebinding<br/>(NS: opendatahub)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_MGR["manager-role"]
        CR_METRICS["metrics-auth-role"]
        CR_READER["metrics-reader"]
        R_LEADER["leader-election-role<br/>(Role, namespaced)"]
    end

    %% Bindings
    SA_CM -->|bound via| CRB_MGR
    SA_CM -->|bound via| CRB_METRICS
    SA_CM -->|bound via| RB_LEADER
    SA_MR -->|bound via| CRB_READER

    CRB_MGR -->|grants| CR_MGR
    CRB_METRICS -->|grants| CR_METRICS
    CRB_READER -->|grants| CR_READER
    RB_LEADER -->|grants| R_LEADER

    subgraph ManagerRolePerms["manager-role Permissions"]
        direction TB

        subgraph CoreAPIs["Core API Group"]
            Events["events<br/>create, patch,<br/>update, watch"]
            Pods["pods<br/>delete, get, list,<br/>patch, update, watch"]
            PodsFin["pods/finalizers<br/>get, update"]
            PodsStat["pods/status<br/>get, patch"]
            PodTemplates["podtemplates<br/>create, delete, get,<br/>list, update, watch"]
            Secrets["secrets<br/>get, list,<br/>update, watch"]
            ReadOnly["limitranges,<br/>namespaces, nodes<br/>get, list, watch"]
        end

        subgraph KueueAPIs["kueue.x-k8s.io"]
            KueueFull["admissionchecks,<br/>clusterqueues, cohorts,<br/>localqueues, workloads<br/>FULL CRUD"]
            KueueRead["multikueueclusters,<br/>multikueueconfigs,<br/>provisioningrequestconfigs,<br/>workloadpriorityclasses<br/>get, list, watch"]
            KueueMgmt["resourceflavors,<br/>topologies<br/>delete, get, list,<br/>update, watch"]
        end

        subgraph JobAPIs["Job Framework APIs"]
            BatchJobs["batch/jobs<br/>get, list, patch,<br/>update, watch"]
            KubeflowJobs["kubeflow.org/*jobs<br/>(pytorch, tf, mpi,<br/>paddle, xgboost)<br/>get, list, patch,<br/>update, watch"]
            RayAPIs["ray.io/rayclusters,<br/>rayjobs<br/>get, list, patch,<br/>update, watch"]
            JobSetAPI["jobset.x-k8s.io<br/>get, list, patch,<br/>update, watch"]
            AppWrapperAPI["workload.codeflare.dev<br/>get, list, patch,<br/>update, watch"]
            LWSAPI["leaderworkerset.x-k8s.io<br/>get, list, watch"]
        end

        subgraph ClusterAPIs["Cluster APIs"]
            AdmReg["admissionregistration<br/>mutating/validating<br/>webhookconfigurations<br/>get, list, update, watch"]
            Apps["apps/deployments,<br/>replicasets, statefulsets<br/>get, list, watch"]
            ProvReq["autoscaling.x-k8s.io<br/>provisioningrequests<br/>FULL CRUD"]
            FlowControl["flowcontrol<br/>flowschemas,<br/>prioritylevelconfigs<br/>list, watch"]
            Scheduling["scheduling.k8s.io<br/>priorityclasses<br/>get, list, watch"]
            NodeRuntime["node.k8s.io<br/>runtimeclasses<br/>get, list, watch"]
        end
    end

    subgraph MetricsAuthPerms["metrics-auth-role Permissions"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph MetricsReaderPerms["metrics-reader Permissions"]
        MetricsURL["/metrics<br/>(non-resource URL)<br/>get"]
    end

    subgraph LeaderElectionPerms["leader-election-role Permissions"]
        Leases["coordination.k8s.io<br/>leases<br/>FULL CRUD"]
        ConfigMaps["configmaps<br/>get, list, watch,<br/>create, update,<br/>patch, delete"]
        LEEvents["events<br/>create, patch"]
    end

    %% Connect roles to permissions
    CR_MGR --> ManagerRolePerms
    CR_METRICS --> MetricsAuthPerms
    CR_READER --> MetricsReaderPerms
    R_LEADER --> LeaderElectionPerms

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_MR fill:#4a90e2,stroke:#333,color:#fff

    style CR_MGR fill:#f5a623,stroke:#333,color:#fff
    style CR_METRICS fill:#f5a623,stroke:#333,color:#fff
    style CR_READER fill:#f5a623,stroke:#333,color:#fff
    style R_LEADER fill:#f5a623,stroke:#333,color:#fff

    style CRB_MGR fill:#e1d5e7,stroke:#9673a6
    style CRB_METRICS fill:#e1d5e7,stroke:#9673a6
    style CRB_READER fill:#e1d5e7,stroke:#9673a6
    style RB_LEADER fill:#e1d5e7,stroke:#9673a6

    style KueueFull fill:#7ed321,stroke:#333,color:#fff
    style KueueRead fill:#b6d7a8,stroke:#333
    style KueueMgmt fill:#93c47d,stroke:#333
    style BatchJobs fill:#d5e8d4,stroke:#333
    style KubeflowJobs fill:#d5e8d4,stroke:#333
    style RayAPIs fill:#d5e8d4,stroke:#333
    style JobSetAPI fill:#d5e8d4,stroke:#333
    style AppWrapperAPI fill:#d5e8d4,stroke:#333
    style LWSAPI fill:#d5e8d4,stroke:#333
    style ProvReq fill:#7ed321,stroke:#333,color:#fff
