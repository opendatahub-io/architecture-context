graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kueue-leader-election-rolebinding<br/>RoleBinding - opendatahub]
        CRB3[kueue-metrics-auth-rolebinding<br/>RoleBinding - opendatahub]
        CRB4[kueue-metrics-reader-clusterrolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR1[kueue-manager-role<br/>ClusterRole]
        CR2[kueue-leader-election-role<br/>Role]
        CR3[kueue-metrics-auth-role<br/>Role]
        CR4[kueue-metrics-reader-role<br/>ClusterRole]
    end

    subgraph "User Roles (Data Scientists)"
        UserRole1[kueue-batch-user-role<br/>ClusterRole]
        UserRole2[kueue-clusterqueue-viewer-role<br/>ClusterRole]
        UserRole3[kueue-localqueue-viewer-role<br/>ClusterRole]
    end

    subgraph "Kueue CRD Resources"
        direction LR
        KueueCRD[kueue.x-k8s.io<br/>• Workload<br/>• ClusterQueue<br/>• LocalQueue<br/>• ResourceFlavor<br/>• AdmissionCheck<br/>• WorkloadPriorityClass<br/>• ProvisioningRequestConfig<br/>• MultiKueueConfig<br/>• MultiKueueCluster<br/>• Cohort<br/>• Topology]
    end

    subgraph "Core Resources"
        direction LR
        CoreResources[core API<br/>• Pods<br/>• Events<br/>• Namespaces<br/>• Nodes<br/>• Secrets<br/>• ConfigMaps<br/>• Leases]
    end

    subgraph "Batch & Workload Resources"
        direction LR
        BatchResources[• Jobs batch<br/>• Deployments apps<br/>• StatefulSets apps<br/>• JobSets jobset.x-k8s.io<br/>• ProvisioningRequests autoscaling.x-k8s.io]
    end

    subgraph "ML Training Resources"
        direction LR
        MLResources[kubeflow.org<br/>• TFJob<br/>• PyTorchJob<br/>• MPIJob<br/>• XGBoostJob<br/>• PaddleJob]
    end

    subgraph "Ray Resources"
        direction LR
        RayResources[ray.io<br/>• RayJob<br/>• RayCluster]
    end

    subgraph "AppWrapper Resources"
        direction LR
        AppWrapperResources[workload.codeflare.dev<br/>• AppWrapper]
    end

    subgraph "Webhook Resources"
        direction LR
        WebhookResources[admissionregistration.k8s.io<br/>• MutatingWebhookConfiguration<br/>• ValidatingWebhookConfiguration]
    end

    subgraph "Visibility API Resources"
        direction LR
        VisibilityResources[visibility.kueue.x-k8s.io<br/>• ClusterQueue/pendingworkloads<br/>• LocalQueue/pendingworkloads]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% Role Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    CRB4 -->|grants| CR4

    %% kueue-manager-role permissions
    CR1 -->|get, list, watch, create,<br/>update, patch, delete| KueueCRD
    CR1 -->|get, list, watch, create,<br/>update, patch| CoreResources
    CR1 -->|get, list, watch,<br/>patch, update| BatchResources
    CR1 -->|get, list, watch,<br/>patch, update| MLResources
    CR1 -->|get, list, watch,<br/>patch, update| RayResources
    CR1 -->|get, list, watch,<br/>patch, update| AppWrapperResources
    CR1 -->|get, list, watch, update| WebhookResources

    %% Leader election role
    CR2 -->|get, list, watch, create,<br/>update, patch, delete| ConfigMapsLeases[ConfigMaps, Leases<br/>coordination.k8s.io]

    %% Metrics roles
    CR3 -->|get| Namespaces[Namespaces]
    CR4 -->|get, list, watch| MetricsResources[Pods, Services, Endpoints]

    %% User roles
    UserRole1 -->|get, list, watch, create,<br/>update, patch, delete| UserWorkload[Workload CRD<br/>kueue.x-k8s.io]
    UserRole2 -->|get, list, watch| UserCQ[ClusterQueue CRD<br/>kueue.x-k8s.io]
    UserRole2 -->|get| VisibilityResources
    UserRole3 -->|get, list, watch| UserLQ[LocalQueue CRD<br/>kueue.x-k8s.io]

