    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB1 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB2 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB4 fill:#e8e8e8,stroke:#333,stroke-width:1px

    style UserRole1 fill:#7ed321,stroke:#333,stroke-width:2px
    style UserRole2 fill:#7ed321,stroke:#333,stroke-width:2px
    style UserRole3 fill:#7ed321,stroke:#333,stroke-width:2px

    style KueueCRD fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CoreResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style BatchResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style MLResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RayResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style AppWrapperResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style WebhookResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style VisibilityResources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
