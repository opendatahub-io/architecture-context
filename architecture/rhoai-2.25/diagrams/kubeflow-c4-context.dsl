/* C4 Context Diagram - ODH Notebook Controller (kubeflow)
   Generated by: Claude Opus 4.6
*/

workspace {
    model {
        user = person "Data Scientist" "Creates and manages notebook workbenches for ML development"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends upstream Kubeflow Notebook Controller with OpenShift-specific features: OAuth proxy injection, TLS routes, network policies, certificate management, and Elyra pipeline integration" {
            reconciler = container "OpenshiftNotebookReconciler" "Watches Notebook CRs and reconciles Routes, Services, ServiceAccounts, Secrets, OAuthClients, NetworkPolicies, ConfigMaps, and RoleBindings" "Go Controller (controller-runtime)"
            webhook = container "NotebookWebhook" "Intercepts Notebook create/update to inject OAuth proxy sidecar, CA bundles, pipeline runtime configs, proxy env vars, and ImageStream resolution" "Mutating Admission Webhook"
            oauthProxy = container "OAuth Proxy Sidecar" "Provides OpenShift OAuth authentication in front of notebook on port 8443/TCP, proxying to upstream localhost:8888" "ose-oauth-proxy (injected)"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller that manages StatefulSet/Service for Notebook CRs" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects and workbenches" "Internal ODH"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Manages DSPA CRs for ML pipeline infrastructure" "Internal ODH"

        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "Provides user authentication via OAuth protocol" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Provides ingress via Routes with TLS termination" "External"
        openshiftServiceCA = softwareSystem "OpenShift Service CA" "Auto-provisions TLS certificates for services" "External"
        openshiftImageRegistry = softwareSystem "OpenShift Image Registry" "Hosts container images via ImageStreams" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core API server for cluster operations" "External"

        # Relationships
        user -> odhNotebookController "Creates Notebook CR via kubectl/Dashboard"
        user -> oauthProxy "Accesses notebook UI via OAuth Route" "HTTPS/443"

        reconciler -> k8sAPI "Manages Routes, Services, Secrets, NetworkPolicies" "HTTPS/443"
        webhook -> k8sAPI "Resolves ImageStream tags" "HTTPS/443"
        reconciler -> odhDashboard "Reads Dashboard CR status.url for Elyra links" "HTTPS/443"
        reconciler -> dspOperator "Reads DSPA CR for Elyra runtime config" "HTTPS/443"

        oauthProxy -> openshiftOAuth "Authenticates users via OAuth flow" "HTTPS/443"
        oauthProxy -> k8sAPI "SubjectAccessReview checks" "HTTPS/443"

        reconciler -> openshiftRouter "Creates Routes per notebook" "HTTPS/443"
        openshiftServiceCA -> webhook "Provisions TLS certificates"
        openshiftServiceCA -> oauthProxy "Provisions TLS certificates"

        reconciler -> openshiftImageRegistry "Resolves notebook images from ImageStreams" "HTTPS/5000"

        odhNotebookController -> kubeflowNotebookController "Shares Notebook CR watch (both controllers reconcile)"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
