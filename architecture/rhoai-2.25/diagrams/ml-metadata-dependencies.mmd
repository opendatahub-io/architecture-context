graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% Internal RHOAI Dependencies
    MLMD -->|"gRPC client<br/>8080/TCP"| DSPCtrl["Data Science Pipelines<br/>(Controller)"]
    MLMD -->|"gRPC client<br/>8080/TCP"| DSPUI["Data Science Pipelines<br/>(UI / SDK)"]

    %% Database Backends
    MLMD -->|"MySQL protocol<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"PostgreSQL protocol<br/>5432/TCP"| PostgreSQL["PostgreSQL"]

    %% Build / Runtime Dependencies
    MLMD -->|"gRPC framework"| gRPC["gRPC C++ 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protobuf 3.21.12"]
    MLMD -->|"C++ utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"filter query parsing"| ZetaSQL["ZetaSQL"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL"]
    MLMD -->|"embedded DB"| SQLite["SQLite 3.39.2"]

    %% Deployment Management
    DSPOp["data-science-pipelines-operator"] -->|"deploys &<br/>configures"| MLMD

