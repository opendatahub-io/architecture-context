graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        MainBin["trustyai-service-operator<br/>Go Operator (controller-runtime)<br/>Ports: 8080/TCP metrics, 8081/TCP health"]

        subgraph Controllers["Controller Loops (--enable-services)"]
            TASCtrl["TAS Controller<br/>TrustyAIService Reconciler"]
            LMESCtrl["LMES Controller<br/>LMEvalJob Reconciler"]
            GORCHCtrl["GORCH Controller<br/>GuardrailsOrchestrator Reconciler"]
            JOBMGRCtrl["JOB_MGR Controller<br/>Kueue GenericJob Interface"]
        end

        MainBin --> TASCtrl
        MainBin --> LMESCtrl
        MainBin --> GORCHCtrl
        MainBin --> JOBMGRCtrl
    end

    subgraph ManagedWorkloads["Managed Workloads"]
        TASDeployment["TrustyAI Service Deployment<br/>+ OAuth Proxy Sidecar<br/>Ports: 8080, 8443, 4443"]
        LMEvalPod["LMEvalJob Pod<br/>Init: ta-lmes-driver (Go)<br/>Main: ta-lmes-job (Python/lm-eval)<br/>Sidecar: driver (port 18080)"]
        GORCHDeployment["GuardrailsOrchestrator Deployment<br/>+ OAuth Proxy Sidecar (optional)<br/>+ Gateway Sidecar (optional)<br/>Ports: 8032, 8090, 8034"]
    end

    %% CRDs
    TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1"]
    LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GuardrailsOrchestratorCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD → Controller
    TrustyAIServiceCR -->|watched by| TASCtrl
    LMEvalJobCR -->|watched by| LMESCtrl
    GuardrailsOrchestratorCR -->|watched by| GORCHCtrl

    %% Controller → Workloads
    TASCtrl -->|creates/manages| TASDeployment
    LMESCtrl -->|creates/manages| LMEvalPod
    GORCHCtrl -->|creates/manages| GORCHDeployment

    %% Created Resources
    TASCtrl -->|creates| Routes["OpenShift Routes<br/>(reencrypt TLS)"]
    TASCtrl -->|creates| ServiceMonitors["Prometheus<br/>ServiceMonitors"]
    TASCtrl -->|creates| IstioResources["Istio DestinationRules<br/>& VirtualServices<br/>(conditional)"]
    TASCtrl -->|patches| InferenceService["KServe<br/>InferenceService<br/>(adds TrustyAI logger)"]

    GORCHCtrl -->|creates| GORCHRoutes["OpenShift Routes<br/>(orchestrator, gateway, health)"]
    GORCHCtrl -->|reads| ServingRuntime["KServe<br/>ServingRuntime"]

    JOBMGRCtrl -->|creates| KueueWorkload["Kueue Workload<br/>(fair-share scheduling)"]

    %% External integrations
    TASDeployment -->|"JDBC (TLS optional)"| Database["External Database"]
    LMEvalPod -->|"HTTPS/443"| HuggingFace["HuggingFace Hub<br/>(when online allowed)"]
    LMEvalPod -->|"HTTPS/443"| S3["S3 Storage<br/>(offline assets)"]
    GORCHDeployment -->|"HTTPS"| DetectorSvc["Detector<br/>InferenceServices"]
    GORCHDeployment -->|"HTTPS"| GenerationSvc["Generation<br/>InferenceServices"]

    %% Config
    ConfigMap["ConfigMap<br/>trustyai-service-operator-config<br/>(image refs, LMEval settings)"]
    DSCConfig["ConfigMap<br/>trustyai-dsc-config<br/>(DSC-level permissions)"]
    ConfigMap -.->|read by| MainBin
    DSCConfig -.->|read by| LMESCtrl

    %% Styling
    style MainBin fill:#4a90e2,stroke:#333,color:#fff
    style TASCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style LMESCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style GORCHCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style JOBMGRCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style TASDeployment fill:#7ed321,stroke:#333,color:#000
    style LMEvalPod fill:#7ed321,stroke:#333,color:#000
    style GORCHDeployment fill:#7ed321,stroke:#333,color:#000
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,color:#000
    style LMEvalJobCR fill:#f5a623,stroke:#333,color:#000
    style GuardrailsOrchestratorCR fill:#f5a623,stroke:#333,color:#000
    style InferenceService fill:#e8e8e8,stroke:#333
    style ServingRuntime fill:#e8e8e8,stroke:#333
    style Database fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style DetectorSvc fill:#e8e8e8,stroke:#333
    style GenerationSvc fill:#e8e8e8,stroke:#333
    style KueueWorkload fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#d5e8d4,stroke:#333
    style DSCConfig fill:#d5e8d4,stroke:#333
