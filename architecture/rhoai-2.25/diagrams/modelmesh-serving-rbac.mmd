graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["modelmesh-controller"]
        SA_ModelMesh["modelmesh"]
        SA_Serving["modelmesh-serving-sa"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["modelmesh-controller-<br/>rolebinding<br/>(Cluster)"]
        CRB_Leader["leader-election-<br/>rolebinding<br/>(Controller NS)"]
        CRB_Proxy["proxy-rolebinding<br/>(Cluster)"]
        CRB_SCC["restricted-scc-<br/>rolebinding<br/>(Controller NS)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["modelmesh-controller-role"]
        CR_Leader["modelmesh-controller-<br/>leader-election-role"]
        CR_Proxy["proxy-role"]
        CR_SCC["restricted-scc"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps"]
        Secrets["secrets"]
        Services["services<br/>services/finalizers"]
        Namespaces["namespaces<br/>namespaces/finalizers"]
        Endpoints["endpoints"]
        Events["events"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps/deployments<br/>deployments/finalizers"]
    end

    subgraph KServeResources["serving.kserve.io Resources"]
        ServingRuntimes["servingruntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status"]
        ClusterServingRuntimes["clusterservingruntimes"]
        Predictors["predictors<br/>predictors/finalizers<br/>predictors/status"]
        InferenceServices["inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        HPAs["horizontalpodautoscalers"]
    end

    subgraph MonitoringResources["monitoring.coreos.com"]
        ServiceMonitors["servicemonitors"]
    end

    subgraph CoordinationResources["coordination.k8s.io"]
        Leases["leases"]
    end

    subgraph AuthResources["Auth API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph SecurityResources["security.openshift.io"]
        SCC["securitycontextconstraints<br/>(restricted)"]
    end

    %% SA → Bindings
    SA_Controller -->|"bound via"| CRB_Main
    SA_Controller -->|"bound via"| CRB_Leader
    SA_Controller -->|"bound via"| CRB_Proxy
    SA_ModelMesh -->|"bound via"| CRB_SCC
    SA_Serving -->|"bound via"| CRB_SCC

    %% Bindings → Roles
    CRB_Main -->|"grants"| CR_Main
    CRB_Leader -->|"grants"| CR_Leader
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_SCC -->|"grants"| CR_SCC

    %% modelmesh-controller-role permissions
    CR_Main -->|"create,delete,get,<br/>list,patch,update,watch"| ConfigMaps
    CR_Main -->|"create,delete,get,<br/>list,patch,update,watch"| Secrets
    CR_Main -->|"create,delete,get,<br/>list,patch,update,watch"| Services
    CR_Main -->|"get,list,watch,<br/>update,patch"| Namespaces
    CR_Main -->|"get,list,watch"| Endpoints
    CR_Main -->|"create,delete,get,<br/>list,patch,update,watch"| Deployments
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| ServingRuntimes
    CR_Main -->|"get,list,watch"| ClusterServingRuntimes
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| Predictors
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| InferenceServices
    CR_Main -->|"create,delete,get,<br/>list,update,watch"| HPAs
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| ServiceMonitors

    %% leader-election-role permissions
    CR_Leader -->|"create,get,<br/>list,update"| Leases
    CR_Leader -->|"create,delete,get,list,<br/>patch,update,watch"| ConfigMaps
    CR_Leader -->|"create"| Events

    %% proxy-role permissions
    CR_Proxy -->|"create"| TokenReviews
    CR_Proxy -->|"create"| SAR

    %% SCC permissions
    CR_SCC -->|"use"| SCC

