graph TD
    subgraph "Service Accounts"
        SA[modelmesh-controller<br/>ServiceAccount]
    end

    subgraph "Cluster Role Bindings"
        CRB1[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB2[modelmesh-auth-proxy<br/>ClusterRoleBinding]
    end

    subgraph "Namespace Role Bindings"
        RB1[modelmesh-controller-leader-election<br/>RoleBinding<br/>Namespace: controller]
    end

    subgraph "Cluster Roles"
        CR1[modelmesh-controller-role<br/>ClusterRole]
        CR2[proxy-role<br/>ClusterRole]
    end

    subgraph "Namespace Roles"
        R1[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        ConfigMaps[core/v1<br/>ConfigMaps<br/>create,delete,get,list,patch,update,watch]
        Secrets[core/v1<br/>Secrets<br/>create,delete,get,list,patch,update,watch]
        Services[core/v1<br/>Services, Services/finalizers<br/>create,delete,get,list,patch,update,watch]
        Endpoints[core/v1<br/>Endpoints<br/>get,list,watch]
        PVCs[core/v1<br/>PersistentVolumeClaims<br/>get,list,watch]
        Namespaces[core/v1<br/>Namespaces, Namespaces/finalizers<br/>get,list,patch,update,watch]
    end

    subgraph "Apps API Resources"
        Deployments[apps/v1<br/>Deployments, Deployments/finalizers<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "KServe API Resources"
        InferenceServices[serving.kserve.io/v1beta1<br/>InferenceServices<br/>inferenceservices/finalizers<br/>inferenceservices/status<br/>create,delete,get,list,patch,update,watch]
        Predictors[serving.kserve.io/v1alpha1<br/>Predictors<br/>predictors/finalizers<br/>predictors/status<br/>create,delete,get,list,patch,update,watch]
        ServingRuntimes[serving.kserve.io/v1alpha1<br/>ServingRuntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status<br/>create,delete,get,list,patch,update,watch]
        ClusterServingRuntimes[serving.kserve.io/v1alpha1<br/>ClusterServingRuntimes<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Monitoring API Resources"
        ServiceMonitors[monitoring.coreos.com/v1<br/>ServiceMonitors<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Autoscaling API Resources"
        HPAs[autoscaling/v2<br/>HorizontalPodAutoscalers<br/>horizontalpodautoscalers/status<br/>get,list,watch,create,delete,update]
    end

    subgraph "Leader Election Resources"
        LeaderConfigMaps[core/v1<br/>ConfigMaps<br/>get,list,watch,create,update,patch,delete]
        Leases[coordination.k8s.io/v1<br/>Leases<br/>get,list,watch,create,update,patch,delete]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% ClusterRole to Resources
    CR1 -->|permissions| ConfigMaps
    CR1 -->|permissions| Secrets
    CR1 -->|permissions| Services
    CR1 -->|permissions| Endpoints
    CR1 -->|permissions| PVCs
    CR1 -->|permissions| Namespaces
    CR1 -->|permissions| Deployments
    CR1 -->|permissions| InferenceServices
    CR1 -->|permissions| Predictors
    CR1 -->|permissions| ServingRuntimes
    CR1 -->|permissions| ClusterServingRuntimes
    CR1 -->|permissions| ServiceMonitors
    CR1 -->|permissions| HPAs

    %% Leader Election Role to Resources
    R1 -->|permissions| LeaderConfigMaps
    R1 -->|permissions| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f39c12,stroke:#333,stroke-width:2px
    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style RB1 fill:#8e44ad,stroke:#333,stroke-width:2px,color:#fff

    style InferenceServices fill:#7ed321,stroke:#333,stroke-width:2px
    style Predictors fill:#7ed321,stroke:#333,stroke-width:2px
    style ServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px
    style ClusterServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px

    style ConfigMaps fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Secrets fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Services fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Deployments fill:#d5e8d4,stroke:#82b366,stroke-width:2px
