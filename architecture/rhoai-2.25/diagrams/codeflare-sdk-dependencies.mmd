graph LR
    SDK["CodeFlare SDK<br/>v0.37.0<br/>(Python Client Library)"]

    %% Internal RHOAI Platform Dependencies
    SDK -->|"creates RayCluster CRs<br/>ray.io/v1"| KubeRay["KubeRay Operator"]
    SDK -->|"creates RayJob CRs<br/>ray.io/v1"| KubeRay
    SDK -->|"lists LocalQueues,<br/>Workloads, PriorityClasses<br/>kueue.x-k8s.io/v1beta1"| Kueue["Kueue"]
    SDK -->|"discovers dashboard URL<br/>HTTPRoute + Gateway<br/>(RHOAI v3.0+)"| GatewayAPI["RHOAI Gateway<br/>(rhods-operator)"]
    SDK -->|"discovers dashboard URL<br/>Route (pre-v3.0)"| OCPRouter["OpenShift Router"]
    SDK -.->|"reads CA bundle<br/>ConfigMap mount"| ODHCA["ODH Trusted CA Bundle"]
    SDK -.->|"uses runtime images<br/>quay.io/modh/ray"| RayImages["Ray Runtime Images<br/>(CUDA / ROCm)"]

    %% External Python Dependencies
    SDK -->|"client protocol"| Ray["ray 2.54.1"]
    SDK -->|"K8s API access"| K8sClient["kubernetes >= 27.2.0"]
    SDK -->|"OpenShift API"| OCPClient["openshift-client 1.0.18"]
    SDK -->|"TLS cert gen<br/>RSA 3072, SHA-256"| Crypto["cryptography 46.0.7"]
    SDK -->|"auth auto-detect"| KubeAuthkit["kube-authkit >= 0.4.0"]
    SDK -->|"data validation"| Pydantic["pydantic >= 2.10.6"]
    SDK -->|"notebook widgets"| IPyWidgets["ipywidgets 8.1.2"]
    SDK -->|"terminal formatting"| Rich["rich >= 12.5, < 15.0"]

    %% Infrastructure Dependencies
    SDK -->|"CRD CRUD ops<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]

    %% Integration Points (other components → SDK)
    Notebooks["Jupyter Notebooks<br/>(RHOAI Workbenches)"] -->|"imports SDK"| SDK
    DSPipelines["Data Science Pipelines"] -.->|"can use SDK"| SDK

