/*
 * C4 Context Diagram for Notebooks (Workbench Images)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/notebooks.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Uses interactive workbenches for ML development and experimentation"
        mlEngineer = person "ML Engineer" "Builds and deploys ML pipelines using Elyra runtimes"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images for data science workbenches (Jupyter, Code Server, RStudio) and Elyra pipeline runtimes" {
            jupyterMinimal = container "Jupyter Minimal" "Minimal JupyterLab environment" "Python 3.11/3.12, UBI9"
            jupyterDS = container "Jupyter Data Science" "JupyterLab with data science libraries" "scikit-learn, Elyra, Boto3, Pandas"
            jupyterPyTorch = container "Jupyter PyTorch" "JupyterLab with PyTorch and CUDA" "PyTorch 2.6, CUDA 12.6"
            jupyterTF = container "Jupyter TensorFlow" "JupyterLab with TensorFlow and CUDA" "TensorFlow, CUDA 12.6"
            jupyterTrustyAI = container "Jupyter TrustyAI" "JupyterLab with AI explainability" "TrustyAI libraries"
            codeServer = container "Code Server" "VS Code in browser" "code-server 4.104, NGINX 1.24"
            rstudio = container "RStudio Server" "R IDE workbench" "R 4.4, Python 3.11"
            runtimeImages = container "Pipeline Runtimes" "Elyra pipeline execution images" "Minimal, DS, PyTorch, TF variants"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream and ConfigMap definitions" "Kustomize overlays"
        }

        notebookController = softwareSystem "ODH Notebook Controller" "Launches notebook Pods from ImageStream tags, injects auth sidecars" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Displays available notebook images with metadata in UI" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "Applies kustomize overlays to create ImageStreams in cluster" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "Executes Elyra pipeline nodes using runtime images" "Internal RHOAI"
        konflux = softwareSystem "Konflux CI/CD" "Builds and pushes container images via Tekton pipelines" "External"
        containerRegistry = softwareSystem "Container Registry" "registry.redhat.io / quay.io - stores container images" "External"
        s3Storage = softwareSystem "S3/Object Storage" "Data and model artifact storage" "External"
        k8sAPI = softwareSystem "Kubernetes API" "OpenShift cluster API server" "External"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication sidecar for notebook pods" "Internal RHOAI"

        /* Relationships */
        dataScientist -> notebooks "Uses workbenches for interactive ML development" "HTTPS/443"
        mlEngineer -> notebooks "Builds pipelines with Elyra" "HTTPS/443"

        rhodsOperator -> notebooks "Deploys ImageStreams via kustomize" "Kubernetes API"
        notebookController -> notebooks "Reads ImageStream tags to launch Pods" "Kubernetes API"
        dashboard -> notebooks "Reads ImageStream annotations for UI" "Kubernetes API"
        dsPipelines -> notebooks "Pulls runtime images for pipeline execution" "HTTPS/443"

        notebooks -> s3Storage "Accesses data and model artifacts" "HTTPS/443, AWS credentials"
        notebooks -> k8sAPI "Cluster interaction from workbenches" "HTTPS/443, ServiceAccount token"

        konflux -> containerRegistry "Pushes built images" "HTTPS/443"
        containerRegistry -> notebooks "Provides container image layers" "HTTPS/443, Pull secret"

        kubeRBACProxy -> notebooks "Proxies authenticated requests" "HTTP/8888, pod-local"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
