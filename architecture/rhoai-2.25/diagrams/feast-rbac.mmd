graph TD
    subgraph "Service Accounts"
        SA_Operator[feast-operator-controller-manager<br/>Namespace: redhat-ods-applications / opendatahub]
        SA_Online["(featurestore-name)-online<br/>Namespace: (user-namespace)"]
        SA_Offline["(featurestore-name)-offline<br/>Namespace: (user-namespace)"]
        SA_Registry["(featurestore-name)-registry<br/>Namespace: (user-namespace)"]
        SA_UI["(featurestore-name)-ui<br/>Namespace: (user-namespace)"]
        SA_Materialization["(featurestore-name)-materialization<br/>Namespace: (user-namespace)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[feast-operator-manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Metrics[feast-operator-metrics-auth-rolebinding<br/>RoleBinding]
        CRB_LeaderElection[feast-operator-leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[feast-operator-manager-role]
        CR_MetricsReader[feast-operator-metrics-reader]
        CR_FeatureStoreEditor[feast-operator-featurestore-editor-role]
        CR_FeatureStoreViewer[feast-operator-featurestore-viewer-role]
        CR_LeaderElection[leader-election-role]
    end

    subgraph "Operator Permissions"
        direction TB
        Perm_Deployments[apps/deployments<br/>create, delete, get, list, update, watch]
        Perm_CronJobs[batch/cronjobs<br/>create, delete, get, list, patch, update, watch]
        Perm_ConfigMaps[core/configmaps, serviceaccounts, services, pvcs<br/>create, delete, get, list, update, watch]
        Perm_Pods[core/pods, secrets<br/>get, list]
        Perm_PodsExec[core/pods/exec<br/>create]
        Perm_FeatureStores[feast.dev/featurestores<br/>create, delete, get, list, patch, update, watch]
        Perm_FeatureStoresStatus[feast.dev/featurestores/status, finalizers<br/>get, patch, update]
        Perm_RBAC[rbac.authorization.k8s.io/roles, rolebindings<br/>create, delete, get, list, update, watch]
        Perm_Routes[route.openshift.io/routes<br/>create, delete, get, list, update, watch]
    end

    subgraph "API Resources"
        direction TB
        Res_FeatureStore[FeatureStore<br/>feast.dev/v1alpha1]
        Res_Deployments[Deployments<br/>apps/v1]
        Res_Services[Services<br/>core/v1]
        Res_ConfigMaps[ConfigMaps<br/>core/v1]
        Res_PVCs[PersistentVolumeClaims<br/>core/v1]
        Res_Routes[Routes<br/>route.openshift.io/v1]
        Res_CronJobs[CronJobs<br/>batch/v1]
    end

    %% Service Account to RoleBinding
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Metrics
    SA_Operator -->|bound via| CRB_LeaderElection

    %% RoleBinding to ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsReader
    CRB_LeaderElection -->|grants| CR_LeaderElection

    %% ClusterRole to Permissions
    CR_Manager -->|includes| Perm_Deployments
    CR_Manager -->|includes| Perm_CronJobs
    CR_Manager -->|includes| Perm_ConfigMaps
    CR_Manager -->|includes| Perm_Pods
    CR_Manager -->|includes| Perm_PodsExec
    CR_Manager -->|includes| Perm_FeatureStores
    CR_Manager -->|includes| Perm_FeatureStoresStatus
    CR_Manager -->|includes| Perm_RBAC
    CR_Manager -->|includes| Perm_Routes

    CR_MetricsReader -->|includes| Perm_Pods

    %% Permissions to Resources
    Perm_FeatureStores -->|operates on| Res_FeatureStore
    Perm_Deployments -->|operates on| Res_Deployments
    Perm_ConfigMaps -->|operates on| Res_Services
    Perm_ConfigMaps -->|operates on| Res_ConfigMaps
    Perm_ConfigMaps -->|operates on| Res_PVCs
    Perm_Routes -->|operates on| Res_Routes
    Perm_CronJobs -->|operates on| Res_CronJobs

    %% Feature Store Service Accounts (created by operator)
    SA_Operator -.->|creates| SA_Online
    SA_Operator -.->|creates| SA_Offline
    SA_Operator -.->|creates| SA_Registry
    SA_Operator -.->|creates| SA_UI
    SA_Operator -.->|creates| SA_Materialization

    %% Editor and Viewer Roles (for end users)
    User[Data Scientist / ML Engineer]
    User -.->|assigned| CR_FeatureStoreEditor
    User -.->|assigned| CR_FeatureStoreViewer

    CR_FeatureStoreEditor -->|create, delete, get, list,<br/>patch, update, watch| Res_FeatureStore
    CR_FeatureStoreViewer -->|get, list, watch| Res_FeatureStore

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Online fill:#dae8fc,stroke:#333,stroke-width:1px
    style SA_Offline fill:#dae8fc,stroke:#333,stroke-width:1px
    style SA_Registry fill:#dae8fc,stroke:#333,stroke-width:1px
    style SA_UI fill:#dae8fc,stroke:#333,stroke-width:1px
    style SA_Materialization fill:#dae8fc,stroke:#333,stroke-width:1px

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_MetricsReader fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_FeatureStoreEditor fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_FeatureStoreViewer fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style Res_FeatureStore fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Res_Deployments fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Res_Services fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Res_ConfigMaps fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Res_PVCs fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Res_Routes fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Res_CronJobs fill:#d5e8d4,stroke:#333,stroke-width:1px

    style User fill:#f9f9f9,stroke:#999,stroke-width:2px
