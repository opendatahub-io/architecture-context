graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-<br/>controller-manager<br/>(operator namespace)"]
        SA_Feast["feast-{name}<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(feast-operator-system)"]
        RB_Feast["feast-{name}<br/>(FeatureStore namespace)"]
        RB_CronJob["feast-{name}-cronjob<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Metrics["metrics-auth-role<br/>(ClusterRole)"]
        CR_MetricsReader["metrics-reader<br/>(ClusterRole)"]
        CR_Editor["featurestore-editor-role<br/>(ClusterRole)"]
        CR_Viewer["featurestore-viewer-role<br/>(ClusterRole)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Leader["leader-election-role<br/>(Role)"]
        R_Feast["feast-{name}<br/>(Role)"]
        R_CronJob["feast-{name}-cronjob<br/>(Role)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        Apps["apps<br/>deployments<br/>create,delete,get,<br/>list,update,watch"]
        Batch["batch<br/>cronjobs<br/>create,delete,get,list,<br/>patch,update,watch"]
        CoreCM["core<br/>configmaps, pvcs,<br/>serviceaccounts, services<br/>create,delete,get,<br/>list,update,watch"]
        CorePods["core<br/>pods, secrets<br/>get,list"]
        CoreExec["core<br/>pods/exec<br/>create"]
        FeastCRD["feast.dev<br/>featurestores<br/>create,delete,get,list,<br/>patch,update,watch"]
        FeastFinalizer["feast.dev<br/>featurestores/finalizers<br/>update"]
        FeastStatus["feast.dev<br/>featurestores/status<br/>get,patch,update"]
        RBAC_Res["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>create,delete,get,<br/>list,update,watch"]
        Routes["route.openshift.io<br/>routes<br/>create,delete,get,<br/>list,update,watch"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        LeaderCM["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
        Leases["coordination.k8s.io<br/>leases<br/>get,list,watch,create,<br/>update,patch,delete"]
        Events["core<br/>events<br/>create,patch"]
    end

    subgraph MetricsResources["metrics-auth-role Resources"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph UserRoles["User-Facing Roles"]
        EditorRes["feast.dev<br/>featurestores (+status)<br/>create,delete,get,list,<br/>patch,update,watch"]
        ViewerRes["feast.dev<br/>featurestores (+status)<br/>get,list,watch"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    SA_Operator -->|"bound via"| CRB_Metrics
    SA_Operator -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_Leader -->|"grants"| R_Leader

    %% FeatureStore SA bindings
    SA_Feast -->|"bound via"| RB_Feast
    SA_Feast -->|"bound via"| RB_CronJob

    RB_Feast -->|"grants"| R_Feast
    RB_CronJob -->|"grants"| R_CronJob

    %% Role → Resources
    CR_Manager -->|"manages"| Apps
    CR_Manager -->|"manages"| Batch
    CR_Manager -->|"manages"| CoreCM
    CR_Manager -->|"reads"| CorePods
    CR_Manager -->|"executes"| CoreExec
    CR_Manager -->|"manages"| FeastCRD
    CR_Manager -->|"updates"| FeastFinalizer
    CR_Manager -->|"updates"| FeastStatus
    CR_Manager -->|"manages"| RBAC_Res
    CR_Manager -->|"manages"| Routes

    R_Leader -->|"manages"| LeaderCM
    R_Leader -->|"manages"| Leases
    R_Leader -->|"creates"| Events

    CR_Metrics -->|"creates"| TokenReview
    CR_Metrics -->|"creates"| SAR

    CR_Editor -->|"manages"| EditorRes
    CR_Viewer -->|"reads"| ViewerRes

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Feast fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623
    style CR_Metrics fill:#f5a623
    style CR_MetricsReader fill:#f5a623
    style CR_Editor fill:#f5a623
    style CR_Viewer fill:#f5a623
    style R_Leader fill:#f5a623
    style R_Feast fill:#f5a623
    style R_CronJob fill:#f5a623
    style FeastCRD fill:#7ed321
    style FeastFinalizer fill:#7ed321
    style FeastStatus fill:#7ed321
    style CoreExec fill:#f8cecc,stroke:#b85450
    style EditorRes fill:#7ed321
    style ViewerRes fill:#7ed321
