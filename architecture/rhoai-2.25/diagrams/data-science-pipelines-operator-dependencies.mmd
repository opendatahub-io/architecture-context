graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (Go libraries / runtime)
    DSPO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.15.0"]
    DSPO -->|"OpenShift types"| OpenShiftAPI["OpenShift API<br/>Routes, Builds, ImageStreams"]
    DSPO -->|"manifest application"| Manifestival["manifestival<br/>v0.7.2"]
    DSPO -->|"S3 health checks"| MinioGo["minio-go/v7<br/>v7.0.56"]
    DSPO -->|"DB health checks"| MySQLDriver["go-sql-driver/mysql<br/>v1.7.1"]
    DSPO -->|"config mgmt"| Viper["viper<br/>v1.8.1"]
    DSPO -->|"metrics"| PromClient["prometheus/client_golang<br/>v1.15.1"]

    %% Platform Dependencies
    DSPO -->|"creates DSPA CRs"| PlatformOp["ODH/RHOAI<br/>Platform Operator"]
    DSPO -->|"TLS cert injection"| ServiceCA["OpenShift<br/>Service CA"]
    DSPO -->|"authentication sidecars"| OAuthProxy["OpenShift<br/>OAuth Proxy"]
    DSPO -->|"custom CA certs"| TrustedCA["ODH Trusted<br/>CA Bundle"]
    DSPO -->|"pipeline execution"| ArgoWF["Argo Workflows<br/>(CRDs + Controller)"]
    DSPO -->|"metrics scraping"| Monitoring["OpenShift<br/>Monitoring"]

    %% Integration Points (downstream consumers)
    Dashboard["ODH Dashboard"] -->|"UI management"| DSPO
    PlatformOp -->|"lifecycle mgmt"| DSPO

    %% Pipeline execution integrations
    DSPO -.->|"InferenceService CRs"| KServe["KServe"]
    DSPO -.->|"RayCluster/RayJob CRs"| Ray["Ray"]
    DSPO -.->|"SeldonDeployment CRs"| Seldon["Seldon"]
    DSPO -.->|"AppWrapper CRs"| CodeFlare["CodeFlare"]

    %% Data Storage
    DSPO -->|"pipeline metadata"| MariaDB["MariaDB<br/>:3306/TCP"]
    DSPO -->|"artifact storage"| MinIO["MinIO / S3<br/>:9000/TCP"]
    DSPO -.->|"external DB option"| ExtDB["External Database<br/>:3306/TCP"]
    DSPO -.->|"external S3 option"| ExtS3["External S3<br/>:443/TCP"]

    %% Core K8s
    DSPO -->|"CRD ops, RBAC"| K8sAPI["Kubernetes<br/>API Server"]
    DSPO -->|"admission control"| AdmissionCtrl["Kubernetes<br/>Admission Control"]
    DSPO -->|"InstructLab import"| RHELAI["InstructLab /<br/>RHELAI"]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Go libraries - grey
    style ControllerRuntime fill:#bbb,stroke:#333,color:#333
    style OpenShiftAPI fill:#bbb,stroke:#333,color:#333
    style Manifestival fill:#bbb,stroke:#333,color:#333
    style MinioGo fill:#bbb,stroke:#333,color:#333
    style MySQLDriver fill:#bbb,stroke:#333,color:#333
    style Viper fill:#bbb,stroke:#333,color:#333
    style PromClient fill:#bbb,stroke:#333,color:#333

    %% Platform dependencies - green
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style ArgoWF fill:#7ed321,stroke:#333,color:#fff
    style Monitoring fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% Integration targets - teal
    style KServe fill:#50c878,stroke:#333,color:#fff
    style Ray fill:#50c878,stroke:#333,color:#fff
    style Seldon fill:#50c878,stroke:#333,color:#fff
    style CodeFlare fill:#50c878,stroke:#333,color:#fff
    style RHELAI fill:#50c878,stroke:#333,color:#fff

    %% Storage - orange
    style MariaDB fill:#f5a623,stroke:#333,color:#fff
    style MinIO fill:#f5a623,stroke:#333,color:#fff
    style ExtDB fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style ExtS3 fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5

    %% Core K8s - dark
    style K8sAPI fill:#555,stroke:#333,color:#fff
    style AdmissionCtrl fill:#555,stroke:#333,color:#fff
