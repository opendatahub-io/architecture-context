graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        direction TB

        subgraph RestProxy["rest-proxy Sidecar"]
            GatewayServer["gRPC-Gateway Server<br/>Go Service<br/>Port: 8008/TCP"]
            Marshaler["Custom JSON Marshaler<br/>Tensor data transforms"]
            RequestTransformer["Request Transformer<br/>REST ↔ gRPC translation"]
            GatewayServer -->|JSON parsing| Marshaler
            GatewayServer -->|request/response| RequestTransformer
        end

        subgraph ModelMeshContainer["ModelMesh Container"]
            GRPCService["GRPCInferenceService<br/>gRPC Server<br/>Port: 8033/TCP"]
        end

        RequestTransformer -->|"gRPC call<br/>localhost:8033"| GRPCService
        GRPCService -->|"gRPC response"| RequestTransformer
    end

    Client["REST Client<br/>(Data Scientist / Application)"]
    ConfigMap["model-serving-config<br/>ConfigMap"]

    Client -->|"HTTP/HTTPS<br/>KServe V2 REST Protocol<br/>Port: 8008"| GatewayServer
    GatewayServer -->|"JSON Response"| Client
    ConfigMap -.->|"restProxy.image<br/>configuration"| RestProxy

    %% Supported Operations
    subgraph Operations["KServe V2 REST Endpoints"]
        direction LR
        GetModel["GET /v2/models/{name}"]
        GetModelVer["GET /v2/models/{name}/versions/{ver}"]
        Infer["POST /v2/models/{name}/infer"]
        InferVer["POST /v2/models/{name}/versions/{ver}/infer"]
    end

    Operations -.->|"served by"| GatewayServer

    %% Styling
    style GatewayServer fill:#4a90e2,stroke:#333,color:#fff
    style Marshaler fill:#5ba3f5,stroke:#333,color:#fff
    style RequestTransformer fill:#5ba3f5,stroke:#333,color:#fff
    style GRPCService fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#333
    style GetModel fill:#f0f0f0,stroke:#999
    style GetModelVer fill:#f0f0f0,stroke:#999
    style Infer fill:#f0f0f0,stroke:#999
    style InferVer fill:#f0f0f0,stroke:#999
