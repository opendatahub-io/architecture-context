graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(Container Image)"]

    %% Core Python Dependencies (bundled in image)
    subgraph PythonDeps["Python Dependencies (pip/poetry)"]
        Caikit["caikit 0.28.1<br/>Core AI Runtime"]
        CaikitNLP["caikit-nlp 0.5.14<br/>NLP Modules"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39<br/>TGIS Connector"]
        FastAPI["fastapi 0.123.7<br/>HTTP Framework"]
        GRPCIO["grpcio >=1.62.2<br/>gRPC Framework"]
        Torch["torch >=2.3.1,<2.7.0<br/>(transitive)"]
        Transformers["transformers >=4.48.3<br/>(transitive)"]
    end

    CaikitTGIS -->|"runtime library"| Caikit
    CaikitTGIS -->|"NLP modules"| CaikitNLP
    CaikitTGIS -->|"backend connector"| CaikitTGISBackend
    CaikitTGIS -->|"HTTP API"| FastAPI
    CaikitTGIS -->|"gRPC API"| GRPCIO
    CaikitNLP -.->|"transitive"| Torch
    CaikitNLP -.->|"transitive"| Transformers

    %% Internal Platform Dependencies
    CaikitTGIS -->|"gRPC localhost:8033"| TGIS["TGIS<br/>(co-located container)<br/>GPU inference"]
    CaikitTGIS -->|"CRD orchestration"| KServe["KServe<br/>ServingRuntime &<br/>InferenceService"]
    CaikitTGIS -->|"serverless scaling"| Knative["Knative Serving"]
    CaikitTGIS -->|"mTLS, ingress"| Istio["Istio / Service Mesh"]

    %% Monitoring Integration
    Prometheus["Prometheus<br/>User Workload Monitoring"] -->|"scrapes :8086"| CaikitTGIS

    %% External Services
    CaikitTGIS -->|"model storage"| S3["S3-compatible Storage"]
    CaikitTGIS -.->|"model download (dev)"| HuggingFace["HuggingFace Hub"]
    CaikitTGIS -->|"model storage (alt)"| PVC["PVC / Persistent Volume"]

    %% Build Infrastructure
    Konflux["Konflux / Tekton"] -->|"builds image"| CaikitTGIS

    %% Base Image
    CaikitTGIS -->|"base image"| UBI9["UBI 9 Minimal<br/>Python 3.12"]

