%% RBAC Visualization for vllm-rocm - Generated by: Claude Opus 4.6
%% Note: vllm-rocm does NOT define its own RBAC resources. RBAC is managed by KServe and rhods-operator.
graph TD
    subgraph "vllm-rocm Runtime Context"
        SA["ServiceAccount<br/>(managed by KServe)<br/>Namespace: {user-namespace}"]
    end

    subgraph "Platform RBAC (managed by KServe / rhods-operator)"
        CRB_KServe["ClusterRoleBinding<br/>kserve-manager-rolebinding"]
        CR_KServe["ClusterRole<br/>kserve-manager-role"]
    end

    subgraph "Authentication at Ingress"
        KRBAC["kube-rbac-proxy<br/>(sidecar)"]
        OAuth["oauth-proxy<br/>(sidecar)"]
    end

    subgraph "Container-Level Auth"
        HTTP["HTTP API 8000/TCP<br/>Auth: None"]
        GRPC["gRPC API 8033/TCP<br/>Auth: None"]
    end

    subgraph "Secrets (Build-time only)"
        GitAuth["git_auth_secret<br/>Type: Opaque<br/>Purpose: Konflux build auth<br/>Provisioned by: Konflux/PaC"]
    end

    SA -->|"runs pod with"| HTTP
    SA -->|"runs pod with"| GRPC

    KRBAC -->|"protects"| HTTP
    OAuth -.->|"alternative protection"| HTTP

    CR_KServe -->|"manages"| SA
    CRB_KServe -->|"binds"| CR_KServe

    Note1["NOTE: vllm-rocm delegates ALL<br/>authentication & authorization<br/>to the platform ingress layer.<br/>No RBAC resources are defined<br/>by this component."]

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR_KServe fill:#f5a623,stroke:#333
    style CRB_KServe fill:#f5a623,stroke:#333
    style KRBAC fill:#7ed321,stroke:#333
    style OAuth fill:#7ed321,stroke:#333
    style HTTP fill:#dae8fc,stroke:#6c8ebf
    style GRPC fill:#dae8fc,stroke:#6c8ebf
