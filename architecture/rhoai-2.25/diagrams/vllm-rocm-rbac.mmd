graph TD
    subgraph "vllm-rocm RBAC Model"
        direction TB

        Note["This component is a container image,<br/>not an operator.<br/>No RBAC resources are defined<br/>in this repository."]

        subgraph "Platform-Provided Security"
            direction TB

            subgraph "Pod-Level Auth (kube-rbac-proxy sidecar)"
                KubeRBAC["kube-rbac-proxy"]
                SAR["SubjectAccessReview<br/>(Kubernetes API)"]
                KubeRBAC -->|"validates bearer token via"| SAR
            end

            subgraph "KServe ServingRuntime SA"
                SA["ServiceAccount<br/>(assigned by KServe)"]
                PodSec["Pod Security<br/>- Device plugin access (AMD GPU)<br/>- Volume mounts (model storage)<br/>- Network access (egress)"]
                SA -->|"grants pod"| PodSec
            end

            subgraph "Authentication Flow"
                ExtClient["External Client<br/>Bearer Token"]
                ExtClient -->|"HTTPS/8443"| KubeRBAC
                KubeRBAC -->|"authorized request<br/>HTTP/8000 localhost"| VLLMProc["vLLM Process<br/>(no auth)"]
            end
        end

        subgraph "Mesh-Level Auth (Alternative)"
            Istio["Istio mTLS<br/>PeerAuthentication: STRICT"]
            AuthzPolicy["AuthorizationPolicy<br/>(platform-defined)"]
            Istio --> AuthzPolicy
        end
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style KubeRBAC fill:#f5a623,stroke:#333,color:#fff
    style SAR fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#7ed321,stroke:#333
    style PodSec fill:#d5e8d4,stroke:#82b366
    style ExtClient fill:#e8e8e8,stroke:#333
    style VLLMProc fill:#4a90e2,stroke:#333,color:#fff
    style Istio fill:#f5a623,stroke:#333,color:#fff
    style AuthzPolicy fill:#f5a623,stroke:#333,color:#fff
