graph TD
    subgraph "OPERATOR LEVEL (DSPO Namespace)"
        SA_Controller[ServiceAccount<br/>data-science-pipelines-operator-controller-manager]

        CRB_Manager[ClusterRoleBinding<br/>manager-rolebinding]
        CR_Manager[ClusterRole<br/>manager-role]

        CRB_Argo[ClusterRoleBinding<br/>manager-argo-rolebinding]
        CR_Argo[ClusterRole<br/>manager-argo-role]

        SA_Controller -->|bound via| CRB_Manager
        SA_Controller -->|bound via| CRB_Argo
        CRB_Manager -->|grants| CR_Manager
        CRB_Argo -->|grants| CR_Argo
    end

    subgraph "OPERATOR PERMISSIONS"
        API_DSPA["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>datasciencepipelinesapplications/status<br/>datasciencepipelinesapplications/finalizers"]
        API_Core["core<br/>configmaps, secrets, serviceaccounts,<br/>services, persistentvolumeclaims,<br/>pods, events"]
        API_Apps["apps<br/>deployments, replicasets"]
        API_Argo["argoproj.io<br/>workflows, workflowtemplates,<br/>cronworkflows, workflowartifactgctasks,<br/>workflowtaskresults"]
        API_Pipelines["pipelines.kubeflow.org<br/>pipelines, pipelineversions"]
        API_Route["route.openshift.io<br/>routes"]
        API_Network["networking.k8s.io<br/>networkpolicies"]
        API_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
        API_Monitor["monitoring.coreos.com<br/>servicemonitors"]
        API_KServe["serving.kserve.io<br/>inferenceservices"]
        API_Ray["ray.io<br/>rayclusters, rayjobs, rayservices"]
        API_Admission["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations"]
        API_Coord["coordination.k8s.io<br/>leases"]

        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_DSPA
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Core
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Apps
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Argo
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Pipelines
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Route
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Network
        CR_Manager -->|create,delete,get,list,<br/>update,watch| API_RBAC
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Monitor
        CR_Manager -->|create,delete,get,list,patch| API_KServe
        CR_Manager -->|create,delete,get,list,patch| API_Ray
        CR_Manager -->|create,delete,get,list,<br/>patch,update,watch| API_Admission

        CR_Argo -->|create,delete,get,list,<br/>patch,update,watch| API_Argo
        CR_Argo -->|create,delete,get,list,<br/>patch,update,watch| API_Core
        CR_Argo -->|create,get,update| API_Coord
    end

    subgraph "DSPA INSTANCE LEVEL (User Namespace)"
        SA_API["ServiceAccount<br/>ds-pipeline-dspa-name"]
        RB_API["RoleBinding<br/>ds-pipeline-dspa-name"]
        R_API["Role<br/>ds-pipeline-dspa-name"]

        SA_WFC["ServiceAccount<br/>ds-pipeline-workflow-controller-dspa-name"]
        RB_WFC["RoleBinding<br/>ds-pipeline-workflow-controller-dspa-name"]

        SA_PA["ServiceAccount<br/>ds-pipeline-persistenceagent-dspa-name"]
        RB_PA["RoleBinding<br/>ds-pipeline-persistenceagent-dspa-name"]

        SA_SWC["ServiceAccount<br/>ds-pipeline-scheduledworkflow-dspa-name"]
        RB_SWC["RoleBinding<br/>ds-pipeline-scheduledworkflow-dspa-name"]

        SA_Runner["ServiceAccount<br/>pipeline-runner-dspa-name"]
        RB_Runner["RoleBinding<br/>pipeline-runner-dspa-name"]
        R_Runner["Role<br/>pipeline-runner-dspa-name"]

        SA_UserAccess["ServiceAccount<br/>ds-pipeline-user-access-dspa-name"]
        RB_UserAccess["RoleBinding<br/>ds-pipeline-user-access-dspa-name"]
        R_UserAccess["Role<br/>ds-pipeline-user-access-dspa-name"]

        SA_API -->|bound via| RB_API
        RB_API -->|grants| R_API

        SA_WFC -->|bound via| RB_WFC
        RB_WFC -->|grants| CR_Argo

        SA_PA -->|bound via| RB_PA
        RB_PA -->|grants| R_API

        SA_SWC -->|bound via| RB_SWC
        RB_SWC -->|grants| R_API

        SA_Runner -->|bound via| RB_Runner
        RB_Runner -->|grants| R_Runner

        SA_UserAccess -->|bound via| RB_UserAccess
        RB_UserAccess -->|grants| R_UserAccess
    end

    subgraph "DSPA INSTANCE PERMISSIONS"
        DSPA_Argo["argoproj.io<br/>workflows, workflowartifactgctasks"]
        DSPA_Core["core<br/>pods, pods/log, configmaps,<br/>secrets, services, events"]
        DSPA_KServe_Instance["serving.kserve.io<br/>inferenceservices"]

        Runner_Argo["argoproj.io<br/>workflows (read-only)"]
        Runner_Core["core<br/>secrets, configmaps,<br/>serviceaccounts (read-only)"]

        UserAccess_Argo["argoproj.io<br/>workflows, workflowartifactgctasks<br/>(read-only)"]

        R_API -->|create,delete,deletecollection,<br/>get,list,patch,update,watch| DSPA_Argo
        R_API -->|create,delete,get,list,<br/>patch,watch| DSPA_Core
        R_API -->|create,delete,get,list,patch| DSPA_KServe_Instance

        R_Runner -->|get| Runner_Core
        R_Runner -->|get,list,watch| Runner_Argo

        R_UserAccess -->|get,list,watch| UserAccess_Argo
    end

