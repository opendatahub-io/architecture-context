    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,color:#fff
    style SA_Persist fill:#4a90e2,stroke:#333,color:#fff
    style SA_Sched fill:#4a90e2,stroke:#333,color:#fff
    style SA_WFCtrl fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333,color:#fff
    style CR_Edit fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#f5a623,stroke:#333,color:#fff

    style CRB_Manager fill:#e8a838,stroke:#333,color:#fff
    style CRB_Argo fill:#e8a838,stroke:#333,color:#fff

    style DSPA_Res fill:#7ed321,stroke:#333,color:#fff
    style Core_Res fill:#7ed321,stroke:#333,color:#fff
    style Apps_Res fill:#7ed321,stroke:#333,color:#fff
    style RBAC_Res fill:#e74c3c,stroke:#333,color:#fff
    style Route_Res fill:#7ed321,stroke:#333,color:#fff
    style Admission_Res fill:#e74c3c,stroke:#333,color:#fff
    style Argo_Res fill:#7ed321,stroke:#333,color:#fff
    style KF_Res fill:#7ed321,stroke:#333,color:#fff
    style Pipeline_Res fill:#7ed321,stroke:#333,color:#fff
    style Monitor_Res fill:#7ed321,stroke:#333,color:#fff
    style NetPol_Res fill:#e74c3c,stroke:#333,color:#fff
    style Auth_Res fill:#e74c3c,stroke:#333,color:#fff
    style AuthZ_Res fill:#e74c3c,stroke:#333,color:#fff
    style Batch_Res fill:#7ed321,stroke:#333,color:#fff
    style Integration_Res fill:#50c878,stroke:#333,color:#fff

    style Role_Pipeline fill:#9b59b6,stroke:#333,color:#fff
    style Role_Runner fill:#9b59b6,stroke:#333,color:#fff
    style Role_UserAccess fill:#9b59b6,stroke:#333,color:#fff
    style Role_Persist fill:#9b59b6,stroke:#333,color:#fff
    style Role_Sched fill:#9b59b6,stroke:#333,color:#fff
