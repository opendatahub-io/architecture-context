graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(Operator NS)"]
        SA_Pipeline["ds-pipeline-{name}<br/>(DSPA NS)"]
        SA_Runner["pipeline-runner-{name}<br/>(DSPA NS)"]
        SA_Persist["ds-pipeline-persistenceagent-{name}<br/>(DSPA NS)"]
        SA_Sched["ds-pipeline-scheduledworkflow-{name}<br/>(DSPA NS)"]
        SA_WFCtrl["ds-pipeline-workflow-controller-{name}<br/>(DSPA NS)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Argo["manager-argo-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Argo["manager-argo-role"]
        CR_Edit["aggregate-dspa-admin-edit<br/>(aggregates to admin/edit)"]
        CR_View["aggregate-dspa-admin-view<br/>(aggregates to view)"]
    end

    subgraph ManagerRoleResources["manager-role Resources"]
        DSPA_Res["datasciencepipelinesapplications.opendatahub.io<br/>DSPA, /status, /finalizers<br/>get,list,watch,create,update,patch,delete"]
        Core_Res["core<br/>configmaps, secrets, serviceaccounts,<br/>pods, pods/exec, pods/log, services,<br/>PVCs, PVs, events<br/>full CRUD"]
        Apps_Res["apps, extensions<br/>deployments, replicasets<br/>full CRUD"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>full CRUD"]
        Route_Res["route.openshift.io<br/>routes<br/>full CRUD"]
        Admission_Res["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>full CRUD"]
        Argo_Res["argoproj.io<br/>workflows, workflowartifactgctasks,<br/>workflowtaskresults<br/>full CRUD"]
        KF_Res["kubeflow.org<br/>all resources<br/>full CRUD"]
        Pipeline_Res["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>full CRUD"]
        Monitor_Res["monitoring.coreos.com<br/>servicemonitors<br/>full CRUD"]
        NetPol_Res["networking.k8s.io<br/>networkpolicies, ingresses<br/>full CRUD / read"]
        Auth_Res["authentication.k8s.io<br/>tokenreviews<br/>create"]
        AuthZ_Res["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        Batch_Res["batch<br/>jobs<br/>full CRUD"]
        Integration_Res["serving.kserve.io, ray.io,<br/>machinelearning.seldon.io,<br/>workload.codeflare.dev<br/>create,delete,get,list,patch"]
    end

    subgraph ArgoRoleResources["manager-argo-role Resources"]
        ArgoWF_Res["argoproj.io<br/>workflows, workflowtasksets,<br/>cronworkflows, workflowtemplates<br/>full CRUD"]
        ArgoCore_Res["core<br/>pods, pods/exec, configmaps,<br/>PVCs, secrets, serviceaccounts,<br/>events<br/>varies"]
        ArgoCoord_Res["coordination.k8s.io<br/>leases<br/>create,get,update"]
        ArgoPDB_Res["policy<br/>poddisruptionbudgets<br/>create,get,delete"]
    end

    subgraph NamespacedRoles["Per-DSPA Namespace Roles"]
        Role_Pipeline["ds-pipeline-{name}<br/>API server permissions"]
        Role_Runner["pipeline-runner-{name}<br/>Pipeline pod execution<br/>(KServe, Ray, Seldon, CodeFlare)"]
        Role_UserAccess["ds-pipeline-user-access-{name}<br/>User access to pipelines"]
        Role_Persist["ds-pipeline-persistenceagent-{name}<br/>Persistence agent permissions"]
        Role_Sched["ds-pipeline-scheduledworkflow-{name}<br/>Scheduled workflow permissions"]
        Role_WFCtrl["ds-pipeline-workflow-controller-{name}<br/>Argo workflow controller perms"]
    end

    %% ClusterRole Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    SA_Controller -->|"bound via"| CRB_Argo
    CRB_Argo -->|"grants"| CR_Argo

    %% Manager Role to Resources
    CR_Manager -->|"manages"| DSPA_Res
    CR_Manager -->|"manages"| Core_Res
    CR_Manager -->|"manages"| Apps_Res
    CR_Manager -->|"manages"| RBAC_Res
    CR_Manager -->|"manages"| Route_Res
    CR_Manager -->|"manages"| Admission_Res
    CR_Manager -->|"manages"| Argo_Res
    CR_Manager -->|"manages"| KF_Res
    CR_Manager -->|"manages"| Pipeline_Res
    CR_Manager -->|"manages"| Monitor_Res
    CR_Manager -->|"manages"| NetPol_Res
    CR_Manager -->|"manages"| Auth_Res
    CR_Manager -->|"manages"| AuthZ_Res
    CR_Manager -->|"manages"| Batch_Res
    CR_Manager -->|"manages"| Integration_Res

    %% Argo Role to Resources
    CR_Argo -->|"manages"| ArgoWF_Res
    CR_Argo -->|"manages"| ArgoCore_Res
    CR_Argo -->|"manages"| ArgoCoord_Res
    CR_Argo -->|"manages"| ArgoPDB_Res

    %% Aggregate Roles
    CR_Edit -->|"aggregates to<br/>admin/edit"| DSPA_Res
    CR_Edit -->|"aggregates to<br/>admin/edit"| Pipeline_Res
    CR_View -.->|"aggregates to<br/>view (read-only)"| DSPA_Res
    CR_View -.->|"aggregates to<br/>view (read-only)"| Pipeline_Res

    %% Namespace Roles
    SA_Pipeline -->|"bound to"| Role_Pipeline
    SA_Runner -->|"bound to"| Role_Runner
    SA_Persist -->|"bound to"| Role_Persist
    SA_Sched -->|"bound to"| Role_Sched
    SA_WFCtrl -->|"bound to"| Role_WFCtrl

