graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / Data Scientist]
    end

    subgraph K8sBoundary["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>Auth: User creds, SA tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Controller["Training Operator Controller<br/>SA: training-operator<br/>ClusterRole: training-operator"]

        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>mTLS (K8s API Server)<br/>Cert: training-operator-webhook-cert"]

        Metrics["Metrics Exporter<br/>8080/TCP HTTP<br/>No encryption<br/>Auth: SA bearer token"]

        CertMgr["Certificate Manager<br/>Auto-rotates webhook certs"]

        CertMgr -->|provisions| Webhook
        Controller -->|exposes| Metrics
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Operator<br/>PodMonitor scraping"]
    end

    subgraph UserNS["USER NAMESPACES (Training Jobs)"]
        direction TB

        subgraph JobResources["Training Job Resources"]
            Master["Training Master Pod<br/>SA: {job-name}-sa<br/>Port: 23456/TCP<br/>Protocol: TCP<br/>Encryption: App-defined"]

            Workers["Training Worker Pods<br/>SA: {job-name}-sa<br/>Port: 23456/TCP<br/>Replicas: 1-100+"]

            NetPol["NetworkPolicy<br/>(Optional)<br/>Ingress/Egress rules"]
        end

        Master <-->|TCP 23456<br/>Framework-specific<br/>App-level encryption| Workers
        NetPol -.->|restricts| Master
        NetPol -.->|restricts| Workers
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull secrets"]

        Storage["Object Storage (S3)<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM (IRSA)"]

        Volcano["Volcano Scheduler<br/>(Optional)<br/>443/TCP HTTPS<br/>Gang scheduling"]

        SchedulerPlugins["Scheduler Plugins<br/>(Optional)<br/>443/TCP HTTPS<br/>Gang scheduling"]
    end

    %% User to K8s API
    User -->|HTTPS 443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% K8s API to Webhook
    K8sAPI -->|HTTPS 9443<br/>TLS 1.2+ mTLS<br/>Validate CRs| Webhook

    %% Controller to K8s API
    Controller -->|HTTPS 443<br/>TLS 1.2+<br/>SA Token JWT<br/>Watch and Manage| K8sAPI

    %% Controller creates resources
    Controller -.->|creates via K8s API| Master
    Controller -.->|creates via K8s API| Workers
    Controller -.->|creates via K8s API| NetPol

    %% Metrics collection
    Prometheus -->|HTTP 8080<br/>SA bearer token<br/>Scrape metrics| Metrics

    %% Certificate management
    CertMgr -->|HTTPS 443<br/>SA Token<br/>Update secret & webhook config| K8sAPI

    %% Training pods to external services
    Workers -->|HTTPS 443<br/>TLS 1.2+<br/>Pull secrets| Registry
    Master -->|HTTPS 443<br/>TLS 1.2+<br/>AWS IAM| Storage
    Workers -->|HTTPS 443<br/>TLS 1.2+<br/>AWS IAM| Storage

    %% Gang scheduling (optional)
    Controller -.->|HTTPS 443<br/>SA Token<br/>Create PodGroups| Volcano
    Controller -.->|HTTPS 443<br/>SA Token<br/>Create PodGroups| SchedulerPlugins

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sBoundary fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef operatorNS fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userNS fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI k8sBoundary
    class Controller,Webhook,Metrics,CertMgr operatorNS
    class Master,Workers,NetPol userNS
    class Prometheus monitoring
    class Registry,Storage,Volcano,SchedulerPlugins externalService
