graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / Client Certs"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB
        Operator["Training Operator<br/>SA: training-operator<br/>User: 65532 (non-root)<br/>FIPS: strictfipsruntime"]

        WebhookSvc["Service: kubeflow-training-operator<br/>ClusterIP 443/TCP → 9443/TCP<br/>TLS (self-signed, OPA cert-controller)"]

        MetricsPort["Metrics: 8080/TCP HTTP<br/>No auth (PodMonitor scrape)"]

        HealthPort["Health: 8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph JobNS["JOB NAMESPACE: {user-namespace}"]
        direction TB

        subgraph PyTorchZone["PyTorch Job"]
            PTMaster["Master Pod<br/>23456/TCP"]
            PTWorkers["Worker Pods<br/>23456/TCP<br/>Init: DNS resolve master"]
            PTHeadless["Headless Services<br/>ClusterIP None"]
            PTNP["NetworkPolicy<br/>Allows intra-job + monitoring"]
        end

        subgraph TFZone["TensorFlow Job"]
            TFPods["Chief/PS/Worker Pods<br/>2222/TCP gRPC"]
            TFHeadless["Headless Services"]
        end

        subgraph MPIZone["MPI Job (kubectl-exec pattern)"]
            MPILauncher["Launcher Pod<br/>SA: {job}-launcher<br/>RBAC-scoped pods/exec"]
            MPIWorkers["Worker Pods<br/>9999/TCP<br/>sleep 365d"]
            MPICM["ConfigMap<br/>hostfile, kubexec.sh"]
        end

        subgraph OtherZone["XGBoost / JAX / PaddlePaddle"]
            XGBPods["XGBoost: 9999/TCP"]
            JAXPods["JAX: 6666/TCP"]
            PaddlePods["Paddle: 36543/TCP"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["OpenShift Monitoring<br/>Prometheus<br/>PodMonitor scrape"]
    end

    subgraph OptionalSchedulers["OPTIONAL SCHEDULERS"]
        Volcano["Volcano Scheduler<br/>PodGroup CRD"]
        SchedPlugins["Scheduler-Plugins<br/>PodGroup CRD"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Admission webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert"| WebhookSvc

    %% Operator to API server
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator creates job resources
    Operator -->|"creates"| PTMaster
    Operator -->|"creates"| PTWorkers
    Operator -->|"creates"| MPILauncher
    Operator -->|"creates"| MPIWorkers

    %% Inter-pod communication
    PTWorkers -->|"TCP/23456<br/>No encryption<br/>NCCL/Gloo"| PTMaster
    TFPods -->|"TCP/2222<br/>No encryption<br/>gRPC"| TFPods

    %% MPI kubectl exec
    MPILauncher -->|"HTTPS/443<br/>pods/exec<br/>SA token (scoped)"| K8sAPI
    K8sAPI -->|"kubectl exec"| MPIWorkers

    %% DNS
    PTWorkers -->|"DNS/53 UDP<br/>No encryption"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| MetricsPort

    %% Gang scheduling
    Operator -.->|"PodGroup CRD<br/>via K8s API"| Volcano
    Operator -.->|"PodGroup CRD<br/>via K8s API"| SchedPlugins

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduler fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef mpizone fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,WebhookSvc,MetricsPort,HealthPort operator
    class PTMaster,PTWorkers,PTHeadless,PTNP,TFPods,TFHeadless,MPILauncher,MPIWorkers,MPICM,XGBPods,JAXPods,PaddlePods jobns
    class Prometheus monitoring
    class Volcano,SchedPlugins scheduler
