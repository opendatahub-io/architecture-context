graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Operator["kuberay-operator<br/>(ClusterRoleBinding)"]
        RB_LeaderElection["kuberay-operator-leader-election<br/>(RoleBinding, operator namespace)"]
    end

    subgraph OperatorClusterRole["ClusterRole: kuberay-operator"]
        direction TB
        CoreAPI["Core API ('')<br/>endpoints: get, list, watch<br/>events, pods/status, services: create, delete, get, list, patch, update, watch<br/>pods: create, delete, deletecollection, get, list, patch, update, watch<br/>pods/proxy, services/status: get, patch, update<br/>serviceaccounts: create, delete, get, list, watch<br/>services/proxy: create, get, patch, update"]
        BatchAPI["batch<br/>jobs: create, delete, get,<br/>list, patch, update, watch"]
        CoordinationAPI["coordination.k8s.io<br/>leases: create, get,<br/>list, update"]
        NetworkingAPI["extensions, networking.k8s.io<br/>ingresses: create, delete, get,<br/>list, patch, update, watch<br/>ingressclasses: get, list, watch"]
        RayAPI["ray.io<br/>rayclusters, rayjobs, rayservices:<br/>create, delete, get, list, patch, update, watch<br/>*/finalizers: update<br/>*/status: get, patch, update"]
        RBACAPI["rbac.authorization.k8s.io<br/>rolebindings: create, delete, get, list, watch<br/>roles: create, delete, get, list, update, watch"]
        RouteAPI["route.openshift.io<br/>routes: create, delete, get,<br/>list, patch, update, watch"]
    end

    subgraph UserFacingRoles["User-Facing ClusterRoles"]
        EditRole["kuberay-edit-role<br/>ray.io: rayjobs, rayclusters, rayservices<br/>Verbs: full CRUD + deletecollection"]
        ViewRole["kuberay-view-role<br/>ray.io: rayjobs, rayclusters, rayservices<br/>Verbs: get, list, watch"]
        JobEditorRole["rayjob-editor-role<br/>ray.io: rayjobs, rayjobs/status<br/>Verbs: full CRUD"]
        JobViewerRole["rayjob-viewer-role<br/>ray.io: rayjobs, rayjobs/status<br/>Verbs: get, list, watch"]
        SvcEditorRole["rayservice-editor-role<br/>ray.io: rayservices, rayservices/status<br/>Verbs: full CRUD"]
        SvcViewerRole["rayservice-viewer-role<br/>ray.io: rayservices, rayservices/status<br/>Verbs: get, list, watch"]
    end

    subgraph SCC["SecurityContextConstraints (OpenShift)"]
        RunAsRayUser["run-as-ray-user<br/>RunAsUser: MustRunAs (UID 1000)<br/>Drop capabilities: ALL<br/>Seccomp: runtime/default"]
    end

    %% Bindings
    SA_Operator -->|bound via| CRB_Operator
    SA_Operator -->|bound via| RB_LeaderElection
    CRB_Operator -->|grants| OperatorClusterRole
    RB_LeaderElection -->|grants| LeaderElectionRole["Role: kuberay-operator-leader-election<br/>coordination.k8s.io/leases:<br/>get, list, watch, create, update, patch, delete"]

    %% SCC binding
    SA_Operator -.->|constrained by| RunAsRayUser

