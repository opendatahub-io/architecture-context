graph TD
    subgraph "Operator Identity"
        SA[ServiceAccount<br/>kuberay-operator<br/>Namespace: kuberay-system/opendatahub]
    end

    subgraph "Cluster-Level Permissions"
        CRB[ClusterRoleBinding<br/>kuberay-operator]
        CR[ClusterRole<br/>kuberay-operator]
    end

    subgraph "Core Resources"
        Pods[Pods<br/>create, delete, deletecollection,<br/>get, list, patch, update, watch]
        PodsProxy[Pods/Proxy, Services/Proxy<br/>create, get, patch, update]
        PodsStatus[Pods/Status<br/>create, delete, get, list,<br/>patch, update, watch]
        Services[Services<br/>create, delete, get, list,<br/>patch, update, watch]
        ServicesStatus[Services/Status<br/>get, patch, update]
        ServiceAccounts[ServiceAccounts<br/>create, delete, get, list, watch]
        Events[Events<br/>create, delete, get, list,<br/>patch, update, watch]
        Endpoints[Endpoints<br/>get, list, watch]
    end

    subgraph "Batch Resources"
        Jobs["Jobs - batch API<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "Ray CRDs"
        RayClusters["RayClusters - ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayJobs["RayJobs - ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayServices["RayServices - ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayStatus["Ray CRD Status & Finalizers<br/>get, patch, update"]
    end

    subgraph "Networking Resources"
        Ingresses["Ingresses - networking.k8s.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        IngressClasses["IngressClasses<br/>get, list, watch"]
        Routes["Routes - route.openshift.io<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "RBAC Resources"
        Roles["Roles - rbac.authorization.k8s.io<br/>create, delete, get, list,<br/>update, watch"]
        RoleBindings["RoleBindings<br/>create, delete, get, list, watch"]
    end

    subgraph "Coordination Resources"
        Leases["Leases - coordination.k8s.io<br/>create, get, list, update"]
    end

    subgraph "Ray Cluster Identity (Dynamically Created)"
        RaySA["ServiceAccount<br/>{cluster-name}-sa<br/>Namespace: {user-namespace}"]
        RayRole["Role<br/>{cluster-name}-role"]
        RayRB["RoleBinding<br/>{cluster-name}-rolebinding"]
    end

    subgraph "Ray Cluster Autoscaler Permissions"
        AutoscalePods["Pods for autoscaling<br/>create, delete, list"]
    end

    %% Operator RBAC bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Operator permissions
    CR -->|manages| Pods
    CR -->|manages| PodsProxy
    CR -->|manages| PodsStatus
    CR -->|manages| Services
    CR -->|manages| ServicesStatus
    CR -->|manages| ServiceAccounts
    CR -->|manages| Events
    CR -->|reads| Endpoints
    CR -->|manages| Jobs
    CR -->|manages| RayClusters
    CR -->|manages| RayJobs
    CR -->|manages| RayServices
    CR -->|manages| RayStatus
    CR -->|manages| Ingresses
    CR -->|reads| IngressClasses
    CR -->|manages| Routes
    CR -->|manages| Roles
    CR -->|manages| RoleBindings
    CR -->|manages| Leases

    %% Operator creates Ray cluster identity
    CR -.->|creates dynamically| RaySA
    CR -.->|creates dynamically| RayRole
    CR -.->|creates dynamically| RayRB

    %% Ray cluster RBAC
    RaySA -->|bound via| RayRB
    RayRB -->|grants| RayRole
    RayRole -->|autoscaling| AutoscalePods

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB fill:#f5a623,stroke:#333,color:#000

    style Pods fill:#7ed321,stroke:#333,color:#000
    style PodsProxy fill:#7ed321,stroke:#333,color:#000
    style PodsStatus fill:#7ed321,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style ServicesStatus fill:#7ed321,stroke:#333,color:#000
    style ServiceAccounts fill:#7ed321,stroke:#333,color:#000
    style Events fill:#7ed321,stroke:#333,color:#000
    style Endpoints fill:#7ed321,stroke:#333,color:#000
    style Jobs fill:#7ed321,stroke:#333,color:#000
    style RayClusters fill:#7ed321,stroke:#333,color:#000
    style RayJobs fill:#7ed321,stroke:#333,color:#000
    style RayServices fill:#7ed321,stroke:#333,color:#000
    style RayStatus fill:#7ed321,stroke:#333,color:#000
    style Ingresses fill:#7ed321,stroke:#333,color:#000
    style IngressClasses fill:#7ed321,stroke:#333,color:#000
    style Routes fill:#7ed321,stroke:#333,color:#000
    style Roles fill:#7ed321,stroke:#333,color:#000
    style RoleBindings fill:#7ed321,stroke:#333,color:#000
    style Leases fill:#7ed321,stroke:#333,color:#000

    style RaySA fill:#9673a6,stroke:#333,color:#fff
    style RayRole fill:#9673a6,stroke:#333,color:#fff
    style RayRB fill:#9673a6,stroke:#333,color:#fff
    style AutoscalePods fill:#9673a6,stroke:#333,color:#fff
