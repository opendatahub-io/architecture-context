graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>Namespace: opendatahub"]
        SA_OAuth["{cluster}-oauth-proxy<br/>Namespace: {user-ns}<br/>(per RayCluster)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Auth["{cluster}-{ns}-auth<br/>(Cluster-scoped, per RayCluster)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDelegator["system:auth-delegator<br/>(built-in)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role<br/>Namespace: opendatahub"]
    end

    %% Bindings
    SA_CM -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    SA_CM -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| R_Leader
    SA_OAuth -->|"bound via"| CRB_Auth
    CRB_Auth -->|"grants"| CR_AuthDelegator

    %% Manager Role Permissions
    subgraph CoreResources["Core API Resources ('')"]
        Events["events<br/>create, patch, update, watch"]
        Nodes["nodes<br/>get, list, watch"]
        Pods["pods<br/>CRUD + watch"]
        Services["services<br/>CRUD + watch"]
        Secrets["secrets<br/>CRUD + watch"]
        ServiceAccounts["serviceaccounts<br/>CRUD + watch"]
    end

    subgraph AdmissionResources["admissionregistration.k8s.io"]
        MWC["mutatingwebhookconfigurations<br/>get, list, update, watch"]
        VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
    end

    subgraph ApiExtResources["apiextensions.k8s.io"]
        CRDs["customresourcedefinitions<br/>get, list, watch"]
    end

    subgraph AppsResources["apps"]
        Deployments["deployments<br/>CRUD + watch"]
        StatefulSets["statefulsets<br/>CRUD + watch"]
    end

    subgraph AuthResources["authentication + authorization"]
        TokenReviews["tokenreviews<br/>create"]
        SAR["subjectaccessreviews<br/>create"]
    end

    subgraph BatchResources["batch"]
        Jobs["jobs<br/>CRUD + watch"]
    end

    subgraph OpenShiftResources["OpenShift APIs"]
        OSIngresses["config.openshift.io/ingresses<br/>get"]
        Routes["route.openshift.io/routes<br/>CRUD + watch"]
    end

    subgraph ODHResources["opendatahub.io"]
        DSCI["dscinitializations<br/>get, list, watch"]
    end

    subgraph RayResources["ray.io"]
        RayClusters["rayclusters<br/>CRUD + watch"]
        RayClustersFinalizers["rayclusters/finalizers<br/>update"]
        RayClustersStatus["rayclusters/status<br/>get, patch, update"]
        RayJobs["rayjobs<br/>CRUD + watch"]
    end

    subgraph WorkloadResources["workload.codeflare.dev"]
        AppWrappers["appwrappers<br/>CRUD + watch"]
        AWFinalizers["appwrappers/finalizers<br/>update"]
        AWStatus["appwrappers/status<br/>get, patch, update"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        Ingresses["ingresses<br/>CRUD + watch"]
        NetworkPolicies["networkpolicies<br/>CRUD + watch"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        ClusterRoleBindings2["clusterrolebindings<br/>CRUD + watch"]
    end

    subgraph SchedulingResources["scheduling APIs"]
        PodGroups["podgroups (sigs.k8s.io + x-k8s.io)<br/>CRUD + watch"]
        JobSets["jobsets (jobset.x-k8s.io)<br/>CRUD + watch"]
        PyTorchJobs["pytorchjobs (kubeflow.org)<br/>CRUD + watch"]
    end

    %% Manager role → resources
    CR_Manager -->|"grants access to"| CoreResources
    CR_Manager -->|"grants access to"| AdmissionResources
    CR_Manager -->|"grants access to"| ApiExtResources
    CR_Manager -->|"grants access to"| AppsResources
    CR_Manager -->|"grants access to"| AuthResources
    CR_Manager -->|"grants access to"| BatchResources
    CR_Manager -->|"grants access to"| OpenShiftResources
    CR_Manager -->|"grants access to"| ODHResources
    CR_Manager -->|"grants access to"| RayResources
    CR_Manager -->|"grants access to"| WorkloadResources
    CR_Manager -->|"grants access to"| NetworkResources
    CR_Manager -->|"grants access to"| RBACResources
    CR_Manager -->|"grants access to"| SchedulingResources

    %% Leader election role → resources
    subgraph LeaderResources["Leader Election Resources"]
        LEConfigMaps["configmaps<br/>CRUD"]
        LELeases["leases (coordination.k8s.io)<br/>CRUD"]
        LEEvents["events<br/>create, patch"]
    end

    R_Leader -->|"grants access to"| LeaderResources

