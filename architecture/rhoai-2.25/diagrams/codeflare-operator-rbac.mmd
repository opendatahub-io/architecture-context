graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB[manager-rolebinding<br/>Scope: cluster-wide]
        RB[leader-election-rolebinding<br/>Scope: operator namespace]
    end

    subgraph "Roles"
        CR[manager-role<br/>Type: ClusterRole]
        LER[leader-election-role<br/>Type: Role]
    end

    subgraph "Core API Resources"
        Events[events<br/>create, patch, update, watch]
        Nodes[nodes<br/>get, list, watch]
        Pods[pods<br/>create, delete, get, list, patch, update, watch]
        Services[services<br/>create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>create, delete, get, list, patch, update, watch]
        ServiceAccounts[serviceaccounts<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Apps API Group"
        Deployments[deployments<br/>create, delete, get, list, patch, update, watch]
        StatefulSets[statefulsets<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Batch API Group"
        Jobs[jobs<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Ray API Group (ray.io)"
        RayClusters[rayclusters<br/>create, delete, get, list, patch, update, watch]
        RayClustersFinalizers[rayclusters/finalizers<br/>update]
        RayClustersStatus[rayclusters/status<br/>get, patch, update]
        RayJobs[rayjobs<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Workload API Group (workload.codeflare.dev)"
        AppWrappers[appwrappers<br/>create, delete, get, list, patch, update, watch]
        AppWrappersFinalizers[appwrappers/finalizers<br/>update]
        AppWrappersStatus[appwrappers/status<br/>get, patch, update]
    end

    subgraph "Networking API Group"
        Ingresses[ingresses<br/>create, delete, get, list, patch, update, watch]
        NetworkPolicies[networkpolicies<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "OpenShift API Group (route.openshift.io)"
        Routes[routes<br/>create, delete, get, list, patch, update, watch]
        RoutesCustomHost[routes/custom-host<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "RBAC API Group"
        ClusterRoleBindings[clusterrolebindings<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Admission API Group"
        MutatingWebhooks[mutatingwebhookconfigurations<br/>get, list, update, watch]
        ValidatingWebhooks[validatingwebhookconfigurations<br/>get, list, update, watch]
    end

    subgraph "Auth API Groups"
        TokenReviews[tokenreviews<br/>create]
        SubjectAccessReviews[subjectaccessreviews<br/>create]
    end

    subgraph "ODH API Group (dscinitialization.opendatahub.io)"
        DSCInit[dscinitializations<br/>get, list, watch]
    end

    subgraph "Other API Groups"
        CRDs[customresourcedefinitions<br/>get, list, watch]
        JobSets[jobsets<br/>create, delete, get, list, patch, update, watch]
        PyTorchJobs[pytorchjobs<br/>create, delete, get, list, patch, update, watch]
        PodGroups[podgroups<br/>create, delete, get, list, patch, update, watch]
        OpenShiftIngress["ingresses config.openshift.io<br/>get"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Bindings to Roles
    CRB -->|grants| CR
    RB -->|grants| LER

    %% ClusterRole to Resources
    CR -->|permissions| Events
    CR -->|permissions| Nodes
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| Secrets
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Deployments
    CR -->|permissions| StatefulSets
    CR -->|permissions| Jobs
    CR -->|permissions| RayClusters
    CR -->|permissions| RayClustersFinalizers
    CR -->|permissions| RayClustersStatus
    CR -->|permissions| RayJobs
    CR -->|permissions| AppWrappers
    CR -->|permissions| AppWrappersFinalizers
    CR -->|permissions| AppWrappersStatus
    CR -->|permissions| Ingresses
    CR -->|permissions| NetworkPolicies
    CR -->|permissions| Routes
    CR -->|permissions| RoutesCustomHost
    CR -->|permissions| ClusterRoleBindings
    CR -->|permissions| MutatingWebhooks
    CR -->|permissions| ValidatingWebhooks
    CR -->|permissions| TokenReviews
    CR -->|permissions| SubjectAccessReviews
    CR -->|permissions| DSCInit
    CR -->|permissions| CRDs
    CR -->|permissions| JobSets
    CR -->|permissions| PyTorchJobs
    CR -->|permissions| PodGroups
    CR -->|permissions| OpenShiftIngress

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,color:#000
    style RB fill:#f5a623,stroke:#333,color:#000
    style CR fill:#f5a623,stroke:#333,color:#000
    style LER fill:#f5a623,stroke:#333,color:#000

    %% Core resources
    style Events fill:#7ed321,stroke:#333,color:#000
    style Nodes fill:#7ed321,stroke:#333,color:#000
    style Pods fill:#7ed321,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style Secrets fill:#7ed321,stroke:#333,color:#000
    style ServiceAccounts fill:#7ed321,stroke:#333,color:#000

    %% Ray resources
    style RayClusters fill:#85bbf0,stroke:#333,color:#000
    style RayClustersFinalizers fill:#85bbf0,stroke:#333,color:#000
    style RayClustersStatus fill:#85bbf0,stroke:#333,color:#000
    style RayJobs fill:#85bbf0,stroke:#333,color:#000

    %% AppWrapper resources
    style AppWrappers fill:#85bbf0,stroke:#333,color:#000
    style AppWrappersFinalizers fill:#85bbf0,stroke:#333,color:#000
    style AppWrappersStatus fill:#85bbf0,stroke:#333,color:#000
