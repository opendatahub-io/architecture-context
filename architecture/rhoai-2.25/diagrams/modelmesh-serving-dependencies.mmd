graph LR
    MMS["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MMS -->|"model state storage<br/>gRPC :2379"| etcd["etcd v3.5.x<br/>(Required)"]
    MMS -->|"controller framework<br/>reconciliation loops"| CR["controller-runtime<br/>v0.16.3<br/>(Required)"]
    MMS -->|"CRD types &<br/>constants"| KServe["kserve v0.12.0<br/>(Required)"]

    %% External Dependencies (Optional)
    MMS -.->|"ServiceMonitor CRD<br/>metrics scraping"| PromOp["prometheus-operator<br/>v0.55.0"]
    MMS -.->|"leader-for-life<br/>election"| OpLib["operator-lib<br/>v0.10.0"]

    %% Internal Platform Dependencies
    MMS -->|"gRPC client<br/>SetVModel/DeleteVModel<br/>:8033/TCP"| ModelMesh["ModelMesh<br/>(Java Runtime)"]
    MMS -->|"container image<br/>puller sidecar<br/>:8085-8086/TCP"| Adapter["modelmesh-runtime-<br/>adapter"]
    MMS -.->|"container image<br/>HTTP→gRPC proxy<br/>:8008/TCP"| RESTProxy["modelmesh<br/>REST Proxy"]

    %% Serving Runtimes (Container images managed by controller)
    MMS -->|"built-in runtime<br/>openvino_ir, onnx"| OVMS["OpenVINO Model<br/>Server (OVMS)"]
    MMS -->|"built-in runtime<br/>multi-framework"| Triton["Triton Inference<br/>Server"]
    MMS -->|"built-in runtime<br/>sklearn, xgboost,<br/>lightgbm"| MLServer["MLServer"]
    MMS -->|"built-in runtime<br/>pytorch-mar"| TorchServe["TorchServe"]

    %% Infrastructure
    MMS -->|"CRD watch, CRUD<br/>HTTPS :6443"| K8sAPI["Kubernetes<br/>API Server"]
    MMS -.->|"webhook TLS certs<br/>(upstream)"| CertMgr["cert-manager<br/>v1.13+"]
    MMS -.->|"service TLS certs<br/>(ODH/RHOAI)"| ServingCert["OpenShift<br/>Serving Cert<br/>Controller"]

    %% Integration Points (inbound)
    NSLabels["Namespace Labels<br/>(modelmesh-enabled)"] -->|"label watch<br/>namespace discovery"| MMS

    %% Security Sidecars
    MMS -.->|"controller metrics<br/>:8443 HTTPS"| KRBACProxy["kube-rbac-proxy"]
    MMS -.->|"REST auth<br/>:8443 HTTPS"| OAuthProxy["OpenShift<br/>OAuth Proxy"]

    %% External Storage (via puller sidecar)
    Adapter -->|"model download<br/>HTTPS :443"| S3["S3 Storage"]
    Adapter -->|"model download<br/>HTTPS :443"| GCS["GCS Storage"]
    Adapter -->|"model download<br/>HTTPS :443"| AzureBlob["Azure Blob<br/>Storage"]

    %% Styling
    style MMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style etcd fill:#999,stroke:#333
    style CR fill:#999,stroke:#333
    style KServe fill:#999,stroke:#333

    %% Optional external deps
    style PromOp fill:#bbb,stroke:#333
    style OpLib fill:#bbb,stroke:#333

    %% Internal platform deps
    style ModelMesh fill:#7ed321,stroke:#333
    style Adapter fill:#7ed321,stroke:#333
    style RESTProxy fill:#7ed321,stroke:#333

    %% Serving runtimes
    style OVMS fill:#7ed321,stroke:#333
    style Triton fill:#7ed321,stroke:#333
    style MLServer fill:#7ed321,stroke:#333
    style TorchServe fill:#7ed321,stroke:#333

    %% Infrastructure
    style K8sAPI fill:#f5a623,stroke:#333
    style CertMgr fill:#bbb,stroke:#333
    style ServingCert fill:#bbb,stroke:#333

    %% External storage
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style AzureBlob fill:#f5a623,stroke:#333

    %% Security sidecars
    style KRBACProxy fill:#bbb,stroke:#333
    style OAuthProxy fill:#bbb,stroke:#333

    %% Inbound
    style NSLabels fill:#e8e8e8,stroke:#333
