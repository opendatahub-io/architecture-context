/*
 * ML Metadata (MLMD) - C4 Context Diagram
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/ml-metadata.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Runs ML pipelines and queries artifact lineage"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server and library for recording and retrieving metadata associated with ML workflows" {
            grpcServer = container "metadata_store_server" "C++ gRPC binary exposing MetadataStoreService with 40+ RPC methods" "C++ / gRPC"
            metadataStore = container "MetadataStore" "Core metadata store logic with database abstraction" "C++ Library"
            pythonClient = container "ml_metadata Python Package" "Python client library with gRPC stubs" "Python"
            container_image = container "odh-mlmd-grpc-server" "UBI9-minimal container running gRPC server on port 8080" "Container Image"
        }

        dsp = softwareSystem "Data Science Pipelines" "Primary consumer; records pipeline run metadata, artifact lineage, and execution history" "Internal RHOAI"
        dspo = softwareSystem "Data Science Pipelines Operator" "Deploys and configures the MLMD gRPC server as part of pipeline infrastructure" "Internal RHOAI"
        mysql = softwareSystem "MySQL / MariaDB" "Persistent storage backend for ML metadata" "Database"
        postgresql = softwareSystem "PostgreSQL" "Alternative persistent storage backend for ML metadata" "Database"

        # Relationships
        datascientist -> dsp "Runs pipelines and queries metadata"
        dsp -> mlmd "Records and queries ML metadata" "gRPC/HTTP2 on 8080/TCP"
        dspo -> mlmd "Deploys and configures server"
        mlmd -> mysql "Stores metadata" "MySQL protocol on 3306/TCP"
        mlmd -> postgresql "Stores metadata (alternative)" "PostgreSQL protocol on 5432/TCP"

        # Internal container relationships
        grpcServer -> metadataStore "Uses for data operations"
        pythonClient -> grpcServer "gRPC calls"
        container_image -> grpcServer "Runs"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Database" {
                background #f5a623
                color #ffffff
                shape Cylinder
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
