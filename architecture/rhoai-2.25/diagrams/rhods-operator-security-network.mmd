graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin["Cluster Admin / User"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>Bearer / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: redhat-ods-operator"]
        direction TB

        subgraph OperatorPod["rhods-operator Pod (3 replicas, HA)"]
            Controllers["Controllers<br/>(DSCInit, DSC, 14 Components,<br/>6 Services)"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS: service-ca cert"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end

        WebhookSvc["webhook-service<br/>ClusterIP 443→9443<br/>HTTPS TLS"]
        MetricsSvc["metrics-service<br/>ClusterIP 8443<br/>HTTPS"]
    end

    subgraph ManagedNS["MANAGED NAMESPACES"]
        direction TB

        subgraph AppNS["redhat-ods-applications"]
            Dashboard["Dashboard"]
            KServe["KServe"]
            ModelMesh["ModelMesh"]
            DSP["DataScience Pipelines"]
            OtherComps["+ 10 more components"]
        end

        subgraph MonNS["redhat-ods-monitoring"]
            MonStack["MonitoringStack"]
            TempoStack["TempoMonolithic"]
            OTELCol["OpenTelemetry<br/>Collector"]
        end

        subgraph MeshNS["istio-system"]
            SMCP["ServiceMeshControlPlane"]
            AuthorinoInst["Authorino"]
        end
    end

    subgraph ConditionalOps["CONDITIONAL OPERATORS (Internal)"]
        IstioOp["Maistra/Istio<br/>Operator"]
        AuthorinoOp["Authorino<br/>Operator"]
        KnativeOp["Knative Serving<br/>Operator"]
        COO["Cluster Observability<br/>Operator"]
        TempoOp["Tempo Operator"]
        OTELOp["OpenTelemetry<br/>Operator"]
    end

    subgraph OSPlatform["OPENSHIFT PLATFORM"]
        OAuth["OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ServiceCA["service-ca<br/>(cert provisioning)"]
        CNO["CNO<br/>(CA bundle injection)"]
        OLM["OLM<br/>(operator detection)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        Segment["Segment.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Write Key<br/>(Self-Managed only)"]
        DMS["Deadmansnitch<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(Managed RHOAI only)"]
        PD["PagerDuty<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(Managed RHOAI only)"]
    end

    %% External → Control Plane
    Admin -->|"HTTPS/6443<br/>TLS 1.2+<br/>User token"| K8sAPI

    %% API Server → Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (service-ca)<br/>API server client cert"| WebhookSvc
    WebhookSvc --> WebhookSrv

    %% Operator → API Server (main control loop)
    Controllers -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator → Managed Namespaces (via K8s API)
    Controllers -.->|"deploys manifests<br/>via K8s API"| AppNS
    Controllers -.->|"creates monitoring<br/>resources"| MonNS
    Controllers -.->|"creates SMCP +<br/>Authorino"| MeshNS

    %% Operator → Conditional Operators (via CRD creation through K8s API)
    Controllers -.->|"CRD create/watch"| IstioOp
    Controllers -.->|"CRD create/watch"| AuthorinoOp
    Controllers -.->|"CRD create/watch"| KnativeOp
    Controllers -.->|"CRD create/watch"| COO
    Controllers -.->|"CRD create/watch"| TempoOp
    Controllers -.->|"CRD create/watch"| OTELOp

    %% Operator → OpenShift Platform
    Controllers -->|"HTTPS/443<br/>OAuthClient secret"| OAuth
    ServiceCA -.->|"cert injection"| WebhookSrv
    CNO -.->|"CA bundle"| Controllers
    Controllers -->|"watch Subscriptions"| OLM

    %% Operator → External Services
    Controllers -->|"HTTPS/443<br/>Write key"| Segment
    Controllers -->|"HTTPS/443<br/>Snitch URL"| DMS
    Controllers -->|"HTTPS/443<br/>Integration key"| PD

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e3f2fd,stroke:#1565C0,stroke-width:2px
    classDef operatorns fill:#e8f5e9,stroke:#2E7D32,stroke-width:2px
    classDef managedns fill:#fff3e0,stroke:#E65100,stroke-width:1px
    classDef conditional fill:#f3e5f5,stroke:#6A1B9A,stroke-width:1px
    classDef osplatform fill:#fce4ec,stroke:#AD1457,stroke-width:1px
    classDef externalsvc fill:#fff8e1,stroke:#F57F17,stroke-width:2px

    class Admin external
    class K8sAPI controlplane
    class Controllers,WebhookSrv,Metrics,Health,WebhookSvc,MetricsSvc operatorns
    class Dashboard,KServe,ModelMesh,DSP,OtherComps,MonStack,TempoStack,OTELCol,SMCP,AuthorinoInst managedns
    class IstioOp,AuthorinoOp,KnativeOp,COO,TempoOp,OTELOp conditional
    class OAuth,ServiceCA,CNO,OLM osplatform
    class Segment,DMS,PD externalsvc
