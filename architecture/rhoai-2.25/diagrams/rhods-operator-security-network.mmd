graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Admin User / GitOps]
    end

    subgraph ControlPlane["KUBERNETES API SERVER (Control Plane)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Bearer Token, mTLS"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)<br/>Network Policy: redhat-ods-operator"]
        direction TB

        subgraph WebhookPod["rhods-operator Pod"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS service-ca<br/>mTLS"]
            Controller["Controller<br/>8080/TCP HTTP metrics<br/>8081/TCP HTTP health<br/>SA: rhods-operator-controller-manager"]
            Renderer["Manifest Renderer<br/>Kustomize Engine"]
        end

        WebhookSvc["webhook-service<br/>ClusterIP<br/>443/TCP to 9443/TCP<br/>TLS service-ca"]
        MetricsSvc["metrics-service<br/>ClusterIP<br/>8443/TCP to 8080/TCP<br/>kube-rbac-proxy"]

        RBACProxy["kube-rbac-proxy<br/>Bearer Token + SAR"]

        WebhookSvc -.->|routes to| Webhook
        MetricsSvc -.->|routes to| RBACProxy
        RBACProxy -.->|proxies to| Controller
    end

    subgraph ComponentNS["COMPONENT NAMESPACES (redhat-ods-applications)"]
        direction TB
        Dashboard["ODH Dashboard<br/>40+ manifests"]
        KServe["KServe Controller<br/>30+ manifests"]
        DSP["Data Science Pipelines<br/>35+ manifests"]
        CodeFlare["CodeFlare Operator<br/>20+ manifests"]
        Ray["Ray Operator<br/>15+ manifests"]
        ModelMesh["ModelMesh Serving<br/>25+ manifests"]
        ModelRegistry["Model Registry<br/>15+ manifests"]
        TrustyAI["TrustyAI Service<br/>10+ manifests"]
        Training["Training Operator<br/>15+ manifests"]
        Workbenches["Workbenches<br/>10+ manifests"]
        Kueue["Kueue<br/>10+ manifests"]
        Feast["Feast Operator<br/>8+ manifests"]
    end

    subgraph MonitoringNS["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        direction TB
        Prometheus["Prometheus<br/>StatefulSet<br/>90d retention"]
        Alertmanager["Alertmanager<br/>StatefulSet"]
        OTel["OpenTelemetry Collector<br/>Deployment"]
        Tempo["Tempo<br/>StatefulSet<br/>Distributed tracing"]
    end

    subgraph ExternalIntegrations["EXTERNAL INTEGRATIONS"]
        direction TB
        PrometheusOp["Prometheus Operator<br/>ServiceMonitors, PrometheusRules"]
        IstioOp["Service Mesh Operator<br/>ServiceMeshMembers, SMCP"]
        ServerlessOp["Serverless Operator<br/>KnativeServing"]
        AuthorinoOp["Authorino Operator<br/>AuthConfigs"]
        OpenShiftOAuth["OpenShift OAuth<br/>OAuthClient creation"]
        OpenShiftConsole["OpenShift Console<br/>ConsoleLink creation"]
        ServiceCA["OpenShift Service CA<br/>Cert rotation, CA injection"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS TLS1.2+"]
        GitRepos["External Git Repos<br/>443/TCP HTTPS TLS1.2+<br/>Manifest downloads"]
    end

    %% External to API Server
    Admin -->|HTTPS 6443<br/>TLS 1.2+<br/>kubectl credentials| K8sAPI

    %% API Server to Webhook (admission control)
    K8sAPI -->|HTTPS 443 to 9443<br/>TLS service-ca<br/>mTLS| WebhookSvc
    WebhookSvc -.->|internal| Webhook

    %% Webhook to API Server
    Webhook -->|HTTPS 6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Controller to API Server
    Controller -->|HTTPS 6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Controller renders and deploys manifests
    Controller -.->|in-process| Renderer
    Renderer -->|deploys via API| K8sAPI

    %% API Server to Components
    K8sAPI -->|Deploy manifests<br/>6443/TCP HTTPS TLS1.2+| ComponentNS

    %% Prometheus to Metrics
    Prometheus -->|GET metrics<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token + SAR| MetricsSvc
    MetricsSvc -.->|proxy| RBACProxy
    RBACProxy -.->|HTTP 8080<br/>localhost| Controller

    %% Controller to External Integrations
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| PrometheusOp
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| IstioOp
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| ServerlessOp
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| AuthorinoOp
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| OpenShiftOAuth
    Controller -->|HTTPS 6443<br/>ServiceAccount Token| OpenShiftConsole

    %% Service CA integration
    ServiceCA -.->|ConfigMap watch<br/>Auto-inject CA| OperatorNS
    ServiceCA -.->|Cert rotation| WebhookSvc

    %% Image pulls
    Controller -->|HTTPS 5000<br/>TLS 1.2+<br/>Pull Secrets| ImageRegistry

    %% Optional manifest downloads
    Controller -.->|HTTPS 443<br/>TLS 1.2+<br/>devFlags.manifests| GitRepos

    %% Controller deploys monitoring stack
    Controller -->|Deploys<br/>6443/TCP HTTPS| MonitoringNS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef components fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integrations fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Admin external
    class K8sAPI controlplane
    class Webhook,Controller,Renderer,WebhookSvc,MetricsSvc,RBACProxy operator
    class Dashboard,KServe,DSP,CodeFlare,Ray,ModelMesh,ModelRegistry,TrustyAI,Training,Workbenches,Kueue,Feast components
    class Prometheus,Alertmanager,OTel,Tempo monitoring
    class PrometheusOp,IstioOp,ServerlessOp,AuthorinoOp,OpenShiftOAuth,OpenShiftConsole,ServiceCA,ImageRegistry,GitRepos integrations
