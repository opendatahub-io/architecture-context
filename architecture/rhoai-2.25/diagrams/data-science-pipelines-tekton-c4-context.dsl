// C4 Context Diagram - Data Science Pipelines Tekton
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages ML pipelines, views run results"
        admin = person "Platform Admin" "Manages DSP deployment and configuration"

        dspTekton = softwareSystem "Data Science Pipelines Tekton" "Kubeflow Pipelines backend using Tekton as workflow execution engine for ML pipeline orchestration" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API server for pipeline CRUD, run management, experiment tracking" "Go Service" {
                tags "Core"
            }
            persistenceAgent = container "ds-pipeline-persistenceagent" "Watches Tekton PipelineRun/TaskRun resources and syncs status to API server database" "Go Agent" {
                tags "Core"
            }
            scheduledWorkflow = container "ds-pipeline-scheduledworkflow" "Reconciles ScheduledWorkflow CRs to create PipelineRuns on cron/periodic schedules" "Go Controller" {
                tags "Core"
            }
            frontendUI = container "ds-pipeline-ui" "Web UI for pipeline visualization, run monitoring, and management behind oauth-proxy" "Node.js/React" {
                tags "Core"
            }
            oauthProxy = container "oauth-proxy" "OpenShift OAuth proxy sidecar for UI authentication" "oauth-proxy" {
                tags "Security"
            }
            vizServer = container "ds-pipeline-visualizationserver" "Generates pipeline run visualizations (HTML)" "Python Service" {
                tags "Supporting"
            }
            viewerController = container "ds-pipeline-viewer-crd-controller" "Reconciles Viewer CRs to create TensorBoard deployments" "Go Controller" {
                tags "Supporting"
            }
            metadataGRPC = container "metadata-grpc-server" "ML Metadata gRPC server for artifact and execution tracking" "gRPC Service" {
                tags "Metadata"
            }
            metadataEnvoy = container "metadata-envoy" "Envoy sidecar proxy fronting MLMD gRPC server" "Envoy Proxy" {
                tags "Metadata"
            }
            metadataWriter = container "metadata-writer" "Writes pipeline execution metadata to MLMD from Tekton annotations" "Python Service" {
                tags "Metadata"
            }
            cacheServer = container "cache-server" "Mutating admission webhook for pipeline step caching" "Go Webhook" {
                tags "Core"
            }
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine providing PipelineRun, TaskRun, Task CRDs" {
            tags "External Dependency"
        }
        database = softwareSystem "MariaDB/MySQL" "Persistent metadata storage for pipelines, runs, experiments" {
            tags "External Dependency"
        }
        objectStore = softwareSystem "MinIO/S3 Object Store" "Pipeline artifact storage (logs, outputs, pipeline packages)" {
            tags "External Dependency"
        }
        mlmd = softwareSystem "ML Metadata (MLMD)" "Artifact and execution lineage tracking" {
            tags "External Dependency"
        }
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" {
            tags "Platform"
        }
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Manages deployment lifecycle of all DSP components" {
            tags "Internal RHOAI"
        }
        odhDashboard = softwareSystem "ODH Dashboard" "RHOAI dashboard for component management" {
            tags "Internal RHOAI"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "Platform"
        }

        // User interactions
        user -> oauthProxy "Manages pipelines via UI" "HTTPS/443"
        user -> apiServer "Submits pipelines via SDK/CLI" "HTTP/8888, gRPC/8887"
        admin -> dspOperator "Configures DSP deployment"

        // Internal flows
        oauthProxy -> frontendUI "Proxies authenticated requests" "HTTP/3000"
        frontendUI -> apiServer "Pipeline CRUD, run management" "HTTP/8888"
        apiServer -> k8sAPI "Creates/watches PipelineRun, TaskRun" "HTTPS/443"
        apiServer -> database "Stores pipeline metadata" "MySQL/3306"
        apiServer -> objectStore "Stores/retrieves artifacts" "HTTP/9000"
        persistenceAgent -> k8sAPI "Watches PipelineRun/TaskRun status" "HTTPS/443"
        persistenceAgent -> apiServer "Syncs workflow status" "HTTP/8888"
        scheduledWorkflow -> k8sAPI "Watches ScheduledWorkflow CRs, creates PipelineRuns" "HTTPS/443"
        metadataWriter -> metadataEnvoy "Writes execution metadata" "gRPC/9090"
        metadataEnvoy -> metadataGRPC "Proxies gRPC requests" "gRPC/8080"
        metadataGRPC -> database "Persists ML metadata" "MySQL/3306"
        cacheServer -> k8sAPI "Receives webhook calls" "HTTPS/8443"

        // External interactions
        k8sAPI -> tekton "Dispatches PipelineRun reconciliation"
        dspOperator -> dspTekton "Manages component lifecycle"
        odhDashboard -> dspTekton "Registers via OdhApplication CR"
        prometheus -> apiServer "Scrapes metrics" "HTTP/8888 /metrics"
    }

    views {
        systemContext dspTekton "SystemContext" {
            include *
            autoLayout
        }

        container dspTekton "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External Dependency" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Platform" {
                background #d4a843
                color #000000
            }
            element "Core" {
                background #438dd5
                color #ffffff
            }
            element "Supporting" {
                background #85bbf0
                color #000000
            }
            element "Metadata" {
                background #5fa8d3
                color #ffffff
            }
            element "Security" {
                background #e05959
                color #ffffff
            }
        }
    }
}
