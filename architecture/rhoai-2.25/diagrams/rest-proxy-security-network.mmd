graph TB
    subgraph External["EXTERNAL (Clients)"]
        Client["REST Client<br/>(Data Scientist / Application)"]
    end

    subgraph Pod["MODELMESH SERVING POD (Pod-Local Network)"]
        direction TB

        subgraph SidecarContainer["Sidecar: rest-proxy"]
            RestProxy["rest-proxy<br/>odh-mm-rest-proxy<br/>Listen: 0.0.0.0:8008/TCP<br/>FIPS: strictfipsruntime"]
        end

        subgraph MainContainer["Container: ModelMesh"]
            ModelMesh["ModelMesh gRPC<br/>GRPCInferenceService<br/>Listen: localhost:8033/TCP"]
        end
    end

    subgraph Config["CONFIGURATION"]
        ConfigMap["model-serving-config<br/>ConfigMap<br/>restProxy.image field"]
        TLSSecret["TLS Certificate<br/>via MM_TLS_KEY_CERT_PATH<br/>Provisioned by cert-manager"]
    end

    %% Network Flows
    Client -->|"HTTP/HTTPS : 8008/TCP<br/>TLS optional (MM_TLS_KEY_CERT_PATH)<br/>Auth: None (delegated to ModelMesh infra)"| RestProxy
    RestProxy -->|"gRPC : localhost:8033/TCP<br/>TLS optional (REST_PROXY_USE_TLS)<br/>InsecureSkipVerify configurable<br/>Auth: None"| ModelMesh

    %% Configuration
    ConfigMap -.->|"image config"| SidecarContainer
    TLSSecret -.->|"TLS cert/key"| RestProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#2a6ab2,stroke-width:2px,color:#fff
    classDef main fill:#7ed321,stroke:#5ea311,stroke-width:2px,color:#fff
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RestProxy sidecar
    class ModelMesh main
    class ConfigMap,TLSSecret config
