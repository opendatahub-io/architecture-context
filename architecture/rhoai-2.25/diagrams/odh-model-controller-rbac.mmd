graph TD
    subgraph "Service Accounts"
        SA[odh-model-controller<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-role-binding<br/>Scope: All namespaces]
        CRB2[odh-model-controller-metrics-auth-rolebinding<br/>Scope: odh-model-controller namespace]
        CRB3[odh-model-controller-auth-proxy-rolebinding<br/>Scope: odh-model-controller namespace]
    end

    subgraph "Role Bindings"
        RB1[leader-election-rolebinding<br/>Scope: odh-model-controller namespace]
    end

    subgraph "ClusterRoles"
        CR[odh-model-controller-role]
        MetricsRole[metrics-auth-role]
        ProxyRole[auth-proxy-role]
    end

    subgraph "Roles"
        LeaderElectionRole[leader-election-role]
    end

    subgraph "KServe API Resources"
        ISVC[serving.kserve.io<br/>InferenceService]
        IG[serving.kserve.io<br/>InferenceGraph]
        LLMISVC[serving.kserve.io<br/>LLMInferenceService]
        SR[serving.kserve.io<br/>ServingRuntime]
        KSvc[serving.knative.dev<br/>Service]
    end

    subgraph "NIM API Resources"
        Account[nim.opendatahub.io<br/>Account<br/>Account/status<br/>Account/finalizers]
    end

    subgraph "Istio API Resources"
        VS[networking.istio.io<br/>VirtualService]
        GW[networking.istio.io<br/>Gateway]
        PA[security.istio.io<br/>PeerAuthentication]
        AuthZ[security.istio.io<br/>AuthorizationPolicy]
        Telem[telemetry.istio.io<br/>Telemetry]
    end

    subgraph "Maistra API Resources"
        SMM[maistra.io<br/>ServiceMeshMember]
        SMMR[maistra.io<br/>ServiceMeshMemberRoll]
        SMCP[maistra.io<br/>ServiceMeshControlPlane]
    end

    subgraph "OpenShift API Resources"
        Route[route.openshift.io<br/>Route<br/>Route/custom-host]
        Template[template.openshift.io<br/>Template]
    end

    subgraph "Monitoring API Resources"
        SM[monitoring.coreos.com<br/>ServiceMonitor]
        PM[monitoring.coreos.com<br/>PodMonitor]
    end

    subgraph "Auth API Resources"
        AuthConfig[authorino.kuadrant.io<br/>AuthConfig]
        AuthPolicy[kuadrant.io<br/>AuthPolicy]
    end

    subgraph "Other API Resources"
        NP[networking.k8s.io<br/>NetworkPolicy]
        Ingress[networking.k8s.io<br/>Ingress]
        TA[keda.sh<br/>TriggerAuthentication]
        RBAC[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>RoleBinding<br/>Role]
        Core[core<br/>ConfigMap<br/>Secret<br/>ServiceAccount<br/>Service<br/>Pod<br/>Namespace<br/>Event<br/>Endpoint]
        Coordination[coordination.k8s.io<br/>Lease]
        Metrics[metrics.k8s.io<br/>Pod<br/>Node]
    end

    subgraph "ODH API Resources"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1

    %% ClusterRole bindings
    CRB1 -->|grants| CR
    CRB2 -->|grants| MetricsRole
    CRB3 -->|grants| ProxyRole

    %% Role bindings
    RB1 -->|grants| LeaderElectionRole

    %% Permissions - KServe
    CR -->|get,list,patch,update,watch| ISVC
    CR -->|get,list,patch,update,watch<br/>finalizers: create,delete,update| IG
    CR -->|get,list,patch,update,watch<br/>finalizers: create,delete,update| LLMISVC
    CR -->|create,get,list,update,watch<br/>finalizers: update| SR
    CR -->|get,list,watch| KSvc

    %% Permissions - NIM
    CR -->|get,list,patch,update,watch| Account

    %% Permissions - Istio
    CR -->|create,delete,get,list,patch,update,watch<br/>finalizers: create,delete,update| VS
    CR -->|get,list,patch,update,watch| GW
    CR -->|create,delete,get,list,patch,update,watch| PA
    CR -->|get,list| AuthZ
    CR -->|create,delete,get,list,patch,update,watch| Telem

    %% Permissions - Maistra
    CR -->|create,delete,get,list,patch,update,watch| SMM
    CR -->|get,list,watch| SMMR
    CR -->|get,list,use,watch| SMCP

    %% Permissions - OpenShift
    CR -->|create,delete,get,list,patch,update,watch| Route
    CR -->|create,delete,get,list,patch,update,watch| Template

    %% Permissions - Monitoring
    CR -->|create,delete,get,list,patch,update,watch| SM
    CR -->|create,delete,get,list,patch,update,watch| PM

    %% Permissions - Auth
    CR -->|create,delete,get,list,patch,update,watch| AuthConfig
    CR -->|create,delete,get,list,patch,update,watch| AuthPolicy

    %% Permissions - Other
    CR -->|create,delete,get,list,patch,update,watch| NP
    CR -->|get,list,watch| Ingress
    CR -->|create,delete,get,list,patch,update,watch| TA
    CR -->|create,delete,get,list,patch,update,watch| RBAC
    CR -->|create,delete,get,list,patch,update,watch| Core
    CR -->|get,list,watch| Metrics

    %% Permissions - ODH
    CR -->|get,list,watch| DSC
    CR -->|get,list,watch| DSCI

    %% Leader election permissions
    LeaderElectionRole -->|get,list,watch,create,update,patch,delete| Coordination
    LeaderElectionRole -->|create,patch| Core

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderElectionRole fill:#f5a623,stroke:#333,stroke-width:2px
    style MetricsRole fill:#f5a623,stroke:#333,stroke-width:2px
    style ProxyRole fill:#f5a623,stroke:#333,stroke-width:2px

    style ISVC fill:#7ed321,stroke:#333
    style IG fill:#7ed321,stroke:#333
    style LLMISVC fill:#7ed321,stroke:#333
    style SR fill:#7ed321,stroke:#333
    style Account fill:#7ed321,stroke:#333

    style VS fill:#9b59b6,stroke:#333
    style GW fill:#9b59b6,stroke:#333
    style PA fill:#9b59b6,stroke:#333
    style Telem fill:#9b59b6,stroke:#333

    style Route fill:#e74c3c,stroke:#333
    style Template fill:#e74c3c,stroke:#333

    style SM fill:#3498db,stroke:#333
    style PM fill:#3498db,stroke:#333

    style AuthConfig fill:#e67e22,stroke:#333
    style AuthPolicy fill:#e67e22,stroke:#333
