graph TB
    subgraph TrainingOperator["Training Operator (Single Deployment)"]
        direction TB
        Controller["Common JobController<br/>controller-runtime<br/>Go Operator"]
        Webhook["Webhook Server<br/>9443/TCP TLS"]
        CertMgr["OPA Cert Controller<br/>Self-signed TLS"]

        subgraph FrameworkControllers["Framework Reconcilers"]
            PyTorchCtrl["PyTorch Controller"]
            TFCtrl["TensorFlow Controller"]
            XGBoostCtrl["XGBoost Controller"]
            MPICtrl["MPI Controller"]
            JAXCtrl["JAX Controller"]
            PaddleCtrl["PaddlePaddle Controller"]
        end

        Controller --> PyTorchCtrl
        Controller --> TFCtrl
        Controller --> XGBoostCtrl
        Controller --> MPICtrl
        Controller --> JAXCtrl
        Controller --> PaddleCtrl
        CertMgr -->|manages certs| Webhook
    end

    %% CRDs
    User[Data Scientist / User] -->|creates| PyTorchJobCR[PyTorchJob CR]
    User -->|creates| TFJobCR[TFJob CR]
    User -->|creates| XGBoostJobCR[XGBoostJob CR]
    User -->|creates| MPIJobCR[MPIJob CR]
    User -->|creates| JAXJobCR[JAXJob CR]
    User -->|creates| PaddleJobCR[PaddleJob CR]

    %% CRD watches
    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MPIJobCR -->|watched by| MPICtrl
    JAXJobCR -->|watched by| JAXCtrl
    PaddleJobCR -->|watched by| PaddleCtrl

    %% Webhook validation
    K8sAPI[Kubernetes API Server] -->|admission webhook| Webhook

    %% Created resources
    Controller -->|creates| MasterPods[Master Pods]
    Controller -->|creates| WorkerPods[Worker Pods]
    Controller -->|creates| HeadlessSvcs[Headless Services<br/>Pod-to-Pod DNS]
    PyTorchCtrl -->|creates| NetworkPolicies[NetworkPolicies]
    PyTorchCtrl -->|creates| HPAs[HPA<br/>Elastic Training]
    MPICtrl -->|creates| MPIResources["ConfigMaps + RBAC<br/>(hostfile, kubexec.sh,<br/>SA, Role, RoleBinding)"]

    %% External integrations
    Controller -->|gang scheduling| Volcano[Volcano Scheduler]
    Controller -->|gang scheduling| SchedulerPlugins[Scheduler-Plugins]
    Controller -->|metrics 8080/TCP| Prometheus[OpenShift Monitoring<br/>PodMonitor]

    %% Styles
    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style CertMgr fill:#4a90e2,color:#fff
    style PyTorchCtrl fill:#5ba5f0,color:#fff
    style TFCtrl fill:#5ba5f0,color:#fff
    style XGBoostCtrl fill:#5ba5f0,color:#fff
    style MPICtrl fill:#5ba5f0,color:#fff
    style JAXCtrl fill:#5ba5f0,color:#fff
    style PaddleCtrl fill:#5ba5f0,color:#fff
    style PyTorchJobCR fill:#f5a623,color:#fff
    style TFJobCR fill:#f5a623,color:#fff
    style XGBoostJobCR fill:#f5a623,color:#fff
    style MPIJobCR fill:#f5a623,color:#fff
