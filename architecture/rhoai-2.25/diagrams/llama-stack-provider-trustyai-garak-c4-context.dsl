/*
 * C4 Context Diagram: llama-stack-provider-trustyai-garak
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/llama-stack-provider-trustyai-garak.md
 */

workspace {
    model {
        user = person "Data Scientist / Security Engineer" "Initiates red-teaming scans against deployed LLMs"

        garakProvider = softwareSystem "Llama Stack Provider TrustyAI Garak" "Out-of-tree Llama Stack Eval provider wrapping NVIDIA Garak for automated LLM red-teaming and security testing" {
            llamaStackServer = container "Llama Stack Server" "Hosts provider on port 8321/TCP, serves Llama Stack Eval API" "Python 3.12 / UBI9"
            garakEvalAdapter = container "GarakEvalAdapter" "Inline provider: runs Garak scans as local async subprocesses with semaphore-based concurrency" "Python"
            garakRemoteEvalAdapter = container "GarakRemoteEvalAdapter" "Remote provider: submits Garak scans as Kubeflow Pipeline runs with S3-based result coordination" "Python"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Orchestrates input/output shield checks around LLM inference using httpx HTTP/2" "Python"
            scanConfig = container "GarakScanConfig" "Defines scan profiles (quick, standard) and compliance frameworks (OWASP LLM Top 10, AVID)" "Python / YAML"
        }

        vllm = softwareSystem "vLLM" "Target LLM model serving endpoint for security probing" "Internal RHOAI"
        filesAPI = softwareSystem "Llama Stack Files API" "Storage of scan reports (JSON, HTML, logs)" "Internal Llama Stack"
        safetyAPI = softwareSystem "Llama Stack Safety API" "Shield execution for guardrail testing (Prompt-Guard, Llama-Guard)" "Internal Llama Stack"
        benchmarksAPI = softwareSystem "Llama Stack Benchmarks API" "Benchmark registration and retrieval for scan profiles" "Internal Llama Stack"
        kfp = softwareSystem "Data Science Pipelines (KFP)" "Kubeflow Pipelines for remote scan execution on Kubernetes" "Internal RHOAI"
        s3 = softwareSystem "S3/MinIO" "Artifact exchange for remote mode result coordination" "External"
        otlp = softwareSystem "OpenTelemetry Collector" "Telemetry trace export via OTLP" "External"
        garak = softwareSystem "NVIDIA Garak" "Red-teaming and security testing framework v0.12.0" "External"

        user -> garakProvider "Starts red-teaming scans via Eval API" "HTTP/8321"
        garakProvider -> vllm "Probes target LLM with security tests" "HTTP/HTTPS"
        garakProvider -> filesAPI "Stores and retrieves scan reports" "In-process API"
        garakProvider -> safetyAPI "Runs shield checks for guardrail testing" "HTTP/8321 loopback"
        garakProvider -> benchmarksAPI "Registers and retrieves scan profiles" "In-process API"
        garakProvider -> kfp "Submits pipeline runs for remote execution" "HTTPS/443"
        garakProvider -> s3 "Uploads/downloads result mappings" "HTTPS/443"
        garakProvider -> otlp "Exports telemetry traces" "HTTPS"
        garakProvider -> garak "Invokes red-teaming probes" "subprocess"

        garakEvalAdapter -> garak "Launches scan subprocess"
        garakRemoteEvalAdapter -> kfp "Submits 3-stage pipeline"
        garakRemoteEvalAdapter -> s3 "Coordinates results"
        shieldOrchestrator -> safetyAPI "Shield check calls"
    }

    views {
        systemContext garakProvider "SystemContext" {
            include *
            autoLayout
        }

        container garakProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal Llama Stack" {
                background #9b59b6
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
