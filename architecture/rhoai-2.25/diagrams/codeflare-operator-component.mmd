graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)"]

        subgraph Controllers["Controllers"]
            RCController["RayCluster Controller<br/>Reconciles RayCluster resources"]
            AWController["AppWrapper Controller<br/>(embedded, optional)<br/>Kueue integration"]
        end

        subgraph Webhooks["Webhooks (9443/TCP TLS)"]
            RCMutate["RayCluster Mutating Webhook<br/>Injects oauth-proxy, mTLS init containers"]
            RCValidate["RayCluster Validating Webhook<br/>Enforces immutability of injected components"]
            AWMutate["AppWrapper Mutating Webhook<br/>Defaults AppWrapper resources"]
            AWValidate["AppWrapper Validating Webhook<br/>SAR-based authorization"]
        end

        CertCtrl["cert-controller<br/>(embedded library)<br/>Webhook TLS cert rotation"]

        Manager --> RCController
        Manager --> AWController
        Manager --> CertCtrl
        RCController --> RCMutate
        RCController --> RCValidate
        AWController --> AWMutate
        AWController --> AWValidate
    end

    %% CRDs watched/created
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)<br/>Owned by KubeRay"]
    AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    %% Resources created per RayCluster
    subgraph CreatedResources["Resources Created per RayCluster"]
        OAuthRoute["OpenShift Route<br/>ray-dashboard-{cluster}<br/>443/TCP Reencrypt"]
        ClientRoute["OpenShift Route<br/>rayclient-{cluster}<br/>443/TCP Passthrough"]
        OAuthSecret["OAuth Config Secret<br/>{cluster}-oauth-config"]
        CASecret["CA Secret<br/>ca-secret-{cluster}<br/>RSA 2048-bit"]
        ProxyTLS["Proxy TLS Secret<br/>{cluster}-proxy-tls-secret"]
        NetPol["NetworkPolicies<br/>{cluster}-head<br/>{cluster}-workers"]
        OAuthSA["ServiceAccount<br/>{cluster}-oauth-proxy"]
        CRB["ClusterRoleBinding<br/>{cluster}-{ns}-auth"]
        OAuthSvc["Service<br/>{cluster}-oauth<br/>443→8443"]
    end

    %% Injected into RayCluster pods
    subgraph InjectedContainers["Injected into RayCluster Pods"]
        OAuthProxy["oauth-proxy sidecar<br/>Port 8443/TCP"]
        CertInit["create-cert init container<br/>mTLS certificate generation"]
    end

    %% External dependencies
    KubeRay["KubeRay Operator"]
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    ODHOperator["opendatahub-operator<br/>(DSCInitialization)"]
    OSHOAuth["OpenShift OAuth Server"]
    OSHIngress["OpenShift Ingress Controller"]
    Kueue["Kueue<br/>(optional)"]
    Prometheus["Prometheus<br/>8080/TCP metrics"]

    %% Relationships
    KubeRay -->|creates| RayClusterCR
    RayClusterCR -->|watched by| RCController
    RCMutate -->|intercepts create/update| RayClusterCR
    RCController -->|creates| OAuthRoute
    RCController -->|creates| ClientRoute
    RCController -->|creates| OAuthSecret
    RCController -->|creates| CASecret
    RCController -->|creates| NetPol
    RCController -->|creates| OAuthSA
    RCController -->|creates| CRB
    RCController -->|creates| OAuthSvc
    RCMutate -->|injects| OAuthProxy
    RCMutate -->|injects| CertInit

    AppWrapperCR -->|managed by| AWController
    AWController -->|integrates| Kueue

    RCController -->|reads DSCInitialization| ODHOperator
    OAuthProxy -->|delegates auth| OSHOAuth
    OAuthRoute -->|consumed by| OSHIngress
    Manager -->|watches, CRUD| K8sAPI
    Prometheus -->|scrapes| Manager

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style RCMutate fill:#9b59b6,stroke:#333,color:#fff
    style RCValidate fill:#9b59b6,stroke:#333,color:#fff
    style AWMutate fill:#9b59b6,stroke:#333,color:#fff
    style AWValidate fill:#9b59b6,stroke:#333,color:#fff
    style CertCtrl fill:#4a90e2,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style OAuthProxy fill:#e74c3c,stroke:#333,color:#fff
    style CertInit fill:#e74c3c,stroke:#333,color:#fff
    style KubeRay fill:#7ed321,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
    style OSHOAuth fill:#999,stroke:#333
    style OSHIngress fill:#999,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
