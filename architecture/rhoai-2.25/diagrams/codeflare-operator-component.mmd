%% Component Structure Diagram - CodeFlare Operator
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "CodeFlare Operator"
        direction TB
        Manager["Operator Manager<br/>(Deployment)"]

        subgraph "Controllers"
            RCController["RayCluster Controller<br/>(controller-runtime)"]
            AWController["AppWrapper Controller<br/>(optional, embedded)"]
        end

        subgraph "Webhooks (9443/TCP HTTPS)"
            RCMutate["RayCluster<br/>Mutating Webhook"]
            RCValidate["RayCluster<br/>Validating Webhook"]
            AWMutate["AppWrapper<br/>Mutating Webhook"]
            AWValidate["AppWrapper<br/>Validating Webhook"]
        end

        CertRotator["Cert Rotator<br/>(cert-controller)"]

        Manager --> RCController
        Manager --> AWController
        Manager --> CertRotator
        CertRotator -->|manages certs| RCMutate
        CertRotator -->|manages certs| RCValidate
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|creates| AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    RayClusterCR -->|watched by| RCController
    AppWrapperCR -->|watched by| AWController

    %% API Server Webhook Flow
    APIServer["Kubernetes API Server"] -->|admission| RCMutate
    APIServer -->|admission| RCValidate
    APIServer -->|admission| AWMutate
    APIServer -->|admission| AWValidate

    %% Resources created by RayCluster Controller
    RCController -->|creates| OAuthRoute["OpenShift Route<br/>(ray-dashboard)"]
    RCController -->|creates| ClientRoute["OpenShift Route<br/>(rayclient)"]
    RCController -->|creates| OAuthService["OAuth Proxy Service<br/>(443 -> 8443)"]
    RCController -->|creates| SA["ServiceAccount"]
    RCController -->|creates| CRB["ClusterRoleBinding"]
    RCController -->|creates| NetPol["NetworkPolicies"]
    RCController -->|creates| CASecret["CA Secret<br/>(mTLS certs)"]

    %% Webhook injects sidecars
    RCMutate -->|injects| OAuthProxy["oauth-proxy sidecar<br/>(8443/TCP)"]
    RCMutate -->|injects| InitCert["create-cert init container"]

    %% AppWrapper creates wrapped resources
    AWController -->|creates wrapped| WrappedResources["Wrapped Resources<br/>(RayClusters, Jobs, etc.)"]

    %% External Dependencies
    RCController -->|depends on| KubeRay["KubeRay Operator"]
    AWController -->|integrates| Kueue["Kueue"]
    RCController -->|reads| DSCI["DSCInitialization CR"]
    RCController -->|reads| IngressConfig["OpenShift Ingress Config"]
    OAuthRoute -->|authenticates via| OpenShiftOAuth["OpenShift OAuth"]

    %% Deployment
    RHODSOp["rhods-operator"] -->|deploys via kustomize| Manager

    %% Styling
    style Manager fill:#4a90e2,color:#fff
    style RCController fill:#4a90e2,color:#fff
    style AWController fill:#4a90e2,color:#fff
    style RCMutate fill:#4a90e2,color:#fff
    style RCValidate fill:#4a90e2,color:#fff
    style AWMutate fill:#4a90e2,color:#fff
    style AWValidate fill:#4a90e2,color:#fff
    style CertRotator fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,color:#000
    style AppWrapperCR fill:#f5a623,color:#000
    style KubeRay fill:#e8e8e8,color:#000
    style Kueue fill:#e8e8e8,color:#000
    style OpenShiftOAuth fill:#e8e8e8,color:#000
    style RHODSOp fill:#7ed321,color:#000
    style DSCI fill:#7ed321,color:#000
