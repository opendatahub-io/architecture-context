graph TB
    subgraph KubeRayOperator["KubeRay Operator (Go / controller-runtime)"]
        direction TB
        RayClusterCtrl["RayCluster Controller<br/>Reconciles head/worker pods,<br/>services, ingress, routes, RBAC"]
        RayJobCtrl["RayJob Controller<br/>Manages job submission &amp;<br/>lifecycle via Dashboard API"]
        RayServiceCtrl["RayService Controller<br/>Zero-downtime upgrades via<br/>blue-green cluster promotion"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>Validates RayCluster CRs"]
        MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>Prometheus metrics"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        BatchSchedulerIface["Batch Scheduler Interface<br/>(pluggable)"]

        RayJobCtrl -->|creates/manages| RayClusterCtrl
        RayServiceCtrl -->|creates/manages| RayClusterCtrl
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    User -->|creates| RayJobCR["RayJob CR<br/>ray.io/v1"]
    User -->|creates| RayServiceCR["RayService CR<br/>ray.io/v1"]

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Resources Created
    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod<br/>Ports: 6379, 8265, 8000, 10001"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>Headless / ClusterIP"]
    RayClusterCtrl -->|creates| ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
    RayClusterCtrl -->|creates| DashboardRoute["Route / Ingress<br/>Dashboard 8265/TCP"]

    %% Operator → Ray Head interactions
    RayJobCtrl -->|submit job / poll status<br/>HTTP 8265/TCP| HeadPod
    RayServiceCtrl -->|deploy serve app<br/>HTTP 8265/TCP| HeadPod
    RayServiceCtrl -->|health check<br/>HTTP 8000/TCP| HeadPod

    %% Worker → Head
    WorkerPods -->|GCS connection<br/>TCP 6379| HeadPod

    %% Batch scheduler
    BatchSchedulerIface -.->|PodGroup| Volcano["Volcano Scheduler"]
    BatchSchedulerIface -.->|AppWrapper| YuniKorn["YuniKorn Scheduler"]
    BatchSchedulerIface -.->|ManagedBy| Kueue["Kueue"]

    %% External dependencies
    RayClusterCtrl -->|CRUD operations<br/>HTTPS 6443| K8sAPI["Kubernetes API Server"]
    WebhookServer -->|cert| CertManager["cert-manager"]

    %% Platform integration
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|deploys via Kustomize| KubeRayOperator
    Prometheus["Prometheus"] -->|scrapes| MetricsEndpoint

    %% Styling
    style KubeRayOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,color:#fff
    style RayJobCtrl fill:#4a90e2,color:#fff
    style RayServiceCtrl fill:#4a90e2,color:#fff
    style WebhookServer fill:#4a90e2,color:#fff
    style MetricsEndpoint fill:#4a90e2,color:#fff
    style HealthProbes fill:#4a90e2,color:#fff
    style BatchSchedulerIface fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,color:#fff
    style RayJobCR fill:#f5a623,color:#fff
    style RayServiceCR fill:#f5a623,color:#fff
    style HeadPod fill:#7ed321,color:#fff
    style WorkerPods fill:#7ed321,color:#fff
    style HeadSvc fill:#7ed321,color:#fff
    style ServeSvc fill:#7ed321,color:#fff
    style DashboardRoute fill:#7ed321,color:#fff
    style Volcano fill:#e8e8e8,stroke:#999
    style YuniKorn fill:#e8e8e8,stroke:#999
    style Kueue fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style CertManager fill:#e8e8e8,stroke:#999
    style PlatformOp fill:#b8e6b8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#999
