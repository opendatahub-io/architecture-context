graph TB
    subgraph "KubeRay Operator"
        Operator[kuberay-operator<br/>Main Controller]
        RayClusterCtrl[RayCluster Controller<br/>Manages clusters]
        RayJobCtrl[RayJob Controller<br/>Manages batch jobs]
        RayServiceCtrl[RayService Controller<br/>Manages ML serving]
        Webhook[Admission Webhook<br/>Validates CRs]
        Metrics[Metrics Exporter<br/>8080/TCP HTTP]

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
        Operator --> Webhook
        Operator --> Metrics
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Resources (Dynamically Created)"
        HeadPod[Ray Head Pod<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP]
        WorkerPods[Ray Worker Pods<br/>Auto-scaling]
        HeadService[Head Service<br/>ClusterIP]
        ServeService[Serve Service<br/>8000/TCP HTTP]
        Ingress[Ingress/Route<br/>External Access]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Collection]
        Redis[External Redis<br/>GCS Fault Tolerance]
        CertManager[cert-manager<br/>Webhook TLS]
        Volcano[Volcano<br/>Gang Scheduling]
    end

    %% User interactions
    User[User/System] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CR to Controller
    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Webhook validation
    K8sAPI -->|validates via| Webhook

    %% Controller creates resources
    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadService
    RayJobCtrl -->|creates| RayClusterCR
    RayServiceCtrl -->|creates| RayClusterCR
    RayServiceCtrl -->|creates| ServeService
    RayClusterCtrl -->|creates| Ingress

    %% Ray cluster internal
    WorkerPods -->|connects to| HeadPod

    %% External integrations
    Operator -->|manages via| K8sAPI
    Prometheus -->|scrapes| Metrics
    HeadPod -->|optional| Redis
    Webhook -->|cert from| CertManager
    HeadPod -.->|gang scheduling| Volcano

    %% External access
    ExternalClient[External Client] -->|HTTP/HTTPS| Ingress
    Ingress -->|routes to| HeadService
    Ingress -->|routes to| ServeService

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Redis fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Volcano fill:#999,stroke:#333
