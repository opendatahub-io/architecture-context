// C4 Context Diagram for vllm-rocm
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Sends inference requests to deployed LLM models"

        vllmRocm = softwareSystem "vllm-rocm" "AMD ROCm-accelerated vLLM inference runtime for serving LLMs on AMD GPUs" {
            vllmEngine = container "vLLM Engine" "Core LLM inference engine with PagedAttention, continuous batching, tensor parallelism" "Python/C++/HIP" "Runtime"
            tgisAdapter = container "vllm-tgis-adapter" "TGIS-compatible gRPC adapter over vLLM engine" "Python" "Runtime"
            entrypoint = container "Custom Entrypoint" "Environment configuration and startup orchestration" "Shell" "Runtime"
        }

        // Platform components (Internal ODH)
        kserve = softwareSystem "KServe" "Deploys and manages InferenceService pods with vllm-rocm container" "Internal ODH"
        modelmesh = softwareSystem "ModelMesh" "Alternative serving runtime deployment target" "Internal ODH"
        odhModelController = softwareSystem "odh-model-controller" "Manages routing and ingress for inference endpoints" "Internal ODH"
        caikitTgis = softwareSystem "caikit-tgis-serving" "Caikit NLP serving framework that can call vLLM via TGIS adapter" "Internal ODH"
        platformIngress = softwareSystem "Platform Ingress" "Gateway API / OpenShift Routes for external access" "Internal ODH"

        // External dependencies
        rhaiisBase = softwareSystem "RHAIIS Base Image" "Red Hat AI Inference Server base image with vLLM and ROCm" "External"
        modelStorage = softwareSystem "Model Storage (S3/PVC)" "Stores model weights and artifacts" "External"
        huggingFaceHub = softwareSystem "Hugging Face Hub" "Public model repository for downloading models/tokenizers" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        amdGpu = softwareSystem "AMD GPU Hardware" "AMD ROCm/HIP-capable GPU for accelerated inference" "External"

        // Relationships
        user -> platformIngress "Sends inference requests" "HTTPS/443"
        platformIngress -> vllmRocm "Forwards requests" "HTTP/8000, gRPC/8033"

        kserve -> vllmRocm "Deploys as predictor container" "Container runtime"
        modelmesh -> vllmRocm "Alternative deployment target" "Container runtime"
        odhModelController -> platformIngress "Manages routing" "Kubernetes API"
        caikitTgis -> vllmRocm "Calls via TGIS gRPC protocol" "gRPC/8033"

        vllmRocm -> modelStorage "Downloads model weights at startup" "HTTPS/443"
        vllmRocm -> huggingFaceHub "Downloads model/tokenizer if not cached" "HTTPS/443"
        vllmRocm -> amdGpu "Executes inference on GPU" "ROCm/HIP"
        prometheus -> vllmRocm "Scrapes metrics" "HTTP/8000 /metrics"

        rhaiisBase -> vllmRocm "Provides base layer" "Container image"

        // Container relationships
        entrypoint -> vllmEngine "Starts"
        entrypoint -> tgisAdapter "Starts"
        tgisAdapter -> vllmEngine "Forwards gRPC to engine"
    }

    views {
        systemContext vllmRocm "SystemContext" {
            include *
            autoLayout
        }

        container vllmRocm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #333333
            }
            element "Runtime" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
