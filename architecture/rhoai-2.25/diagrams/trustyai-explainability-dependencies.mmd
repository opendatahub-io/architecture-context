graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"gRPC V2 Inference<br/>model invocation"| KServe["KServe"]
    TrustyAI -->|"gRPC V2 Inference<br/>model invocation"| ModelMesh["ModelMesh Serving"]
    TrustyAI -.->|"deployed & configured by<br/>TrustyAIService CR"| TrustyAIOp["TrustyAI Operator"]

    %% Inbound integrations
    ModelMesh -->|"HTTP POST<br/>/consumer/kserve/v2<br/>partial payloads"| TrustyAI
    KServe -->|"CloudEvents (Knative)<br/>inference payloads"| TrustyAI
    Dashboard["ODH Dashboard"] -->|"REST API<br/>bias/fairness UI"| TrustyAI

    %% Monitoring
    Prometheus["Prometheus<br/>ServiceMonitor"] -->|"GET /q/metrics<br/>4s scrape<br/>Bearer Token"| TrustyAI

    %% Framework Dependencies
    TrustyAI -->|"application framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"V2 protocol client"| GRPC["gRPC 1.75.0"]
    TrustyAI -->|"payload serialization"| Protobuf["Protobuf 3.25.5"]
    TrustyAI -->|"constraint solver<br/>(Counterfactual)"| OptaPlanner["OptaPlanner 8.30.0"]
    TrustyAI -->|"metrics exposition"| Micrometer["Micrometer<br/>Prometheus"]
    TrustyAI -->|"reactive I/O"| Vertx["Vert.x 4.5.24"]

    %% Storage Dependencies
    TrustyAI -->|"flat-file storage<br/>volume mount /inputs"| PVC["PVC Volume"]
    TrustyAI -->|"S3 API<br/>Access Key auth"| MinIO["MinIO<br/>(Quarkiverse 3.3.1)"]
    TrustyAI -->|"JDBC<br/>Username/Password"| MariaDB["MariaDB/MySQL<br/>(Hibernate 6.2.13)"]

    %% Infrastructure
    TrustyAI -.->|"TLS certs<br/>/etc/tls/internal/"| CertManager["cert-manager"]
    TrustyAI -->|"configmap CRUD"| K8sAPI["Kubernetes API"]

    %% Optional
    TrustyAI -.->|"Arrow IPC<br/>(Python bridge)"| Arrow["Apache Arrow 15.0.2"]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% Framework
    style Quarkus fill:#4695EB,stroke:#333,color:#fff
    style GRPC fill:#4695EB,stroke:#333,color:#fff
    style Protobuf fill:#4695EB,stroke:#333,color:#fff
    style OptaPlanner fill:#4695EB,stroke:#333,color:#fff
    style Micrometer fill:#4695EB,stroke:#333,color:#fff
    style Vertx fill:#4695EB,stroke:#333,color:#fff

    %% Storage / External
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style MinIO fill:#f5a623,stroke:#333,color:#fff
    style MariaDB fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style Arrow fill:#999,stroke:#333,color:#fff
