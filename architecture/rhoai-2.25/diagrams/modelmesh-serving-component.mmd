graph TB
    subgraph ModelmeshController["ModelMesh Serving Controller"]
        direction TB
        subgraph Reconcilers["Reconciliation Controllers"]
            ServiceReconciler["ServiceReconciler<br/>Manages inference Service<br/>& ServiceMonitor"]
            SRReconciler["ServingRuntimeReconciler<br/>Constructs multi-container<br/>Deployments (14-step pipeline)"]
            PredictorReconciler["PredictorReconciler<br/>Bridges K8s CRDs to<br/>ModelMesh gRPC API"]
        end
        subgraph PredictorSources["Predictor Source Plugins"]
            PredCR["PredictorCRRegistry<br/>(native Predictor CRs)"]
            ISvcReg["InferenceServiceRegistry<br/>(KServe InferenceServices)"]
            CachedSrc["CachedPredictorSource<br/>(local cache + min-heap<br/>deletion queue)"]
        end
        EventStream["ModelMeshEventStream<br/>Watches etcd for vmodel<br/>& model state changes"]
        Webhook["Webhook Server<br/>:9443/TCP<br/>ValidatingWebhook"]
        HealthProbes["Health Probes<br/>:8081/TCP /healthz /readyz"]
        Metrics["Metrics<br/>:8080/TCP /metrics<br/>(behind kube-rbac-proxy :8443)"]
    end

    %% CRDs
    PredictorCR["Predictor CR<br/>serving.kserve.io/v1alpha1"]
    ISvcCR["InferenceService CR<br/>serving.kserve.io/v1beta1"]
    SRCR["ServingRuntime CR<br/>serving.kserve.io/v1alpha1"]
    CSRCR["ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1"]

    %% Generated Resources
    subgraph RuntimePod["Runtime Pod (generated)"]
        direction LR
        MMContainer["ModelMesh<br/>Container"]
        RuntimeContainer["Runtime Container<br/>(OVMS/Triton/<br/>MLServer/TorchServe)"]
        RESTProxy["REST Proxy<br/>(optional)"]
        OAuthProxy["OAuth Proxy<br/>(optional)"]
        PullerSidecar["Puller/Adapter<br/>Sidecar"]
    end

    %% External Dependencies
    etcd["etcd<br/>:2379/TCP"]
    K8sAPI["Kubernetes API<br/>:6443/TCP"]

    %% CR → Controller flows
    PredictorCR -->|"watched by"| PredictorReconciler
    ISvcCR -->|"watched by (ENABLE_ISVC_WATCH)"| PredictorReconciler
    SRCR -->|"watched by"| SRReconciler
    CSRCR -->|"watched by"| SRReconciler

    %% Predictor source chain
    PredictorReconciler --> PredCR
    PredictorReconciler --> ISvcReg
    PredCR --> CachedSrc
    ISvcReg --> CachedSrc

    %% Controller → Resources
    SRReconciler -->|"creates/manages"| RuntimePod
    ServiceReconciler -->|"creates"| InferenceService["modelmesh-serving<br/>Service"]
    PredictorReconciler -->|"gRPC SetVModel/<br/>DeleteVModel"| MMContainer

    %% etcd flows
    EventStream -->|"watches"| etcd
    MMContainer -->|"stores state"| etcd

    %% Webhook
    K8sAPI -->|"admission review"| Webhook

    %% Styling
    style ModelmeshController fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Reconcilers fill:#e8eaf6,stroke:#3949ab,stroke-width:1px
    style PredictorSources fill:#e8eaf6,stroke:#3949ab,stroke-width:1px
    style RuntimePod fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style PredictorCR fill:#f5a623,stroke:#333
    style ISvcCR fill:#f5a623,stroke:#333
    style SRCR fill:#f5a623,stroke:#333
    style CSRCR fill:#f5a623,stroke:#333
    style etcd fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ServiceReconciler fill:#4a90e2,color:#fff
    style SRReconciler fill:#4a90e2,color:#fff
    style PredictorReconciler fill:#4a90e2,color:#fff
    style EventStream fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
