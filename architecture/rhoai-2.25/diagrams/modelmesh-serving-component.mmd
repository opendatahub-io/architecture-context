%% ModelMesh Serving - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.25/modelmesh-serving.md

graph TB
    subgraph ControlPlane["ModelMesh Serving Controller"]
        Controller["modelmesh-controller<br/>(Go Operator)"]
        SRReconciler["ServingRuntimeReconciler"]
        PReconciler["PredictorReconciler"]
        SvcReconciler["ServiceReconciler"]
        Webhook["ServingRuntime Webhook<br/>9443/TCP HTTPS"]

        Controller --> SRReconciler
        Controller --> PReconciler
        Controller --> SvcReconciler
        Controller --> Webhook
    end

    subgraph RuntimePod["Runtime Deployment Pod"]
        direction TB
        MMSidecar["ModelMesh Sidecar (mm)<br/>Java - gRPC 8033/TCP"]
        RuntimeContainer["Runtime Container<br/>(user-defined)"]
        RESTProxy["REST Proxy Sidecar<br/>8008/TCP HTTP"]
        OAuthProxy["oauth-proxy Sidecar<br/>8443/TCP HTTPS"]
        Puller["Puller Sidecar<br/>(modelmesh-runtime-adapter)"]

        OAuthProxy -->|"HTTP 8008"| RESTProxy
        RESTProxy -->|"gRPC 8033"| MMSidecar
        MMSidecar -->|"gRPC/UDS"| RuntimeContainer
        Puller -->|"downloads models"| RuntimeContainer
    end

    %% CRDs
    User["Data Scientist / Client"] -->|creates| SRTCR["ServingRuntime CR"]
    User -->|creates| CSRTCR["ClusterServingRuntime CR"]
    User -->|creates| PredCR["Predictor CR"]
    User -->|creates| ISVCCR["InferenceService CR"]

    SRTCR -->|watched by| SRReconciler
    CSRTCR -->|watched by| SRReconciler
    PredCR -->|watched by| PReconciler
    ISVCCR -->|watched by| PReconciler

    SRReconciler -->|creates| RuntimePod
    SRReconciler -->|creates/manages| EtcdSecret["etcd Secrets"]
    SvcReconciler -->|creates| InferSvc["Inference Service<br/>(Headless ClusterIP)"]
    SvcReconciler -->|creates| SvcMonitor["ServiceMonitor"]
    PReconciler -->|"gRPC SetVModel 8033"| MMSidecar

    %% External Dependencies
    MMSidecar -->|"2379/TCP password auth"| etcd["etcd<br/>State Coordination"]
    MMSidecar -->|"8080/TCP gRPC"| MMSidecar2["ModelMesh<br/>(other pods)"]
    Puller -->|"443/TCP HTTPS"| Storage["Model Storage<br/>(S3/GCS/Azure/PVC)"]
    Controller -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    OAuthProxy -->|"443/TCP HTTPS"| OAuthServer["OpenShift OAuth"]

    %% Inference flow
    Client["External Client"] -->|"gRPC 8033<br/>Optional TLS/mTLS"| InferSvc
    Client -->|"HTTPS 8443<br/>OAuth"| InferSvc
    InferSvc --> OAuthProxy
    InferSvc --> MMSidecar

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape 2112/TCP"| MMSidecar
    Prometheus -->|"scrape 8080/TCP"| Controller

