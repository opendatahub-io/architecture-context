// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/data-science-pipelines.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Authors, submits, and monitors ML pipelines"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines v2 - end-to-end ML workflow orchestration on OpenShift" {
            apiServer = container "ml-pipeline API Server" "Central API server for pipeline/run/experiment management; webhook endpoints for PipelineVersion validation/mutation" "Go Service" {
                tags "Core"
            }
            persistenceAgent = container "Persistence Agent" "Watches Argo Workflow and ScheduledWorkflow CRs, reports execution status back to API server" "Go Agent" {
                tags "Core"
            }
            swController = container "Scheduled Workflow Controller" "Reconciles ScheduledWorkflow CRDs, creates Argo Workflow CRs on schedule" "Go Controller" {
                tags "Core"
            }
            viewerController = container "Viewer Controller" "Reconciles Viewer CRDs, creates Deployment and Service resources for TensorBoard" "Go Controller (controller-runtime)" {
                tags "Core"
            }
            cacheServer = container "Cache Server" "Mutating admission webhook that intercepts pod creation for pipeline step caching" "Go Webhook Server" {
                tags "Core"
            }
            frontend = container "ML Pipeline UI" "Web UI for viewing pipelines, runs, experiments" "React/Node.js" {
                tags "Frontend"
            }
            vizServer = container "Visualization Server" "Generates visualizations for pipeline artifacts" "Python Service" {
                tags "Core"
            }
            metadataWriter = container "Metadata Writer" "Watches Argo Workflows and writes execution metadata to MLMD" "Python Agent" {
                tags "Core"
            }
            mlmdServer = container "Metadata gRPC Server" "ML Metadata store for artifact lineage tracking" "gRPC Service (MLMD)" {
                tags "Core"
            }
            envoyProxy = container "Metadata Envoy Proxy" "Fronts MLMD gRPC server, provides HTTP/gRPC transcoding" "Envoy Proxy" {
                tags "Core"
            }
            driver = container "KFP Driver v2" "Injected into pipeline task pods; orchestrates DAG/container task execution" "Go Binary" {
                tags "Injected"
            }
            launcher = container "KFP Launcher v2" "Injected into pipeline task pods; handles artifact upload/download, metadata logging" "Go Binary" {
                tags "Injected"
            }
        }

        // External Dependencies
        argoWorkflows = softwareSystem "Argo Workflows" "Pipeline execution engine (Workflow CRDs), v3.5.14" {
            tags "External"
        }
        database = softwareSystem "MySQL / PostgreSQL" "Pipeline metadata, run state, cache storage" {
            tags "External"
        }
        objectStore = softwareSystem "MinIO / S3 Object Store" "Pipeline artifact and log storage" {
            tags "External"
        }
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform, API server" {
            tags "External"
        }

        // Internal ODH Dependencies
        dspo = softwareSystem "Data Science Pipelines Operator" "Deploys and manages all DSP components" {
            tags "Internal RHOAI"
        }
        mlMetadata = softwareSystem "ML Metadata (MLMD)" "Artifact lineage tracking service" {
            tags "Internal RHOAI"
        }
        kfpSDK = softwareSystem "KFP Python SDK" "Pipeline authoring and submission client" {
            tags "Client"
        }

        // Relationships - System Context
        user -> dsp "Authors pipelines, submits runs, monitors execution"
        kfpSDK -> dsp "Submits compiled pipelines via HTTP/gRPC"
        dsp -> argoWorkflows "Executes pipeline runs as Argo Workflow CRs"
        dsp -> database "Stores pipeline metadata, run state, cache" "MySQL/PostgreSQL 3306/5432"
        dsp -> objectStore "Stores pipeline artifacts, logs, compiled pipelines" "HTTP/HTTPS 9000/443"
        dsp -> kubernetes "Manages Workflow CRs, pods, RBAC" "HTTPS/443"
        dsp -> mlMetadata "Tracks artifact lineage and execution metadata" "gRPC/8080"
        dspo -> dsp "Deploys, configures, and manages all components"

        // Relationships - Container Level
        user -> frontend "Views pipelines, runs, experiments" "HTTP/3000"
        user -> apiServer "Creates pipelines and runs" "REST/8888, gRPC/8887"
        kfpSDK -> apiServer "Submits pipelines" "REST/8888, gRPC/8887"

        frontend -> apiServer "Proxies API calls" "HTTP/8888"
        persistenceAgent -> apiServer "Reports execution status" "HTTP/gRPC 8888/8887"
        driver -> apiServer "Resolves task inputs" "gRPC/8887"

        swController -> kubernetes "Watches SWF CRs, creates Workflow CRs" "HTTPS/443"
        viewerController -> kubernetes "Watches Viewer CRs, creates Deployments" "HTTPS/443"
        persistenceAgent -> kubernetes "Watches Workflow CRs" "HTTPS/443"

        metadataWriter -> mlmdServer "Writes execution metadata" "gRPC/8080"
        launcher -> mlmdServer "Logs metadata" "gRPC/8080"
        envoyProxy -> mlmdServer "Transcodes HTTP/gRPC" "gRPC/8080"

        apiServer -> database "Stores/retrieves pipeline data" "DB/3306/5432"
        cacheServer -> database "Checks/stores cache entries" "DB/3306/5432"

        apiServer -> objectStore "Stores/retrieves artifacts" "HTTP/HTTPS 9000/443"
        launcher -> objectStore "Uploads/downloads artifacts" "HTTP/HTTPS 9000/443"

        apiServer -> kubernetes "Creates Workflow CRs" "HTTPS/443"
        kubernetes -> cacheServer "Pod creation webhook" "HTTPS/8443"
        kubernetes -> apiServer "PipelineVersion webhooks" "HTTPS/8443"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Client" {
                background #f5a623
                color #000000
            }
            element "Core" {
                background #438dd5
                color #ffffff
            }
            element "Frontend" {
                background #4a90e2
                color #ffffff
            }
            element "Injected" {
                background #6b8fc2
                color #ffffff
            }
        }
    }
}
