graph TB
    subgraph CoreOperator["Core Platform Operator"]
        rhods["rhods-operator<br/>(Platform Root)<br/>20+ CRDs, 14 components"]
    end

    subgraph ServingStack["Model Serving Stack"]
        KServe["KServe<br/>Serverless + Raw + LLM"]
        ModelMesh["ModelMesh Serving<br/>Multi-model serving"]
        OVMS["OpenVINO Model Server<br/>OVMS runtime"]
        CaikitTGIS["caikit-tgis-serving<br/>Text generation"]
        ODHModelCtrl["odh-model-controller<br/>Serving integration hub"]
    end

    subgraph LLMdStack["Disaggregated LLM Stack (New in 2.25)"]
        LLMd["llm-d<br/>Distributed inference"]
        EPP["llm-d-inference-scheduler<br/>EPP + KV-cache routing"]
        KVCache["llm-d-kv-cache<br/>KV-cache indexing"]
        RoutingSidecar["llm-d-routing-sidecar<br/>P/D routing"]
    end

    subgraph UserInterface["User Interface"]
        Dashboard["odh-dashboard<br/>UI + BFF + Module Federation"]
    end

    subgraph MLLifecycle["ML Lifecycle"]
        DSPO["Data Science Pipelines<br/>Operator (DSPO)"]
        Argo["Argo Workflows<br/>Pipeline execution"]
        ModelRegistry["Model Registry<br/>Model metadata"]
        ModelRegistryOp["Model Registry Operator"]
        TrustyAI["TrustyAI Operator<br/>Explainability + Guardrails"]
        Feast["Feast Operator<br/>Feature store"]
        LlamaStack["Llama Stack Operator<br/>Gen AI inference"]
        ModelMetadata["Model Metadata Collection"]
    end

    subgraph DistributedCompute["Distributed Computing"]
        CodeFlare["CodeFlare Operator"]
        KubeRay["KubeRay Operator"]
        Kueue["Kueue<br/>Job queuing + quota"]
        TrainingOp["Training Operator<br/>PyTorchJob, TFJob, MPIJob"]
        Notebooks["Kubeflow Notebook<br/>Controllers"]
    end

    subgraph ExternalDeps["External Platform Dependencies"]
        Knative["Knative Serving"]
        Istio["Istio Service Mesh"]
        Authorino["Authorino<br/>External AuthZ"]
        GatewayAPI["Gateway API<br/>HTTPRoute + InferencePool"]
        OLM["OLM<br/>Lifecycle management"]
    end

    %% rhods-operator deploys all components
    rhods -->|deploys| KServe
    rhods -->|deploys| ModelMesh
    rhods -->|deploys| ODHModelCtrl
    rhods -->|deploys| Dashboard
    rhods -->|deploys| DSPO
    rhods -->|deploys| ModelRegistryOp
    rhods -->|deploys| TrustyAI
    rhods -->|deploys| Feast
    rhods -->|deploys| LlamaStack
    rhods -->|deploys| CodeFlare
    rhods -->|deploys| KubeRay
    rhods -->|deploys| Kueue
    rhods -->|deploys| TrainingOp
    rhods -->|deploys| Notebooks

    %% KServe dependencies
    KServe -->|autoscaling| Knative
    KServe -->|traffic mgmt| Istio
    KServe -->|LLMInferenceService| GatewayAPI
    KServe -->|LLM scheduling| LLMd

    %% LLM-d stack internal
    LLMd ---|ext-proc gRPC| EPP
    EPP ---|KV-cache events| KVCache
    LLMd ---|P/D routing| RoutingSidecar

    %% odh-model-controller integrations
    ODHModelCtrl -->|Route, NetworkPolicy| KServe
    ODHModelCtrl -->|AuthConfig| Authorino
    ODHModelCtrl -->|Ray TLS certs| KubeRay

    %% Dashboard integrations
    Dashboard -->|serving UI| KServe
    Dashboard -->|pipeline UI| DSPO
    Dashboard -->|model catalog| ModelRegistry
    Dashboard -->|explainability| TrustyAI
    Dashboard -->|feature mgmt| Feast
    Dashboard -->|gen AI| LlamaStack
    Dashboard -->|workbench mgmt| Notebooks

    %% ML lifecycle connections
    DSPO -->|executes| Argo
    ModelRegistryOp -->|deploys| ModelRegistry
    ModelRegistry -->|ISVC labels| KServe
    TrustyAI -->|ISVC patching| KServe
    TrustyAI -->|quota| Kueue

    %% ModelMesh serving
    ModelMesh -->|KServe v2 protocol| OVMS
    ModelMesh -->|serving runtime| CaikitTGIS
    CaikitTGIS -->|serving| KServe

    %% Distributed compute
    CodeFlare -->|cluster mgmt| KubeRay
    CodeFlare -->|AppWrapper| Kueue
    KubeRay -->|job scheduling| Kueue
    TrainingOp -->|job scheduling| Kueue
    Notebooks -->|distributed jobs| CodeFlare

