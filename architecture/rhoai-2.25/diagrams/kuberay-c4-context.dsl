// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Ray clusters, jobs, and serve deployments"
        platformAdmin = person "Platform Admin" "Deploys and configures KubeRay operator via RHOAI"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and services on OpenShift" {
            rcController = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker Pods, Services, Routes, RBAC" "Go Reconciler"
            rjController = container "RayJob Controller" "Reconciles RayJob CRs: creates clusters, submits jobs via Dashboard API" "Go Reconciler"
            rsController = container "RayService Controller" "Reconciles RayService CRs: manages serve deployments with zero-downtime upgrades" "Go Reconciler"
            dashboardClient = container "Dashboard HTTP Client" "Communicates with Ray head dashboard API for job/serve management" "HTTP Client"
            batchMgr = container "Batch Scheduler Manager" "Integrates with Volcano and Yunikorn for gang scheduling" "Plugin Manager"
            webhookServer = container "Webhook Server" "Validates RayCluster resources" "Admission Webhook"
            metricsEndpoint = container "Metrics Endpoint" "Exposes Prometheus metrics on 8080/TCP" "HTTP /metrics"
        }

        rayCluster = softwareSystem "Ray Cluster" "Distributed computing cluster (head + worker pods)" {
            rayHead = container "Ray Head Node" "Dashboard API (8265), GCS (6379), Client (10001), Serve (8000)" "Ray Process"
            rayWorkers = container "Ray Worker Nodes" "Execute distributed tasks and serve inference" "Ray Process"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano Scheduler" "Batch scheduling with PodGroup gang scheduling" "External"
        yunikorn = softwareSystem "Yunikorn Scheduler" "Task group batch scheduling" "External"
        codeflare = softwareSystem "CodeFlare Operator" "Creates RayCluster CRs for distributed workloads" "Internal RHOAI"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys KubeRay operator via kustomize overlay" "Internal RHOAI"

        // User interactions
        user -> kuberay "Creates RayCluster/RayJob/RayService CRs via kubectl" "HTTPS/443"
        user -> rayCluster "Sends inference requests to serve endpoints" "HTTP/8000"
        platformAdmin -> rhodsOperator "Configures RHOAI platform"

        // Operator interactions
        kuberay -> k8sAPI "CRUD on Pods, Services, Routes, Jobs, RBAC" "HTTPS/443, SA Token"
        kuberay -> rayCluster "Job submission, serve deployment, health checks" "HTTP/8265, plaintext"
        kuberay -> volcano "Creates PodGroup CRDs for gang scheduling" "CRD"
        kuberay -> yunikorn "Adds scheduling annotations to pods" "Pod Annotations"

        // Internal container interactions
        rcController -> dashboardClient "Uses for health checks"
        rjController -> dashboardClient "Uses for job submission"
        rsController -> dashboardClient "Uses for serve deployment"
        rcController -> batchMgr "Uses for gang scheduling"

        // External integrations
        prometheus -> kuberay "Scrapes /metrics" "HTTP/8080"
        codeflare -> kuberay "Creates RayCluster CRs" "CRD"
        rhodsOperator -> kuberay "Deploys via kustomize" "Kustomize"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
