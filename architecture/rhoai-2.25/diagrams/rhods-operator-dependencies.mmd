graph LR
    RhodsOp["rhods-operator<br/>(RHOAI Platform Operator)"]

    %% ── External Dependencies (Required) ──
    subgraph Required["Required Dependencies"]
        CtrlRuntime["controller-runtime<br/>v0.20.4"]
        ClientGo["client-go<br/>v0.32.4"]
        OSApi["OpenShift API<br/>(Route, OAuth, Console,<br/>Config, Security, User)"]
        OFApi["Operator Framework<br/>API v0.31.0"]
        PromOp["prometheus-operator<br/>v0.68.0"]
    end

    RhodsOp -->|"controller framework"| CtrlRuntime
    RhodsOp -->|"K8s API client"| ClientGo
    RhodsOp -->|"platform APIs"| OSApi
    RhodsOp -->|"OLM integration"| OFApi
    RhodsOp -->|"monitoring CRDs"| PromOp

    %% ── Conditional Dependencies ──
    subgraph Conditional["Conditional Dependencies"]
        Istio["Maistra/Istio v2<br/>(when ServiceMesh enabled)"]
        Authorino["Authorino Operator<br/>v1beta1<br/>(when ServiceMesh enabled)"]
        Knative["Knative Serving<br/>v1beta1<br/>(when KServe Serverless)"]
        COO["Cluster Observability<br/>Operator v1alpha1<br/>(when monitoring enabled)"]
        Tempo["Tempo Operator<br/>v1alpha1<br/>(when traces enabled)"]
        OTEL["OpenTelemetry<br/>Operator v1beta1<br/>(when metrics/traces export)"]
    end

    RhodsOp -.->|"service mesh"| Istio
    RhodsOp -.->|"authorization"| Authorino
    RhodsOp -.->|"serverless"| Knative
    RhodsOp -.->|"monitoring stack"| COO
    RhodsOp -.->|"distributed tracing"| Tempo
    RhodsOp -.->|"telemetry collection"| OTEL

    %% ── Internal Platform Components (Deployed by operator) ──
    subgraph Components["Internal Platform Components (14)"]
        direction TB
        Dashboard["odh-dashboard"]
        Workbenches["kubeflow<br/>notebook-controller"]
        KServe["kserve"]
        ModelMesh["modelmesh-serving"]
        ModelCtrl["odh-model-controller"]
        DSP["data-science-pipelines-<br/>operator"]
        Kueue["kueue"]
        CodeFlare["codeflare-operator"]
        Ray["kuberay"]
        TrustyAI["trustyai-service-<br/>operator"]
        ModelReg["model-registry-<br/>operator"]
        TrainingOp["training-operator"]
        Feast["feast-operator"]
        LlamaStack["llama-stack-k8s-<br/>operator"]
    end

    RhodsOp ==>|"deploys manifests"| Dashboard
    RhodsOp ==>|"deploys manifests"| Workbenches
    RhodsOp ==>|"deploys manifests"| KServe
    RhodsOp ==>|"deploys manifests"| ModelMesh
