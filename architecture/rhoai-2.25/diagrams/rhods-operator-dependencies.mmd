graph TB
    RHODS[RHOAI Operator<br/>rhods-operator]

    subgraph "External Platform Dependencies (Required)"
        K8s[Kubernetes 1.32+]
        OpenShift[OpenShift 4.x<br/>REQUIRED]
        PrometheusOp[Prometheus Operator 0.68.0]
    end

    subgraph "External Operator Dependencies (Conditional)"
        Istio[Service Mesh Operator 2.x<br/>Istio<br/>Required for KServe + Auth]
        Knative[Serverless Operator<br/>Knative Serving<br/>Required for KServe]
        Authorino[Authorino Operator<br/>Required for Auth-based<br/>model serving]
        CertMgr[cert-manager<br/>Required for KServe]
        Pipelines[OpenShift Pipelines<br/>Optional]
    end

    subgraph "OpenShift Platform Services"
        OAuth[OpenShift OAuth<br/>Authentication]
        Console[OpenShift Console<br/>Web UI]
        ServiceCA[OpenShift Service CA<br/>Certificate management]
        Registry[OpenShift Image Registry<br/>Container images]
    end

    subgraph "Deployed AI/ML Components (via Manifests)"
        Dashboard[ODH Dashboard<br/>40+ manifests]
        KServe[KServe Controller<br/>30+ manifests]
        DSP[Data Science Pipelines<br/>35+ manifests]
        CodeFlare[CodeFlare Operator<br/>20+ manifests]
        Ray[Ray Operator<br/>15+ manifests]
        ModelMesh[ModelMesh Serving<br/>25+ manifests]
        ModelRegistry[Model Registry<br/>15+ manifests]
        TrustyAI[TrustyAI Service<br/>10+ manifests]
        Training[Training Operator<br/>15+ manifests]
        Workbenches[Workbenches<br/>10+ manifests]
        Kueue[Kueue<br/>10+ manifests]
        Feast[Feast Operator<br/>8+ manifests]
        LlamaStack[LlamaStack Operator<br/>manifests]
        ModelController[Model Controller<br/>manifests]
    end

    subgraph "Monitoring Stack (Deployed when Managed)"
        Prometheus[Prometheus<br/>StatefulSet<br/>90d retention]
        Alertmanager[Alertmanager<br/>StatefulSet]
        OTel[OpenTelemetry Collector<br/>Deployment]
        Tempo[Tempo<br/>StatefulSet]
        Blackbox[Blackbox Exporter<br/>Deployment]
    end

    subgraph "Platform Services (Deployed via Service CRs)"
        AuthSvc[Auth Service<br/>OAuthClient, ServiceMeshMember]
        MonitoringSvc[Monitoring Service<br/>Prometheus stack]
        ServiceMeshSvc[ServiceMesh Integration<br/>Authorino, VirtualServices]
    end

    %% Core platform dependencies
    RHODS -->|requires| K8s
    RHODS -->|requires| OpenShift
    RHODS -->|requires| PrometheusOp

    %% Conditional operator dependencies
    RHODS -.->|KServe feature| Istio
    RHODS -.->|KServe feature| Knative
    RHODS -.->|Auth feature| Authorino
    RHODS -.->|KServe feature| CertMgr
    RHODS -.->|optional| Pipelines

    %% OpenShift platform services
    RHODS -->|creates OAuthClients| OAuth
    RHODS -->|creates ConsoleLinks| Console
    RHODS -->|webhook certs| ServiceCA
    RHODS -->|image pulls| Registry

    %% Deploys AI/ML components
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| KServe
    RHODS -->|deploys| DSP
    RHODS -->|deploys| CodeFlare
    RHODS -->|deploys| Ray
    RHODS -->|deploys| ModelMesh
    RHODS -->|deploys| ModelRegistry
    RHODS -->|deploys| TrustyAI
    RHODS -->|deploys| Training
    RHODS -->|deploys| Workbenches
    RHODS -->|deploys| Kueue
    RHODS -->|deploys| Feast
    RHODS -->|deploys| LlamaStack
    RHODS -->|deploys| ModelController

    %% Deploys monitoring stack
    RHODS -->|deploys via DSCI| Prometheus
    RHODS -->|deploys via DSCI| Alertmanager
    RHODS -->|deploys via DSCI| OTel
    RHODS -->|deploys via DSCI| Tempo
    RHODS -->|deploys via DSCI| Blackbox

    %% Deploys platform services
    RHODS -->|creates Auth CR| AuthSvc
    RHODS -->|creates Monitoring CR| MonitoringSvc
    RHODS -->|creates ServiceMesh CR| ServiceMeshSvc

    %% Component dependencies on external operators
    KServe -->|requires| Istio
    KServe -->|requires| Knative
    AuthSvc -->|requires| Istio
    AuthSvc -->|requires| Authorino
    ServiceMeshSvc -->|requires| Istio

    %% Component interactions
    Dashboard -.->|UI integration| KServe
    Dashboard -.->|UI integration| DSP
    Dashboard -.->|UI integration| ModelRegistry
    CodeFlare -.->|manages| Ray
    CodeFlare -.->|uses| Kueue
    DSP -.->|integrates| Workbenches

    %% Monitoring
    Prometheus -.->|scrapes| Dashboard
    Prometheus -.->|scrapes| KServe
    Prometheus -.->|scrapes| DSP
    Prometheus -.->|scrapes| RHODS
    Prometheus -->|sends alerts| Alertmanager

    %% External services
    Git[External Git Repos<br/>Manifest downloads<br/>optional]
    RHODS -.->|devFlags.manifests| Git

