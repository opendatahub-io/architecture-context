    subgraph ExtServices["External Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        OSPlatform["OpenShift Platform<br/>(OAuth, service-ca, CNO)"]
        OLM["OLM<br/>(Operator Lifecycle)"]
        Segment["Segment.io<br/>(telemetry)"]
    end

    RhodsOp -->|"6443/TCP HTTPS"| K8sAPI
    RhodsOp -->|"443/TCP HTTPS"| OSPlatform
    RhodsOp -->|"watch CRDs"| OLM
    RhodsOp -->|"443/TCP HTTPS"| Segment

