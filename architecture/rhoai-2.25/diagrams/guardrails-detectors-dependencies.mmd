graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal Platform Dependencies
    GD -->|"called by<br/>(REST API callee)"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployed as<br/>InferenceService"| KServe["KServe"]
    GD -->|"runtime definition"| ServingRT["KServe<br/>ServingRuntime"]
    GD -->|"model download<br/>(init container)"| StorageInit["KServe Storage<br/>Initializer"]
    GD -->|"evaluation requests<br/>HTTP/8080"| vLLM["vLLM Server"]
    GD -->|"sidecar injection<br/>mTLS transport"| Istio["Istio Service<br/>Mesh"]

    %% External Service Dependencies
    StorageInit -->|"model artifacts<br/>HTTP/9000<br/>AWS IAM"| S3["S3/MinIO<br/>Storage"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8080"| GD

    %% Build-time Dependencies
    GD -.->|"model download<br/>(build-time)<br/>HTTPS/443"| HFHub["HuggingFace<br/>Hub"]

    %% Key Python Dependencies
    subgraph PythonDeps["Key Python Libraries"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["uvicorn 0.30.5"]
        Transformers["transformers 4.50.0"]
        PyTorch["torch >=2.0"]
        VLLMJudge["vllm-judge 0.1.8"]
        PromClient["prometheus-client"]
    end

    GD -.->|"web framework"| FastAPI
    GD -.->|"ASGI server"| Uvicorn
    GD -.->|"model loading<br/>(HF detector)"| Transformers
    GD -.->|"inference<br/>(HF detector)"| PyTorch
    GD -.->|"judge library<br/>(LLM Judge)"| VLLMJudge
    GD -.->|"metrics"| PromClient

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRT fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#999,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style PythonDeps fill:#f9f9f9,stroke:#ccc,stroke-dasharray: 5 5
    style FastAPI fill:#e8e8e8,stroke:#999
    style Uvicorn fill:#e8e8e8,stroke:#999
    style Transformers fill:#e8e8e8,stroke:#999
    style PyTorch fill:#e8e8e8,stroke:#999
    style VLLMJudge fill:#e8e8e8,stroke:#999
    style PromClient fill:#e8e8e8,stroke:#999
