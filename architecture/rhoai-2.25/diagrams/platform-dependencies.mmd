    style ModelMesh fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style ModelCtl fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    style ModelReg fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff

    style Notebooks fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff
    style Training fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff
    style Pipelines fill:#16a085,stroke:#0e6655,stroke-width:2px,color:#fff

    style CodeFlare fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style KubeRay fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff
    style Kueue fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#fff

