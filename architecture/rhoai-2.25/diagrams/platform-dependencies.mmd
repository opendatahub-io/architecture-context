graph LR
    subgraph "RHOAI Platform Components"
        RHODS[rhods-operator<br/>Platform Orchestrator]
        Dashboard[odh-dashboard<br/>Web UI]

        subgraph "Model Serving"
            KServe[kserve<br/>Serverless]
            ModelMesh[modelmesh<br/>Multi-Model]
            ModelCtl[odh-model-controller<br/>Integration Layer]
            ModelReg[model-registry<br/>Metadata]
        end

        subgraph "Development & Training"
            Notebooks[notebook-controller<br/>Workbenches]
            Training[training-operator<br/>Distributed Training]
            Pipelines[data-science-pipelines<br/>Workflows]
        end

        subgraph "Distributed Computing"
            CodeFlare[codeflare-operator<br/>Orchestration]
            KubeRay[kuberay<br/>Ray Clusters]
            Kueue[kueue<br/>Queueing]
        end

        subgraph "AI Safety & Features"
            TrustyAI[trustyai-operator<br/>Explainability]
            Feast[feast-operator<br/>Feature Store]
        end

        LlamaStack[llama-stack-operator<br/>LLM Serving]
    end

    subgraph "External Infrastructure Dependencies"
        Istio[Istio 1.20+<br/>Service Mesh]
        Knative[Knative Serving 1.12+<br/>Autoscaling]
        CertMgr[cert-manager 1.13+<br/>Certificate Mgmt]
        K8sAPI[Kubernetes API<br/>Resource Mgmt]
        OAuth[OpenShift OAuth<br/>Authentication]
        Prometheus[Prometheus<br/>Monitoring]
    end

    subgraph "External Storage Dependencies"
        S3[S3-Compatible Storage<br/>Model Artifacts]
        PostgreSQL[PostgreSQL/MySQL<br/>Metadata DB]
        Redis[Redis<br/>Feature Cache]
        ETCD[ETCD<br/>ModelMesh State]
    end

    subgraph "External AI/ML Services"
        NGC[NVIDIA NGC API<br/>NIM Accounts]
        HuggingFace[HuggingFace Hub<br/>Models & Datasets]
        ContainerReg[Container Registries<br/>Images]
    end

    %% Platform orchestration
    RHODS -->|deploys all| Dashboard
    RHODS -->|deploys all| KServe
    RHODS -->|deploys all| ModelMesh
    RHODS -->|deploys all| ModelCtl
    RHODS -->|deploys all| Notebooks
    RHODS -->|deploys all| Training
    RHODS -->|deploys all| Pipelines
    RHODS -->|deploys all| CodeFlare
    RHODS -->|deploys all| KubeRay
    RHODS -->|deploys all| Kueue
    RHODS -->|deploys all| TrustyAI
    RHODS -->|deploys all| Feast
    RHODS -->|deploys all| LlamaStack
    RHODS -->|deploys all| ModelReg

    %% Dashboard integrations
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| ModelReg
    Dashboard -->|creates CRs| Notebooks
    Dashboard -->|manages| Pipelines
    Dashboard -->|queries metrics| Prometheus

    %% Model serving dependencies
    KServe -->|requires| Knative
    KServe -->|optional| Istio
    KServe -->|extended by| ModelCtl
    KServe -.->|optional integration| ModelReg
    KServe -->|loads from| S3
    KServe -->|webhook certs| CertMgr

    ModelMesh -->|state storage| ETCD
    ModelMesh -->|loads from| S3
    ModelMesh -->|configured by| ModelCtl

    ModelCtl -->|watches| KServe
    ModelCtl -->|creates VirtualServices| Istio
    ModelCtl -->|NIM integration| NGC
    ModelCtl -.->|optional| ModelReg

    %% Development & Training dependencies
    Notebooks -->|authenticates| OAuth
    Notebooks -->|data access| S3
    Notebooks -->|submits jobs| Training
    Notebooks -->|deploys models| KServe

    Training -->|optional scheduling| Kueue
    Training -->|saves checkpoints| S3
    Training -.->|registers models| ModelReg
    Training -->|downloads models| HuggingFace

    Pipelines -->|executes workflows| K8sAPI
    Pipelines -->|metadata storage| PostgreSQL
    Pipelines -->|artifact storage| S3
    Pipelines -->|deploys models| KServe
    Pipelines -->|registers models| ModelReg
    Pipelines -->|authenticates| OAuth

    %% Distributed computing dependencies
    CodeFlare -->|manages| KubeRay
    CodeFlare -->|queues via| Kueue
    CodeFlare -->|authenticates| OAuth

    KubeRay -->|optional fault tolerance| Redis
    KubeRay -->|data access| S3

    Kueue -->|admits| Training
    Kueue -->|admits| CodeFlare
    Kueue -->|admits| TrustyAI

    %% AI Safety & Features dependencies
    TrustyAI -->|monitors| KServe
    TrustyAI -->|monitors| ModelMesh
    TrustyAI -->|stores metrics| PostgreSQL
    TrustyAI -->|queues jobs| Kueue

    Feast -->|feature metadata| PostgreSQL
    Feast -->|online cache| Redis
    Feast -->|offline storage| S3
    Feast -->|authenticates| OAuth

    %% Model Registry dependencies
    ModelReg -->|metadata storage| PostgreSQL
    ModelReg -->|authenticates| OAuth

    %% LLM Serving dependencies
    LlamaStack -->|downloads models| HuggingFace
    LlamaStack -->|pulls images| ContainerReg

    %% Common dependencies
    RHODS -->|manages via| K8sAPI
    Dashboard -->|API calls| K8sAPI
    KServe -->|API calls| K8sAPI
    ModelCtl -->|API calls| K8sAPI
    Training -->|API calls| K8sAPI
    Pipelines -->|API calls| K8sAPI
    CodeFlare -->|API calls| K8sAPI
    KubeRay -->|API calls| K8sAPI
    Kueue -->|API calls| K8sAPI
    TrustyAI -->|API calls| K8sAPI
    Feast -->|API calls| K8sAPI
    LlamaStack -->|API calls| K8sAPI

    %% Metrics collection
    KServe -->|exposes metrics| Prometheus
    ModelMesh -->|exposes metrics| Prometheus
    Training -->|exposes metrics| Prometheus
    Pipelines -->|exposes metrics| Prometheus
    CodeFlare -->|exposes metrics| Prometheus
    KubeRay -->|exposes metrics| Prometheus

    %% Image pulls
    RHODS -->|pulls images| ContainerReg
    Notebooks -->|pulls images| ContainerReg
    KServe -->|pulls images| ContainerReg
    Training -->|pulls images| ContainerReg

