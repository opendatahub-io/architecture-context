    style Istio fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style Knative fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style CertMgr fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style K8sAPI fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style OAuth fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px
    style Prometheus fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px

    style S3 fill:#f8c471,stroke:#f39c12,stroke-width:2px
    style PostgreSQL fill:#f8c471,stroke:#f39c12,stroke-width:2px
