graph LR
    MMRA["ModelMesh Runtime Adapter<br/>(sidecar)"]

    %% Internal Platform Dependencies (colocated in pod)
    MMRA -->|"mmesh.ModelRuntime<br/>gRPC/8085 inbound"| ModelMesh["ModelMesh<br/>(pod colocated)"]
    Controller["modelmesh-controller<br/>(modelmesh-serving)"] -->|"deploys as<br/>storageHelperImage"| MMRA

    %% Inference Runtime Dependencies (colocated in pod)
    MMRA -->|"gRPC/8001<br/>RepositoryModelLoad/Unload"| Triton["Triton Inference Server"]
    MMRA -->|"gRPC/8001<br/>RepositoryModelLoad/Unload"| MLServer["Seldon MLServer"]
    MMRA -->|"HTTP/8001<br/>REST config/reload"| OVMS["OpenVINO Model Server"]
    MMRA -->|"gRPC/7071 mgmt<br/>gRPC/7070 infer"| TorchServe["PyTorch TorchServe"]

    %% Cloud Storage Dependencies (egress)
    MMRA -->|"HTTPS/443<br/>Access Key Auth"| S3["AWS S3 /<br/>IBM COS"]
    MMRA -->|"HTTPS/443<br/>SA OAuth2"| GCS["Google Cloud<br/>Storage"]
    MMRA -->|"HTTPS/443<br/>Connection String"| Azure["Azure Blob<br/>Storage"]
    MMRA -->|"HTTP/HTTPS<br/>Headers / mTLS"| HTTPEndpoint["HTTP Model<br/>Endpoints"]
    MMRA -.->|"filesystem<br/>symlinks"| PVC["Kubernetes<br/>PVCs"]

    %% Build Dependencies
    MMRA -.->|"build"| Go["Go 1.25.5"]
    MMRA -.->|"build"| Python["Python 3.11"]
    MMRA -.->|"build"| TensorFlow["TensorFlow 2.19.0"]
    MMRA -.->|"build"| Keras["Keras 3.14.0"]

    %% Library Dependencies
    MMRA -.->|"gRPC framework"| gRPCGo["gRPC Go 1.79.3"]
    MMRA -.->|"serialization"| Protobuf["protobuf 1.36.11"]
    MMRA -.->|"secure paths"| SecureJoin["filepath-securejoin<br/>0.2.4"]

    %% Styling
    style MMRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333
    style Controller fill:#9b59b6,stroke:#333,color:#fff

    style Triton fill:#e8e8e8,stroke:#333
    style MLServer fill:#e8e8e8,stroke:#333
    style OVMS fill:#e8e8e8,stroke:#333
    style TorchServe fill:#e8e8e8,stroke:#333

    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style HTTPEndpoint fill:#f5a623,stroke:#333
    style PVC fill:#e1d5e7,stroke:#333

    style Go fill:#fff2cc,stroke:#d6b656
    style Python fill:#fff2cc,stroke:#d6b656
    style TensorFlow fill:#fff2cc,stroke:#d6b656
    style Keras fill:#fff2cc,stroke:#d6b656
    style gRPCGo fill:#fff2cc,stroke:#d6b656
    style Protobuf fill:#fff2cc,stroke:#d6b656
    style SecureJoin fill:#fff2cc,stroke:#d6b656
