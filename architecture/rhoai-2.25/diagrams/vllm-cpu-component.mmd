graph TB
    subgraph "vllm-cpu Component"
        direction TB

        subgraph "vllm-openai (Port 8000/TCP)"
            FastAPI["FastAPI + Uvicorn<br/>OpenAI-compatible HTTP API"]
            AuthMiddleware["AuthenticationMiddleware<br/>API Key Validation (SHA-256)"]
            SSLContext["SSLCertRefresher<br/>Optional TLS with hot-reload"]
            FastAPI --> AuthMiddleware
            FastAPI --> SSLContext
        end

        subgraph "vllm-grpc-adapter (Port 8033/TCP)"
            TGISAdapter["vllm-tgis-adapter<br/>TGIS gRPC Protocol"]
        end

        subgraph "vLLM Engine"
            AsyncLLM["AsyncLLM (V1)<br/>Default async engine"]
            MQLLMEngine["MQLLMEngineClient (V0)<br/>Legacy ZMQ IPC engine"]
            ModelExecutor["Model Executor/Worker<br/>CPU inference coordination"]
        end

        subgraph "C/C++ Kernels"
            Attention["CPU Attention Kernels"]
            Cache["Cache Operations"]
            LayerNorm["LayerNorm Kernels"]
            Quantization["Quantization Support"]
            MoE["MoE (Mixture of Experts)"]
        end

        FastAPI -->|"inference request"| AsyncLLM
        FastAPI -.->|"legacy path"| MQLLMEngine
        TGISAdapter -->|"inference request"| AsyncLLM
        AsyncLLM --> ModelExecutor
        MQLLMEngine --> ModelExecutor
        ModelExecutor --> Attention
        ModelExecutor --> Cache
        ModelExecutor --> LayerNorm
    end

    Client[External Client] -->|"POST /v1/chat/completions<br/>8000/TCP HTTP"| FastAPI
    KServePredictor[KServe Predictor] -->|"gRPC<br/>8033/TCP"| TGISAdapter
    Prometheus[Prometheus] -->|"GET /metrics<br/>8000/TCP"| FastAPI

    ModelExecutor -->|"Model Download<br/>443/TCP HTTPS"| HFHub[HuggingFace Hub]
    ModelExecutor -->|"Model Download<br/>443/TCP HTTPS"| S3[S3-compatible Storage]

    subgraph "CPU Acceleration"
        IPEX["Intel Extension for PyTorch<br/>(x86_64)"]
        OpenBLAS["OpenBLAS<br/>(ppc64le/s390x)"]
        PyTorch["PyTorch 2.6.0+cpu"]
    end

    ModelExecutor --> PyTorch
    PyTorch --> IPEX
    PyTorch --> OpenBLAS

    style FastAPI fill:#4a90e2,stroke:#333
    style TGISAdapter fill:#4a90e2,stroke:#333
    style AsyncLLM fill:#50b8e7,stroke:#333
    style MQLLMEngine fill:#50b8e7,stroke:#333,stroke-dasharray: 5 5
    style ModelExecutor fill:#50b8e7,stroke:#333
    style Attention fill:#9b59b6,stroke:#333
    style Cache fill:#9b59b6,stroke:#333
    style LayerNorm fill:#9b59b6,stroke:#333
    style Quantization fill:#9b59b6,stroke:#333
    style MoE fill:#9b59b6,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style KServePredictor fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style IPEX fill:#e8e8e8,stroke:#333
    style OpenBLAS fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style AuthMiddleware fill:#4a90e2,stroke:#333
    style SSLContext fill:#4a90e2,stroke:#333
