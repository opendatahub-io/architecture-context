graph TB
    subgraph "vLLM Inference Runtime Container"
        subgraph "Application Layer"
            TGISAdapter["vLLM TGIS Adapter<br/>gRPC :8033"]
            HTTPServer["vLLM HTTP Server<br/>OpenAI-compatible :8000"]
            VLLMEngine["vLLM Engine<br/>(PagedAttention, Continuous Batching,<br/>Speculative Decoding)"]
        end

        subgraph "Runtime Layer"
            PythonRT["Python Runtime"]
            CUDARuntime["NVIDIA CUDA Runtime"]
        end

        TGISAdapter -->|"Python IPC"| VLLMEngine
        HTTPServer -->|"Python IPC"| VLLMEngine
        VLLMEngine --> PythonRT
        PythonRT --> CUDARuntime
    end

    subgraph "Base Image"
        RHAIIS["RHAIIS vllm-cuda-rhel9<br/>registry.redhat.io/rhaiis/vllm-cuda-rhel9<br/>v3.2.2"]
    end

    subgraph "KServe Platform"
        KServeRouter["KServe Router"]
        InferenceService["InferenceService CR"]
        ServingRuntime["ServingRuntime Definition"]
    end

    subgraph "External"
        Client["External Client"]
        PlatformIngress["Platform Ingress<br/>(HTTPRoute/Route)<br/>443/TCP HTTPS"]
        AuthProxy["kube-rbac-proxy /<br/>oauth-proxy Sidecar<br/>8443/TCP HTTPS"]
        ModelStorage["Model Storage<br/>(S3 / PVC)"]
        GPU["GPU Device<br/>(CUDA IPC)"]
    end

    %% Flows
    Client -->|"HTTPS/443"| PlatformIngress
    PlatformIngress -->|"HTTPS/8443"| AuthProxy
    AuthProxy -->|"HTTP/8000<br/>gRPC/8033"| KServeRouter
    KServeRouter -->|"gRPC/8033"| TGISAdapter
    KServeRouter -->|"HTTP/8000"| HTTPServer
    InferenceService -->|"defines"| ServingRuntime
    ServingRuntime -->|"runs"| TGISAdapter
    ServingRuntime -->|"runs"| HTTPServer
    ModelStorage -->|"volume mount /<br/>HTTPS/443"| VLLMEngine
    CUDARuntime -->|"CUDA IPC"| GPU
    RHAIIS -.->|"base image"| PythonRT

    %% Styling
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style PythonRT fill:#6baed6,stroke:#333
    style CUDARuntime fill:#6baed6,stroke:#333
    style RHAIIS fill:#bdd7e7,stroke:#333
    style KServeRouter fill:#7ed321,stroke:#333
    style InferenceService fill:#f5a623,stroke:#333
    style ServingRuntime fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style PlatformIngress fill:#ffe6cc,stroke:#d79b00
    style AuthProxy fill:#ffe6cc,stroke:#d79b00
    style ModelStorage fill:#fff2cc,stroke:#d6b656
    style GPU fill:#e8e8e8,stroke:#333
