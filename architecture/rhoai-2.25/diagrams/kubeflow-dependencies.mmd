graph LR
    subgraph Controllers["Kubeflow Notebook Controllers"]
        KFCtrl["kf-notebook-controller<br/>(core lifecycle)"]
        ODHCtrl["odh-notebook-controller<br/>(OpenShift integration)"]
    end

    %% External Dependencies
    KFCtrl -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    ODHCtrl -->|"controller framework"| ControllerRuntime
    ODHCtrl -->|"Route, OAuth, ImageStream,<br/>Proxy APIs"| OpenShiftAPI["OpenShift API<br/>v0.0.0-20231118"]

    %% Optional External Dependencies
    ODHCtrl -.->|"Elyra pipeline<br/>integration (optional)"| DSPOperator["data-science-pipelines-operator<br/>v1.1.1"]

    %% Internal Platform Dependencies (consumed by controllers)
    ODHCtrl -->|"OAuthClient CRUD"| OpenShiftOAuth["OpenShift OAuth"]
    ODHCtrl -->|"annotation-triggered<br/>TLS cert provisioning"| ServiceCA["OpenShift Service CA"]
    ODHCtrl -->|"Route creation,<br/>TLS termination"| IngressController["OpenShift Ingress<br/>Controller"]
    ODHCtrl -->|"CRD watch (DSPA)"| DSPA["Data Science Pipelines<br/>Operator"]
    ODHCtrl -->|"CRD read (Dashboard)<br/>API URL for Elyra"| Dashboard["ODH Dashboard"]

    %% Istio (optional)
    KFCtrl -.->|"VirtualService CRUD<br/>(when USE_ISTIO=true)"| Istio["Istio<br/>(optional)"]

    %% Integration Points (other components → controllers)
    DashboardUI["ODH Dashboard UI"] -->|"creates Notebook CRs"| KFCtrl
    DashboardUI -->|"creates Notebook CRs"| ODHCtrl

    %% Shared resources
    KFCtrl -->|"watch/manage"| NotebookCRD["Notebook CRD<br/>kubeflow.org/v1"]
    ODHCtrl -->|"watch/mutate"| NotebookCRD

    %% Runtime dependencies
    KFCtrl -->|"HTTPS 6443"| K8sAPI["Kubernetes API<br/>Server"]
    ODHCtrl -->|"HTTPS 6443"| K8sAPI

    %% Styling
    style KFCtrl fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ODHCtrl fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style DSPOperator fill:#999,stroke:#333,color:#fff
    style OpenShiftOAuth fill:#7ed321,stroke:#333,color:#000
    style ServiceCA fill:#7ed321,stroke:#333,color:#000
    style IngressController fill:#7ed321,stroke:#333,color:#000
    style DSPA fill:#7ed321,stroke:#333,color:#000
    style Dashboard fill:#7ed321,stroke:#333,color:#000
    style DashboardUI fill:#7ed321,stroke:#333,color:#000
    style Istio fill:#999,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style NotebookCRD fill:#f5a623,stroke:#333,color:#000
    style K8sAPI fill:#f5a623,stroke:#333,color:#000
