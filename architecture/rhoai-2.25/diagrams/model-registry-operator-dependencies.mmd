graph LR
    MROperator["Model Registry<br/>Operator"]

    %% External Dependencies (frameworks/libraries)
    MROperator -->|"operator framework<br/>v0.16.3"| ControllerRuntime["controller-runtime"]
    MROperator -->|"resource diffing<br/>v1.8.0"| ObjectMatcher["k8s-objectmatcher"]
    MROperator -->|"scheme registration<br/>(legacy v1alpha1)"| IstioClient["Istio client-go<br/>v1.20.3"]

    %% OpenShift Platform APIs
    MROperator -->|"Route CRUD<br/>443/TCP HTTPS"| RouteAPI["OpenShift Route API<br/>(route.openshift.io)"]
    MROperator -->|"User groups CRUD<br/>443/TCP HTTPS"| UserAPI["OpenShift User API<br/>(user.openshift.io)"]
    MROperator -->|"Ingress domain<br/>443/TCP HTTPS"| ConfigAPI["OpenShift Config API<br/>(config.openshift.io)"]
    MROperator -->|"TLS cert auto-provisioning"| ServingCert["OpenShift Serving<br/>Cert Controller"]

    %% Kubernetes APIs
    MROperator -->|"CRD watches, CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    MROperator -->|"v1alpha1→v1beta1<br/>migration"| SVMAPI["StorageVersionMigration<br/>API (migration.k8s.io)"]
    MROperator -->|"CRD status reads"| CRDAPI["CRD API<br/>(apiextensions.k8s.io)"]

    %% Internal ODH Dependencies (container images)
    MROperator -->|"REST proxy container"| ModelRegistry["model-registry<br/>(REST service)"]
    MROperator -->|"gRPC MLMD container"| MLMDServer["mlmd-grpc-server<br/>(gRPC service)"]
    MROperator -->|"OAuth sidecar container"| OAuthProxy["ose-oauth-proxy<br/>(sidecar)"]
    MROperator -->|"catalog data init container"| CatalogData["odh-model-metadata<br/>-collection"]
    MROperator -->|"async upload job"| AsyncUpload["model-registry-job<br/>-async-upload"]

    %% Platform Integration
    MROperator -->|"watches platform CR<br/>for catalog ownership"| PlatformCR["Platform ModelRegistry<br/>(components.platform.<br/>opendatahub.io)"]

    %% External Data Stores
    MROperator -.->|"metadata storage<br/>{port}/TCP<br/>optional TLS"| PostgreSQL["PostgreSQL"]
    MROperator -.->|"metadata storage<br/>{port}/TCP<br/>optional TLS"| MySQL["MySQL"]

    %% Consumers / Integrators
    Prometheus["Prometheus<br/>(monitoring.coreos.com)"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| MROperator

    %% Styling
    style MROperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External framework dependencies
    style ControllerRuntime fill:#e8e8e8,stroke:#333
    style ObjectMatcher fill:#e8e8e8,stroke:#333
    style IstioClient fill:#e8e8e8,stroke:#333

    %% OpenShift APIs
    style RouteAPI fill:#cc99ff,stroke:#333
    style UserAPI fill:#cc99ff,stroke:#333
    style ConfigAPI fill:#cc99ff,stroke:#333
    style ServingCert fill:#cc99ff,stroke:#333

    %% Kubernetes APIs
    style K8sAPI fill:#e1d5e7,stroke:#333
    style SVMAPI fill:#e1d5e7,stroke:#333
    style CRDAPI fill:#e1d5e7,stroke:#333

    %% Internal ODH components
    style ModelRegistry fill:#7ed321,stroke:#333
    style MLMDServer fill:#7ed321,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333
    style CatalogData fill:#7ed321,stroke:#333
