graph TD
    subgraph OVMSNote["OVMS RBAC Model"]
        direction TB
        Note["OVMS is a containerized inference service,<br/>NOT a Kubernetes operator.<br/>It does NOT define any RBAC resources.<br/>All RBAC is managed by the deploying operator."]
    end

    subgraph DeploymentOperators["Deploying Operators (Manage RBAC)"]
        KServeOp["KServe Operator<br/>(creates ServiceAccount,<br/>Role, RoleBinding)"]
        ModelMeshOp["ModelMesh Controller<br/>(creates ServiceAccount,<br/>Role, RoleBinding)"]
    end

    subgraph CreatedResources["Resources Created by Operator"]
        SA["ServiceAccount<br/>(operator-managed)"]
        Role["Role / ClusterRole<br/>(operator-managed)"]
        RB["RoleBinding<br/>(operator-managed)"]
    end

    subgraph AuthEnforcement["Authentication Enforcement (Sidecar)"]
        direction TB
        KubeRBAC["kube-rbac-proxy (RHOAI 3.x)<br/>───────────────────<br/>Port: 8443/TCP → app port<br/>TLS: Terminates TLS<br/>AuthN: SubjectAccessReview<br/>AuthZ: Kubernetes RBAC"]
        OAuthProxy["oauth-proxy (RHOAI 2.x)<br/>───────────────────<br/>Port: 8443/TCP → app port<br/>TLS: Terminates TLS<br/>AuthN: OAuth/OIDC<br/>AuthZ: Token validation"]
    end

    subgraph OVMSContainer["OVMS Container"]
        OVMSApp["OVMS Application<br/>───────────────────<br/>gRPC: InsecureServerCredentials<br/>REST: No TLS, No Auth<br/>Auth: NONE<br/>⚠ Direct exposure = unauthenticated"]
    end

    subgraph Secrets["Secrets (User/Operator Provisioned)"]
        S3Creds["S3 Credentials<br/>Type: Opaque<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>Auto-Rotate: No"]
        AzureCreds["Azure Storage Credentials<br/>Type: Opaque<br/>Connection String<br/>Auto-Rotate: No"]
        GCSCreds["GCS Credentials<br/>Type: Opaque<br/>Credentials JSON<br/>Auto-Rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>HF_TOKEN<br/>Auto-Rotate: No"]
    end

    %% Operator creates resources
    KServeOp -->|creates| SA
    KServeOp -->|creates| Role
    KServeOp -->|creates| RB
    ModelMeshOp -->|creates| SA
    ModelMeshOp -->|creates| Role
    ModelMeshOp -->|creates| RB

    %% Binding
    RB -->|binds| SA
    RB -->|references| Role

    %% SA used by pod
    SA -->|"assigned to pod"| OVMSApp

    %% Auth enforcement
    KubeRBAC -->|"plaintext forward<br/>pre-authenticated"| OVMSApp
    OAuthProxy -->|"plaintext forward<br/>pre-authenticated"| OVMSApp

    %% Secrets mounted
    S3Creds -.->|"env vars / mounted files"| OVMSApp
    AzureCreds -.->|"env vars / mounted files"| OVMSApp
    GCSCreds -.->|"env vars / mounted files"| OVMSApp
    HFToken -.->|"env vars / mounted files"| OVMSApp

    %% Styling
    style OVMSNote fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Note fill:#fff3cd,stroke:#ffc107
    style DeploymentOperators fill:#d5e8d4,stroke:#82b366
    style CreatedResources fill:#dae8fc,stroke:#6c8ebf
    style AuthEnforcement fill:#ffe6cc,stroke:#d79b00
    style OVMSContainer fill:#f8cecc,stroke:#b85450
    style Secrets fill:#e1d5e7,stroke:#9673a6
    style OVMSApp fill:#f8cecc,stroke:#b85450
    style KubeRBAC fill:#ffe6cc,stroke:#d79b00
    style OAuthProxy fill:#ffe6cc,stroke:#d79b00
