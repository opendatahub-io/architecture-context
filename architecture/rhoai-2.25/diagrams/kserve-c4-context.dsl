// KServe C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/kserve.md

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys ML models for inference"

        kserve = softwareSystem "KServe" "Kubernetes-native ML model serving platform with serverless inference, raw deployment, and LLM-optimized serving" {
            controllerManager = container "kserve-controller-manager" "Main operator managing InferenceService, InferenceGraph, TrainedModel, LocalModelCache, LLMInferenceService CRDs" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Mutating and validating webhooks for all KServe CRDs" "Admission Webhook, 9443/TCP HTTPS"
            storageInitializer = container "storage-initializer" "Downloads model artifacts from cloud storage into serving containers" "Init Container"
            kserveAgent = container "kserve-agent" "Request logging, batching, and model lifecycle management" "Sidecar Container"
            kserveRouter = container "kserve-router" "InferenceGraph routing logic for multi-step inference pipelines" "Container"
            eppScheduler = container "EPP Scheduler" "LLM-d inference scheduler for intelligent request routing via ext_proc" "gRPC Service, 9002/TCP"
        }

        // External Dependencies
        istio = softwareSystem "Istio Service Mesh" "Network layer for VirtualService-based routing, mTLS, local gateway" "External" {
            tags "External"
        }
        knative = softwareSystem "Knative Serving" "Serverless model serving with autoscaling to/from zero" "External" {
            tags "External"
        }
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute-based ingress for raw deployment and LLM serving modes" "External" {
            tags "External"
        }
        gie = softwareSystem "Gateway API Inference Extension" "InferencePool/InferenceModel CRDs for LLM request routing" "External" {
            tags "External"
        }
        openshift = softwareSystem "OpenShift" "Container platform with Routes, SCCs, service-ca cert injection" "External" {
            tags "External"
        }
        keda = softwareSystem "KEDA" "Event-driven autoscaling via ScaledObject" "External" {
            tags "External"
        }
        lws = softwareSystem "LeaderWorkerSet" "Multi-node LLM serving workload orchestration" "External" {
            tags "External"
        }
        cloudStorage = softwareSystem "Cloud Storage (S3/GCS/Azure)" "Model artifact storage" "External" {
            tags "External"
        }
        prometheus = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor for metrics" "External" {
            tags "External"
        }

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys KServe manifests via kustomize overlays" "Internal ODH" {
            tags "Internal ODH"
        }
        odhModelController = softwareSystem "odh-model-controller" "Manages OpenShift Routes and auth proxy for InferenceServices" "Internal ODH" {
            tags "Internal ODH"
        }

        // Relationships - User
        user -> kserve "Creates InferenceService / LLMInferenceService via kubectl/API"

        // Relationships - External Dependencies
        kserve -> istio "VirtualService, Gateway, DestinationRule CRs for ingress and mTLS"
        kserve -> knative "Knative Service CRs for serverless autoscaling"
        kserve -> gatewayAPI "HTTPRoute CRs for raw deployment ingress"
        kserve -> gie "InferencePool/InferenceModel CRs for LLM routing"
        kserve -> openshift "Routes, SCCs, service-ca certificates"
        kserve -> keda "ScaledObject CRs for event-driven autoscaling" "Optional"
        kserve -> lws "LeaderWorkerSet CRs for multi-node serving" "Optional"
        kserve -> cloudStorage "Downloads model artifacts" "HTTPS/443"
        kserve -> prometheus "ServiceMonitor/PodMonitor CRs for metrics scraping"

        // Relationships - Internal ODH
        rhodsOperator -> kserve "Deploys via kustomize overlays"
        odhModelController -> kserve "Manages auth proxy and OpenShift Routes"

        // Container relationships
        controllerManager -> webhookServer "Webhook registration"
        controllerManager -> storageInitializer "Configures as init container on model pods"
        controllerManager -> kserveAgent "Configures as sidecar on model pods"
        controllerManager -> kserveRouter "Deploys for InferenceGraph pipelines"
        controllerManager -> eppScheduler "Deploys for LLMInferenceService scheduling"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
