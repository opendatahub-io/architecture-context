graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        Server["Axum HTTP Server<br/>Port 8080/TCP<br/>Rust"]
        HealthEndpoint["/health<br/>GET"]
        DetectionEndpoint["/api/v1/text/contents<br/>POST"]
        Server --> HealthEndpoint
        Server --> DetectionEndpoint

        subgraph "Detection Engine"
            BuiltIn["Built-in PII Detectors<br/>(HashMap)"]
            EmailDetector["Email Detector<br/>regex pattern"]
            SSNDetector["SSN Detector<br/>regex pattern"]
            CCDetector["Credit Card Detector<br/>regex pattern"]
            CustomRegex["Custom Regex<br/>Compiled per-request"]
            BuiltIn --> EmailDetector
            BuiltIn --> SSNDetector
            BuiltIn --> CCDetector
        end

        DetectionEndpoint --> BuiltIn
        DetectionEndpoint --> CustomRegex
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| Server
    Server -->|"Detection Results<br/>[[detections]]"| Orchestrator

    subgraph "Runtime Dependencies"
        Tokio["Tokio Async Runtime"]
        TowerHTTP["Tower-HTTP<br/>Tracing Middleware"]
        Serde["Serde / Serde JSON<br/>Serialization"]
        RegexCrate["regex crate<br/>Pattern Engine"]
    end

    Server -.->|uses| Tokio
    Server -.->|uses| TowerHTTP
    DetectionEndpoint -.->|uses| Serde
    BuiltIn -.->|uses| RegexCrate
    CustomRegex -.->|uses| RegexCrate

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#7ed321,stroke:#333
    style DetectionEndpoint fill:#7ed321,stroke:#333
    style BuiltIn fill:#f5a623,stroke:#333
    style EmailDetector fill:#f8d486,stroke:#333
    style SSNDetector fill:#f8d486,stroke:#333
    style CCDetector fill:#f8d486,stroke:#333
    style CustomRegex fill:#f5a623,stroke:#333
    style Orchestrator fill:#e8e8e8,stroke:#333
    style Tokio fill:#ddd,stroke:#999
    style TowerHTTP fill:#ddd,stroke:#999
    style Serde fill:#ddd,stroke:#999
    style RegexCrate fill:#ddd,stroke:#999
