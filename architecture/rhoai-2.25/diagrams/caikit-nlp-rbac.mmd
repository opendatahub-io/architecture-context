graph TD
    subgraph Note["caikit-nlp RBAC"]
        direction TB
        Info["caikit-nlp is a Python library,<br/>not a Kubernetes operator.<br/><br/>No ClusterRoles, Roles,<br/>or RoleBindings are defined.<br/><br/>RBAC is managed by the<br/>model serving infrastructure<br/>(KServe / ModelMesh)."]
    end

    subgraph ContainerSecurity["Container Security"]
        direction TB
        Image["Container Image<br/>odh-caikit-nlp-rhel9<br/>Base: UBI 9 (ubi-minimal)"]
        User["Runtime User<br/>caikit (UID 1001)<br/>Non-root"]
        Volume["Volume Mount<br/>/caikit/<br/>Models & config"]
    end

    subgraph TLSAuth["TLS / mTLS Authentication"]
        direction TB

        subgraph ServerTLS["Server-Side TLS"]
            ServerKey["RUNTIME_TLS_SERVER_KEY<br/>(TLS key file)<br/>Provisioned: Manual / cert-manager"]
            ServerCert["RUNTIME_TLS_SERVER_CERT<br/>(TLS cert file)<br/>Provisioned: Manual / cert-manager"]
            ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>(TLS cert file)<br/>mTLS client verification"]
        end

        subgraph TGISTls["TGIS Backend TLS"]
            TGISCa["TGIS ca_cert_file<br/>(CA cert)<br/>Provisioned: Manual"]
            TGISClientCert["TGIS client_cert_file<br/>(TLS cert)<br/>Provisioned: Manual"]
            TGISClientKey["TGIS client_key_file<br/>(TLS key)<br/>Provisioned: Manual"]
        end
    end

    subgraph AuthEndpoints["Authentication Enforcement"]
        gRPCAuth["gRPC Services<br/>Auth: mTLS optional<br/>Enforcement: Caikit runtime<br/>gRPC server"]
        HTTPAuth["HTTP Endpoints<br/>Auth: Configurable<br/>Enforcement: Caikit runtime<br/>HTTP server"]
        TGISAuth["TGIS Backend<br/>Auth: mTLS optional<br/>Enforcement: gRPC channel"]
    end

    ServerKey --> gRPCAuth
    ServerCert --> gRPCAuth
    ClientCert --> gRPCAuth
    ServerKey --> HTTPAuth
    ServerCert --> HTTPAuth
    TGISCa --> TGISAuth
    TGISClientCert --> TGISAuth
    TGISClientKey --> TGISAuth

    style Note fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    style Info fill:#fff3e0,stroke:#ef6c00
    style ContainerSecurity fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style TLSAuth fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style ServerTLS fill:#bbdefb,stroke:#1565c0
    style TGISTls fill:#bbdefb,stroke:#1565c0
    style AuthEndpoints fill:#fce4ec,stroke:#c62828,stroke-width:2px

    style Image fill:#43a047,color:#fff
    style User fill:#43a047,color:#fff
    style Volume fill:#43a047,color:#fff
    style ServerKey fill:#4a90e2,color:#fff
    style ServerCert fill:#4a90e2,color:#fff
    style ClientCert fill:#4a90e2,color:#fff
    style TGISCa fill:#4a90e2,color:#fff
    style TGISClientCert fill:#4a90e2,color:#fff
    style TGISClientKey fill:#4a90e2,color:#fff
    style gRPCAuth fill:#e57373,color:#fff
    style HTTPAuth fill:#e57373,color:#fff
    style TGISAuth fill:#e57373,color:#fff
