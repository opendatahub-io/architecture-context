graph TD
    %% Generated by: Claude Opus 4.6
    %% Source: architecture/rhoai-2.25/caikit-nlp.md
    %% Note: caikit-nlp is a Python library, not a Kubernetes operator.
    %% It defines no CRDs, ClusterRoles, or RBAC resources of its own.
    %% Security is enforced by the platform layer (KServe/ModelMesh/Istio).
    subgraph Note["caikit-nlp Security Model"]
        direction TB
        Info["caikit-nlp is a Python library<br/>No Kubernetes RBAC defined<br/>Auth delegated to platform"]
    end

    subgraph PlatformAuth["Platform Authentication (Delegated)"]
        direction TB
        IstioSidecar["Istio Sidecar Proxy<br/>mTLS enforcement<br/>RequestAuthentication"]
        KServeAuth["KServe Gateway<br/>Route-level auth<br/>TLS termination"]
        ModelMeshAuth["ModelMesh<br/>Internal gRPC routing<br/>Platform auth"]
    end

    subgraph ContainerSecurity["Container Security"]
        direction TB
        BaseImage["Base Image<br/>ubi9/ubi-minimal:latest"]
        RunAsUser["Run-as User<br/>caikit (UID 1001)<br/>Non-root"]
        NoShell["Shell: /sbin/nologin<br/>No interactive access"]
        NoDownloads["Downloads Disabled<br/>allow_downloads: false"]
    end

    subgraph TLSConfig["TLS / mTLS Configuration"]
        direction TB

        subgraph ServingTLS["Serving Endpoint TLS"]
            ServerKey["RUNTIME_TLS_SERVER_KEY<br/>TLS private key<br/>Provisioned by: Platform/cert-manager"]
            ServerCert["RUNTIME_TLS_SERVER_CERT<br/>TLS certificate<br/>Provisioned by: Platform/cert-manager"]
            ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>mTLS client cert<br/>Provisioned by: Platform/cert-manager"]
        end

        subgraph BackendTLS["TGIS Backend mTLS"]
            CACert["ca_cert_file<br/>CA certificate<br/>Provisioned by: Platform/manual"]
            BEClientCert["client_cert_file<br/>Client certificate<br/>Provisioned by: Platform/manual"]
            BEClientKey["client_key_file<br/>Client key<br/>Provisioned by: Platform/manual"]
        end
    end

    subgraph Endpoints["Endpoint Auth Summary"]
        HTTP["HTTP API (8080/TCP)<br/>Auth: Delegated to platform<br/>Enforcement: Istio sidecar"]
        GRPC["gRPC API (8085/TCP)<br/>Auth: Delegated to platform<br/>Enforcement: Istio sidecar"]
        TGISEndpoint["TGIS Backend (gRPC)<br/>Auth: mTLS (optional)<br/>Enforcement: caikit-tgis-backend client"]
    end

    %% Connections
    IstioSidecar -->|enforces auth on| HTTP
    IstioSidecar -->|enforces auth on| GRPC
    KServeAuth -->|routes to| HTTP
    ModelMeshAuth -->|routes to| GRPC

    ServerKey -->|configures| HTTP
    ServerCert -->|configures| HTTP
    ServerKey -->|configures| GRPC
    ServerCert -->|configures| GRPC
    ClientCert -->|configures| GRPC

    CACert -->|configures| TGISEndpoint
    BEClientCert -->|configures| TGISEndpoint
    BEClientKey -->|configures| TGISEndpoint

