graph TB
    subgraph External["External Clients"]
        Client["Client Application"]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["Gateway Controller<br/>(Envoy / Istio / AgentGateway)<br/>80/TCP HTTP"]
        HTTPRoute["HTTPRoute<br/>(per InferenceModel)"]
        HTTPRoute -->|"routes to"| Gateway
    end

    subgraph ControlPlane["Control Plane (Gateway API Inference Extension)"]
        EPP["llm-d Router (EPP)<br/>llm-d-inference-scheduler<br/>9002/TCP gRPC ext-proc"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        InferenceModel["InferenceModel CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        InferenceModel -->|"maps model → pool"| InferencePool
        EPP -->|"watches"| InferencePool
        EPP -->|"watches"| InferenceModel
    end

    subgraph ModelServers["Model Server Pods"]
        direction TB
        subgraph CUDAServer["CUDA Server (Primary)"]
            vLLM_CUDA["vLLM + CUDA 13.0.2<br/>NIXL + UCX + NVSHMEM<br/>FlashInfer + DeepEP + DeepGEMM<br/>LMCache + Infinistore<br/>8000/TCP"]
        end
        subgraph ROCmServer["ROCm Server"]
            vLLM_ROCm["vLLM + ROCm<br/>RIXL + UCX<br/>8000/TCP"]
        end
        subgraph HPUServer["HPU Server"]
            vLLM_HPU["vLLM + vllm-gaudi<br/>NIXL<br/>8000/TCP"]
        end
        subgraph CPUServer["CPU Server"]
            vLLM_CPU["vLLM (CPU-only)<br/>NIXL + UCX<br/>8000/TCP"]
        end
    end

    subgraph BuildSystem["Build System"]
        Makefile["Makefile<br/>Multi-arch Build Orchestration"]
        Dockerfile_CUDA["Dockerfile.cuda<br/>Multi-stage (20+ build args)"]
        Dockerfile_ROCm["Dockerfile.rocm"]
        Dockerfile_HPU["Dockerfile.hpu"]
        Dockerfile_CPU["Dockerfile.cpu"]
        Dockerfile_RDMA["Dockerfile.rdma-tools<br/>Diagnostic Image"]
        Makefile --> Dockerfile_CUDA
        Makefile --> Dockerfile_ROCm
        Makefile --> Dockerfile_HPU
        Makefile --> Dockerfile_CPU
        Makefile --> Dockerfile_RDMA
    end

    subgraph DeploymentRecipes["Deployment Recipes"]
        KustomizeBase["Kustomize Base<br/>guides/recipes/modelserver/"]
        HelmChart["Helm Chart<br/>(EPP / Router)"]
        Overlays["Guide Overlays<br/>optimized-baseline<br/>pd-disaggregation<br/>wide-ep-lws<br/>tiered-prefix-cache"]
        KustomizeBase --> Overlays
    end

    %% Request Flow
    Client -->|"HTTP/80"| Gateway
    Gateway -->|"gRPC ext-proc/9002"| EPP
    EPP -->|"selects endpoint"| Gateway
    Gateway -->|"HTTP/8000"| vLLM_CUDA

    %% RDMA Flow (P/D disaggregation)
    vLLM_CUDA <-->|"RDMA (NIXL/UCX)<br/>KV cache transfer"| vLLM_CUDA

    %% Build outputs
    Dockerfile_CUDA -.->|"builds"| vLLM_CUDA
    Dockerfile_ROCm -.->|"builds"| vLLM_ROCm
    Dockerfile_HPU -.->|"builds"| vLLM_HPU
    Dockerfile_CPU -.->|"builds"| vLLM_CPU

    %% Deployment
    Overlays -.->|"deploys"| vLLM_CUDA
    HelmChart -.->|"deploys"| EPP

    %% Styling
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style HTTPRoute fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    style EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,stroke-width:1px
    style InferenceModel fill:#f5a623,stroke:#333,stroke-width:1px
    style vLLM_CUDA fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style vLLM_ROCm fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style vLLM_HPU fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style vLLM_CPU fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Makefile fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Dockerfile_CUDA fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Dockerfile_ROCm fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Dockerfile_HPU fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Dockerfile_CPU fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Dockerfile_RDMA fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style KustomizeBase fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style HelmChart fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style Overlays fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
