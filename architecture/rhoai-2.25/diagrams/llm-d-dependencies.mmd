graph LR
    LLMD["llm-d<br/>Inference Serving Stack"]

    %% Core Runtime Dependencies
    LLMD -->|"model serving engine<br/>v0.19.1 (fork)"| vLLM["vLLM"]
    LLMD -->|"alternative engine"| SGLang["SGLang"]

    %% GPU Compute Dependencies
    LLMD -->|"GPU compute<br/>CUDA 13.0.2"| CUDA["CUDA"]
    LLMD -->|"AMD GPU compute"| ROCm["ROCm"]
    LLMD -->|"Intel Gaudi SDK<br/>SynapseAI 1.23.0"| Habana["Habana SynapseAI"]
    LLMD -->|"deep learning framework<br/>2.10.0"| PyTorch["PyTorch"]

    %% High-Performance Networking
    LLMD -->|"GPU-to-GPU RDMA<br/>v1.0.0"| NIXL["NIXL"]
    LLMD -->|"transport layer<br/>v1.20.0"| UCX["UCX"]
    LLMD -->|"multi-GPU shared mem"| NVSHMEM["NVSHMEM"]
    LLMD -->|"GPUDirect RDMA<br/>v2.5.2"| GDRCopy["GDRCopy"]

    %% Compute Kernels
    LLMD -->|"flash attention<br/>v0.6.6"| FlashInfer["FlashInfer"]
    LLMD -->|"expert parallelism<br/>MoE models"| DeepEP["DeepEP"]
    LLMD -->|"matrix multiplication<br/>MoE models"| DeepGEMM["DeepGEMM"]

    %% KV Cache Management
    LLMD -->|"KV cache offloading<br/>v0.4.4-cu13"| LMCache["LMCache"]
    LLMD -->|"remote KV storage<br/>0.2.33"| Infinistore["Infinistore"]

    %% Platform Dependencies
    LLMD -->|"orchestration<br/>1.29+"| K8s["Kubernetes"]
    LLMD -->|"CRDs: InferencePool<br/>InferenceModel"| GatewayAPIExt["Gateway API<br/>Inference Extension<br/>v1.5.0"]
    LLMD -->|"CRDs: Gateway<br/>HTTPRoute"| GatewayAPI["Gateway API v1"]
    LLMD -->|"chart deployment"| Helm["Helm 3.x"]
    LLMD -->|"overlay deployment"| Kustomize["Kustomize 4.x+"]

    %% Observability
    LLMD -->|"tracing<br/>1.39.1+"| OTel["OpenTelemetry SDK"]

    %% Internal Platform Components
    EPP["llm-d Router (EPP)<br/>llm-d-inference-scheduler"] -->|"ext-proc gRPC/9002<br/>endpoint selection"| LLMD
    GatewayCtrl["Gateway Controller<br/>(Envoy/Istio/AgentGateway)"] -->|"HTTP/80<br/>L7 proxy"| LLMD
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/8000"| LLMD
    Grafana["Grafana"] -->|"dashboards"| Prometheus
    HPA["HPA / KEDA"] -->|"autoscaling"| LLMD
    WVA["Workload Variant<br/>Autoscaler"] -->|"SLO-aware scaling"| LLMD
    LWS["LeaderWorkerSet"] -->|"multi-node orchestration"| LLMD

    %% External Services
    LLMD -->|"model downloads<br/>HTTPS/443"| HF["HuggingFace Hub"]
    LLMD -->|"image pulls<br/>HTTPS/443"| GHCR["ghcr.io"]

