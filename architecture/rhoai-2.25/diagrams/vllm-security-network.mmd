graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-managed)"]
        PlatformIngress["Platform Ingress<br/>(HTTPRoute / Route)<br/>443/TCP<br/>TLS 1.2+"]
        AuthProxy["Auth Proxy Sidecar<br/>8443/TCP HTTPS<br/>oauth-proxy (2.x) /<br/>kube-rbac-proxy (3.x)"]
    end

    subgraph PodBoundary["POD BOUNDARY (KServe InferenceService Pod)"]
        direction TB

        KServeRouter["KServe Router"]

        subgraph VLLMContainer["vLLM Container (odh-vllm-cuda-rhel9)"]
            direction TB
            TGISAdapter["vLLM TGIS Adapter<br/>8033/TCP gRPC<br/>No TLS (pod-internal)"]
            HTTPServer["vLLM HTTP Server<br/>8000/TCP HTTP<br/>No TLS (pod-internal)<br/>Endpoints:<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"]
            VLLMEngine["vLLM Engine<br/>(PagedAttention,<br/>Continuous Batching,<br/>Speculative Decoding)"]

            TGISAdapter -->|"Python IPC<br/>(in-process)"| VLLMEngine
            HTTPServer -->|"Python IPC<br/>(in-process)"| VLLMEngine
        end

        KServeRouter -->|"gRPC/8033<br/>No encryption<br/>pod-internal"| TGISAdapter
        KServeRouter -->|"HTTP/8000<br/>No encryption<br/>pod-internal"| HTTPServer
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / HMAC"]
        GPU["GPU Device<br/>NVIDIA CUDA<br/>CUDA IPC"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| PlatformIngress
    PlatformIngress -->|"HTTPS/8443<br/>TLS<br/>Auth passthrough"| AuthProxy
    AuthProxy -->|"HTTP/8000 or gRPC/8033<br/>No encryption<br/>AuthN/AuthZ enforced"| KServeRouter

    %% Egress flows
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / HMAC<br/>Model download"| S3
    VLLMEngine -->|"CUDA IPC<br/>Tensor operations"| GPU

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class PlatformIngress,AuthProxy ingress
    class KServeRouter,TGISAdapter,HTTPServer,VLLMEngine pod
    class S3,GPU externalservice
