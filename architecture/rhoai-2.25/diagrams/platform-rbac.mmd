        CR_ModelMesh[modelmesh-controller-role<br/>═════════<br/>serving.kserve.io/*<br/>predictors, servingruntimes]

        CR_Pipelines[manager-role<br/>═════════<br/>datasciencepipelinesapplications.*<br/>argoproj.io/workflows<br/>serving.kserve.io/inferenceservices]

        CR_Training[training-operator<br/>═════════<br/>kubeflow.org/pytorchjobs<br/>kubeflow.org/tfjobs<br/>kubeflow.org/mpijobs<br/>kubeflow.org/xgboostjobs<br/>kubeflow.org/paddlejobs<br/>kubeflow.org/jaxjobs]

        CR_CodeFlare[manager-role<br/>═════════<br/>workload.codeflare.dev/*<br/>ray.io/rayclusters<br/>dscinitialization.opendatahub.io/*]

        CR_KubeRay[kuberay-operator<br/>═════════<br/>ray.io/rayclusters<br/>ray.io/rayjobs<br/>ray.io/rayservices]

        CR_Kueue[kueue-manager-role<br/>═════════<br/>kueue.x-k8s.io/*<br/>batch/jobs<br/>kubeflow.org/* training jobs<br/>ray.io/*]

        CR_TrustyAI[manager-role<br/>═════════<br/>trustyai.opendatahub.io/*<br/>serving.kserve.io/inferenceservices<br/>kueue.x-k8s.io/workloads]

        CR_Feast[feast-operator-manager-role<br/>═════════<br/>feast.dev/featurestores]

        CR_LlamaStack[manager-role<br/>═════════<br/>llamastack.io/llamastackdistributions]

        CR_Notebook[notebook-controller-role<br/>═════════<br/>kubeflow.org/notebooks<br/>networking.istio.io/virtualservices]

        CR_ModelReg[manager-role<br/>═════════<br/>modelregistry.opendatahub.io/*]
