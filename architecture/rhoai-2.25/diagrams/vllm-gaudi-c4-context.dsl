/*
 * C4 Context Diagram for vllm-gaudi
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries LLM inference endpoints"
        application = person "Application" "Sends inference requests to deployed models"

        vllmGaudi = softwareSystem "vllm-gaudi" "vLLM hardware plugin for Intel Gaudi accelerators, providing optimized LLM inference on HPU devices" {
            apiServer = container "OpenAI API Server" "OpenAI-compatible HTTP API server for inference" "Python / vLLM entrypoint" "Port 8000/TCP"
            hpuPlatform = container "HpuPlatform" "Registers HPU as vLLM platform; configures device, attention backends, quantization" "Python Plugin"
            hpuWorker = container "HPUWorker" "Manages HPU device lifecycle, model loading, KV cache allocation" "Python Worker"
            hpuModelRunner = container "HPUModelRunner" "Handles input preparation, bucketing, batching, model forward pass" "Python Model Runner"
            attentionBackends = container "HPU Attention Backends" "Custom attention implementations (V1, Unified, MLA) for Gaudi" "Python Modules"
            customOps = container "Custom Ops" "HPU-optimized operators: fused MoE, rotary embedding, layernorm, FP8" "Python Modules"
            communicator = container "HpuCommunicator" "Distributed communication via HCCL for tensor/expert parallelism" "Python Module"
            modelOverrides = container "Model Overrides" "HPU-optimized implementations for 12+ model architectures" "Python Modules"
        }

        vllm = softwareSystem "vLLM" "Core inference engine (v0.16.0)" "External"
        synapseAI = softwareSystem "Intel SynapseAI" "Habana device drivers and runtime (v1.23.0)" "External"
        pytorch = softwareSystem "PyTorch" "Deep learning framework with Habana extensions (v2.9.0)" "External"
        ray = softwareSystem "Ray" "Distributed execution framework for multi-HPU inference" "External"
        transformers = softwareSystem "HuggingFace Transformers" "Model loading and tokenization" "External"

        kserve = softwareSystem "KServe" "Deploys vllm-gaudi as InferenceService serving runtime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Alternative deployment as ServingRuntime" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages lifecycle of serving runtimes" "Internal RHOAI"
        odhModelController = softwareSystem "odh-model-controller" "Creates ingress routes for inference endpoints" "Internal RHOAI"

        s3Storage = softwareSystem "Model Storage (S3/PVC)" "Stores model weight artifacts" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and tokenizer repository" "External"
        gaudiHPU = softwareSystem "Intel Gaudi HPU" "Gaudi 2/3 AI accelerator hardware" "External Hardware"

        # Relationships
        application -> vllmGaudi "Sends inference requests" "HTTPS/443 via KServe Gateway"
        datascientist -> kserve "Deploys InferenceService with vllm-gaudi runtime" "kubectl / RHOAI Dashboard"

        vllmGaudi -> vllm "Extends as hardware plugin" "Python entry points"
        vllmGaudi -> synapseAI "Uses device drivers" "habanalabs drivers"
        vllmGaudi -> pytorch "Uses for tensor operations" "Python API"
        vllmGaudi -> ray "Uses for distributed execution" "TCP/6379 + dynamic"
        vllmGaudi -> transformers "Loads models and tokenizers" "Python API"
        vllmGaudi -> gaudiHPU "Executes inference on accelerator" "PCIe/Device"
        vllmGaudi -> s3Storage "Downloads model weights" "HTTPS/443, IAM Auth"
        vllmGaudi -> huggingfaceHub "Downloads models/tokenizers" "HTTPS/443, API Token"

        kserve -> vllmGaudi "Deploys as container runtime" "HTTP/8000"
        modelmesh -> vllmGaudi "Deploys as ServingRuntime" "HTTP/8000"
        rhoaiOperator -> kserve "Manages serving runtime lifecycle"
        odhModelController -> kserve "Creates ingress routes"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "External Hardware" {
                background #f5a623
                color #000000
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
