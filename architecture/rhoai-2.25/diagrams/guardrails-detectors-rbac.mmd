graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["🟢 No RBAC roles required"]
        L2["🟡 Example binding only (not production)"]
    end

    subgraph DetectorWorkloads["Detector Workloads (No K8s API Access)"]
        BuiltIn["Built-In Detector<br/>No ServiceAccount<br/>No RBAC needed"]
        HF["HuggingFace Detector<br/>KServe-managed SA<br/>No custom RBAC"]
        Judge["LLM Judge Detector<br/>KServe-managed SA<br/>No custom RBAC"]
    end

    subgraph ExampleRBAC["Example RBAC (model_container.yaml - NOT production)"]
        SA["ServiceAccount<br/>user-one"]
        RB["RoleBinding<br/>user-one-view"]
        CR["ClusterRole<br/>view"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| CR

    subgraph PlatformAuth["Platform-Level Authentication (KServe/Istio/RHOAI)"]
        direction TB
        IstioMTLS["Istio mTLS<br/>ISTIO_MUTUAL mode<br/>sidecar.istio.io/inject='true'"]
        RHOAIAuth["RHOAI Auth<br/>security.opendatahub.io/<br/>enable-auth='true'"]
        DetectorIDHeader["Application Auth<br/>detector_id HTTP header<br/>(required but NOT verified)"]
    end

    HF -.->|"transport security"| IstioMTLS
    Judge -.->|"transport security"| IstioMTLS
    HF -.->|"platform auth"| RHOAIAuth
    Judge -.->|"platform auth"| RHOAIAuth
    HF -.->|"app-level header"| DetectorIDHeader
    Judge -.->|"app-level header"| DetectorIDHeader

    subgraph Secrets["Secrets"]
        S3Secret["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>Type: Opaque (S3)<br/>Purpose: MinIO model storage<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    HF -.->|"model storage access"| S3Secret

    %% Styling
    style DetectorWorkloads fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ExampleRBAC fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5
    style PlatformAuth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Legend fill:#f9f9f9,stroke:#ccc
    style BuiltIn fill:#d5e8d4,stroke:#82b366
    style HF fill:#dae8fc,stroke:#6c8ebf
    style Judge fill:#dae8fc,stroke:#6c8ebf
    style SA fill:#fff2cc,stroke:#d6b656
    style RB fill:#fff2cc,stroke:#d6b656
    style CR fill:#fff2cc,stroke:#d6b656
    style IstioMTLS fill:#dae8fc,stroke:#6c8ebf
    style RHOAIAuth fill:#dae8fc,stroke:#6c8ebf
    style DetectorIDHeader fill:#dae8fc,stroke:#6c8ebf
    style S3Secret fill:#f8cecc,stroke:#b85450
