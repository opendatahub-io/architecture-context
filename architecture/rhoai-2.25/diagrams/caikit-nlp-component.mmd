graph TB
    subgraph CaikitNLP["caikit-nlp Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local PyTorch)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftPT["PeftPromptTuning<br/>(Local Training)"]
            PeftTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
        end

        subgraph Embedding["Embedding & Reranking Modules"]
            EmbeddingMod["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEncoder["CrossEncoderModule<br/>(cross-encoder)"]
        end

        subgraph Classification["Classification & Tokenization"]
            SeqClass["SequenceClassification"]
            FilteredSpan["FilteredSpanClassification"]
            RegexSplit["RegexSentenceSplitter"]
        end

        subgraph Core["Core Components"]
            TGISAutoFinder["TGISAutoFinder<br/>(Model Finder)"]
            PretrainedModel["PretrainedModelBase<br/>(Resource)"]
            ConfigMgr["Config Manager"]
        end
    end

    subgraph Container["odh-caikit-nlp-rhel9 Container"]
        CaikitRuntime["Caikit Runtime<br/>(gRPC: 8085/TCP, HTTP: 8080/TCP)"]
    end

    Client[Client] -->|gRPC / HTTP| CaikitRuntime
    CaikitRuntime -->|loads modules| CaikitNLP

    TextGenTGIS -->|gRPC 8033/TCP| TGIS["TGIS Backend"]
    PeftTGIS -->|gRPC 8033/TCP| TGIS
    TGISAutoFinder -.->|probes| TGIS

    PretrainedModel -->|downloads| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    PeftPT -->|distributed training| TorchDist["PyTorch Distributed<br/>29550/TCP"]

    KServe["KServe / ModelMesh"] -->|deploys| Container

