graph LR
    vllmCpu["vllm-cpu<br/>CPU-only LLM Inference Server"]

    %% External Dependencies — Core Framework
    vllmCpu -->|"CPU inference<br/>framework"| PyTorch["PyTorch<br/>2.6.0+cpu / 2.7.0"]
    vllmCpu -->|"HTTP API<br/>framework"| FastAPI["FastAPI<br/>>= 0.120.1"]
    vllmCpu -->|"ASGI server"| Uvicorn["Uvicorn"]
    vllmCpu -->|"model loading &<br/>tokenization"| Transformers["transformers<br/>4.55.0–4.57.3"]

    %% External Dependencies — CPU Acceleration
    PyTorch -->|"x86_64<br/>acceleration"| IPEX["Intel Extension<br/>for PyTorch 2.6.0"]
    PyTorch -->|"ppc64le/s390x<br/>acceleration"| OpenBLAS["OpenBLAS<br/>(built from source)"]

    %% External Dependencies — Inference Features
    vllmCpu -->|"gRPC TGIS<br/>protocol"| TGISAdapter["vllm-tgis-adapter<br/>0.9.0.post1"]
    vllmCpu -->|"structured<br/>output"| XGrammar["xgrammar<br/>0.1.21"]
    vllmCpu -->|"structured<br/>output"| OutlinesCore["outlines-core<br/>0.2.10"]
    vllmCpu -->|"quantized<br/>models"| CompressedTensors["compressed-tensors<br/>0.10.2"]
    vllmCpu -->|"speculative<br/>decoding"| Numba["numba<br/>0.60.0 / 0.61.2"]

    %% External Dependencies — Tokenization & Data
    vllmCpu -->|"fast<br/>tokenization"| Tokenizers["tokenizers<br/>>= 0.21.1"]
    vllmCpu -->|"LLaMA<br/>tokenizer"| SentencePiece["sentencepiece"]
    vllmCpu -->|"data validation"| Pydantic["pydantic<br/>>= 2.10"]
    vllmCpu -->|"API protocol<br/>types"| OpenAIPkg["openai<br/>>= 1.99.1"]

    %% External Dependencies — Observability
    vllmCpu -->|"metrics<br/>exposition"| PromClient["Prometheus client<br/>>= 0.18.0"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe<br/>ServingRuntime"] -->|"deploys as<br/>ServingRuntime"| vllmCpu
    ModelServing["RHOAI Model Serving"] -->|"references<br/>container image"| vllmCpu

    %% Integration Points
    vllmCpu -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    vllmCpu -->|"model download<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrape /metrics<br/>HTTP/8000"| vllmCpu
    KServeGraph["KServe Inference<br/>Graph"] -->|"inference routing<br/>HTTP/8000, gRPC/8033"| vllmCpu
    vllmCpu -.->|"fast model<br/>deserialization"| Tensorizer["Tensorizer<br/>(optional)"]

    %% Styling
    style vllmCpu fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style IPEX fill:#bbb,stroke:#333
    style OpenBLAS fill:#bbb,stroke:#333
    style TGISAdapter fill:#999,stroke:#333,color:#fff
    style XGrammar fill:#999,stroke:#333,color:#fff
    style OutlinesCore fill:#999,stroke:#333,color:#fff
    style CompressedTensors fill:#999,stroke:#333,color:#fff
    style Numba fill:#999,stroke:#333,color:#fff
    style Tokenizers fill:#999,stroke:#333,color:#fff
    style SentencePiece fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style OpenAIPkg fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelServing fill:#7ed321,stroke:#333,color:#fff
