graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph PlatformLayer["RHOAI PLATFORM LAYER"]
        Dashboard["RHOAI Dashboard<br/>443/TCP HTTPS"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3"]
        NotebookCtrl["odh-notebook-controller<br/>SA Bearer Token"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (StatefulSet)"]
        direction TB
        KubeRBAC["kube-rbac-proxy (Sidecar)<br/>8443/TCP HTTPS TLS 1.3<br/>OAuth + RBAC enforcement"]

        subgraph InternalPod["Pod Internal (plaintext)"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>/lab, /api"]
            NGINX["NGINX Proxy<br/>8787/TCP HTTP"]
            HTTPD["httpd CGI<br/>8080/TCP HTTP<br/>/api/kernels"]
            CodeServer["code-server<br/>9999/TCP"]
            RStudioSrv["RStudio Server<br/>8787/TCP"]
        end

        KubeRBAC -->|HTTP/8888<br/>plaintext localhost<br/>No auth (trusted)| JupyterLab
        KubeRBAC -->|HTTP/8787<br/>plaintext localhost<br/>No auth (trusted)| NGINX
        NGINX --> CodeServer
        NGINX --> RStudioSrv
    end

    subgraph RuntimePod["PIPELINE RUNTIME POD (Ephemeral)"]
        RuntimeImg["Runtime Image<br/>(minimal/datascience/pytorch/tf)<br/>Headless Python execution"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Credentials"]
        Registry["registry.redhat.io / Quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secret"]
    end

    subgraph BuildTimeOnly["BUILD-TIME EGRESS ONLY"]
        PyPI["PyPI (pypi.org)<br/>443/TCP HTTPS<br/>Hash-verified packages"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS<br/>oc CLI"]
        CRAN["cran.rstudio.com<br/>443/TCP HTTPS<br/>R packages"]
    end

    %% User access flow
    User -->|HTTPS/443<br/>TLS 1.3<br/>OAuth (OpenShift)| Dashboard
    Dashboard -->|HTTPS/6443<br/>TLS 1.3<br/>SA Bearer Token| K8sAPI
    K8sAPI --> NotebookCtrl
    NotebookCtrl -->|HTTPS/6443<br/>Creates StatefulSet<br/>+ injects sidecar| K8sAPI
    User -->|HTTPS/8443<br/>TLS 1.3<br/>OAuth Token| KubeRBAC
    KubeRBAC -->|HTTPS/6443<br/>SubjectAccessReview| K8sAPI

    %% Registry pull
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry

    %% Runtime egress
    WorkbenchPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token| K8sAPI
    WorkbenchPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials| S3

    %% Pipeline flow
    RuntimePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials| S3

    %% Build-time flows
    Registry -.->|build-time| PyPI
    Registry -.->|build-time| Mirror
    Registry -.->|build-time| CRAN

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#f5f5f5,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Dashboard,K8sAPI,NotebookCtrl platform
    class KubeRBAC authproxy
    class JupyterLab,NGINX,HTTPD,CodeServer,RStudioSrv internal
    class RuntimeImg internal
    class S3,Registry externalservice
    class PyPI,Mirror,CRAN buildtime
