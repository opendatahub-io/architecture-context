%% Security Network Diagram for Notebooks
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.25/notebooks.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (TLS Termination)"]
        Gateway["OpenShift Ingress / Gateway<br/>443/TCP<br/>TLS 1.2+<br/>OAuth / Bearer Token"]
    end

    subgraph Pod["NOTEBOOK POD"]
        direction TB

        subgraph AuthSidecar["Auth Sidecar (injected by Notebook Controller)"]
            KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>(RHOAI 3.x)"]
        end

        subgraph AppContainer["Application Container (UID 1001, UBI9)"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP"]
            CodeSrv["Code Server<br/>8080/TCP HTTP<br/>(NGINX 1.24 proxy)"]
            RStudioApp["RStudio Server<br/>8787/TCP HTTP"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Credentials"]
        Registry["Container Registry<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS<br/>Pull Secret"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["rhods-operator<br/>Kustomize Apply"]
        ImageStreams["ImageStream CRs<br/>SHA256 Digest Pinned<br/>N through N-6 versions"]
    end

    %% Flows - Notebook Access
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth / Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SubjectAccessReview"| KubeRBAC
    KubeRBAC -->|"HTTP/8888<br/>plaintext (pod-local)<br/>Trusted sidecar"| Jupyter
    KubeRBAC -->|"HTTP/8080<br/>plaintext (pod-local)<br/>Trusted sidecar"| CodeSrv
    KubeRBAC -->|"HTTP/8787<br/>plaintext (pod-local)<br/>Trusted sidecar"| RStudioApp

    %% Flows - Outbound from notebook
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS credentials"| S3

    %% Flows - Operator deployment
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI
    Operator -->|creates| ImageStreams
    K8sAPI -->|"HTTPS/443<br/>Pull secret"| Registry

