graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS → 8443/TCP<br/>TLS 1.2+ Termination<br/>Route: notebook-{username}"]
    end

    subgraph PodNetwork["POD NETWORK (Trusted)"]
        direction TB

        subgraph WorkbenchPod["Workbench Pod: {user-namespace}"]
            OAuth["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>SA: {notebook-name}-sa<br/>OpenShift OAuth Validation"]
            Jupyter["Jupyter Container<br/>8888/TCP HTTP<br/>JupyterLab 4.4<br/>Image: workbench-images:jupyter-*"]
            CodeServer["Code Server Container<br/>8080/TCP HTTP<br/>VS Code IDE<br/>Image: workbench-images:codeserver-*"]
            RStudio["RStudio Container<br/>8787/TCP HTTP<br/>RStudio Server<br/>Image: workbench-images:rstudio-*"]
        end

        subgraph RuntimePod["Runtime Pod: {user-namespace}"]
            Runtime["Runtime Container<br/>No Exposed Ports<br/>SA: {pipeline-name}-sa<br/>Image: workbench-images:runtime-*"]
        end

        subgraph KubeflowNS["Namespace: kubeflow"]
            KFPController["Kubeflow Pipeline Controller<br/>SA: pipeline-runner"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS SigV4 or S3 Credentials"]
        Quay["Quay.io Registry<br/>443/TCP HTTPS TLS1.2+<br/>Pull/Push Secrets"]
        RedHatReg["registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secret"]
        PyPI["pypi.org<br/>443/TCP HTTPS TLS1.2+<br/>No Auth"]
        GitHub["GitHub<br/>443/TCP HTTPS TLS1.2+<br/>Git Token"]
        KubeAPI["Kubeflow API<br/>443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
    end

    subgraph BuildPipeline["BUILD PIPELINE (Konflux)"]
        Konflux["Konflux CI/CD Pipeline<br/>SA: appstudio-pipeline<br/>Multi-arch builds"]
    end

    %% Workbench User Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|HTTPS/8443<br/>Internal TLS<br/>OpenShift OAuth| OAuth
    OAuth -->|HTTP/8888<br/>Localhost<br/>No Encryption| Jupyter
    OAuth -->|HTTP/8080<br/>Localhost<br/>No Encryption| CodeServer
    OAuth -->|HTTP/8787<br/>Localhost<br/>No Encryption| RStudio
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    CodeServer -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    RStudio -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    %% Pipeline Runtime Flow
    KFPController -->|Pod Creation<br/>K8s API 6443/TCP<br/>HTTPS TLS1.2+<br/>SA Token| RuntimePod
    Runtime -->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4| S3
    Runtime -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| KubeAPI

    %% Build Flow
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Git Token| GitHub
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| RedHatReg
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| PyPI
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Push Secret| Quay

    %% Image Pull
    WorkbenchPod -.->|Image Pull<br/>HTTPS/443<br/>Pull Secret| Quay
    RuntimePod -.->|Image Pull<br/>HTTPS/443<br/>Pull Secret| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Router ingress
    class OAuth,Jupyter,CodeServer,RStudio,Runtime,KFPController podnetwork
    class S3,Quay,RedHatReg,PyPI,GitHub,KubeAPI externalservice
    class Konflux build
