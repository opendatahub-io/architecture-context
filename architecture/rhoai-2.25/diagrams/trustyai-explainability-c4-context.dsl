/*
 * TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */
workspace {
    model {
        datascientist = person "Data Scientist" "Monitors model fairness and requests explanations"
        sre = person "SRE / Platform Admin" "Monitors TrustyAI metrics and health"

        trustyai = softwareSystem "TrustyAI Explainability" "Quarkus REST service providing fairness metrics, data drift detection, and model explainability (XAI) for ML models" {
            service = container "explainability-service" "REST API service exposing fairness, drift, explainability, and data management endpoints" "Java 17 / Quarkus 3.8.5"
            core = container "explainability-core" "Core library with fairness metrics (SPD, DIR), XAI algorithms (LIME, SHAP, CF), data structures" "Java Library"
            connectors = container "explainability-connectors" "Connectors for KServe v1/v2 (HTTP, gRPC) and ModelMesh inference payload parsing" "Java Library"
            prometheusScheduler = container "PrometheusScheduler" "Scheduled metric computation engine; publishes fairness/drift metrics to Prometheus" "Internal Component"
            cloudEventConsumer = container "CloudEventConsumer" "Consumes Knative CloudEvents for KServe inference payloads" "Internal Component"
        }

        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages TrustyAI service deployments via CRDs" "Internal RHOAI"
        odhModelController = softwareSystem "odh-model-controller" "Configures ModelMesh payloadProcessors routing" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        mariadb = softwareSystem "MariaDB/MySQL" "Relational database for persistent storage" "External"
        minio = softwareSystem "MinIO/S3" "Object storage for inference data" "External"
        knative = softwareSystem "Knative Eventing" "CloudEvent delivery for KServe integration" "External"
        k8sapi = softwareSystem "Kubernetes API" "Cluster API for ConfigMap management" "External"

        # Relationships
        datascientist -> trustyai "Requests fairness metrics, drift detection, and explanations" "REST/HTTP 80/TCP"
        sre -> prometheus "Monitors TrustyAI metrics" "Web UI"

        modelmesh -> trustyai "Sends inference payloads" "HTTP POST /consumer/kserve/v2 80/TCP"
        kserve -> trustyai "Sends inference payloads via Knative" "CloudEvents HTTP 8080/TCP"
        prometheus -> trustyai "Scrapes metrics" "HTTP GET /q/metrics 80/TCP Bearer Token"
        trustyaiOperator -> trustyai "Manages deployment lifecycle" "Kubernetes API"
        odhModelController -> trustyai "Configures payload routing" "Configuration"

        trustyai -> kserve "Connects to model servers for explainability" "gRPC/HTTP2 KServe v2"
        trustyai -> mariadb "Stores inference data" "JDBC MySQL 3306/TCP"
        trustyai -> minio "Stores inference data" "HTTP/HTTPS 443/9000"
        trustyai -> k8sapi "Manages ConfigMaps" "HTTPS 443/TCP SA Token"

        # Container-level relationships
        service -> core "Uses for metric computation and XAI"
        service -> connectors "Uses for model server communication"
        prometheusScheduler -> core "Triggers scheduled metric computation"
        cloudEventConsumer -> service "Delivers KServe inference payloads"
        connectors -> kserve "gRPC ModelInfer RPC" "gRPC/HTTP2"
    }

    views {
        systemContext trustyai "SystemContext" "TrustyAI Explainability in context" {
            include *
            autoLayout
        }

        container trustyai "Containers" "Internal structure of TrustyAI Explainability" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
