graph TD
    subgraph "FMS Guardrails Orchestrator - Auth Model"
        direction TB

        subgraph "Service Identity"
            SA["Stateless Service<br/>(No Kubernetes ServiceAccount RBAC)"]
        end

        subgraph "Authentication Flow"
            direction LR
            ClientAuth["Client sends<br/>X-Forwarded-Access-Token<br/>or Authorization header"]
            HeaderRewrite["Orchestrator rewrites<br/>X-Forwarded-Access-Token<br/>→ Authorization: Bearer"]
            Passthrough["Headers passed through<br/>to downstream services"]
        end

        subgraph "TLS Configuration"
            direction TB
            ServerTLS["Server TLS<br/>--tls-cert-path<br/>--tls-key-path<br/>rustls/ring (non-FIPS)"]
            ClientCA["Client mTLS<br/>--tls-client-ca-cert-path<br/>(optional mutual TLS)"]
            PerServiceTLS["Per-Service Client TLS<br/>config.yaml tls section<br/>(cert/key/CA per downstream)"]
            InsecureMode["⚠ NoVerifier Mode<br/>insecure: true in config<br/>Disables cert verification"]
        end

        subgraph "Downstream Auth Enforcement"
            direction TB
            TGISAuth["TGIS: mm-model-id header"]
            NLPAuth["Caikit NLP: mm-model-id header"]
            DetectorAuth["Detector: detector-id,<br/>x-model-name headers"]
            OpenAIAuth["OpenAI: Header passthrough<br/>(Bearer token)"]
        end

        subgraph "Unauthenticated Endpoints"
            Health["/health - Liveness probe<br/>No auth required"]
            Info["/info - Downstream health<br/>No auth required"]
        end
    end

    ClientAuth --> HeaderRewrite
    HeaderRewrite --> Passthrough
    Passthrough --> TGISAuth
    Passthrough --> NLPAuth
    Passthrough --> DetectorAuth
    Passthrough --> OpenAIAuth

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style ClientAuth fill:#7ed321,stroke:#333
    style HeaderRewrite fill:#f5a623,stroke:#333
    style Passthrough fill:#f5a623,stroke:#333
    style ServerTLS fill:#dae8fc,stroke:#6c8ebf
    style ClientCA fill:#dae8fc,stroke:#6c8ebf
    style PerServiceTLS fill:#dae8fc,stroke:#6c8ebf
    style InsecureMode fill:#f8cecc,stroke:#b85450
    style TGISAuth fill:#d5e8d4,stroke:#82b366
    style NLPAuth fill:#d5e8d4,stroke:#82b366
    style DetectorAuth fill:#d5e8d4,stroke:#82b366
    style OpenAIAuth fill:#d5e8d4,stroke:#82b366
    style Health fill:#e8e8e8,stroke:#333
    style Info fill:#e8e8e8,stroke:#333
