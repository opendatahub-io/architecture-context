%% RBAC Visualization for vllm-gaudi
%% Generated by: Claude Opus 4.6
%% Note: vllm-gaudi defines no RBAC resources itself.
%% RBAC is delegated to the deploying infrastructure (KServe, rhods-operator).

graph TD
    subgraph VllmGaudi["vllm-gaudi Container"]
        Container["vllm-gaudi<br/>UID: 2000, GID: 0<br/>(non-root)"]
    end

    subgraph DeploymentRBAC["Deployment Infrastructure RBAC"]
        direction TB

        subgraph KServeRBAC["KServe RBAC (manages deployment)"]
            KServeSA["ServiceAccount<br/>kserve-controller-manager"]
            KServeCR["ClusterRole<br/>kserve-manager-role"]
            KServeCRB["ClusterRoleBinding<br/>kserve-manager-rolebinding"]

            KServeSA -->|bound via| KServeCRB
            KServeCRB -->|grants| KServeCR
        end

        subgraph OperatorRBAC["RHOAI Operator RBAC"]
            OperatorSA["ServiceAccount<br/>rhods-operator"]
            OperatorCR["ClusterRole<br/>rhods-operator-role"]
            OperatorCRB["ClusterRoleBinding<br/>rhods-operator-binding"]

            OperatorSA -->|bound via| OperatorCRB
            OperatorCRB -->|grants| OperatorCR
        end
    end

    subgraph AuthDelegation["Authentication Delegation"]
        direction TB
        Endpoint["/v1/* endpoints<br/>Methods: POST, GET"]
        AuthMech["Auth Mechanism:<br/>None at container level"]
        Enforcement["Enforcement Point:<br/>KServe gateway /<br/>kube-rbac-proxy"]
        Policy["Policy:<br/>Enforced by serving<br/>infrastructure"]

        Endpoint --> AuthMech
        AuthMech --> Enforcement
        Enforcement --> Policy
    end

    subgraph Secrets["Injected Secrets"]
        ModelSecret["(model-serving-secret)<br/>Type: Opaque<br/>S3/storage credentials<br/>Provisioned by: User/Operator"]
        HFToken["(huggingface-token)<br/>Type: Opaque<br/>HuggingFace API token<br/>Provisioned by: User"]
    end

    KServeCR -->|"deploys & manages"| Container
    OperatorCR -->|"manages runtime lifecycle"| KServeSA
    Secrets -->|"injected at deploy time<br/>by KServe/ModelMesh"| Container

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333
    style KServeCR fill:#f5a623,stroke:#333
    style KServeCRB fill:#f5a623,stroke:#333
    style OperatorSA fill:#7ed321,stroke:#333
    style OperatorCR fill:#f5a623,stroke:#333
    style OperatorCRB fill:#f5a623,stroke:#333
    style ModelSecret fill:#e8e8e8,stroke:#333
    style HFToken fill:#e8e8e8,stroke:#333
    style Endpoint fill:#dae8fc,stroke:#6c8ebf
    style AuthMech fill:#dae8fc,stroke:#6c8ebf
    style Enforcement fill:#dae8fc,stroke:#6c8ebf
    style Policy fill:#dae8fc,stroke:#6c8ebf
