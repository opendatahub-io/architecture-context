graph TD
    subgraph "Container Security Context"
        Container["odh-vllm-gaudi-rhel9<br/><i>Container Image</i>"]
        UID["UID: 2000<br/>GID: 0<br/>(Non-Root, OpenShift compatible)"]
        Base["Base: RHEL 9.6 UBI<br/>SynapseAI 1.24.0"]
    end

    subgraph "RBAC (Managed by KServe - Not by this component)"
        SA["ServiceAccount<br/><i>Defined by InferenceService CR</i><br/>Managed by KServe operator"]
        ISVC["InferenceService CR<br/><i>Created by user/operator</i>"]
    end

    subgraph "Authentication Layers"
        direction TB
        PlatformAuth["Platform Auth Layer<br/>kube-rbac-proxy sidecar<br/>Bearer Token validation"]
        DevModeGate["Dev Mode Gate<br/>VLLM_SERVER_DEV_MODE=1<br/>/v1/models/switch only"]
        NoAppAuth["Application Auth<br/>None (delegated to platform)"]
    end

    subgraph "Secrets"
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace auth<br/>Provisioned by: User/Operator<br/>Auto-Rotate: No"]
        SSLCerts["SSL Certificates<br/>Type: kubernetes.io/tls (optional)<br/>Purpose: API server TLS<br/>Provisioned by: cert-manager/manual"]
    end

    subgraph "Endpoint Security Matrix"
        direction TB
        EP_Inference["/v1/completions<br/>/v1/chat/completions<br/>/v1/embeddings<br/>Auth: Platform ingress"]
        EP_Models["/v1/models<br/>Auth: Platform ingress"]
        EP_Switch["/v1/models/switch<br/>Auth: DEV_MODE gate"]
        EP_Health["/health<br/>Auth: None"]
        EP_Tokenize["/v1/tokenize<br/>Auth: Platform ingress"]
    end

    subgraph "FIPS Status"
        FIPSWarning["FIPS: NOT COMPLIANT<br/>openssl-fips-provider-so REMOVED<br/>Reason: Habana SynapseAI<br/>incompatible with FIPS OpenSSL"]
    end

    ISVC -->|"triggers deployment"| SA
    SA -->|"runs as"| Container
    Container --- UID
    Container --- Base

    PlatformAuth -->|"protects"| EP_Inference
    PlatformAuth -->|"protects"| EP_Models
    PlatformAuth -->|"protects"| EP_Tokenize
    DevModeGate -->|"gates"| EP_Switch
    NoAppAuth -->|"allows"| EP_Health

    Container -.->|"may use"| HFToken
    Container -.->|"may use"| SSLCerts

