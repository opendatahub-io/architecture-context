graph TB
    subgraph ModelMeshPod["ModelMesh Pod"]
        direction TB

        subgraph Sidecar["ModelMesh Sidecar (Java 21)"]
            direction TB
            API["ModelMesh API Server<br/>gRPC :8033"]
            Core["ModelMesh Core<br/>Distributed LRU Cache"]
            Litelinks["Litelinks Service<br/>gRPC/Thrift :8080"]
            PrometheusServer["Prometheus Metrics Server<br/>HTTPS :2112"]
            PreStop["Pre-Stop Hook Server<br/>HTTP :8090"]
            HealthProbe["Health Probe Server<br/>HTTP :8089"]

            API -->|"routes requests"| Core
            Core -->|"inter-pod comm"| Litelinks
            Core -->|"emits metrics"| PrometheusServer
        end

        subgraph Runtime["Model Runtime Container"]
            RuntimeGRPC["ModelRuntime gRPC<br/>:8085/TCP or UDS"]
        end

        Core -->|"loadModel / unloadModel<br/>gRPC (plaintext, localhost)"| RuntimeGRPC
        API -->|"inference pass-through<br/>gRPC (plaintext, localhost)"| RuntimeGRPC
        PreStop -->|"graceful shutdown<br/>coordination"| RuntimeGRPC
    end

    Client["External Client"] -->|"gRPC :8033<br/>TLS + mTLS (optional)"| API
    Client -->|"inference requests<br/>mm-model-id header"| API

    OtherPod["Other ModelMesh Pod"] <-->|"gRPC/Thrift :8080<br/>TLS (optional)"| Litelinks

    etcd["etcd Cluster<br/>:2379"] <-->|"gRPC<br/>TLS (optional)"| Core

    ModelmeshServing["modelmesh-serving<br/>Controller"] -->|"creates/manages<br/>Deployment"| ModelMeshPod

    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTPS :2112"| PrometheusServer

    K8s["Kubernetes API"] -->|"readiness: /ready<br/>liveness: /live"| HealthProbe

    style API fill:#4a90e2,stroke:#333,color:#fff
    style Core fill:#4a90e2,stroke:#333,color:#fff
    style Litelinks fill:#4a90e2,stroke:#333,color:#fff
    style PrometheusServer fill:#4a90e2,stroke:#333,color:#fff
    style PreStop fill:#4a90e2,stroke:#333,color:#fff
    style HealthProbe fill:#4a90e2,stroke:#333,color:#fff
    style RuntimeGRPC fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style OtherPod fill:#9b59b6,stroke:#333,color:#fff
    style etcd fill:#e8e8e8,stroke:#333
    style ModelmeshServing fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8s fill:#e8e8e8,stroke:#333
