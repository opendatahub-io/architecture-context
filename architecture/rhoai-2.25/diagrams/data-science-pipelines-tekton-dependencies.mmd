graph LR
    DSPT["Data Science Pipelines<br/>Tekton"]

    %% External Dependencies (Required)
    DSPT -->|"workflow execution<br/>CRD Watch/Create"| Tekton["Tekton Pipelines<br/>>= 0.41.0"]
    DSPT -->|"metadata storage<br/>3306/TCP MySQL"| MySQL["MySQL 5.7+"]
    DSPT -->|"artifact storage<br/>HTTP/HTTPS"| MinIO["MinIO / S3<br/>Compatible Store"]
    DSPT -->|"container orchestration<br/>443/TCP HTTPS"| K8s["Kubernetes 1.20+"]

    %% Kubernetes API interactions
    DSPT -->|"SAR / TokenReview<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    DSPT -->|"admission webhooks<br/>MutatingWebhookConfig"| K8sAdmission["K8s Admission<br/>Controller"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys & manages<br/>CRD/Controller"| DSPT
    Dashboard["ODH Dashboard"] -->|"UI management<br/>REST API"| DSPT

    %% Optional/Integration Dependencies
    DSPT -->|"run metadata<br/>gRPC"| MLMD["ML Metadata<br/>(MLMD)"]
    DSPT -->|"viewer routing<br/>annotations"| Ambassador["Ambassador"]
    DSPT -.->|"model serving<br/>SeldonDeployment CRD"| Seldon["Seldon Core"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scraping<br/>GET /metrics 8888/TCP"| DSPT

    %% SDK
    PythonSDK["Python SDK<br/>(kfp-tekton)"] -->|"compile & upload<br/>REST API"| DSPT

    %% Tekton Catalog dependencies
    DSPT -->|"loop execution<br/>custom.tekton.dev CRD"| TektonCustom["Tekton Custom Tasks<br/>(PipelineLoop)"]

    %% Styling
    style DSPT fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style Tekton fill:#e74c3c,stroke:#333,color:#fff
    style MySQL fill:#e74c3c,stroke:#333,color:#fff
    style MinIO fill:#e74c3c,stroke:#333,color:#fff
    style K8s fill:#e74c3c,stroke:#333,color:#fff

    %% Kubernetes
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style K8sAdmission fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% Optional/Integration
    style MLMD fill:#f5a623,stroke:#333
    style Ambassador fill:#f5a623,stroke:#333
    style Seldon fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
