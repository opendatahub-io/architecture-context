        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        IstioGW["Istio Ingress Gateway<br/>443/TCP → internal<br/>TLS 1.2+ SIMPLE<br/>Host: {name}.{ns}.{domain}"]
        GatewayAPI["Gateway (HTTPRoute)<br/>443/TCP<br/>TLS 1.2+ SIMPLE<br/>Host: {name}-{ns}.{domain}"]
        LLMGW["Gateway + ext_proc<br/>443/TCP → EPP 9002/TCP gRPC<br/>TLS 1.2+<br/>LLMInferenceService"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Ports: 8081(health), 8443(metrics),<br/>9443(webhooks)<br/>NetworkPolicy: allow all ingress"]
            WebhookSvc["kserve-webhook-server-service<br/>ClusterIP 443→9443<br/>TLS: OpenShift service-ca"]
        end

        subgraph NS_Knative["Namespace: knative-serving"]
            KnativeGW["Knative Local Gateway<br/>80/TCP HTTP<br/>mTLS (mesh)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            Predictor["Model Serving Pod<br/>(InferenceService)<br/>8080/TCP HTTP<br/>mTLS (Istio sidecar)<br/>Init: storage-initializer"]
            LLMPod["LLM Serving Pod<br/>(LLMInferenceService)<br/>SA: {llmisvc}-sa<br/>8000/TCP HTTP<br/>SCC: llminferenceservice-scc<br/>Caps: IPC_LOCK, SYS_RAWIO"]
            EPP["EPP Scheduler<br/>SA: {llmisvc}-epp-sa<br/>9002/TCP gRPC (ext_proc)<br/>9003/TCP gRPC (health)<br/>9090/TCP HTTP (metrics)<br/>TLS: self-signed certs"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
        S3["Cloud Storage<br/>(S3/GCS/Azure)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: IAM / storage-config"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Registry credentials"]
    end

    %% External to Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| IstioGW
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| GatewayAPI
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| LLMGW

    %% Serverless path
    IstioGW -->|"HTTP/80<br/>mTLS (Istio)<br/>VirtualService routing"| KnativeGW
    KnativeGW -->|"HTTP/8080<br/>mTLS (mesh)<br/>Service Identity"| Predictor

    %% RawDeployment path
    GatewayAPI -->|"HTTP/8080<br/>HTTPRoute<br/>mTLS"| Predictor

    %% LLMInferenceService path
    LLMGW -->|"gRPC/9002<br/>TLS (self-signed)<br/>ext_proc"| EPP
    EPP -->|"HTTP/8000<br/>InferencePool query"| LLMPod
    LLMGW -->|"HTTP/8000<br/>Selected endpoint"| LLMPod

    %% Controller egress
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/Secret"| S3

