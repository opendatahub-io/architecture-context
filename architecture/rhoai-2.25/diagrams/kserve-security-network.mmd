graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(Data Scientist / Application)"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["OpenShift Gateway / Istio Ingress<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Gateway: openshift-ai-inference<br/>Host: {isvc}.{ns}.{domain}"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_KServe["Namespace: kserve"]
            ControllerMgr["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Ports: 9443 (webhook), 8080 (metrics), 8081 (probes)<br/>autoMountSAToken: disabled"]
            WebhookSvc["kserve-webhook-server-service<br/>ClusterIP 443→9443<br/>TLS: OpenShift cert injection"]
            CtrlSvc["kserve-controller-manager-service<br/>ClusterIP 8443/TCP"]
            LMController["kserve-localmodel-controller<br/>SA: kserve-localmodel-controller-manager<br/>Ports: 8080, 8081"]
            LMAgent["kserve-localmodelnode-agent<br/>(DaemonSet)<br/>SA: kserve-localmodelnode-agent<br/>Ports: 8080, 8081"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            ModelPod["Model Server Pod<br/>(InferenceService)<br/>Init: storage-initializer<br/>Sidecar: kserve-agent :9081<br/>Container: model-server :8080<br/>Optional: oauth-proxy / kube-rbac-proxy"]
            LLMPod["LLM Worker Pods<br/>(LLMInferenceService)<br/>Managed by: LeaderWorkerSet<br/>SCC: openshift-ai-llminferenceservice-scc<br/>Caps: IPC_LOCK, SYS_RAWIO<br/>TLS: Self-signed"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph PlatformDeps["PLATFORM DEPENDENCIES (Internal)"]
        Knative["Knative Serving<br/>CRD: serving.knative.dev/v1"]
        Istio["Istio Service Mesh<br/>CRD: networking.istio.io"]
        GatewayAPI["Gateway API<br/>CRD: gateway.networking.k8s.io"]
        GatewayInfExt["Gateway API Inference Ext<br/>CRD: inference.networking.x-k8s.io"]
        LWS["LeaderWorkerSet<br/>CRD: leaderworkerset.x-k8s.io"]
        Prometheus["Prometheus Operator<br/>CRD: monitoring.coreos.com"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: GCS SA key"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Azure creds"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF token"]
        HDFS["HDFS<br/>Kerberos/TCP<br/>Auth: krb5 keytab"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress → Pods
    Gateway -->|"HTTP/8080<br/>No encryption<br/>(post-TLS termination)"| ModelPod
    Gateway -->|"HTTP/varies<br/>Self-signed TLS<br/>via InferencePool scheduler"| LLMPod

    %% K8s API ↔ Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>Client Certificate"| WebhookSvc

    %% Controller → K8s API
    ControllerMgr -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LMController -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LMAgent -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Controller → Platform (via K8s API CRDs)
    ControllerMgr -.->|CRD| Knative
    ControllerMgr -.->|CRD| Istio
    ControllerMgr -.->|CRD| GatewayAPI
    ControllerMgr -.->|CRD| GatewayInfExt
    ControllerMgr -.->|CRD| LWS
    ControllerMgr -.->|CRD| Prometheus

    %% Storage downloads
    ModelPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud creds"| S3
    ModelPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud creds"| GCS
    ModelPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud creds"| Azure
    ModelPod -->|"HTTPS/443<br/>TLS 1.2+<br/>HF token"| HF
    ModelPod -->|"Kerberos/TCP<br/>krb5 keytab"| HDFS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef apiserver fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class ControllerMgr,WebhookSvc,CtrlSvc,LMController,LMAgent,ModelPod,LLMPod clusterinternal
    class Knative,Istio,GatewayAPI,GatewayInfExt,LWS,Prometheus platform
    class S3,GCS,Azure,HF,HDFS externalservice
    class K8sAPI apiserver
