graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / OpenShift Route<br/>443/TCP → 80/TCP<br/>TLS 1.2+ termination<br/>Host: {isvc}-{ns}.apps.{cluster}"]
        VirtualService["Istio VirtualService<br/>Host-based routing"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Autoscaling & buffering"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction LR

            subgraph Pod["InferenceService Pod<br/>SA: {isvc-name}-sa"]
                IstioSidecar["Istio Sidecar<br/>(envoy)<br/>mTLS proxy"]
                AgentSidecar["Agent Sidecar<br/>9081/TCP HTTP<br/>Batching & logging"]
                ModelServer["Model Server<br/>8080/TCP HTTP<br/>MLServer/Triton"]
            end

            subgraph InitContainers["Init Containers"]
                StorageInit["storage-initializer<br/>Downloads to /mnt/models"]
            end
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Controller["kserve-controller-manager<br/>Namespace: kserve<br/>SA: kserve-controller-manager"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>Cert: cert-manager"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>AWS IAM / IRSA"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>GCP Service Account"]
        Azure["Azure Blob<br/>blob.core.windows.net<br/>443/TCP HTTPS<br/>Azure credentials"]
        EventSink["Event Sink<br/>{broker-url}<br/>80/443 HTTP/HTTPS<br/>Bearer Token"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token optional| Gateway

    %% Ingress routing
    Gateway -->|Host header routing| VirtualService
    VirtualService -->|HTTP/80<br/>mTLS STRICT<br/>Service Identity| Activator

    %% Service Mesh flows
    Activator -->|HTTP/8080<br/>mTLS<br/>Service Identity| IstioSidecar
    IstioSidecar -->|localhost:8080<br/>HTTP plaintext| AgentSidecar
    AgentSidecar -->|localhost:8080<br/>HTTP plaintext| ModelServer

    %% Storage initialization
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/IRSA| S3
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>GCP SA| GCS
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>Azure creds| Azure
    StorageInit -.->|Shared volume<br/>/mnt/models| ModelServer

    %% Logging
    AgentSidecar -.->|HTTP/HTTPS<br/>80/443<br/>Bearer Token<br/>optional| EventSink

    %% Control plane
    Client -->|kubectl/API<br/>HTTPS/6443<br/>Bearer Token| K8sAPI
    K8sAPI -->|Webhook call<br/>HTTPS/9443<br/>API Server cert| Webhook
    K8sAPI -->|Watch events| Controller
    Controller -->|Create resources<br/>HTTPS/6443<br/>SA Token| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class Client external
    class Gateway,VirtualService ingress
    class Activator,IstioSidecar,AgentSidecar,ModelServer,StorageInit servicemesh
    class K8sAPI,Controller,Webhook controlplane
    class S3,GCS,Azure,EventSink externalservice
