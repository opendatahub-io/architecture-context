graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Frontends["Protocol Frontends"]
            KServeV2["KServe v2 Frontend<br/>(gRPC + REST)"]
            TFSFrontend["TensorFlow Serving Frontend<br/>(gRPC + REST)"]
            OpenAIFrontend["OpenAI/Cohere API Frontend<br/>(REST via MediaPipe)"]
        end

        subgraph AIModules["AI Processing Modules"]
            LLMEngine["LLM Continuous Batching Engine<br/>(OpenVINO GenAI)"]
            EmbeddingsModule["Embeddings Module<br/>(MediaPipe calculator)"]
            RerankModule["Rerank Module<br/>(MediaPipe calculator)"]
            ImageGenModule["Image Generation Module<br/>(MediaPipe calculator)"]
        end

        subgraph PipelineEngine["Pipeline Engine"]
            MediaPipe["MediaPipe Graph Engine"]
            DAGScheduler["DAG Pipeline Scheduler"]
            PythonExec["Python Executor<br/>(PyBind11)"]
        end

        subgraph CoreServices["Core Services"]
            ModelManager["Model Manager<br/>(loading, versioning, hot-reload)"]
            ModelPull["Model Pull Module<br/>(libgit2 + curl)"]
            Metrics["Metrics Module<br/>(Prometheus)"]
            CAPI["libovms_shared.so<br/>(C API)"]
        end

        subgraph Runtime["Inference Runtime"]
            OpenVINO["OpenVINO Runtime 2025.3"]
            Tokenizers["OpenVINO Tokenizers"]
        end
    end

    %% Frontend routing
    KServeV2 -->|inference request| ModelManager
    TFSFrontend -->|prediction request| ModelManager
    OpenAIFrontend -->|chat/embeddings/rerank| MediaPipe

    %% MediaPipe routing to AI modules
    MediaPipe --> LLMEngine
    MediaPipe --> EmbeddingsModule
    MediaPipe --> RerankModule
    MediaPipe --> ImageGenModule
    MediaPipe --> PythonExec

    %% DAG scheduling
    DAGScheduler -->|multi-model pipeline| ModelManager

    %% Model Manager to runtime
    ModelManager -->|execute inference| OpenVINO
    LLMEngine -->|token generation| OpenVINO
    EmbeddingsModule -->|embedding inference| OpenVINO
    RerankModule -->|rerank inference| OpenVINO
    ImageGenModule -->|image generation| OpenVINO
    OpenVINO --> Tokenizers

    %% Model loading
    ModelManager -->|load models| ModelPull

    %% External interactions
    Client["Client<br/>(Data Scientist / Application)"]
    Client -->|"REST rest_port/TCP"| KServeV2
    Client -->|"REST rest_port/TCP"| TFSFrontend
    Client -->|"REST rest_port/TCP<br/>/v3/*/chat/completions"| OpenAIFrontend
    Client -->|"gRPC grpc_port/TCP"| KServeV2
    Client -->|"gRPC grpc_port/TCP"| TFSFrontend

    Prometheus["Prometheus"] -->|"scrape /metrics"| Metrics

    ModelPull -->|"HTTPS/443"| HFHub["HuggingFace Hub"]
    ModelManager -->|"HTTPS/443"| S3["S3 / Azure Blob / GCS"]

    %% Auth sidecars (platform-managed)
    subgraph AuthLayer["Auth Layer (Platform-Managed)"]
        AuthProxy["kube-rbac-proxy / oauth-proxy<br/>8443/TCP → app port<br/>TLS termination"]
    end
    Client -.->|"HTTPS/8443<br/>(in RHOAI deployment)"| AuthProxy
    AuthProxy -.->|"HTTP (plaintext)"| KServeV2

    %% Styling
    style OVMS fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Frontends fill:#d5e8d4,stroke:#82b366
    style AIModules fill:#fff2cc,stroke:#d6b656
    style PipelineEngine fill:#f8cecc,stroke:#b85450
    style CoreServices fill:#dae8fc,stroke:#6c8ebf
    style Runtime fill:#e1d5e7,stroke:#9673a6
    style AuthLayer fill:#f5f5f5,stroke:#999,stroke-dasharray:5 5
    style Client fill:#f9f9f9,stroke:#333
    style Prometheus fill:#f9f9f9,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style AuthProxy fill:#ffe6cc,stroke:#d79b00
