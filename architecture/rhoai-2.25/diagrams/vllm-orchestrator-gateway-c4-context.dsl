/*
 * C4 Context Diagram: vllm-orchestrator-gateway
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/vllm-orchestrator-gateway.md
 */

workspace {
    model {
        client = person "Client Application" "Sends OpenAI-compatible chat completion requests"

        gateway = softwareSystem "vllm-orchestrator-gateway" "Rust HTTP gateway that routes chat completion requests through configurable guardrail detector pipelines" {
            gatewayService = container "Gateway Service" "Routes requests, injects detector configs, handles fallback responses" "Rust / axum 0.7.9"
            config = container "GatewayConfig" "YAML configuration defining routes, detectors, and orchestrator connection" "YAML"
            tlsClient = container "TLS Client Builder" "Builds HTTP/HTTPS client with optional mTLS identity" "reqwest + openssl"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Handles chat completions with content detection via /api/v2/chat/completions-detection" "Internal RHOAI"
        detectors = softwareSystem "Guardrails Detectors" "Content safety detector services (PII, regex-lang, content filters)" "Internal RHOAI"
        vllm = softwareSystem "vLLM" "LLM inference engine for text generation" "Internal RHOAI"

        # Relationships
        client -> gateway "POST /{route}/v1/chat/completions" "HTTP/8090 plaintext"
        gateway -> orchestrator "POST /api/v2/chat/completions-detection" "HTTP or HTTPS/8085, optional mTLS"
        orchestrator -> detectors "Content analysis requests" "HTTP/HTTPS"
        orchestrator -> vllm "LLM inference requests" "HTTP/HTTPS"

        # Internal relationships
        gatewayService -> config "reads route and detector definitions"
        gatewayService -> tlsClient "uses for orchestrator communication"
    }

    views {
        systemContext gateway "SystemContext" {
            include *
            autoLayout
            description "System context showing vllm-orchestrator-gateway in the RHOAI guardrails ecosystem"
        }

        container gateway "Containers" {
            include *
            autoLayout
            description "Internal structure of the vllm-orchestrator-gateway"
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #6baed6
                color #ffffff
            }
            element "Person" {
                background #f5a623
                shape Person
            }
        }
    }
}
