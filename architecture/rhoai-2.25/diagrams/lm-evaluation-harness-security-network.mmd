graph TB
    subgraph Orchestration["ORCHESTRATION (Cluster-Internal)"]
        Operator["trustyai-service-operator<br/>Creates LMEval Jobs"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>ServiceAccount Token"]
    end

    subgraph BatchJob["BATCH JOB (Ephemeral Pod)"]
        direction TB
        Job["lmes-job Pod<br/>User: 65532:65532 (non-root)<br/>Base: UBI 9 / Python 3.11<br/>Arch: x86_64, s390x, ppc64le<br/>No exposed ports"]

        subgraph LocalStorage["LOCAL STORAGE"]
            SQLiteCache["SQLite Response Cache<br/>SHA-256 indexed"]
            PickleCache["Task Cache<br/>dill + pickle"]
            PVC["PVC / Local Filesystem<br/>Models, outputs"]
        end

        Job --- SQLiteCache
        Job --- PickleCache
        Job --- PVC
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress Only - TLS 1.2+)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>Auth: HF_TOKEN (Bearer)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>Auth: AWS IAM (boto3)"]
        WatsonX["IBM WatsonX AI<br/>443/TCP HTTPS<br/>Auth: WATSONX_API_KEY"]
        OpenAI["OpenAI-compatible API<br/>Configurable port HTTPS<br/>Auth: API Key (Bearer)"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>Auth: ANTHROPIC_API_KEY"]
        TextSynth["TextSynth API<br/>443/TCP HTTPS<br/>Auth: TEXTSYNTH_API_SECRET_KEY"]
        WandB["Weights & Biases<br/>wandb.ai<br/>443/TCP HTTPS<br/>Auth: WANDB_API_KEY"]
    end

    %% Flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    K8sAPI -->|"Creates/schedules Pod"| Job

    Job -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HFHub
    Job -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Job -->|"HTTPS/443<br/>TLS 1.2+<br/>WATSONX_API_KEY"| WatsonX
    Job -->|"HTTPS/configurable<br/>TLS 1.2+<br/>API Key Bearer"| OpenAI
    Job -->|"HTTPS/443<br/>TLS 1.2+<br/>ANTHROPIC_API_KEY"| Anthropic
    Job -->|"HTTPS/443<br/>TLS 1.2+<br/>TEXTSYNTH_API_SECRET_KEY"| TextSynth
    Job -.->|"HTTPS/443<br/>TLS 1.2+<br/>WANDB_API_KEY<br/>(optional)"| WandB

    %% Styling
    classDef orchestration fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef batchjob fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef localstorage fill:#f0e6d2,stroke:#d6a756,stroke-width:1px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optionalservice fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5

    class Operator,K8sAPI orchestration
    class Job batchjob
    class SQLiteCache,PickleCache,PVC localstorage
    class HFHub,S3,WatsonX,OpenAI,Anthropic,TextSynth externalservice
    class WandB optionalservice
