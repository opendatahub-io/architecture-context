// C4 Context Diagram for ilab-on-ocp
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/ilab-on-ocp.md

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist" "Creates and runs InstructLab fine-tuning pipelines to customize LLMs"

        // Primary System
        ilabOnOcp = softwareSystem "ilab-on-ocp" "InstructLab LLM fine-tuning pipeline for OpenShift AI - orchestrates SDG, distributed training, and evaluation" {
            pipelineDef = container "Pipeline Definition" "KFP v2 pipeline DAG defining InstructLab workflow stages" "Python / KFP SDK"
            sdgComponent = container "SDG Component" "Generates synthetic training data using Teacher model" "Python / InstructLab SDG"
            trainingComponent = container "Training Component" "Data processing and PyTorchJob launcher for distributed training" "Python / kubeflow-training"
            evalComponent = container "Evaluation Component" "MT-Bench and MMLU model quality evaluation" "Python / InstructLab Eval"
            utilsComponent = container "Utilities" "Model upload (OCI), prerequisites checks, Model Registry registration" "Python / skopeo / olot"
            runtimeImage = container "Runtime Image" "odh-ml-pipelines-runtime-generic container image" "Container Image (UBI9 Python 3.12)"
        }

        // Internal ODH Dependencies
        dsp = softwareSystem "Data Science Pipelines" "KFP/Argo-based pipeline orchestration engine (DSPA)" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform for model serving" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages distributed training jobs (PyTorchJob)" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores and tracks ML model metadata and artifacts" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Web UI for managing Data Science projects and pipelines" "Internal RHOAI"
        gpuOperator = softwareSystem "NVIDIA GPU Operator" "GPU device plugin and resource allocation" "Internal RHOAI"

        // Platform Dependencies
        serviceMesh = softwareSystem "OpenShift Service Mesh v2" "Istio-based service mesh for mTLS and traffic management" "Platform"
        serverless = softwareSystem "OpenShift Serverless" "Knative Serving for serverless inference endpoints" "Platform"
        authorino = softwareSystem "Red Hat Authorino" "Authentication for model serving endpoints" "Platform"

        // External Services
        ociRegistry = softwareSystem "OCI Container Registry" "Stores trained models as OCI ModelCar images (e.g. quay.io)" "External"
        s3Storage = softwareSystem "S3 Object Storage" "Pipeline artifact storage" "External"
        gitRepo = softwareSystem "Git Repository" "Hosts InstructLab taxonomy for SDG" "External"

        // Relationships - User
        dataScientist -> ilabOnOcp "Submits InstructLab pipeline runs"
        dataScientist -> rhoaiDashboard "Manages pipelines via Web UI"

        // Relationships - Internal
        ilabOnOcp -> dsp "Orchestrated by (pipeline execution)" "KFP v2"
        ilabOnOcp -> kserve "Serves Teacher (Mixtral) and Judge (Prometheus) models" "REST/HTTPS/443"
        ilabOnOcp -> trainingOperator "Creates distributed training jobs" "PyTorchJob CRD/HTTPS/443"
        ilabOnOcp -> modelRegistry "Registers trained model artifacts" "REST/HTTPS/443"
        ilabOnOcp -> gpuOperator "GPU resource allocation for training and inference"
        rhoaiDashboard -> ilabOnOcp "Pipeline run creation and monitoring"

        // Relationships - Platform
        kserve -> serviceMesh "Traffic routing and mTLS"
        kserve -> serverless "Serverless autoscaling"
        kserve -> authorino "Endpoint authentication"

        // Relationships - External
        ilabOnOcp -> ociRegistry "Pushes trained model OCI images" "HTTPS/443 Docker auth"
        ilabOnOcp -> s3Storage "Stores pipeline artifacts" "HTTPS/443 AWS credentials"
        ilabOnOcp -> gitRepo "Clones taxonomy repository for SDG" "HTTPS/443 basic-auth/ssh"

        // Container-level relationships
        pipelineDef -> sdgComponent "Stage 2: Synthetic Data Generation"
        pipelineDef -> trainingComponent "Stage 3: Distributed Training"
        pipelineDef -> evalComponent "Stages 4-5: Evaluation"
        pipelineDef -> utilsComponent "Stages 1,6: Prerequisites, Upload"
        sdgComponent -> kserve "POST /v1/chat/completions to Teacher" "HTTPS/443 Bearer Token"
        trainingComponent -> trainingOperator "CREATE PyTorchJob" "HTTPS/443 SA Token"
        evalComponent -> kserve "POST /v1/chat/completions to Judge" "HTTPS/443 Bearer Token"
        utilsComponent -> modelRegistry "Register model metadata" "HTTPS/443 SA Token"
        utilsComponent -> ociRegistry "Push OCI ModelCar" "HTTPS/443 Docker auth"
    }

    views {
        systemContext ilabOnOcp "SystemContext" {
            include *
            autoLayout
        }

        container ilabOnOcp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #f5a623
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
