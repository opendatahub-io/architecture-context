// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/model-registry.md

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist" "Creates and manages ML models, versions, and artifacts"
        mlEngineer = person "ML Engineer" "Deploys and monitors inference services"

        // Model Registry System
        modelRegistry = softwareSystem "Model Registry" "Centralized metadata repository for ML workflows - stores registered models, versions, artifacts, inference services, and experiments" {
            proxy = container "model-registry proxy" "OpenAPI v1alpha3 REST API server for ML metadata CRUD operations" "Go REST API, Port 8080"
            controller = container "model-registry controller" "Watches KServe InferenceService CRs and synchronizes state with Model Registry" "Go Controller (controller-runtime)"
            catalog = container "model-registry catalog" "Read-only catalog API for browsing model sources (HuggingFace, YAML)" "Go REST API, Port 8080"
            storageInitializer = container "mr-storage-initializer" "KServe CSI init-container resolving model-registry:// URIs" "Go CLI"
        }

        // Internal ODH Systems
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for model management" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService CRD" "Internal RHOAI"

        // External Dependencies
        istio = softwareSystem "Istio Service Mesh" "Traffic management, mTLS encryption, and authorization" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster orchestration and CRD management" "External"

        // External Services
        database = softwareSystem "Database" "MySQL 8.3+ or PostgreSQL 13+ for persistent ML metadata storage" "External"
        modelStorage = softwareSystem "Model Storage" "S3/GCS for model artifact storage" "External"

        // User relationships
        dataScientist -> modelRegistry "Registers models, versions, artifacts via REST API"
        mlEngineer -> modelRegistry "Manages inference services and serving environments"

        // Internal container relationships
        proxy -> database "Stores/retrieves ML metadata" "SQL/3306 or 5432, Optional TLS 1.2+"
        controller -> proxy "Syncs InferenceService state" "HTTP/8080"
        controller -> k8sAPI "Watches InferenceService CRs, updates labels" "HTTPS/443"
        storageInitializer -> proxy "Resolves model-registry:// URIs" "HTTP/8080"
        storageInitializer -> modelStorage "Downloads model artifacts" "HTTPS/443"

        // Internal ODH relationships
        odhDashboard -> modelRegistry "Model management UI" "REST API HTTP/8080, Istio mTLS"
        dsPipelines -> modelRegistry "Registers model artifacts and versions" "REST API HTTP/8080, Istio mTLS"
        kserve -> modelRegistry "InferenceService CRD watched by controller" "Kubernetes API"

        // External dependency relationships
        modelRegistry -> istio "mTLS encryption and AuthorizationPolicy" "Sidecar injection"
        modelRegistry -> k8sAPI "Controller watches CRDs, manages resources" "HTTPS/443"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS/8443, Bearer Token"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
