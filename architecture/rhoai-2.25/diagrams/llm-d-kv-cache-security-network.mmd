graph TB
    subgraph External["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN Bearer"]
        S3["S3 Object Store<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        ModelScope["ModelScope (optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph Cluster["CLUSTER-INTERNAL (No Ingress)"]
        direction TB

        subgraph KVCachePod["KV-Cache Manager Pod (StatefulSet)"]
            direction TB

            subgraph MainContainer["kv-cache-manager container"]
                ScoringAPI["Scoring API<br/>8080/TCP HTTP<br/>No Encryption, No Auth"]
                GRPCService["IndexerService gRPC<br/>50051/TCP gRPC<br/>No Encryption, No Auth"]
                ZMQSUB["ZMQ Subscriber<br/>5557/TCP ZMQ<br/>No Encryption, No Auth"]
                Metrics["Prometheus Metrics<br/>8080/TCP HTTP /metrics<br/>No Auth"]
            end

            subgraph Sidecar["uds-tokenizer sidecar"]
                TokenizerUDS["TokenizationService<br/>Unix Domain Socket gRPC<br/>Pod-local only"]
                TokenizerHealth["Health Check<br/>8082/TCP HTTP /healthz<br/>No Auth"]
            end

            MainContainer -->|gRPC via UDS<br/>No Encryption| Sidecar
        end

        subgraph Consumers["CONSUMERS"]
            EPP["llm-d Inference Scheduler<br/>(EPP)<br/>Library embed or HTTP/gRPC"]
        end

        subgraph ModelServers["MODEL SERVER FLEET"]
            vLLMPods["vLLM Pods<br/>ZMQ PUB 5557/TCP<br/>No Encryption, No Auth"]
            SGLangPods["SGLang Pods<br/>ZMQ PUB 5557/TCP<br/>No Encryption, No Auth"]
        end

        subgraph OptionalServices["OPTIONAL INTERNAL SERVICES"]
            Redis["Redis / Valkey<br/>6379/TCP Redis Protocol<br/>Optional TLS<br/>Optional Auth (URL-encoded)"]
            OTEL["OTLP Collector<br/>4317/TCP gRPC<br/>No Encryption, No Auth"]
            PVC["Shared Filesystem (PVC)<br/>POSIX I/O<br/>Filesystem Permissions"]
        end

        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
    end

    %% Consumer flows
    EPP -->|HTTP/8080 or gRPC/50051<br/>No Encryption, No Auth| KVCachePod

    %% Model server flows
    vLLMPods -->|ZMQ PUB/SUB 5557/TCP<br/>No Encryption, No Auth| ZMQSUB
    SGLangPods -->|ZMQ PUB/SUB 5557/TCP<br/>No Encryption, No Auth| ZMQSUB

    %% Prometheus
    Prometheus -->|HTTP/8080<br/>No Auth| Metrics

    %% Optional services
    KVCachePod -.->|Redis/6379<br/>Optional TLS & Auth| Redis
    KVCachePod -.->|gRPC/4317<br/>No Encryption| OTEL
    KVCachePod -.->|POSIX I/O| PVC

    %% Control plane
    KVCachePod -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% External
    Sidecar -->|HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer| HFHub
    Sidecar -.->|HTTPS/443<br/>TLS 1.2+| ModelScope
    KVCachePod -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class HFHub,S3,ModelScope external
    class K8sAPI controlplane
    class EPP consumer
    class vLLMPods,SGLangPods internal
    class ScoringAPI,GRPCService,ZMQSUB,Metrics,TokenizerUDS,TokenizerHealth pod
    class Redis,OTEL,PVC optional
    class Prometheus internal
