graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Application /<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - re-encrypt TLS)"]
        RouteOnline["feast-online Route<br/>443/TCP → 80|443/TCP<br/>TLS re-encrypt"]
        RouteRegistry["feast-registry Route<br/>443/TCP → 80|443/TCP<br/>TLS re-encrypt"]
        RouteOffline["feast-offline Route<br/>443/TCP → 80|443/TCP<br/>TLS re-encrypt"]
        RouteUI["feast-ui Route<br/>443/TCP → 80|443/TCP<br/>TLS re-encrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["feast-operator<br/>SA: feast-operator-controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP (HTTPS)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OnlineServer["Feature Server (online)<br/>SA: feast-{name}<br/>6566/TCP HTTP | 6567/TCP HTTPS<br/>Auth: OIDC/K8s RBAC"]
            RegistryServer["Feature Server (registry)<br/>6570/TCP gRPC | 6571/TCP gRPC+TLS<br/>6572/TCP REST | 6573/TCP REST+TLS"]
            OfflineServer["Feature Server (offline)<br/>8815/TCP HTTP | 8816/TCP HTTPS"]
            UIServer["Feature Server (UI)<br/>8888/TCP HTTP | 8443/TCP HTTPS"]
            CronJob["CronJob Pod<br/>SA: feast-{name}<br/>Image: origin-cli:4.17"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Optional password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Username/password"]
        DynamoDB["AWS DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP credentials"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Username/password"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS"]
        TransformSvc["Transformation Service<br/>gRPC (configurable port)<br/>⚠ INSECURE (no TLS, no auth)"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA Token"]
        Prometheus["Prometheus<br/>Scrape: 8443/TCP HTTPS"]
        ContainerReg["Container Registry<br/>443/TCP HTTPS<br/>Pull secret"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>OIDC/K8s RBAC"| RouteOnline
    Client -->|"HTTPS/443"| RouteRegistry
    Client -->|"HTTPS/443"| RouteOffline
    Client -->|"HTTPS/443"| RouteUI

    %% Ingress → Services
    RouteOnline -->|"HTTP(S)<br/>re-encrypt"| OnlineServer
    RouteRegistry -->|"HTTP(S)<br/>re-encrypt"| RegistryServer
    RouteOffline -->|"HTTP(S)<br/>re-encrypt"| OfflineServer
    RouteUI -->|"HTTP(S)<br/>re-encrypt"| UIServer

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS<br/>SA Token"| K8sAPI

    %% CronJob → Feature Server
    CronJob -->|"kubectl exec<br/>pods/exec<br/>SA Token"| OnlineServer

    %% Feature Server → External Stores
    OnlineServer -->|"TCP/6379<br/>Optional TLS<br/>Password"| Redis
    OnlineServer -->|"TCP/5432<br/>Optional TLS<br/>User/Pass"| PostgreSQL
    OnlineServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| DynamoDB
    RegistryServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RegistryServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| GCS
    OfflineServer -->|"TCP/5432<br/>Optional TLS"| PostgreSQL
    OfflineServer -->|"HTTPS/443<br/>TLS 1.2+"| Snowflake

    %% Auth
    OnlineServer -->|"HTTPS/443<br/>Token validation"| OIDC

    %% Transformation (insecure)
    OnlineServer -->|"gRPC<br/>⚠ INSECURE"| TransformSvc

    %% Platform
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>SA Token"| Operator
    Operator -->|"HTTPS/443<br/>Pull secret"| ContainerReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class RouteOnline,RouteRegistry,RouteOffline,RouteUI ingress
    class Operator,OnlineServer,RegistryServer,OfflineServer,UIServer,CronJob internal
    class Redis,PostgreSQL,DynamoDB,S3,GCS,Snowflake,OIDC externalservice
    class K8sAPI,Prometheus,ContainerReg platform
    class TransformSvc warning
