        ExtDB["External Databases<br/>(PostgreSQL, Redis, etc.)<br/>Various ports<br/>TLS configurable<br/>Secrets-based auth"]
        ObjStore["S3/GCS Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>TLS"| Route
    Route -->|"HTTP/8888 or HTTPS/8443<br/>Reencrypt/Edge"| UIServer

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Internal flows
    MLApp -->|"HTTP/80 or HTTPS/443<br/>None / K8s RBAC / OIDC"| OnlineStore
    OnlineStore -->|"gRPC/80 or gRPC+TLS/443"| Registry
    CronJob -->|"kubectl exec<br/>SA CronJob Role"| OnlineStore

    %% Egress flows
    OnlineStore -.->|"Various ports<br/>TLS configurable<br/>Secrets auth"| ExtDB
    OfflineStore -.->|"Various ports<br/>TLS configurable<br/>Secrets auth"| ExtDB
    Registry -.->|"HTTPS/443<br/>TLS 1.2+"| ObjStore
    FeastDeploy -.->|"HTTPS/443<br/>TLS 1.2+"| GitRepo

