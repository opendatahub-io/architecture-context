graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Application /<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        RouteOnline["OpenShift Route - Online<br/>(name)-online-(ns).apps.(cluster)<br/>443/TCP → 80/443/TCP<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteOffline["OpenShift Route - Offline<br/>(name)-offline-(ns).apps.(cluster)<br/>443/TCP → 80/443/TCP<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteRegistry["OpenShift Route - Registry<br/>(name)-registry-(ns).apps.(cluster)<br/>443/TCP → 80/443/TCP<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteUI["OpenShift Route - UI<br/>(name)-ui-(ns).apps.(cluster)<br/>443/TCP → 80/443/TCP<br/>TLS 1.2+ Edge/Re-encrypt"]
    end

    subgraph AppPods["APPLICATION PODS (User Namespace)"]
        direction TB

        subgraph OnlinePod["Online Store Pod"]
            OnlineStore["Online Feature Store<br/>SA: (name)-online<br/>Image: odh-feature-server-rhel9<br/>6566/6567 TCP HTTP/HTTPS"]
        end

        subgraph OfflinePod["Offline Store Pod"]
            OfflineStore["Offline Feature Store<br/>SA: (name)-offline<br/>Image: odh-feature-server-rhel9<br/>8815/8816 TCP HTTP/HTTPS"]
        end

        subgraph RegistryPod["Registry Pod"]
            Registry["Registry Server<br/>SA: (name)-registry<br/>Image: odh-feature-server-rhel9<br/>6570/6571 TCP gRPC/REST"]
        end

        subgraph UIPod["UI Pod"]
            UI["UI Server<br/>SA: (name)-ui<br/>Image: odh-feature-server-rhel9<br/>8888/8443 TCP HTTP/HTTPS"]
        end

        subgraph CronPod["Materialization CronJob"]
            CronJob["Materialization Job<br/>SA: (name)-materialization<br/>Image: origin-cli:4.17"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        Operator["Feast Operator<br/>SA: feast-operator-controller-manager<br/>Image: odh-feast-operator-rhel9"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token Auth"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        direction TB
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Username/Password"]
        Redis["Redis<br/>6379/TCP<br/>TLS 1.2+ (optional)<br/>Password"]
        S3["S3/GCS/Azure Blob<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM/Service Account"]
        Snowflake["Snowflake<br/>443/TCP HTTPS TLS1.2+<br/>OAuth/Key Pair"]
        Git["Git Repository<br/>443/TCP HTTPS TLS1.2+<br/>Token/SSH Key"]
        OIDC["OIDC Provider<br/>OpenShift OAuth<br/>443/TCP HTTPS TLS1.2+"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>Service Account Token"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>None or OIDC Bearer"| RouteOnline
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>None or OIDC Bearer"| RouteOffline
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>None or OIDC Bearer"| RouteRegistry
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>None or OIDC Bearer"| RouteUI

    %% Ingress to Application
    RouteOnline -->|"HTTP/HTTPS<br/>80/443 TCP<br/>TLS 1.2+ (optional)<br/>OIDC or RBAC"| OnlineStore
    RouteOffline -->|"HTTP/HTTPS<br/>80/443 TCP<br/>TLS 1.2+ (optional)<br/>OIDC or RBAC"| OfflineStore
    RouteRegistry -->|"HTTP/HTTPS gRPC<br/>80/443 TCP<br/>TLS 1.2+ (optional)<br/>OIDC or RBAC"| Registry
    RouteUI -->|"HTTP/HTTPS<br/>80/443 TCP<br/>TLS 1.2+ (optional)<br/>OIDC or RBAC"| UI

    %% Application to Storage
    OnlineStore -->|"Redis or PostgreSQL<br/>6379 or 5432 TCP<br/>TLS 1.2+ (optional)<br/>Password or Certificate"| Redis
    OnlineStore -->|"Redis or PostgreSQL<br/>6379 or 5432 TCP<br/>TLS 1.2+ (optional)<br/>Password or Certificate"| PostgreSQL
    OnlineStore -->|"gRPC or REST<br/>80/443 TCP<br/>TLS 1.2+ (optional)"| Registry

    OfflineStore -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM or Service Account"| S3
    OfflineStore -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth or Key Pair"| Snowflake
    OfflineStore -->|"PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)"| PostgreSQL
    OfflineStore -->|"gRPC or REST<br/>80/443 TCP<br/>TLS 1.2+ (optional)"| Registry

    Registry -->|"PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)"| PostgreSQL
    Registry -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM or Service Account"| S3

    UI -->|"gRPC or REST<br/>80/443 TCP<br/>TLS 1.2+ (optional)"| Registry

    CronJob -->|"HTTP or HTTPS<br/>80/443 TCP<br/>Service Account Token"| OnlineStore
    CronJob -->|"HTTP or HTTPS<br/>80/443 TCP<br/>Service Account Token"| OfflineStore

    %% Operator connections
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+"| Git

    %% Authentication
    OnlineStore -.->|"OAuth 2.0<br/>HTTPS/443<br/>TLS 1.2+"| OIDC
    OfflineStore -.->|"OAuth 2.0<br/>HTTPS/443<br/>TLS 1.2+"| OIDC
    Registry -.->|"OAuth 2.0<br/>HTTPS/443<br/>TLS 1.2+"| OIDC
    UI -.->|"OAuth 2.0<br/>HTTPS/443<br/>TLS 1.2+"| OIDC

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| MetricsSvc
    MetricsSvc -->|exposes| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef appPods fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class OnlineStore,OfflineStore,Registry,UI,CronJob appPods
    class Operator,MetricsSvc operator
    class PostgreSQL,Redis,S3,Snowflake,Git,OIDC,K8sAPI,Prometheus externalService
