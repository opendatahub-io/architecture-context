            OfflineStore["Offline Store Server<br/>Service: feast-{name}-offline<br/>80→8815/TCP gRPC<br/>443→8816/TCP gRPC+TLS<br/>Auth: None / K8s RBAC / OIDC"]
            Registry["Registry Server<br/>Service: feast-{name}-registry<br/>gRPC 80→6570 / 443→6571<br/>REST 80→6572 / 443→6573<br/>Auth: None / K8s RBAC / OIDC"]
