graph LR
    Operator["llama-stack-k8s-operator<br/>(Llama Stack K8s Operator)"]

    %% External Library Dependencies
    Operator -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.17.2"]
    Operator -->|"manifest rendering"| Kustomize["kustomize/api<br/>v0.18.0"]
    Operator -->|"API types"| K8sAPI["k8s.io/api<br/>v0.29.2"]
    Operator -->|"cluster client"| ClientGo["k8s.io/client-go<br/>v0.29.2"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlay"| Operator
    Operator -->|"watches CA bundle"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    Operator -->|"resolves images from"| DistImages["Llama Stack<br/>Distribution Images<br/>(distributions.json /<br/>RELATED_IMAGE_RH_DISTRIBUTION)"]

    %% Runtime Dependencies
    Operator -->|"CRUD operations<br/>HTTPS/443"| K8sAPIServer["Kubernetes<br/>API Server"]
    Operator -->|"health polling<br/>HTTP/8321"| LlamaServer["Llama Stack<br/>Distribution Server"]

    %% Integration Points (incoming)
    Prometheus["Prometheus /<br/>ServiceMonitor"] -->|"scrapes metrics<br/>HTTPS/8443"| Operator

    %% OpenShift Integration
    Operator -->|"SCC binding<br/>(anyuid)"| OpenShiftSCC["OpenShift SCC<br/>(security.openshift.io)"]

    %% ConfigMap Integration
    Operator -->|"watches for changes"| UserConfig["User ConfigMaps<br/>(user-config, CA bundle)"]
    Operator -->|"reads feature flags"| OpConfig["llama-stack-operator-config<br/>ConfigMap"]

