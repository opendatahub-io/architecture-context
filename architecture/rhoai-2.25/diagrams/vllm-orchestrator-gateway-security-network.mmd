graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph GatewayZone["GATEWAY SERVICE (Internal)"]
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>0.0.0.0:8090/TCP<br/>HTTP (plaintext)<br/>No local auth enforcement"]

        subgraph Config["Configuration Sources"]
            ConfigFile["YAML Config<br/>(GATEWAY_CONFIG env)<br/>Routes + Detectors"]
        end

        subgraph TLS["TLS Certificates (Volume Mounts)"]
            TLSCert["/etc/tls/private/tls.crt<br/>Client cert (x509)"]
            TLSKey["/etc/tls/private/tls.key<br/>Private key"]
            CACert["/etc/tls/ca/service-ca.crt<br/>CA cert (OpenShift service-ca)"]
        end
    end

    subgraph Backend["BACKEND SERVICES (Internal Platform)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP (configurable)<br/>HTTP or HTTPS"]
        Detectors["Guardrails Detectors<br/>(e.g., regex-detector)<br/>Content filtering"]
        LLM["vLLM / LLM Server<br/>Model serving backend"]
    end

    %% External → Gateway
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header<br/>(passthrough)"| Gateway

    %% Config → Gateway
    ConfigFile -.->|"route definitions<br/>detector mappings"| Gateway
    TLSCert -.->|"client identity"| Gateway
    TLSKey -.->|"private key"| Gateway
    CACert -.->|"CA validation"| Gateway

    %% Gateway → Orchestrator
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>(native-tls/OpenSSL)<br/>PEM→PKCS#12<br/>Fwd: Authorization +<br/>X-Forwarded-*"| Orchestrator

    %% Orchestrator → Backend
    Orchestrator -->|"detector invocation"| Detectors
    Orchestrator -->|"inference request"| LLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tls fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class Gateway gateway
    class ConfigFile config
    class TLSCert,TLSKey,CACert tls
    class Orchestrator,Detectors,LLM backend
