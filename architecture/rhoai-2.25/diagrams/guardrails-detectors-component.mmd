graph TB
    subgraph "Guardrails Detectors"
        subgraph CommonLib["Common Library (detectors/common/)"]
            BaseAPI["DetectorBaseAPI<br/>FastAPI Base Class"]
            Schemas["Pydantic Schemas<br/>Request/Response"]
            Metrics["Prometheus<br/>Instrumentator"]
            HealthCheck["Health Check<br/>Endpoint"]
        end

        subgraph BuiltIn["Built-In Detector<br/>Port: 8080/TCP"]
            BuiltInApp["FastAPI App<br/>(uvicorn)"]
            RegexRegistry["RegexDetectorRegistry<br/>PII Detection"]
            FileTypeRegistry["FileTypeDetectorRegistry<br/>File Validation"]
            BuiltInApp --> RegexRegistry
            BuiltInApp --> FileTypeRegistry
        end

        subgraph HF["HuggingFace Detector<br/>Port: 8000/TCP"]
            HFApp["FastAPI App<br/>(uvicorn)"]
            SeqClassifier["AutoModelForSequenceClassification<br/>HAP Detection"]
            GraniteLM["GraniteForCausalLM<br/>Granite Guardian"]
            HFApp --> SeqClassifier
            HFApp --> GraniteLM
        end

        subgraph LLMJudge["LLM Judge Detector<br/>Port: 8000/TCP"]
            JudgeApp["FastAPI App<br/>(uvicorn)"]
            VLLMJudgeLib["vllm_judge Library<br/>Metrics Engine"]
            JudgeApp --> VLLMJudgeLib
        end

        BuiltInApp -.->|inherits| BaseAPI
        HFApp -.->|inherits| BaseAPI
        JudgeApp -.->|inherits| BaseAPI
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP, Istio mTLS| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP, Istio mTLS| JudgeApp

    KServe["KServe Platform"] -->|deploys as<br/>InferenceService| HF
    KServe -->|deploys as<br/>InferenceService| LLMJudge

    StorageInit["KServe Storage<br/>Initializer"] -->|downloads model| S3["S3/MinIO<br/>9000/TCP"]
    StorageInit -->|mounts to /mnt/models| HFApp

    VLLMJudgeLib -->|HTTP 8080/TCP<br/>OpenAI API| VLLMServer["vLLM Server"]

    Prometheus["Prometheus"] -->|scrapes /metrics| BuiltInApp
    Prometheus -->|scrapes /metrics| HFApp
    Prometheus -->|scrapes /metrics| JudgeApp

    style BuiltIn fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style HF fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style LLMJudge fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style CommonLib fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5
    style Orchestrator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style KServe fill:#e8e8e8,stroke:#999
    style S3 fill:#f5a623,stroke:#333
    style VLLMServer fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#999
    style StorageInit fill:#e8e8e8,stroke:#999
