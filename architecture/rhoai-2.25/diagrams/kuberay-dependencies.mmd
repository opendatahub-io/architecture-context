graph LR
    KubeRay[KubeRay Operator]

    %% External Dependencies - Required
    KubeRay -->|"required<br/>container orchestration"| K8s[Kubernetes 1.21+]

    %% External Dependencies - Optional
    KubeRay -.->|"optional<br/>webhook TLS certs"| CertManager[cert-manager 1.0+]
    KubeRay -.->|"optional<br/>metrics collection"| Prometheus[Prometheus 2.x]
    KubeRay -.->|"optional<br/>metrics viz"| Grafana[Grafana 7.x+]
    KubeRay -.->|"optional<br/>GCS fault tolerance"| Redis[External Redis 6.x+]
    KubeRay -.->|"optional<br/>gang scheduling"| Volcano[Volcano 1.x]
    KubeRay -.->|"optional<br/>batch scheduling"| YuniKorn[YuniKorn 1.x]
    KubeRay -.->|"optional<br/>job queuing"| Kueue[Kueue 0.x]

    %% Internal RHOAI Dependencies
    KubeRay -->|"creates Routes<br/>external access"| OpenShift[OpenShift API]
    KubeRay -->|"Security Context<br/>Constraints"| OpenShiftSCC[OpenShift SCC]
    KubeRay -.->|"optional<br/>UI integration"| ODHDashboard[ODH Dashboard]

    %% Integration Points (upstream consumers)
    DataPipelines[Data Science Pipelines] -.->|"submits RayJobs<br/>distributed training"| KubeRay
    Notebooks[Jupyter Notebooks] -.->|"creates RayClusters<br/>interactive compute"| KubeRay
    Workbenches[RHOAI Workbenches] -.->|"uses Ray client<br/>remote execution"| KubeRay

    %% Ray Cluster Runtime Dependencies
    subgraph "Ray Cluster Runtime"
        RayCluster[Ray Cluster Pods]
        RayCluster -->|"pulls images"| Registry[Container Registry]
        RayCluster -->|"downloads packages"| PyPI[Ray Package Index]
        RayCluster -.->|"fetches code/data"| Git[Git/S3/GCS]
        RayCluster -.->|"stores models"| S3[S3 Storage]
    end

    KubeRay -->|"creates & manages"| RayCluster

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (required)
    style K8s fill:#326ce5,stroke:#333,color:#fff

    %% External dependencies (optional)
    style CertManager fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style Grafana fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333,color:#fff
    style YuniKorn fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style OpenShift fill:#7ed321,stroke:#333,color:#000
    style OpenShiftSCC fill:#7ed321,stroke:#333,color:#000
    style ODHDashboard fill:#7ed321,stroke:#333,color:#000
    style DataPipelines fill:#7ed321,stroke:#333,color:#000
    style Notebooks fill:#7ed321,stroke:#333,color:#000
