graph TD
    subgraph "Component Security Model"
        MRA["modelmesh-runtime-adapter<br/>(Sidecar Container)<br/>No K8s API access"]
    end

    subgraph "Access Control: Pod-Internal (No Auth)"
        Puller["Puller gRPC :8084<br/>Auth: None<br/>Enforcement: Pod network isolation"]
        Adapter["Adapter gRPC :8085<br/>Auth: None<br/>Enforcement: Pod network isolation"]
    end

    subgraph "Access Control: External Storage"
        S3Auth["S3 Storage Access<br/>Auth: Access Key ID +<br/>Secret Access Key<br/>Enforcement: S3 endpoint"]
        GCSAuth["GCS Storage Access<br/>Auth: Service Account JSON /<br/>OAuth2<br/>Enforcement: GCS API"]
        AzureAuth["Azure Storage Access<br/>Auth: Azure AD /<br/>Managed Identity / SAS Token<br/>Enforcement: Azure Blob API"]
    end

    subgraph "Secrets"
        StorageConfig["storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned by: User / Controller<br/>Auto-Rotate: No"]
    end

    subgraph "FIPS Compliance"
        FIPS["GOEXPERIMENT=strictfipsruntime<br/>-tags strictfipsruntime<br/>FIPS-compliant crypto"]
    end

    subgraph "No RBAC Defined"
        NoClusterRole["No ClusterRoles"]
        NoRoleBindings["No RoleBindings"]
        NoServiceAccount["No dedicated ServiceAccount<br/>(uses Pod SA from modelmesh-serving)"]
    end

    MRA -->|"localhost only"| Puller
    MRA -->|"localhost only"| Adapter
    MRA -->|"credentials from"| StorageConfig
    StorageConfig -->|"S3 keys"| S3Auth
    StorageConfig -->|"GCS SA JSON"| GCSAuth
    StorageConfig -->|"Azure creds"| AzureAuth
    MRA -->|"built with"| FIPS

    style MRA fill:#4a90e2,stroke:#333,color:#fff
    style Puller fill:#d5e8d4,stroke:#82b366
    style Adapter fill:#d5e8d4,stroke:#82b366
    style S3Auth fill:#fff2cc,stroke:#d6b656
    style GCSAuth fill:#fff2cc,stroke:#d6b656
    style AzureAuth fill:#fff2cc,stroke:#d6b656
    style StorageConfig fill:#f8cecc,stroke:#b85450
    style FIPS fill:#e1d5e7,stroke:#9673a6
    style NoClusterRole fill:#f5f5f5,stroke:#ccc
    style NoRoleBindings fill:#f5f5f5,stroke:#ccc
    style NoServiceAccount fill:#f5f5f5,stroke:#ccc
