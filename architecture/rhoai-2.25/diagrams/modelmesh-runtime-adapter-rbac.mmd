graph TD
    subgraph "ModelMesh Runtime Adapter - RBAC"
        direction TB

        Note["This component has NO direct RBAC.<br/>It runs as a sidecar container and does<br/>not interact with the Kubernetes API."]
    end

    subgraph "Pod-Level RBAC (managed by modelmesh-controller)"
        direction TB

        SA["Pod ServiceAccount<br/>(managed by modelmesh-controller)"]
        SecretAccess["Secret Access"]
        PVCAccess["PVC Access"]
    end

    subgraph "Secrets Consumed (provisioned by user / controller)"
        direction TB

        S3Secret["S3 Credentials<br/>Type: Opaque<br/>Keys: access_key_id,<br/>secret_access_key<br/>Auto-rotate: No"]
        GCSSecret["GCS Credentials<br/>Type: Opaque<br/>Keys: private_key,<br/>client_email<br/>Auto-rotate: No"]
        AzureSecret["Azure Credentials<br/>Type: Opaque<br/>Keys: connection_string<br/>or client_id/secret/tenant<br/>Auto-rotate: No"]
        HTTPSecret["HTTP Credentials<br/>Type: Opaque<br/>Keys: headers, certificate,<br/>client_certificate, client_key<br/>Auto-rotate: No"]
    end

    subgraph "Authentication at Endpoints"
        direction TB

        AdapterEndpoint["mmesh.ModelRuntime<br/>8085/TCP gRPC<br/>Auth: None<br/>(localhost trust boundary)"]
    end

    SA -->|"reads"| SecretAccess
    SA -->|"mounts"| PVCAccess
    SecretAccess -->|"provides credentials"| S3Secret
    SecretAccess -->|"provides credentials"| GCSSecret
    SecretAccess -->|"provides credentials"| AzureSecret
    SecretAccess -->|"provides credentials"| HTTPSecret

    %% Styling
    style Note fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style SecretAccess fill:#dae8fc,stroke:#6c8ebf
    style PVCAccess fill:#dae8fc,stroke:#6c8ebf
    style S3Secret fill:#f8cecc,stroke:#b85450
    style GCSSecret fill:#f8cecc,stroke:#b85450
    style AzureSecret fill:#f8cecc,stroke:#b85450
    style HTTPSecret fill:#f8cecc,stroke:#b85450
    style AdapterEndpoint fill:#d5e8d4,stroke:#82b366
