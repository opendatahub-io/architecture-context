%% TrustyAI Explainability - Security Network Diagram
%% Generated by: Claude Opus 4.6
graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Dashboard"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route: trustyai<br/>80/TCP → 8080/TCP<br/>TLS: Operator-managed<br/>Auth: Sidecar (oauth-proxy / kube-rbac-proxy)"]
    end

    subgraph Service["SERVICE (ClusterIP - Internal)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS)<br/>Volume: /inputs (1Gi PVC RWO)"]
        end
    end

    subgraph InternalIntegrations["INTERNAL INTEGRATIONS"]
        ModelMesh["ModelMesh Serving<br/>HTTP callback"]
        KServeKnative["KServe via Knative<br/>CloudEvents"]
        Prometheus["Prometheus<br/>Metrics scrape"]
    end

    subgraph EgressModelServers["EGRESS - Model Servers"]
        ModelServers["KServe/ModelMesh<br/>Model Servers<br/>gRPC/HTTP2<br/>plaintext"]
    end

    subgraph EgressDataStores["EGRESS - Data Stores"]
        MariaDB["MariaDB/MySQL<br/>3306/TCP<br/>MySQL protocol<br/>plaintext<br/>Username/Password"]
        MinIO["MinIO/S3<br/>443 or 9000/TCP<br/>HTTP/HTTPS<br/>TLS configurable<br/>Access Key/Secret Key"]
    end

    subgraph EgressK8s["EGRESS - Kubernetes"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
    end

    %% Inbound flows
    Client -->|"HTTP/80<br/>No TLS (base)<br/>Auth: Sidecar-injected"| Route
    Route -->|"HTTP/8080<br/>No encryption (internal)"| TrustyAI
    ModelMesh -->|"HTTP/80<br/>POST /consumer/kserve/v2<br/>No Auth"| TrustyAI
    KServeKnative -->|"HTTP/8080<br/>CloudEvents<br/>No Auth"| TrustyAI
    Prometheus -->|"HTTP/80<br/>GET /q/metrics<br/>Bearer Token (SA)"| TrustyAI

    %% Egress flows
    TrustyAI -->|"gRPC/Variable<br/>plaintext<br/>No Auth"| ModelServers
    TrustyAI -->|"MySQL/3306<br/>plaintext<br/>Username/Password"| MariaDB
    TrustyAI -->|"HTTP-HTTPS/443-9000<br/>TLS configurable<br/>Access Key/Secret"| MinIO
    TrustyAI -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egressDanger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI service
    class ModelMesh,KServeKnative,Prometheus internal
    class ModelServers egressDanger
    class MariaDB,MinIO egress
    class K8sAPI egress
