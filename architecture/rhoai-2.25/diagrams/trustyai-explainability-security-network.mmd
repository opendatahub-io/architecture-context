graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client / ODH Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route: trustyai<br/>80/TCP → 8080/TCP<br/>TLS: None on Route"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph AuthProxy["Auth Proxy (injected by Operator)"]
            Sidecar["kube-rbac-proxy / oauth-proxy<br/>Enforces AuthN/AuthZ<br/>Injected by TrustyAI Operator"]
        end

        subgraph TrustyAIPod["TrustyAI Service Pod"]
            direction TB
            Service["TrustyAI Explainability Service<br/>SA: trustyai-serviceaccount<br/>Image: registry.redhat.io/rhods/<br/>odh-trustyai-service-rhel8<br/>Quarkus 3.8.5 / UBI9 JDK17"]
            Port8080["8080/TCP HTTP<br/>(REST API, health, metrics)"]
            Port4443["4443/TCP HTTPS<br/>(TLS: /etc/tls/internal/*)"]
        end

        subgraph ModelServing["Model Serving (In-Cluster)"]
            KServeModel["KServe / ModelMesh<br/>Model Endpoints<br/>gRPC/HTTP2 plaintext"]
        end

        subgraph InboundPayloads["Inference Payload Sources"]
            ModelMesh["ModelMesh Serving<br/>POST /consumer/kserve/v2<br/>8080/TCP HTTP"]
            KServeIS["KServe InferenceService<br/>CloudEvents (Knative)<br/>8080/TCP HTTP"]
        end

        subgraph Monitoring["Monitoring"]
            Prometheus["Prometheus ServiceMonitor<br/>GET /q/metrics<br/>8080/TCP HTTP<br/>Bearer Token (SA)<br/>Scrape: 4s"]
        end
    end

    subgraph StorageBackends["STORAGE BACKENDS (Configurable)"]
        direction LR
        PVC["PVC Volume<br/>/inputs mount<br/>Filesystem I/O<br/>No auth"]
        MinIO["MinIO<br/>S3-compatible API<br/>HTTP/HTTPS configurable<br/>Access Key + Secret Key"]
        MariaDB["MariaDB/MySQL<br/>JDBC configurable<br/>Username + Password"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS (Router)<br/>Auth: kube-rbac-proxy"| Route
    Route -->|"HTTP/8080<br/>No encryption<br/>Auth: Sidecar enforced"| Sidecar
    Sidecar -->|"HTTP/8080 or HTTPS/4443<br/>TLS on 4443<br/>Auth: None (app level)"| Service

    %% Inbound payload flows
    ModelMesh -->|"HTTP/8080<br/>No encryption<br/>No auth (in-cluster)"| Service
    KServeIS -->|"HTTP/8080 CloudEvents<br/>No encryption<br/>No auth (in-cluster)"| Service

    %% Outbound flows
    Service -->|"gRPC/HTTP2<br/>Plaintext (in-cluster)<br/>No auth"| KServeModel

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>Bearer Token (SA)<br/>No encryption"| Service

    %% Storage flows
    Service -->|"Filesystem I/O"| PVC
    Service -->|"S3 API<br/>Access Key auth"| MinIO
    Service -->|"JDBC<br/>Username/Password"| MariaDB

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef modelserving fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class Client external
    class Route ingress
    class Sidecar authproxy
    class Service,Port8080,Port4443 service
    class PVC,MinIO,MariaDB storage
    class Prometheus monitoring
    class KServeModel,ModelMesh,KServeIS modelserving
