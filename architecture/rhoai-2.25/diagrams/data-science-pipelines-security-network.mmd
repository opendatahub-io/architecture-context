graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist / Client"]
        Dashboard["ODH Dashboard"]
    end

    subgraph Ingress["INGRESS (Route/HTTPRoute — managed by RHOAI Operator)"]
        Route["OpenShift Route<br/>443/TCP → 8888/TCP<br/>TLS termination"]
    end

    subgraph DSPNamespace["DSP NAMESPACE (In-Cluster)"]
        direction TB

        APIServer["API Server<br/>Service: ml-pipeline (ClusterIP)<br/>8888/TCP HTTP REST<br/>8887/TCP gRPC<br/>8443/TCP HTTPS Webhook<br/>SA: ml-pipeline<br/>Auth: Bearer Token → TokenReview + SAR"]

        CacheServer["Cache Server<br/>Service: cache-server (ClusterIP)<br/>443/TCP → 8443/TCP HTTPS<br/>Auth: TLS client cert<br/>Secret: webhook-server-tls"]

        PersistenceAgent["Persistence Agent<br/>SA: ml-pipeline-persistenceagent<br/>(outbound only)"]

        SWFController["SWF Controller<br/>SA: ml-pipeline-scheduledworkflow<br/>(outbound only)"]

        FrontendUI["Frontend UI<br/>Service: ml-pipeline-ui (ClusterIP)<br/>80/TCP → 3000/TCP HTTP<br/>Auth: None"]

        VizServer["Visualization Server<br/>Service: ml-pipeline-visualizationserver<br/>8888/TCP HTTP<br/>Auth: None"]
    end

    subgraph ArgoPods["ARGO WORKFLOW PODS (Pipeline Namespace)"]
        Driver["Driver (init container)<br/>Image: odh-ml-pipelines-driver<br/>(outbound only)"]
        Launcher["Launcher (main wrapper)<br/>Image: odh-ml-pipelines-launcher<br/>FIPS dual-binary<br/>(outbound only)"]
    end

    subgraph DataTier["DATA TIER (In-Cluster)"]
        MySQL["MySQL / PostgreSQL<br/>3306/5432 TCP<br/>No encryption (in-cluster)<br/>Auth: Username/Password"]
        MinIO["MinIO<br/>9000/TCP HTTP(S)<br/>Optional TLS<br/>Auth: Access Key / Secret Key"]
        MLMD["ML Metadata (MLMD)<br/>8080/TCP gRPC<br/>Optional TLS (CA cert)<br/>Auth: None"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS<br/>Auth: ServiceAccount Token"]
        ArgoEngine["Argo Workflows Engine<br/>(via K8s CRDs)"]
    end

    subgraph CloudStorage["EXTERNAL SERVICES (Optional)"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: GCP SA"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS termination<br/>Bearer Token"| Route
    Dashboard -->|"HTTP/8888<br/>in-cluster<br/>Bearer Token"| APIServer
    Route -->|"HTTP/8888<br/>in-cluster"| APIServer

    %% Internal service flows
    PersistenceAgent -->|"gRPC/8887<br/>SA Token"| APIServer
    SWFController -->|"gRPC/8887<br/>SA Token"| APIServer
    Driver -->|"gRPC/8887<br/>cache lookup"| APIServer
    Launcher -->|"gRPC/8887<br/>cache record"| APIServer
    APIServer -->|"HTTPS/443<br/>TLS client cert"| CacheServer

    %% Data tier flows
    APIServer -->|"TCP/3306 or 5432<br/>Username/Password"| MySQL
    APIServer -->|"HTTP(S)/9000<br/>Access Key"| MinIO
    Driver -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Launcher -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Launcher -->|"HTTP(S)/9000-443<br/>Access Key / IAM"| MinIO
    Driver -->|"HTTP(S)/9000-443<br/>Access Key / IAM"| MinIO

    %% Control plane flows
    APIServer -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    PersistenceAgent -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    SWFController -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    Driver -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    Launcher -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    K8sAPI --- ArgoEngine

    %% Cloud storage flows
    Launcher -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM"| S3
    Launcher -.->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    Driver -.->|"HTTPS/443<br/>TLS 1.2+"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef argopod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef datatier fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cloudstorage fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,Dashboard external
    class Route ingress
    class APIServer,CacheServer,PersistenceAgent,SWFController,FrontendUI,VizServer internal
    class Driver,Launcher argopod
    class MySQL,MinIO,MLMD datatier
    class K8sAPI,ArgoEngine controlplane
    class S3,GCS cloudstorage
