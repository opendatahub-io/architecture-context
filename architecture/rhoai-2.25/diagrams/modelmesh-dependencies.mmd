graph LR
    ModelMesh["ModelMesh<br/>Sidecar Service<br/>(Java 21)"]

    %% Internal Platform Dependencies
    ModelMesh -->|"deployment orchestration<br/>Kubernetes API"| ModelmeshServing["modelmesh-serving<br/>Controller"]
    ModelMesh -->|"model load/unload/inference<br/>gRPC :8085 or UDS<br/>Plaintext"| ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)"]
    ModelMesh -->|"model registry, leader election<br/>config, vmodel state<br/>gRPC :2379 TLS (optional)"| etcd["etcd Cluster"]

    %% Alternative KV Store
    ModelMesh -.->|"alternative KV store (legacy)<br/>ZooKeeper :2181<br/>TLS (optional)"| ZooKeeper["ZooKeeper<br/>(Alternative)"]

    %% Inter-Pod Communication
    ModelMesh <-->|"model routing, replication<br/>cache coordination<br/>gRPC/Thrift :8080 TLS (optional)"| OtherMM["Other ModelMesh<br/>Pods"]

    %% Observability
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTPS :2112<br/>Self-signed TLS"| ModelMesh
    ModelMesh -.->|"metrics emission<br/>UDP :8126"| StatsD["StatsD Agent<br/>(Optional)"]
    ModelMesh -.->|"payload forwarding<br/>HTTP(S) configurable"| PayloadProcessor["Remote Payload<br/>Processor (Optional)"]

    %% Infrastructure
    ModelMesh -->|"pod identity<br/>Downward API"| K8sAPI["Kubernetes API"]

    %% Key Libraries
    subgraph KeyLibraries["Key Runtime Libraries"]
        direction TB
        gRPCJava["gRPC-Java 1.63.2"]
        Netty["Netty 4.1.132.Final"]
        Litelinks["Litelinks 1.7.2"]
        etcdJava["etcd-java 0.0.24"]
        BouncyCastle["BouncyCastle 1.78"]
        Protobuf["Protobuf 3.25.5"]
        Thrift["Apache Thrift 0.20.0"]
    end

    ModelMesh -->|"runtime libraries"| KeyLibraries

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelmeshServing fill:#7ed321,stroke:#333,color:#fff
    style ModelRuntime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style OtherMM fill:#9b59b6,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style StatsD fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style PayloadProcessor fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style K8sAPI fill:#e8e8e8,stroke:#333
    style gRPCJava fill:#dae8fc,stroke:#6c8ebf
    style Netty fill:#dae8fc,stroke:#6c8ebf
    style Litelinks fill:#dae8fc,stroke:#6c8ebf
    style etcdJava fill:#dae8fc,stroke:#6c8ebf
