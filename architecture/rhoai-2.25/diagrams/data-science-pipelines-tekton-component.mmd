        end

        subgraph MetadataServices["ML Metadata Services"]
            MetadataWriter["metadata-writer<br/>(Python)"]
            MetadataEnvoy["metadata-envoy<br/>9090/TCP gRPC"]
            MetadataGRPC["metadata-grpc-server<br/>8080/TCP gRPC"]
            MetadataWriter -->|writes| MetadataEnvoy
            MetadataEnvoy -->|proxies| MetadataGRPC
        end

        subgraph VisualizationLayer["Visualization"]
            VizServer["ds-pipeline-visualizationserver<br/>Python<br/>8888/TCP"]
        end
    end

    %% CRDs
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    ScheduledWorkflowCR -->|watched by| ScheduledWorkflow
    ViewerCR -->|watched by| ViewerController

    %% User interactions
    User["User / Dashboard"] -->|HTTPS 8443| OAuthProxy
    UI -->|HTTP 8888| APIServer
    APIServer -->|creates| ScheduledWorkflowCR

    %% External dependencies
    APIServer -->|creates PipelineRun| TektonAPI["Tekton Pipelines"]
    PersistenceAgent -->|watches PipelineRun/TaskRun| TektonAPI
    PersistenceAgent -->|syncs status| APIServer
    ScheduledWorkflow -->|creates PipelineRun| TektonAPI

    %% Data stores
    APIServer -->|stores metadata| MySQL["MariaDB/MySQL<br/>3306/TCP"]
    MetadataGRPC -->|stores metadata| MySQL
    APIServer -->|stores artifacts| MinIO["MinIO/S3<br/>9000/TCP"]

    %% Integration
    APIServer -->|metrics| Prometheus["Prometheus"]
    DSPOperator["DSP Operator"] -->|manages lifecycle| DSPTekton
    ODHDashboard["ODH Dashboard"] -->|OdhApplication CR| DSPTekton

