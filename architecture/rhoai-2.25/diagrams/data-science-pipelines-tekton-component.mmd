            ViewerController["ds-pipeline-viewer-crd-controller<br/>(Viewer Controller)"]
        end

        subgraph Frontend["Frontend"]
            UI["ds-pipeline-ui<br/>Node.js/React<br/>3000/TCP"]
            OAuthProxy["oauth-proxy<br/>8443/TCP TLS"]
