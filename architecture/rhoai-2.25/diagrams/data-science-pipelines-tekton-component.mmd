graph TB
    subgraph DSPT["Data Science Pipelines Tekton"]
        subgraph CoreServices["Core Services"]
            APIServer["API Server<br/>Go | 8888/TCP HTTP | 8887/TCP gRPC<br/>Pipeline CRUD, Run Management, RBAC"]
            PersistenceAgent["Persistence Agent<br/>Go | No listener<br/>Watches PipelineRuns, syncs to DB"]
            SWController["Scheduled Workflow Controller<br/>Go | No listener<br/>Reconciles ScheduledWorkflow CRDs"]
        end

        subgraph CachingLayer["Caching Layer"]
            CacheServer["Cache Server<br/>Go | 8443/TCP HTTPS<br/>Mutating Admission Webhook"]
        end

        subgraph VisualizationLayer["Visualization & UI"]
            VizServer["Visualization Server<br/>Python | 8888/TCP HTTP<br/>HTML visualization generation"]
            ViewerController["Viewer Controller<br/>Go | No listener<br/>Deploys Tensorboard instances"]
            Frontend["Frontend<br/>React/TypeScript<br/>Pipeline management UI"]
        end

        subgraph TektonCatalog["Tekton Catalog Extensions"]
            LoopController["Pipeline-Loops Controller<br/>Go/Knative | No listener<br/>Iterative PipelineRun execution"]
            LoopWebhook["Pipeline-Loops Webhook<br/>Go/Knative | 8443/TCP HTTPS<br/>PipelineLoop validation"]
            AnySequencer["Any-Sequencer<br/>Go CLI<br/>TaskRun condition watching"]
            KubectlWrapper["Kubectl-Wrapper<br/>Go CLI<br/>K8s resource lifecycle"]
        end

        subgraph MetadataServices["Metadata Services"]
            MetadataWriter["Metadata Writer<br/>Python<br/>MLMD persistence"]
            ArtifactManager["Artifact Manager<br/>Python<br/>Artifact storage ops"]
        end
    end

    %% CRDs
    SWFCRD["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCRD["Viewer CR<br/>kubeflow.org/v1beta1"]
    PipelineLoopCRD["PipelineLoop CR<br/>custom.tekton.dev/v1alpha1"]

    %% External Dependencies
    MySQL[("MySQL 5.7+<br/>Pipeline metadata, cache")]
    MinIO[("MinIO / S3<br/>Artifacts, templates, logs")]
    TektonPipelines["Tekton Pipelines >= 0.41.0"]
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Internal flows
    APIServer -->|"stores metadata"| MySQL
    APIServer -->|"stores artifacts"| MinIO
    APIServer -->|"creates PipelineRuns"| K8sAPI
    APIServer -->|"delegates viz"| VizServer
    PersistenceAgent -->|"reports status<br/>gRPC 8887"| APIServer
    PersistenceAgent -->|"watches PipelineRuns"| K8sAPI
    CacheServer -->|"cache lookup"| MySQL
    SWController -->|"creates PipelineRuns"| K8sAPI
    MetadataWriter -->|"writes metadata"| MLMD["ML Metadata<br/>gRPC"]

    %% CRD relationships
    SWFCRD -->|"watched by"| SWController
    ViewerCRD -->|"watched by"| ViewerController
    PipelineLoopCRD -->|"reconciled by"| LoopController
    PipelineLoopCRD -->|"validated by"| LoopWebhook

    %% External
    K8sAPI -->|"executes"| TektonPipelines
    TektonPipelines -->|"runs"| PipelineRunnerPod["Pipeline Runner Pod<br/>SA: pipeline-runner"]
    PipelineRunnerPod -->|"uses"| KubectlWrapper
    PipelineRunnerPod -->|"uses"| AnySequencer

    %% Client
    Client["Client<br/>(UI / SDK / CLI)"] -->|"REST/gRPC"| APIServer

    %% Operator
    DSPO["Data Science Pipelines Operator"] -.->|"deploys & manages"| DSPT

