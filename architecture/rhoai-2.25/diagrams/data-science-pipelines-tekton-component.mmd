            CacheServer["cache-server<br/>(Webhook)<br/>8443/TCP TLS"]
        end

        subgraph Controllers["Controllers & Agents"]
            PersistenceAgent["ds-pipeline-persistenceagent<br/>(Status Sync Agent)"]
