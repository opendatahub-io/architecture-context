graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ re-encrypt<br/>Auto-assigned hostname"]
    end

    subgraph Internal["INTERNAL (Cluster Network)"]
        direction TB

        subgraph NS_Controller["Namespace: opendatahub"]
            KFCtrl["kf-notebook-controller<br/>SA: notebook-controller-service-account<br/>8080/TCP metrics<br/>8081/TCP probes"]
            ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>8080/TCP metrics<br/>8081/TCP probes"]
            WebhookSvc["Webhook Service<br/>443/TCP → 8443/TCP<br/>TLS (OpenShift Service CA)<br/>failurePolicy: Fail"]
        end

        subgraph NS_Notebook["Namespace: {user-namespace}"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS (Service CA cert)<br/>SAR: get notebooks"]
            Jupyter["Jupyter Notebook<br/>8888/TCP HTTP<br/>No auth (localhost only)"]
            NBService["ClusterIP Service<br/>80/TCP → 8888<br/>HTTP / No encryption"]
            TLSService["ClusterIP Service (-tls)<br/>443/TCP → 8443<br/>HTTPS / TLS (Service CA)"]
            NetworkPolicy1["NetworkPolicy<br/>Allow controller → 8888"]
            NetworkPolicy2["NetworkPolicy<br/>Allow ingress → 8443"]
        end
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth client creds"]
        ServiceCA["OpenShift Service CA<br/>Annotation-triggered<br/>Auto-cert provisioning"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>None (redirect to OAuth)"| Route

    %% Ingress → Internal
    Route -->|"HTTPS/8443<br/>TLS re-encrypt<br/>OAuth token"| OAuthProxy

    %% OAuth flow
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth client creds"| OAuthServer

    %% OAuth → Jupyter
    OAuthProxy -->|"HTTP/8888<br/>No encryption<br/>None (pre-authed, localhost)"| Jupyter

    %% Controller → K8s API
    KFCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    ODHCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller → Notebook (culling)
    KFCtrl -->|"HTTP/8888<br/>No encryption<br/>None (in-cluster)"| Jupyter

    %% Webhook
    K8sAPI -->|"HTTPS/443→8443<br/>TLS (Service CA)<br/>API server TLS cert"| WebhookSvc

    %% Service CA
    ServiceCA -.->|"Auto-provision certs"| TLSService
    ServiceCA -.->|"Auto-provision certs"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route ingress
    class KFCtrl,ODHCtrl,WebhookSvc,OAuthProxy,Jupyter,NBService,TLSService internal
    class K8sAPI,OAuthServer,ServiceCA platform
    class NetworkPolicy1,NetworkPolicy2 security
