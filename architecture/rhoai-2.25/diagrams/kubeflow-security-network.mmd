%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>443/TCP<br/>TLS Reencrypt (OAuth) / Edge (non-OAuth)<br/>Auth: OpenShift OAuth"]
    end

    subgraph NotebookPod["NOTEBOOK POD (User Namespace)"]
        direction TB
        OAuthProxy["OAuth Proxy Sidecar<br/>(ose-oauth-proxy)<br/>8443/TCP HTTPS<br/>TLS: service-ca signed<br/>Auth: OAuth cookie + SAR check"]
        NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>No encryption (localhost)"]
        OAuthProxy -->|"HTTP/8888<br/>localhost<br/>No auth"| NotebookContainer
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE (opendatahub)"]
        direction TB
        ControllerMgr["ODH Notebook Controller Manager<br/>SA: odh-notebook-controller-manager"]

        subgraph Services["Services"]
            WebhookSvc["Webhook Service<br/>443/TCP -> 8443/TCP<br/>HTTPS TLS (service-ca)<br/>Auth: K8s API server mTLS"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>No encryption<br/>No auth"]
        end

        ControllerMgr --- WebhookSvc
        ControllerMgr --- MetricsSvc
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount token"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: OAuthClient credentials"]
        ServiceCA["OpenShift Service CA<br/>Auto-provisions TLS certs"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS<br/>TLS<br/>Auth: ServiceAccount token"]
    end

    subgraph NetworkPolicies["NETWORK POLICIES (per notebook)"]
        CtrlNP["{notebook}-ctrl-np<br/>Allow TCP/8888<br/>from controller NS only"]
        OAuthNP["{notebook}-oauth-np<br/>Allow TCP/8443<br/>from all sources"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>TLS<br/>No auth (redirect to OAuth)"| Route
    Route -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth token (cookie)"| OAuthProxy

    %% OAuth flow
    Browser -.->|"HTTPS/443<br/>TLS 1.2+<br/>Username/Password"| OAuthServer
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SAR check"| K8sAPI

    %% Controller flows
    K8sAPI -->|"Webhook call<br/>HTTPS/8443<br/>API server mTLS"| WebhookSvc
    ControllerMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI
    ControllerMgr -->|"HTTPS/5000<br/>TLS<br/>ServiceAccount token"| ImageRegistry

    %% Certificate provisioning
    ServiceCA -.->|"Auto-provision<br/>TLS certs"| WebhookSvc
    ServiceCA -.->|"Auto-provision<br/>TLS certs"| OAuthProxy

    %% Network policy enforcement
    CtrlNP -.-> NotebookContainer
    OAuthNP -.-> OAuthProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef notebookpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Browser external
    class Route ingress
    class OAuthProxy,NotebookContainer notebookpod
    class ControllerMgr,WebhookSvc,MetricsSvc controller
    class K8sAPI,OAuthServer,ServiceCA,ImageRegistry platform
    class CtrlNP,OAuthNP netpol
