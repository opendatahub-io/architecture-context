graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User/Dashboard"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC + ServiceAccount Tokens"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph ControllerNamespace["Namespace: kubeflow"]
            Controller["Notebook Controller Pod<br/>SA: notebook-controller-service-account<br/>User: 1001 (non-root)"]

            subgraph ControllerComponents["Controller Components"]
                NotebookRecon["Notebook Reconciler<br/>Watches: notebooks.kubeflow.org<br/>Creates: StatefulSets, Services, VS"]
                CullingRecon["Culling Reconciler<br/>Checks: Kernel activity<br/>Updates: Annotations"]
                Metrics["Metrics Server<br/>:8080/TCP HTTP<br/>No encryption, No auth"]
                Health["Health Probe<br/>:8081/TCP HTTP<br/>/healthz, /readyz"]
            end

            Controller --> NotebookRecon
            Controller --> CullingRecon
            Controller --> Metrics
            Controller --> Health
        end

        Kubelet["Kubelet<br/>10250/TCP HTTPS<br/>mTLS"]

        subgraph UserNamespace["Namespace: {user-namespace}"]
            NotebookPod["Notebook Pod<br/>:8888/TCP HTTP<br/>No encryption<br/>Image: {jupyter-image}"]
            NotebookService["Service: notebook-{name}<br/>ClusterIP<br/>80/TCP → 8888/TCP"]
        end

        NotebookService -->|routes to| NotebookPod
    end

    subgraph Monitoring["MONITORING (Cluster Internal)"]
        Prometheus["Prometheus<br/>openshift-monitoring"]
    end

    subgraph Ingress["INGRESS (Optional - USE_ISTIO=true)"]
        IstioGateway["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.3<br/>RequestAuthentication"]
        VirtualService["VirtualService<br/>Host: {ISTIO_HOST}<br/>Gateway: {ISTIO_GATEWAY}"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI
    K8sAPI -.->|Watch events<br/>Notebook CRs| Controller
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token JWT| K8sAPI
    K8sAPI -->|HTTPS/10250<br/>mTLS| Kubelet
    Kubelet -->|Manages lifecycle| NotebookPod

    CullingRecon -->|HTTP/8888<br/>GET /api/kernels<br/>No encryption, No auth| NotebookPod
    Prometheus -->|HTTP/8080<br/>GET /metrics<br/>No encryption, No auth| Metrics

    IstioGateway -.->|VirtualService routing| NotebookService
    VirtualService -.->|optional| NotebookService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef ingress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef insecure fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,NotebookRecon,CullingRecon,Kubelet,NotebookPod,NotebookService clusterinternal
    class Metrics,Health insecure
    class Prometheus monitoring
    class IstioGateway,VirtualService ingress
