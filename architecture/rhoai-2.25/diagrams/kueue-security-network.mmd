graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Job Controller"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>SA tokens / X.509 certs"]
    end

    subgraph KueueNS["KUEUE NAMESPACE: opendatahub (RHOAI)"]
        direction TB

        subgraph Controller["kueue-controller-manager"]
            direction LR
            HealthPort["8081/TCP HTTP<br/>/healthz, /readyz<br/>No auth"]
            MetricsPort["8443/TCP HTTPS<br/>/metrics<br/>TLS + Bearer Token<br/>TokenReview + SAR"]
            WebhookPort["9443/TCP HTTPS<br/>/mutate-*, /validate-*<br/>TLS (self-signed/cert-mgr)<br/>API Server client cert<br/>Fail-closed"]
        end

        subgraph Services["Services (ClusterIP)"]
            WebhookSvc["kueue-webhook-service<br/>443 → 9443/TCP<br/>HTTPS TLS"]
            MetricsSvc["kueue-metrics-service<br/>8443 → 8443/TCP<br/>HTTPS TLS"]
        end

        subgraph NetworkPol["NetworkPolicy (RHOAI)"]
            NP["Ingress: Allow TCP/9443<br/>All other: default deny"]
        end

        WebhookSvc --> WebhookPort
        MetricsSvc --> MetricsPort
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape<br/>Bearer Token auth"]
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL CONNECTIONS"]
        WorkerClusters["MultiKueue Worker Clusters<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>kubeconfig from Secret"]
        AutoScaler["cluster-autoscaler<br/>(CRD-mediated,<br/>no direct connection)"]
    end

    %% Flows - External to API Server
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token / User creds"| K8sAPI

    %% API Server to Webhook (ingress)
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API Server client cert<br/>Fail-closed"| WebhookSvc

    %% Controller to API Server (egress)
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRD CRUD, leader election,<br/>event recording, discovery"| K8sAPI

    %% Prometheus scraping
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token (SA)<br/>TokenReview + SAR"| MetricsSvc

    %% MultiKueue (optional)
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig Secret<br/>(when MultiKueue enabled)"| WorkerClusters

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f5f5f5,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5
    classDef networkpol fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class User external
    class K8sAPI controlplane
    class Controller kueuens
    class Prometheus monitoring
    class WorkerClusters,AutoScaler optional
    class NP networkpol
    class WebhookSvc,MetricsSvc service
