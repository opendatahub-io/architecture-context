graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / Data Scientist<br/>kubectl/API]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.3<br/>RBAC"]
    end

    subgraph NS_Opendatahub["NAMESPACE: opendatahub"]
        direction TB

        subgraph Controller_Pod["kueue-controller-manager Pod"]
            Controller["Controller Manager<br/>SA: kueue-controller-manager<br/>User: 65532:65532<br/>Image: ubi9-minimal FIPS"]
            WebhookServer["Webhook Server<br/>Port: 9443/TCP"]
            MetricsServer["Metrics Server<br/>Port: 8443/TCP"]
            VisibilityAPI["Visibility API<br/>(in-process)"]
            Cache["In-Memory Cache<br/>(in-process)"]
        end

        WebhookService["kueue-webhook-service<br/>ClusterIP<br/>443→9443/TCP<br/>HTTPS TLS1.2+"]
        MetricsService["kueue-metrics-service<br/>ClusterIP<br/>8443/TCP<br/>HTTPS TLS1.2+"]

        WebhookCert["Secret:<br/>kueue-webhook-server-cert<br/>(kubernetes.io/tls)<br/>cert-manager managed"]
        MetricsToken["Secret:<br/>metrics-token<br/>(SA token)"]

        NetworkPolicy["NetworkPolicy:<br/>kueue-webhook-server<br/>Allow TCP 9443"]
    end

    subgraph ExternalServices["EXTERNAL INTEGRATIONS"]
        CertManager["cert-manager<br/>Certificate provisioning"]
        ClusterAutoscaler["Cluster Autoscaler<br/>Node provisioning"]
        RemoteCluster["Remote K8s Clusters<br/>(MultiKueue)"]
        CloudAPI["Cloud Provider API<br/>(AWS/GCP/Azure)"]
        Prometheus["Prometheus<br/>Metrics collection"]
    end

    subgraph CustomResources["CUSTOM RESOURCES"]
        direction LR
        Workload["Workload<br/>(kueue.x-k8s.io)"]
        ClusterQueue["ClusterQueue<br/>(kueue.x-k8s.io)"]
        LocalQueue["LocalQueue<br/>(kueue.x-k8s.io)"]
        ProvisioningRequest["ProvisioningRequest<br/>(autoscaling.x-k8s.io)"]
    end

    %% External User Flow
    User -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| K8sAPI

    %% Webhook Flow
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>API Server client cert| WebhookService
    WebhookService -->|routes to| WebhookServer
    WebhookCert -.->|TLS cert| WebhookServer
    NetworkPolicy -.->|allows| WebhookService

    %% Controller Watch Flow
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token| K8sAPI
    K8sAPI -.->|watches| Workload
    K8sAPI -.->|watches| ClusterQueue
    K8sAPI -.->|watches| LocalQueue

    %% Controller reconcile CRDs
    Controller -->|creates/patches| Workload
    Controller -->|reconciles| ClusterQueue
    Controller -->|reconciles| LocalQueue
    Controller -->|creates| ProvisioningRequest

    %% Visibility API Flow
    K8sAPI -->|in-process<br/>aggregated API| VisibilityAPI
    VisibilityAPI -->|queries| Cache

    %% Metrics Flow
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>SA Bearer Token| MetricsService
    MetricsService -->|routes to| MetricsServer
    MetricsToken -.->|bearer token| MetricsServer

    %% External Integrations
    CertManager -->|provisions| WebhookCert
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| CertManager

    ClusterAutoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    K8sAPI -.->|watches| ProvisioningRequest
    ClusterAutoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials| CloudAPI

    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Kubeconfig| RemoteCluster

    %% Health Checks
    HealthProbe["Health Probes<br/>/healthz, /readyz<br/>8081/TCP HTTP"] -.->|monitors| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef namespace fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:3px
    classDef service fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef secret fill:#fce4ec,stroke:#c2185b,stroke-width:2px
    classDef crd fill:#f5a623,stroke:#333,stroke-width:2px
    classDef externalservice fill:#e8e8e8,stroke:#666,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookServer,MetricsServer,VisibilityAPI,Cache controller
    class WebhookService,MetricsService service
    class WebhookCert,MetricsToken secret
    class Workload,ClusterQueue,LocalQueue,ProvisioningRequest crd
    class CertManager,ClusterAutoscaler,RemoteCluster,CloudAPI,Prometheus externalservice
