graph LR
    ODH["odh-model-controller<br/>Go Operator"]

    %% External Dependencies (Required)
    ODH -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.19.1"]
    ODH -->|"CRD types"| KServe["KServe<br/>v0.15.0 (ODH fork)"]
    ODH -->|"Gateway, VirtualService,<br/>PeerAuth, Telemetry"| IstioAPI["Istio API<br/>v1.24.2"]
    ODH -->|"typed Istio client"| IstioClient["Istio Client Go<br/>v1.24.2"]
    ODH -->|"ServiceMeshMember,<br/>ServiceMeshMemberRoll"| Maistra["Maistra API<br/>v0.0.0-20240319"]
    ODH -->|"Route, Template types"| OSAPI["OpenShift API<br/>v0.0.0-20250102"]
    ODH -->|"Template clientset"| OSClient["OpenShift Client Go<br/>v0.0.0-20250102"]
    ODH -->|"ServiceMonitor,<br/>PodMonitor types"| PromOp["Prometheus Operator<br/>v0.76.2"]

    %% External Dependencies (Conditional)
    ODH -.->|"Knative Service types<br/>(Serverless mode)"| Knative["Knative Serving<br/>v0.44.0"]
    ODH -.->|"TriggerAuth types<br/>(KEDA autoscaling)"| KEDA["KEDA<br/>v2.17.3"]
    ODH -.->|"AuthConfig types<br/>(mesh auth)"| Authorino["Authorino<br/>v0.20.0"]
    ODH -.->|"AuthPolicy types<br/>(LLM auth)"| Kuadrant["Kuadrant Operator<br/>v1.2.0"]
    ODH -.->|"Model Registry client<br/>(when managed)"| ModelRegLib["Model Registry<br/>v0.2.19"]
    ODH -.->|"Gateway API types<br/>(AuthPolicy binding)"| GatewayAPI["Gateway API<br/>v1.2.1"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys, configures"| ODH
    ODH -->|"watches CRDs"| KServePlatform["KServe Platform<br/>(InferenceService,<br/>InferenceGraph,<br/>LLMInferenceService,<br/>ServingRuntime)"]
    ODH -->|"creates mesh resources"| IstioPlatform["Istio / Service Mesh<br/>(Gateway, VirtualService,<br/>PeerAuth, Telemetry, SMM)"]
    ODH -->|"creates AuthConfigs"| AuthorinoPlatform["Authorino<br/>(auth enforcement)"]
    ODH -->|"creates AuthPolicies"| KuadrantPlatform["Kuadrant<br/>(gateway auth)"]
    ODH -->|"creates TriggerAuths"| KEDAPlatform["KEDA<br/>(autoscaling)"]
    ODH -->|"creates ServiceMonitors,<br/>PodMonitors, RoleBindings"| PromPlatform["Prometheus /<br/>OpenShift Monitoring"]
    ODH -->|"creates Routes"| OSRouter["OpenShift Router"]

    %% Integration Points (consumers of this controller)
    Dashboard["ODH Dashboard"] -.->|"UI management"| ODH
    Pipelines["Data Science Pipelines"] -.->|"auto deploy"| ODH

    %% External Services
    ODH -->|"API key validation,<br/>model catalog"| NGCAPI["NVIDIA NGC API<br/>api.ngc.nvidia.com"]
    ODH -->|"model metadata"| ModelRegSvc["Kubeflow Model Registry<br/>(REST API)"]
    ODH -->|"CRD CRUD,<br/>resource watches"| K8sAPI["Kubernetes API Server"]

