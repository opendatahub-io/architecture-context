graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        DashboardClient["Ray Dashboard Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["{cluster}-ingress Route<br/>443/TCP → 8265/TCP<br/>TLS Edge Termination<br/>Auth: None (default)"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>SCC: run-as-ray-user (UID 1000)<br/>Image: quay.io/opendatahub/kuberay-operator:v1.4.0"]
            OperatorSvc["kuberay-operator Service<br/>ClusterIP 8080/TCP<br/>HTTP (metrics)"]
            WebhookSvc["webhook-service<br/>ClusterIP 443→9443/TCP<br/>HTTPS (TLS cert-manager)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            HeadPod["Ray Head Pod<br/>6379/TCP (GCS)<br/>8265/TCP (Dashboard API)<br/>8000/TCP (Serve Proxy)<br/>10001/TCP (Client)<br/>8080/TCP (Metrics)"]
            WorkerPods["Ray Worker Pods"]
            HeadSvc["{cluster}-head-svc<br/>Headless/ClusterIP"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
            HeadlessSvc["{cluster}-headless<br/>ClusterIP=None<br/>Worker peer comm"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["Redis (optional)<br/>6379/TCP<br/>TCP (encryption configurable)<br/>Auth: Password (optional)"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    %% External flows
    User -->|"HTTPS/6443<br/>TLS<br/>Bearer Token"| K8sAPI
    DashboardClient -->|"HTTPS/443<br/>TLS Edge"| Route

    %% Ingress to internal
    Route -->|"HTTP/8265<br/>No encryption<br/>No auth"| HeadPod

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS<br/>ServiceAccount token"| K8sAPI
    Operator -->|"HTTP/8265<br/>No encryption<br/>No auth"| HeadPod
    Operator -->|"HTTP/8000<br/>No encryption<br/>Health check"| HeadPod

    %% K8s API to webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (cert-manager)<br/>Webhook validation"| WebhookSvc

    %% Ray internal
    WorkerPods -->|"TCP/6379<br/>No encryption<br/>GCS connection"| HeadPod

    %% Optional GCS FT
    HeadPod -->|"TCP/6379<br/>Configurable encryption<br/>Password (optional)"| Redis

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| OperatorSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef apiserver fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,DashboardClient external
    class Route ingress
    class Operator,OperatorSvc,WebhookSvc operatorns
    class HeadPod,WorkerPods,HeadSvc,ServeSvc,HeadlessSvc userns
    class Redis,Prometheus externalservice
    class K8sAPI apiserver
