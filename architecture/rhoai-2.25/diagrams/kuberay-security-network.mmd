%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        ExtClient["External Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / SA Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>UID: 65532<br/>FIPS: strictfipsruntime<br/>CPU: 100m, Mem: 512Mi"]
        Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>plaintext, No Auth"]
        Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph RayNS["RAY CLUSTER NAMESPACE (user namespace)<br/>SCC: run-as-ray-user (UID 1000, Drop ALL)"]
        direction TB

        subgraph HeadGroup["Head Node"]
            RayHead["Ray Head Pod<br/>SA: auto-created/user"]
            Dashboard["Dashboard API<br/>8265/TCP HTTP plaintext"]
            GCS["GCS Server<br/>6379/TCP"]
            RayClient["Ray Client<br/>10001/TCP"]
            HeadServe["Serve Port<br/>8000/TCP"]
            HeadMetrics["Metrics<br/>8080/TCP"]
        end

        subgraph WorkerGroup["Worker Nodes"]
            Workers["Ray Worker Pods<br/>SA: default/user"]
        end

        HeadSvc["{cluster}-head-svc<br/>Headless (ClusterIP: None)<br/>10001, 6379, 8265, 8080, 8000"]
        ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
        HeadlessSvc["{cluster}-headless<br/>Headless (peer comm)"]
    end

    subgraph IngressZone["INGRESS (Optional, if enableIngress=true)"]
        Route["OpenShift Route<br/>8265/TCP HTTP<br/>Edge TLS optional"]
        Ingress["K8s Ingress<br/>8265/TCP HTTP<br/>(vanilla K8s only)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP<br/>HTTP plaintext"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    ExtClient -->|"HTTP/8265<br/>via Route/Ingress"| Route
    ExtClient -->|"HTTP/8000<br/>via serve-svc"| ServeSvc

    %% Control plane to operator
    K8sAPI -.->|"Watch events<br/>CRD changes"| Operator

    %% Operator egress
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTP/8265<br/>plaintext<br/>No Auth"| Dashboard

    %% Ingress to Ray
    Route -->|"HTTP/8265"| Dashboard
    Ingress -->|"HTTP/8265"| Dashboard

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>plaintext"| Metrics

    %% Internal Ray cluster
    RayHead --- HeadSvc
    Workers --- HeadlessSvc
    ServeSvc -->|"8000/TCP"| HeadServe

