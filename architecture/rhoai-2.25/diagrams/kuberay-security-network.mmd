graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressCtrl["Ingress/OpenShift Route<br/>8265/TCP (Dashboard)<br/>8000/TCP (Serve)<br/>Optional TLS<br/>Edge/Passthrough"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Webhook["Admission Webhook<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Cert: webhook-server-cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (kuberay-system/opendatahub)"]
        direction TB

        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Image: UBI9 minimal"]
        Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>Auth: None"]
        Operator --> Metrics
    end

    subgraph AppNS["APPLICATION NAMESPACE ({user-namespace})"]
        direction TB

        subgraph RayCluster["RAY CLUSTER"]
            direction TB

            HeadPod["Ray Head Pod<br/>SA: {cluster}-sa<br/>━━━━━━━━━━━━━━━<br/>6379/TCP: GCS<br/>8265/TCP: Dashboard HTTP<br/>10001/TCP: Client API<br/>8080/TCP: Metrics<br/>52365/TCP: Agent"]

            WorkerPods["Ray Worker Pods<br/>SA: {cluster}-sa<br/>Auto-scaling<br/>━━━━━━━━━━━━━━━<br/>Connect to Head GCS"]

            HeadSvc["Head Service (ClusterIP)<br/>6379, 8265, 10001"]
            ServeSvc["Serve Service (ClusterIP)<br/>8000/TCP HTTP"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Redis["External Redis<br/>6379/TCP<br/>Optional TLS<br/>Redis Password"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
        PackageIndex["Ray Package Index<br/>Git / S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% External Client flows
    Client -->|"HTTPS/HTTP<br/>443/80<br/>Optional TLS"| IngressCtrl
    IngressCtrl -->|"HTTP<br/>8265 (Dashboard)<br/>8000 (Serve)<br/>Optional Token Auth"| HeadSvc
    IngressCtrl -->|"HTTP<br/>8000"| ServeSvc

    %% Control Plane flows
    K8sAPI -->|"HTTPS<br/>9443/TCP<br/>mTLS<br/>K8s API cert"| Webhook
    Operator -->|"HTTPS<br/>443/TCP<br/>TLS 1.2+<br/>SA token<br/>Manage Resources"| K8sAPI

    %% Service routing
    HeadSvc --> HeadPod
    ServeSvc --> HeadPod

    %% Ray cluster internal communication
    WorkerPods -->|"TCP<br/>6379 GCS<br/>Optional password"| HeadPod

    %% Autoscaling
    HeadPod -->|"HTTPS<br/>443/TCP<br/>SA token<br/>create/delete Pods"| K8sAPI

    %% External dependencies
    HeadPod -->|"Redis protocol<br/>6379/TCP<br/>Optional TLS<br/>Password auth"| Redis
    Operator -->|"HTTPS<br/>443/TCP<br/>TLS 1.2+"| Registry
    HeadPod -->|"HTTPS<br/>443/TCP<br/>TLS 1.2+"| PackageIndex
    Prometheus -->|"HTTP<br/>8080/TCP<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef rayapp fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class K8sAPI,Webhook controlplane
    class Operator,Metrics operator
    class HeadPod,WorkerPods,HeadSvc,ServeSvc rayapp
    class Redis,Registry,PackageIndex,Prometheus externalsvc
