graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB[kserve-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "API Resources - serving.kserve.io"
        InferenceService[InferenceService<br/>v1beta1]
        ServingRuntime[ServingRuntime<br/>ClusterServingRuntime<br/>v1alpha1]
        TrainedModel[TrainedModel<br/>v1alpha1]
        InferenceGraph[InferenceGraph<br/>v1alpha1]
        LLMService[LLMInferenceService<br/>LLMInferenceServiceConfig<br/>v1alpha1]
        LocalModel[LocalModelCache<br/>LocalModelNode<br/>LocalModelNodeGroup<br/>v1alpha1]
    end

    subgraph "API Resources - Knative/Istio"
        KnativeService[serving.knative.dev<br/>Service]
        VirtualService[networking.istio.io<br/>VirtualService<br/>DestinationRule]
    end

    subgraph "API Resources - Kubernetes Core"
        Deployments[apps/Deployment]
        HPA[autoscaling/HPA]
        Services[core/Service]
        Secrets[core/Secret]
        ServiceAccounts[core/ServiceAccount]
        ConfigMaps[core/ConfigMap]
        Events[core/Event]
        Namespaces[core/Namespace]
        Pods[core/Pod]
    end

    subgraph "API Resources - Networking"
        Ingresses[networking.k8s.io<br/>Ingress]
        Routes[route.openshift.io<br/>Route]
        GatewayAPI[gateway.networking.k8s.io<br/>HTTPRoute, Gateway,<br/>GatewayClass]
    end

    subgraph "API Resources - Extensions"
        KEDA[keda.sh<br/>ScaledObject]
        OTel[opentelemetry.io<br/>OpenTelemetryCollector]
        Monitoring[monitoring.coreos.com<br/>ServiceMonitor<br/>PodMonitor]
        Webhooks[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration<br/>ValidatingWebhookConfiguration]
        RBAC[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>RoleBinding, Role]
        SCC[security.openshift.io<br/>SecurityContextConstraints]
        LWS[leaderworkerset.x-k8s.io<br/>LeaderWorkerSet]
        InferenceAPI[inference.networking.x-k8s.io<br/>InferenceModel<br/>InferencePool]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - KServe API
    CR -->|create, delete, get,<br/>list, patch, update, watch| InferenceService
    CR -->|create, delete, get,<br/>list, patch, update, watch| ServingRuntime
    CR -->|create, delete, get,<br/>list, patch, update, watch| TrainedModel
    CR -->|create, delete, get,<br/>list, patch, update, watch| InferenceGraph
    CR -->|create, delete, get,<br/>list, patch, update, watch| LLMService
    CR -->|get, list, watch| LocalModel

    %% Permissions - Knative/Istio
    CR -->|create, delete, get,<br/>list, patch, update, watch| KnativeService
    CR -->|create, delete, get,<br/>list, patch, update, watch| VirtualService

    %% Permissions - Kubernetes Core
    CR -->|create, delete, get,<br/>list, patch, update, watch| Deployments
    CR -->|create, delete, get,<br/>list, patch, update, watch| HPA
    CR -->|create, delete, get,<br/>list, patch, update, watch| Services
    CR -->|create, delete, get,<br/>list, patch, update, watch| Secrets
    CR -->|create, delete, get,<br/>list, patch, update, watch| ServiceAccounts
    CR -->|create, delete, get,<br/>list, patch, update, watch| ConfigMaps
    CR -->|create, delete, get,<br/>list, patch, update, watch| Events
    CR -->|get, list, watch| Namespaces
    CR -->|get, list, watch| Pods

    %% Permissions - Networking
    CR -->|create, delete, get,<br/>list, patch, update, watch| Ingresses
    CR -->|create, delete, get,<br/>list, patch, update, watch| Routes
    CR -->|create, delete, get,<br/>list, patch, update, watch| GatewayAPI

    %% Permissions - Extensions
    CR -->|create, delete, get,<br/>list, patch, update, watch| KEDA
    CR -->|create, delete, get,<br/>list, patch, update, watch| OTel
    CR -->|create, delete, get,<br/>list, patch, update, watch| Monitoring
    CR -->|create, delete, get,<br/>list, patch, update, watch| Webhooks
    CR -->|create, delete, get,<br/>list, patch, update, watch| RBAC
    CR -->|use<br/>openshift-ai-llminferenceservice-scc| SCC
    CR -->|create, delete, get,<br/>list, patch, update, watch| LWS
    CR -->|create, delete, get,<br/>list, patch, update, watch| InferenceAPI

