graph TD
    subgraph ServiceAccounts["Service Accounts (namespace: kserve)"]
        SA_Main["kserve-controller-manager"]
        SA_LMCtrl["kserve-localmodel-controller-manager"]
        SA_LMAgent["kserve-localmodelnode-agent"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Main["kserve-manager-rolebinding"]
        CRB_Proxy["kserve-proxy-rolebinding"]
        CRB_LMCtrl["kserve-localmodel-manager-rolebinding"]
        CRB_LMAgent["kserve-localmodelnode-agent-rolebinding"]
        RB_Leader["kserve-leader-election-rolebinding<br/>(namespace: kserve)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["kserve-manager-role"]
        CR_Proxy["kserve-proxy-role"]
        CR_LMCtrl["kserve-localmodel-manager-role"]
        CR_LMAgent["kserve-localmodelnode-agent-role"]
        R_Leader["kserve-leader-election-role<br/>(Role, namespace: kserve)"]
    end

    subgraph UserRoles["User-Facing Roles (RHOAI)"]
        UR_Admin["kserve-admin<br/>(aggregates to admin)"]
        UR_Edit["kserve-edit"]
        UR_View["kserve-view"]
    end

    %% SA → Binding → Role
    SA_Main -->|"bound via"| CRB_Main
    SA_Main -->|"bound via"| CRB_Proxy
    SA_Main -->|"bound via"| RB_Leader
    SA_LMCtrl -->|"bound via"| CRB_LMCtrl
    SA_LMAgent -->|"bound via"| CRB_LMAgent

    CRB_Main -->|"grants"| CR_Main
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_LMCtrl -->|"grants"| CR_LMCtrl
    CRB_LMAgent -->|"grants"| CR_LMAgent
    RB_Leader -->|"grants"| R_Leader

    subgraph Resources_Main["kserve-manager-role Resources"]
        R_KServeCRDs["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>clusterservingruntimes, trainedmodels,<br/>inferencegraphs, llminferenceservices,<br/>localmodelcaches, ...<br/>→ full CRUD"]
        R_Knative["serving.knative.dev<br/>services<br/>→ full CRUD"]
        R_Istio["networking.istio.io<br/>virtualservices, destinationrules<br/>→ full CRUD"]
        R_Gateway["gateway.networking.k8s.io<br/>httproutes, gateways<br/>→ full CRUD"]
        R_InfExt["inference.networking.x-k8s.io<br/>inferencepools, inferencemodels<br/>→ full CRUD"]
        R_LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/>→ full CRUD"]
        R_Apps["apps: deployments<br/>→ full CRUD"]
        R_Core["core: configmaps, events,<br/>secrets, serviceaccounts,<br/>services, pods, namespaces<br/>→ full CRUD"]
        R_Autoscaling["autoscaling: hpa<br/>keda.sh: scaledobjects<br/>→ full CRUD"]
        R_Monitoring["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/>→ full CRUD"]
        R_OTel["opentelemetry.io<br/>opentelemetrycollectors<br/>→ full CRUD"]
        R_OpenShift["route.openshift.io: routes<br/>security.openshift.io: SCC (use)<br/>→ full CRUD / use"]
        R_Webhook["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>→ full CRUD"]
        R_Auth["authentication.k8s.io<br/>tokenreviews, subjectaccessreviews<br/>→ create"]
    end

    subgraph Resources_LMCtrl["localmodel-manager-role Resources"]
        R_LMCRDs["serving.kserve.io<br/>localmodelcaches, localmodelnodes,<br/>localmodelnodegroups, inferenceservices<br/>→ full CRUD"]
        R_LMStorage["core: nodes, persistentvolumes,<br/>persistentvolumeclaims, configmaps<br/>→ get, list, watch, create, update, patch"]
    end

    subgraph Resources_LMAgent["localmodelnode-agent-role Resources"]
        R_LMACRDs["serving.kserve.io<br/>localmodelnodes, localmodelnodegroups,<br/>clusterstoragecontainers<br/>→ full CRUD"]
        R_LMABatch["batch: jobs<br/>→ full CRUD"]
        R_LMACore["core: nodes, configmaps<br/>→ get, list, watch"]
    end

    subgraph Resources_User["User-Facing Role Resources"]
        R_UserEdit["inferenceservices,<br/>llminferenceservices,<br/>servingruntimes<br/>→ create, delete, get, list,<br/>patch, update, watch"]
        R_UserView["inferenceservices,<br/>llminferenceservices,<br/>servingruntimes<br/>→ get, list, watch"]
    end

    CR_Main -->|"permits"| Resources_Main
    CR_LMCtrl -->|"permits"| Resources_LMCtrl
    CR_LMAgent -->|"permits"| Resources_LMAgent
    UR_Edit -->|"permits"| R_UserEdit
    UR_View -->|"permits"| R_UserView

