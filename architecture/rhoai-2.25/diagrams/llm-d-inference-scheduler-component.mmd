graph TB
    subgraph EPP["llm-d-inference-scheduler (EPP)"]
        direction TB
        ExtProc["ext-proc gRPC Server<br/>Port 9002/TCP"]
        HealthServer["Health Server<br/>Port 9003/TCP"]
        MetricsServer["Metrics Endpoint<br/>Port 9090/TCP"]

        subgraph PluginFramework["Plugin Framework (extends GIE)"]
            direction TB

            subgraph Filters["Filters"]
                ByLabel["by-label Filter"]
                ByLabelSelector["by-label-selector Filter"]
                DecodeFilter["decode-filter"]
                PrefillFilter["prefill-filter"]
            end

            subgraph Scorers["Scorers"]
                PrefixCache["prefix-cache-scorer<br/>(estimation mode)"]
                CacheTracking["prefix-cache-scorer<br/>(cache_tracking mode)"]
                LoadAware["load-aware-scorer"]
                SessionAffinity["session-affinity-scorer"]
            end

            subgraph ProfileHandlers["Profile Handlers"]
                PdProfile["pd-profile-handler"]
            end

            subgraph PreRequestHandlers["Pre-Request Handlers"]
                PrefillHeader["prefill-header-handler"]
            end
        end

        subgraph KVCache["KV-Cache Tracking"]
            ZMQSub["ZMQ SUB Client"]
            KVIndexer["KV-Cache Indexer"]
            Tokenizer["HuggingFace Tokenizer<br/>(Rust FFI)"]
            ZMQSub --> KVIndexer
            Tokenizer --> KVIndexer
        end
    end

    %% External actors
    Client["External Client"]
    EnvoyGW["Envoy Gateway<br/>(Gateway API)"]

    %% CRDs watched
    InferencePoolCR["InferencePool CR<br/>(inference.networking.x-k8s.io/v1alpha2)"]
    InferenceModelCR["InferenceModel CR<br/>(inference.networking.x-k8s.io/v1alpha2)"]
    EPPConfig["EndpointPickerConfig<br/>(YAML / ConfigMap)"]

    %% Backend pods
    vLLMPods["vLLM Model-Serving Pods<br/>(port 8000)"]

    %% External services
    K8sAPI["Kubernetes API Server"]
    Prometheus["Prometheus"]
    OTELCollector["OpenTelemetry Collector"]
    HFHub["HuggingFace Hub"]

    %% Flow: Client → Envoy → EPP → Envoy → vLLM
    Client -->|"HTTP/HTTPS"| EnvoyGW
    EnvoyGW -->|"gRPC ext-proc<br/>9002/TCP"| ExtProc
    ExtProc -->|"routing decision<br/>(target pod IP:port)"| EnvoyGW
    EnvoyGW -->|"HTTP 8000/TCP"| vLLMPods

    %% CRD watches
    InferencePoolCR -->|"watched by"| ExtProc
    InferenceModelCR -->|"watched by"| ExtProc
    EPPConfig -->|"loaded by"| PluginFramework

    %% EPP → K8s API
    ExtProc -->|"Watch Pods,<br/>EndpointSlices"| K8sAPI

    %% KV-Cache tracking
    vLLMPods -->|"ZMQ events<br/>5557/TCP"| ZMQSub
    KVIndexer -->|"cache scores"| CacheTracking

    %% Metrics & tracing
    Prometheus -->|"scrapes"| MetricsServer
    ExtProc -->|"OTLP traces<br/>4317/TCP"| OTELCollector

    %% Tokenizer download
    Tokenizer -->|"HTTPS 443"| HFHub

    %% Scheduling pipeline flow
    ExtProc --> Filters
    Filters --> Scorers
    Scorers --> ProfileHandlers
    ProfileHandlers --> PreRequestHandlers

    %% Styling
    style EPP fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style ExtProc fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style PluginFramework fill:#e8eaf6,stroke:#3949ab,stroke-width:2px
    style KVCache fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceModelCR fill:#f5a623,stroke:#333
    style EPPConfig fill:#f5a623,stroke:#333
    style EnvoyGW fill:#999,stroke:#333,color:#fff
    style vLLMPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style OTELCollector fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
