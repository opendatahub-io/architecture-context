graph TD
    subgraph "vLLM RBAC Model"
        direction TB

        Note["NOTE: vLLM defines no RBAC resources.<br/>All RBAC is managed by KServe and the<br/>platform operator at runtime."]

        subgraph "KServe-Managed RBAC (Runtime)"
            SA["Pod ServiceAccount<br/>(set by KServe InferenceService)"]
            KServeSA["kserve-controller-manager<br/>ServiceAccount"]
        end

        subgraph "Authentication Enforcement"
            AuthProxy["Auth Proxy Sidecar<br/>(kube-rbac-proxy / oauth-proxy)<br/>Port: 8443/TCP HTTPS"]
        end

        subgraph "Protected Endpoints (Pod-Internal)"
            TGIS["vLLM TGIS Adapter<br/>8033/TCP gRPC<br/>No direct auth"]
            HTTP["vLLM HTTP Server<br/>8000/TCP HTTP<br/>No direct auth"]
        end

        subgraph "Platform Ingress"
            Ingress["Platform Ingress<br/>(HTTPRoute / Route)<br/>443/TCP HTTPS TLS 1.2+"]
        end

        subgraph "Resource Access"
            ModelSecret["storage-config Secret<br/>(S3 credentials)<br/>Provided by KServe"]
            GPU["GPU Device Access<br/>(nvidia.com/gpu resource)<br/>Scheduled by KServe"]
        end
    end

    %% Flow
    Ingress -->|"External traffic<br/>TLS terminated"| AuthProxy
    AuthProxy -->|"AuthN/AuthZ enforced<br/>then proxy to pod"| TGIS
    AuthProxy -->|"AuthN/AuthZ enforced<br/>then proxy to pod"| HTTP
    KServeSA -->|"manages lifecycle"| SA
    SA -->|"mounts"| ModelSecret
    SA -->|"allocated"| GPU

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style AuthProxy fill:#f5a623,stroke:#333,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style HTTP fill:#7ed321,stroke:#333,color:#fff
    style Ingress fill:#ffe6cc,stroke:#d79b00
    style ModelSecret fill:#dae8fc,stroke:#6c8ebf
    style GPU fill:#e8e8e8,stroke:#333
