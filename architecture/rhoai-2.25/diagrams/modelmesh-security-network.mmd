graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(via modelmesh-serving Route/Ingress)"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph PodBoundary["ModelMesh Pod Boundary"]
            direction TB

            subgraph SidecarContainer["ModelMesh Sidecar Container"]
                APIServer["ModelMesh gRPC API<br/>Port: 8033/TCP<br/>Protocol: gRPC<br/>Encryption: TLS (optional)<br/>Auth: mTLS (MM_TLS_CLIENT_AUTH)"]
                HealthServer["Health Probe Server<br/>Port: 8089/TCP<br/>Protocol: HTTP<br/>Encryption: None<br/>Auth: None"]
                MetricsServer["Prometheus Metrics<br/>Port: 2112/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS (self-signed)<br/>Auth: None"]
                PreStopServer["Pre-Stop Hook<br/>Port: 8090/TCP<br/>Protocol: HTTP<br/>Encryption: None<br/>Auth: None"]
                LitelinksServer["Litelinks Inter-Pod<br/>Port: 8080/TCP<br/>Protocol: gRPC/Thrift<br/>Encryption: TLS (optional)<br/>Auth: mTLS (optional)"]
            end

            subgraph RuntimeContainer["Model Runtime Container"]
                RuntimeGRPC["ModelRuntime gRPC<br/>Port: 8085/TCP or UDS<br/>Protocol: gRPC<br/>Encryption: Plaintext<br/>Auth: None"]
            end

            SidecarContainer -->|"gRPC :8085 or UDS<br/>Plaintext (localhost)<br/>No Auth"| RuntimeContainer
        end

        subgraph OtherPods["Other ModelMesh Pods"]
            OtherMM["ModelMesh Instance<br/>Litelinks :8080/TCP"]
        end

        subgraph InfraServices["Infrastructure Services"]
            etcd["etcd Cluster<br/>Port: 2379/TCP<br/>Protocol: gRPC<br/>Encryption: TLS (optional)<br/>Auth: Certificate (optional)"]
            Prometheus["Prometheus<br/>Scraper"]
            K8sAPI["Kubernetes API<br/>Downward API"]
        end

        subgraph Controller["Platform Controllers"]
            MMServing["modelmesh-serving<br/>Controller"]
        end
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        StatsD["StatsD Agent<br/>Port: 8126/UDP<br/>Protocol: StatsD<br/>Encryption: None"]
        PayloadProcessor["Remote Payload Processor<br/>Port: configurable/TCP<br/>Protocol: HTTP/HTTPS<br/>Encryption: TLS (optional)"]
    end

    %% Ingress Flows
    Client -->|"gRPC/8033<br/>TLS (optional)<br/>mTLS (optional)"| APIServer
    K8sAPI -->|"GET /ready, /live<br/>HTTP/8089<br/>No Auth"| HealthServer
    Prometheus -->|"GET /metrics<br/>HTTPS/2112<br/>TLS (self-signed)"| MetricsServer
    MMServing -->|"Kubernetes API<br/>Deployment mgmt"| PodBoundary

    %% Inter-Pod Flows
    LitelinksServer <-->|"gRPC/Thrift :8080<br/>TLS (optional)<br/>mTLS (optional)"| OtherMM

    %% Egress Flows
    SidecarContainer -->|"gRPC/2379<br/>TLS (optional)<br/>Cert Auth (optional)"| etcd
    SidecarContainer -.->|"UDP/8126<br/>Plaintext<br/>No Auth"| StatsD
    SidecarContainer -.->|"HTTP(S)/configurable<br/>TLS (optional)<br/>No Auth"| PayloadProcessor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef infra fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class APIServer,HealthServer,MetricsServer,PreStopServer,LitelinksServer ingress
    class RuntimeGRPC internal
    class etcd,Prometheus,K8sAPI,MMServing infra
    class StatsD,PayloadProcessor optional
    class OtherMM internal
