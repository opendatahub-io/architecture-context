graph TD
    subgraph "lm-evaluation-harness RBAC Model"
        direction TB

        Note["NOTE: This component defines NO RBAC resources.<br/>All RBAC is managed by the trustyai-service-operator.<br/>This diagram shows the delegated security model."]

        subgraph "Operator-Managed RBAC"
            OperatorSA["trustyai-service-operator<br/>ServiceAccount"]
            OperatorCR["Operator ClusterRole<br/>(manages Jobs, Pods, CRDs)"]
            OperatorSA -->|"bound via ClusterRoleBinding"| OperatorCR
        end

        subgraph "Job-Level Security"
            JobSA["lmes-job Pod<br/>ServiceAccount<br/>(created by operator)"]
            JobPod["lmes-job Pod<br/>UID: 65532<br/>GID: 65532<br/>(non-root)"]
            JobSA -->|"runs as"| JobPod
        end

        subgraph "Secrets Access (Environment Variables)"
            direction LR
            HF_TOKEN["HF_TOKEN<br/>Opaque<br/>User-provisioned"]
            WATSONX_KEY["WATSONX_API_KEY<br/>Opaque<br/>User-provisioned"]
            WATSONX_URL["WATSONX_URL<br/>Opaque<br/>User-provisioned"]
            WATSONX_PID["WATSONX_PROJECT_ID<br/>Opaque<br/>User-provisioned"]
            TEXTSYNTH["TEXTSYNTH_API_SECRET_KEY<br/>Opaque<br/>User-provisioned"]
            WANDB["WANDB_API_KEY<br/>Opaque<br/>User-provisioned"]
        end

        subgraph "External Auth Targets"
            HFHubAuth["HuggingFace Hub<br/>Bearer Token Auth"]
            WatsonXAuth["WatsonX AI<br/>API Key + Project ID"]
            OpenAIAuth["OpenAI-compatible<br/>Bearer Token Auth"]
            AnthropicAuth["Anthropic<br/>API Key Auth"]
            TextSynthAuth["TextSynth<br/>API Key Auth"]
        end

        OperatorCR -->|"creates Job with"| JobSA

        JobPod -->|"uses"| HF_TOKEN
        JobPod -->|"uses"| WATSONX_KEY
        JobPod -->|"uses"| WATSONX_URL
        JobPod -->|"uses"| WATSONX_PID
        JobPod -->|"uses"| TEXTSYNTH
        JobPod -->|"uses"| WANDB

        HF_TOKEN -->|"authenticates to"| HFHubAuth
        WATSONX_KEY -->|"authenticates to"| WatsonXAuth
        WATSONX_PID -->|"scopes to"| WatsonXAuth
        TEXTSYNTH -->|"authenticates to"| TextSynthAuth
    end

    subgraph "Code Execution Safety"
        UnsafeFlag["confirm_run_unsafe_code<br/>flag required"]
        UnsafeTasks["Code-eval benchmarks<br/>(arbitrary Python execution)"]
        UnsafeFlag -->|"gates execution of"| UnsafeTasks
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style OperatorSA fill:#7ed321,stroke:#333,color:#fff
    style OperatorCR fill:#f5a623,stroke:#333
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style JobPod fill:#4a90e2,stroke:#333,color:#fff
    style HF_TOKEN fill:#f8d7da,stroke:#dc3545
    style WATSONX_KEY fill:#f8d7da,stroke:#dc3545
    style WATSONX_URL fill:#f8d7da,stroke:#dc3545
    style WATSONX_PID fill:#f8d7da,stroke:#dc3545
    style TEXTSYNTH fill:#f8d7da,stroke:#dc3545
    style WANDB fill:#f8d7da,stroke:#dc3545
    style UnsafeFlag fill:#ff6b6b,stroke:#c0392b,color:#fff
    style UnsafeTasks fill:#ff6b6b,stroke:#c0392b,color:#fff
    style HFHubAuth fill:#ddd,stroke:#333
    style WatsonXAuth fill:#ddd,stroke:#333
    style OpenAIAuth fill:#ddd,stroke:#333
    style AnthropicAuth fill:#ddd,stroke:#333
    style TextSynthAuth fill:#ddd,stroke:#333
