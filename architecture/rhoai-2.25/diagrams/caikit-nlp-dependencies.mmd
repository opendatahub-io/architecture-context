graph LR
    CaikitNLP["caikit-nlp<br/>(NLP Module Library)"]

    %% Core Framework Dependencies
    CaikitNLP -->|"module system,<br/>runtime, data model"| Caikit["caikit<br/>>=0.26.34,<0.28.0"]
    CaikitNLP -->|"TGIS connection<br/>management"| CaikitTGIS["caikit-tgis-backend<br/>>=0.1.36,<0.2.0"]

    %% ML Framework Dependencies
    CaikitNLP -->|"model loading,<br/>tokenization"| Transformers["transformers<br/>>=4.38.0,<4.44.0"]
    CaikitNLP -->|"inference &<br/>training"| PyTorch["torch<br/>>=2.3.1,<2.5.0"]
    CaikitNLP -->|"prompt tuning"| PEFT["peft<br/>==0.6.0"]
    CaikitNLP -->|"embeddings,<br/>reranking"| SentenceTransformers["sentence-transformers<br/>>=3.0.0,<3.1.0"]
    CaikitNLP -->|"distributed training,<br/>mixed precision"| Accelerate["accelerate<br/>>=0.22.0"]

    %% Data Dependencies
    CaikitNLP -->|"training data"| Datasets["datasets<br/>>=2.4.0"]
    CaikitNLP -->|"model downloads"| HFHub["huggingface-hub"]

    %% gRPC Dependencies
    CaikitNLP -->|"TGIS gRPC client"| gRPC["grpcio<br/>>=1.62.2"]

    %% Internal Platform Dependencies
    CaikitNLP -->|"gRPC 8033/TCP"| TGIS["TGIS Backend"]
    CaikitNLP -.->|"in-process"| CaikitRuntime["Caikit Runtime"]

    %% Integration Points (things that depend on caikit-nlp)
    KServe["KServe / ModelMesh"] -->|"deploys container"| CaikitNLP

    %% External Services
    CaikitNLP -->|"HTTPS 443/TCP"| HuggingFaceHub["HuggingFace Hub<br/>(huggingface.co)"]
    CaikitNLP -->|"TCP 29550/TCP"| TorchDist["PyTorch Distributed"]

