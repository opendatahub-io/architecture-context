graph TB
    subgraph ClientEnv["CLIENT ENVIRONMENT (User Workstation / Jupyter Notebook)"]
        SDK["CodeFlare SDK<br/>Python ^3.11<br/>cryptography 46.0.7<br/>kube-authkit auto-detect"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph IngressLayer["INGRESS LAYER"]
        direction TB
        GatewayAPI["Gateway API (RHOAI v3.0+)<br/>HTTPRoute → Gateway<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Bearer Token (OAuth)"]
        OCPRoute["OpenShift Route (pre-v3.0)<br/>ray-dashboard-{name}<br/>443/TCP HTTPS<br/>edge/passthrough<br/>Bearer Token (OAuth proxy)"]
        K8sIngress["K8s Ingress (Kind)<br/>{name}-ingress<br/>80/TCP HTTP<br/>No encryption<br/>No auth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Ray Namespace)"]
        direction TB

        subgraph HeadSvc["{cluster}-head-svc (ClusterIP)"]
            GCS["Port 6379/TCP<br/>gRPC | mTLS<br/>Ray GCS"]
            Dashboard["Port 8265/TCP<br/>HTTP | None<br/>Ray Dashboard"]
            ClientPort["Port 10001/TCP<br/>gRPC | mTLS<br/>Ray Client"]
        end

        RayHead["Ray Head Pod<br/>Image: quay.io/modh/ray<br/>(SHA-pinned)"]
        RayWorkers["Ray Worker Pods"]

        RayHead --- GCS
        RayHead --- Dashboard
        RayHead --- ClientPort
        RayHead -->|manages| RayWorkers
    end

    subgraph Operators["PLATFORM OPERATORS"]
        KubeRayOp["KubeRay Operator<br/>SA: kuberay-operator<br/>Reconciles: RayCluster, RayJob"]
        KueueCtrl["Kueue Controller<br/>Mutating Webhook<br/>Workload admission"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Registry["quay.io/modh/ray<br/>443/TCP HTTPS<br/>Image Pull Secret"]
    end

    %% SDK → K8s API
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / kubeconfig<br/>CRD CRUD: RayCluster, RayJob,<br/>LocalQueue, HTTPRoute, Secret"| K8sAPI

    %% SDK → Ray Dashboard (external)
    SDK -->|"HTTPS/443<br/>TLS<br/>Bearer Token (OAuth)"| GatewayAPI
    SDK -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| OCPRoute

    %% SDK → Ray Client (mTLS)
    SDK -->|"gRPC/10001<br/>mTLS<br/>Client cert (RSA 3072-bit)<br/>Signed by KubeRay CA"| ClientPort

    %% Ingress → Dashboard
    GatewayAPI -->|"HTTP/8265<br/>internal"| Dashboard
    OCPRoute -->|"HTTP/8265<br/>internal"| Dashboard
    K8sIngress -->|"HTTP/8265<br/>internal"| Dashboard

    %% Operators → K8s API
    KubeRayOp -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account"| K8sAPI
    KueueCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account"| K8sAPI

    %% Image pull
    RayHead -->|"HTTPS/443<br/>TLS<br/>Pull Secret"| Registry

    %% Styling
    classDef client fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class SDK client
    class K8sAPI controlplane
    class GatewayAPI,OCPRoute,K8sIngress ingress
    class RayHead,RayWorkers,GCS,Dashboard,ClientPort internal
    class KubeRayOp,KueueCtrl operator
    class Registry external
