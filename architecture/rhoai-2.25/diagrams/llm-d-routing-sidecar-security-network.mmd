%% Security Network Diagram: llm-d-routing-sidecar
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Scheduler<br/>Sets x-prefiller-host-port header"]
    end

    subgraph IngressZone["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>8080/TCP<br/>TLS Edge Termination"]
        Service["ClusterIP Service<br/>8080/TCP<br/>HTTP (no encryption)"]
        Route --> Service
    end

    subgraph SidecarZone["SIDECAR PROXY (Trust Boundary)"]
        direction TB

        Proxy["llm-d-routing-sidecar<br/>8000/TCP HTTPS<br/>TLS 1.2+ (6 cipher suites)<br/>SSRF Protection (optional)"]

        subgraph SSRFCheck["SSRF Validation"]
            Allowlist["Allowlist Validator<br/>InferencePool pod IPs<br/>30s resync"]
        end

        Proxy -->|validate target| Allowlist
    end

    subgraph PodBoundary["POD (Co-located Containers)"]
        Decoder["Local vLLM Decoder<br/>8001/TCP<br/>HTTP/HTTPS Optional TLS 1.2+"]
    end

    subgraph RemotePods["REMOTE PODS (Prefill Workers)"]
        Prefiller["Remote Prefiller Pods<br/>Dynamic Port<br/>HTTP/HTTPS Optional TLS 1.2+"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>ServiceAccount Token Auth"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    end

    %% Flows
    Client -->|"HTTPS/8000<br/>TLS 1.2+<br/>No Auth (upstream)"| Proxy
    Proxy -->|"HTTP or HTTPS/Dynamic<br/>Optional TLS 1.2+<br/>Prefill Phase"| Prefiller
    Prefiller -->|"kv_transfer_params<br/>(block IDs, engine, host)"| Proxy
    Proxy -->|"HTTP or HTTPS/8001<br/>Optional TLS 1.2+<br/>Decode Phase"| Decoder
    Decoder -->|"Streaming Response"| Proxy
    Proxy -->|"HTTPS/8000<br/>TLS 1.2+<br/>Response"| Client

    Allowlist -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    K8sAPI --- InferencePool

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Proxy sidecar
