graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Gateway / EPP"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
        Service["ClusterIP Service<br/>8080/TCP"]
    end

    subgraph PodBoundary["POD BOUNDARY (Decoder + Sidecar)"]
        direction TB

        subgraph SidecarContainer["Sidecar Container"]
            Proxy["llm-d-routing-sidecar<br/>8000/TCP<br/>TLS 1.2+ (AES-GCM, CHACHA20)<br/>SSRF Allowlist Validator"]
        end

        subgraph DecoderContainer["Decoder Container"]
            Decoder["vLLM Decoder<br/>8001/TCP (configurable)<br/>localhost"]
        end
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod Network)"]
        Prefiller1["vLLM Prefiller Pod 1<br/>dynamic IP/port<br/>InferencePool member"]
        Prefiller2["vLLM Prefiller Pod 2<br/>dynamic IP/port<br/>InferencePool member"]
        PrefillerN["vLLM Prefiller Pod N<br/>dynamic IP/port<br/>InferencePool member"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io<br/>/v1alpha2"]
        PodResources["Pod Resources<br/>(matching selector)"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>No Auth"| Route
    Route -->|"HTTP/8080<br/>Post-TLS-termination"| Service
    Service -->|"HTTP(S)/8000<br/>TLS 1.2+ (optional)"| Proxy

    %% Sidecar to Decoder (within pod)
    Proxy -->|"HTTP(S)/8001<br/>Optional TLS 1.2+<br/>--decoder-use-tls<br/>No Auth"| Decoder

    %% Sidecar to Prefillers (cross-pod)
    Proxy -->|"HTTP(S)/dynamic<br/>Optional TLS 1.2+<br/>--prefiller-use-tls<br/>SSRF Allowlist"| Prefiller1
    Proxy -.->|"HTTP(S)/dynamic"| Prefiller2
    Proxy -.->|"HTTP(S)/dynamic"| PrefillerN

    %% SSRF Allowlist watches
    Proxy -->|"HTTPS/443<br/>TLS<br/>SA Bearer Token<br/>Watch InferencePool + Pods"| APIServer
    APIServer --- InferencePool
    APIServer --- PodResources

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef decoder fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef prefiller fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e8e8e8,stroke:#666,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Proxy sidecar
    class Decoder decoder
    class Prefiller1,Prefiller2,PrefillerN prefiller
    class APIServer,InferencePool,PodResources controlplane
