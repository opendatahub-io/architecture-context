graph TB
    subgraph OperatorNS["Operator Namespace (redhat-ods-applications)"]
        Controller["DSPO Controller Manager<br/>Go Operator (controller-runtime)<br/>:8080 metrics, :8081 health"]
        Webhook["Pipeline Version Webhook<br/>:8443/TCP HTTPS<br/>Validates/Mutates PipelineVersion CRs"]
    end

    subgraph DSPANamespace["DSPA Namespace (per-tenant)"]
        subgraph PipelineCore["Pipeline Core Services"]
            APIServer["DS Pipeline API Server<br/>REST :8888/TCP | gRPC :8887/TCP<br/>OAuth Proxy :8443/TCP"]
            PersistenceAgent["Persistence Agent<br/>Syncs Argo Workflow status"]
            ScheduledWorkflow["Scheduled Workflow Controller<br/>Manages recurring pipeline runs"]
        end

        subgraph ExecutionEngine["Execution Engine"]
            ArgoController["Argo Workflow Controller<br/>Executes pipeline DAGs"]
            PipelinePods["Pipeline Pods<br/>(dynamically created)"]
        end

        subgraph MetadataLayer["ML Metadata Layer"]
            MLMDgRPC["MLMD gRPC Server<br/>:8080/TCP gRPC<br/>C++ implementation"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>:9090/TCP HTTP | :8443/TCP HTTPS<br/>HTTP-to-gRPC + OAuth"]
        end

        subgraph UI["User Interface"]
            PipelinesUI["ML Pipelines UI<br/>:8443/TCP HTTPS<br/>Node.js + OAuth Proxy"]
        end

        subgraph Storage["Data Storage (built-in or external)"]
            MariaDB["MariaDB<br/>:3306/TCP MySQL<br/>Pipeline metadata"]
            MinIO["MinIO<br/>:9000/TCP HTTP<br/>Artifact storage"]
        end
    end

    %% CRDs
    DSPACR["DataSciencePipelinesApplication CR"]
    PipelineCR["Pipeline / PipelineVersion CRs"]
    WorkflowCR["Argo Workflow CRs"]

    %% External
    User["User / Dashboard"]
    K8sAPI["Kubernetes API Server"]
    ServiceCA["OpenShift Service CA"]

    %% CR Relationships
    DSPACR -->|watched by| Controller
    Controller -->|creates/manages| APIServer
    Controller -->|creates/manages| PersistenceAgent
    Controller -->|creates/manages| ScheduledWorkflow
    Controller -->|creates/manages| ArgoController
    Controller -->|creates/manages| MLMDgRPC
    Controller -->|creates/manages| MLMDEnvoy
    Controller -->|creates/manages| PipelinesUI
    Controller -->|creates/manages| MariaDB
    Controller -->|creates/manages| MinIO
    Controller -->|health checks| MariaDB
    Controller -->|health checks| MinIO

    %% Data flow
    User -->|creates| DSPACR
    User -->|HTTPS :443| APIServer
    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| MinIO
    APIServer -->|creates| WorkflowCR
    WorkflowCR -->|watched by| ArgoController
    ArgoController -->|creates| PipelinePods
    PipelinePods -->|records metadata| MLMDgRPC
    MLMDgRPC -->|stores in| MariaDB
    PersistenceAgent -->|syncs status| APIServer

    %% Webhook
    K8sAPI -->|admission review| Webhook
    PipelineCR -->|validated by| Webhook

    %% TLS
    ServiceCA -->|injects certs| APIServer
    ServiceCA -->|injects certs| MLMDgRPC
    ServiceCA -->|injects certs| PipelinesUI

