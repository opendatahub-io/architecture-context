graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ml-pipeline"]
        SA_SWF["ml-pipeline-scheduledworkflow"]
        SA_PA["ml-pipeline-persistenceagent"]
        SA_Viewer["ml-pipeline-viewer-crd-<br/>service-account"]
        SA_Runner["pipeline-runner"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        CRB_API["ml-pipeline<br/>binding"]
        CRB_SWF["ml-pipeline-scheduledworkflow-<br/>binding"]
        CRB_PA["ml-pipeline-persistenceagent-<br/>binding"]
        CRB_Viewer["ml-pipeline-viewer-crd-<br/>binding"]
        CRB_Runner["pipeline-runner-<br/>binding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_API["ml-pipeline"]
        CR_SWF["ml-pipeline-scheduledworkflow-role"]
        CR_PA["ml-pipeline-persistenceagent-role"]
        CR_Viewer["ml-pipeline-viewer-controller-role"]
        CR_Runner["pipeline-runner"]
    end

    subgraph Resources_API["ml-pipeline Resources"]
        R_Pods["core: pods, pods/log<br/>get, list, delete"]
        R_Workflows_API["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SWF_API["kubeflow.org: scheduledworkflows,<br/>scheduledworkflows/finalizers<br/>create, get, list, update,<br/>patch, delete"]
        R_Pipelines_API["pipelines.kubeflow.org: pipelines<br/>get, list, watch"]
        R_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        R_TokenReview["authentication.k8s.io:<br/>tokenreviews<br/>create"]
    end

    subgraph Resources_SWF["SWF Controller Resources"]
        R_Workflows_SWF["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SWF_SWF["kubeflow.org: scheduledworkflows,<br/>scheduledworkflows/finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_Runs_SWF["pipelines.kubeflow.org: runs<br/>create"]
        R_Events["core: events<br/>create, patch"]
    end

    subgraph Resources_PA["Persistence Agent Resources"]
        R_Workflows_PA["argoproj.io: workflows<br/>get, list, watch"]
        R_SWF_PA["kubeflow.org: scheduledworkflows<br/>get, list, watch"]
        R_Runs_PA["pipelines.kubeflow.org:<br/>runs (reportMetrics, readArtifact)<br/>scheduledworkflows, workflows (report)"]
    end

    subgraph Resources_Viewer["Viewer Controller Resources"]
        R_Deploy_Viewer["*: deployments, services<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_Viewers["kubeflow.org: viewers,<br/>viewers/finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
    end

    subgraph Resources_Runner["Pipeline Runner Resources (Broad)"]
        R_Secrets_Runner["core: secrets<br/>get"]
        R_CM_Runner["core: configmaps<br/>get, watch, list"]
        R_PV_Runner["core: persistentvolumes,<br/>persistentvolumeclaims<br/>* (all verbs)"]
        R_Pods_Runner["core: pods, pods/exec,<br/>pods/log, services<br/>* (all verbs)"]
        R_Apps_Runner["apps, extensions: deployments,<br/>replicasets<br/>* (all verbs)"]
        R_Argo_Runner["argoproj.io: workflows<br/>get, list, watch,<br/>update, patch"]
        R_KF_Runner["kubeflow.org: *<br/>* (all verbs)"]
        R_Batch_Runner["batch: jobs<br/>* (all verbs)"]
        R_Seldon_Runner["machinelearning.seldon.io:<br/>seldondeployments<br/>* (all verbs)"]
        R_Snap_Runner["snapshot.storage.k8s.io:<br/>volumesnapshots<br/>create, delete, get"]
    end

    %% Bindings
    SA_API -->|"bound via"| CRB_API
    SA_SWF -->|"bound via"| CRB_SWF
    SA_PA -->|"bound via"| CRB_PA
    SA_Viewer -->|"bound via"| CRB_Viewer
    SA_Runner -->|"bound via"| CRB_Runner

    CRB_API -->|"grants"| CR_API
    CRB_SWF -->|"grants"| CR_SWF
    CRB_PA -->|"grants"| CR_PA
    CRB_Viewer -->|"grants"| CR_Viewer
    CRB_Runner -->|"grants"| CR_Runner

    %% Resource grants
    CR_API --> R_Pods
    CR_API --> R_Workflows_API
    CR_API --> R_SWF_API
    CR_API --> R_Pipelines_API
    CR_API --> R_SAR
    CR_API --> R_TokenReview

    CR_SWF --> R_Workflows_SWF
    CR_SWF --> R_SWF_SWF
    CR_SWF --> R_Runs_SWF
    CR_SWF --> R_Events

    CR_PA --> R_Workflows_PA
    CR_PA --> R_SWF_PA
    CR_PA --> R_Runs_PA

    CR_Viewer --> R_Deploy_Viewer
    CR_Viewer --> R_Viewers

    CR_Runner --> R_Secrets_Runner
    CR_Runner --> R_CM_Runner
    CR_Runner --> R_PV_Runner
    CR_Runner --> R_Pods_Runner
    CR_Runner --> R_Apps_Runner
    CR_Runner --> R_Argo_Runner
    CR_Runner --> R_KF_Runner
    CR_Runner --> R_Batch_Runner
    CR_Runner --> R_Seldon_Runner
    CR_Runner --> R_Snap_Runner

