graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>HTTPS TLS 1.2+<br/>Edge Termination"]
    end

    subgraph Cluster["KUBERNETES CLUSTER (Trusted)"]
        direction TB

        subgraph RegistryNS["Namespace: registry-namespace"]
            direction TB

            Service["Model Registry Service<br/>ClusterIP<br/>8443/TCP OAuth or 8080/TCP non-OAuth"]

            subgraph Pod["Model Registry Deployment Pod<br/>SA: name<br/>SCC: restricted-v2"]
                direction LR
                OAuthProxy["OAuth Proxy Container<br/>8443/TCP HTTPS<br/>TLS Cert: name-oauth-proxy<br/>Cookie: name-oauth-cookie-secret"]
                RESTContainer["REST Container<br/>8080/TCP HTTP<br/>API: /api/model_registry/v1alpha3/*"]

                OAuthProxy -->|localhost<br/>8080/TCP HTTP<br/>No Auth| RESTContainer
            end

            NetPol["NetworkPolicy: name-https-route<br/>Allows: network.openshift.io/policy-group=ingress<br/>Port: oauth-proxy-port/TCP"]

            Service --> Pod
        end

        subgraph OperatorNS["Namespace: operator-namespace"]
            direction TB

            Controller["Controller Manager<br/>SA: controller-manager<br/>Replicas: 1<br/>runAsNonRoot"]
            WebhookSvc["Webhook Service<br/>ClusterIP 443/TCP → 9443/TCP<br/>TLS: webhook-server-cert"]
            MetricsSvc["Metrics Service<br/>ClusterIP 8443/TCP<br/>kube-rbac-proxy"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]

        Controller -->|Watch/Manage CRs<br/>HTTPS TLS 1.2+<br/>ServiceAccount Token| K8sAPI
        K8sAPI -->|Validate/Mutate<br/>HTTPS TLS<br/>Webhook Client Cert| WebhookSvc
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        PostgreSQL["PostgreSQL Database<br/>spec.postgres.host:5432<br/>TLS optional sslMode<br/>Username/Password"]
        MySQL["MySQL Database<br/>spec.mysql.host:3306<br/>TLS optional<br/>Username/Password"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% External User Flows
    User -->|HTTPS 443/TCP<br/>TLS 1.2+<br/>Bearer Token| Router
    Router -->|HTTPS 8443/TCP<br/>TLS 1.2+<br/>Edge Termination| Service

    %% OAuth Validation
    OAuthProxy -->|Validate Token<br/>HTTPS 443/TCP<br/>TLS 1.2+<br/>ServiceAccount Token| OSAuth
    OAuthProxy -.->|Check RBAC<br/>GET permission on<br/>service/name| OSAuth

    %% Database Connections
    RESTContainer -->|PostgreSQL 5432/TCP<br/>TLS optional<br/>Username/Password| PostgreSQL
    RESTContainer -->|MySQL 3306/TCP<br/>TLS optional<br/>Username/Password| MySQL

    %% Metrics
    Prometheus -->|Scrape /metrics<br/>HTTPS 8443/TCP<br/>TLS<br/>Bearer Token| MetricsSvc

    %% Internal Pod Access - Non-OAuth Mode
    InternalPod[Internal Pod<br/>Cluster Access] -->|HTTP 8080/TCP<br/>No Auth<br/>Internal Only| Service

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Router ingress
    class Service,NetPol,InternalPod cluster
    class Controller,WebhookSvc,MetricsSvc,K8sAPI operator
    class PostgreSQL,MySQL,OSAuth,Prometheus externalservice
    class Pod,OAuthProxy,RESTContainer pod
