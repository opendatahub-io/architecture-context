graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / User"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        RouteHTTPS["{name}-https Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt<br/>Host: {name}-rest.{domain}"]
        CatalogRoute["model-catalog-https Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        RouteHTTP["{name}-http Route<br/>80/TCP (non-OAuth only)"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph MRPod["ModelRegistry Pod (per instance)"]
            direction TB
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>OpenShift OAuth2 SAR"]
            RESTContainer["REST Container<br/>(model-registry)<br/>{rest.port}/TCP HTTP"]
            gRPCContainer["gRPC Container<br/>(mlmd-grpc-server)<br/>{grpc.port}/TCP gRPC"]
            OAuthProxy -->|"HTTP/{rest.port}<br/>localhost<br/>No encryption<br/>OAuth validated"| RESTContainer
            RESTContainer -->|"gRPC/{grpc.port}<br/>localhost<br/>No encryption"| gRPCContainer
        end

        subgraph OperatorPod["Operator Pod (opendatahub ns)"]
            ControllerMgr["Controller Manager<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>Webhooks: 9443/TCP HTTPS"]
        end

        subgraph CatalogPod["Model Catalog Pod (singleton, optional)"]
            CatalogOAuth["OAuth Proxy<br/>8443/TCP HTTPS"]
            CatalogREST["Catalog REST Container"]
            CatalogOAuth -->|"localhost<br/>No encryption"| CatalogREST
        end
    end

    subgraph Services["SERVICES (ClusterIP)"]
        MetricsSvc["controller-manager-metrics-service<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>Bearer Token auth"]
        WebhookSvc["webhook-service<br/>443/TCP → 9443<br/>HTTPS TLS serving cert<br/>API server auth"]
        MRSvcOAuth["{name} Service (OAuth)<br/>{oauthProxy.port}/TCP HTTPS<br/>TLS serving cert"]
        MRSvcPlain["{name} Service (no OAuth)<br/>{rest.port}/TCP HTTP<br/>No auth"]
        CatalogSvc["model-catalog Service<br/>8443/TCP HTTPS<br/>TLS serving cert"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>ServiceAccount token"]
        OSConfig["OpenShift Config API<br/>443/TCP HTTPS TLS<br/>Ingress domain resolution"]
        ServingCert["OpenShift Serving Cert Controller<br/>Annotation-driven TLS provisioning"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Username + Password"]
        MySQL["MySQL<br/>3306/TCP<br/>Optional TLS<br/>Username + Password"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>Image pulls"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>OAuth2 Token"| RouteHTTPS
    Client -->|"HTTPS/443<br/>TLS<br/>OAuth2 Token"| CatalogRoute
    Client -->|"HTTP/80<br/>No auth"| RouteHTTP

    %% Ingress → App
    RouteHTTPS -->|"HTTPS/8443<br/>TLS reencrypt"| OAuthProxy
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt"| CatalogOAuth
    RouteHTTP -->|"HTTP/{rest.port}"| RESTContainer

    %% Operator → K8s
    ControllerMgr -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    ControllerMgr -->|"HTTPS/443<br/>TLS<br/>SA token"| OSConfig

    %% K8s → Operator (webhooks)
    K8sAPI -->|"HTTPS/443→9443<br/>TLS client cert<br/>Mutate/Validate/Convert"| WebhookSvc

    %% App → Database
    gRPCContainer -->|"DB wire protocol<br/>{db.port}/TCP<br/>Optional TLS<br/>User+Pass from Secret"| PostgreSQL
    gRPCContainer -->|"DB wire protocol<br/>{db.port}/TCP<br/>Optional TLS<br/>User+Pass from Secret"| MySQL

    %% Service → Pod connections
    MetricsSvc -.->|internal| ControllerMgr
    WebhookSvc -.->|internal| ControllerMgr
    MRSvcOAuth -.->|internal| OAuthProxy
    MRSvcPlain -.->|internal| RESTContainer
    CatalogSvc -.->|internal| CatalogOAuth

    %% Monitoring
    Prometheus["Prometheus<br/>(monitoring.coreos.com)"]
    Prometheus -->|"HTTPS/8443<br/>TLS serving cert<br/>Bearer Token"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RouteHTTPS,CatalogRoute,RouteHTTP ingress
    class OAuthProxy,RESTContainer,gRPCContainer,ControllerMgr,CatalogOAuth,CatalogREST app
    class MetricsSvc,WebhookSvc,MRSvcOAuth,MRSvcPlain,CatalogSvc service
    class K8sAPI,OSConfig,ServingCert controlplane
    class PostgreSQL,MySQL,Registry,Prometheus externalservice
