graph LR
    KVCache["llm-d KV-Cache<br/>(KV-Cache Manager +<br/>UDS Tokenizer +<br/>FS Backend +<br/>PVC Evictor)"]

    %% Required External Dependencies
    KVCache -->|"ZMQ PUB/SUB<br/>5557/TCP"| ZeroMQ["ZeroMQ (libzmq)<br/>4.x<br/>Required"]
    KVCache -->|"tokenizer framework<br/>offload API"| vLLM["vLLM<br/>0.19.1<br/>Required (Python)"]

    %% Optional External Dependencies
    KVCache -.->|"6379/TCP<br/>Redis protocol"| Redis["Redis / Valkey<br/>6.x+<br/>Optional"]
    KVCache -.->|"S3 via NIXL<br/>443/TCP HTTPS"| NIXL["NVIDIA NIXL<br/>Latest<br/>Optional"]
    KVCache -.->|"4317/TCP gRPC<br/>OTLP"| OTELCollector["OpenTelemetry Collector<br/>OTLP-compatible<br/>Optional"]
    KVCache -.->|"443/TCP HTTPS<br/>HF_TOKEN"| HFHub["HuggingFace Hub<br/>Latest<br/>Optional"]
    KVCache -.->|"8080/TCP HTTP<br/>/metrics scrape"| Prometheus["Prometheus<br/>2.x+<br/>Optional"]

    %% Internal Platform Dependencies
    EPP["llm-d Inference Scheduler<br/>(EPP)"] -->|"library embed<br/>(Go import)"| KVCache
    vLLMPods["vLLM Model Server Pods"] -->|"ZMQ PUB/SUB<br/>5557/TCP"| KVCache
    SGLangPods["SGLang Model Server Pods"] -.->|"ZMQ PUB/SUB<br/>5557/TCP"| KVCache
    KVCache -->|"pod watch/list<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% FS Backend specific
    KVCache -->|"POSIX I/O<br/>mount"| PVC["Shared Filesystem<br/>(PVC)"]
    KVCache -.->|"443/TCP HTTPS<br/>AWS IAM"| S3["S3 Object Store"]

