graph TD
    subgraph NotebookRepo["Notebooks Repository"]
        NoRBAC["No RBAC resources defined<br/>(images only, not an operator)"]
    end

    subgraph RuntimeRBAC["Runtime RBAC (managed by notebook controller)"]
        direction TB

        subgraph SidecarAuth["kube-rbac-proxy Sidecar (per pod)"]
            KubeRBAC["kube-rbac-proxy<br/>:8443/TCP HTTPS"]
        end

        subgraph AuthFlow["Authentication Flow"]
            User["Data Scientist<br/>(Browser)"]
            OAuthToken["OAuth Token<br/>(OpenShift)"]
            SAR["SubjectAccessReview<br/>(K8s API 6443/TCP)"]
        end

        User -->|presents| OAuthToken
        OAuthToken -->|validated by| KubeRBAC
        KubeRBAC -->|checks| SAR
        SAR -->|authorized?| Decision{Allow / Deny}
    end

    subgraph WorkbenchAccess["Workbench Access Control"]
        direction TB

        subgraph Endpoints["Protected Endpoints"]
            JupyterEP["JupyterLab :8888<br/>ALL methods"]
            CodeServerEP["code-server :8787<br/>ALL methods"]
            RStudioEP["RStudio :8787<br/>ALL methods"]
        end

        subgraph Policy["Access Policy"]
            PolicyRule["Only authenticated users<br/>with notebook access<br/>can reach the workbench"]
        end
    end

    subgraph PodServiceAccounts["Pod Service Accounts"]
        direction TB
        WB_SA["Workbench Pod SA<br/>(configured by notebook controller)"]
        RT_SA["Pipeline Runtime Pod SA<br/>(configured by KFP)"]

        subgraph WB_Permissions["Workbench Pod Permissions"]
            WB_K8s["Kubernetes API access<br/>6443/TCP HTTPS<br/>SA Bearer Token"]
            WB_S3["S3 storage access<br/>443/TCP HTTPS<br/>User-configured credentials"]
        end

        subgraph RT_Permissions["Runtime Pod Permissions"]
            RT_S3["S3 storage access<br/>443/TCP HTTPS<br/>AWS credentials"]
        end

        WB_SA --> WB_K8s
        WB_SA --> WB_S3
        RT_SA --> RT_S3
    end

    Decision -->|Allow| Endpoints
    Decision -->|Deny| Reject["403 Forbidden"]

    %% Styling
    style NoRBAC fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
    style KubeRBAC fill:#e74c3c,stroke:#c0392b,color:#fff
    style User fill:#4a90e2,stroke:#357abd,color:#fff
    style OAuthToken fill:#f5a623,stroke:#d68910,color:#fff
    style SAR fill:#f5a623,stroke:#d68910,color:#fff
    style Decision fill:#27ae60,stroke:#1e8449,color:#fff
    style Reject fill:#e74c3c,stroke:#c0392b,color:#fff
    style JupyterEP fill:#85bbf0,stroke:#4a90e2
    style CodeServerEP fill:#85bbf0,stroke:#4a90e2
    style RStudioEP fill:#85bbf0,stroke:#4a90e2
    style PolicyRule fill:#d5e8d4,stroke:#82b366
    style WB_SA fill:#8e44ad,stroke:#6c3483,color:#fff
    style RT_SA fill:#8e44ad,stroke:#6c3483,color:#fff
    style WB_K8s fill:#e1d5e7,stroke:#9673a6
    style WB_S3 fill:#e1d5e7,stroke:#9673a6
    style RT_S3 fill:#e1d5e7,stroke:#9673a6
