graph TD
    subgraph Notes["RBAC Overview"]
        Note1["This component does NOT define ClusterRoles or RoleBindings"]
        Note2["RBAC is managed by ODH Notebook Controller"]
        Note3["Workbench pods run with ServiceAccount created by Notebook Controller"]
    end

    subgraph RuntimeSAs["Runtime ServiceAccounts"]
        WorkbenchSA["ServiceAccount: notebook-name-sa<br/>Namespace: user-namespace"]
        PipelineSA["ServiceAccount: pipeline-name-sa<br/>Namespace: user-namespace"]
    end

    subgraph Permissions["Permissions - Granted by ODH Notebook Controller"]
        direction TB

        subgraph SecretAccess["Secret Access"]
            ReadSecrets["Read Secrets<br/>API: core/v1/secrets<br/>Verbs: get, list"]
        end

        subgraph ConfigMapAccess["ConfigMap Access"]
            ReadConfigMaps["Read ConfigMaps<br/>API: core/v1/configmaps<br/>Verbs: get, list"]
        end

        subgraph PodMgmt["Pod Management"]
            ManagePods["Manage Pods<br/>API: core/v1/pods<br/>Verbs: get, list, create, update"]
        end
    end

    subgraph Secrets["Secrets Used by Workbenches"]
        PullSecret["Pull Secret<br/>Type: kubernetes.io/dockerconfigjson<br/>Purpose: Pull images from Quay.io"]
        UserCreds["User Credentials<br/>Type: Opaque<br/>Purpose: S3 access, cloud credentials"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB

        OAuthProxy["OAuth Proxy Sidecar<br/>OpenShift OAuth Validation<br/>Enforces user identity"]

        OAuthPolicy["Authorization Policy:<br/>User must own namespace OR<br/>User has explicit RBAC permissions<br/>Validated via OpenShift OAuth"]
    end

    subgraph RegistryAuthFlow["Container Registry Auth"]
        RegistryAuth["Container Registry<br/>Image Pull Auth<br/>Mechanism: Pull Secret"]

        Kubelet["Kubelet<br/>Enforcement Point"]
    end

    UserRequest["User HTTP Request"]

    %% Relationships
    WorkbenchSA -->|granted by controller| ReadSecrets
    WorkbenchSA -->|granted by controller| ReadConfigMaps
    WorkbenchSA -->|granted by controller| ManagePods

    PipelineSA -->|granted by controller| ReadSecrets
    PipelineSA -->|granted by controller| ReadConfigMaps

    ReadSecrets -->|reads| PullSecret
    ReadSecrets -->|reads| UserCreds

    OAuthProxy -->|enforces| OAuthPolicy
    OAuthProxy -->|validates| UserRequest

    Kubelet -->|validates| RegistryAuth
    RegistryAuth -->|uses| PullSecret

    %% Styling
    classDef note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef permission fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef secret fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef auth fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    class Note1,Note2,Note3 note
    class WorkbenchSA,PipelineSA sa
    class ReadSecrets,ReadConfigMaps,ManagePods permission
    class PullSecret,UserCreds secret
    class OAuthProxy,OAuthPolicy,RegistryAuth,Kubelet,UserRequest auth
