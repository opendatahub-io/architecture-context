%% RBAC Visualization for Notebooks
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.25/notebooks.md

graph TD
    subgraph "Authentication Architecture"
        direction TB

        subgraph "RHOAI 3.x Pattern"
            User3x["User Browser"]
            Ingress3x["OpenShift Gateway API<br/>HTTPRoute"]
            KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS"]
            SAR["SubjectAccessReview<br/>Kubernetes API"]

            User3x -->|"HTTPS/443<br/>Bearer Token"| Ingress3x
            Ingress3x -->|"HTTPS/8443"| KRBAC
            KRBAC -->|"validates access"| SAR
        end

        subgraph "RHOAI 2.x Pattern"
            User2x["User Browser"]
            Route2x["OpenShift Route"]
            OAuthProxy["oauth-proxy sidecar"]
            OAuthProvider["OAuth Provider"]

            User2x -->|"HTTPS/443"| Route2x
            Route2x -->|"proxy"| OAuthProxy
            OAuthProxy -->|"validates"| OAuthProvider
        end
    end

    subgraph "Notebook Controller RBAC"
        direction TB

        NotebookCtrlSA["ServiceAccount<br/>notebook-controller-service-account<br/>Namespace: redhat-ods-applications"]

        subgraph "Controller Permissions"
            ISRead["ImageStreams<br/>image.openshift.io<br/>get, list, watch"]
            NotebookCR["Notebooks<br/>kubeflow.org<br/>get, list, watch, create, update, patch, delete"]
            PodMgmt["Pods, Services, Routes<br/>core, route.openshift.io<br/>get, list, watch, create, update, patch, delete"]
        end

        NotebookCtrlSA -->|"ClusterRoleBinding"| ISRead
        NotebookCtrlSA -->|"ClusterRoleBinding"| NotebookCR
        NotebookCtrlSA -->|"ClusterRoleBinding"| PodMgmt
    end

    subgraph "Operator RBAC"
        direction TB

        OperatorSA["ServiceAccount<br/>rhods-operator<br/>Namespace: redhat-ods-operator"]

        subgraph "Operator Permissions"
            ISMgmt["ImageStreams<br/>image.openshift.io<br/>get, list, watch, create, update, patch, delete"]
            CMgmt["ConfigMaps<br/>core<br/>get, list, watch, create, update, patch, delete"]
            BCMgmt["BuildConfigs<br/>build.openshift.io<br/>get, list, watch, create, update, patch, delete"]
        end

        OperatorSA -->|"ClusterRoleBinding"| ISMgmt
        OperatorSA -->|"ClusterRoleBinding"| CMgmt
        OperatorSA -->|"ClusterRoleBinding"| BCMgmt
    end

    subgraph "Notebook Pod Identity"
        direction TB

        NotebookSA["ServiceAccount<br/>(per notebook instance)<br/>Namespace: user-project"]

        subgraph "Pod Access"
            K8sAccess["Kubernetes API<br/>443/TCP HTTPS<br/>ServiceAccount token"]
            S3Access["S3 / Object Storage<br/>443/TCP HTTPS<br/>AWS credentials (user-provided)"]
        end

        NotebookSA -->|"mounted token"| K8sAccess
        NotebookSA -.->|"user-injected secrets"| S3Access
    end

    subgraph "Authorization Policy"
        direction TB
        Policy1["User must have access to notebook namespace"]
        Policy2["Namespace-scoped RBAC enforced by kube-rbac-proxy"]
        Policy3["No cluster-admin required for notebook users"]
    end

    %% Connections between sections
    KRBAC -.->|"enforces"| Policy1
    SAR -.->|"checks"| Policy2

