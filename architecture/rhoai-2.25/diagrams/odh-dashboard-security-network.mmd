graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph AuthBoundary["AUTHENTICATION BOUNDARY"]
        OAuthProxy["oauth-proxy Sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth 2.0<br/>Policy: list projects<br/>Cookie: _oauth_proxy"]
    end

    subgraph DashboardPod["APPLICATION LAYER (Pod-Internal)"]
        direction TB

        subgraph MainContainer["Main Container"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP (pod-internal)<br/>SA: odh-dashboard<br/>AuthZ: secureRoute()"]
        end

        subgraph MRSidecar["Model Registry Sidecar"]
            MRBFF["model-registry-ui BFF<br/>Go 1.25 (FIPS: strictfipsruntime)<br/>8043/TCP HTTPS TLS 1.3<br/>AuthZ: SAR/SSAR"]
        end
    end

    subgraph ClusterServices["CLUSTER-INTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>Bearer Token"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS TLS<br/>SA Token"]
        DSP["DS Pipelines<br/>8443/TCP HTTPS TLS<br/>Bearer Token"]
        MLMD["MLMD Envoy<br/>8443/TCP HTTPS TLS<br/>Bearer Token"]
        ModelRegistry["Model Registry API<br/>8080/TCP HTTP/HTTPS<br/>Bearer Token"]
        TrustyAI["TrustyAI<br/>443/TCP HTTPS TLS<br/>Bearer Token"]
        Feast["Feast Feature Store<br/>443/TCP HTTPS TLS<br/>Bearer Token"]
    end

    subgraph PlaintextServices["PLAINTEXT SERVICES (Risk)"]
        LlamaStack["LlamaStack<br/>8321/TCP HTTP<br/>*** NO TLS ***<br/>API Key"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Segment["Segment.io<br/>443/TCP HTTPS TLS<br/>API Key"]
    end

    %% Flows - External to Auth
    Browser -->|"HTTPS/443<br/>TLS Edge<br/>OAuth Cookie"| Route
    Route -->|"HTTPS/8443<br/>TLS Reencrypt<br/>Cookie Passthrough"| OAuthProxy

    %% Auth to Backend
    OAuthProxy -->|"HTTP/8080<br/>No Encryption (localhost)<br/>x-forwarded-access-token"| Backend

    %% Backend to MR BFF (pod-internal)
    Backend -->|"HTTPS/8043<br/>TLS (shared cert)<br/>x-forwarded-access-token"| MRBFF

    %% Backend Egress
    Backend -->|"HTTPS/443<br/>Bearer Token (user/SA)"| K8sAPI
    Backend -->|"HTTPS/9092<br/>SA Token"| Thanos
    Backend -->|"HTTPS/8443<br/>Bearer Token"| DSP
    Backend -->|"HTTPS/8443<br/>Bearer Token"| MLMD
    Backend -->|"HTTPS/443<br/>Bearer Token"| TrustyAI
    Backend -->|"HTTPS/443<br/>Bearer Token"| Feast
    Backend -->|"HTTP/8321<br/>API Key<br/>*** PLAINTEXT ***"| LlamaStack
    Backend -->|"HTTPS/443<br/>API Key"| Segment

    %% MR BFF Egress
    MRBFF -->|"HTTPS/443<br/>Bearer Token<br/>SAR/SSAR"| K8sAPI
    MRBFF -->|"HTTP/8080<br/>Bearer Token"| ModelRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef risk fill:#f8cecc,stroke:#b85450,stroke-width:3px
    classDef extservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Browser external
    class Route ingress
    class OAuthProxy auth
    class Backend,MRBFF app
    class K8sAPI,Thanos,DSP,MLMD,ModelRegistry,TrustyAI,Feast cluster
    class LlamaStack risk
    class Segment extservice
