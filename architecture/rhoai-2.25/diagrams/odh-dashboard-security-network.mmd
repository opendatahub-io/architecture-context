graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (edge mode)"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        OAuthProxy["OAuth Proxy Sidecar<br/>SA: odh-dashboard<br/>Port: 8443/TCP (external)<br/>Port: 8080/TCP (backend)<br/>TLS: dashboard-proxy-tls<br/>Health: /oauth/healthz"]
        OAuthServer["OpenShift OAuth Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth 2.0"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph NS_Dashboard["Namespace: opendatahub / redhat-ods-applications"]
            Backend["Dashboard Backend<br/>Fastify + Node.js 20<br/>SA: odh-dashboard<br/>Port: 8080/TCP HTTP<br/>Replicas: 2<br/>CPU: 500m-1000m<br/>Mem: 1Gi-2Gi<br/>Health: /api/health"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth<br/>RBAC: odh-dashboard ClusterRole"]
    end

    subgraph Observability["OBSERVABILITY LAYER"]
        Prometheus["Prometheus/Thanos<br/>openshift-monitoring<br/>Scrape: odh-dashboard:8443/metrics<br/>Query: 9092/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ODHComponents["INTERNAL ODH COMPONENTS"]
        ODHOperator["opendatahub-operator<br/>DataScienceCluster<br/>DSCInitialization"]
        KubeflowNB["Kubeflow Notebooks<br/>Notebook CR"]
        KServe["KServe<br/>InferenceService CR"]
        ModelReg["Model Registry<br/>ModelRegistry CR"]
    end

    subgraph Secrets["SECRETS"]
        TLSSecret["dashboard-proxy-tls<br/>kubernetes.io/tls<br/>Auto-rotate: Yes (2yr)"]
        OAuthCookie["dashboard-oauth-config-generated<br/>Opaque (cookie secret)"]
        OAuthClient["dashboard-oauth-client-generated<br/>Opaque (OAuth client)"]
        SAToken["odh-dashboard SA Token<br/>Auto-rotate: Yes (1hr)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| Router
    Router -->|"HTTPS/8443<br/>TLS 1.2+<br/>Re-encrypted"| OAuthProxy
    OAuthProxy -->|"OAuth Flow<br/>HTTPS/6443<br/>TLS 1.2+<br/>OAuth 2.0"| OAuthServer
    OAuthProxy -->|"HTTP/8080<br/>Localhost<br/>Bearer Token (header)"| Backend
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Backend -->|"HTTPS/9092<br/>TLS 1.2+<br/>ServiceAccount Token"| Prometheus
    Prometheus -->|"Scrape /metrics<br/>HTTPS/8443<br/>No Auth (bypass)"| OAuthProxy

    %% Component interactions via K8s API
    Backend -.->|"CRD Read/Write<br/>via K8s API"| ODHOperator
    Backend -.->|"CRD Manage<br/>via K8s API"| KubeflowNB
    Backend -.->|"CRD Read<br/>via K8s API"| KServe
    Backend -.->|"CRD Manage<br/>via K8s API"| ModelReg

    %% Secret mounting
    TLSSecret -.->|"Mounted"| OAuthProxy
    OAuthCookie -.->|"Env Var"| OAuthProxy
    OAuthClient -.->|"Env Var"| OAuthProxy
    SAToken -.->|"Mounted"| Backend

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef app fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef controlplane fill:#f5a623,stroke:#333,stroke-width:2px
    classDef observability fill:#e1bee7,stroke:#8e24aa,stroke-width:2px
    classDef odhcomponent fill:#7ed321,stroke:#333,stroke-width:2px
    classDef secrets fill:#ffccbc,stroke:#d84315,stroke-width:2px

    class Client external
    class Router ingress
    class OAuthProxy,OAuthServer auth
    class Backend app
    class K8sAPI controlplane
    class Prometheus observability
    class ODHOperator,KubeflowNB,KServe,ModelReg odhcomponent
    class TLSSecret,OAuthCookie,OAuthClient,SAToken secrets
