graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide scope)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Permitted Verbs"]
        direction LR
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permits access to"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph AuthDelegation["Authentication Delegation (Infrastructure Level)"]
        direction TB
        AuthNote["All REST endpoint auth is delegated<br/>to infrastructure-level sidecars"]
        KubeRBAC["kube-rbac-proxy sidecar<br/>(injected by TrustyAI Operator)"]
        OAuthProxy["oauth-proxy sidecar<br/>(alternative, injected by Operator)"]
    end

    subgraph MetricsAuth["Metrics Endpoint Auth"]
        MetricsSA["ServiceAccount Token<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token"]
        MetricsEndpoint["/q/metrics<br/>Bearer Token auth"]
    end

    subgraph OpenEndpoints["Unauthenticated Endpoints"]
        HealthLive["/q/health/live<br/>Liveness probe"]
        HealthReady["/q/health/ready<br/>Readiness probe"]
    end

    SA -.->|"token used for"| MetricsSA
    MetricsSA -->|"Bearer Token"| MetricsEndpoint

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#e8f5e9,stroke:#388E3C
    style Delete fill:#ffebee,stroke:#C62828
    style Get fill:#e8f5e9,stroke:#388E3C
    style List fill:#e8f5e9,stroke:#388E3C
    style Patch fill:#fff3e0,stroke:#F57C00
    style Update fill:#fff3e0,stroke:#F57C00
    style Watch fill:#e8f5e9,stroke:#388E3C

    style KubeRBAC fill:#f8cecc,stroke:#b85450
    style OAuthProxy fill:#f8cecc,stroke:#b85450
    style AuthNote fill:#fff9c4,stroke:#F9A825

    style MetricsSA fill:#dae8fc,stroke:#6c8ebf
    style MetricsEndpoint fill:#dae8fc,stroke:#6c8ebf
    style HealthLive fill:#d5e8d4,stroke:#82b366
    style HealthReady fill:#d5e8d4,stroke:#82b366
