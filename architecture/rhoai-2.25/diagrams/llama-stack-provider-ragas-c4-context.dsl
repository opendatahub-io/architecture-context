// C4 Context Diagram: llama-stack-provider-ragas
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Runs RAG evaluation benchmarks via Llama Stack API"

        llamaStackProviderRagas = softwareSystem "llama-stack-provider-ragas" "Llama Stack evaluation provider integrating Ragas framework for RAG quality assessment" {
            inlineProvider = container "RagasEvaluatorInline" "Runs Ragas evaluation in-process within Llama Stack server" "Python Plugin"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluation jobs to Kubeflow Pipelines" "Python Plugin"
            inlineWrappers = container "Inline Wrappers" "LlamaStackInlineLLM, LlamaStackInlineEmbeddings - adapts Llama Stack internal APIs to Ragas interfaces" "Python"
            remoteWrappers = container "Remote Wrappers" "LlamaStackRemoteLLM, LlamaStackRemoteEmbeddings - adapts Llama Stack client SDK to Ragas interfaces" "Python"
            kfpPipeline = container "KFP Pipeline" "ragas_evaluation_pipeline - two-step pipeline: retrieve dataset, run evaluation" "KFP Components"
        }

        llamaStack = softwareSystem "Llama Stack Server" "Llama Stack framework providing Eval, Inference, and DatasetIO APIs" "Internal RHOAI"
        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Deploys and manages Llama Stack server instances on OpenShift" "Internal RHOAI"
        kfp = softwareSystem "Data Science Pipelines (Kubeflow Pipelines)" "Orchestrates multi-step ML pipelines on Kubernetes" "Internal RHOAI"
        s3 = softwareSystem "S3-Compatible Storage" "Stores and retrieves evaluation results" "External"
        ollama = softwareSystem "Ollama" "LLM inference and embeddings backend (sample distribution)" "External"
        trustyai = softwareSystem "TrustyAI" "AI trustworthiness and explainability platform (parent project)" "Internal RHOAI"

        // User interactions
        user -> llamaStack "Submits eval benchmarks via REST API" "HTTP/8321"
        llamaStack -> llamaStackProviderRagas "Loads as eval provider plugin" "In-process"

        // Inline mode
        inlineProvider -> inlineWrappers "Uses for Ragas LLM/Embeddings interface"
        inlineWrappers -> llamaStack "Calls internal Inference API" "In-process"

        // Remote mode
        remoteProvider -> kfp "Submits pipeline runs" "HTTPS/443 Bearer Token"
        kfpPipeline -> llamaStack "Retrieves datasets, calls inference" "HTTP(S)/configurable"
        kfpPipeline -> s3 "Stores evaluation results" "HTTPS/443 AWS IAM"
        remoteProvider -> s3 "Reads evaluation results" "HTTPS/443 AWS IAM"
        remoteWrappers -> llamaStack "Calls Llama Stack from KFP pods" "HTTP(S)/configurable"

        // Infrastructure
        llamaStackOperator -> llamaStack "Deploys and manages"
        llamaStack -> ollama "Inference backend (sample)" "HTTP/11434"
    }

    views {
        systemContext llamaStackProviderRagas "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackProviderRagas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
