graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Dashboard / CLI / SDK)"]
    end

    subgraph Ingress["INGRESS (Istio Service Mesh)"]
        VirtualService["Istio VirtualService<br/>kubeflow-gateway<br/>DestinationRule: ISTIO_MUTUAL<br/>AuthorizationPolicy: ALLOW all"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            MRService["Model Registry REST API<br/>model-registry-service:8080/TCP<br/>SA: model-registry<br/>Image: odh-model-registry-container<br/>FIPS: strictfipsruntime"]

            MRCatalog["Model Catalog Service<br/>8080/TCP (shared binary)<br/>API: /api/model_catalog/v1alpha1/*"]

            MRDB["MySQL 8.3+ / PostgreSQL 14.7+<br/>model-registry-db:3306/5432/TCP<br/>Auth: Username/password<br/>PVC: 10Gi"]
        end

        subgraph NS_Controller["Namespace: kubeflow"]
            Controller["Controller Manager<br/>SA: controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP (HTTPS, self-signed)<br/>HTTP/2: DISABLED"]
        end

        subgraph NS_KServe["Namespace: user workloads"]
            CSIInit["CSI Storage Initializer<br/>(init container)<br/>model-registry:// protocol"]

            AsyncJob["Async Upload Job<br/>(Python, on-demand)<br/>skopeo for OCI ops"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]

        HFHub["HuggingFace Hub API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer token (API key)"]

        S3["S3 / MinIO Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]

        OCIReg["OCI Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker config auth"]

        Prometheus["Prometheus<br/>Scrapes 8443/TCP<br/>HTTPS, self-signed TLS<br/>TokenReview + SAR"]
    end

    %% External → Ingress
    Client -->|"HTTP/8080<br/>Istio mTLS"| VirtualService

    %% Ingress → Service
    VirtualService -->|"HTTP/8080<br/>mTLS ISTIO_MUTUAL<br/>Service Identity"| MRService

    %% Internal Service Flows
    MRService -->|"MySQL: 3306/TCP<br/>PG: 5432/TCP<br/>Optional TLS<br/>Username/password"| MRDB

    Controller -->|"HTTP/8080<br/>Optional TLS<br/>Bearer token"| MRService
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI

    CSIInit -->|"HTTP/8080<br/>Optional TLS<br/>No auth"| MRService
    CSIInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    AsyncJob -->|"HTTP/8080<br/>Optional TLS<br/>Bearer token"| MRService
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker config"| OCIReg

    MRCatalog -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| HFHub

    Prometheus -->|"HTTPS/8443<br/>self-signed TLS<br/>TokenReview + SAR"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class VirtualService ingress
    class MRService,MRCatalog,Controller,CSIInit,AsyncJob servicemesh
    class MRDB database
    class K8sAPI,HFHub,S3,OCIReg,Prometheus externalservice
