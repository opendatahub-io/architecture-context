graph LR
    DSP["Data Science<br/>Pipelines"]

    %% External Dependencies (Required)
    DSP -->|"execution engine<br/>Workflow CRDs"| Argo["Argo Workflows<br/>v3.5.x"]
    DSP -->|"metadata storage<br/>TCP 3306"| MySQL["MySQL 5.7+"]
    DSP -.->|"alt metadata storage<br/>TCP 5432"| PostgreSQL["PostgreSQL 12+"]
    DSP -->|"artifact storage<br/>HTTP(S) 9000"| MinIO["MinIO<br/>(S3-compatible)"]
    DSP -->|"lineage tracking<br/>gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"CRDs, RBAC, pods<br/>HTTPS 6443"| K8s["Kubernetes<br/>1.27+"]

    %% External Cloud Storage (Optional)
    DSP -.->|"cloud artifacts<br/>HTTPS 443"| S3["AWS S3"]
    DSP -.->|"cloud artifacts<br/>HTTPS 443"| GCS["Google Cloud<br/>Storage"]

    %% Internal RHOAI Dependencies
    RHOAIOp["RHOAI Operator"] -->|"deploys via<br/>DSPA CR"| DSP
    Dashboard["ODH Dashboard"] -->|"REST API<br/>HTTP 8888"| DSP
    DSP -.->|"SeldonDeployment<br/>CRD access"| Seldon["Seldon Core"]

    %% ConfigMaps and Secrets
    DSP -->|"reads config"| PIC["pipeline-install-config<br/>ConfigMap"]
    DSP -->|"reads config"| KFL["kfp-launcher<br/>ConfigMap"]
    DSP -->|"reads credentials"| MYS["mysql-secret<br/>Secret"]
    DSP -->|"reads credentials"| MAS["mlpipeline-minio-artifact<br/>Secret"]
    DSP -->|"reads TLS cert"| WTS["webhook-server-tls<br/>Secret"]

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style Argo fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MinIO fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff

    style S3 fill:#f5a623,stroke:#333,color:#000
    style GCS fill:#f5a623,stroke:#333,color:#000

    style RHOAIOp fill:#7ed321,stroke:#333,color:#000
    style Dashboard fill:#7ed321,stroke:#333,color:#000
    style Seldon fill:#7ed321,stroke:#333,color:#000

    style PIC fill:#e8e8e8,stroke:#333,color:#000
    style KFL fill:#e8e8e8,stroke:#333,color:#000
