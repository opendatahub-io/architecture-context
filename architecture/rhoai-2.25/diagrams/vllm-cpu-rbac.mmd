%% Source: architecture/rhoai-2.25/vllm-cpu.md
%% Note: vllm-cpu is a container image, not a Kubernetes operator.
%% It does not define its own RBAC resources. RBAC is managed by KServe/ModelMesh.
%% This diagram shows the authentication and authorization model at the application level.
graph TD
    subgraph "Application-Level Auth (vLLM-CPU)"
        APIKey["API Key<br/>(--api-key / VLLM_API_KEY)"]
        TLSCerts["TLS Certificates<br/>(--ssl-certfile / --ssl-keyfile)"]
    end

    subgraph "Authentication Enforcement"
        FastAPIMiddleware["FastAPI Middleware<br/>Bearer Token Validation"]
        UvicornSSL["Uvicorn SSL<br/>TLS Client Certs (optional)"]
    end

    subgraph "Endpoint Access Control"
        ProtectedEndpoints["Protected Endpoints<br/>/v1/chat/completions<br/>/v1/completions<br/>/v1/embeddings<br/>/v1/models<br/>/v1/score<br/>/v1/rerank<br/>/v1/responses<br/>/v1/audio/*"]
        PublicEndpoints["Public Endpoints<br/>(Always Unauthenticated)<br/>/health<br/>/ping<br/>/metrics"]
    end

    subgraph "Deploying Operator RBAC"
        KServeRBAC["KServe RBAC<br/>Manages ServiceAccounts<br/>and RoleBindings for<br/>InferenceService pods"]
        ModelMeshRBAC["ModelMesh RBAC<br/>Manages ServiceAccounts<br/>and RoleBindings for<br/>ServingRuntime pods"]
    end

    subgraph "Secrets Management"
        SSLKeyFile["ssl-keyfile<br/>(File mount)<br/>Auto-rotate: SSLCertRefresher"]
        SSLCertFile["ssl-certfile<br/>(File mount)<br/>Auto-rotate: SSLCertRefresher"]
        SSLCACerts["ssl-ca-certs<br/>(File mount)<br/>Auto-rotate: SSLCertRefresher"]
        HFToken["hf-token<br/>(Env: HF_TOKEN)<br/>No auto-rotate"]
        VLLMAPIKey["api-key<br/>(Env: VLLM_API_KEY)<br/>No auto-rotate"]
    end

    APIKey -->|"validates requests"| FastAPIMiddleware
    TLSCerts -->|"enables TLS"| UvicornSSL
    FastAPIMiddleware -->|"protects"| ProtectedEndpoints
    FastAPIMiddleware -.->|"bypasses auth"| PublicEndpoints
    UvicornSSL -->|"encrypts all traffic"| ProtectedEndpoints
    UvicornSSL -->|"encrypts all traffic"| PublicEndpoints

    KServeRBAC -->|"creates SA for"| ProtectedEndpoints
    ModelMeshRBAC -->|"creates SA for"| ProtectedEndpoints

    VLLMAPIKey -->|"provides"| APIKey
    SSLKeyFile -->|"provides"| TLSCerts
    SSLCertFile -->|"provides"| TLSCerts
    SSLCACerts -->|"provides"| TLSCerts
    HFToken -.->|"HF Hub auth"| ProtectedEndpoints

