graph TD
    subgraph "Runtime Identity"
        Pod["vllm-cpu Pod<br/>UID: 2000 (non-root)<br/>Base: UBI 9 minimal"]
    end

    subgraph "Note: No Kubernetes RBAC"
        Note["vllm-cpu is a runtime service,<br/>NOT a Kubernetes operator.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined.<br/><br/>RBAC is managed by KServe<br/>ServingRuntime that deploys<br/>this container."]
    end

    subgraph "Application-Level Authentication"
        direction TB
        APIKeyAuth["API Key Authentication<br/>Mechanism: SHA-256 hash comparison<br/>Source: VLLM_API_KEY env / --api-key flag<br/>Enforcement: FastAPI AuthenticationMiddleware<br/>Timing-safe: secrets.compare_digest"]
    end

    subgraph "Protected Endpoints (API Key Required)"
        V1Chat["/v1/chat/completions — POST"]
        V1Comp["/v1/completions — POST"]
        V1Embed["/v1/embeddings — POST"]
        V1Models["/v1/models — GET"]
        V1Resp["/v1/responses — POST"]
        V1Score["/v1/score — POST"]
        V1Rerank["/v1/rerank — POST"]
        V1Token["/tokenize — POST"]
        V1Detoken["/detokenize — POST"]
    end

    subgraph "Unauthenticated Endpoints (No Auth)"
        Health["/health — GET"]
        Ping["/ping — GET"]
        Metrics["/metrics — GET"]
        Load["/load — GET"]
        Version["/version — GET"]
    end

    subgraph "Secrets Used"
        HFToken["HF_TOKEN<br/>Type: Opaque<br/>Purpose: HuggingFace Hub auth<br/>Provisioned by: User/Operator<br/>Auto-rotate: No"]
        S3Creds["S3_ACCESS_KEY_ID /<br/>S3_SECRET_ACCESS_KEY<br/>Type: Opaque<br/>Purpose: S3 storage auth<br/>Provisioned by: User<br/>Auto-rotate: No"]
        APIKey["VLLM_API_KEY<br/>Type: Opaque<br/>Purpose: Client request auth<br/>Provisioned by: User<br/>Auto-rotate: No"]
        TLSCert["SSL key/cert<br/>Type: kubernetes.io/tls<br/>Purpose: TLS encryption<br/>Provisioned by: cert-manager<br/>Auto-rotate: Optional<br/>(--enable-ssl-refresh)"]
    end

