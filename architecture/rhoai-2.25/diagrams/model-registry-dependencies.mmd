    style KnativeServing fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style MRPython fill:#999,stroke:#333,color:#fff
    style Boto3 fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style KServeISVC fill:#7ed321,stroke:#333,color:#fff
    style KServeCSC fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
