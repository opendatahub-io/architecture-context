graph LR
    MR["Model Registry<br/>(REST API + Catalog + Controller + CSI + Async Job)"]

    %% Required External Dependencies
    subgraph RequiredExternal["Required External Dependencies"]
        MySQL["MySQL 8.3+"]
        PostgreSQL["PostgreSQL 14.7+"]
        GORM["GORM v1.30.1"]
        GolangMigrate["golang-migrate v4.18.3"]
        GoChi["go-chi v5.2.2"]
    end

    MR -->|"metadata storage<br/>3306/TCP"| MySQL
    MR -->|"metadata storage<br/>5432/TCP"| PostgreSQL
    MR -->|"ORM layer"| GORM
    MR -->|"schema migrations"| GolangMigrate
    MR -->|"HTTP routing"| GoChi

    %% Optional External Dependencies
    subgraph OptionalExternal["Optional External Dependencies"]
        KServe["KServe v0.15.2"]
        KnativeServing["Knative Serving 0.44.0"]
        ControllerRuntime["controller-runtime v0.21.0"]
        MRPython["model-registry Python 0.3.0"]
        Boto3["boto3 1.40.25"]
        HFHub["huggingface-hub 1.6.0+"]
        Skopeo["skopeo (system)"]
    end

    MR -->|"ISVC CRD watch"| KServe
    KServe -.->|"transitive"| KnativeServing
    MR -->|"controller framework"| ControllerRuntime
    MR -->|"Python client"| MRPython
    MR -->|"S3 access"| Boto3
    MR -->|"model downloads"| HFHub
    MR -->|"OCI image copy"| Skopeo

    %% Internal Platform Dependencies
    subgraph InternalPlatform["Internal Platform Dependencies"]
        Istio["Istio Service Mesh<br/>(sidecar, mTLS, AuthzPolicy)"]
        KServeISVC["KServe InferenceService<br/>(CRD Watch)"]
        KServeCSC["KServe ClusterStorageContainer<br/>(model-registry:// URIs)"]
    end

    MR -->|"mTLS, traffic mgmt"| Istio
    MR -->|"CRD reconciliation"| KServeISVC
    MR -->|"storage protocol"| KServeCSC

    %% Integration Points (consumers)
    subgraph Consumers["Consumers / Integrations"]
        Dashboard["RHOAI Dashboard<br/>(REST API consumer)"]
        Prometheus["Prometheus<br/>(metrics scraping)"]
    end

    Dashboard -->|"HTTP/8080<br/>Istio mTLS"| MR
    Prometheus -->|"HTTPS/8443<br/>TokenReview"| MR

    %% External Services (runtime)
    subgraph ExternalServices["External Services (Runtime)"]
        S3["S3 / MinIO<br/>443/TCP"]
        OCIReg["OCI Container Registry<br/>443/TCP"]
        HFHubAPI["HuggingFace Hub API<br/>443/TCP"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    end

    MR -->|"model artifacts"| S3
    MR -->|"model images"| OCIReg
    MR -->|"catalog browsing"| HFHubAPI
    MR -->|"CRD operations"| K8sAPI

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style GORM fill:#999,stroke:#333,color:#fff
    style GolangMigrate fill:#999,stroke:#333,color:#fff
    style GoChi fill:#999,stroke:#333,color:#fff
