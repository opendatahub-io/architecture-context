graph TB
    subgraph UserAccess["User Access"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph Platform["RHOAI Platform"]
        Dashboard["RHOAI Dashboard"]
        NotebookCtrl["odh-notebook-controller"]
        Operator["rhods-operator"]
        ImageStreams["OpenShift ImageStreams<br/>(manifests/base)"]
    end

    subgraph WorkbenchPod["Workbench Pod (StatefulSet)"]
        direction TB
        KubeRBAC["kube-rbac-proxy<br/>:8443/TCP HTTPS"]

        subgraph IDELayer["IDE Layer"]
            JupyterLab["JupyterLab<br/>:8888/TCP"]
            CodeServer["code-server<br/>:9999/TCP"]
            RStudio["RStudio Server<br/>:8787/TCP"]
        end

        subgraph ProxyLayer["Proxy Layer (code-server/RStudio only)"]
            NGINX["NGINX Proxy<br/>:8787/TCP"]
            HTTPD["httpd CGI<br/>:8080/TCP"]
        end

        KubeRBAC -->|auth passed| JupyterLab
        KubeRBAC -->|auth passed| NGINX
        NGINX --> CodeServer
        NGINX --> RStudio
        HTTPD -->|kernel access<br/>validation| CodeServer
        HTTPD -->|kernel access<br/>validation| RStudio
    end

    subgraph WorkbenchImages["Workbench Images (Build Layers)"]
        direction TB

        subgraph CPUChain["CPU Build Chain"]
            AIPCC_CPU["AIPCC Base (CPU)"] --> MinimalCPU["jupyter-minimal"]
            MinimalCPU --> DataSciCPU["jupyter-datascience"]
            DataSciCPU --> TrustyAI["jupyter-trustyai"]
        end

        subgraph CUDAChain["CUDA Build Chain"]
            AIPCC_CUDA["AIPCC Base (CUDA)"] --> MinimalCUDA["jupyter-minimal-cuda"]
            MinimalCUDA --> DataSciCUDA["jupyter-datascience-cuda"]
            DataSciCUDA --> PyTorchCUDA["jupyter-pytorch"]
            DataSciCUDA --> TensorFlowCUDA["jupyter-tensorflow"]
            DataSciCUDA --> LLMCompressor["jupyter-pytorch-llmcompressor"]
        end

        subgraph ROCmChain["ROCm Build Chain"]
            AIPCC_ROCm["AIPCC Base (ROCm)"] --> MinimalROCm["jupyter-minimal-rocm"]
        end

        subgraph NonJupyter["Non-Jupyter IDEs"]
            CS["codeserver"]
            RS_CPU["rstudio-cpu"]
            RS_CUDA["rstudio-cuda"]
        end
    end

    subgraph RuntimeImages["Runtime Images (Elyra Pipelines)"]
        RT_Min["runtime-minimal"]
        RT_DS["runtime-datascience"]
        RT_PT["runtime-pytorch"]
        RT_TF["runtime-tensorflow"]
        RT_LLM["runtime-pytorch-llmcompressor"]
        RT_ROCm_PT["runtime-rocm-pytorch"]
        RT_ROCm_TF["runtime-rocm-tensorflow"]
    end

    User -->|HTTPS/443| Dashboard
    Dashboard -->|selects image| ImageStreams
    Operator -->|deploys| ImageStreams
    Dashboard -->|creates Workbench| NotebookCtrl
    NotebookCtrl -->|creates StatefulSet<br/>+ injects kube-rbac-proxy| WorkbenchPod
    User -->|HTTPS/8443| KubeRBAC

    %% Styling
    style KubeRBAC fill:#e74c3c,stroke:#c0392b,color:#fff
    style JupyterLab fill:#4a90e2,stroke:#357abd,color:#fff
    style CodeServer fill:#4a90e2,stroke:#357abd,color:#fff
    style RStudio fill:#4a90e2,stroke:#357abd,color:#fff
    style NGINX fill:#27ae60,stroke:#1e8449,color:#fff
    style HTTPD fill:#27ae60,stroke:#1e8449,color:#fff
    style Dashboard fill:#8e44ad,stroke:#6c3483,color:#fff
    style NotebookCtrl fill:#8e44ad,stroke:#6c3483,color:#fff
    style Operator fill:#8e44ad,stroke:#6c3483,color:#fff
    style User fill:#f39c12,stroke:#d68910,color:#fff
    style AIPCC_CPU fill:#95a5a6,stroke:#7f8c8d,color:#fff
    style AIPCC_CUDA fill:#95a5a6,stroke:#7f8c8d,color:#fff
    style AIPCC_ROCm fill:#95a5a6,stroke:#7f8c8d,color:#fff
