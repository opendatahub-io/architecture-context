graph TB
    subgraph "Notebooks Component (Container Images)"
        subgraph "Workbench Images"
            JupyterCPU[Jupyter Minimal CPU<br/>Python 3.12, JupyterLab 4.4]
            JupyterCUDA[Jupyter Minimal CUDA<br/>NVIDIA GPU, CUDA 12.6/12.8]
            JupyterROCm[Jupyter Minimal ROCm<br/>AMD GPU, ROCm 6.2/6.4]
            JupyterDataScience[Jupyter Data Science<br/>Pandas, Scikit-learn, Matplotlib]
            JupyterPyTorchCUDA[Jupyter PyTorch CUDA<br/>PyTorch 2.x, NVIDIA GPU]
            JupyterPyTorchROCm[Jupyter PyTorch ROCm<br/>PyTorch 2.x, AMD GPU]
            JupyterTensorFlowCUDA[Jupyter TensorFlow CUDA<br/>TensorFlow 2.x, NVIDIA GPU]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainable AI, Pandas]
            CodeServerDS[Code Server Data Science<br/>VS Code IDE, Python 3.12]
            RStudioCPU[RStudio Minimal CPU<br/>R 4.x, Python 3.11]
            RStudioCUDA[RStudio CUDA<br/>R 4.x, NVIDIA GPU]
        end

        subgraph "Runtime Images"
            RuntimeMinimal[Runtime Minimal CPU<br/>Python 3.12]
            RuntimeDataScience[Runtime Data Science CPU<br/>Pandas, Scikit-learn]
            RuntimePyTorchCUDA[Runtime PyTorch CUDA<br/>PyTorch 2.x, NVIDIA]
            RuntimePyTorchROCm[Runtime PyTorch ROCm<br/>PyTorch 2.x, AMD]
            RuntimeTensorFlowCUDA[Runtime TensorFlow CUDA<br/>TensorFlow 2.x, NVIDIA]
        end

        subgraph "Build Infrastructure"
            KonfluxPipeline[Konflux CI/CD Pipeline<br/>Multi-arch builds]
            TektonTasks[Tekton Build Tasks<br/>Buildah, Skopeo]
            Kustomize[Kustomize Manifests<br/>ImageStream Definitions]
        end

        subgraph "Base Images"
            UBI9Python[UBI9 Python 3.12<br/>Base OS and Runtime]
            CUDABase[CUDA Base Images<br/>NVIDIA GPU Drivers]
            ROCmBase[ROCm Base Images<br/>AMD GPU Drivers]
        end
    end

    subgraph "External Dependencies"
        Quay[Quay.io Registry<br/>Image Storage]
        RedHatRegistry[registry.redhat.io<br/>Red Hat Images]
        PyPI[PyPI.org<br/>Python Packages]
        OpenShiftMirror[mirror.openshift.com<br/>OpenShift CLI]
    end

    subgraph "ODH Platform"
        NotebookController[ODH Notebook Controller<br/>Pod Lifecycle Management]
        Dashboard[ODH Dashboard<br/>User Interface]
        KubeflowPipelines[Kubeflow Pipelines<br/>Pipeline Execution]
        ImageStreams[OpenShift ImageStreams<br/>Image References]
    end

    subgraph "Users"
        DataScientist[Data Scientist<br/>Interactive Development]
        PipelineTask[Pipeline Task<br/>Automated Execution]
    end

    %% Build Flow
    KonfluxPipeline -->|clones| GitHub[GitHub Repository]
    KonfluxPipeline -->|executes| TektonTasks
    TektonTasks -->|pulls base| UBI9Python
    TektonTasks -->|pulls base| CUDABase
    TektonTasks -->|pulls base| ROCmBase
    TektonTasks -->|installs from| PyPI
    TektonTasks -->|downloads from| OpenShiftMirror
    TektonTasks -->|pushes to| Quay
    Kustomize -->|creates| ImageStreams
    ImageStreams -->|references| Quay

    %% Deployment Flow
    Dashboard -->|queries| ImageStreams
    DataScientist -->|selects workbench| Dashboard
    Dashboard -->|creates| NotebookCRD[Notebook CR]
    NotebookController -->|watches| NotebookCRD
    NotebookController -->|creates pods using| JupyterCPU
    NotebookController -->|creates pods using| JupyterCUDA
    NotebookController -->|creates pods using| CodeServerDS
    NotebookController -->|creates pods using| RStudioCPU

    %% Pipeline Flow
    KubeflowPipelines -->|executes tasks using| RuntimeMinimal
    KubeflowPipelines -->|executes tasks using| RuntimePyTorchCUDA
    KubeflowPipelines -->|executes tasks using| RuntimeDataScience
    PipelineTask -->|runs in| KubeflowPipelines

    %% Registry Access
    RedHatRegistry -->|provides| UBI9Python

    %% Styling
    classDef workbench fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef build fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef base fill:#e8e8e8,stroke:#333,stroke-width:2px
    classDef external fill:#999,stroke:#333,stroke-width:2px
    classDef odh fill:#50e3c2,stroke:#333,stroke-width:2px
    classDef user fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    class JupyterCPU,JupyterCUDA,JupyterROCm,JupyterDataScience,JupyterPyTorchCUDA,JupyterPyTorchROCm,JupyterTensorFlowCUDA,JupyterTrustyAI,CodeServerDS,RStudioCPU,RStudioCUDA workbench
    class RuntimeMinimal,RuntimeDataScience,RuntimePyTorchCUDA,RuntimePyTorchROCm,RuntimeTensorFlowCUDA runtime
    class KonfluxPipeline,TektonTasks,Kustomize build
    class UBI9Python,CUDABase,ROCmBase base
    class Quay,RedHatRegistry,PyPI,OpenShiftMirror external
    class NotebookController,Dashboard,KubeflowPipelines,ImageStreams odh
    class DataScientist,PipelineTask user
