    subgraph "Notebooks Component (Workbench Images)"
        direction TB

        subgraph JupyterImages["Jupyter Workbench Images"]
            JupMinimal["Jupyter Minimal<br/>Python 3.11/3.12"]
            JupDS["Jupyter Data Science<br/>scikit-learn, Elyra, Boto3"]
            JupPyTorch["Jupyter PyTorch<br/>PyTorch 2.6, CUDA 12.6"]
            JupTF["Jupyter TensorFlow<br/>TensorFlow, CUDA 12.6"]
            JupTrustyAI["Jupyter TrustyAI<br/>Explainability Libraries"]
        end

        subgraph ROCmImages["ROCm GPU Workbenches"]
            ROCmMinimal["ROCm Minimal<br/>AMD GPU"]
            ROCmPyTorch["ROCm PyTorch<br/>AMD GPU"]
            ROCmTF["ROCm TensorFlow<br/>AMD GPU"]
        end

        subgraph OtherWorkbenches["Other Workbenches"]
            CodeServer["Code Server<br/>VS Code 4.104<br/>NGINX + httpd"]
            RStudio["RStudio Server<br/>R 4.4, Python 3.11"]
            CUDARStudio["CUDA RStudio<br/>GPU Support"]
        end

        subgraph RuntimeImages["Elyra Pipeline Runtimes"]
            RTMinimal["Runtime Minimal"]
            RTDS["Runtime Data Science"]
            RTPyTorch["Runtime PyTorch"]
            RTTF["Runtime TensorFlow"]
            RTROCmPT["Runtime ROCm PyTorch"]
            RTROCmTF["Runtime ROCm TensorFlow"]
        end

        subgraph Manifests["Kustomize Manifests"]
            Base["manifests/base/<br/>py3.11 ImageStreams"]
            Overlay["manifests/overlays/additional/<br/>py3.12 ImageStreams"]
            ParamsEnv["params.env<br/>Pinned Image Digests"]
        end
    end

    %% Image inheritance
    JupMinimal -->|base for| JupDS
    JupDS -->|base for| JupPyTorch
    JupDS -->|base for| JupTF
    JupDS -->|base for| JupTrustyAI

    %% Deployment flow
    ParamsEnv -->|digest refs| Base
    Base -->|included by| Overlay

    %% External consumers
    Operator["rhods-operator"] -->|applies kustomize| Overlay
    Overlay -->|creates| ImageStreams["ImageStream CRs<br/>image.openshift.io/v1"]

    %% Internal consumers
    ImageStreams -->|consumed by| NotebookCtrl["ODH Notebook Controller"]
    ImageStreams -->|displayed by| Dashboard["ODH Dashboard"]
    RuntimeImages -.->|used by| DSP["Data Science Pipelines"]

    %% External dependencies
    UBI9["UBI9 Base Image"] -->|base layer| JupMinimal
    CUDA["CUDA 12.6/12.8"] -->|GPU layer| JupPyTorch
    CUDA -->|GPU layer| JupTF
    ROCm["ROCm 6.2/6.4"] -->|GPU layer| ROCmMinimal

    %% CI/CD
    Konflux["Konflux CI/CD<br/>29 push + 28 PR pipelines"] -->|builds| JupyterImages
    Konflux -->|builds| ROCmImages
    Konflux -->|builds| OtherWorkbenches
    Konflux -->|builds| RuntimeImages

