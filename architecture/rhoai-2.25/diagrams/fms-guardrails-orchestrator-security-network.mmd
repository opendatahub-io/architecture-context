graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Inference Pipeline"]
    end

    subgraph Ingress["GUARDRAILS SERVICE"]
        direction TB
        GuardrailsServer["Guardrails Server<br/>fms-guardrails-orchestr8<br/>8033/TCP API | 8034/TCP Health<br/>TLS: rustls/ring (Optional TLS 1.2+)<br/>Mode: SIMPLE or MUTUAL<br/>Auth: Passthrough only"]
    end

    subgraph Downstream["DOWNSTREAM SERVICES (Internal)"]
        direction TB

        subgraph Generation["Text Generation Backends"]
            TGIS["TGIS Server<br/>8033/TCP gRPC<br/>Optional TLS<br/>Auth: mm-model-id"]
            CaikitNLP["Caikit NLP<br/>8085/TCP gRPC<br/>Optional TLS<br/>Auth: mm-model-id"]
            OpenAIServer["OpenAI Server (vLLM)<br/>8080/TCP HTTP<br/>Optional TLS<br/>Auth: Header passthrough"]
        end

        subgraph Processing["Content Processing"]
            Chunkers["Chunker Services (Caikit)<br/>8085/TCP gRPC<br/>Optional TLS<br/>Auth: mm-model-id"]
            Detectors["Detector Services<br/>8080/TCP HTTP<br/>Optional TLS<br/>Auth: detector-id, x-model-name"]
        end
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>OTLP<br/>No encryption / No auth"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS :8033<br/>Optional TLS 1.2+ (rustls/ring)<br/>X-Forwarded-Access-Token → Bearer"| GuardrailsServer

    GuardrailsServer -->|"gRPC :8033<br/>Optional TLS<br/>Header passthrough"| TGIS
    GuardrailsServer -->|"gRPC :8085<br/>Optional TLS<br/>Header passthrough"| CaikitNLP
    GuardrailsServer -->|"HTTP :8080<br/>Optional TLS<br/>Header passthrough"| OpenAIServer
    GuardrailsServer -->|"gRPC :8085<br/>Optional TLS<br/>mm-model-id"| Chunkers
    GuardrailsServer -->|"HTTP :8080<br/>Optional TLS<br/>detector-id"| Detectors
    GuardrailsServer -.->|"OTLP :4317/4318<br/>Traces + Metrics"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef downstream fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class GuardrailsServer ingress
    class TGIS,CaikitNLP,OpenAIServer,Chunkers,Detectors downstream
    class OTel observability
