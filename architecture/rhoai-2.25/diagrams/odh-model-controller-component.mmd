graph TB
    subgraph ODH_Model_Controller["odh-model-controller (Go Operator)"]
        direction TB

        subgraph Controllers["Controllers"]
            ISVCCtrl["InferenceService<br/>Controller"]
            IGCtrl["InferenceGraph<br/>Controller"]
            LLMCtrl["LLMInferenceService<br/>Controller"]
            NIMCtrl["NIM Account<br/>Controller"]
            PodCtrl["Pod Controller<br/>(Ray TLS)"]
            CMCtrl["ConfigMap Controller<br/>(CA Certs)"]
            SecretCtrl["Secret Controller<br/>(Storage Config)"]
            SRCtrl["ServingRuntime<br/>Controller"]
        end

        subgraph Reconcilers["Sub-Reconciler Architecture"]
            direction TB

            subgraph Serverless["Serverless Mode (12 sub-reconcilers)"]
                SL_Route["Route"]
                SL_Gateway["Istio Gateway"]
                SL_VS["VirtualService"]
                SL_PA["PeerAuthentication"]
                SL_Telemetry["Telemetry"]
                SL_SMM["ServiceMeshMember"]
                SL_AuthConfig["AuthConfig"]
                SL_NP["NetworkPolicy"]
                SL_KEDA["KEDA TriggerAuth"]
                SL_Metrics["Metrics Service"]
                SL_SM["ServiceMonitor"]
                SL_PM["PodMonitor"]
            end

            subgraph Raw["RawDeployment Mode (6 sub-reconcilers)"]
                Raw_Route["Route"]
                Raw_CRB["ClusterRoleBinding"]
                Raw_NP["NetworkPolicy"]
                Raw_Metrics["Metrics Service"]
                Raw_SM["ServiceMonitor"]
                Raw_SA["ServiceAccount"]
            end

            subgraph MM["ModelMesh Mode (3 sub-reconcilers)"]
                MM_Route["Route"]
                MM_CRB["ClusterRoleBinding"]
                MM_NP["NetworkPolicy"]
            end
        end

        subgraph Webhooks["Webhook Server (9443/TCP)"]
            W_Pod["Pod Mutator<br/>(Ray TLS Injection)"]
            W_ISVC_M["ISVC Mutator<br/>(Serverless Defaults)"]
            W_IG_M["InferenceGraph Mutator<br/>(Serverless Defaults)"]
            W_NIM["NIM Account Validator<br/>(Singleton)"]
            W_KS["Knative Service Validator<br/>(Mesh Membership)"]
            W_IG_V["InferenceGraph Validator<br/>(URL Format)"]
            W_ISVC_V["ISVC Validator<br/>(Namespace Restrictions)"]
        end

        subgraph NIMPipeline["NIM Handler Pipeline"]
            NIM_Valid["Validation Handler"]
            NIM_CM["ConfigMap Handler"]
            NIM_Tmpl["Template Handler"]
            NIM_Pull["PullSecret Handler"]
            NIM_Status["Status Handler"]
            NIM_Valid --> NIM_CM --> NIM_Tmpl --> NIM_Pull --> NIM_Status
        end

        DeltaProc["Delta Processor<br/>(17 Comparators)"]
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    IG_CR["InferenceGraph CR<br/>(serving.kserve.io/v1alpha1)"]
    LLM_CR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha1)"]
    NIM_CR["NIM Account CR<br/>(nim.opendatahub.io/v1)"]
    SR_CR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]

    %% Watch connections
    ISVC_CR -->|watched by| ISVCCtrl
    IG_CR -->|watched by| IGCtrl
    LLM_CR -->|watched by| LLMCtrl
    NIM_CR -->|watched by| NIMCtrl
    SR_CR -->|watched by| SRCtrl

    %% Controller to reconciler delegation
    ISVCCtrl -->|delegates| Serverless
    ISVCCtrl -->|delegates| Raw
    ISVCCtrl -->|delegates| MM
    NIMCtrl -->|delegates| NIMPipeline

    %% External systems
    K8sAPI["Kubernetes API Server"]
    IstioMesh["Istio / Service Mesh"]
    AuthorinoSvc["Authorino"]
    KuadrantSvc["Kuadrant"]
    PromSvc["Prometheus / Monitoring"]
    KEDASvc["KEDA"]
    NGCAPI["NVIDIA NGC API"]
    ModelReg["Model Registry"]
    OSRouter["OpenShift Router"]

    %% Integration connections
    Serverless -->|creates| IstioMesh
    Serverless -->|creates| AuthorinoSvc
    Serverless -->|creates| KEDASvc
    Serverless -->|creates| PromSvc
    Serverless -->|creates| OSRouter
    Raw -->|creates| OSRouter
    MM -->|creates| OSRouter
    LLMCtrl -->|creates| KuadrantSvc
    NIMPipeline -->|REST API| NGCAPI
    ISVCCtrl -->|registers| ModelReg
    DeltaProc -->|CRUD| K8sAPI

