graph TB
    subgraph "ODH Model Controller"
        Controller[Controller Manager]

        subgraph "Reconcilers"
            ISVCReconciler[InferenceService<br/>Controller]
            IGReconciler[InferenceGraph<br/>Controller]
            LLMReconciler[LLMInferenceService<br/>Controller]
            NIMReconciler[NIM Account<br/>Controller]
            SRReconciler[ServingRuntime<br/>Controller]
            CMReconciler[ConfigMap<br/>Controller]
            SecretReconciler[Secret<br/>Controller]
            PodReconciler[Pod<br/>Controller]
        end

        subgraph "Webhooks"
            PodWebhook[Pod Mutating<br/>Webhook]
            ISVCWebhook[InferenceService<br/>Webhook]
            IGWebhook[InferenceGraph<br/>Webhook]
            NIMWebhook[NIM Account<br/>Webhook]
            KSvcWebhook[Knative Service<br/>Webhook]
        end

        subgraph "HTTP Endpoints"
            MetricsEndpoint[Metrics Server<br/>8080/TCP HTTP]
            HealthEndpoint[Health Probes<br/>8081/TCP HTTP]
        end

        Controller --> ISVCReconciler
        Controller --> IGReconciler
        Controller --> LLMReconciler
        Controller --> NIMReconciler
        Controller --> SRReconciler
        Controller --> CMReconciler
        Controller --> SecretReconciler
        Controller --> PodReconciler
    end

    subgraph "Custom Resources"
        NIMAccount[NIM Account CR<br/>nim.opendatahub.io/v1]
    end

    subgraph "Watched KServe CRDs"
        ISVC[InferenceService<br/>serving.kserve.io/v1beta1]
        IG[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        LLMISVC[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
        SR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        KSvc[Knative Service<br/>serving.knative.dev/v1]
    end

    subgraph "Created Resources"
        Route[OpenShift Route]
        VirtualService[Istio VirtualService]
        Gateway[Istio Gateway]
        PeerAuth[PeerAuthentication]
        AuthConfig[Authorino AuthConfig]
        ServiceMonitor[ServiceMonitor]
        NetworkPolicy[NetworkPolicy]
        KEDA[KEDA TriggerAuthentication]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        KServeController[KServe Controller]
        Istio[Istio/Maistra<br/>Service Mesh]
        Authorino[Authorino]
        Prometheus[Prometheus]
        NGC[NVIDIA NGC API<br/>443/TCP HTTPS]
        ModelRegistry[Model Registry<br/>443/TCP HTTPS]
    end

    User[Data Scientist] -->|creates| ISVC
    User -->|creates| NIMAccount

    ISVC -->|watched by| ISVCReconciler
    IG -->|watched by| IGReconciler
    LLMISVC -->|watched by| LLMReconciler
    NIMAccount -->|watched by| NIMReconciler
    SR -->|watched by| SRReconciler
    KSvc -->|validated by| KSvcWebhook

    ISVCWebhook -->|validates/mutates| ISVC
    IGWebhook -->|validates/mutates| IG
    NIMWebhook -->|validates| NIMAccount
    PodWebhook -->|mutates| PodReconciler

    ISVCReconciler -->|creates| Route
    ISVCReconciler -->|creates| VirtualService
    ISVCReconciler -->|creates| AuthConfig
    ISVCReconciler -->|creates| ServiceMonitor
    ISVCReconciler -->|creates| NetworkPolicy
    ISVCReconciler -->|creates| PeerAuth
    ISVCReconciler -->|creates| KEDA

    NIMReconciler -->|creates| SR
    NIMReconciler -->|validates account| NGC

    Controller -->|watches/creates via| K8sAPI
    Controller -->|coordinates with| KServeController
    Controller -->|configures| Istio
    Controller -->|creates auth| Authorino
    ISVCReconciler -->|registers metadata| ModelRegistry

    Prometheus -->|scrapes| MetricsEndpoint

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style ISVCReconciler fill:#4a90e2,stroke:#333
    style NIMReconciler fill:#4a90e2,stroke:#333
    style ISVC fill:#f5a623,stroke:#333
    style NIMAccount fill:#f5a623,stroke:#333
    style Route fill:#7ed321,stroke:#333
    style VirtualService fill:#7ed321,stroke:#333
    style AuthConfig fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style KServeController fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style NGC fill:#999,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
