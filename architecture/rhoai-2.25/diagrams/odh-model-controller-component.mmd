    style ODH_Model_Controller fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Controllers fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style Webhooks fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    style NIMPipeline fill:#ede9fe,stroke:#8b5cf6,stroke-width:2px
    style Serverless fill:#d1fae5,stroke:#10b981,stroke-width:1px
    style Raw fill:#d1fae5,stroke:#10b981,stroke-width:1px
    style MM fill:#d1fae5,stroke:#10b981,stroke-width:1px
    style Reconcilers fill:#ecfdf5,stroke:#059669,stroke-width:2px
    style ISVC_CR fill:#f5a623,stroke:#333
    style IG_CR fill:#f5a623,stroke:#333
    style LLM_CR fill:#f5a623,stroke:#333
    style NIM_CR fill:#f5a623,stroke:#333
    style SR_CR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style IstioMesh fill:#e8e8e8,stroke:#333
    style AuthorinoSvc fill:#e8e8e8,stroke:#333
    style KuadrantSvc fill:#e8e8e8,stroke:#333
    style PromSvc fill:#e8e8e8,stroke:#333
