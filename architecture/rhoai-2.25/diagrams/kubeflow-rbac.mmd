graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[notebook-controller-service-account<br/>Namespace: kubeflow]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB1[notebook-controller-role-binding<br/>Scope: All namespaces]
        CRB2[leader-election-role-binding<br/>Scope: Controller namespace]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR1[notebook-controller-role]
        CR2[leader-election-role]
        CR3[kubeflow-notebooks-edit]
        CR4[kubeflow-notebooks-view]
    end

    subgraph CoreAPIResources["Core API Resources (v1)"]
        Events[events<br/>create, get, list, patch, watch]
        Pods[pods<br/>delete, get, list, watch]
        Services[services<br/>* all verbs]
        ConfigMaps[configmaps<br/>get, list, watch, create,<br/>update, patch, delete]
        ConfigMapsStatus[configmaps/status<br/>get, update, patch]
    end

    subgraph AppsAPIResources["Apps API (apps/v1)"]
        StatefulSets[statefulsets<br/>* all verbs]
    end

    subgraph KubeflowAPIResources["Kubeflow API (kubeflow.org/v1)"]
        Notebooks[notebooks<br/>* all verbs]
        NotebooksFinalizers[notebooks/finalizers<br/>* all verbs]
        NotebooksStatus[notebooks/status<br/>* all verbs]
    end

    subgraph IstioAPIResources["Istio API (networking.istio.io)"]
        VirtualServices[virtualservices<br/>* all verbs]
    end

    subgraph UserRoles["User-facing Roles"]
        EditRole[kubeflow-notebooks-edit<br/>Allows: create, delete,<br/>update notebooks]
        ViewRole[kubeflow-notebooks-view<br/>Allows: get, list,<br/>watch notebooks]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% notebook-controller-role permissions
    CR1 -->|permissions| Events
    CR1 -->|permissions| Pods
    CR1 -->|permissions| Services
    CR1 -->|permissions| StatefulSets
    CR1 -->|permissions| Notebooks
    CR1 -->|permissions| NotebooksFinalizers
    CR1 -->|permissions| NotebooksStatus
    CR1 -->|permissions| VirtualServices

    %% leader-election-role permissions
    CR2 -->|permissions| ConfigMaps
    CR2 -->|permissions| ConfigMapsStatus

    %% User role permissions
    CR3 -->|permissions| Notebooks
    CR3 -->|permissions| NotebooksStatus
    CR4 -->|permissions| Notebooks
    CR4 -->|permissions| NotebooksStatus

    %% User roles connections
    EditRole -.->|implemented by| CR3
    ViewRole -.->|implemented by| CR4

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR4 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#d5e8d4,stroke:#333
    style CRB2 fill:#d5e8d4,stroke:#333
    style Notebooks fill:#fff2cc,stroke:#333,stroke-width:2px
    style NotebooksFinalizers fill:#fff2cc,stroke:#333
    style NotebooksStatus fill:#fff2cc,stroke:#333
    style StatefulSets fill:#dae8fc,stroke:#333
    style Services fill:#dae8fc,stroke:#333
    style VirtualServices fill:#dae8fc,stroke:#333
    style EditRole fill:#7ed321,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style ViewRole fill:#7ed321,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
