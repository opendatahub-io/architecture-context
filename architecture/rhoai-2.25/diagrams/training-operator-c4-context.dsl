/*
 * Training Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/training-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or automation"

        trainingOperator = softwareSystem "Training Operator (KFTO)" "Kubernetes-native operator for managing distributed training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, and JAX" {
            controller = container "Training Operator" "Manages lifecycle of 6 training job CRDs, creates Pods, Services, NetworkPolicies" "Go Operator (controller-runtime)" "operator"
            webhookServer = container "Webhook Server" "Validates CREATE/UPDATE on training job CRDs" "HTTPS/9443 TLS (self-signed)" "webhook"
            certController = container "Cert Controller" "Self-managed TLS certificate rotation for webhook server" "open-policy-agent/cert-controller" "utility"
        }

        k8sApi = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages RHOAI components via kustomize" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduling via PodGroups" "External Optional"
        schedulerPlugins = softwareSystem "scheduler-plugins" "Optional gang scheduling via PodGroups" "External Optional"
        kueue = softwareSystem "Kueue" "Job scheduling delegation via MultiKueue" "Internal RHOAI"

        # Relationships
        user -> trainingOperator "Submits training jobs (PyTorchJob, TFJob, etc.) via kubectl" "HTTPS/443"
        user -> k8sApi "Creates training job CRs" "HTTPS/443 TLS 1.2+"

        k8sApi -> webhookServer "Sends admission review requests" "HTTPS/9443 TLS (self-signed)"
        controller -> k8sApi "Watches CRDs, creates Pods/Services/NetworkPolicies" "HTTPS/443 TLS 1.2+"
        certController -> webhookServer "Manages TLS certificates" "Internal"

        prometheus -> controller "Scrapes metrics via PodMonitor" "HTTP/8080 plaintext"
        rhodsOperator -> trainingOperator "Deploys via kustomize overlay" "Kustomize"
        controller -> volcano "Creates PodGroups for gang scheduling" "CRD (optional)"
        controller -> schedulerPlugins "Creates PodGroups for gang scheduling" "CRD (optional)"
        controller -> kueue "Delegates scheduling via managedBy field" "CRD (optional)"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
            description "System context showing Training Operator in the RHOAI ecosystem"
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
            description "Internal structure of the Training Operator"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #BBBBBB
                color #ffffff
                border dashed
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "operator" {
                shape hexagon
                background #4a90e2
            }
            element "webhook" {
                shape component
                background #f5a623
            }
            element "utility" {
                shape component
                background #82b366
            }
        }
    }
}
