graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Application"]
    end

    subgraph Platform["PLATFORM SECURITY LAYER"]
        KServeRouter["KServe Router / Istio Gateway<br/>Traffic routing & TLS"]
    end

    subgraph PodBoundary["POD SECURITY BOUNDARY"]
        direction TB

        subgraph Sidecar["Security Sidecar"]
            KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token AuthN<br/>SubjectAccessReview AuthZ"]
        end

        subgraph VLLMContainer["vLLM Container (odh-vllm-rocm-rhel9)"]
            HTTPServer["vLLM HTTP Server<br/>8000/TCP HTTP (plaintext)<br/>No Auth (localhost)"]
            GRPCEndpoint["TGIS gRPC Adapter<br/>8033/TCP gRPC<br/>Platform-level Auth"]
            InferenceEngine["vLLM Inference Engine<br/>(in-process)"]
        end

        subgraph GPUAccess["GPU Access"]
            GPU["AMD GPU<br/>ROCm/HIP Runtime<br/>(device plugin)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM Credentials"]
        PVC["PVC Model Storage<br/>Filesystem Mount<br/>ServiceAccount"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token (optional)"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP<br/>HTTP (in-cluster)"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KServeRouter
    KServeRouter -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP/8000<br/>Plaintext<br/>localhost only"| HTTPServer
    KServeRouter -.->|"gRPC/8033<br/>Platform Auth"| GRPCEndpoint
    HTTPServer -->|in-process| InferenceEngine
    GRPCEndpoint -->|in-process| InferenceEngine
    InferenceEngine -->|"HIP Runtime<br/>(in-process)"| GPU
    InferenceEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM Auth"| S3
    InferenceEngine -->|"Filesystem<br/>Volume Mount"| PVC
    InferenceEngine -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Token"| HFHub
    Prometheus -.->|"HTTP/8000<br/>Scrape /metrics"| HTTPServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeRouter platform
    class KubeRBAC security
    class HTTPServer,GRPCEndpoint,InferenceEngine container
    class GPU gpu
    class S3,PVC,HFHub,Prometheus externalservice
