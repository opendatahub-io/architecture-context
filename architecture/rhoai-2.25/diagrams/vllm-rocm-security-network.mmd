%% Security Network Diagram for vllm-rocm
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Platform Managed"]
        Gateway["Platform Ingress<br/>(Gateway API / OpenShift Route)<br/>443/TCP<br/>TLS 1.2+<br/>kube-rbac-proxy / oauth-proxy"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod Network)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph PredictorPod["KServe Predictor Pod"]
                VLLM["vLLM Engine<br/>8000/TCP HTTP<br/>OpenAI-compatible API<br/>+ /metrics endpoint"]
                TGIS["vllm-tgis-adapter<br/>8033/TCP gRPC<br/>TGIS-compatible API"]
                ROCm["AMD ROCm/HIP Runtime"]

                TGIS -->|internal| VLLM
                VLLM -->|HIP| ROCm
            end
        end

        subgraph NS_Platform["Platform Services"]
            Caikit["caikit-tgis-serving"]
            Prometheus["Prometheus"]
            ODHController["odh-model-controller"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["Model Storage (S3/PVC)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM / SA token"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API token (optional)"]
    end

    subgraph Hardware["HARDWARE"]
        AMDGPU["AMD GPU<br/>ROCm/HIP<br/>PagedAttention<br/>Tensor Parallelism"]
    end

    %% External flows
    Client -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP 8000/TCP<br/>plaintext<br/>No Auth (delegated)"| VLLM
    Gateway -->|"gRPC 8033/TCP<br/>plaintext<br/>No Auth (delegated)"| TGIS

    %% Internal flows
    Caikit -->|"gRPC 8033/TCP<br/>plaintext"| TGIS
    Prometheus -->|"HTTP 8000/TCP<br/>/metrics<br/>plaintext"| VLLM
    ODHController -.->|"manages routing"| Gateway

    %% Egress flows
    VLLM -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>IAM credentials"| S3
    VLLM -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>API token"| HFHub

    %% Hardware
    ROCm -->|"HIP runtime"| AMDGPU

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class VLLM,TGIS,ROCm internal
