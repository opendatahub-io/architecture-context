        SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>Verbs: create"]
    end

    CR_Proxy --> TokenReview
    CR_Proxy --> SAR

    subgraph LMEvalResources["lmeval-user-role Resources"]
        LMEvalJobRes["trustyai.opendatahub.io:<br/>lmevaljobs (CRUD + watch)<br/>lmevaljobs/status (get)<br/>⚠️ All authenticated users"]
