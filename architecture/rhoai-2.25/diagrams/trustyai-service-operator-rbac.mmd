graph TD
    subgraph "Service Accounts"
        SA_Operator[trustyai-service-operator<br/>-controller-manager<br/>Namespace: redhat-ods-applications]
        SA_TrustyAI["{trustyai-service-name}<br/>Namespace: {user-namespace}"]
        SA_Guardrails["{orchestrator-name}<br/>Namespace: {user-namespace}"]
        SA_LMEval["{lmevaljob-name}-sa<br/>Namespace: {user-namespace}"]
        SA_AllUsers["system:authenticated<br/>(All authenticated users)"]
    end

    subgraph "ClusterRoles"
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Leader["leader-election-role<br/>(Role)"]
        CR_AuthProxy["auth-proxy-role<br/>(ClusterRole)"]
        CR_LMEval["non-admin-lmeval-role<br/>(ClusterRole)"]
    end

    subgraph "ClusterRoleBindings / RoleBindings"
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding in system ns)"]
        CRB_AuthProxy["auth-proxy-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_LMEval["default-lmeval-user-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph "API Resources - Core"
        Res_ConfigMaps["core/ConfigMaps"]
        Res_PVCs["core/PersistentVolumeClaims"]
        Res_Pods["core/Pods"]
        Res_Secrets["core/Secrets"]
        Res_Services["core/Services"]
        Res_ServiceAccounts["core/ServiceAccounts"]
        Res_Events["core/Events"]
        Res_PVs["core/PersistentVolumes"]
        Res_PodsExec["core/Pods/exec"]
    end

    subgraph "API Resources - Apps"
        Res_Deployments["apps/Deployments"]
        Res_DepFinalizers["apps/Deployments/finalizers"]
        Res_DepStatus["apps/Deployments/status"]
    end

    subgraph "API Resources - Monitoring"
        Res_ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors"]
    end

    subgraph "API Resources - Networking"
        Res_Routes["route.openshift.io<br/>Routes"]
        Res_VirtualServices["networking.istio.io<br/>VirtualServices"]
        Res_DestinationRules["networking.istio.io<br/>DestinationRules"]
    end

    subgraph "API Resources - KServe"
        Res_InferenceServices["serving.kserve.io<br/>InferenceServices"]
        Res_ISFinalizers["serving.kserve.io<br/>InferenceServices/finalizers"]
        Res_ServingRuntimes["serving.kserve.io<br/>ServingRuntimes"]
    end

    subgraph "API Resources - TrustyAI CRDs"
        Res_TrustyAIServices["trustyai.opendatahub.io<br/>TrustyAIServices"]
        Res_LMEvalJobs["trustyai.opendatahub.io<br/>LMEvalJobs"]
        Res_Guardrails["trustyai.opendatahub.io<br/>GuardrailsOrchestrators"]
        Res_TASFinalizers["trustyai.opendatahub.io<br/>TrustyAIServices/finalizers"]
        Res_LMFinalizers["trustyai.opendatahub.io<br/>LMEvalJobs/finalizers"]
        Res_GOFinalizers["trustyai.opendatahub.io<br/>GuardrailsOrchestrators/finalizers"]
        Res_TASStatus["trustyai.opendatahub.io<br/>TrustyAIServices/status"]
        Res_LMStatus["trustyai.opendatahub.io<br/>LMEvalJobs/status"]
        Res_GOStatus["trustyai.opendatahub.io<br/>GuardrailsOrchestrators/status"]
    end

    subgraph "API Resources - Kueue"
        Res_Workloads["kueue.x-k8s.io<br/>Workloads"]
        Res_WLFinalizers["kueue.x-k8s.io<br/>Workloads/finalizers"]
        Res_WLStatus["kueue.x-k8s.io<br/>Workloads/status"]
        Res_ResourceFlavors["kueue.x-k8s.io<br/>ResourceFlavors"]
        Res_WLPriorityClasses["kueue.x-k8s.io<br/>WorkloadPriorityClasses"]
    end

    subgraph "API Resources - RBAC & Others"
        Res_ClusterRoleBindings["rbac.authorization.k8s.io<br/>ClusterRoleBindings"]
        Res_CRDs["apiextensions.k8s.io<br/>CustomResourceDefinitions"]
        Res_PriorityClasses["scheduling.k8s.io<br/>PriorityClasses"]
        Res_Leases["coordination.k8s.io<br/>Leases"]
    end

    %% Service Account to Bindings
    SA_Operator -->|"bound via"| CRB_Manager
    SA_Operator -->|"bound via"| RB_Leader
    SA_Operator -->|"bound via"| CRB_AuthProxy
    SA_AllUsers -->|"bound via"| CRB_LMEval

    %% Bindings to Roles
    CRB_Manager -->|"grants"| CR_Manager
    RB_Leader -->|"grants"| CR_Leader
    CRB_AuthProxy -->|"grants"| CR_AuthProxy
    CRB_LMEval -->|"grants"| CR_LMEval

    %% Manager Role Permissions (Core Resources)
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_ConfigMaps
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_PVCs
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Pods
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Secrets
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Services
    CR_Manager -->|"create, delete, get, list,<br/>update, watch"| Res_ServiceAccounts
    CR_Manager -->|"create, patch, update, watch"| Res_Events
    CR_Manager -->|"get, list, watch"| Res_PVs
    CR_Manager -->|"create, delete, get, list, watch"| Res_PodsExec

    %% Manager Role Permissions (Apps)
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Deployments
    CR_Manager -->|"get, patch, update"| Res_DepFinalizers
    CR_Manager -->|"get, patch, update"| Res_DepStatus

    %% Manager Role Permissions (Monitoring)
    CR_Manager -->|"create, list, watch"| Res_ServiceMonitors

    %% Manager Role Permissions (Networking)
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Routes
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_VirtualServices
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_DestinationRules

    %% Manager Role Permissions (KServe)
    CR_Manager -->|"get, list, patch,<br/>update, watch"| Res_InferenceServices
    CR_Manager -->|"delete, get, list, patch,<br/>update, watch"| Res_ISFinalizers
    CR_Manager -->|"get, list, watch"| Res_ServingRuntimes

    %% Manager Role Permissions (TrustyAI CRDs)
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_TrustyAIServices
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_LMEvalJobs
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Guardrails
    CR_Manager -->|"update"| Res_TASFinalizers
    CR_Manager -->|"update"| Res_LMFinalizers
    CR_Manager -->|"update"| Res_GOFinalizers
    CR_Manager -->|"get, patch, update"| Res_TASStatus
    CR_Manager -->|"get, patch, update"| Res_LMStatus
    CR_Manager -->|"get, patch, update"| Res_GOStatus

    %% Manager Role Permissions (Kueue)
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| Res_Workloads
    CR_Manager -->|"get, patch, update"| Res_WLFinalizers
    CR_Manager -->|"get, patch, update"| Res_WLStatus
    CR_Manager -->|"get, list, watch"| Res_ResourceFlavors
    CR_Manager -->|"get, list, watch"| Res_WLPriorityClasses

    %% Manager Role Permissions (RBAC & Others)
    CR_Manager -->|"create, delete, get, list,<br/>update, watch"| Res_ClusterRoleBindings
    CR_Manager -->|"get, list, watch"| Res_CRDs
    CR_Manager -->|"get, list, watch"| Res_PriorityClasses
    CR_Manager -->|"create, get, update"| Res_Leases

    %% Leader Election Role Permissions
    CR_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Res_ConfigMaps
    CR_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Res_Leases
    CR_Leader -->|"create, patch"| Res_Events

    %% Non-Admin LMEval Role Permissions
    CR_LMEval -->|"create, delete, get, list,<br/>patch, update, watch"| Res_LMEvalJobs

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_AllUsers fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:3px
    style CR_LMEval fill:#f5a623,stroke:#333,stroke-width:2px
    style Res_TrustyAIServices fill:#7ed321,stroke:#333
    style Res_LMEvalJobs fill:#7ed321,stroke:#333
    style Res_Guardrails fill:#7ed321,stroke:#333
    style Res_InferenceServices fill:#9370db,stroke:#333
    style Res_Deployments fill:#ff8c00,stroke:#333
    style Res_Services fill:#ff8c00,stroke:#333
