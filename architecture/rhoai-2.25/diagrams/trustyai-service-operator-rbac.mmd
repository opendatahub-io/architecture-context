        RouteResources["route.openshift.io:<br/>routes<br/>Verbs: CRUD + watch"]
        MonitorResources["monitoring.coreos.com:<br/>servicemonitors<br/>Verbs: create, list, watch"]
        IstioResources["networking.istio.io:<br/>destinationrules,<br/>virtualservices<br/>Verbs: CRUD + watch"]
        RBACResources["rbac.authorization.k8s.io:<br/>clusterrolebindings<br/>Verbs: CRUD + watch"]
        KueueResources["kueue.x-k8s.io:<br/>workloads (CRUD)<br/>resourceflavors,<br/>workloadpriorityclasses<br/>(get, list, watch)"]
        SchedulingResources["scheduling.k8s.io:<br/>priorityclasses<br/>(get, list, watch)"]
        CRDResources["apiextensions.k8s.io:<br/>customresourcedefinitions<br/>(get, list, watch)"]
    end

    CR_Manager --> CoreResources
