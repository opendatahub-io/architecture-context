graph TB
    subgraph KubeflowNotebooks["Kubeflow Notebook Controllers"]
        direction TB

        subgraph KFController["kf-notebook-controller"]
            NotebookReconciler["NotebookReconciler<br/>8080/TCP metrics<br/>8081/TCP probes"]
            CullingReconciler["CullingReconciler<br/>Idle notebook detection"]
            ReconcileHelper["reconcilehelper<br/>Shared utilities"]
            NotebookReconciler --> ReconcileHelper
            CullingReconciler -->|"checks activity"| NotebookReconciler
        end

        subgraph ODHController["odh-notebook-controller"]
            ODHReconciler["ODH NotebookReconciler<br/>8080/TCP metrics<br/>8081/TCP probes"]
            WebhookServer["Mutating Webhook<br/>8443/TCP HTTPS<br/>/mutate-notebook-v1"]
            OAuthManager["OAuth Manager<br/>Proxy injection"]
            RouteManager["Route Manager<br/>TLS Routes"]
            NetworkManager["Network Manager<br/>NetworkPolicies"]
            CertManager["Certificate Manager<br/>CA bundle aggregation"]
            DSPAIntegration["DSPA Integration<br/>Elyra pipeline config"]

            ODHReconciler --> OAuthManager
            ODHReconciler --> RouteManager
            ODHReconciler --> NetworkManager
            ODHReconciler --> CertManager
            ODHReconciler --> DSPAIntegration
            WebhookServer -->|"mutates on CREATE/UPDATE"| ODHReconciler
        end
    end

    %% CRD
    User["User / Dashboard"] -->|"creates/updates"| NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>Namespaced"]

    %% Watches
    NotebookCR -->|"watched by"| NotebookReconciler
    NotebookCR -->|"watched by"| ODHReconciler
    NotebookCR -->|"intercepted on mutation"| WebhookServer

    %% kf-notebook-controller outputs
    NotebookReconciler -->|"creates"| StatefulSet["StatefulSet<br/>replicas=1"]
    NotebookReconciler -->|"creates"| NBService["ClusterIP Service<br/>80/TCP → 8888"]
    NotebookReconciler -->|"creates (if Istio)"| VirtualService["VirtualService<br/>(optional)"]
    CullingReconciler -->|"HTTP 8888/TCP<br/>/api/kernels, /api/terminals"| NotebookPod["Notebook Pod<br/>Jupyter 8888/TCP"]
    CullingReconciler -->|"sets stop annotation<br/>→ replicas=0"| StatefulSet

    %% odh-notebook-controller outputs
    OAuthManager -->|"injects sidecar"| OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS"]
    OAuthManager -->|"creates"| OAuthClient["OAuthClient<br/>cluster-scoped"]
    OAuthManager -->|"creates"| OAuthSecrets["OAuth Secrets<br/>cookie + client"]
    RouteManager -->|"creates"| Route["OpenShift Route<br/>443/TCP re-encrypt TLS"]
    NetworkManager -->|"creates"| NetworkPolicy["NetworkPolicy<br/>per-notebook isolation"]
    CertManager -->|"aggregates"| CABundle["workbench-trusted-ca-bundle<br/>ConfigMap"]
    DSPAIntegration -->|"creates"| ElyraSecret["ds-pipeline-config<br/>Secret"]

    %% External dependencies
    NotebookReconciler -->|"HTTPS 6443"| K8sAPI["Kubernetes API"]
    ODHReconciler -->|"HTTPS 6443"| K8sAPI
    ODHReconciler -->|"HTTPS 6443"| OSAPIs["OpenShift APIs<br/>Route, OAuth, ImageStream, Proxy"]

    %% Styling
    style KFController fill:#4a90e2,stroke:#2a6cb0,color:#fff
    style ODHController fill:#4a90e2,stroke:#2a6cb0,color:#fff
    style NotebookCR fill:#f5a623,stroke:#d4880e,color:#000
    style StatefulSet fill:#7ed321,stroke:#5ba318,color:#000
    style NBService fill:#7ed321,stroke:#5ba318,color:#000
    style VirtualService fill:#7ed321,stroke:#5ba318,color:#000
    style Route fill:#7ed321,stroke:#5ba318,color:#000
    style NetworkPolicy fill:#7ed321,stroke:#5ba318,color:#000
    style OAuthClient fill:#7ed321,stroke:#5ba318,color:#000
    style OAuthProxy fill:#7ed321,stroke:#5ba318,color:#000
    style K8sAPI fill:#e8e8e8,stroke:#999,color:#000
    style OSAPIs fill:#e8e8e8,stroke:#999,color:#000
    style NotebookPod fill:#bd10e0,stroke:#8b0ba5,color:#fff
