graph TD
    subgraph "User Identity"
        User["Data Scientist<br/>(Authenticated User)"]
    end

    subgraph "Authentication Methods"
        KubeAuthkit["kube-authkit<br/>Auto-detect"]
        BearerToken["Bearer Token<br/>(OpenShift OAuth)"]
        Kubeconfig["Kubeconfig<br/>(file-based)"]
        InClusterSA["In-Cluster SA<br/>(pod service account)"]

        KubeAuthkit -->|"detects"| BearerToken
        KubeAuthkit -->|"detects"| Kubeconfig
        KubeAuthkit -->|"detects"| InClusterSA
    end

    subgraph "Required RBAC Permissions (User's Role)"
        UserRole["User's ClusterRole / Role<br/>(must be pre-configured)"]
    end

    subgraph "Ray Resources (ray.io)"
        RayClusters["ray.io<br/>rayclusters"]
        RayJobs["ray.io<br/>rayjobs"]
    end

    subgraph "Kueue Resources (kueue.x-k8s.io)"
        LocalQueues["kueue.x-k8s.io<br/>localqueues"]
        Workloads["kueue.x-k8s.io<br/>workloads"]
        WPC["kueue.x-k8s.io<br/>workloadpriorityclasses"]
    end

    subgraph "Gateway Resources (gateway.networking.k8s.io)"
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        Gateways["gateway.networking.k8s.io<br/>gateways"]
    end

    subgraph "OpenShift Resources"
        Routes["route.openshift.io<br/>routes"]
    end

    subgraph "Core Resources"
        Secrets["core/v1<br/>secrets"]
        Namespaces["core/v1<br/>namespaces"]
        Ingresses["networking.k8s.io<br/>ingresses"]
    end

    subgraph "mTLS Authentication (Ray Client)"
        ClientCert["Client TLS Certificate<br/>RSA 3072-bit, SHA-256<br/>Signed by KubeRay CA"]
    end

    User -->|"authenticates via"| KubeAuthkit
    KubeAuthkit -->|"grants access to"| UserRole

    UserRole -->|"create, get, list,<br/>delete, patch"| RayClusters
    UserRole -->|"create, get, list,<br/>delete, patch"| RayJobs
    UserRole -->|"list"| LocalQueues
    UserRole -->|"list"| Workloads
    UserRole -->|"get"| WPC
    UserRole -->|"list"| HTTPRoutes
    UserRole -->|"get"| Gateways
    UserRole -->|"list"| Routes
    UserRole -->|"list, get,<br/>create, replace"| Secrets
    UserRole -->|"get"| Namespaces
    UserRole -->|"list"| Ingresses

    User -->|"ray.init() via<br/>mTLS 10001/TCP"| ClientCert

    %% Styling
    style User fill:#08427b,stroke:#333,color:#fff
    style KubeAuthkit fill:#4a90e2,stroke:#333,color:#fff
    style BearerToken fill:#4a90e2,stroke:#333,color:#fff
    style Kubeconfig fill:#4a90e2,stroke:#333,color:#fff
    style InClusterSA fill:#4a90e2,stroke:#333,color:#fff
    style UserRole fill:#f5a623,stroke:#333,color:#fff
    style ClientCert fill:#e74c3c,stroke:#333,color:#fff

    style RayClusters fill:#7ed321,stroke:#333,color:#fff
    style RayJobs fill:#7ed321,stroke:#333,color:#fff
    style LocalQueues fill:#7ed321,stroke:#333
    style Workloads fill:#7ed321,stroke:#333
    style WPC fill:#7ed321,stroke:#333
    style HTTPRoutes fill:#9b59b6,stroke:#333,color:#fff
    style Gateways fill:#9b59b6,stroke:#333,color:#fff
    style Routes fill:#9b59b6,stroke:#333,color:#fff
    style Secrets fill:#e8e8e8,stroke:#333
    style Namespaces fill:#e8e8e8,stroke:#333
    style Ingresses fill:#e8e8e8,stroke:#333
