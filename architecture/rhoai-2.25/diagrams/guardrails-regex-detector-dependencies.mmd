graph LR
    RegexDetector["Guardrails Regex Detector<br/>Rust Service"]

    %% Internal RHOAI Dependencies (Inbound — Orchestrator calls this service)
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"REST inbound<br/>HTTP 8080/TCP<br/>Plaintext"| RegexDetector

    %% Rust Crate Dependencies
    subgraph "Rust Crate Dependencies"
        Axum["axum 0.7.9<br/>HTTP Framework"]
        Regex["regex 1.11.1<br/>Pattern Engine"]
        Serde["serde 1.0.215<br/>Serialization"]
        SerdeJSON["serde_json 1.0.133<br/>JSON Support"]
        Tokio["tokio 1.41.1<br/>Async Runtime"]
        TowerHTTP["tower-http 0.6.2<br/>HTTP Middleware"]
        Tracing["tracing 0.1.41<br/>Diagnostics"]
        TracingSub["tracing-subscriber 0.3.19<br/>Log Formatting"]
    end

    RegexDetector -.->|"web framework"| Axum
    RegexDetector -.->|"pattern matching"| Regex
    RegexDetector -.->|"serialization"| Serde
    RegexDetector -.->|"JSON parsing"| SerdeJSON
    RegexDetector -.->|"async runtime"| Tokio
    RegexDetector -.->|"HTTP tracing"| TowerHTTP
    RegexDetector -.->|"logging"| Tracing
    RegexDetector -.->|"log subscriber"| TracingSub

    %% Infrastructure
    K8s["Kubernetes<br/>Network Isolation"] -.->|"ClusterIP service<br/>namespace isolation"| RegexDetector

    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
