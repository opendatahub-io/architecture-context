graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB
        Note["No RBAC Resources Defined"]
        Reason["This component is a stateless HTTP service<br/>with no Kubernetes API interactions.<br/>No ClusterRoles, Roles, or RoleBindings."]
    end

    subgraph "Authentication Model"
        direction TB
        AuthNote["No Local Auth Enforcement"]
        AuthFlow["Client → Authorization header → Gateway<br/>↓ (passthrough, not validated)<br/>Gateway → forwards Authorization header → Orchestrator<br/>↓<br/>Auth enforcement delegated to orchestrator<br/>and/or external ingress layer"]
    end

    subgraph "Security Controls"
        direction TB
        HeaderFilter["Header Forwarding Filter<br/>Only forwards: Authorization, X-Forwarded-*<br/>Blocks: all other client headers"]
        mTLS["Optional mTLS to Orchestrator<br/>Client cert: /etc/tls/private/tls.crt<br/>Client key: /etc/tls/private/tls.key<br/>CA cert: /etc/tls/ca/service-ca.crt"]
        FallbackMsg["Detection Fallback<br/>Replaces response on content detection<br/>Prevents unsafe content reaching client"]
    end

    Note --> Reason
    AuthNote --> AuthFlow
    HeaderFilter ~~~ mTLS
    mTLS ~~~ FallbackMsg

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Reason fill:#fff2cc,stroke:#d6b656
    style AuthNote fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style AuthFlow fill:#dae8fc,stroke:#6c8ebf
    style HeaderFilter fill:#d5e8d4,stroke:#82b366
    style mTLS fill:#d5e8d4,stroke:#82b366
    style FallbackMsg fill:#d5e8d4,stroke:#82b366
