graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
        RayClient["Ray Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        DashRoute["Route: ray-dashboard-{cluster}<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["Route: rayclient-{cluster}<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Controller["codeflare-operator-controller-manager<br/>SA: controller-manager<br/>Image: codeflare-operator:v1.16.0"]
        WebhookSvc["webhook-service<br/>443→9443/TCP HTTPS<br/>cert-controller TLS"]
        MetricsSvc["manager-metrics<br/>8080/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACE (per RayCluster)"]
        direction TB

        subgraph HeadPod["Ray Head Pod"]
            RayHead["ray-head container<br/>8265/TCP (dashboard)<br/>10001/TCP (gRPC)"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth"]
            CertInitH["create-cert init<br/>mTLS cert gen"]
        end

        OAuthSvc["{cluster}-oauth Service<br/>443→8443/TCP HTTPS<br/>serving-cert TLS"]

        subgraph WorkerPods["Ray Worker Pods"]
            RayWorker["ray-worker container<br/>10001/TCP gRPC<br/>RAY_USE_TLS=1"]
            CertInitW["create-cert init"]
        end

        subgraph NetworkPolicies["NetworkPolicies"]
            HeadPolicy["{cluster}-head<br/>Allow: same-cluster, same-ns,<br/>kuberay-ns, monitoring,<br/>all on 8443+10001"]
            WorkerPolicy["{cluster}-workers<br/>Allow: same-cluster ONLY"]
        end
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount token"]
        OSHOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+"]
        CertSigner["OpenShift serving-cert-signer<br/>Annotation-triggered"]
        KubeRay["KubeRay Operator<br/>Creates RayCluster CRs"]
        ODHOp["opendatahub-operator<br/>DSCInitialization CR"]
        Kueue["Kueue (optional)<br/>Quota-aware scheduling"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>ServiceMonitor"]
    end

    %% External → Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (→ OAuth redirect)"| DashRoute
    RayClient -->|"HTTPS/443<br/>TLS passthrough<br/>mTLS client cert"| ClientRoute

    %% Ingress → User NS flows
    DashRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth token"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>mTLS passthrough<br/>CA-signed cert"| RayHead

    %% Within User NS
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>Delegated SAR"| RayHead
    OAuthSvc -->|"443→8443"| OAuthProxy

    %% Head ↔ Worker mTLS
    RayHead <-->|"gRPC/10001<br/>mTLS (RAY_USE_TLS=1)<br/>CA-signed certs"| RayWorker

    %% Controller flows
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRD watch, CRUD, SAR"| K8sAPI
    K8sAPI -->|"HTTPS/443<br/>API server client cert"| WebhookSvc

    %% Platform integrations
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth redirect"| OSHOAuth
    CertSigner -.->|"Generates TLS cert"| OAuthSvc
    KubeRay -->|"Creates RayCluster CRs"| K8sAPI
    Controller -.->|"Reads DSCInitialization"| ODHOp
    Controller -.->|"AppWrapper integration"| Kueue
    Prometheus -->|"HTTP/8080<br/>Metrics scraping"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User,RayClient external
    class DashRoute,ClientRoute ingress
    class Controller,WebhookSvc,MetricsSvc operator
    class RayHead,OAuthProxy,CertInitH,OAuthSvc,RayWorker,CertInitW userns
    class K8sAPI,OSHOAuth,CertSigner,KubeRay,ODHOp,Kueue,Prometheus platform
    class HeadPolicy,WorkerPolicy netpol
