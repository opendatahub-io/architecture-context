graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User]
        RayClient[Ray Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        DashboardRoute["OpenShift Route<br/>ray-dashboard-{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ edge<br/>OAuth Bearer Token"]
        ClientRoute["OpenShift Route<br/>ray-client-{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ passthrough<br/>Client Certificate"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE (Trusted - Control Plane)"]
        direction TB

        subgraph ManagerPod["Manager Pod<br/>SA: controller-manager<br/>UBI9 minimal FIPS"]
            WebhookSvc["Webhook Service<br/>443→9443/TCP<br/>HTTPS TLS1.2+<br/>mTLS (API Server only)"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>Bearer Token (Prometheus)"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph UserNamespace["USER NAMESPACES (Multi-tenant)"]
        direction TB

        subgraph NS_User["{user-namespace}"]
            subgraph RayHeadPod["Ray Head Pod<br/>SA: {cluster}-sa<br/>Label: ray.io/node-type=head"]
                RayDashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>OAuth proxy sidecar"]
                RayClientAPI["Ray Client API<br/>10001/TCP gRPC<br/>mTLS (optional)<br/>CA: {cluster}-ca"]
            end

            subgraph RayWorkerPods["Ray Worker Pods<br/>SA: {cluster}-sa<br/>Label: ray.io/node-type=worker"]
                Workers["Worker Processes"]
            end

            NetworkPolicy["NetworkPolicy<br/>{cluster}-head-*: Allow same cluster + KubeRay NS<br/>{cluster}-workers-*: Allow same cluster only"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Bearer Token Auth"]
        KubeRay["KubeRay Operator<br/>v1.2.1<br/>Namespace: kuberay-system"]
        Kueue["Kueue<br/>v0.10.1+<br/>Namespace: kueue-system"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>ServiceAccount Bearer Token"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+ edge<br/>OAuth Bearer Token| DashboardRoute
    RayClient -->|HTTPS/443<br/>TLS 1.2+ passthrough<br/>Client Certificate| ClientRoute

    %% Ingress to User Namespace
    DashboardRoute -->|HTTP/8265<br/>No encryption<br/>Pod-to-pod| RayDashboard
    ClientRoute -->|gRPC/10001<br/>mTLS<br/>Client Certificate| RayClientAPI

    %% Ray Internal
    RayClientAPI -->|Internal TCP<br/>mTLS optional| Workers
    NetworkPolicy -.->|enforces| RayHeadPod
    NetworkPolicy -.->|enforces| RayWorkerPods

    %% Operator to K8s API
    ManagerPod -->|HTTPS/6443<br/>TLS 1.3<br/>Bearer Token SA| K8sAPI

    %% K8s API to Webhooks
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS| WebhookSvc

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Bearer Token| MetricsSvc

    %% Dependencies
    ManagerPod -.->|watches CRDs| KubeRay
    ManagerPod -.->|integrates| Kueue

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef usernamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,RayClient external
    class DashboardRoute,ClientRoute ingress
    class ManagerPod,WebhookSvc,MetricsSvc,HealthProbes operator
    class RayHeadPod,RayWorkerPods,RayDashboard,RayClientAPI,Workers,NetworkPolicy usernamespace
    class K8sAPI,KubeRay,Kueue,Prometheus controlplane
