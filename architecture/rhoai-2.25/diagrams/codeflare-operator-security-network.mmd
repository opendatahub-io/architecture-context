%% Security Network Diagram - CodeFlare Operator
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        RayClient["Ray Client"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["CodeFlare Operator Manager"]
            Controller["RayCluster Controller +<br/>AppWrapper Controller"]
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-managed)"]
            Metrics["Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        end
    end

    subgraph UserNS["USER NAMESPACE"]
        direction TB

        subgraph HeadPod["Ray Head Pod (with injected sidecars)"]
            OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>service-serving-cert<br/>OpenShift OAuth"]
            RayHead["Ray Head<br/>8265/TCP HTTP (dashboard)<br/>10001/TCP gRPC (client)<br/>mTLS (CA-signed)"]
            InitCert["create-cert init<br/>(generates TLS certs)"]
        end

        subgraph WorkerPods["Ray Worker Pods"]
            RayWorker["Ray Workers<br/>mTLS (CA-signed)<br/>RSA 2048-bit, 1yr"]
        end

        NetPolHead["NetworkPolicy: head<br/>Allow: cluster pods (all)<br/>Allow: 8265,10001 (namespace)<br/>Allow: 8080 (monitoring)<br/>Allow: 8443 (all)"]
        NetPolWorker["NetworkPolicy: workers<br/>Allow: cluster pods only"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        DashboardRoute["ray-dashboard Route<br/>443/TCP HTTPS<br/>TLS Reencrypt<br/>OpenShift OAuth"]
        ClientRoute["rayclient Route<br/>443/TCP HTTPS<br/>TLS Passthrough<br/>mTLS client cert"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>OpenShift Monitoring"]
    end

    subgraph InternalODH["INTERNAL ODH COMPONENTS"]
        RHODSOp["rhods-operator<br/>(deploys via kustomize)"]
        KubeRay["KubeRay Operator<br/>(pod label lookup)"]
        DSCI["DSCInitialization CR"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OpenShiftOAuth["OpenShift OAuth<br/>443/TCP HTTPS"]
        CertSigner["service-serving-cert-signer<br/>(annotation-based)"]
        Kueue["Kueue<br/>(AppWrapper integration)"]
    end

    %% User flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| APIServer
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OAuth"| DashboardRoute

    RayClient -->|"HTTPS/443<br/>TLS Passthrough<br/>mTLS client cert"| ClientRoute

    %% API Server to Webhooks
    APIServer -->|"HTTPS/9443<br/>TLS<br/>API server client cert"| WebhookServer

    %% Controller to API Server
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| APIServer

    %% Route flows
    DashboardRoute -->|"HTTPS/8443<br/>service-serving-cert"| OAuthProxy
    OAuthProxy -->|"HTTP/8265<br/>plaintext (localhost)"| RayHead
    ClientRoute -->|"gRPC/10001<br/>mTLS passthrough"| RayHead

    %% Ray internal
    RayHead -->|"gRPC/10001<br/>mTLS<br/>CA-signed cert"| RayWorker

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>plaintext"| Metrics

    %% Internal ODH
    RHODSOp -.->|"deploys"| OperatorPod
    Controller -->|"HTTPS/6443<br/>pod label lookup"| KubeRay
    Controller -->|"reads"| DSCI

    %% External services
    OAuthProxy -.->|"OAuth redirect"| OpenShiftOAuth
    CertSigner -.->|"provisions cert"| OAuthProxy
    Controller -->|"HTTPS/6443<br/>CRD integration"| Kueue

