/*
 * C4 Context Diagram: model-metadata-collection
 * Generated by: Claude Opus 4.6
 *
 * This component is a build-time data pipeline that produces a static
 * catalog container image. It has NO runtime network services.
 */

workspace {
    model {
        // Actors
        cicd = person "CI/CD Pipeline" "Konflux / GitHub Actions triggers build-time catalog generation"

        // Primary System
        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time Go pipeline that extracts, enriches, and catalogs metadata from Red Hat AI container images (ModelCars) and HuggingFace, producing a static YAML catalog in a minimal container image" {
            modelExtractor = container "model-extractor" "Main pipeline: discovers HuggingFace collections, extracts model cards from OCI layers, enriches metadata, generates catalog" "Go CLI"
            metadataReport = container "metadata-report" "Analyzes metadata completeness and data source tracking across all processed models" "Go CLI"
            huggingfaceLib = container "huggingface package" "Fetches HuggingFace collections, model details, README files; parses YAML frontmatter and tags" "Go Library"
            registryLib = container "registry package" "Fetches OCI manifest metadata from container registries" "Go Library"
            enrichmentLib = container "enrichment package" "Enriches extracted model metadata with HuggingFace data, manages data priority hierarchy" "Go Library"
            catalogLib = container "catalog package" "Aggregates individual model metadata into unified catalog, handles deduplication and merging" "Go Library"
            metadataLib = container "metadata package" "Parses model card markdown, extracts structured metadata via YAML frontmatter and regex" "Go Library"
            dataContainer = container "Data Container" "Minimal UBI9-micro container serving static catalog YAML via volume mount; runs sleep infinity" "Container (UBI9-micro)"
        }

        // External Systems
        huggingface = softwareSystem "HuggingFace" "Model collections, details, README content, and tags" "External"
        redhatRegistry = softwareSystem "Red Hat Container Registry" "Source of ModelCar OCI container images (registry.redhat.io)" "External"
        konflux = softwareSystem "Konflux" "Tekton-based hermetic container build pipeline with multi-arch support" "External"

        // Internal ODH Systems
        odhDashboard = softwareSystem "ODH Dashboard" "Displays validated model catalog to users" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata (compatible schema)" "Internal ODH"

        // Relationships
        cicd -> modelMetadataCollection "Triggers build-time catalog generation"
        modelExtractor -> huggingfaceLib "Uses"
        modelExtractor -> registryLib "Uses"
        modelExtractor -> enrichmentLib "Uses"
        modelExtractor -> catalogLib "Uses"
        modelExtractor -> metadataLib "Uses"

        modelMetadataCollection -> huggingface "Fetches model collections, details, and README files" "HTTPS/443"
        modelMetadataCollection -> redhatRegistry "Pulls ModelCar OCI manifests and image layers" "HTTPS/443"
        konflux -> modelMetadataCollection "Builds container image with pre-generated catalog data"

        odhDashboard -> modelMetadataCollection "Mounts or copies models-catalog.yaml" "Volume mount"
        modelMetadataCollection -> modelRegistry "Catalog output compatible with registry schema" "Data format"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
