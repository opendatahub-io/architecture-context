graph TB
    subgraph RhodsOperator["rhods-operator (RHOAI Platform Operator)"]
        direction TB

        subgraph InfraLayer["Infrastructure Layer"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            AuthSvc["Auth Service<br/>Controller"]
            MonSvc["Monitoring Service<br/>Controller"]
            SMSvc["ServiceMesh Service<br/>Controller"]
            CertGen["CertConfigMapGenerator<br/>Controller"]
            SecGen["SecretGenerator<br/>Controller"]
            SetupSvc["Setup Service<br/>Controller"]
        end

        subgraph AppLayer["Application Layer"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
            CompReg["Component Registry<br/>(plugin system)"]
            DSCCtrl -->|iterates| CompReg
        end

        subgraph ComponentControllers["Component Controllers (14)"]
            direction LR
            DashCtrl["Dashboard"]
            WBCtrl["Workbenches"]
            KServeCtrl["KServe"]
            MMCtrl["ModelMesh"]
            MCCtrl["ModelController"]
            DSPCtrl["DataScience<br/>Pipelines"]
            KueueCtrl["Kueue"]
            CFCtrl["CodeFlare"]
            RayCtrl["Ray"]
            TAICtrl["TrustyAI"]
            MRCtrl["ModelRegistry"]
            TOCtrl["Training<br/>Operator"]
            FeastCtrl["Feast<br/>Operator"]
            LlamaCtrl["LlamaStack<br/>Operator"]
        end

        subgraph Webhooks["Admission Webhooks (10)"]
            direction LR
            MutDSC["Mutate DSC"]
            ValDSC["Validate DSC"]
            ValDSCI["Validate DSCI"]
            MutHWP["Mutate<br/>HardwareProfile"]
            MutISVC["Mutate<br/>InferenceService"]
            MutNB["Mutate<br/>Notebook"]
            ValKueue["Validate<br/>Kueue"]
        end
    end

    %% CRDs
    DSCICR["DSCInitialization CR<br/>(Cluster-scoped, singleton)"]
    DSCCR["DataScienceCluster CR<br/>(Cluster-scoped, singleton)"]
    CompCRs["Component CRs<br/>(14 types, v1alpha1)"]

    %% External Dependencies
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    OSShift["OpenShift Platform<br/>(OAuth, Routes, Console)"]
    Istio["Maistra/Istio<br/>ServiceMesh"]
    Authorino["Authorino<br/>Authorization"]
    Knative["Knative Serving<br/>Operator"]
    COO["Cluster Observability<br/>Operator"]
    Tempo["Tempo Operator"]
    OTEL["OpenTelemetry<br/>Operator"]
    OLM["OLM<br/>(Operator Lifecycle)"]

    %% Flows
    DSCICR -->|watched by| DSCICtrl
    DSCCR -->|watched by| DSCCtrl
    CompReg -->|creates| CompCRs
    CompCRs -->|watched by| ComponentControllers

    DSCICtrl -->|initializes| AuthSvc
    DSCICtrl -->|initializes| MonSvc
    DSCICtrl -->|initializes| SMSvc
    DSCICtrl -->|initializes| CertGen
    DSCICtrl -->|initializes| SecGen

    %% External connections
    ComponentControllers -->|deploys manifests via| K8sAPI
    DSCICtrl -->|configures| K8sAPI
    SMSvc -->|creates SMCP| Istio
    SMSvc -->|deploys| Authorino
    KServeCtrl -->|configures| Knative
    MonSvc -->|creates MonitoringStack| COO
    MonSvc -->|creates TempoStack| Tempo
    MonSvc -->|creates Collector| OTEL
    DSCCtrl -->|detects operators| OLM
    SecGen -->|registers OAuthClient| OSShift

    %% Styling
    style RhodsOperator fill:#e8f4fd,stroke:#2196F3,stroke-width:2px
    style InfraLayer fill:#fff3e0,stroke:#FF9800,stroke-width:1px
    style AppLayer fill:#e8f5e9,stroke:#4CAF50,stroke-width:1px
    style ComponentControllers fill:#f3e5f5,stroke:#9C27B0,stroke-width:1px
    style Webhooks fill:#fce4ec,stroke:#E91E63,stroke-width:1px

    style DSCICtrl fill:#FF9800,color:#fff
    style DSCCtrl fill:#4CAF50,color:#fff
    style CompReg fill:#66BB6A,color:#fff

    style DSCICR fill:#f5a623,stroke:#333
    style DSCCR fill:#f5a623,stroke:#333
    style CompCRs fill:#f5a623,stroke:#333

    style K8sAPI fill:#e0e0e0,stroke:#333
    style OSShift fill:#e0e0e0,stroke:#333
    style Istio fill:#e0e0e0,stroke:#333
    style Authorino fill:#e0e0e0,stroke:#333
    style Knative fill:#e0e0e0,stroke:#333
    style COO fill:#e0e0e0,stroke:#333
    style Tempo fill:#e0e0e0,stroke:#333
    style OTEL fill:#e0e0e0,stroke:#333
    style OLM fill:#e0e0e0,stroke:#333
