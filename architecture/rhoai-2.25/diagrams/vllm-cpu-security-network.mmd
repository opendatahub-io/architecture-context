graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) — Managed by KServe"]
        KServeRoute["KServe Route / HTTPRoute<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Per-InferenceService routing"]
    end

    subgraph Application["APPLICATION (vllm-cpu Pod, UID 2000, UBI 9 minimal)"]
        direction TB

        subgraph OpenAI["vllm-openai (Primary)"]
            FastAPI["FastAPI + Uvicorn<br/>8000/TCP HTTP<br/>Optional TLS (--ssl-keyfile/certfile)<br/>SSLCertRefresher hot-reload"]
            AuthMW["AuthenticationMiddleware<br/>API Key: SHA-256 constant-time<br/>Scope: /v1/* endpoints"]
            FastAPI --- AuthMW
        end

        subgraph GRPC["vllm-grpc-adapter (Alternate)"]
            TGISAdapter["vllm-tgis-adapter 0.9.0.post1<br/>8033/TCP gRPC<br/>Encryption: Configurable<br/>Auth: Configurable"]
        end

        subgraph EngineInternal["vLLM Engine (In-process only)"]
            Engine["AsyncLLM V1 / MQLLMEngineClient V0<br/>PyTorch CPU + IPEX/OpenBLAS<br/>C/C++ optimized kernels"]
        end

        FastAPI --> Engine
        TGISAdapter --> Engine
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (HF_TOKEN)"]
        S3["S3-compatible Storage<br/>(optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM credentials"]
        Stats["vLLM Stats Server<br/>stats.vllm.ai<br/>443/TCP HTTPS<br/>DISABLED by default"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus / OpenShift Monitoring<br/>Scrape: GET /metrics<br/>8000/TCP HTTP"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| KServeRoute
    KServeRoute -->|"HTTP/8000<br/>Optional TLS<br/>API key (optional)"| FastAPI
    Client -->|"gRPC/8033<br/>Configurable TLS"| TGISAdapter

    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Engine -.->|"HTTPS/443<br/>DISABLED"| Stats

    Prometheus -->|"HTTP/8000<br/>No auth"| FastAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef disabled fill:#f0f0f0,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class KServeRoute ingress
    class FastAPI,AuthMW,TGISAdapter,Engine application
    class HFHub,S3 externalservice
    class Stats disabled
    class Prometheus observability
