graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)"]

    %% Internal Platform Dependencies (Direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>HTTP/HTTPS 8085/TCP<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (Indirect via Orchestrator)
    Orchestrator -.->|"detector invocation"| Detectors["Guardrails Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -.->|"inference requests"| vLLM["vLLM / LLM Server"]

    %% Platform Infrastructure
    Gateway -->|"volume mount<br/>/etc/tls/private/"| K8sSecrets["Kubernetes Secrets<br/>(TLS cert + key)"]
    Gateway -->|"volume mount<br/>/etc/tls/ca/service-ca.crt"| ServiceCA["OpenShift Service CA"]
    Gateway -->|"GATEWAY_CONFIG env<br/>ConfigMap/Volume"| ConfigMap["Gateway Config<br/>(YAML)"]

    %% Key Rust Dependencies
    subgraph "Rust Crate Dependencies"
        axum["axum 0.7.9<br/>(HTTP framework)"]
        reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        tokio["tokio 1.41.1<br/>(async runtime)"]
        nativeTLS["native-tls 0.2.12<br/>(TLS backend)"]
        openssl["openssl 0.10.73<br/>(cert handling)"]
        serde["serde / serde_json<br/>(JSON serialization)"]
        serdeYml["serde_yml 0.0.12<br/>(YAML parsing)"]
    end

    Gateway -->|"framework"| axum
    Gateway -->|"upstream client"| reqwest
    Gateway -->|"runtime"| tokio
    reqwest -->|"TLS backend"| nativeTLS
    nativeTLS -->|"OpenSSL bindings"| openssl
    Gateway -->|"payload parsing"| serde
    Gateway -->|"config parsing"| serdeYml

    %% Styling
    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style K8sSecrets fill:#f5a623,stroke:#333
    style ServiceCA fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style axum fill:#dae8fc,stroke:#6c8ebf
    style reqwest fill:#dae8fc,stroke:#6c8ebf
    style tokio fill:#dae8fc,stroke:#6c8ebf
    style nativeTLS fill:#dae8fc,stroke:#6c8ebf
    style openssl fill:#dae8fc,stroke:#6c8ebf
    style serde fill:#dae8fc,stroke:#6c8ebf
    style serdeYml fill:#dae8fc,stroke:#6c8ebf
