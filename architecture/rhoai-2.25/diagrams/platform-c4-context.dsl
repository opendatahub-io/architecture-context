// RHOAI 2.25 Platform C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/PLATFORM.md

workspace {
    model {
        // Personas
        dataScientist = person "Data Scientist" "Develops, trains, and deploys ML models using notebooks and pipelines"
        mlEngineer = person "ML Engineer" "Deploys and manages model serving infrastructure"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform lifecycle and configuration"
        securityTeam = person "Security / Compliance" "Reviews model safety, bias, and platform security"

        // Main system
        rhoai = softwareSystem "Red Hat OpenShift AI (RHOAI) 2.25" "Enterprise AI/ML platform on OpenShift" {

            // Top-level operator
            rhodsOperator = container "rhods-operator" "Top-level OLM operator managing 15+ component sub-systems via DSCInitialization and DataScienceCluster CRs" "Go, controller-runtime, 3 replicas"

            // Interactive Development
            dashboard = container "ODH Dashboard" "Web-based management UI for notebooks, model serving, pipelines, and model registry" "TypeScript (React/PatternFly) + Go BFF"
            notebookController = container "Notebook Controller" "Manages Jupyter, Code Server, and RStudio workbench pods" "Go, controller-runtime"

            // Model Serving
            kserveController = container "KServe Controller" "Manages InferenceService lifecycle for serverless and raw deployment modes" "Go, controller-runtime"
            odhModelController = container "ODH Model Controller" "Creates Routes, Gateways, AuthConfigs, and NIM account management for InferenceServices" "Go, controller-runtime"
            modelmeshServing = container "ModelMesh Serving" "Multi-model serving with distributed LRU cache, gRPC routing, and runtime adapters" "Go + Java (ModelMesh sidecar)"

            // LLM Infrastructure
            llmdScheduler = container "llm-d Inference Scheduler" "Disaggregated prefill/decode scheduling via Envoy ext-proc for LLM workloads" "Go"
            orchestratorGateway = container "vLLM Orchestrator Gateway" "Route-specific detector config injection for guardrailed LLM inference" "Rust (axum)"

            // AI Safety
            guardrailsOrchestrator = container "FMS Guardrails Orchestrator" "Content safety orchestration with input/output detector pipelines" "Rust (axum)"
            guardrailsDetectors = container "Guardrails Detectors" "HuggingFace and LLM Judge text safety classification" "Python (FastAPI)"

            // Pipelines
            dspOperator = container "DSP Operator" "Deploys per-namespace KFP v2 pipeline stacks" "Go, controller-runtime"
            dspService = container "Data Science Pipelines" "Pipeline API server, persistence agent, and scheduler" "Go"
            argoWorkflows = container "Argo Workflows" "Workflow execution engine for pipeline steps" "Go"
            mlMetadata = container "ML Metadata" "gRPC metadata store for artifact lineage and experiment tracking" "C++"

            // Model Registry
            modelRegistryOp = container "Model Registry Operator" "Deploys per-namespace Model Registry instances" "Go, controller-runtime"
            modelRegistry = container "Model Registry" "ML model metadata management (versions, artifacts, deployments)" "Go/C++"

            // Training & Scheduling
            trainingOperator = container "Training Operator" "Manages distributed training jobs (PyTorch, TF, MPI, JAX, XGBoost)" "Go, controller-runtime"
            kuberay = container "KubeRay Operator" "Manages Ray clusters, jobs, and services" "Go, controller-runtime"
            codeflare = container "CodeFlare Operator" "Manages AppWrapper CRs for batch workload scheduling" "Go, controller-runtime"
            kueue = container "Kueue Controller" "Resource quota management and job queuing with fair sharing" "Go, controller-runtime"

            // Explainability
            trustyaiOp = container "TrustyAI Service Operator" "Deploys TrustyAI, LMEval, and Guardrails instances" "Go, controller-runtime"
            trustyai = container "TrustyAI Explainability" "Bias detection, drift monitoring, LIME/SHAP explanations" "Java 17 (Quarkus)"

            // Feature Store & LLM Agents
            feastOperator = container "Feast Operator" "Deploys feature store instances" "Go/Python, controller-runtime"
            llamaStackOp = container "Llama Stack Operator" "Deploys LLM inference, RAG, and agent orchestration stacks" "Go, controller-runtime"

            // Inference Runtimes
            inferenceRuntimes = container "Inference Runtimes" "vLLM (CUDA/CPU/ROCm/Gaudi), OVMS, TGIS, Caikit-TGIS" "Python/C++/Rust"
        }

        // External dependencies (OCP Platform)
        ocp = softwareSystem "OpenShift Container Platform" "Kubernetes distribution providing OLM, Routes, OAuth, monitoring" "External" {
            tags "External"
        }
        istio = softwareSystem "Istio / Service Mesh" "Service mesh for mTLS, traffic management, and Authorino integration" "External" {
            tags "External"
        }
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform for KServe serverless mode" "External" {
            tags "External"
        }
        certManager = softwareSystem "cert-manager" "TLS certificate management for KServe webhooks" "External" {
            tags "External"
        }

        // External services
        s3 = softwareSystem "S3 / Object Storage" "Model weight storage, pipeline artifacts, TrustyAI data" "External Service" {
            tags "External Service"
        }
        mariadb = softwareSystem "MariaDB" "Pipeline metadata and TrustyAI data persistence" "External Service" {
            tags "External Service"
        }
        etcd = softwareSystem "etcd" "ModelMesh coordination store for model registry and leader election" "External Service" {
            tags "External Service"
        }
        ngc = softwareSystem "NVIDIA NGC" "NIM account validation for NVIDIA model serving" "External Service" {
            tags "External Service"
        }
        huggingface = softwareSystem "HuggingFace" "Model weights and metadata for inference runtimes and catalog" "External Service" {
            tags "External Service"
        }
        containerRegistries = softwareSystem "Container Registries" "registry.redhat.io, quay.io - 76 container images pinned by SHA256" "External Service" {
            tags "External Service"
        }

        // Relationships - Users
        dataScientist -> dashboard "Creates notebooks, deploys models, runs pipelines via" "HTTPS/443"
        mlEngineer -> kserveController "Deploys InferenceService CRs via" "kubectl"
        mlEngineer -> modelmeshServing "Deploys multi-model serving via" "kubectl"
        platformAdmin -> rhodsOperator "Configures DSC/DSCI CRs via" "kubectl"
        securityTeam -> trustyai "Reviews bias/drift metrics via" "HTTPS"
        securityTeam -> guardrailsOrchestrator "Configures safety detectors via" "HTTP"

        // Relationships - Operator hierarchy
        rhodsOperator -> dashboard "Deploys and manages"
        rhodsOperator -> notebookController "Deploys and manages"
        rhodsOperator -> kserveController "Deploys and manages"
        rhodsOperator -> odhModelController "Deploys and manages"
        rhodsOperator -> modelmeshServing "Deploys and manages"
        rhodsOperator -> dspOperator "Deploys and manages"
        rhodsOperator -> trainingOperator "Deploys and manages"
        rhodsOperator -> kuberay "Deploys and manages"
        rhodsOperator -> codeflare "Deploys and manages"
        rhodsOperator -> kueue "Deploys and manages"
        rhodsOperator -> modelRegistryOp "Deploys and manages"
        rhodsOperator -> trustyaiOp "Deploys and manages"
        rhodsOperator -> feastOperator "Deploys and manages"
        rhodsOperator -> llamaStackOp "Deploys and manages"

        // Component interactions
        kserveController -> inferenceRuntimes "Creates predictor pods with"
        kserveController -> istio "Uses for mTLS and traffic routing"
        kserveController -> knative "Uses for serverless autoscaling"
        odhModelController -> kserveController "Creates Routes/AuthConfigs for"
        modelmeshServing -> etcd "Coordination store" "gRPC/2379"
        dspOperator -> dspService "Deploys"
        dspService -> argoWorkflows "Executes pipelines via"
        dspService -> mlMetadata "Records lineage via" "gRPC/8080"
        modelRegistryOp -> modelRegistry "Deploys"
        trustyaiOp -> trustyai "Deploys"
        trustyaiOp -> guardrailsOrchestrator "Deploys"
        orchestratorGateway -> guardrailsOrchestrator "Routes guardrailed requests to" "HTTP/8033"
        guardrailsOrchestrator -> guardrailsDetectors "Calls safety detectors" "HTTP/8000"
        llmdScheduler -> inferenceRuntimes "Schedules prefill/decode" "ext-proc gRPC/9002"
        dashboard -> modelRegistry "Browses models via" "HTTP/8080"

        // External service usage
        inferenceRuntimes -> s3 "Downloads model weights" "HTTPS/443"
        dspService -> s3 "Stores pipeline artifacts" "HTTPS/443"
        dspService -> mariadb "Persists pipeline metadata" "MySQL/3306"
        trustyai -> mariadb "Stores monitoring data" "JDBC/3306"
        odhModelController -> ngc "Validates NIM accounts" "HTTPS/443"
        rhodsOperator -> ocp "Reconciles via Kubernetes API" "HTTPS/6443"
        rhodsOperator -> containerRegistries "Pulls 76 container images" "HTTPS/443"
        kserveController -> certManager "Obtains webhook certificates"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #000000
            }
        }
    }
}
