/*
 * C4 Context Diagram: LM Evaluation Harness
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Defines evaluation tasks and reviews results"
        mlEngineer = person "ML Engineer" "Configures model evaluation pipelines"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Framework for evaluating generative language models on standardized benchmarks and custom tasks. Runs as batch Kubernetes Jobs." {
            cli = container "lm_eval CLI" "Main entry point for running model evaluations" "Python CLI"
            evaluator = container "Evaluator" "Core evaluation orchestration - manages task execution, metric computation, result aggregation" "Python Module"
            taskFramework = container "Task Framework" "Configurable task system with YAML-based task definitions and registry pattern" "Python Module"
            modelRegistry = container "Model Registry" "Plugin-based model backend system supporting HuggingFace, vLLM, OpenAI API, watsonx.ai" "Python Module"
            metricsSystem = container "Metrics System" "50+ bundled HF Evaluate-compatible metrics for offline evaluation" "Python Module + Bundled Metrics"
            unitxtIntegration = container "Unitxt Integration" "Integration with Unitxt framework for customizable text data preparation" "Python Module"
            cachingSystem = container "Caching System" "SQLite-based request/response caching" "Python Module"
        }

        trustyaiOperator = softwareSystem "TrustyAI LMEval Operator" "Creates and manages Kubernetes Jobs running lm-eval container" "Internal RHOAI"
        vllmServing = softwareSystem "vLLM Inference Service" "High-throughput model serving via OpenAI-compatible API" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform" "Internal RHOAI"
        modelRegistryService = softwareSystem "Model Registry" "Stores model metadata and versions" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and dataset repository" "External"
        s3Storage = softwareSystem "S3 Storage" "Object storage for models and datasets" "External"
        watsonxAI = softwareSystem "IBM watsonx.ai" "IBM cloud AI platform" "External"

        # Relationships
        dataScientist -> trustyaiOperator "Submits LMEvalJob CR"
        mlEngineer -> trustyaiOperator "Configures evaluation pipelines"
        trustyaiOperator -> lmEvalHarness "Creates Kubernetes Job" "K8s API / mTLS"

        lmEvalHarness -> huggingfaceHub "Downloads models, datasets, tokenizers" "HTTPS/443"
        lmEvalHarness -> vllmServing "Sends evaluation prompts" "HTTP/8000"
        lmEvalHarness -> kserve "Sends evaluation prompts" "HTTP(S)/8080-443"
        lmEvalHarness -> s3Storage "Downloads models/datasets" "HTTPS/443"
        lmEvalHarness -> watsonxAI "Evaluates models via API" "HTTPS/443"
        lmEvalHarness -> modelRegistryService "References tracked models" "Indirect"

        # Internal container relationships
        cli -> evaluator "Orchestrates"
        evaluator -> taskFramework "Loads tasks"
        evaluator -> modelRegistry "Selects backend"
        evaluator -> metricsSystem "Computes metrics"
        evaluator -> cachingSystem "Caches results"
        taskFramework -> unitxtIntegration "Prepares data"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
