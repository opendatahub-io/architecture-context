graph TB
    subgraph Pod["KServe InferenceService Pod"]
        direction TB

        subgraph TransformerContainer["transformer-container"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            CaikitConfig["caikit.yml<br/>Runtime Configuration"]
            CaikitNLP["caikit-nlp 0.5.14<br/>NLP Module Library"]
            CaikitTGISBackend["caikit-tgis-backend 0.1.39<br/>TGIS gRPC Connector"]

            CaikitConfig -->|configures| CaikitRuntime
            CaikitRuntime -->|loads| CaikitNLP
            CaikitRuntime -->|uses| CaikitTGISBackend
        end

        subgraph KServeContainer["kserve-container"]
            TGIS["TGIS<br/>(Text Generation Inference Server)<br/>GPU-accelerated inference"]
        end

        ModelDir["/mnt/models<br/>Model Artifacts"]

        CaikitTGISBackend -->|"gRPC localhost:8033"| TGIS
        CaikitRuntime -->|reads| ModelDir
        TGIS -->|loads| ModelDir
    end

    Client["External Client"] -->|"HTTPS/443"| IstioGW["Istio Ingress Gateway"]
    IstioGW -->|"HTTP/8012 (mTLS)"| QueueProxy["Knative Queue-Proxy"]
    QueueProxy -->|"HTTP/8080 or gRPC/8085"| CaikitRuntime

    Prometheus["Prometheus<br/>User Workload Monitoring"] -->|"HTTP/8086<br/>(PERMISSIVE mTLS)"| CaikitRuntime

    KServeStorageInit["KServe Storage Initializer"] -->|"downloads models"| ModelDir
    S3["S3-compatible Storage"] -->|"HTTPS/443"| KServeStorageInit

    subgraph APIs["Caikit APIs"]
        HTTP_API["HTTP API :8080<br/>/api/v1/task/text-generation<br/>/api/v1/task/embedding<br/>/health"]
        GRPC_API["gRPC API :8085<br/>caikit.runtime.Nlp"]
        Metrics_API["Metrics :8086"]
    end

    CaikitRuntime --- HTTP_API
    CaikitRuntime --- GRPC_API
    CaikitRuntime --- Metrics_API

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style TGIS fill:#e67e22,stroke:#333,color:#fff
    style CaikitNLP fill:#5dade2,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#5dade2,stroke:#333,color:#fff
    style CaikitConfig fill:#85c1e9,stroke:#333
    style IstioGW fill:#999,stroke:#333,color:#fff
    style QueueProxy fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style ModelDir fill:#f9e79f,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style KServeStorageInit fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#333
    style HTTP_API fill:#d5f5e3,stroke:#333
    style GRPC_API fill:#d5f5e3,stroke:#333
    style Metrics_API fill:#d5f5e3,stroke:#333
