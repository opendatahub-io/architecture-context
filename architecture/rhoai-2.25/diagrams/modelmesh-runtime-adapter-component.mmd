graph TB
    subgraph Pod["ModelMesh Serving Pod"]
        direction TB

        subgraph MMesh["ModelMesh Container"]
            ModelMesh["ModelMesh<br/>Orchestrator"]
        end

        subgraph AdapterContainer["Runtime Adapter Sidecar<br/>(odh-modelmesh-runtime-adapter)"]
            direction TB

            subgraph Adapters["Runtime Adapters (one active per pod)"]
                TritonAdapter["triton-adapter<br/>8085/TCP gRPC"]
                MLServerAdapter["mlserver-adapter<br/>8085/TCP gRPC"]
                OVMSAdapter["ovms-adapter<br/>8085/TCP gRPC"]
                TorchServeAdapter["torchserve-adapter<br/>8085/TCP gRPC"]
            end

            subgraph PullerLayer["Model Puller"]
                Puller["puller<br/>Standalone gRPC Service"]
                Pullman["pullman<br/>Storage Provider Framework"]
                Puller --> Pullman
            end

            subgraph StorageProviders["Storage Providers (pullman)"]
                S3Provider["S3 Provider<br/>(AWS/IBM COS)"]
                GCSProvider["GCS Provider"]
                AzureProvider["Azure Provider"]
                HTTPProvider["HTTP Provider<br/>(mTLS support)"]
                PVCProvider["PVC Provider<br/>(symlinks)"]
            end

            Pullman --> S3Provider
            Pullman --> GCSProvider
            Pullman --> AzureProvider
            Pullman --> HTTPProvider
            Pullman --> PVCProvider

            TFConvert["tf_pb.py<br/>Keras→TF Converter"]
        end

        subgraph RuntimeContainer["Inference Runtime Container (one per pod)"]
            Triton["Triton Inference Server<br/>8001/TCP gRPC"]
            MLServer["Seldon MLServer<br/>8001/TCP gRPC"]
            OVMS["OpenVINO Model Server<br/>8001/TCP HTTP"]
            TorchServe["TorchServe<br/>7071/TCP mgmt gRPC<br/>7070/TCP infer gRPC"]
        end
    end

    %% ModelMesh to Adapters (mmesh.ModelRuntime gRPC)
    ModelMesh -->|"mmesh.ModelRuntime<br/>gRPC/8085 localhost"| TritonAdapter
    ModelMesh -->|"mmesh.ModelRuntime<br/>gRPC/8085 localhost"| MLServerAdapter
    ModelMesh -->|"mmesh.ModelRuntime<br/>gRPC/8085 localhost"| OVMSAdapter
    ModelMesh -->|"mmesh.ModelRuntime<br/>gRPC/8085 localhost"| TorchServeAdapter

    %% Adapters to Runtimes
    TritonAdapter -->|"gRPC/8001<br/>RepositoryModelLoad/Unload"| Triton
    MLServerAdapter -->|"gRPC/8001<br/>RepositoryModelLoad/Unload"| MLServer
    OVMSAdapter -->|"HTTP/8001<br/>POST /v1/config/reload"| OVMS
    TorchServeAdapter -->|"gRPC/7071<br/>RegisterModel/Unregister"| TorchServe

    %% Triton special: Keras conversion
    TritonAdapter -->|"subprocess"| TFConvert

    %% Embedded puller connections
    TritonAdapter -.->|"USE_EMBEDDED_PULLER"| Pullman
    MLServerAdapter -.->|"USE_EMBEDDED_PULLER"| Pullman
    OVMSAdapter -.->|"USE_EMBEDDED_PULLER"| Pullman
    TorchServeAdapter -.->|"USE_EMBEDDED_PULLER"| Pullman

    %% External: modelmesh-controller
    Controller["modelmesh-controller<br/>(modelmesh-serving)"] -->|"deploys image as<br/>storageHelperImage sidecar"| AdapterContainer

    %% External storage
    S3Provider -->|"HTTPS/443"| S3Storage["S3/IBM COS<br/>Storage"]
    GCSProvider -->|"HTTPS/443"| GCSStorage["Google Cloud<br/>Storage"]
    AzureProvider -->|"HTTPS/443"| AzureBlobStorage["Azure Blob<br/>Storage"]
    HTTPProvider -->|"HTTP/HTTPS"| HTTPEndpoint["HTTP Model<br/>Endpoint"]
    PVCProvider -->|"symlink"| PVCMount["/pvc_mounts/{name}/"]

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style TritonAdapter fill:#7ed321,stroke:#333
    style MLServerAdapter fill:#7ed321,stroke:#333
    style OVMSAdapter fill:#7ed321,stroke:#333
    style TorchServeAdapter fill:#7ed321,stroke:#333
    style Puller fill:#7ed321,stroke:#333
    style Pullman fill:#50c878,stroke:#333
    style TFConvert fill:#f5a623,stroke:#333
    style Triton fill:#e8e8e8,stroke:#333
    style MLServer fill:#e8e8e8,stroke:#333
    style OVMS fill:#e8e8e8,stroke:#333
    style TorchServe fill:#e8e8e8,stroke:#333
    style Controller fill:#9b59b6,stroke:#333,color:#fff
    style S3Storage fill:#f5a623,stroke:#333
    style GCSStorage fill:#f5a623,stroke:#333
    style AzureBlobStorage fill:#f5a623,stroke:#333
    style HTTPEndpoint fill:#f5a623,stroke:#333
    style PVCMount fill:#f5a623,stroke:#333
