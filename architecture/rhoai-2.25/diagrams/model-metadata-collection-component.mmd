graph TB
    subgraph "Model Metadata Collection"
        direction TB
        subgraph "CLI Tools (CI/CD Time Only)"
            Extractor["model-extractor<br/>Go CLI<br/>Main metadata pipeline"]
            Reporter["metadata-report<br/>Go CLI<br/>Completeness reports"]
        end

        subgraph "Data Container (Runtime)"
            DataContainer["odh-model-metadata-collection-rhel9<br/>ubi9-micro base<br/>CMD: sleep infinity"]
            CatalogFile["models-catalog.yaml"]
            IndexFile["models-index.yaml"]
            DataContainer --- CatalogFile
            DataContainer --- IndexFile
        end
    end

    subgraph "Input Sources"
        ModelsIndex["data/models-index.yaml<br/>Model definitions"]
        SupplementalCatalog["input/supplemental-catalog.yaml<br/>Static/legacy models"]
    end

    subgraph "External Services (CI/CD Egress)"
        Registry["registry.redhat.io<br/>OCI Distribution v2<br/>443/TCP HTTPS"]
        HuggingFace["huggingface.co<br/>REST API<br/>443/TCP HTTPS"]
    end

    subgraph "Platform Consumers (Runtime)"
        Dashboard["RHOAI Dashboard<br/>Displays validated models"]
    end

    subgraph "Build System"
        Konflux["Konflux CI/CD<br/>Tekton Pipeline"]
        Quay["quay.io/rhoai<br/>Container Registry"]
    end

    %% CI/CD data flows
    ModelsIndex -->|reads| Extractor
    SupplementalCatalog -->|merges| Extractor
    Extractor -->|pulls OCI images| Registry
    Extractor -->|fetches metadata| HuggingFace
    Extractor -->|generates| CatalogFile
    Reporter -->|reads| CatalogFile

    %% Build flows
    Konflux -->|builds| DataContainer
    DataContainer -->|pushed to| Quay

    %% Runtime consumption
    DataContainer -->|volume mount| Dashboard

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Reporter fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style CatalogFile fill:#f5a623,stroke:#333
    style IndexFile fill:#f5a623,stroke:#333
    style Registry fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333
    style Quay fill:#e8e8e8,stroke:#333
    style ModelsIndex fill:#f5a623,stroke:#333
    style SupplementalCatalog fill:#f5a623,stroke:#333
