graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB

        subgraph ControllerDeployment["workflow-controller Deployment"]
            Controller["workflow-controller<br/>Go Controller<br/>Ports: 9090/TCP metrics, 6060/TCP healthz"]
            LeaderElection["Leader Election<br/>via Lease API"]
            WorkflowWorkers["Workflow Workers (32)"]
            TTLWorkers["TTL Workers (4)"]
            PodCleanupWorkers["Pod Cleanup Workers (4)"]
            CronWorkers["CronWorkflow Workers (8)"]
            Controller --> LeaderElection
            Controller --> WorkflowWorkers
            Controller --> TTLWorkers
            Controller --> PodCleanupWorkers
            Controller --> CronWorkers
        end

        subgraph ExecutorSidecar["argoexec Sidecar (in Workflow Pods)"]
            ArgoExec["argoexec<br/>Go Sidecar/Init Container<br/>Emissary Mode"]
            ArtifactMgr["Artifact Upload/Download"]
            LogCapture["Log Capture"]
            TaskResult["WorkflowTaskResult Reporter"]
            ArgoExec --> ArtifactMgr
            ArgoExec --> LogCapture
            ArgoExec --> TaskResult
        end
    end

    %% CRDs
    WorkflowCR["Workflow CR<br/>argoproj.io/v1alpha1"]
    WorkflowTemplateCR["WorkflowTemplate CR<br/>argoproj.io/v1alpha1"]
    ClusterWFTemplateCR["ClusterWorkflowTemplate CR<br/>argoproj.io/v1alpha1"]
    CronWorkflowCR["CronWorkflow CR<br/>argoproj.io/v1alpha1"]
    TaskSetCR["WorkflowTaskSet CR<br/>argoproj.io/v1alpha1"]
    ArtifactGCCR["WorkflowArtifactGCTask CR<br/>argoproj.io/v1alpha1"]
    TaskResultCR["WorkflowTaskResult CR<br/>argoproj.io/v1alpha1"]

    %% External interactions
    DSP["Data Science Pipelines<br/>API Server"]
    K8sAPI["Kubernetes API Server"]
    S3["S3 / MinIO<br/>Artifact Store"]

    %% Flows
    DSP -->|creates| WorkflowCR
    WorkflowCR -->|watched by| Controller
    WorkflowTemplateCR -->|watched by| Controller
    ClusterWFTemplateCR -->|watched by| Controller
    CronWorkflowCR -->|watched by| CronWorkers
    Controller -->|creates| TaskSetCR
    Controller -->|creates| ArtifactGCCR

    Controller -->|creates Pods with| ArgoExec
    ArgoExec -->|creates| TaskResultCR
    TaskResultCR -->|watched by| Controller

    Controller -->|CRUD via| K8sAPI
    ArgoExec -->|reports via| K8sAPI
    ArgoExec -->|upload/download| S3

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExec fill:#4a90e2,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style WorkflowTemplateCR fill:#f5a623,stroke:#333,color:#fff
    style ClusterWFTemplateCR fill:#f5a623,stroke:#333,color:#fff
    style CronWorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style TaskSetCR fill:#f5a623,stroke:#333,color:#fff
    style ArtifactGCCR fill:#f5a623,stroke:#333,color:#fff
    style TaskResultCR fill:#f5a623,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
