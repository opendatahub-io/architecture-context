/*
 * ModelMesh Serving - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/modelmesh-serving.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates ServingRuntime and InferenceService/Predictor CRs to deploy and serve ML models"
        mlClient = person "ML Client" "Sends inference requests to deployed models via gRPC or REST"

        modelmeshServing = softwareSystem "ModelMesh Serving" "Kubernetes controller that manages multi-model serving runtimes with intelligent model placement, loading, and inference routing" {
            controller = container "modelmesh-controller" "Main controller manager running ServingRuntime, Predictor, and Service reconcilers" "Go Operator (controller-runtime)"
            webhook = container "ServingRuntime Webhook" "Validates ServingRuntime and ClusterServingRuntime specs for reserved names, ports, volumes" "Go Validating Webhook" "9443/TCP HTTPS"
            modelmeshSidecar = container "ModelMesh Sidecar" "Java-based model management runtime injected into serving pods; coordinates model placement and routing" "Java Sidecar" "8033/TCP gRPC"
            restProxy = container "REST Proxy Sidecar" "Translates HTTP/REST inference requests to gRPC" "Go Sidecar" "8008/TCP HTTP"
            oauthProxy = container "OAuth Proxy Sidecar" "Provides OpenShift OAuth authentication for REST inference" "OpenShift OAuth Proxy" "8443/TCP HTTPS"
            puller = container "Puller Sidecar" "Downloads model artifacts from storage backends (S3, GCS, Azure, PVC)" "modelmesh-runtime-adapter" "8086/TCP gRPC"
        }

        etcd = softwareSystem "etcd" "Key-value store for ModelMesh model placement coordination and state management" "Internal Dependency"
        k8sApi = softwareSystem "Kubernetes API" "Kubernetes control plane for CRD management, Deployment, Service, Secret lifecycle" "Platform"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "OpenShift authentication server for user identity verification" "Platform"
        modelStorage = softwareSystem "Model Storage" "S3, GCS, Azure Blob, or PVC-based model artifact storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor CRs" "Platform"

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys modelmesh-serving manifests, injects image references" "Internal RHOAI"
        odhModelController = softwareSystem "ODH Model Controller" "May also reconcile InferenceService CRs in the same namespace" "Internal RHOAI"

        /* Relationships */
        dataScientist -> modelmeshServing "Creates ServingRuntime, Predictor, InferenceService CRs via kubectl/dashboard"
        mlClient -> modelmeshServing "Sends inference requests" "gRPC/8033 or HTTPS/8443"

        /* Internal flows */
        controller -> modelmeshSidecar "Manages vModels via SetVModel" "gRPC/8033"
        controller -> k8sApi "Watches CRDs, creates Deployments, Services, Secrets" "HTTPS/443"
        controller -> webhook "Registers validating webhook" "HTTPS/9443"
        oauthProxy -> restProxy "Forwards authenticated requests" "HTTP/8008"
        restProxy -> modelmeshSidecar "Translates REST to gRPC" "gRPC/8033"
        modelmeshSidecar -> puller "Requests model download" "gRPC/8086"

        /* External flows */
        modelmeshSidecar -> etcd "Model placement state coordination" "HTTP/2379 Password auth"
        puller -> modelStorage "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        oauthProxy -> openshiftOAuth "Validates OAuth tokens" "HTTPS/443 TLS 1.2+"
        prometheus -> modelmeshServing "Scrapes metrics" "HTTP/2112, HTTP/8080"

        /* RHOAI flows */
        rhodsOperator -> modelmeshServing "Deploys via Kustomize manifests"
        odhModelController -> modelmeshServing "Co-reconciles InferenceService CRs"

        /* API server to webhook */
        k8sApi -> webhook "Sends admission reviews" "HTTPS/9443"
    }

    views {
        systemContext modelmeshServing "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal Dependency" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "External" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
