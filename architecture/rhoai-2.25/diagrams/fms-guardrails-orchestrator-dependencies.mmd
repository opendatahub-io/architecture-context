graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Text Generation Backends (gRPC)
    Orchestrator -->|"gRPC :8033<br/>Generate, GenerateStream<br/>Tokenize, ModelInfo"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    Orchestrator -->|"gRPC :8085<br/>TextGenerationTaskPredict<br/>ServerStreamingTextGeneration"| CaikitNLP["Caikit NLP<br/>Service"]
    Orchestrator -->|"HTTP :8080<br/>/v1/chat/completions<br/>/v1/completions, /tokenize"| OpenAI["OpenAI-compatible<br/>Server (vLLM)"]

    %% Content Processing
    Orchestrator -->|"gRPC :8085<br/>ChunkerTokenizationTaskPredict<br/>BidiStreamingChunker"| Chunkers["Chunker Services<br/>(Caikit)"]
    Orchestrator -->|"HTTP :8080<br/>/api/v1/text/contents<br/>/text/chat, /text/context/doc"| Detectors["Detector<br/>Services"]

    %% Observability
    Orchestrator -.->|"OTLP :4317/:4318<br/>Traces + Metrics"| OTel["OpenTelemetry<br/>Collector"]

    %% Runtime Dependencies
    Orchestrator -->|"async runtime"| Tokio["tokio 1.47"]
    Orchestrator -->|"HTTP server"| Axum["axum 0.8"]
    Orchestrator -->|"gRPC client"| Tonic["tonic 0.14"]
    Orchestrator -->|"TLS (non-FIPS)"| Rustls["rustls 0.23<br/>(ring backend)"]
    Orchestrator -->|"DNS load balancing"| Ginepro["ginepro<br/>(gRPC LB)"]

    %% Styling
    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style TGIS fill:#999,stroke:#333,color:#fff
    style CaikitNLP fill:#999,stroke:#333,color:#fff
    style OpenAI fill:#999,stroke:#333,color:#fff
    style Chunkers fill:#999,stroke:#333,color:#fff
    style Detectors fill:#999,stroke:#333,color:#fff

    style OTel fill:#f5a623,stroke:#333,color:#fff

    style Tokio fill:#e8e8e8,stroke:#333
    style Axum fill:#e8e8e8,stroke:#333
    style Tonic fill:#e8e8e8,stroke:#333
    style Rustls fill:#f8cecc,stroke:#b85450
    style Ginepro fill:#e8e8e8,stroke:#333
