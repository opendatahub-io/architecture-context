// C4 Context Diagram for rest-proxy
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.25/rest-proxy.md

workspace {
    model {
        client = person "External Client" "Sends KServe V2 REST inference requests"

        restProxy = softwareSystem "rest-proxy" "Reverse-proxy sidecar translating KServe V2 REST inference requests into gRPC calls for ModelMesh Serving" {
            proxyService = container "rest-proxy" "Translates REST to gRPC using gRPC-Gateway reverse proxy" "Go HTTP/gRPC-Gateway Service"
            grpcGateway = container "gRPC-Gateway Handlers" "Auto-generated reverse proxy handlers from protobuf definitions" "Generated Go Code"
            customMarshaler = container "CustomJSONPb Marshaler" "Custom JSON marshaling for tensor data types (BOOL, INT8-64, FP16-64, BYTES)" "Go Custom Marshaler"
        }

        modelMesh = softwareSystem "ModelMesh Serving" "gRPC-based model inference serving platform" "Internal RHOAI"
        modelMeshOperator = softwareSystem "ModelMesh Serving Operator" "Manages ModelMesh deployments and configures rest-proxy sidecar" "Internal RHOAI"
        modelRuntime = softwareSystem "Model Runtime" "Executes model inference (e.g., Triton, MLServer)" "Internal RHOAI"

        // External dependencies
        grpcGatewayLib = softwareSystem "grpc-gateway v2.15.0" "gRPC-Gateway reverse proxy framework" "External Library"
        grpcLib = softwareSystem "google.golang.org/grpc v1.56.3" "gRPC client library" "External Library"

        // Relationships
        client -> restProxy "Sends REST inference requests" "HTTP/HTTPS 8008/TCP, KServe V2 REST Protocol"
        restProxy -> modelMesh "Forwards translated gRPC inference requests" "gRPC localhost:8033/TCP, Optional TLS"
        modelMesh -> modelRuntime "Routes to model runtime" "gRPC"
        modelMeshOperator -> restProxy "Configures sidecar image via restProxy.image in config" "ConfigMap"

        // Internal container relationships
        proxyService -> grpcGateway "Uses for REST-to-gRPC translation"
        proxyService -> customMarshaler "Uses for tensor JSON marshaling"
        grpcGateway -> modelMesh "gRPC calls via generated client stubs" "gRPC localhost:8033"
    }

    views {
        systemContext restProxy "SystemContext" {
            include *
            exclude grpcGatewayLib
            exclude grpcLib
            autoLayout
        }

        container restProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Library" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
