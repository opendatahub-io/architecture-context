/*
 * C4 Context Diagram: Text Generation Inference Server (TGIS)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/text-generation-inference.md
 */

workspace {
    model {
        // People
        datascientist = person "Data Scientist" "Deploys and configures LLM models for inference"
        sre = person "SRE / Platform Admin" "Monitors and operates the inference platform"

        // Core System
        tgis = softwareSystem "Text Generation Inference Server (TGIS)" "High-performance text generation inference server with gRPC/HTTP APIs, continuous batching, tensor parallelism, and flash attention support" {
            launcher = container "text-generation-launcher" "Process orchestrator that starts model shards and the router, manages lifecycle and graceful shutdown" "Rust Binary"
            router = container "text-generation-router" "Request router providing gRPC (GenerationService) and HTTP (health/metrics) APIs, handles batching and validation" "Rust Binary"
            modelShard = container "text-generation-server" "Model serving shard that loads and runs inference on LLM models via PyTorch" "Python Service"
            customKernels = container "custom_kernels" "Custom CUDA kernels for optimized model inference" "Python/C++ Extension"
        }

        // Internal ODH/RHOAI Systems
        caikitTgis = softwareSystem "caikit-tgis-serving" "Upstream service that proxies inference requests to TGIS" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Manages TGIS as an InferenceService runtime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Manages TGIS model serving pods" "Internal RHOAI"

        // External Systems
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otel = softwareSystem "OpenTelemetry Collector" "Distributed trace collection" "External"
        modelStorage = softwareSystem "Model Storage (PVC/S3)" "Persistent storage for HuggingFace model weights" "External"
        gpu = softwareSystem "NVIDIA GPU (CUDA 12.1)" "GPU compute for model inference" "External"

        // Relationships - People
        datascientist -> kserve "Deploys models via InferenceService"
        sre -> prometheus "Monitors TGIS metrics"

        // Relationships - System level
        caikitTgis -> tgis "Sends inference requests" "gRPC/8033"
        kserve -> tgis "Deploys and manages as runtime"
        modelmesh -> tgis "Manages model serving pods" "gRPC/8033 TLS"
        prometheus -> tgis "Scrapes metrics" "HTTP/3000"
        tgis -> modelStorage "Loads model weights" "Filesystem mount"
        tgis -> gpu "Runs inference" "CUDA"
        tgis -> otel "Exports traces" "gRPC/OTLP"

        // Relationships - Container level
        launcher -> router "Starts and monitors" "Process management"
        launcher -> modelShard "Starts and monitors" "Process management"
        router -> modelShard "Inference requests" "UDS gRPC (plaintext)"
        modelShard -> customKernels "Uses optimized kernels" "In-process"
        modelShard -> modelStorage "Loads model weights" "Filesystem"
        modelShard -> gpu "CUDA compute" "Device access"
        caikitTgis -> router "Generate, GenerateStream, Tokenize, ModelInfo" "gRPC/8033 Optional TLS/mTLS"
        prometheus -> router "GET /metrics" "HTTP/3000 plaintext"
        router -> otel "Export traces" "gRPC/OTLP"
    }

    views {
        systemContext tgis "SystemContext" {
            include *
            autoLayout
        }

        container tgis "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
