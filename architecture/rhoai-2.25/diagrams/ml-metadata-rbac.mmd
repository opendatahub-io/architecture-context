graph TD
    subgraph "ML Metadata RBAC Model"
        direction TB

        Note["NOTE: No RBAC resources defined<br/>in the ml-metadata repository.<br/>RBAC is managed externally by the<br/>data-science-pipelines-operator."]

        subgraph "Container Security"
            Container["odh-mlmd-grpc-server<br/>UID: 65534 (non-root)<br/>Image: UBI9 ubi-minimal"]
        end

        subgraph "Authentication Mechanisms"
            direction TB
            mTLS["Optional mTLS<br/>(SSLConfig.client_verify=true)<br/>Client must present cert<br/>signed by custom CA"]
            NoAuth["No App-Level Auth<br/>(default)<br/>No token / RBAC enforcement<br/>Relies on network isolation"]
        end

        subgraph "Access Control (External)"
            DSPOp["data-science-pipelines-operator<br/>Manages RBAC for MLMD deployment"]
            NetPolicy["Network-Level Isolation<br/>(Kubernetes NetworkPolicy)<br/>Restricts access to ClusterIP service"]
        end

        subgraph "Secrets Required"
            DBCreds["Database Credentials (Opaque)<br/>MySQL/PostgreSQL username + password<br/>Provisioned by: DSP operator<br/>Auto-Rotate: No"]
            TLSCerts["TLS Certificates (kubernetes.io/tls)<br/>Server key, cert, CA<br/>Provisioned by: Manual / cert-manager<br/>Auto-Rotate: Varies"]
            MySQLSSL["MySQL SSL Certs (Opaque)<br/>Client cert, key, CA, cipher<br/>Provisioned by: Manual<br/>Auto-Rotate: No"]
            PgSSL["PostgreSQL SSL Certs (Opaque)<br/>sslcert, sslkey, sslpassword, sslrootcert<br/>Provisioned by: Manual<br/>Auto-Rotate: No"]
        end

        Container -->|"runs as"| mTLS
        Container -->|"runs as"| NoAuth
        DSPOp -->|"provisions"| DBCreds
        DSPOp -->|"configures"| NetPolicy
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style mTLS fill:#d5e8d4,stroke:#82b366
    style NoAuth fill:#f8d7da,stroke:#721c24
    style DSPOp fill:#7ed321,stroke:#333,color:#fff
    style NetPolicy fill:#dae8fc,stroke:#6c8ebf
    style DBCreds fill:#fff2cc,stroke:#d6b656
    style TLSCerts fill:#fff2cc,stroke:#d6b656
    style MySQLSSL fill:#fff2cc,stroke:#d6b656
    style PgSSL fill:#fff2cc,stroke:#d6b656
