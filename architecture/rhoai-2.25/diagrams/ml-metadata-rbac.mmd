graph TD
    subgraph "gRPC Access Control (Application-Level)"
        direction TB

        subgraph "Authentication Mode: Optional mTLS"
            SSLConfig["SSLConfig<br/>(gRPC Server Configuration)"]
            ClientVerify["client_verify flag"]
            CustomCA["custom_ca<br/>(CA Certificate)"]

            SSLConfig -->|contains| ClientVerify
            SSLConfig -->|references| CustomCA
        end

        subgraph "When mTLS Enabled (client_verify=true)"
