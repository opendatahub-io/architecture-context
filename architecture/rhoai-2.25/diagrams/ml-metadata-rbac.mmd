            ClientCert -->|grants access to| AllRPCs_Secure["All 40+ RPC Methods<br/>(MetadataStoreService)"]
        end

        subgraph "When Insecure (default, no ssl_config)"
            Insecure["InsecureServerCredentials"]
            Insecure -->|grants access to| AllRPCs_Open["All 40+ RPC Methods<br/>(No Auth Required)"]
        end
    end

    subgraph "Container Security Context"
        Container["odh-mlmd-grpc-server"]
        UserID["Run as: 65534 (nobody)"]
        GroupID["Run as group: 65534 (nobody)"]
        BaseImg["Base: UBI9-minimal"]
        BuildSys["Build: Konflux"]

        Container --- UserID
        Container --- GroupID
        Container --- BaseImg
        Container --- BuildSys
    end

    subgraph "Secrets Used"
        S1["mysql-config (Opaque)<br/>DB credentials<br/>Provisioned by: DSP Operator"]
        S2["metadata-grpc-tls (kubernetes.io/tls)<br/>Server TLS cert/key/CA<br/>Provisioned by: admin/cert-manager"]
        S3["mysql-ssl-certs (Opaque)<br/>MySQL client SSL certs<br/>Provisioned by: admin"]
        S4["postgres-ssl-certs (Opaque)<br/>PostgreSQL client SSL certs<br/>Provisioned by: admin"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No Kubernetes RBAC defined<br/>(Standalone gRPC server,<br/>no K8s API interactions)"]
    end

