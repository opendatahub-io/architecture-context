graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist /<br/>External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS 1.2+"]
        OAuth["OAuth Proxy<br/>8443/TCP HTTPS<br/>OpenShift OAuth"]
        Route -->|"TLS 1.2+<br/>Service Cert"| OAuth
    end

    subgraph Application["APPLICATION LAYER (User Namespace)"]
        direction TB

        subgraph API_Pod["API Server Pod"]
            API["API Server<br/>8888/TCP HTTP/HTTPS<br/>SA: ds-pipeline-(name)"]
        end

        subgraph WFC_Pod["Workflow Controller Pod"]
            WFC["Workflow Controller<br/>Argo 3.5.14<br/>SA: ds-pipeline-workflow-controller-(name)"]
        end

        subgraph PA_Pod["Persistence Agent Pod"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-(name)"]
        end

        subgraph SWC_Pod["Scheduled Workflow Pod"]
            SWC["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-(name)"]
        end

        subgraph PipelinePod["Pipeline Step Pod"]
            Step["Pipeline Step<br/>SA: pipeline-runner-(name)"]
        end

        subgraph MLMD_Pod["MLMD Pod (Optional)"]
            MLMDEnvoy["Envoy Proxy<br/>9090/TCP gRPC/HTTP2<br/>OAuth"]
            MLMDgRPC["MLMD gRPC<br/>8080/TCP gRPC<br/>mTLS (optional)"]
            MLMDEnvoy -->|"internal"| MLMDgRPC
        end

        subgraph Storage["Storage Layer"]
            DB["MariaDB<br/>3306/TCP MySQL<br/>TLS 1.2+ (optional)"]
            S3["Minio/S3<br/>9000/443 HTTP/HTTPS<br/>TLS 1.2+ (external)"]
        end
    end

    subgraph Operator["OPERATOR LAYER (DSPO Namespace)"]
        direction TB
        Controller["DSPO Controller<br/>SA: data-science-pipelines-operator-controller-manager<br/>ClusterRole: manager-role, manager-argo-role"]
        Webhook["Webhook Server<br/>8443/TCP HTTPS<br/>K8s API mTLS"]
        Metrics["Metrics/Health<br/>8080/8081 HTTP<br/>No Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtS3["External S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / S3 Keys"]
        ExtDB["External MySQL/MariaDB<br/>3306/TCP MySQL<br/>TLS 1.2+ (optional)<br/>DB Credentials"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Registry Auth"]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
        K8sOAuth["OpenShift OAuth<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth Token"| Route

    %% Ingress → Application
    OAuth -->|"HTTP/HTTPS/8888<br/>TLS 1.2+ (podToPod)<br/>Bearer Token"| API

    %% API Server connections
    API -->|"MySQL/3306<br/>TLS 1.2+ (opt)<br/>DB Creds"| DB
    API -->|"HTTP/HTTPS<br/>S3 Creds"| S3
    API -->|"gRPC/8080<br/>TLS 1.2+ (podToPod)<br/>mTLS (opt)"| MLMDgRPC
    API -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Workflow Controller
    WFC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"Pod Creation"| Step

    %% Pipeline Step
    Step -->|"HTTP/HTTPS<br/>S3 Creds"| S3
    Step -->|"gRPC/8080<br/>TLS 1.2+ (podToPod)<br/>mTLS (opt)"| MLMDgRPC

    %% Persistence Agent
    PA -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    PA -->|"MySQL/3306<br/>TLS 1.2+ (opt)<br/>DB Creds"| DB

    %% Scheduled Workflow
    SWC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% MLMD
    MLMDgRPC -->|"MySQL/3306<br/>TLS 1.2+ (opt)<br/>DB Creds"| DB
    Client -->|"HTTPS/443<br/>OAuth"| Route
    Route -->|"via OAuth"| MLMDEnvoy

    %% Operator
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Controller -.->|"Creates/Manages"| API_Pod
    Controller -.->|"Creates/Manages"| WFC_Pod
    Controller -.->|"Creates/Manages"| Storage
    K8sAPI -->|"Webhook Calls<br/>HTTPS/8443<br/>mTLS"| Webhook

    %% External Services
    API -.->|"Alternative"| ExtS3
    API -.->|"Alternative"| ExtDB
    Step -->|"Pull Images"| Registry
    WFC -->|"Pull Images"| Registry

    %% OAuth validation
    OAuth -->|"Validate Token"| K8sOAuth

    %% Prometheus
    Metrics -->|"Scrape"| External

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route,OAuth ingress
    class API,WFC,PA,SWC,Step,MLMDEnvoy,MLMDgRPC application
    class DB,S3 storage
    class Controller,Webhook,Metrics operator
    class ExtS3,ExtDB,Registry externalservice
    class K8sAPI,K8sOAuth k8s
