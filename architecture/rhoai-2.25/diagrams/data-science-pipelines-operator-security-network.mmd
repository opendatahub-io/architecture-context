graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Dashboard<br/>External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        APIRoute["ds-pipeline-{name} Route<br/>443/TCP -> 8443/TCP<br/>TLS Reencrypt"]
        UIRoute["ds-pipeline-ui-{name} Route<br/>443/TCP -> 8443/TCP<br/>TLS Reencrypt"]
        EnvoyRoute["ds-pipeline-metadata-envoy-{name} Route<br/>443/TCP -> 8443/TCP<br/>TLS Reencrypt"]
        MinIORoute["minio-{name} Route (optional)<br/>443/TCP -> 9000/TCP<br/>TLS Edge"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        Controller["DSPO Controller Manager<br/>SA: controller-manager<br/>:8080 metrics, :8081 health"]
        WebhookDeploy["Pipeline Version Webhook<br/>:8443/TCP HTTPS (service-ca)<br/>Auth: K8s API mTLS"]
    end

    subgraph DSPANamespace["DSPA NAMESPACE (per-tenant, mTLS optional)"]
        direction TB

        subgraph OAuthLayer["OAuth Proxy Layer (TLS service-ca)"]
            OAuthAPI["OAuth Proxy<br/>:8443/TCP HTTPS<br/>OpenShift SSO"]
        end

        subgraph CoreServices["Core Pipeline Services"]
            APIServer["DS Pipeline API Server<br/>SA: ds-pipeline-{name}<br/>:8888/TCP REST, :8887/TCP gRPC<br/>Optional PodToPodTLS"]
            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}<br/>Auth: SA token (audience: pipelines.kubeflow.org)"]
            ScheduledWF["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-{name}"]
        end

        subgraph ExecutionLayer["Execution Engine"]
            ArgoWF["Argo Workflow Controller<br/>SA: ds-pipeline-workflow-controller-{name}<br/>:9090/TCP metrics (deprecated)"]
            PipelinePods["Pipeline Pods<br/>SA: pipeline-runner-{name}<br/>Can create: InferenceService,<br/>RayCluster, SeldonDeployment, AppWrapper"]
        end

        subgraph MetadataServices["ML Metadata (NetworkPolicy-restricted)"]
            MLMDgRPC["MLMD gRPC Server<br/>:8080/TCP gRPC<br/>Optional PodToPodTLS<br/>NetworkPolicy: metadata-grpc"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>:9090/TCP HTTP, :8443/TCP HTTPS<br/>HTTP-to-gRPC translation"]
        end

        subgraph UILayer["User Interface"]
            PipelinesUI["ML Pipelines UI<br/>:8443/TCP HTTPS (OAuth Proxy)<br/>Node.js"]
        end

        subgraph DataStores["Data Storage (NetworkPolicy-protected)"]
            MariaDB["MariaDB<br/>:3306/TCP MySQL<br/>Optional TLS (service-ca)<br/>Auth: Username/Password<br/>NetworkPolicy: mariadb"]
            MinIO["MinIO<br/>:9000/TCP HTTP<br/>Auth: Access Key/Secret Key"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtDB["External Database<br/>:3306/TCP MySQL<br/>Optional TLS<br/>Auth: Username/Password"]
        ExtS3["External S3 Storage<br/>:443/TCP HTTPS<br/>TLS<br/>Auth: Access Key/Secret Key"]
        K8sAPI["Kubernetes API Server<br/>:443/TCP HTTPS TLS<br/>Auth: ServiceAccount token"]
        ServiceCA["OpenShift Service CA<br/>Certificate Injection"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Token"| APIRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Token"| UIRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Token"| EnvoyRoute

    %% Ingress to OAuth
    APIRoute -->|"HTTPS/8443<br/>TLS (service-ca)<br/>OAuth"| OAuthAPI
    UIRoute -->|"HTTPS/8443<br/>TLS (service-ca)<br/>OAuth"| PipelinesUI
    EnvoyRoute -->|"HTTPS/8443<br/>TLS (service-ca)<br/>OAuth"| MLMDEnvoy

    %% OAuth to API Server
    OAuthAPI -->|"HTTP/8888<br/>Optional PodToPodTLS<br/>Proxied Identity"| APIServer

    %% API Server connections
    APIServer -->|"MySQL/3306<br/>Optional TLS<br/>User/Pass"| MariaDB
    APIServer -->|"HTTP/9000<br/>Optional TLS<br/>AccessKey"| MinIO
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Internal data flow
    PersistenceAgent -->|"REST/8888 + gRPC/8887<br/>Optional PodToPodTLS<br/>SA token"| APIServer
    ArgoWF -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    PipelinePods -->|"gRPC/8080<br/>Optional PodToPodTLS<br/>NetworkPolicy"| MLMDgRPC
    MLMDgRPC -->|"MySQL/3306<br/>Optional TLS<br/>User/Pass"| MariaDB
    MLMDEnvoy -->|"gRPC/8080<br/>PodToPodTLS"| MLMDgRPC

    %% Operator connections
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    Controller -->|"MySQL/3306<br/>Health check"| MariaDB
    Controller -->|"HTTP/9000<br/>Health check"| MinIO
    K8sAPI -->|"HTTPS/8443<br/>TLS (service-ca)<br/>mTLS"| WebhookDeploy

    %% Service CA
    ServiceCA -.->|"cert injection"| OAuthAPI
    ServiceCA -.->|"cert injection"| MLMDgRPC
    ServiceCA -.->|"cert injection"| WebhookDeploy

    %% Optional external backends
    APIServer -.->|"MySQL/3306<br/>TLS<br/>User/Pass"| ExtDB
    APIServer -.->|"HTTPS/443<br/>TLS<br/>AccessKey"| ExtS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef oauth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class APIRoute,UIRoute,EnvoyRoute,MinIORoute ingress
    class Controller,WebhookDeploy operator
    class APIServer,PersistenceAgent,ScheduledWF,ArgoWF,PipelinePods,MLMDgRPC,MLMDEnvoy,PipelinesUI servicemesh
    class MariaDB,MinIO datastore
    class ExtDB,ExtS3,K8sAPI,ServiceCA externalservice
    class OAuthAPI oauth
