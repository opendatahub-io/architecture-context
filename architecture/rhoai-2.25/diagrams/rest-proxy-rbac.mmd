graph TD
    subgraph RestProxyComponent["rest-proxy (Sidecar Container)"]
        direction TB
        Note["No Kubernetes API interaction<br/>No RBAC roles or bindings defined"]
    end

    subgraph SecurityModel["Security Model"]
        direction TB
        NoRBAC["No ClusterRoles"]
        NoBindings["No RoleBindings"]
        NoSA["No dedicated ServiceAccount<br/>(runs in ModelMesh pod SA)"]
    end

    subgraph AuthDelegation["Authentication & Authorization"]
        direction TB
        ProxyLevel["rest-proxy Level:<br/>No auth enforcement"]
        InfraLevel["ModelMesh Infrastructure:<br/>Handles all auth"]
        ProxyLevel -->|"delegates to"| InfraLevel
    end

    subgraph TLSConfig["TLS Configuration"]
        direction TB
        RESTtls["REST Endpoint (8008/TCP)<br/>TLS via MM_TLS_KEY_CERT_PATH<br/>Optional"]
        GRPCtls["gRPC Backend (8033/TCP)<br/>TLS via REST_PROXY_USE_TLS<br/>Optional"]
        SkipVerify["InsecureSkipVerify<br/>via REST_PROXY_SKIP_VERIFY<br/>Default: false"]
        GRPCtls -.->|"configurable"| SkipVerify
    end

    subgraph FIPSCompliance["FIPS Compliance"]
        direction TB
        KonfluxBuild["Konflux Build:<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>✅ FIPS Compliant"]
        UpstreamBuild["Upstream Build:<br/>CGO_ENABLED=0<br/>❌ Non-FIPS"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,color:#333
    style NoRBAC fill:#e8e8e8,stroke:#999
    style NoBindings fill:#e8e8e8,stroke:#999
    style NoSA fill:#e8e8e8,stroke:#999
    style ProxyLevel fill:#ffcccc,stroke:#cc3333
    style InfraLevel fill:#d5e8d4,stroke:#82b366
    style RESTtls fill:#dce8f5,stroke:#4a90e2
    style GRPCtls fill:#dce8f5,stroke:#4a90e2
    style SkipVerify fill:#fff3cd,stroke:#ffc107
    style KonfluxBuild fill:#d5e8d4,stroke:#82b366
    style UpstreamBuild fill:#ffcccc,stroke:#cc3333
