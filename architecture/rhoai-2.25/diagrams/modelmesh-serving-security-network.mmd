graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Services["KUBERNETES SERVICES"]
        ServingService["modelmesh-serving Service<br/>ClusterIP/Headless<br/>8033/TCP gRPC, 8008/TCP HTTP"]
        WebhookService["modelmesh-webhook-server-service<br/>9443/TCP HTTPS TLS1.2+"]
        MetricsService["controller-manager-metrics-service<br/>8443/TCP HTTPS TLS1.2+"]
    end

    subgraph RuntimePod["RUNTIME POD"]
        direction TB

        RESTProxy["REST Proxy<br/>8008/TCP HTTP<br/>No encryption"]
        ModelMesh["ModelMesh (Java)<br/>8033/TCP gRPC (external)<br/>8080/TCP gRPC (internal)<br/>2112/TCP HTTP (metrics)<br/>No encryption"]
        RuntimeAdapter["Runtime Adapter<br/>Sidecar"]
        ModelRuntime["Model Runtime<br/>Triton/MLServer/OpenVINO<br/>8001/TCP gRPC UDS<br/>No encryption"]
        StoragePuller["Storage Puller<br/>8086/TCP gRPC<br/>Init/Sidecar"]

        RESTProxy -->|8033/TCP gRPC| ModelMesh
        ModelMesh -->|UDS/8001| RuntimeAdapter
        RuntimeAdapter --> ModelRuntime
    end

    subgraph ControlPlane["CONTROL PLANE"]
        User["User/kubectl"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>Bearer Token"]
        Controller["modelmesh-controller<br/>8081/TCP HTTP (health)<br/>8443/TCP HTTPS (metrics)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>K8s API cert"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ETCD["ETCD Cluster<br/>2379/TCP HTTP/gRPC<br/>Optional TLS<br/>Optional mTLS"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS Signature V4"]
        PVC["PVC Storage<br/>Filesystem<br/>K8s RBAC"]
    end

    %% Client flows
    Client -->|8033/TCP gRPC<br/>No encryption<br/>Optional app auth| ServingService
    Client -->|8008/TCP HTTP<br/>No encryption<br/>Optional app auth| ServingService

    ServingService -->|8033/TCP gRPC| ModelMesh
    ServingService -->|8008/TCP HTTP| RESTProxy

    %% Control plane flows
    User -->|6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    K8sAPI -->|9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API cert| WebhookService
    WebhookService --> Webhook
    K8sAPI -->|Watch events| Controller
    Controller -->|6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token| K8sAPI

    %% Runtime to external services
    ModelMesh -->|2379/TCP HTTP/gRPC<br/>Optional TLS<br/>Optional mTLS| ETCD
    StoragePuller -->|443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4| S3
    StoragePuller -.->|Filesystem<br/>K8s RBAC| PVC

    %% Metrics collection
    Client -.->|8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token| MetricsService
    MetricsService -.-> Controller
    Client -.->|2112/TCP HTTP<br/>No auth| ModelMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef service fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef control fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class ServingService,WebhookService,MetricsService service
    class RESTProxy,ModelMesh,RuntimeAdapter,ModelRuntime,StoragePuller runtime
    class User,K8sAPI,Controller,Webhook control
    class ETCD,S3,PVC externalservice
