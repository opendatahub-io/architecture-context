graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(system)"]
        SA_MR["model-registry<br/>(API server)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(namespace: kubeflow)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role<br/>(namespace: kubeflow)"]
    end

    subgraph APIResources_Manager["Manager Role - API Resources"]
        Svc["core/v1<br/>Services"]
        ISVC["serving.kserve.io<br/>InferenceServices"]
        ISVCFin["serving.kserve.io<br/>InferenceServices/finalizers"]
    end

    subgraph APIResources_Metrics["Metrics Auth - API Resources"]
        TokenReview["authentication.k8s.io<br/>TokenReviews"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
    end

    subgraph APIResources_MetricsRead["Metrics Reader - Resources"]
        MetricsURL["/metrics<br/>(non-resource URL)"]
    end

    subgraph APIResources_Leader["Leader Election - API Resources"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
        Leases["coordination.k8s.io<br/>Leases"]
        Events["core/v1<br/>Events"]
    end

    %% Service Account → Binding → Role → Resources
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_Metrics
    SA_Controller -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth

    RB_Leader -->|"grants"| R_Leader

    CR_Manager -->|"get, list, watch"| Svc
    CR_Manager -->|"get, list, patch,<br/>update, watch"| ISVC
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| ISVCFin

    CR_MetricsAuth -->|"create"| TokenReview
    CR_MetricsAuth -->|"create"| SAR

    CR_MetricsReader -->|"get"| MetricsURL

    R_Leader -->|"get, list, watch,<br/>create, update, patch, delete"| ConfigMaps
    R_Leader -->|"get, list, watch,<br/>create, update, patch, delete"| Leases
    R_Leader -->|"create, patch"| Events

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_MR fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_Metrics fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style Svc fill:#7ed321,stroke:#333,color:#fff
    style ISVC fill:#7ed321,stroke:#333,color:#fff
    style ISVCFin fill:#7ed321,stroke:#333,color:#fff
    style TokenReview fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style MetricsURL fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Leases fill:#7ed321,stroke:#333,color:#fff
    style Events fill:#7ed321,stroke:#333,color:#fff
