// C4 Context Diagram - CodeFlare Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates RayClusters and AppWrappers for distributed ML workloads"
        rayClient = person "Ray Client Application" "Connects to Ray cluster for distributed computing"

        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages RayCluster lifecycle with OAuth proxy injection, mTLS certificate management, and optional AppWrapper controller" {
            controllerManager = container "Operator Manager" "Single-replica deployment running controllers and webhook server" "Go (controller-runtime)"
            rayclusterController = container "RayCluster Controller" "Watches RayCluster CRs; creates OAuth Routes, Services, SAs, CRBs, Secrets, NetworkPolicies" "Go Controller"
            appwrapperController = container "AppWrapper Controller" "Manages AppWrapper CRs for gang scheduling and Kueue integration (optional)" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating/validating webhooks for RayCluster and AppWrapper resources" "Go, 9443/TCP HTTPS"
            certRotator = container "Cert Rotator" "Manages webhook TLS certificates with automatic rotation" "cert-controller"
        }

        kubeAPI = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"
        kuberayOperator = softwareSystem "KubeRay Operator" "Manages RayCluster pod lifecycle" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and configures CodeFlare Operator via kustomize" "Internal ODH"
        dsci = softwareSystem "DSCInitialization" "Provides RHOAI applications namespace discovery" "Internal ODH"
        openShiftOAuth = softwareSystem "OpenShift OAuth" "Provides OAuth authentication for Ray dashboard access" "External"
        certSigner = softwareSystem "service-serving-cert-signer" "Provisions TLS certificates for OAuth proxy services" "External"
        kueue = softwareSystem "Kueue" "Provides quota management and scheduling for AppWrappers" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Scrapes operator metrics" "External"

        // User interactions
        user -> codeflareOperator "Creates RayCluster and AppWrapper CRs via kubectl" "HTTPS/6443"
        user -> codeflareOperator "Accesses Ray Dashboard via Route" "HTTPS/443 (OAuth)"
        rayClient -> codeflareOperator "Connects to Ray cluster" "gRPC/10001 (mTLS)"

        // Operator interactions
        codeflareOperator -> kubeAPI "Resource CRUD, webhook registration, leader election" "HTTPS/6443"
        codeflareOperator -> kuberayOperator "Discovers operator namespace for NetworkPolicy" "HTTPS/6443"
        codeflareOperator -> dsci "Discovers RHOAI applications namespace" "HTTPS/6443"
        codeflareOperator -> openShiftOAuth "OAuth redirect for dashboard auth" "HTTPS/443"
        codeflareOperator -> kueue "AppWrapper quota management integration" "HTTPS/6443"

        // External to operator
        rhodsOperator -> codeflareOperator "Deploys via kustomize overlays" "Kustomize"
        certSigner -> codeflareOperator "Provisions OAuth proxy TLS certs" "Annotation-based"
        prometheus -> codeflareOperator "Scrapes metrics" "HTTP/8080"

        // Internal container relationships
        controllerManager -> rayclusterController "Manages" ""
        controllerManager -> appwrapperController "Manages" ""
        controllerManager -> certRotator "Manages" ""
        certRotator -> webhookServer "Provisions TLS certs" ""
        rayclusterController -> kubeAPI "Creates Routes, Services, Secrets, NetworkPolicies" "HTTPS/6443"
        appwrapperController -> kubeAPI "Creates wrapped resources" "HTTPS/6443"
    }

    views {
        systemContext codeflareOperator "SystemContext" {
            include *
            autoLayout
        }

        container codeflareOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
