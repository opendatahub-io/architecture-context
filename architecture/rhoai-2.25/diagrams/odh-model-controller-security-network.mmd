graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist / Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS 1.3 Termination"]
        IstioGW["Istio Ingress Gateway<br/>8080/TCP HTTP<br/>SA: istio-ingressgateway"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS Optional)"]
        direction TB

        Authorino["Authorino<br/>5001/TCP gRPC mTLS<br/>JWT Validation"]

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>8012/TCP HTTP<br/>SA: activator<br/>Autoscaling & Queuing"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            Predictor["Predictor Pod<br/>8080/TCP HTTP mTLS<br/>SA: {isvc-name}-sa<br/>UID: 2000 (non-root)"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE (Kubernetes Cluster)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Auth: OIDC/ServiceAccount"]

        subgraph NS_ODH["Namespace: redhat-ods-applications"]
            Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>UID: 2000 (FIPS)"]
            Webhook["ODH Model Controller<br/>Webhook Server<br/>443/TCP → 9443/TCP HTTPS<br/>TLS1.2+ (cert-manager)<br/>Cert: webhook-server-cert"]
        end

        KServeCtrl["KServe Controller<br/>Creates Knative/K8s<br/>Deployment"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP<br/>Auth: Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: IAM/Access Key"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS1.3<br/>Auth: NGC API Key<br/>Refresh: 24h"]
        MR["Model Registry<br/>443/TCP HTTPS TLS1.2+<br/>Optional"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Route
    Route -->|HTTP/8080<br/>Plaintext| IstioGW
    IstioGW -->|gRPC/5001<br/>mTLS<br/>JWT Validation| Authorino
    IstioGW -->|HTTP/8012<br/>Plaintext| Activator
    Activator -->|HTTP/8080<br/>mTLS if PeerAuth| Predictor
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>IAM Auth| S3

    Client -->|HTTPS/6443<br/>TLS 1.3<br/>OIDC/Bearer| K8sAPI
    K8sAPI -->|HTTPS/443<br/>mTLS<br/>Webhook Call| Webhook
    K8sAPI <-->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| Controller
    K8sAPI <-->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| KServeCtrl

    Controller -->|HTTPS/443<br/>TLS 1.3<br/>NGC API Key| NGC
    Controller -->|HTTPS/443<br/>TLS 1.2+| MR

    Prometheus -->|HTTP/8080<br/>Bearer Token| Controller
    Prometheus -->|HTTP/8080<br/>mTLS if configured<br/>Bearer Token| Predictor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route,IstioGW ingress
    class Authorino,Activator,Predictor servicemesh
    class K8sAPI,Controller,Webhook,KServeCtrl controlplane
    class Prometheus monitoring
    class S3,NGC,MR externalservice
