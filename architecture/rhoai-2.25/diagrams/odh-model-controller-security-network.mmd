graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>443/TCP<br/>TLS 1.2+<br/>Passthrough / Edge / Reencrypt"]
    end

    subgraph MeshIngress["MESH INGRESS (Serverless only)"]
        IstioGW["Istio Ingress Gateway"]
        LocalGW["KServe Local Gateway<br/>8445/TCP → 8012/TCP<br/>TLS SIMPLE (serving cert)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS via PeerAuthentication)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            Predictor["Knative Service / Predictor Pod<br/>SA: varies per ISVC<br/>PeerAuth: mTLS"]
            MetricsSvc["{isvc-name}-metrics Service<br/>ClusterIP, varies/TCP<br/>HTTP, No TLS"]
            NP1["NetworkPolicy:<br/>allow-from-openshift-monitoring"]
            NP2["NetworkPolicy:<br/>allow-openshift-ingress"]
            NP3["NetworkPolicy:<br/>allow-from-opendatahub"]
        end

        subgraph NS_Controller["Namespace: Operator (controller plane)"]
            direction TB
            Controller["odh-model-controller<br/>SA: odh-model-controller<br/>Single Replica"]
            WebhookSvc["webhook-service (ClusterIP)<br/>443/TCP → 9443/TCP<br/>HTTPS, TLS<br/>Auth: K8s API Server"]
            MetricsCtrlSvc["metrics-service (ClusterIP)<br/>8443/TCP HTTPS<br/>Auth: Bearer Token (SA)"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
            RayCA["ray-ca-tls Secret<br/>4096-bit RSA CA<br/>5-year validity"]
        end

        subgraph NS_Mesh["Namespace: {mesh-namespace}"]
            SMM["ServiceMeshMember CRs<br/>(user namespace enrollment)"]
            PA["PeerAuthentication CRs<br/>(mTLS enforcement)"]
            Telemetry["Telemetry CRs<br/>(Prometheus metrics)"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (SA)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus / OpenShift Monitoring<br/>ServiceMonitor + PodMonitor CRs"]
    end

    subgraph AuthZ["AUTHORIZATION SERVICES"]
        Authorino["Authorino<br/>AuthConfig CRs<br/>(Serverless + InferenceGraph)"]
        Kuadrant["Kuadrant<br/>AuthPolicy CRs<br/>(LLMInferenceService)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        NGCTOKEN["NVIDIA NGC Token API<br/>authn.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key (Basic Auth)"]
        NGCAPI["NVIDIA NGC Catalog API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token (NGC)"]
        ModelReg["Kubeflow Model Registry<br/>varies/TCP HTTPS/HTTP<br/>TLS 1.2+ (configurable)<br/>Auth: Bearer Token (SA)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Route
    Route -->|"TLS Passthrough<br/>(Serverless)"| IstioGW
    Route -->|"Edge/Reencrypt TLS<br/>(Raw/ModelMesh)"| Predictor
    IstioGW -->|"HTTPS/8445<br/>TLS (serving cert)"| LocalGW
    LocalGW -->|"HTTP/8012<br/>plaintext (mesh-internal)<br/>Auth: Authorino"| Predictor

    %% Controller egress
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (Basic)"| NGCTOKEN
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (NGC)"| NGCAPI
    Controller -->|"HTTPS or HTTP<br/>TLS 1.2+<br/>Bearer Token (SA)"| ModelReg

    %% Webhook flow
    K8sAPI -->|"HTTPS/443→9443<br/>TLS<br/>Webhook calls"| WebhookSvc

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>Bearer Token"| MetricsCtrlSvc
    Prometheus -->|"HTTP/varies<br/>scrape"| MetricsSvc

    %% Auth integration
    LocalGW -.->|"validates"| Authorino
    Controller -.->|"creates"| Authorino
    Controller -.->|"creates"| Kuadrant

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef meshingress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef authz fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class IstioGW,LocalGW meshingress
    class Predictor,MetricsSvc,NP1,NP2,NP3,Controller,WebhookSvc,MetricsCtrlSvc,HealthProbe,RayCA,SMM,PA,Telemetry servicemesh
    class K8sAPI controlplane
    class NGCTOKEN,NGCAPI,ModelReg externalservice
    class Prometheus monitoring
    class Authorino,Kuadrant authz
