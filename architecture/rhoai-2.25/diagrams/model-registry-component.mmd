graph TB
    subgraph ModelRegistry["Model Registry Component"]
        direction TB

        subgraph CoreAPI["Core REST API Server"]
            APIServer["Model Registry REST API<br/>Go Service<br/>Port: 8080/TCP"]
            OpenAPI["OpenAPI v1alpha3<br/>CRUD Endpoints"]
            EmbedMD["EmbedMD Storage Layer<br/>GORM ORM"]
            APIServer --> OpenAPI
            OpenAPI --> EmbedMD
        end

        subgraph CatalogSvc["Catalog Service"]
            Catalog["Model Catalog Service<br/>Go Service<br/>Port: 8080/TCP"]
            YAMLProvider["YAML Catalog Provider<br/>File-based, hot-reload"]
            HFProvider["HuggingFace Provider<br/>API-based"]
            Catalog --> YAMLProvider
            Catalog --> HFProvider
        end

        subgraph ControllerMgr["Controller Manager"]
            Controller["InferenceService Controller<br/>controller-runtime<br/>Health: 8081/TCP | Metrics: 8443/TCP"]
        end

        subgraph StorageInit["Storage Initializer"]
            CSI["CSI Storage Initializer<br/>Go CLI<br/>model-registry:// protocol"]
        end

        subgraph AsyncJob["Async Upload"]
            Upload["Async Upload Job<br/>Python<br/>S3/OCI/HF sync"]
        end
    end

    %% External Users
    User["Data Scientist / Dashboard"]
    User -->|"REST API calls"| APIServer
    User -->|"Browse catalogs"| Catalog

    %% CRD Interactions
    ISVCCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    ISVCCR -->|"watched by"| Controller
    Controller -->|"CRUD metadata"| APIServer
    Controller -->|"labels/finalizers"| ISVCCR

    %% CSI Flow
    KServePod["KServe Predictor Pod"]
    KServePod -->|"init container"| CSI
    CSI -->|"resolve URI"| APIServer

    %% Async Job Flow
    Upload -->|"register artifacts"| APIServer

    %% Database
    DB["MySQL 8.3+ / PostgreSQL 14.7+"]
    EmbedMD -->|"SQL queries"| DB

    %% External Services
    HFHub["HuggingFace Hub API"]
    HFProvider -->|"HTTPS/443"| HFHub
    Upload -->|"download models"| HFHub

    S3["S3 / MinIO Storage"]
    CSI -->|"download artifacts"| S3
    Upload -->|"download/upload"| S3

    OCIReg["OCI Container Registry"]
    Upload -->|"push models"| OCIReg

    K8sAPI["Kubernetes API Server"]
    Controller -->|"watch/update"| K8sAPI

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style Upload fill:#4a90e2,stroke:#333,color:#fff
    style ISVCCR fill:#f5a623,stroke:#333,color:#fff
    style DB fill:#9b59b6,stroke:#333,color:#fff
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCIReg fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#7ed321,stroke:#333,color:#fff
    style KServePod fill:#7ed321,stroke:#333,color:#fff
