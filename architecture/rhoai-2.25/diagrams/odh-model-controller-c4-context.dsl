// C4 Context Diagram: odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates InferenceServices and model serving resources"
        platformadmin = person "Platform Admin" "Configures RHOAI platform and service mesh"

        odhModelController = softwareSystem "odh-model-controller" "Kubernetes controller that automates model serving infrastructure management for KServe and ModelMesh InferenceServices in OpenShift AI" {
            isvcController = container "InferenceService Controller" "Reconciles InferenceServices across Serverless, RawDeployment, and ModelMesh modes" "Go Controller"
            igController = container "InferenceGraph Controller" "Reconciles InferenceGraphs and creates AuthConfig CRs" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages monitoring RoleBindings and Ray TLS certificates" "Go Controller"
            llmController = container "LLMInferenceService Controller" "Reconciles LLMInferenceServices with AuthPolicy" "Go Controller"
            secretController = container "Secret Controller" "Generates storage-config Secret from data connections" "Go Controller"
            configmapController = container "ConfigMap Controller" "Manages CA certificate bundle ConfigMaps for KServe" "Go Controller"
            podController = container "Pod Controller" "Generates per-pod TLS certificates for Ray clusters" "Go Controller"
            nimController = container "NIM Account Controller" "Validates NGC API keys and generates NIM model catalogs" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating and Validating admission webhooks" "Go HTTPS Server" "9443/TCP"
        }

        // External dependencies
        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform" "External"
        istio = softwareSystem "Istio / Service Mesh" "Service mesh for traffic management and mTLS" "External"
        knativeServing = softwareSystem "Knative Serving" "Serverless autoscaling platform" "External"
        authorino = softwareSystem "Authorino" "External authorization service" "External"
        kuadrant = softwareSystem "Kuadrant Operator" "API management and authorization" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "Monitoring and metrics collection" "External"
        certManager = softwareSystem "OpenShift service-ca" "Certificate management" "External"

        // Internal ODH dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages RHOAI components" "Internal ODH"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for OpenShift AI" "Internal ODH"

        // External services
        ngcAPI = softwareSystem "NVIDIA NGC API" "NIM model catalog and API key validation" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server" "Infrastructure"

        // Relationships - Users
        datascientist -> odhModelController "Creates InferenceService, ServingRuntime, InferenceGraph CRs via kubectl/dashboard"
        platformadmin -> odhModelController "Configures NIM Accounts, service mesh settings"

        // Relationships - Internal
        rhodsOperator -> odhModelController "Deploys via kustomize overlays"
        odhDashboard -> odhModelController "Provides auth-refs and service-mesh-refs ConfigMaps"

        // Relationships - Watches
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRs" "HTTPS/443"
        odhModelController -> modelMesh "Manages Routes and ClusterRoleBindings for ModelMesh-mode ISVCs" "HTTPS/443"

        // Relationships - Creates/Manages
        odhModelController -> istio "Creates/updates Gateways, PeerAuthentications, Telemetries" "HTTPS/443"
        odhModelController -> authorino "Creates AuthConfig CRs for per-ISVC authorization" "HTTPS/443"
        odhModelController -> kuadrant "Creates AuthPolicy CRs for LLMInferenceService" "HTTPS/443"
        odhModelController -> keda "Creates TriggerAuthentication for RawDeployment autoscaling" "HTTPS/443"
        odhModelController -> prometheusOp "Creates ServiceMonitor/PodMonitor for metrics" "HTTPS/443"

        // Relationships - External services
        odhModelController -> ngcAPI "Validates API keys, fetches NIM model catalog" "HTTPS/443"
        odhModelController -> modelRegistry "Syncs InferenceService metadata" "HTTP(S)/443,80"
        odhModelController -> k8sAPI "All reconciliation API calls" "HTTPS/443"

        // Relationships - Infrastructure
        certManager -> odhModelController "Provisions webhook TLS certificates"
        knativeServing -> odhModelController "Knative Service webhook validation"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Infrastructure" {
                background #666666
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
