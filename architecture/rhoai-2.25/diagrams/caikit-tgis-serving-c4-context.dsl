/*
 * C4 Context Diagram for caikit-tgis-serving
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.25/caikit-tgis-serving.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM models for text generation inference"
        admin = person "Cluster Administrator" "Manages platform infrastructure and certificates"

        caikitTgisServing = softwareSystem "Caikit-TGIS-Serving" "Model serving runtime providing HTTP and gRPC APIs for LLM inference using Caikit framework with TGIS backend" {
            caikitContainer = container "Caikit Runtime Container" "Provides standardized HTTP (8080) and gRPC (8085) inference APIs using Caikit AI toolkit" "Python 3.12 / FastAPI / gRPC"
            tgisContainer = container "TGIS Sidecar Container" "Loads and runs LLM models, performs actual text generation inference" "Text Generation Inference Server"
            caikitNlp = container "caikit-nlp" "NLP model handling module for text generation tasks" "Python Library"
            caikitBackend = container "caikit-tgis-backend" "Backend connector bridging Caikit to TGIS via gRPC on port 8033" "Python Library"
        }

        kserve = softwareSystem "KServe" "Manages ServingRuntime and InferenceService lifecycle, storage initialization" "Internal RHOAI"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Provides mTLS, traffic management, ingress gateway" "External"
        knative = softwareSystem "OpenShift Serverless (Knative)" "Provides autoscaling, scale-to-zero, and request routing" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        s3 = softwareSystem "S3/MinIO Storage" "Model artifact storage" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning for ingress gateway" "External"

        # User interactions
        user -> caikitTgisServing "Sends inference requests via HTTP POST or gRPC" "HTTPS/443"
        admin -> kserve "Creates ServingRuntime and InferenceService CRDs" "kubectl"

        # Internal container interactions
        caikitContainer -> caikitNlp "Uses for NLP model handling"
        caikitContainer -> caikitBackend "Uses for TGIS communication"
        caikitBackend -> tgisContainer "Delegates inference" "gRPC/8033 plaintext"

        # Platform dependencies
        kserve -> caikitTgisServing "Orchestrates deployment, manages lifecycle" "ServingRuntime/InferenceService CRDs"
        caikitTgisServing -> istio "Traffic routing, mTLS enforcement" "Sidecar proxy"
        caikitTgisServing -> knative "Autoscaling, serverless routing" "Queue-Proxy"
        prometheus -> caikitTgisServing "Scrapes metrics" "HTTP/8086 PERMISSIVE mTLS"
        kserve -> s3 "Downloads model artifacts at init" "HTTPS/443 TLS 1.2+"
        istio -> certManager "Obtains TLS certificates" "wildcard-certs"
    }

    views {
        systemContext caikitTgisServing "SystemContext" {
            include *
            autoLayout
        }

        container caikitTgisServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
