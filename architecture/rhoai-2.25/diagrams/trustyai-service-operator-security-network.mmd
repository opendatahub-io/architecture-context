        GORCHRoute["Guardrails Orchestrator Route<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
        GORCHHealthRoute["Guardrails Health Route<br/>443/TCP HTTPS<br/>TLS Edge"]
        GORCHGWRoute["Guardrails Gateway Route<br/>443/TCP HTTPS<br/>TLS Reencrypt/Edge"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
    end

    subgraph TASNamespace["USER NAMESPACE (TrustyAI Service)"]
        direction TB
        subgraph TASPod["TrustyAI Service Pod"]
            TASContainer["trustyai-service<br/>8080/TCP HTTP"]
            OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>TLS serving certs"]
        end
        TASSvcInternal["Service: {name}<br/>80/TCP -> 8080 HTTP"]
        TASSvcTLS["Service: {name}-tls<br/>443/TCP -> 8443 HTTPS<br/>OAuth Proxy"]
    end

    subgraph GORCHNamespace["USER NAMESPACE (Guardrails Orchestrator)"]
        direction TB
        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            GORCHContainer["orchestrator<br/>8032/TCP HTTPS<br/>8033/TCP health"]
            BuiltInDetector["built-in-detector<br/>8080/TCP HTTP<br/>(optional)"]
            GatewaySidecar["gateway-sidecar<br/>8090/TCP HTTP<br/>(optional)"]
            GORCHOAuth["oauth-proxy<br/>8432/8490 HTTPS<br/>(optional)"]
        end
        GORCHSvcHTTPS["Service: {name}-service<br/>8032/TCP HTTPS TLS"]
        GORCHSvcHealth["Service: {name}-service<br/>8034/TCP HTTP"]
    end

    subgraph LMESNamespace["USER NAMESPACE (LMEvalJob)"]
        subgraph EvalPod["Evaluation Pod"]
            EvalContainer["evaluation container"]
            LMESDriver["lmes-driver sidecar"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS"]
        Database["Database<br/>JDBC Optional TLS<br/>sslMode=verify-ca"]
        S3["S3 Endpoints<br/>443/TCP HTTPS TLS<br/>AWS AccessKey/SecretKey"]
        ModelEndpoints["Model Endpoints<br/>(HF/OpenAI/vLLM)<br/>HTTP/HTTPS API key"]
        KServeIS["KServe InferenceServices<br/>HTTP/HTTPS"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Optional OAuth"| TASRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Optional OAuth"| GORCHRoute

    %% Route to service flows
    TASRoute -->|"HTTPS/8443<br/>TLS serving certs<br/>OAuth SAR check"| OAuthProxy
    GORCHRoute -->|"HTTPS/8032<br/>TLS serving certs"| GORCHContainer

    %% Internal flows
    OAuthProxy -->|"HTTP/8080<br/>localhost"| TASContainer
    GORCHContainer -->|"HTTP/8080<br/>localhost"| BuiltInDetector
    GatewaySidecar -->|"HTTPS/8032<br/>TLS"| GORCHContainer

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    Operator -->|"exec WebSocket<br/>TLS SA token"| EvalPod

    %% Egress flows
    TASContainer -->|"JDBC<br/>Optional TLS<br/>DB credentials"| Database
    EvalPod -->|"HTTP/HTTPS<br/>API key"| ModelEndpoints
    EvalPod -->|"HTTPS/443<br/>TLS AWS creds"| S3
    GORCHContainer -->|"HTTP/HTTPS<br/>Optional TLS<br/>service-ca certs"| KServeIS

    %% Prometheus
    Prom["Prometheus"] -->|"HTTP/80<br/>plaintext"| TASSvcInternal

