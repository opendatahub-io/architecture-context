graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes — TLS Termination)"]
        TASRoute["Route: {tas-name}<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        GORCHRoute["Route: {gorch-name}<br/>443/TCP → 8432/TCP<br/>TLS Reencrypt"]
        GWRoute["Route: {gorch-name}-gateway<br/>443/TCP → 8490/TCP<br/>TLS Reencrypt/Edge"]
        HealthRoute["Route: {gorch-name}-health<br/>443/TCP → 8034/TCP<br/>TLS Edge"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            OAuthTAS["OAuth Proxy<br/>8443/TCP HTTPS<br/>TLS (service-ca)<br/>SAR: pods/get"]
            TASContainer["TrustyAI Service<br/>8080/TCP HTTP<br/>4443/TCP HTTPS"]
        end

        subgraph GORCHPod["GuardrailsOrchestrator Pod"]
            OAuthGORCH["OAuth Proxy (opt)<br/>8432/TCP HTTPS<br/>8490/TCP HTTPS<br/>SAR: pods/get"]
            GORCHContainer["Orchestrator<br/>8032/TCP HTTPS<br/>TLS (service-ca)"]
            GWContainer["Gateway Sidecar (opt)<br/>8090/TCP HTTP"]
            HealthEndpoint["Health<br/>8034/TCP HTTP"]
        end

        subgraph LMEvalPodSG["LMEvalJob Pod (ephemeral)"]
            LMEvalInit["Init: ta-lmes-driver<br/>(copies binary)"]
            LMEvalMain["Main: lm-eval<br/>(Python 3.11)<br/>RunAsNonRoot<br/>Drop ALL caps"]
            LMEvalDriver["Driver Sidecar<br/>18080/TCP HTTP<br/>No auth (pod-local)"]
        end

        subgraph OperatorPod["Operator Pod"]
            OperatorContainer["trustyai-service-operator<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health"]
        end

        MetricsSvc["controller-manager-metrics-service<br/>8443/TCP HTTPS<br/>Bearer Token (kube-rbac-proxy)"]
    end

    subgraph IstioMesh["ISTIO SERVICE MESH (Conditional)"]
        DestRule["DestinationRule<br/>{tas-name}"]
        VirtSvc["VirtualService<br/>{tas-name}"]
    end

    subgraph PlatformIntegrations["PLATFORM INTEGRATIONS"]
        KServeIS["KServe InferenceService<br/>(patched with TrustyAI logger)"]
        KServeSR["KServe ServingRuntime<br/>(GORCH service discovery)"]
        Prometheus["Prometheus<br/>(ServiceMonitors)"]
        Kueue["Kueue<br/>(Workload CRs)"]
        ODHOperator["ODH Operator<br/>(DSC config)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database["External Database<br/>JDBC, TLS optional<br/>Username/password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+, AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>⚠️ BLOCKED in RHOAI"]
        DetectorSvcs["Detector InferenceServices<br/>HTTPS, TLS (service-ca)"]
        GenSvcs["Generation InferenceServices<br/>HTTPS, TLS (service-ca)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>OAuth Token"| TASRoute
    Client -->|"HTTPS/443<br/>OAuth (opt)"| GORCHRoute
    Client -->|"HTTPS/443"| GWRoute
    Client -->|"HTTPS/443"| HealthRoute

    %% Ingress → Services
    TASRoute -->|"HTTPS/8443<br/>TLS (service-ca)"| OAuthTAS
    GORCHRoute -->|"HTTPS/8432<br/>TLS (service-ca)"| OAuthGORCH
    GWRoute -->|"HTTPS/8490 or HTTP/8090"| GWContainer
    HealthRoute -->|"HTTP/8034"| HealthEndpoint

    %% Internal Pod flows
    OAuthTAS -->|"HTTP/8080<br/>localhost"| TASContainer
    OAuthGORCH -->|"HTTPS/8032<br/>TLS (service-ca)"| GORCHContainer

    %% Operator → managed workloads
    OperatorContainer -.->|"Kubernetes API<br/>HTTPS/6443"| KServeIS
    OperatorContainer -->|"HTTP/18080<br/>POST /GetStatus"| LMEvalDriver

    %% Egress flows
    TASContainer -->|"JDBC (varies)<br/>TLS optional<br/>db-credentials"| Database
    LMEvalMain -->|"HTTPS/443<br/>AWS IAM"| S3
    LMEvalMain -->|"HTTPS/443<br/>⚠️ RHOAI: blocked"| HuggingFace
    GORCHContainer -->|"HTTPS (varies)<br/>TLS (service-ca)"| GenSvcs
    GORCHContainer -->|"HTTPS (varies)<br/>TLS (service-ca)"| DetectorSvcs

    %% Platform integrations
    KServeIS -->|"HTTPS/443<br/>Inference payloads"| TASContainer
    OperatorContainer -.->|"creates"| Prometheus
    OperatorContainer -.->|"creates"| Kueue
    ODHOperator -.->|"ConfigMap"| OperatorContainer
    TASContainer -.->|"conditional"| DestRule
    TASContainer -.->|"conditional"| VirtSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef istio fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class TASRoute,GORCHRoute,GWRoute,HealthRoute ingress
    class OAuthTAS,TASContainer,OAuthGORCH,GORCHContainer,GWContainer,HealthEndpoint,LMEvalInit,LMEvalMain,LMEvalDriver,MetricsSvc service
    class OperatorContainer operator
    class DestRule,VirtSvc istio
    class KServeIS,KServeSR,Prometheus,Kueue,ODHOperator platform
    class Database,S3,HuggingFace,DetectorSvcs,GenSvcs externalservice
