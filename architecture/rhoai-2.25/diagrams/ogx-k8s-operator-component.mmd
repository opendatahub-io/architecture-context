graph TB
    subgraph "Llama Stack K8s Operator"
        Controller["llama-stack-k8s-operator<br/>(Go Operator / controller-runtime)"]
        KustomizePipeline["Kustomize Manifest Pipeline<br/>(Embedded kustomize + Go plugins)"]
        NPTransformer["NetworkPolicy Transformer<br/>(Go kustomize plugin)"]

        Controller -->|renders manifests via| KustomizePipeline
        KustomizePipeline -->|transforms NetworkPolicy| NPTransformer
    end

    User["User / Platform Admin"] -->|creates/updates| LLSDCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LLSDCR -->|watched by| Controller

    Controller -->|creates/manages| Deployment["Deployment<br/>(Llama Stack Server)"]
    Controller -->|creates/manages| Service["{instance}-service<br/>8321/TCP"]
    Controller -->|creates/manages| SA["ServiceAccount<br/>{instance}-sa"]
    Controller -->|creates/manages| PVC["PersistentVolumeClaim<br/>(optional)"]
    Controller -->|creates/manages| NP["NetworkPolicy<br/>(feature-flagged)"]
    Controller -->|creates/manages| Ingress["Ingress<br/>(optional, exposeRoute=true)"]
    Controller -->|creates/manages| CRB["ClusterRoleBinding<br/>(anyuid SCC)"]

    Controller -->|polls health/status| LlamaServer["Llama Stack Server<br/>/v1/health, /v1/providers,<br/>/v1/version"]
    Controller -->|watches| ConfigMap["ConfigMaps<br/>(user-config, CA bundle,<br/>odh-trusted-ca-bundle)"]

    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|deploys via<br/>kustomize overlay| Controller

    Controller -->|CRUD operations| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style KustomizePipeline fill:#4a90e2,stroke:#333,color:#fff
    style NPTransformer fill:#4a90e2,stroke:#333,color:#fff
    style LLSDCR fill:#f5a623,stroke:#333,color:#fff
    style Deployment fill:#7ed321,stroke:#333,color:#fff
    style Service fill:#7ed321,stroke:#333,color:#fff
    style SA fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#7ed321,stroke:#333,color:#fff
    style NP fill:#7ed321,stroke:#333,color:#fff
    style Ingress fill:#7ed321,stroke:#333,color:#fff
    style CRB fill:#7ed321,stroke:#333,color:#fff
    style LlamaServer fill:#9b59b6,stroke:#333,color:#fff
    style ConfigMap fill:#f39c12,stroke:#333,color:#fff
    style PlatformOp fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#3498db,stroke:#333,color:#fff
