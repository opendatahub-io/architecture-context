graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Platform Admin"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB
        Operator["llama-stack-k8s-operator<br/>SA: controller-manager<br/>Replicas: 1 (leader election)"]
        MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP → 8080/TCP<br/>HTTPS / TLS<br/>Bearer Token Auth"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACE ({user-namespace})<br/>NetworkPolicy Protected"]
        direction TB
        LlamaServer["Llama Stack Distribution Server<br/>SA: {instance}-sa<br/>SCC: anyuid"]
        InstanceSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP / No Encryption<br/>No Auth"]
        NetPol["NetworkPolicy<br/>(feature-flagged)<br/>Allows: same-ns pods, operator-ns,<br/>configured ns/labels, ingress router"]
        InstanceIngress["{instance}-ingress<br/>(optional)<br/>80/TCP HTTP<br/>External Access"]
        PVC["PVC (optional)<br/>Model Storage"]
        ConfigMaps["ConfigMaps<br/>user-config, CA bundle,<br/>odh-trusted-ca-bundle"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus / ServiceMonitor<br/>Scrapes 8443/TCP HTTPS<br/>Bearer Token"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control plane to operator
    K8sAPI -->|"Watch events<br/>HTTPS/TLS 1.2+<br/>SA Token"| Operator

    %% Operator to control plane
    Operator -->|"CRUD resources<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator to workload
    Operator -->|"HTTP/8321<br/>No Encryption<br/>No Auth<br/>Health polling"| InstanceSvc

    %% Workload internal
    InstanceSvc --> LlamaServer
    NetPol -.->|"restricts access to"| InstanceSvc
    InstanceIngress -->|"HTTP/80"| InstanceSvc

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc
    MetricsSvc --> Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workloadns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef netpolicy fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,MetricsSvc,HealthProbes operatorns
    class LlamaServer,InstanceSvc,InstanceIngress,PVC,ConfigMaps workloadns
    class NetPol netpolicy
    class Prometheus monitoring
