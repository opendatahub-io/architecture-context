graph TD
    subgraph AuthMechanisms["Authentication Mechanisms"]
        OAuth["OpenShift OAuth<br/>(oauth-proxy sidecar)<br/>Dashboard, Notebooks, Ray,<br/>Model Registry, TrustyAI,<br/>Feast, LlamaStack"]
        BearerPass["Bearer Token Passthrough<br/>Dashboard BFF → K8s API<br/>CodeFlare SDK"]
        AuthorinoAuth["Authorino External AuthZ<br/>KServe InferenceServices<br/>(mesh-dependent)"]
        KubeRBACProxy["kube-rbac-proxy<br/>Kueue metrics,<br/>Training Operator metrics"]
        mTLSIstio["mTLS - Istio<br/>KServe ISVCs, TrustyAI,<br/>odh-model-controller"]
        mTLSRay["mTLS - Self-signed CA<br/>Ray cluster worker<br/>communication"]
        APIKeyNIM["API Key Validation<br/>NVIDIA NIM (NGC API)<br/>odh-model-controller"]
        SAR["SubjectAccessReview<br/>Dashboard BFF,<br/>CodeFlare webhook, Kueue"]
    end

    subgraph ServiceAccounts["Key ServiceAccounts"]
        SA_rhods["rhods-operator<br/>NS: redhat-ods-operator"]
        SA_kserve["kserve-controller-manager<br/>NS: redhat-ods-applications"]
        SA_kueue["kueue-controller-manager<br/>NS: redhat-ods-applications"]
        SA_odhmodel["odh-model-controller<br/>NS: redhat-ods-applications"]
        SA_dashboard["odh-dashboard<br/>NS: redhat-ods-applications"]
        SA_codeflare["codeflare-operator<br/>NS: redhat-ods-applications"]
        SA_dspo["data-science-pipelines-operator<br/>NS: redhat-ods-applications"]
        SA_training["training-operator<br/>NS: redhat-ods-applications"]
    end

    subgraph ClusterRoles["ClusterRoles (Most Privileged)"]
        CR_rhods["rhods-operator-role<br/>20+ CRD groups: *.opendatahub.io/*<br/>core/*, apps/*, networking/*<br/>OLM, monitoring, autoscaling"]
        CR_kserve["kserve-manager-role<br/>serving.kserve.io/*<br/>core/services, apps/deployments<br/>networking, autoscaling"]
        CR_kueue["kueue-manager-role<br/>kueue.x-k8s.io/*<br/>batch/jobs, pod scheduling<br/>13 job framework integrations"]
        CR_odhmodel["odh-model-controller-role<br/>serving.kserve.io/*<br/>route, networkpolicy<br/>authconfig, nim account"]
        CR_dashboard["odh-dashboard-role<br/>opendatahub.io/*<br/>monitoring/servicemonitors<br/>read: accelerators, hardware profiles"]
        CR_trustyai["trustyai-operator-role<br/>trustyai.opendatahub.io/*<br/>serving.kserve.io/inferenceservices"]
    end

    subgraph BroadGrants["Broad Access Grants (Security Concern)"]
        BG_lmeval["default-lmeval-user-rolebinding<br/>ClusterRoleBinding: system:authenticated<br/>→ Full CRUD on LMEvalJob cluster-wide"]
        BG_dashboard["system:authenticated read access<br/>AcceleratorProfiles, HardwareProfiles<br/>NIM Accounts, ServingRuntime templates"]
    end

    subgraph ContainerSecurity["Container Security Patterns"]
        CS_nonroot["Non-root Execution<br/>UIDs: 65532, 1001, 2000, 8737<br/>RunAsNonRoot: true<br/>All Go operators"]
        CS_ubi9["UBI 9 Base Images<br/>registry.redhat.io/ubi9/ubi-minimal<br/>All components (Konflux builds)"]
        CS_fips["FIPS-Compliant Go Builds<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>All Go operators"]
        CS_caps["Capability Drops<br/>capabilities.drop: ALL<br/>SeccompProfile: RuntimeDefault<br/>TrustyAI, Kueue, KServe"]
        CS_digest["Digest-Pinned Images<br/>SHA256 digest pinning<br/>All Konflux-built images"]
        CS_hermetic["Hermetic Builds<br/>cachi2/Hermeto pre-fetch<br/>rhods-operator, KServe, Kueue,<br/>llm-d-scheduler, odh-model-ctrl"]
    end

    subgraph FIPSGaps["FIPS Compliance Gaps"]
        FG_localmodel["KServe localmodel.Dockerfile<br/>CGO_ENABLED=0 + distroless base<br/>Would fail FIPS check-payload"]
        FG_python["Python services<br/>caikit-nlp, vLLM, Feast<br/>Rely on UBI 9 system OpenSSL<br/>No explicit FIPS validation"]
        FG_dsp["DSP components<br/>driver, launcher, persistence agent<br/>Run as root (USER root)"]
    end

    subgraph ElevatedPriv["Elevated Privileges"]
        EP_llmscc["KServe LLM SCC<br/>IPC_LOCK, SYS_RAWIO<br/>GPU memory operations"]
        EP_multinode["Multi-node SCC<br/>hostPath volumes<br/>Shared storage for distributed"]
        EP_dsproot["DSP Root Containers<br/>driver, launcher,<br/>persistence agent,<br/>scheduled workflow controller"]
    end

    subgraph ServiceMeshSecurity["Service Mesh Security (Optional)"]
        PA["PeerAuthentication<br/>Mode: STRICT mTLS<br/>Namespace-scoped"]
        AP_kserve["AuthorizationPolicy<br/>Per-InferenceService<br/>→ Authorino ext authz"]
        VS["VirtualService<br/>KServe serverless traffic<br/>TrustyAI routing"]
        EF["EnvoyFilter<br/>KServe activator filter<br/>Inference graph filter"]
        NP["NetworkPolicies<br/>Namespace isolation<br/>Per-component egress rules"]
    end

    subgraph WebhookSecurity["Webhook Security (TLS 9443)"]
        WH_rhods["rhods-operator: 10 webhooks<br/>DSC, DSCI, HardwareProfile,<br/>Kueue queue-name enforcement"]
        WH_kserve["KServe: 6 webhooks<br/>ISVC, ServingRuntime,<br/>InferenceGraph, storage init"]
        WH_kueue["Kueue: 13 integrations<br/>Job, RayJob, PyTorchJob,<br/>Pod admission"]
        WH_codeflare["CodeFlare: 2 webhooks<br/>oauth-proxy injection,<br/>mTLS certificate generation"]
    end

    %% RBAC bindings
    SA_rhods -->|bound to| CR_rhods
    SA_kserve -->|bound to| CR_kserve
    SA_kueue -->|bound to| CR_kueue
    SA_odhmodel -->|bound to| CR_odhmodel
    SA_dashboard -->|bound to| CR_dashboard

    %% Auth mechanism usage
    OAuth -->|authenticates| SA_dashboard
    AuthorinoAuth -->|authorizes| SA_kserve
    mTLSIstio -->|secures| SA_kserve
    mTLSIstio -->|secures| SA_odhmodel
    mTLSRay -->|secures| SA_codeflare
    KubeRBACProxy -->|protects metrics| SA_kueue
    KubeRBACProxy -->|protects metrics| SA_training
    APIKeyNIM -->|validates| SA_odhmodel
    SAR -->|authorizes| SA_dashboard
    BearerPass -->|forwards tokens| SA_dashboard

    %% Service mesh enforcement
    PA -->|enforces| mTLSIstio
    AP_kserve -->|delegates to| AuthorinoAuth

    %% FIPS gap connections
    CS_fips -.->|gap| FG_localmodel
    CS_fips -.->|gap| FG_python
    CS_nonroot -.->|exception| EP_dsproot

