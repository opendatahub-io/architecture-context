    TrustyAI -->|"HTTPS/443<br/>⚠️ RHOAI: blocked"| HuggingFace["HuggingFace<br/>Hub"]
    TrustyAI -->|"HTTPS/6443"| K8sAPI["Kubernetes API"]
    TrustyAI -->|"metrics scraping"| Prometheus["Prometheus"]

    %% Runtime Dependencies
    TrustyAI -->|"lm-eval runtime<br/>(Python 3.11)"| LMEvalHarness["lm-evaluation-harness<br/>opendatahub-io fork"]

