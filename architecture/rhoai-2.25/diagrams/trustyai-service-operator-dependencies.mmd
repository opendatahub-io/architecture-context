graph LR
    TrustyAI[TrustyAI Service Operator]

    %% Required External Dependencies
    TrustyAI -->|"runtime<br/>required"| K8s[Kubernetes/OpenShift 1.19+/4.6+]

    %% Optional External Dependencies
    TrustyAI -.->|"metrics scraping<br/>optional"| Prometheus[Prometheus Operator]
    TrustyAI -.->|"authentication<br/>OpenShift only"| OAuth[OpenShift OAuth]
    TrustyAI -.->|"traffic mgmt<br/>KServe serverless mode"| Istio[Istio Service Mesh]
    TrustyAI -.->|"webhook certs<br/>alternative to service-ca"| CertManager[cert-manager 1.13+]
    TrustyAI -.->|"job queueing<br/>LM eval admission control"| Kueue[Kueue v0.6+]
    TrustyAI -.->|"data storage<br/>alternative to PVC"| Database[PostgreSQL/MySQL]

    %% Internal ODH Dependencies
    TrustyAI -->|"watch/patch CRs<br/>model monitoring"| KServe[KServe]
    TrustyAI -->|"pod exec config<br/>payload processor"| ModelMesh[ModelMesh Serving]
    TrustyAI -.->|"shared storage<br/>PVC"| DSP[Data Science Pipelines]
    TrustyAI -.->|"UI integration<br/>CR creation"| Dashboard[ODH Dashboard]

    %% Managed Services (Created by Operator)
    TrustyAI ==>|"creates/manages"| TAService[TrustyAI Service]
    TrustyAI ==>|"creates/manages"| LMEval[LM Eval Jobs]
    TrustyAI ==>|"creates/manages"| Guardrails[Guardrails Orchestrator]

    %% Service Dependencies
    TAService -->|"monitors predictions"| KServe
    TAService -->|"payload processing"| ModelMesh
    TAService -.->|"data persistence"| Database
    TAService -->|"metrics"| Prometheus

    LMEval -->|"model evaluation"| KServe
    LMEval -->|"workload queueing"| Kueue
    LMEval -->|"result storage"| S3[S3-compatible Storage]
    LMEval -->|"model/dataset download"| HuggingFace[Hugging Face Hub]

    Guardrails -->|"detector/generator calls"| KServe
    Guardrails -->|"authentication"| OAuth

    %% Integration Points (reverse dependencies)
    Dashboard -.->|"UI mgmt"| TrustyAI
    DSP -.->|"auto-deploy eval jobs"| LMEval

    %% External Services
    TAService -.->|"storage"| S3

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px

    %% Required dependencies (solid)
    style K8s fill:#d32f2f,stroke:#333,stroke-width:2px,color:#fff

    %% Optional external dependencies (dashed)
    style Prometheus fill:#999,stroke:#333,stroke-dasharray: 5 5
    style OAuth fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Istio fill:#999,stroke:#333,stroke-dasharray: 5 5
    style CertManager fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Kueue fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Database fill:#999,stroke:#333,stroke-dasharray: 5 5

    %% Internal ODH dependencies
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style DSP fill:#7ed321,stroke:#333,stroke-dasharray: 5 5
    style Dashboard fill:#7ed321,stroke:#333,stroke-dasharray: 5 5

    %% Managed services
    style TAService fill:#4fc3f7,stroke:#333,stroke-width:2px
    style LMEval fill:#4fc3f7,stroke:#333,stroke-width:2px
    style Guardrails fill:#4fc3f7,stroke:#333,stroke-width:2px

    %% External services
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
