    TrustyAI -->|"watch + patch<br/>InferenceServices"| KServe["KServe<br/>(InferenceService,<br/>ServingRuntime)"]
    TrustyAI -->|"auth sidecar"| OAuthProxy["OpenShift<br/>OAuth Proxy"]
    TrustyAI -->|"TLS cert generation<br/>(annotation-triggered)"| ServiceCA["OpenShift<br/>Service CA"]
    TrustyAI -->|"DestinationRules +<br/>VirtualServices<br/>(conditional)"| Istio["Istio<br/>Service Mesh"]
    TrustyAI -->|"DSC config<br/>(LMEval permissions)"| ODHOperator["OpenDataHub<br/>Operator"]
