    %% Integration Points (other components → TrustyAI)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    Pipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| TrustyAI

    %% External Services
    TrustyAI -->|"JDBC (TLS optional)<br/>monitoring data"| Database["External<br/>Database"]
