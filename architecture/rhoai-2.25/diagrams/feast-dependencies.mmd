graph LR
    Feast["Feast<br/>(Operator + Feature Server)"]

    %% Platform Dependencies (Internal RHOAI)
    Feast -->|"CRD deployment<br/>kustomize overlays"| RHOAIOperator["RHOAI Operator"]
    Feast -->|"TLS cert provisioning<br/>annotation-driven"| ServingCerts["OpenShift Service<br/>Serving Certs"]
    Feast -->|"CA trust chain<br/>volume mount"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Kubernetes Platform
    Feast -->|"CRUD resources<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    Feast -->|"external access<br/>HTTPS/6443"| RouteAPI["OpenShift Route API"]
    Feast -->|"operator metrics<br/>HTTPS/8443"| Prometheus["Prometheus /<br/>ServiceMonitor"]

    %% External Store Backends (Online)
    Feast -->|"online store<br/>TCP/6379"| Redis["Redis"]
    Feast -->|"online/offline store<br/>TCP/5432"| PostgreSQL["PostgreSQL"]
    Feast -->|"online store<br/>HTTPS/443"| DynamoDB["AWS DynamoDB"]

    %% External Store Backends (Offline/Registry)
    Feast -->|"registry storage<br/>HTTPS/443"| S3["AWS S3"]
    Feast -->|"registry/offline<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    Feast -->|"offline store<br/>HTTPS/443"| Snowflake["Snowflake"]

    %% External Services
    Feast -->|"token validation<br/>HTTPS/443"| OIDC["OIDC Provider"]
    Feast -->|"pull images<br/>HTTPS/443"| ContainerReg["Container Registry<br/>(quay.io)"]
    Feast -.->|"on-demand transforms<br/>gRPC (insecure)"| TransformSvc["Transformation Service"]

    %% Framework Dependencies
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.18.4+"]
    Feast -->|"REST framework"| FastAPI["FastAPI<br/>>=0.120.1"]
    Feast -->|"data format"| Arrow["Apache Arrow<br/>v17"]
    Feast -->|"serialization"| Protobuf["protobuf<br/>>=4.24.0"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style RHOAIOperator fill:#7ed321,stroke:#333
    style ServingCerts fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333

    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style RouteAPI fill:#dae8fc,stroke:#6c8ebf
    style Prometheus fill:#dae8fc,stroke:#6c8ebf

    style Redis fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style DynamoDB fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Snowflake fill:#f5a623,stroke:#333

    style OIDC fill:#999,stroke:#333,color:#fff
    style ContainerReg fill:#999,stroke:#333,color:#fff
    style TransformSvc fill:#f8cecc,stroke:#b85450

    style ControllerRuntime fill:#e8e8e8,stroke:#333
    style FastAPI fill:#e8e8e8,stroke:#333
    style Arrow fill:#e8e8e8,stroke:#333
    style Protobuf fill:#e8e8e8,stroke:#333
