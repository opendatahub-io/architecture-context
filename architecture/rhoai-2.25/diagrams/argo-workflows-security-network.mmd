graph TB
    subgraph Internal["INTERNAL CLUSTER SERVICES"]
        DSP["Data Science Pipelines<br/>API Server"]
    end

    subgraph K8sLayer["KUBERNETES API"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph ControllerZone["WORKFLOW CONTROLLER ZONE"]
        direction TB

        subgraph NS_Controller["Namespace: (DSP-configured)"]
            WFC["workflow-controller<br/>SA: argo<br/>Image: argo-workflowcontroller<br/>FIPS: Yes (strictfipsruntime)"]
            Metrics["Metrics Endpoint<br/>9090/TCP HTTP<br/>No Auth"]
            Health["Health Endpoint<br/>6060/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph ExecutionZone["WORKFLOW EXECUTION ZONE"]
        direction TB

        subgraph NS_Workflow["Namespace: (workflow-specified)"]
            WFPod["Workflow Pod<br/>+ argoexec sidecar<br/>SA: (workflow-specified)<br/>FIPS: Dual binary (default: non-FIPS)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / MinIO<br/>Artifact Store<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / AccessKey"]
        GCS["GCS<br/>(alternative)<br/>443/TCP HTTPS<br/>SA JSON key"]
        Azure["Azure Blob<br/>(alternative)<br/>443/TCP HTTPS<br/>Azure Identity"]
    end

    subgraph OptionalServices["OPTIONAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/Password"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS optional<br/>Username/Password"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    %% Flows
    DSP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Creates Workflow CRs"| K8sAPI
    K8sAPI -->|"Watch/Informer<br/>TLS 1.2+<br/>SA Token"| WFC
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD Pods, CRDs, PVCs"| K8sAPI
    WFC -->|"Creates Pods with"| WFPod
    WFPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Workflow SA Token<br/>TaskResult CRs"| K8sAPI
    WFPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / AccessKey<br/>Artifacts"| S3
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / AccessKey<br/>Artifact GC"| S3
    WFC -.->|"TCP/5432<br/>TLS optional<br/>Username/Password<br/>Archival"| PostgreSQL
    WFC -.->|"TCP/3306<br/>TLS optional<br/>Username/Password<br/>Archival"| MySQL
    Prometheus -->|"HTTP/9090<br/>No Auth<br/>Scrape"| Metrics

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef executor fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef endpoint fill:#ffe6cc,stroke:#d79b00,stroke-width:1px

    class DSP internal
    class K8sAPI k8s
    class WFC controller
    class WFPod executor
    class S3,GCS,Azure external
    class PostgreSQL,MySQL optional
    class Prometheus monitoring
    class Metrics,Health endpoint
