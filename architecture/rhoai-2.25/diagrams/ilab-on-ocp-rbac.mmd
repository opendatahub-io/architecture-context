%% RBAC Matrix Diagram for ilab-on-ocp
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.25/ilab-on-ocp.md

graph TD
    subgraph "Service Accounts"
        SA_Pipeline["pipeline-runner-dspa<br/>(provisioned by DSPA)"]
        SA_Mixtral["mixtral-sa"]
        SA_Prometheus["prometheus-sa"]
    end

    subgraph "Role Bindings"
        RB_Mixtral["mixtral-view<br/>(User namespace)"]
        RB_Prometheus["prometheus-view<br/>(User namespace)"]
        RB_DSP["dsp-permissions<br/>(rhoai-model-registries ns)"]
    end

    subgraph "Roles"
        R_Mixtral["mixtral-view-role"]
        R_Prometheus["prometheus-view-role"]
        R_Registry["registry-user-{registry-name}"]
    end

    subgraph "API Resources"
        IS_Mixtral["serving.kserve.io<br/>InferenceService<br/>(resourceName: mixtral)"]
        IS_Prometheus["serving.kserve.io<br/>InferenceService<br/>(resourceName: prometheus)"]
        MR_Resources["Model Registry<br/>Resources"]
    end

    subgraph "Kubernetes API Access (via SA Token)"
        K8s_Secrets["core/v1<br/>Secrets"]
        K8s_PyTorchJob["kubeflow.org/v1<br/>PyTorchJob"]
        K8s_Namespaces["core/v1<br/>Namespaces"]
    end

    subgraph "Secrets Consumed"
        S_Teacher["teacher-secret<br/>(Opaque)<br/>endpoint, model_name, api_token"]
        S_Judge["judge-secret<br/>(Opaque)<br/>endpoint, model_name, api_token"]
        S_Taxonomy["taxonomy-repo-secret<br/>(basic-auth / ssh-auth)<br/>Git credentials"]
        S_OCI["{oci-registry-push-secret}<br/>(dockerconfigjson)<br/>OCI push credentials"]
        S_HF["hugging-face-token<br/>(Opaque)<br/>HuggingFace token"]
    end

    %% Mixtral RBAC chain
    SA_Mixtral -->|"bound via"| RB_Mixtral
    RB_Mixtral -->|"grants"| R_Mixtral
    R_Mixtral -->|"get"| IS_Mixtral

    %% Prometheus RBAC chain
    SA_Prometheus -->|"bound via"| RB_Prometheus
    RB_Prometheus -->|"grants"| R_Prometheus
    R_Prometheus -->|"get"| IS_Prometheus

    %% Pipeline SA RBAC chain
    SA_Pipeline -->|"bound via"| RB_DSP
    RB_DSP -->|"grants"| R_Registry
    R_Registry -->|"CRUD"| MR_Resources

    %% Pipeline SA K8s API access
    SA_Pipeline -->|"GET"| K8s_Secrets
    SA_Pipeline -->|"CREATE, GET, DELETE"| K8s_PyTorchJob
    SA_Pipeline -->|"GET, LIST"| K8s_Namespaces

    %% Pipeline SA Secret consumption
    SA_Pipeline -->|"reads"| S_Teacher
    SA_Pipeline -->|"reads"| S_Judge
    SA_Pipeline -->|"reads"| S_Taxonomy
    SA_Pipeline -->|"reads"| S_OCI
    SA_Pipeline -->|"reads"| S_HF

    subgraph "Auth Endpoints"
        Auth_Teacher["Teacher Model Server<br/>POST /v1/chat/completions<br/>Enforcement: KServe/Authorino"]
        Auth_Judge["Judge Model Server<br/>POST /v1/chat/completions<br/>Enforcement: KServe/Authorino"]
        Auth_K8s["Kubernetes API<br/>HTTPS/443<br/>Enforcement: K8s RBAC"]
        Auth_MR["Model Registry<br/>HTTPS/443<br/>Enforcement: MR Auth"]
        Auth_OCI["OCI Registry<br/>HTTPS/443<br/>Enforcement: Registry Auth"]
    end

    S_Teacher -->|"Bearer Token"| Auth_Teacher
    S_Judge -->|"Bearer Token"| Auth_Judge
    SA_Pipeline -->|"SA Bearer Token"| Auth_K8s
    SA_Pipeline -->|"SA Bearer Token"| Auth_MR
    S_OCI -->|"Docker auth"| Auth_OCI

