graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>(Data Scientists, API Consumers)"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes / Gateway API)"]
        DashRoute["ODH Dashboard Route<br/>443/TCP HTTPS<br/>TLS termination<br/>OAuth (oauth-proxy)"]
        KServeRoute["KServe Inference Routes<br/>443/TCP HTTPS<br/>TLS termination<br/>Bearer Token or Authorino"]
        LLMdGW["LLMInferenceService Gateway<br/>443/TCP HTTPS<br/>Gateway API HTTPRoute<br/>Envoy ext-proc"]
        NotebookRoute["Notebook Routes<br/>443/TCP HTTPS<br/>TLS termination<br/>OAuth (oauth-proxy)"]
        RayRoute["Ray Dashboard Routes<br/>443/TCP HTTPS<br/>TLS termination<br/>OAuth (oauth-proxy)"]
        RegistryRoute["Model Registry Route<br/>443/TCP HTTPS<br/>TLS termination<br/>OAuth (oauth-proxy)"]
    end

    subgraph OperatorNS["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator<br/>Leader election"]
    end

    subgraph PlatformNS["Namespace: redhat-ods-applications"]
        direction TB
        Dashboard["odh-dashboard<br/>SA: odh-dashboard<br/>8080/TCP + oauth-proxy"]
        KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager<br/>Leader election"]
        KueueCtrl["Kueue Controller<br/>SA: kueue-controller-manager<br/>Leader election"]
        ODHModelCtrl2["odh-model-controller<br/>SA: odh-model-controller<br/>Leader election"]
        CodeFlareOp["CodeFlare Operator<br/>SA: codeflare-operator<br/>Leader election"]
        KubeRayOp["KubeRay Operator<br/>SA: kuberay-operator<br/>Leader election"]
        DSPOCtrl["DSPO<br/>SA: data-science-pipelines-operator<br/>Leader election"]
        TrainingOp2["Training Operator<br/>SA: training-operator<br/>Leader election"]
        TrustyAIOp["TrustyAI Operator<br/>SA: trustyai-operator<br/>Leader election"]
        ModelRegOp["Model Registry Operator<br/>SA: model-registry-operator<br/>Leader election"]
        FeastOp["Feast Operator<br/>SA: feast-operator<br/>Leader election"]
        LlamaStackOp["Llama Stack Operator<br/>SA: llamastack-operator<br/>Leader election"]
        ModelMeshCtrl["ModelMesh Serving<br/>SA: modelmesh-serving<br/>Controller"]
    end

    subgraph MonitoringNS["Namespace: redhat-ods-monitoring"]
        MonStack["MonitoringStack<br/>Prometheus + Alertmanager"]
        Tempo["Tempo<br/>Trace backend"]
        OTELCollector["OpenTelemetry Collector<br/>Trace collection"]
    end

    subgraph UserNS["User Namespaces (per-project)"]
        direction TB
        NotebookPod["Notebook Pods<br/>(StatefulSet)<br/>oauth-proxy sidecar"]
        ISVCPod["InferenceService Pods<br/>storage-initializer init<br/>kserve-agent sidecar"]
        LLMdPod["LLMInferenceService Pods<br/>vLLM + routing-sidecar<br/>EPP StatefulSet"]
        ModelMeshPod["ModelMesh Pods<br/>ModelMesh sidecar<br/>runtime adapter"]
        DSPAPod["DSPA Instance<br/>API Server, Argo Controller<br/>MariaDB, MLMD, MinIO"]
        RayCluster["Ray Clusters<br/>Head + Workers<br/>mTLS (self-signed CA)"]
        TrustyAIInst["TrustyAI Instance<br/>Deployment"]
        ModelRegInst["Model Registry Instance<br/>REST proxy + MLMD backend"]
        FeastInst["FeatureStore Instance<br/>Online + Offline serving"]
    end

    subgraph MeshNS["Namespace: istio-system (Optional)"]
        SMCP["ServiceMeshControlPlane<br/>Maistra/Istio"]
        AuthorinoSvc["Authorino<br/>External AuthZ"]
    end

    subgraph EgressSvc["EGRESS (External Services)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>AWS IAM / Static creds"]
        ContainerReg["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS<br/>Pull secrets"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>ServiceAccount tokens"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>API token"]
    end

    %% External to Ingress
    Clients -->|"HTTPS/443"| DashRoute
    Clients -->|"HTTPS/443"| KServeRoute
    Clients -->|"HTTPS/443"| LLMdGW
    Clients -->|"HTTPS/443"| NotebookRoute
    Clients -->|"HTTPS/443"| RayRoute
    Clients -->|"HTTPS/443"| RegistryRoute

    %% Ingress to Platform / User NS
    DashRoute -->|"HTTP/8080"| Dashboard
    KServeRoute -->|"HTTP/8012"| ISVCPod
    LLMdGW -->|"ext-proc gRPC"| LLMdPod
    NotebookRoute -->|"HTTP/8080"| NotebookPod
    RayRoute -->|"HTTP/8265"| RayCluster
    RegistryRoute -->|"HTTP/8080"| ModelRegInst

    %% Platform NS to K8s API
    RhodsOp -->|"HTTPS/6443<br/>SA token"| K8sAPI
    KServeCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    KueueCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    ODHModelCtrl2 -->|"HTTPS/6443<br/>SA token"| K8sAPI
    Dashboard -->|"HTTPS/6443<br/>Bearer passthrough"| K8sAPI

    %% Platform NS to User NS (controller reconciliation)
    KServeCtrl -->|"reconciles"| ISVCPod
    KServeCtrl -->|"reconciles"| LLMdPod
    ODHModelCtrl2 -->|"Route, NetworkPolicy<br/>AuthConfig"| ISVCPod
    DSPOCtrl -->|"reconciles"| DSPAPod
    CodeFlareOp -->|"oauth-proxy, mTLS<br/>NetworkPolicy"| RayCluster
    KubeRayOp -->|"reconciles"| RayCluster
    TrustyAIOp -->|"reconciles"| TrustyAIInst
    ModelRegOp -->|"reconciles"| ModelRegInst
    FeastOp -->|"reconciles"| FeastInst

    %% Service Mesh (optional)
    ISVCPod -.->|"mTLS STRICT<br/>(when mesh enabled)"| SMCP
    ODHModelCtrl2 -.->|"AuthConfig"| AuthorinoSvc
    TrustyAIInst -.->|"mTLS"| SMCP

    %% User NS to Egress
    ISVCPod -->|"HTTPS/443<br/>model download"| S3
    LLMdPod -->|"HTTPS/443<br/>model download"| S3
    DSPAPod -->|"HTTPS/443<br/>artifacts"| S3
    ModelRegInst -->|"HTTPS/443<br/>artifact storage"| S3
    ISVCPod -->|"HTTPS/443<br/>runtime images"| ContainerReg
    NotebookPod -->|"HTTPS/443<br/>workbench images"| ContainerReg
    KServeCtrl -->|"HTTPS/443<br/>tokenizer"| HuggingFace

    %% Monitoring
    MonStack -.->|"scrapes metrics"| Dashboard
    MonStack -.->|"scrapes metrics"| KServeCtrl
    MonStack -.->|"scrapes metrics"| KueueCtrl
    OTELCollector -.->|"OTLP/gRPC"| Tempo

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef userns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef mesh fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f5f5f5,stroke:#666,stroke-width:2px

    class Clients external
    class DashRoute,KServeRoute,LLMdGW,NotebookRoute,RayRoute,RegistryRoute ingress
    class RhodsOp operator
    class Dashboard,KServeCtrl,KueueCtrl,ODHModelCtrl2,CodeFlareOp,KubeRayOp,DSPOCtrl,TrainingOp2,TrustyAIOp,ModelRegOp,FeastOp,LlamaStackOp,ModelMeshCtrl platform
    class MonStack,Tempo,OTELCollector monitoring
    class NotebookPod,ISVCPod,LLMdPod,ModelMeshPod,DSPAPod,RayCluster,TrustyAIInst,ModelRegInst,FeastInst userns
    class SMCP,AuthorinoSvc mesh
    class S3,ContainerReg,K8sAPI,HuggingFace egress
