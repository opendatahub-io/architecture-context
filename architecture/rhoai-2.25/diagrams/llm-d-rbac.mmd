graph TD
    subgraph ModelServerSA["Model Server Service Account"]
        SA_Model["sa<br/>(guides/recipes/modelserver/common/sa.yaml)"]
    end

    subgraph EPPSA["EPP Service Account"]
        SA_EPP["llm-d-inference-scheduler SA<br/>(defined in Helm chart)"]
    end

    subgraph EPPBindings["EPP ClusterRole Bindings"]
        CRB_EPP["ClusterRoleBinding<br/>(defined in llm-d-inference-scheduler Helm chart)"]
    end

    subgraph EPPRole["EPP ClusterRole Permissions"]
        CR_EPP["ClusterRole<br/>(defined in llm-d-inference-scheduler Helm chart)"]
    end

    subgraph InferenceResources["Inference API Resources"]
        InferencePool["inference.networking.x-k8s.io<br/>InferencePool"]
        InferenceModel["inference.networking.x-k8s.io<br/>InferenceModel"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>Pods"]
        Endpoints["core<br/>Endpoints"]
    end

    subgraph SecretsAccess["Secrets"]
        HFToken["hf-token<br/>(Opaque)<br/>HuggingFace API token<br/>Manual provisioning<br/>No auto-rotation"]
        PromTLS["prometheus-web-tls<br/>(kubernetes.io/tls)<br/>Prometheus HTTPS cert<br/>Script-provisioned<br/>10-year validity"]
    end

    subgraph AuthEndpoints["Authentication & Authorization"]
        EP_Completions["/v1/completions<br/>POST<br/>Auth: None (configurable at Gateway)"]
        EP_Chat["/v1/chat/completions<br/>POST<br/>Auth: None (configurable at Gateway)"]
        EP_Health["/health<br/>GET<br/>Auth: None (open)"]
        EP_Metrics["/metrics<br/>GET<br/>Auth: None (Prometheus scrape)"]
    end

    %% EPP RBAC chain
    SA_EPP -->|"bound via"| CRB_EPP
    CRB_EPP -->|"grants"| CR_EPP
    CR_EPP -->|"get, list, watch"| InferencePool
    CR_EPP -->|"get, list, watch"| InferenceModel
    CR_EPP -->|"get, list, watch"| Pods
    CR_EPP -->|"get, list, watch"| Endpoints

    %% Model server SA - minimal RBAC
    SA_Model -.->|"minimal RBAC<br/>(no cluster roles)"| CoreResources

    %% Secrets consumed by pods
    SA_Model -->|"mounts secret"| HFToken

    %% Styling
    style SA_Model fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB_EPP fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style CR_EPP fill:#f5a623,stroke:#333,stroke-width:2px
    style InferencePool fill:#7ed321,stroke:#333,stroke-width:1px
    style InferenceModel fill:#7ed321,stroke:#333,stroke-width:1px
    style Pods fill:#7ed321,stroke:#333,stroke-width:1px
    style Endpoints fill:#7ed321,stroke:#333,stroke-width:1px
    style HFToken fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style PromTLS fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style EP_Completions fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style EP_Chat fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style EP_Health fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style EP_Metrics fill:#d5e8d4,stroke:#82b366,stroke-width:1px
