graph LR
    Kueue["Kueue Operator<br/>(kueue-controller-manager)"]

    %% External Dependencies (Required)
    Kueue -->|"CRD CRUD, leader election<br/>443/TCP HTTPS"| K8sAPI["Kubernetes 1.32.x<br/>(Required)"]
    Kueue -->|"controller framework"| CtrlRuntime["controller-runtime 0.19.4<br/>(Required, pinned)"]

    %% External Dependencies (Optional)
    Kueue -.->|"optional TLS certs"| CertManager["cert-manager v1.17.1<br/>(Optional)"]
    Kueue -.->|"ProvisioningRequest CRD"| AutoScaler["cluster-autoscaler<br/>(Optional)"]
    Kueue -.->|"remote workload sync<br/>443/TCP HTTPS"| WorkerClusters["MultiKueue Worker<br/>Clusters (Optional)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8443/TCP HTTPS"| Kueue

    %% Job Framework Integrations (CRD Watch + Webhook)
    Kueue -->|"suspend/resume<br/>CRD Watch + Webhook"| BatchJob["batch/Job"]
    Kueue -->|"CRD Watch + Webhook"| PyTorchJob["kubeflow.org<br/>PyTorchJob"]
    Kueue -->|"CRD Watch + Webhook"| TFJob["kubeflow.org<br/>TFJob"]
    Kueue -->|"CRD Watch + Webhook"| MPIJob["kubeflow.org<br/>MPIJob"]
    Kueue -->|"CRD Watch + Webhook"| PaddleJob["kubeflow.org<br/>PaddleJob"]
    Kueue -->|"CRD Watch + Webhook"| XGBoostJob["kubeflow.org<br/>XGBoostJob"]
    Kueue -->|"CRD Watch + Webhook"| RayJob["ray.io<br/>RayJob"]
    Kueue -->|"CRD Watch + Webhook"| RayCluster["ray.io<br/>RayCluster"]
    Kueue -->|"CRD Watch + Webhook"| JobSet["jobset.x-k8s.io<br/>JobSet"]
    Kueue -->|"CRD Watch + Webhook"| AppWrapper["codeflare.dev<br/>AppWrapper"]
    Kueue -->|"CRD Watch + Webhook"| LWS["sigs.k8s.io<br/>LeaderWorkerSet"]
    Kueue -->|"CRD Watch + Webhook"| PodDeploy["Pod / Deployment /<br/>StatefulSet"]

    %% Kubernetes Resources Watched
    Kueue -->|"watch"| PriorityClass["scheduling.k8s.io<br/>PriorityClass"]
    Kueue -->|"watch (TAS)"| Nodes["core/Node"]
    Kueue -->|"watch"| LimitRange["core/LimitRange"]
    Kueue -->|"watch"| RuntimeClass["node.k8s.io<br/>RuntimeClass"]

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style AutoScaler fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style WorkerClusters fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Monitoring
    style Prometheus fill:#e6522c,stroke:#333,color:#fff

    %% Job frameworks (internal integrations)
    style BatchJob fill:#7ed321,stroke:#333,color:#fff
    style PyTorchJob fill:#7ed321,stroke:#333,color:#fff
    style TFJob fill:#7ed321,stroke:#333,color:#fff
    style MPIJob fill:#7ed321,stroke:#333,color:#fff
    style PaddleJob fill:#7ed321,stroke:#333,color:#fff
    style XGBoostJob fill:#7ed321,stroke:#333,color:#fff
    style RayJob fill:#7ed321,stroke:#333,color:#fff
    style RayCluster fill:#7ed321,stroke:#333,color:#fff
    style JobSet fill:#7ed321,stroke:#333,color:#fff
    style AppWrapper fill:#7ed321,stroke:#333,color:#fff
    style LWS fill:#7ed321,stroke:#333,color:#fff
    style PodDeploy fill:#7ed321,stroke:#333,color:#fff

    %% Kubernetes resources
    style PriorityClass fill:#f5a623,stroke:#333
    style Nodes fill:#f5a623,stroke:#333
    style LimitRange fill:#f5a623,stroke:#333
    style RuntimeClass fill:#f5a623,stroke:#333
