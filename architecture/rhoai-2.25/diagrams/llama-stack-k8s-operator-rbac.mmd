graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: llama-stack-k8s-operator-system]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
        CRB_AuthProxy[auth-proxy-rolebinding]
        RB_LeaderElection[leader-election-rolebinding<br/>Namespace-scoped]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_AuthProxy[auth-proxy-role]
        CR_MetricsReader[metrics-reader]
        R_LeaderElection[leader-election-role<br/>Role]
    end

    subgraph "User-facing Roles"
        CR_Editor[llsd-editor-role<br/>Create/Edit LlamaStackDistributions]
        CR_Viewer[llsd-viewer-role<br/>Read-only access]
    end

    subgraph "API Resources - llamastack.io"
        API_LLSD[llamastackdistributions<br/>get, list, watch, create, update, patch, delete]
        API_LLSD_Status[llamastackdistributions/status<br/>get, update, patch]
        API_LLSD_Finalizers[llamastackdistributions/finalizers<br/>update]
    end

    subgraph "API Resources - apps"
        API_Deployments[deployments<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - core"
        API_Services[services<br/>get, list, watch, create, update, patch, delete]
        API_ServiceAccounts[serviceaccounts<br/>get, list, watch, create, update, patch, delete]
        API_PVCs[persistentvolumeclaims<br/>get, list, watch, create]
        API_ConfigMaps[configmaps<br/>get, list, watch, create, update, patch]
        API_Metrics[endpoints, services, pods<br/>get, list, watch]
    end

    subgraph "API Resources - networking.k8s.io"
        API_Ingresses[ingresses<br/>get, list, watch, create, update, patch, delete]
        API_NetworkPolicies[networkpolicies<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - rbac.authorization.k8s.io"
        API_ClusterRoleBindings[clusterrolebindings<br/>get, list, watch, create, update, patch, delete]
        API_ClusterRoles[clusterroles<br/>get, list, watch]
    end

    subgraph "API Resources - security.openshift.io"
        API_SCC[securitycontextconstraints<br/>use]
        API_SCC_Anyuid[securitycontextconstraints<br/>resourceName: anyuid<br/>use]
    end

    subgraph "API Resources - authentication/authorization"
        API_TokenReviews[tokenreviews<br/>create]
        API_SubjectAccessReviews[subjectaccessreviews<br/>create]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_AuthProxy
    SA_Controller -->|bound via| RB_LeaderElection

    %% ClusterRole Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_LeaderElection -->|grants| R_LeaderElection

    %% manager-role permissions
    CR_Manager -->|full CRUD| API_LLSD
    CR_Manager -->|get, update, patch| API_LLSD_Status
    CR_Manager -->|update| API_LLSD_Finalizers
    CR_Manager -->|full CRUD| API_Deployments
    CR_Manager -->|full CRUD| API_Services
    CR_Manager -->|full CRUD| API_ServiceAccounts
    CR_Manager -->|get, list, watch, create| API_PVCs
    CR_Manager -->|get, list, watch, create, update, patch| API_ConfigMaps
    CR_Manager -->|full CRUD| API_Ingresses
    CR_Manager -->|full CRUD| API_NetworkPolicies
    CR_Manager -->|full CRUD| API_ClusterRoleBindings
    CR_Manager -->|get, list, watch| API_ClusterRoles
    CR_Manager -->|use| API_SCC
    CR_Manager -->|use| API_SCC_Anyuid

    %% auth-proxy-role permissions
    CR_AuthProxy -->|create| API_TokenReviews
    CR_AuthProxy -->|create| API_SubjectAccessReviews

    %% metrics-reader permissions
    CR_MetricsReader -->|get, list, watch| API_Metrics

    %% User-facing roles
    CR_Editor -->|full CRUD| API_LLSD
    CR_Viewer -->|get, list, watch| API_LLSD

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_MetricsReader fill:#f5a623,stroke:#333
    style R_LeaderElection fill:#f5a623,stroke:#333
    style CR_Editor fill:#7ed321,stroke:#333
    style CR_Viewer fill:#7ed321,stroke:#333
    style API_LLSD fill:#d5e8d4,stroke:#333
    style API_LLSD_Status fill:#d5e8d4,stroke:#333
    style API_LLSD_Finalizers fill:#d5e8d4,stroke:#333
    style API_Deployments fill:#d5e8d4,stroke:#333
    style API_Services fill:#d5e8d4,stroke:#333
    style API_SCC_Anyuid fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
