graph TB
    subgraph "vllm-gaudi Plugin Package"
        direction TB
        Platform["HpuPlatform<br/><i>Platform Registration</i><br/>Device config, attention backends,<br/>quantization support"]
        ModelRunner["HPUModelRunner<br/><i>Model Execution</i><br/>Graph compilation, bucketing,<br/>memory optimization"]
        Worker["HPUWorker<br/><i>Device Lifecycle</i><br/>KV cache, profiling,<br/>sleep/wake cycles"]
        MultiModel["MultiModelAsyncLLM<br/><i>Multi-Model Engine</i><br/>Dynamic model switching,<br/>sleep/wake/reconfigure"]
        APIServer["multi_model_api_server<br/><i>FastAPI Server</i><br/>OpenAI-compatible API<br/>Port 8000/TCP"]
        ExtFramework["Extension Framework<br/><i>Config System</i><br/>Feature flags, bucketing,<br/>profiling, defrag"]
        CalibTools["Calibration Tools<br/><i>Quantization Pipeline</i><br/>FP8/INC/AWQ/GPTQ<br/>measure → quantize → unify"]

        Platform -->|configures| ModelRunner
        Platform -->|configures| Worker
        Worker -->|executes| ModelRunner
        MultiModel -->|manages lifecycle| Worker
        APIServer -->|routes to| MultiModel
        ExtFramework -->|configures| Worker
        ExtFramework -->|configures| ModelRunner
    end

    subgraph "vLLM Core (Upstream)"
        vLLMEngine["vLLM Engine<br/><i>Core Inference Engine</i>"]
        vLLMEntrypoints["vLLM Entrypoints<br/><i>OpenAI API Server</i>"]
    end

    Client["Client<br/>(via KServe Ingress)"] -->|"POST /v1/chat/completions<br/>HTTP 8000/TCP"| APIServer
    APIServer -->|"GET /health"| Client

    Platform -->|"entry_points:<br/>vllm.platform_plugins<br/>vllm.general_plugins"| vLLMEngine

    Worker -->|"HPU API<br/>habana-frameworks"| GaudiHPU["Gaudi HPU Device<br/><i>Gaudi2 / Gaudi3</i>"]

    Worker -.->|"NIXL KV Transfer<br/>RDMA/TCP"| OtherVLLM["Other vLLM Instances<br/><i>Disaggregated Prefill/Decode</i>"]

    APIServer -->|"HTTPS/443<br/>Bearer Token"| HFHub["HuggingFace Hub<br/><i>Model Downloads</i>"]

    Worker -->|"TCP/6379"| RayHead["Ray Head Node<br/><i>Multi-HPU Coordination</i>"]

    KServe["KServe<br/><i>ServingRuntime</i>"] -->|"deploys container"| APIServer
    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTP/8000"| APIServer

    style Platform fill:#4a90e2,color:#fff
    style ModelRunner fill:#4a90e2,color:#fff
    style Worker fill:#4a90e2,color:#fff
    style MultiModel fill:#4a90e2,color:#fff
    style APIServer fill:#4a90e2,color:#fff
    style ExtFramework fill:#4a90e2,color:#fff
    style CalibTools fill:#4a90e2,color:#fff
    style GaudiHPU fill:#7b68ee,color:#fff
    style vLLMEngine fill:#e8e8e8,stroke:#333
    style vLLMEntrypoints fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,color:#fff
    style HFHub fill:#f5a623,color:#fff
    style RayHead fill:#f5a623,color:#fff
    style OtherVLLM fill:#f5a623
    style Prometheus fill:#7ed321,color:#fff
    style Client fill:#f9f9f9,stroke:#333
