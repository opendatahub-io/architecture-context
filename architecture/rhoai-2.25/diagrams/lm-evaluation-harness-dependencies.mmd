    subgraph OptionalDeps["Optional Dependencies"]
        vLLM["vLLM<br/>(GPU inference)"]
        SGLang["SGLang<br/>(structured gen)"]
        WandBClient["wandb<br/>(experiment tracking)"]
        NLTK["NLTK 3.9.3<br/>(NLP for IFEval)"]
        aiohttp["aiohttp 3.13.3<br/>(async HTTP)"]
    end

    LMEval -.->|"GPU-optimized backend"| vLLM
    LMEval -.->|"structured generation"| SGLang
    LMEval -.->|"metric logging"| WandBClient
    LMEval -.->|"IFEval tasks"| NLTK
    LMEval -.->|"async API calls"| aiohttp

