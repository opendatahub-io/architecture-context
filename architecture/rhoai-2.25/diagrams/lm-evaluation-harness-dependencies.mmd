    subgraph MetricDeps["Metric Libraries"]
        sacrebleu["sacrebleu 2.4.3"]
        jiwer["jiwer 3.0.5"]
        mathverify["math-verify 0.8.0"]
    end

    LMEval -->|"BLEU scoring"| sacrebleu
    LMEval -->|"word error rate"| jiwer
    LMEval -->|"math verification"| mathverify

