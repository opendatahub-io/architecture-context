    subgraph CoreDeps["Core Dependencies (Required)"]
        PyTorch["PyTorch 2.6.0"]
        HFTransformers["HF Transformers 4.48.0"]
        HFDatasets["HF Datasets 3.1.0"]
        HFAccelerate["HF Accelerate 1.0.1"]
        HFEvaluate["HF Evaluate 0.4.3"]
        PEFT["PEFT 0.13.2"]
        Unitxt["Unitxt 1.17.2"]
        ScikitLearn["scikit-learn 1.5.2"]
        PyArrow["PyArrow 20.0.0"]
    end

    LMEval -->|"model inference"| PyTorch
    LMEval -->|"model loading/tokenization"| HFTransformers
    LMEval -->|"dataset loading"| HFDatasets
    LMEval -->|"multi-GPU inference"| HFAccelerate
    LMEval -->|"metric computation"| HFEvaluate
    LMEval -->|"LoRA model support"| PEFT
    LMEval -->|"data preparation"| Unitxt
    LMEval -->|"statistical metrics"| ScikitLearn
    LMEval -->|"columnar data"| PyArrow

    %% External Service Dependencies
    subgraph ExternalAPIs["External Service APIs"]
        HFHub["HuggingFace Hub<br/>huggingface.co"]
        S3["S3-compatible Storage"]
        WatsonXAPI["WatsonX AI API"]
        OpenAIAPI["OpenAI-compatible API"]
        AnthropicAPI["Anthropic API"]
        TextSynthAPI["TextSynth API"]
