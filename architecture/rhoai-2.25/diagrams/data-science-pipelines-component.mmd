graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB

        subgraph CoreServices["Core Services"]
            APIServer["API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>(no network port)"]
            SWFController["Scheduled Workflow<br/>Controller<br/>(no network port)"]
        end

        subgraph ArgoStepBinaries["Argo Workflow Step Binaries"]
            Driver["Driver<br/>(injected into Argo pods)"]
            Launcher["Launcher<br/>(injected into Argo pods)"]
        end

        subgraph CacheLayer["Cache Layer"]
            CacheServer["Cache Server<br/>443/TCP HTTPS<br/>Admission Webhook"]
        end

        APIServer -->|"gRPC cache queries"| CacheServer
        PersistenceAgent -->|"gRPC 8887<br/>persist state"| APIServer
        SWFController -->|"gRPC 8887<br/>create runs"| APIServer
        Driver -->|"gRPC 8887<br/>cache lookup"| APIServer
        Launcher -->|"gRPC 8887<br/>cache record"| APIServer
    end

    %% CRDs
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>v3.5.x"]
    MySQL["MySQL 5.7+ /<br/>PostgreSQL 12+"]
    MinIO["MinIO / S3<br/>Object Storage"]
    MLMD["ML Metadata<br/>(MLMD)"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% Internal Platform
    Dashboard["ODH Dashboard<br/>(Frontend UI)"]
    RHOAIOp["RHOAI Operator<br/>(DSP Stack)"]

    %% User
    User["Data Scientist /<br/>Client"]

    %% Flows - User
    User -->|"REST 8888"| APIServer
    Dashboard -->|"REST 8888"| APIServer

    %% CRD interactions
    SWFController -->|"watches"| ScheduledWorkflowCR
    PersistenceAgent -->|"watches"| ScheduledWorkflowCR
    APIServer -->|"creates/validates"| PipelineCR
    APIServer -->|"creates/validates"| PipelineVersionCR
    APIServer -->|"creates"| ScheduledWorkflowCR

    %% External dependency flows
    APIServer -->|"TCP 3306/5432"| MySQL
    APIServer -->|"HTTP(S) 9000/443"| MinIO
    APIServer -->|"HTTPS 6443"| K8sAPI
    APIServer -->|"creates Workflows"| ArgoWF
    Driver -->|"gRPC 8080"| MLMD
    Driver -->|"HTTPS 6443"| K8sAPI
    Launcher -->|"gRPC 8080"| MLMD
    Launcher -->|"HTTP(S) 9000/443"| MinIO
    PersistenceAgent -->|"watches Workflows"| ArgoWF
    SWFController -->|"creates Workflows"| ArgoWF
    RHOAIOp -->|"deploys"| DSP

    %% Styling
    style APIServer fill:#4a90e2,color:#fff
    style PersistenceAgent fill:#4a90e2,color:#fff
    style SWFController fill:#4a90e2,color:#fff
    style Driver fill:#5b6abf,color:#fff
    style Launcher fill:#5b6abf,color:#fff
    style CacheServer fill:#4a90e2,color:#fff
    style ScheduledWorkflowCR fill:#f5a623,color:#000
    style ViewerCR fill:#f5a623,color:#000
    style PipelineCR fill:#f5a623,color:#000
    style PipelineVersionCR fill:#f5a623,color:#000
    style ArgoWF fill:#e8e8e8,color:#000
    style MySQL fill:#e8e8e8,color:#000
    style MinIO fill:#e8e8e8,color:#000
    style MLMD fill:#e8e8e8,color:#000
    style K8sAPI fill:#e8e8e8,color:#000
    style Dashboard fill:#7ed321,color:#000
    style RHOAIOp fill:#7ed321,color:#000
