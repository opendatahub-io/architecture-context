graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>{trustyai-name}<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph OperatorNamespace["Namespace: trustyai-operator-system"]
        direction TB

        subgraph OperatorPod["Operator Controller Manager Pod"]
            Operator["TrustyAI Operator<br/>SA: controller-manager"]
            RBACProxy["Kube-RBAC-Proxy<br/>8443/TCP HTTPS<br/>TokenReview + SubjectAccessReview"]
        end

        OperatorMetrics["Metrics Service<br/>8080/TCP HTTP"]
        SecuredMetrics["Secured Metrics Service<br/>8443/TCP HTTPS"]
    end

    subgraph UserNamespace["Namespace: {user-namespace}"]
        direction TB

        subgraph TrustyAIPod["TrustyAI Service Pod"]
            TrustyAI["TrustyAI Service<br/>SA: {trustyai-name}-sa<br/>Image: trustyai-service:latest"]
        end

        TrustyAIService["Service: {trustyai-name}<br/>80/TCP HTTP → 8080"]
        TrustyAITLSService["Service: {trustyai-name}<br/>443/TCP HTTPS → 4443<br/>OpenShift cert"]
        TrustyAIMetricsService["Service: {trustyai-name}-tls<br/>443/TCP HTTPS → 8443<br/>kube-rbac-proxy"]

        InferenceService["KServe InferenceService<br/>80/443 HTTP/HTTPS<br/>mTLS (Istio)"]

        subgraph LMEvalPod["LMEvalJob Pod"]
            LMEval["LMEvalJob<br/>SA: {lmevaljob-name}-sa<br/>Image: lm-evaluation-harness-driver"]
        end

        subgraph GuardrailsPod["Guardrails Orchestrator Pod"]
            Guardrails["Guardrails Orchestrator<br/>SA: {orchestrator-name}-sa<br/>80/443 mTLS"]
        end

        PVC[("PVC Storage<br/>Filesystem<br/>No encryption")]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        PrometheusService["Prometheus<br/>8080/TCP HTTP<br/>ServiceMonitor"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database[("Database<br/>PostgreSQL/MySQL<br/>JDBC TLS verify-ca<br/>Username/Password")]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token (optional)"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+ Reencrypt| Route
    Route -->|HTTPS/443<br/>OpenShift cert<br/>mTLS| TrustyAITLSService

    %% Operator flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Operator -->|Creates/Manages| TrustyAI
    Operator -->|Creates/Manages| Guardrails
    Operator -->|Creates/Manages| LMEval
    RBACProxy -->|HTTPS/8443<br/>TLS 1.2+| SecuredMetrics

    %% TrustyAI flows
    TrustyAI -->|JDBC<br/>TLS verify-ca<br/>Username/Password| Database
    TrustyAI -->|Filesystem<br/>No auth| PVC
    InferenceService -->|HTTP/HTTPS<br/>mTLS Istio<br/>Svc Identity| TrustyAIService
    TrustyAIService -->|Routes to| TrustyAI
    PrometheusService -->|HTTP/8080<br/>Scrape /q/metrics| TrustyAI

    %% LMEval flows
    LMEval -->|HTTPS/443<br/>TLS 1.2+<br/>API Token| HuggingFace
    LMEval -->|gRPC/HTTP<br/>TLS| InferenceService

    %% Guardrails flows
    Guardrails -->|HTTP/HTTPS<br/>mTLS Istio| InferenceService
    Client -->|HTTPS/443<br/>mTLS| Guardrails

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef user fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class Operator,RBACProxy,OperatorMetrics,SecuredMetrics operator
    class TrustyAI,InferenceService,LMEval,Guardrails,TrustyAIService,TrustyAITLSService,TrustyAIMetricsService,PVC user
    class K8sAPI,PrometheusService cluster
    class Database,HuggingFace externalservice
