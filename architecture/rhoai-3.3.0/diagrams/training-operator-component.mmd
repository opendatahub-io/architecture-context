graph TB
    subgraph "Training Operator Component"
        Controller[Training Operator Controller<br/>Go Operator]

        subgraph "Framework Controllers"
            PyTorchCtl[PyTorchJob Controller<br/>Master/Worker topology]
            TFCtl[TFJob Controller<br/>Chief/Worker/PS topology]
            XGBoostCtl[XGBoostJob Controller<br/>Master/Worker topology]
            MPICtl[MPIJob Controller<br/>Launcher/Worker topology]
            JAXCtl[JAXJob Controller<br/>Distributed JAX]
            PaddleCtl[PaddleJob Controller<br/>Master/Worker topology]
        end

        Webhook[Validating Webhooks<br/>Port 9443/TCP HTTPS TLS1.2+]
        CertMgr[Cert Controller<br/>open-policy-agent/cert-controller]
        Metrics[Metrics Server<br/>Port 8080/TCP HTTP]
        Health[Health Probes<br/>Port 8081/TCP HTTP]

        Controller --> PyTorchCtl
        Controller --> TFCtl
        Controller --> XGBoostCtl
        Controller --> MPICtl
        Controller --> JAXCtl
        Controller --> PaddleCtl
        Controller --> Webhook
        Controller --> Metrics
        Controller --> Health
        CertMgr -.->|manages certs| Webhook
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        JAXJobCR[JAXJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Kubernetes Resources Created"
        Pods[Training Pods<br/>Master/Worker/PS/Launcher]
        Services[Services<br/>Pod discovery]
        ConfigMaps[ConfigMaps<br/>Job configuration]
        SAs[ServiceAccounts]
        HPAs[HorizontalPodAutoscalers<br/>Optional elastic scaling]
    end

    User[Data Scientist] -->|kubectl apply| PyTorchJobCR
    User -->|kubectl apply| TFJobCR
    User -->|kubectl apply| XGBoostJobCR
    User -->|kubectl apply| MPIJobCR
    User -->|kubectl apply| JAXJobCR
    User -->|kubectl apply| PaddleJobCR

    PyTorchJobCR -->|watched by| PyTorchCtl
    TFJobCR -->|watched by| TFCtl
    XGBoostJobCR -->|watched by| XGBoostCtl
    MPIJobCR -->|watched by| MPICtl
    JAXJobCR -->|watched by| JAXCtl
    PaddleJobCR -->|watched by| PaddleCtl

    PyTorchCtl -->|creates| Pods
    TFCtl -->|creates| Pods
    XGBoostCtl -->|creates| Pods
    MPICtl -->|creates| Pods
    JAXCtl -->|creates| Pods
    PaddleCtl -->|creates| Pods

    Controller -->|creates| Services
    Controller -->|creates| ConfigMaps
    Controller -->|creates| SAs
    Controller -->|creates| HPAs

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics scraping]
        VolcanoOpt[Volcano Scheduler<br/>Optional gang scheduling]
        SchedulerPluginsOpt[scheduler-plugins<br/>Optional gang scheduling]
    end

    Controller -->|watches/manages| K8sAPI
    Webhook -->|validates via| K8sAPI
    Prometheus -->|scrapes| Metrics
    Controller -.->|optional| VolcanoOpt
    Controller -.->|optional| SchedulerPluginsOpt

    subgraph "Training Job Communication"
        MasterPod[Master Pod<br/>Port 23456/TCP PyTorch]
        WorkerPods[Worker Pods<br/>Framework-specific]
        MasterPod <-->|TCP/UDP plaintext| WorkerPods
    end

    Pods -.->|spawns| MasterPod
    Pods -.->|spawns| WorkerPods

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style PyTorchCtl fill:#4a90e2,stroke:#333
    style TFCtl fill:#4a90e2,stroke:#333
    style XGBoostCtl fill:#4a90e2,stroke:#333
    style MPICtl fill:#4a90e2,stroke:#333
    style JAXCtl fill:#4a90e2,stroke:#333
    style PaddleCtl fill:#4a90e2,stroke:#333
