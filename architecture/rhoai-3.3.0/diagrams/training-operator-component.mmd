graph TB
    subgraph "Kubeflow Training Operator"
        Operator[Training Operator<br/>Main Controller]
        PyTorchCtrl[PyTorch Controller<br/>Master/Worker]
        TFCtrl[TensorFlow Controller<br/>Chief/Worker/PS]
        XGBoostCtrl[XGBoost Controller<br/>Master/Worker]
        MPICtrl[MPI Controller<br/>Launcher/Worker]
        JAXCtrl[JAX Controller]
        PaddleCtrl[PaddlePaddle Controller<br/>Master/Worker]
        Webhook[Validating Webhooks<br/>9443/TCP HTTPS]
        CertMgr[cert-controller<br/>TLS Cert Management]
        Metrics[Metrics Server<br/>8080/TCP HTTP]

        Operator -->|manages| PyTorchCtrl
        Operator -->|manages| TFCtrl
        Operator -->|manages| XGBoostCtrl
        Operator -->|manages| MPICtrl
        Operator -->|manages| JAXCtrl
        Operator -->|manages| PaddleCtrl
        Operator -->|exposes| Metrics
        Webhook -->|uses| CertMgr
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        JAXJob[JAXJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Kubernetes Resources"
        Pods[Training Pods]
        Services[Services]
        ConfigMaps[ConfigMaps]
        Events[Events]
        HPA[HorizontalPodAutoscaler]
    end

    User[Data Scientist] -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| XGBoostJob
    User -->|creates| MPIJob
    User -->|creates| JAXJob
    User -->|creates| PaddleJob

    PyTorchJob -->|validated by| Webhook
    TFJob -->|validated by| Webhook
    XGBoostJob -->|validated by| Webhook
    MPIJob -->|validated by| Webhook
    JAXJob -->|validated by| Webhook
    PaddleJob -->|validated by| Webhook

    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    MPIJob -->|watched by| MPICtrl
    JAXJob -->|watched by| JAXCtrl
    PaddleJob -->|watched by| PaddleCtrl

    PyTorchCtrl -->|creates| Pods
    PyTorchCtrl -->|creates| Services
    PyTorchCtrl -->|creates| ConfigMaps

    TFCtrl -->|creates| Pods
    XGBoostCtrl -->|creates| Pods
    MPICtrl -->|creates| Pods
    JAXCtrl -->|creates| Pods
    PaddleCtrl -->|creates| Pods

    Operator -->|manages| Events
    Operator -->|manages| HPA

    subgraph "Optional Gang Scheduling"
        Volcano[Volcano Scheduler<br/>PodGroups]
        SchedulerPlugins[scheduler-plugins<br/>PodGroups]
    end

    Operator -.->|optional| Volcano
    Operator -.->|optional| SchedulerPlugins

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    Operator -->|watches/creates| K8sAPI
    Metrics -->|scraped by| Prometheus

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style PyTorchCtrl fill:#4a90e2,stroke:#333
    style TFCtrl fill:#4a90e2,stroke:#333
    style XGBoostCtrl fill:#4a90e2,stroke:#333
    style MPICtrl fill:#4a90e2,stroke:#333
    style JAXCtrl fill:#4a90e2,stroke:#333
    style PaddleCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333
    style Metrics fill:#4a90e2,stroke:#333
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style JAXJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style SchedulerPlugins fill:#e8e8e8,stroke:#333
