    style TFJobCR fill:#f5a623,stroke:#333
    style XGBoostJobCR fill:#f5a623,stroke:#333
    style MPIJobCR fill:#f5a623,stroke:#333
    style JAXJobCR fill:#f5a623,stroke:#333
    style PaddleJobCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
