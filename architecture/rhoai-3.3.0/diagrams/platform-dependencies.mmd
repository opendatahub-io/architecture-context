graph LR
    subgraph "User Interface"
        Dashboard[ODH Dashboard<br/>Web UI]
    end

    subgraph "Core ML Platform"
        KServe[KServe<br/>Model Serving]
        DSP[Data Science Pipelines<br/>Kubeflow Pipelines v2]
        Notebooks[Notebooks<br/>JupyterLab/RStudio]
        ModelRegistry[Model Registry<br/>Metadata & Versioning]
        MLflow[MLflow<br/>Experiment Tracking]
        Feast[Feast<br/>Feature Store]
    end

    subgraph "Training Infrastructure"
        Trainer[Kubeflow Trainer<br/>Distributed Training]
        TrainingOp[Training Operator<br/>PyTorch/TF/JAX/MPI]
        KubeRay[KubeRay<br/>Ray Clusters]
    end

    subgraph "LLM & Governance"
        Llama[Llama Stack<br/>LLM Inference]
        TrustyAI[TrustyAI<br/>Explainability]
    end

    subgraph "Controllers"
        NotebookCtrl[odh-notebook-controller<br/>Gateway API]
        ModelCtrl[odh-model-controller<br/>Routes & Policies]
    end

    subgraph "External Platform Dependencies"
        Istio[Istio Service Mesh<br/>1.20+]
        Knative[Knative Serving<br/>1.12+]
        Argo[Argo Workflows<br/>3.5+]
        CertManager[cert-manager<br/>1.13+]
        Prometheus[Prometheus<br/>Monitoring]
        Volcano[Volcano<br/>Gang Scheduling]
        GatewayAPI[Gateway API<br/>Ingress]
        KEDA[KEDA<br/>Autoscaling]
    end

    subgraph "External Services"
        S3[S3-compatible Storage<br/>AWS/GCS/Azure]
        PostgreSQL[PostgreSQL<br/>Metadata DB]
        MySQL[MySQL<br/>Alternative DB]
        Redis[Redis<br/>Caching]
        HuggingFace[HuggingFace Hub<br/>Models/Datasets]
        NGC[NVIDIA NGC<br/>NIM Inference]
        PyPI[PyPI<br/>Package Registry]
    end

    subgraph "OpenShift Platform"
        K8sAPI[Kubernetes API<br/>6443/TCP]
        OpenShiftOAuth[OpenShift OAuth<br/>Authentication]
        OpenShiftRoutes[OpenShift Routes<br/>Ingress]
    end

    %% Dashboard dependencies
    Dashboard -->|UI management| Notebooks
    Dashboard -->|UI management| KServe
    Dashboard -->|UI management| DSP
    Dashboard -->|UI management| ModelRegistry
    Dashboard -->|UI management| MLflow
    Dashboard -->|UI management| Feast
    Dashboard -->|API calls| K8sAPI
    Dashboard -->|Auth| OpenShiftOAuth

    %% KServe dependencies
    KServe -->|traffic mgmt| Istio
    KServe -->|autoscaling| Knative
    KServe -->|extended by| ModelCtrl
    KServe -->|certificates| CertManager
    KServe -->|model storage| S3
    KServe -->|metadata| ModelRegistry
    KServe -->|features| Feast

    %% Data Science Pipelines
    DSP -->|workflow engine| Argo
    DSP -->|artifact storage| S3
    DSP -->|metadata storage| PostgreSQL
    DSP -->|metadata storage| MySQL
    DSP -->|model deployment| KServe
    DSP -->|model registry| ModelRegistry

    %% Notebooks
    Notebooks -->|submit workflows| DSP
    Notebooks -->|inference| KServe
    Notebooks -->|experiments| MLflow
    Notebooks -->|features| Feast
    Notebooks -->|model metadata| ModelRegistry
    Notebooks -->|data storage| S3
    Notebooks -->|packages| PyPI
    Notebooks -->|models| HuggingFace
    Notebooks -->|routing| NotebookCtrl

    %% Training
    Trainer -->|data/models| S3
    Trainer -->|base models| HuggingFace
    Trainer -->|metrics| MLflow
    Trainer -->|registration| ModelRegistry
    Trainer -->|gang scheduling| Volcano
    TrainingOp -->|supports| Trainer

    %% Model Registry
    ModelRegistry -->|storage| PostgreSQL
    ModelRegistry -->|storage| MySQL
    ModelRegistry -->|auth| K8sAPI

    %% MLflow
    MLflow -->|metadata| PostgreSQL
    MLflow -->|artifacts| S3
    MLflow -->|routing| GatewayAPI
    MLflow -->|auth| K8sAPI

    %% Feast
    Feast -->|online store| PostgreSQL
    Feast -->|online store| Redis
    Feast -->|offline store| S3
    Feast -->|routing| OpenShiftRoutes

    %% TrustyAI
    TrustyAI -->|monitoring| KServe
    TrustyAI -->|metrics storage| PostgreSQL
    TrustyAI -->|metrics export| Prometheus
    TrustyAI -->|eval models| HuggingFace

    %% Model Controller
    ModelCtrl -->|extends| KServe
    ModelCtrl -->|creates| OpenShiftRoutes
    ModelCtrl -->|creates| Prometheus
    ModelCtrl -->|autoscaling| KEDA
    ModelCtrl -->|NIM validation| NGC

    %% Notebook Controller
    NotebookCtrl -->|creates| GatewayAPI
    NotebookCtrl -->|manages| Notebooks
    NotebookCtrl -->|auth| K8sAPI

    %% KubeRay
    KubeRay -->|certificates| CertManager
    KubeRay -->|metrics| Prometheus
    KubeRay -->|routing| GatewayAPI

    %% Llama Stack
    Llama -->|models| HuggingFace

