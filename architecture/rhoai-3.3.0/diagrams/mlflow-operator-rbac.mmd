graph TD
    subgraph "Operator Service Accounts"
        OpSA[controller-manager<br/>ServiceAccount<br/>opendatahub or redhat-ods-applications]
    end

    subgraph "MLflow Service Accounts"
        MLflowSA[mlflow-sa<br/>ServiceAccount<br/>opendatahub or redhat-ods-applications<br/>per MLflow instance]
    end

    subgraph "Operator ClusterRole Bindings"
        OpCRB[manager-role-binding<br/>ClusterRoleBinding]
    end

    subgraph "Operator Namespace Role Bindings"
        OpNSRB[namespace-role-binding<br/>RoleBinding<br/>opendatahub or redhat-ods-applications]
        LeaderRB[leader-election-role-binding<br/>RoleBinding]
    end

    subgraph "MLflow ClusterRole Bindings"
        MLflowCRB[mlflow<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions - Operator"
        OpCR[manager-role<br/>ClusterRole]
    end

    subgraph "Namespace Role Permissions - Operator"
        OpNSRole[manager-role<br/>Role]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "ClusterRole Permissions - MLflow"
        MLflowCR[mlflow<br/>ClusterRole]
    end

    subgraph "API Resources - Operator ClusterRole"
        direction TB
        NS[Namespaces<br/>get, list, watch]
        MLflowCRD[mlflow.opendatahub.io/mlflows<br/>create, delete, get, list, patch, update, watch]
        MLflowStatus[mlflow.opendatahub.io/mlflows/status<br/>get, patch, update]
        MLflowFinalizers[mlflow.opendatahub.io/mlflows/finalizers<br/>update]
        RBAC[rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create, delete, get, list, patch, update, watch]
        ConsoleLinks[console.openshift.io/consolelinks<br/>create, delete, get, list, patch, update, watch]
        HTTPRoutes[gateway.networking.k8s.io/httproutes<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Operator Namespace Role"
        direction TB
        PVCs[PersistentVolumeClaims<br/>create, delete, get, list, patch, update, watch]
        Secrets[Secrets<br/>create, delete, get, list, patch, update, watch]
        SvcAccts[ServiceAccounts<br/>create, delete, get, list, patch, update, watch]
        Services[Services<br/>create, delete, get, list, patch, update, watch]
        Deployments[apps/Deployments<br/>create, delete, get, list, patch, update, watch]
        NetPolicies[networking.k8s.io/NetworkPolicies<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - MLflow ClusterRole"
        direction TB
        NSMLflow[Namespaces<br/>get, list, watch]
    end

    %% Service Account Bindings
    OpSA -->|bound via| OpCRB
    OpSA -->|bound via| OpNSRB
    OpSA -->|bound via| LeaderRB
    MLflowSA -->|bound via| MLflowCRB

    %% Role Bindings to Roles
    OpCRB -->|grants| OpCR
    OpNSRB -->|grants| OpNSRole
    LeaderRB -->|grants| LeaderRole
    MLflowCRB -->|grants| MLflowCR

    %% ClusterRole Permissions
    OpCR -->|manages| NS
    OpCR -->|manages| MLflowCRD
    OpCR -->|manages| MLflowStatus
    OpCR -->|manages| MLflowFinalizers
    OpCR -->|manages| RBAC
    OpCR -->|manages| ConsoleLinks
    OpCR -->|manages| HTTPRoutes

    %% Namespace Role Permissions
    OpNSRole -->|manages| PVCs
    OpNSRole -->|manages| Secrets
    OpNSRole -->|manages| SvcAccts
    OpNSRole -->|manages| Services
    OpNSRole -->|manages| Deployments
    OpNSRole -->|manages| NetPolicies

    %% MLflow ClusterRole Permissions
    MLflowCR -->|reads| NSMLflow

    %% Styling
    style OpSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MLflowSA fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style OpCRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style OpNSRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style LeaderRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style MLflowCRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style OpCR fill:#d0021b,stroke:#333,stroke-width:2px,color:#fff
    style OpNSRole fill:#d0021b,stroke:#333,stroke-width:2px,color:#fff
    style LeaderRole fill:#d0021b,stroke:#333,stroke-width:2px,color:#fff
    style MLflowCR fill:#d0021b,stroke:#333,stroke-width:2px,color:#fff

    style NS fill:#e8e8e8,stroke:#333,stroke-width:1px
    style MLflowCRD fill:#e8e8e8,stroke:#333,stroke-width:1px
    style MLflowStatus fill:#e8e8e8,stroke:#333,stroke-width:1px
    style MLflowFinalizers fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RBAC fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ConsoleLinks fill:#e8e8e8,stroke:#333,stroke-width:1px
    style HTTPRoutes fill:#e8e8e8,stroke:#333,stroke-width:1px
    style PVCs fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Secrets fill:#e8e8e8,stroke:#333,stroke-width:1px
    style SvcAccts fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Services fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Deployments fill:#e8e8e8,stroke:#333,stroke-width:1px
    style NetPolicies fill:#e8e8e8,stroke:#333,stroke-width:1px
    style NSMLflow fill:#e8e8e8,stroke:#333,stroke-width:1px
