graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op[controller-manager<br/>Namespace: opendatahub OR<br/>redhat-ods-applications]
        SA_MLflow[mlflow-sa<br/>Namespace: opendatahub OR<br/>redhat-ods-applications<br/>per MLflow instance]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager[manager-role<br/>Operator ClusterRole]
        CR_MLflow[mlflow<br/>MLflow Server ClusterRole]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        R_Manager[manager-role<br/>Operator Namespace Role<br/>Namespace: opendatahub OR<br/>redhat-ods-applications]
        R_Leader[leader-election-role<br/>Leader Election Role]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Manager[manager-role-binding]
        CRB_MLflow[mlflow<br/>per instance]
    end

    subgraph RoleBindings["RoleBindings"]
        RB_Namespace[namespace-role-binding]
        RB_Leader[leader-election-role-binding]
    end

    subgraph ClusterResources["Cluster-Scoped API Resources"]
        direction TB
        API_NS[namespaces<br/>core/v1]
        API_MLflow[mlflows<br/>mlflow.opendatahub.io/v1]
        API_CR[clusterroles<br/>rbac.authorization.k8s.io]
        API_CRB[clusterrolebindings<br/>rbac.authorization.k8s.io]
        API_CL[consolelinks<br/>console.openshift.io]
        API_HTTPRoute[httproutes<br/>gateway.networking.k8s.io]
    end

    subgraph NamespaceResources["Namespace-Scoped API Resources"]
        direction TB
        API_PVC[persistentvolumeclaims<br/>core/v1]
        API_Secret[secrets<br/>core/v1]
        API_SA[serviceaccounts<br/>core/v1]
        API_Svc[services<br/>core/v1]
        API_Deploy[deployments<br/>apps/v1]
        API_NetPol[networkpolicies<br/>networking.k8s.io]
    end

    %% Operator ServiceAccount Bindings
    SA_Op -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_Op -->|bound via| RB_Namespace
    RB_Namespace -->|grants| R_Manager

    SA_Op -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% MLflow ServiceAccount Bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow

    %% Operator ClusterRole Permissions
    CR_Manager -->|get, list, watch| API_NS
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_MLflow
    CR_Manager -->|get, patch, update| API_MLflow
    CR_Manager -->|update| API_MLflow
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_CR
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_CRB
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_CL
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_HTTPRoute

    %% Operator Namespace Role Permissions
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_PVC
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_Secret
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_SA
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_Svc
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_Deploy
    R_Manager -->|create, delete, get, list,<br/>patch, update, watch| API_NetPol

    %% MLflow Server ClusterRole Permissions
    CR_MLflow -->|get, list, watch| API_NS

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_MLflow fill:#4a90e2,stroke:#333,stroke-width:2px

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_MLflow fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB_Manager fill:#bd10e0,stroke:#333,stroke-width:2px
    style CRB_MLflow fill:#bd10e0,stroke:#333,stroke-width:2px
    style RB_Namespace fill:#bd10e0,stroke:#333,stroke-width:2px
    style RB_Leader fill:#bd10e0,stroke:#333,stroke-width:2px

    style API_NS fill:#7ed321,stroke:#333,stroke-width:1px
    style API_MLflow fill:#7ed321,stroke:#333,stroke-width:1px
    style API_CR fill:#7ed321,stroke:#333,stroke-width:1px
    style API_CRB fill:#7ed321,stroke:#333,stroke-width:1px
    style API_CL fill:#7ed321,stroke:#333,stroke-width:1px
    style API_HTTPRoute fill:#7ed321,stroke:#333,stroke-width:1px

    style API_PVC fill:#50e3c2,stroke:#333,stroke-width:1px
    style API_Secret fill:#50e3c2,stroke:#333,stroke-width:1px
    style API_SA fill:#50e3c2,stroke:#333,stroke-width:1px
    style API_Svc fill:#50e3c2,stroke:#333,stroke-width:1px
    style API_Deploy fill:#50e3c2,stroke:#333,stroke-width:1px
    style API_NetPol fill:#50e3c2,stroke:#333,stroke-width:1px

    %% Notes
    subgraph Notes[" "]
        direction TB
        Note1["🔵 Service Accounts"]
        Note2["🟠 Roles (ClusterRole/Role)"]
        Note3["🟣 Bindings (ClusterRoleBinding/RoleBinding)"]
        Note4["🟢 Cluster-scoped API Resources"]
        Note5["🔷 Namespace-scoped API Resources"]
    end

    style Notes fill:#f5f5f5,stroke:#ccc,stroke-width:1px
