graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-operator]
    end

    subgraph "ClusterRole Binding"
        CRB[opendatahub-operator-manager<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[opendatahub-operator-manager<br/>⚠️ Cluster-admin level permissions]
    end

    subgraph "ODH/RHOAI CRD Permissions"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
        CompCRDs[components.platform.opendatahub.io<br/>Dashboard, Workbenches, Kserve,<br/>Ray, ModelRegistry, etc.]
        SvcCRDs[services.platform.opendatahub.io<br/>Monitoring, Auth, GatewayConfig]
        InfraCRDs[infrastructure.opendatahub.io<br/>HardwareProfile]
    end

    subgraph "Core K8s Resources"
        CoreRes[Core API<br/>Deployments, Services, ConfigMaps,<br/>Secrets, ServiceAccounts, Pods, PVCs]
        RBAC[rbac.authorization.k8s.io<br/>Roles, RoleBindings,<br/>ClusterRoles, ClusterRoleBindings<br/>⚠️ ALL VERBS - wildcard]
        Net[networking.k8s.io<br/>NetworkPolicies, Ingresses]
        AdmReg[admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations,<br/>MutatingWebhookConfigurations]
        APIExt[apiextensions.k8s.io<br/>CustomResourceDefinitions]
    end

    subgraph "OpenShift Resources"
        Routes[route.openshift.io<br/>Routes]
        Users[user.openshift.io<br/>Users, Groups]
        Console[console.openshift.io<br/>ConsoleLinks]
        OAuth[oauth.openshift.io<br/>OAuthClients]
        SCC[security.openshift.io<br/>SecurityContextConstraints<br/>⚠️ Includes 'use' verb]
    end

    subgraph "Monitoring Resources"
        MonRes[monitoring.coreos.com<br/>ServiceMonitors, PrometheusRules,<br/>Prometheuses, AlertManagers]
    end

    subgraph "OLM Resources"
        OLM[operators.coreos.com<br/>Subscriptions, ClusterServiceVersions,<br/>CatalogSources]
    end

    subgraph "Component Operator CRDs"
        KServeRes[serving.kserve.io<br/>InferenceServices, ServingRuntimes,<br/>ClusterServingRuntimes]
        RayRes[ray.io<br/>RayClusters, RayServices, RayJobs]
        ArgoRes[argoproj.io<br/>Workflows]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR

