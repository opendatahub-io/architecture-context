graph TD
    subgraph "Service Account"
        SA[kubeflow-trainer-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kubeflow-trainer-controller-manager<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[kubeflow-trainer-controller-manager<br/>ClusterRole]
    end

    subgraph "API Resources - trainer.kubeflow.org"
        TrainJob[TrainJob<br/>trainjobs]
        TrainingRuntime[TrainingRuntime<br/>trainingruntimes]
        ClusterTrainingRuntime[ClusterTrainingRuntime<br/>clustertrainingruntimes]
        TrainJobStatus[TrainJob Status<br/>trainjobs/status]
        Finalizers[Finalizers<br/>trainjobs/finalizers<br/>trainingruntimes/finalizers<br/>clustertrainingruntimes/finalizers]
    end

    subgraph "API Resources - jobset.x-k8s.io"
        JobSets[JobSet<br/>jobsets]
    end

    subgraph "API Resources - scheduling"
        PodGroups[PodGroup<br/>scheduling.volcano.sh<br/>scheduling.x-k8s.io]
    end

    subgraph "API Resources - networking.k8s.io (RHOAI)"
        NetworkPolicies[NetworkPolicy<br/>networkpolicies]
    end

    subgraph "API Resources - core"
        ConfigMaps[ConfigMap<br/>configmaps]
        Secrets[Secret<br/>secrets]
        Events[Event<br/>events]
        Pods[Pod<br/>pods<br/>RHOAI: get, list only]
        LimitRanges[LimitRange<br/>limitranges]
    end

    subgraph "API Resources - Other"
        Webhooks[ValidatingWebhookConfiguration<br/>admissionregistration.k8s.io]
        Leases[Lease<br/>coordination.k8s.io]
        RuntimeClasses[RuntimeClass<br/>node.k8s.io]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - trainer.kubeflow.org
    CR -->|get, list, watch, patch, update| TrainJob
    CR -->|get, list, watch, patch, update| TrainingRuntime
    CR -->|get, list, watch, patch, update| ClusterTrainingRuntime
    CR -->|get, patch, update| TrainJobStatus
    CR -->|get, patch, update| Finalizers

    %% Permissions - jobset
    CR -->|create, get, list, patch, update, watch| JobSets

    %% Permissions - scheduling
    CR -->|create, get, list, patch, update, watch| PodGroups

    %% Permissions - networking (RHOAI)
    CR -->|get, list, watch, create, update, patch| NetworkPolicies

    %% Permissions - core
    CR -->|create, get, list, patch, update, watch| ConfigMaps
    CR -->|create, get, list, patch, update, watch| Secrets
    CR -->|create, patch, update, watch| Events
    CR -->|get, list| Pods
    CR -->|get, list, watch| LimitRanges

    %% Permissions - other
    CR -->|get, list, update, watch| Webhooks
    CR -->|create, get, list, update| Leases
    CR -->|get, list, watch| RuntimeClasses

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainJob fill:#7ed321,stroke:#333,stroke-width:2px
    style TrainingRuntime fill:#7ed321,stroke:#333,stroke-width:2px
    style ClusterTrainingRuntime fill:#7ed321,stroke:#333,stroke-width:2px
    style TrainJobStatus fill:#7ed321,stroke:#333,stroke-width:2px
    style Finalizers fill:#7ed321,stroke:#333,stroke-width:2px
    style JobSets fill:#dae8fc,stroke:#333,stroke-width:2px
    style PodGroups fill:#dae8fc,stroke:#333,stroke-width:2px
    style NetworkPolicies fill:#f8cecc,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#dae8fc,stroke:#333,stroke-width:2px
    style Secrets fill:#f8cecc,stroke:#333,stroke-width:2px
    style Events fill:#dae8fc,stroke:#333,stroke-width:2px
    style Pods fill:#dae8fc,stroke:#333,stroke-width:2px
    style LimitRanges fill:#dae8fc,stroke:#333,stroke-width:2px
