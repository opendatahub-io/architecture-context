graph TD
    subgraph "Service Account"
        SA[kubeflow-trainer-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kubeflow-trainer-controller-manager<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRole Permissions"
        CR[kubeflow-trainer-controller-manager]
    end

    subgraph "Core API Resources"
        ConfigMaps[ConfigMaps, Secrets<br/>create, get, list, patch, update, watch]
        Events[Events<br/>create, patch, update, watch]
        LimitRanges[LimitRanges<br/>get, list, watch]
        Pods[Pods RHOAI<br/>get, list]
    end

    subgraph "Admission Registration"
        ValidatingWebhooks[ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io<br/>get, list, update, watch]
    end

    subgraph "Coordination"
        Leases[Leases<br/>coordination.k8s.io<br/>create, get, list, update]
    end

    subgraph "JobSet API"
        JobSets[JobSets<br/>jobset.x-k8s.io<br/>create, get, list, patch, update, watch]
    end

    subgraph "Node API"
        RuntimeClasses[RuntimeClasses<br/>node.k8s.io<br/>get, list, watch]
    end

    subgraph "Scheduling API"
        PodGroups[PodGroups<br/>scheduling.volcano.sh<br/>scheduling.x-k8s.io<br/>create, get, list, patch, update, watch]
    end

    subgraph "Trainer CRDs"
        TrainJobs[TrainJobs<br/>trainer.kubeflow.org<br/>get, list, patch, update, watch]
        TrainingRuntimes[TrainingRuntimes<br/>trainer.kubeflow.org<br/>get, list, patch, update, watch]
        ClusterTrainingRuntimes[ClusterTrainingRuntimes<br/>trainer.kubeflow.org<br/>get, list, patch, update, watch]
        TrainJobStatus[TrainJobs/status<br/>trainer.kubeflow.org<br/>get, patch, update]
        Finalizers[*/finalizers<br/>trainer.kubeflow.org<br/>get, patch, update]
    end

    subgraph "Network Policies (RHOAI)"
        NetworkPolicies[NetworkPolicies<br/>networking.k8s.io<br/>get, list, watch, create, update, patch]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Events
    CR -->|permissions| LimitRanges
    CR -->|permissions RHOAI| Pods

    CR -->|permissions| ValidatingWebhooks
    CR -->|permissions| Leases
    CR -->|permissions| JobSets
    CR -->|permissions| RuntimeClasses
    CR -->|permissions| PodGroups

    CR -->|permissions| TrainJobs
    CR -->|permissions| TrainingRuntimes
    CR -->|permissions| ClusterTrainingRuntimes
    CR -->|permissions| TrainJobStatus
    CR -->|permissions| Finalizers

    CR -->|permissions RHOAI| NetworkPolicies

    %% Use cases
    subgraph UseCases["Primary Use Cases"]
        UC1[Watch TrainJob CRDs<br/>Create JobSets]
        UC2[Manage training lifecycle<br/>Update status]
        UC3[Poll training pod metrics<br/>RHOAI progression tracking]
        UC4[Create NetworkPolicies<br/>RHOAI pod isolation]
        UC5[Manage webhook configuration<br/>Validate TrainJobs]
    end

    TrainJobs -.->|enables| UC1
    JobSets -.->|enables| UC1
    TrainJobStatus -.->|enables| UC2
    Pods -.->|enables| UC3
    NetworkPolicies -.->|enables| UC4
    ValidatingWebhooks -.->|enables| UC5

