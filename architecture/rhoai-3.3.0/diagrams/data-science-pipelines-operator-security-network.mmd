graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist / Notebook<br/>External Client]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        RouteMLMD["OpenShift Route<br/>ds-pipeline-md-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        RouteMinio["OpenShift Route<br/>minio-{name} (dev only)<br/>443/TCP<br/>TLS 1.2+ Edge"]
    end

    subgraph APILayer["API LAYER (Namespace-Scoped)"]
        direction TB

        OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>TLS service-cert<br/>Secret: ds-pipelines-proxy-tls"]

        APIServer["DS Pipeline API Server<br/>SA: ds-pipeline-{name}<br/>Ports:<br/>- 8888/TCP HTTP (Bearer Token)<br/>- 8887/TCP gRPC (Bearer Token)<br/>NetworkPolicy: ds-pipelines-{name}"]

        OAuthMLMD["OAuth Proxy (MLMD)<br/>8443/TCP HTTPS<br/>TLS service-cert<br/>Secret: ds-pipelines-envoy-proxy-tls"]

        EnvoyProxy["ML Metadata Envoy Proxy<br/>9090/TCP gRPC/HTTP2<br/>Optional mTLS<br/>NetworkPolicy: ds-pipelines-envoy"]
    end

    subgraph Controllers["CONTROLLERS (Namespace-Scoped)"]
        direction TB

        PersAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}<br/>Watches Workflows → DB"]

        Scheduler["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-{name}<br/>Manages recurring runs"]

        ArgoCtrl["Argo Workflow Controller<br/>SA: ds-pipeline-argo-{name}<br/>Namespace-scoped<br/>Creates workflow pods"]
    end

    subgraph Storage["STORAGE (Optional Dev/Test)"]
        direction TB

        MariaDB["MariaDB<br/>3306/TCP MySQL<br/>Optional TLS<br/>Secret: ds-pipelines-mariadb-tls<br/>Secret: {custom-db-secret}<br/>NetworkPolicy: mariadb-{name}<br/>Ingress: API, MLMD, PersAgent"]

        Minio["Minio<br/>Ports: 9000/TCP, 80/TCP<br/>S3-compatible<br/>Auth: AccessKey/SecretKey<br/>Secret: {custom-storage-secret}"]
    end

    subgraph MLMD["ML METADATA (Optional)"]
        MLMDgRPC["ML Metadata gRPC<br/>8080/TCP gRPC<br/>Optional mTLS<br/>Secret: ds-pipeline-metadata-grpc-tls-certs<br/>NetworkPolicy: ds-pipeline-metadata-grpc<br/>Ingress: v2_components, DSP"]
    end

    subgraph Execution["PIPELINE EXECUTION"]
        WorkflowPods["Argo Workflow Pods<br/>SA: pipeline-runner-{name}<br/>Ephemeral task executors<br/>NetworkPolicy: Egress to API, Storage, MLMD"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        ExtS3["External S3 Storage<br/>AWS/Compatible<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM or Access Keys"]

        ExtDB["External MySQL/MariaDB<br/>3306/TCP MySQL<br/>Optional TLS<br/>Auth: Username/Password"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]

        Registry["Image Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Pull Secrets"]
    end

    subgraph ODH["ODH INTEGRATION"]
        Dashboard["ODH Dashboard<br/>Pipeline UI"]
        Workbenches["Workbenches/Notebooks<br/>KFP SDK clients"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| RouteMLMD
    Client -.->|HTTPS/443<br/>TLS 1.2+ Edge<br/>dev only| RouteMinio

    %% Ingress to API Layer
    Route -->|HTTPS/8443<br/>TLS service-cert<br/>OAuth validation| OAuthProxy
    RouteMLMD -->|HTTPS/8443<br/>TLS service-cert<br/>OAuth validation| OAuthMLMD

    OAuthProxy -->|HTTP/8888 or gRPC/8887<br/>Optional mTLS<br/>Bearer Token| APIServer
    OAuthMLMD -->|gRPC/9090<br/>Optional mTLS<br/>OAuth Proxy| EnvoyProxy

    %% API to Storage
    APIServer -->|MySQL/3306<br/>Optional TLS<br/>Username/Password| MariaDB
    APIServer -->|MySQL/3306<br/>Optional TLS<br/>Username/Password| ExtDB
    APIServer -->|HTTP/9000<br/>AccessKey/SecretKey| Minio
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM or Keys| ExtS3

    %% API to K8s
    APIServer -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create Workflows| K8sAPI
    PersAgent -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch Workflows| K8sAPI
    Scheduler -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create Workflows| K8sAPI
    ArgoCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create Pods| K8sAPI

    %% Controllers to Storage
    PersAgent -->|MySQL/3306<br/>Optional TLS<br/>Username/Password| MariaDB
    PersAgent -->|MySQL/3306<br/>Optional TLS| ExtDB

    %% Argo creates workflow pods
    ArgoCtrl -->|Creates & manages| WorkflowPods

    %% Workflow pods interactions
    WorkflowPods -->|gRPC/8887<br/>Optional mTLS<br/>ServiceAccount Token| APIServer
    WorkflowPods -->|HTTP/9000<br/>AccessKey/SecretKey| Minio
    WorkflowPods -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM or Keys| ExtS3
    WorkflowPods -->|gRPC/8080<br/>Optional mTLS| MLMDgRPC
    WorkflowPods -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry

    %% MLMD relationships
    EnvoyProxy -->|gRPC/8080<br/>Optional mTLS| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>Optional TLS<br/>Username/Password| MariaDB
    MLMDgRPC -->|MySQL/3306<br/>Optional TLS| ExtDB

    %% ODH Integration
    Dashboard -->|HTTPS/443<br/>OAuth Token| Route
    Workbenches -->|HTTPS/443<br/>OAuth Token<br/>KFP SDK| Route

    %% Minio route (dev only)
    RouteMinio -.->|HTTP/9000 or 80| Minio

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef api fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef execution fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef odh fill:#d4edda,stroke:#7ec699,stroke-width:2px

    class Client external
    class Route,RouteMLMD,RouteMinio ingress
    class OAuthProxy,APIServer,OAuthMLMD,EnvoyProxy api
    class PersAgent,Scheduler,ArgoCtrl controller
    class MariaDB,Minio storage
    class MLMDgRPC storage
    class WorkflowPods execution
    class ExtS3,ExtDB,K8sAPI,Registry externalservice
    class Dashboard,Workbenches odh
