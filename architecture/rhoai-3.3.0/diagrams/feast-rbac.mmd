graph TD
    subgraph "Service Accounts"
        SA_Manager[controller-manager<br/>feast-operator-system namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-role-binding]
        CRB_Leader[leader-election-role-binding]
        CRB_Metrics[metrics-auth-role-binding]
    end

    subgraph "ClusterRoles & Roles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Editor[featurestore-editor-role<br/>ClusterRole]
        CR_Viewer[featurestore-viewer-role<br/>ClusterRole]
        R_Leader[leader-election-role<br/>Role]
        CR_Metrics[metrics-auth-role<br/>ClusterRole]
    end

    subgraph "Feast API Resources"
        FS_CRD[feast.dev/featurestores<br/>Custom Resource]
        FS_Status[feast.dev/featurestores/status]
        FS_Finalizers[feast.dev/featurestores/finalizers]
    end

    subgraph "Core Kubernetes Resources"
        Apps_Deploy[apps/deployments]
        Core_Services[core/services]
        Core_CM[core/configmaps]
        Core_PVC[core/persistentvolumeclaims]
        Core_SA[core/serviceaccounts]
        Core_Secrets[core/secrets]
        Core_Pods[core/pods]
        Core_Namespaces[core/namespaces]
        Core_PodExec[core/pods/exec]
        Batch_CronJobs[batch/cronjobs]
    end

    subgraph "RBAC & Auth Resources"
        RBAC_Roles[rbac.authorization.k8s.io/roles]
        RBAC_RoleBindings[rbac.authorization.k8s.io/rolebindings]
        RBAC_ClusterRoles[rbac.authorization.k8s.io/clusterroles]
        RBAC_ClusterRoleBindings[rbac.authorization.k8s.io/clusterrolebindings]
        RBAC_SAR[rbac.authorization.k8s.io/subjectaccessreviews]
        Auth_TokenReviews[authentication.k8s.io/tokenreviews]
    end

    subgraph "OpenShift & ODH Resources"
        Route_Routes[route.openshift.io/routes]
        Kubeflow_Notebooks[kubeflow.org/notebooks]
        CRD_List[apiextensions.k8s.io/customresourcedefinitions]
    end

    subgraph "Leader Election Resources"
        Coord_Leases[coordination.k8s.io/leases]
        Core_CM_Leader[core/configmaps<br/>for leader election]
    end

    %% Service Account to Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Leader
    SA_Manager -->|bound via| CRB_Metrics

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| R_Leader
    CRB_Metrics -->|grants| CR_Metrics

    %% manager-role permissions
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| FS_CRD
    CR_Manager -->|get, update, patch| FS_Status
    CR_Manager -->|update| FS_Finalizers

    CR_Manager -->|get, list, watch,<br/>create, update, delete| Apps_Deploy
    CR_Manager -->|get, list, watch,<br/>create, update, delete| Core_Services
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| Core_CM
    CR_Manager -->|get, list, watch,<br/>create, update, delete| Core_PVC
    CR_Manager -->|get, list, watch,<br/>create, update, delete| Core_SA
    CR_Manager -->|get, list, watch| Core_Secrets
    CR_Manager -->|get, list, watch| Core_Pods
    CR_Manager -->|get, list, watch| Core_Namespaces
    CR_Manager -->|create| Core_PodExec
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| Batch_CronJobs

    CR_Manager -->|get, list, watch,<br/>create, update, delete| RBAC_Roles
    CR_Manager -->|get, list, watch,<br/>create, update, delete| RBAC_RoleBindings
    CR_Manager -->|get, list, watch,<br/>create, update, delete| RBAC_ClusterRoles
    CR_Manager -->|get, list, watch,<br/>create, update, delete| RBAC_ClusterRoleBindings
    CR_Manager -->|create| RBAC_SAR
    CR_Manager -->|create| Auth_TokenReviews

    CR_Manager -->|get, list, watch,<br/>create, update, delete| Route_Routes
    CR_Manager -->|get, list, watch| Kubeflow_Notebooks
    CR_Manager -->|get, list| CRD_List

    %% editor-role permissions
    CR_Editor -->|get, list, watch,<br/>create, update,<br/>patch, delete| FS_CRD

    %% viewer-role permissions
    CR_Viewer -->|get, list, watch| FS_CRD

    %% leader-election-role permissions
    R_Leader -->|get, list, watch,<br/>create, update,<br/>patch, delete| Core_CM_Leader
    R_Leader -->|get, list, watch,<br/>create, update,<br/>patch, delete| Coord_Leases

    %% metrics-auth-role permissions
    CR_Metrics -->|create| Auth_TokenReviews
    CR_Metrics -->|create| RBAC_SAR

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef resource fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    classDef feastresource fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    class SA_Manager serviceaccount
    class CRB_Manager,CRB_Leader,CRB_Metrics binding
    class CR_Manager,CR_Editor,CR_Viewer,R_Leader,CR_Metrics role
    class FS_CRD,FS_Status,FS_Finalizers feastresource
    class Apps_Deploy,Core_Services,Core_CM,Core_PVC,Core_SA,Core_Secrets,Core_Pods,Core_Namespaces,Core_PodExec,Batch_CronJobs,RBAC_Roles,RBAC_RoleBindings,RBAC_ClusterRoles,RBAC_ClusterRoleBindings,RBAC_SAR,Auth_TokenReviews,Route_Routes,Kubeflow_Notebooks,CRD_List,Coord_Leases,Core_CM_Leader resource
