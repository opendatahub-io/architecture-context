graph TD
    subgraph "Service Accounts"
        SA_Operator[controller-manager<br/>feast-operator-system]
        SA_Online["(name)-online<br/>(user-namespace)"]
        SA_Offline["(name)-offline<br/>(user-namespace)"]
        SA_Registry["(name)-registry<br/>(user-namespace)"]
        SA_UI["(name)-ui<br/>(user-namespace)"]
        SA_Cron["(name)-cronjob<br/>(user-namespace)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-role-binding]
        CRB_Leader[leader-election-role-binding]
        CRB_Metrics[metrics-auth-role-binding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Editor[featurestore-editor-role]
        CR_Viewer[featurestore-viewer-role]
        CR_Leader[leader-election-role]
        CR_Metrics[metrics-auth-role]
    end

    subgraph "API Resources - feast.dev"
        API_FS[FeatureStore<br/>feast.dev/v1]
        API_FS_Status[FeatureStore/status]
        API_FS_Final[FeatureStore/finalizers]
    end

    subgraph "API Resources - Core"
        API_Deploy[Deployments<br/>apps/v1]
        API_Svc[Services<br/>v1]
        API_CM[ConfigMaps<br/>v1]
        API_PVC[PersistentVolumeClaims<br/>v1]
        API_SA[ServiceAccounts<br/>v1]
        API_Secrets[Secrets<br/>v1]
        API_Pods[Pods<br/>v1]
        API_NS[Namespaces<br/>v1]
    end

    subgraph "API Resources - Batch"
        API_Cron[CronJobs<br/>batch/v1]
    end

    subgraph "API Resources - RBAC"
        API_Roles[Roles/RoleBindings<br/>rbac.authorization.k8s.io]
        API_CRoles[ClusterRoles/ClusterRoleBindings<br/>rbac.authorization.k8s.io]
        API_SAR[SubjectAccessReviews<br/>authorization.k8s.io]
        API_TR[TokenReviews<br/>authentication.k8s.io]
    end

    subgraph "API Resources - OpenShift"
        API_Routes[Routes<br/>route.openshift.io/v1]
    end

    subgraph "API Resources - Kubeflow"
        API_Notebooks[Notebooks<br/>kubeflow.org]
    end

    %% Service Account to ClusterRoleBindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Leader
    SA_Operator -->|bound via| CRB_Metrics

    %% ClusterRoleBindings to ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Metrics -->|grants| CR_Metrics

    %% manager-role permissions
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_FS
    CR_Manager -->|get,update,patch| API_FS_Status
    CR_Manager -->|update| API_FS_Final
    CR_Manager -->|get,list,watch,create,update,delete| API_Deploy
    CR_Manager -->|get,list,watch,create,update,delete| API_Svc
    CR_Manager -->|get,list,watch,create,update,delete,patch| API_CM
    CR_Manager -->|get,list,watch,create,update,delete| API_PVC
    CR_Manager -->|get,list,watch,create,update,delete| API_SA
    CR_Manager -->|get,list,watch| API_Secrets
    CR_Manager -->|get,list,watch| API_Pods
    CR_Manager -->|get,list,watch| API_NS
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Cron
    CR_Manager -->|get,list,watch,create,update,delete| API_Roles
    CR_Manager -->|get,list,watch,create,update,delete| API_CRoles
    CR_Manager -->|create| API_SAR
    CR_Manager -->|create| API_TR
    CR_Manager -->|get,list,watch,create,update,delete| API_Routes
    CR_Manager -->|get,list,watch| API_Notebooks

    %% featurestore-editor-role permissions
    CR_Editor -->|get,list,watch,create,update,patch,delete| API_FS

    %% featurestore-viewer-role permissions
    CR_Viewer -->|get,list,watch| API_FS

    %% leader-election-role permissions
    CR_Leader -->|get,list,watch,create,update,patch,delete| API_CM
    CR_Leader -->|get,list,watch,create,update,patch,delete| API_Leases[Leases<br/>coordination.k8s.io]

    %% metrics-auth-role permissions
    CR_Metrics -->|create| API_TR
    CR_Metrics -->|create| API_SAR

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Online fill:#7ed321,stroke:#333,color:#fff
    style SA_Offline fill:#7ed321,stroke:#333,color:#fff
    style SA_Registry fill:#7ed321,stroke:#333,color:#fff
    style SA_UI fill:#7ed321,stroke:#333,color:#fff
    style SA_Cron fill:#7ed321,stroke:#333,color:#fff

    style CRB_Manager fill:#f5a623,stroke:#333,color:#fff
    style CRB_Leader fill:#f5a623,stroke:#333,color:#fff
    style CRB_Metrics fill:#f5a623,stroke:#333,color:#fff

    style CR_Manager fill:#e74c3c,stroke:#333,color:#fff
    style CR_Editor fill:#e74c3c,stroke:#333,color:#fff
    style CR_Viewer fill:#e74c3c,stroke:#333,color:#fff
    style CR_Leader fill:#e74c3c,stroke:#333,color:#fff
    style CR_Metrics fill:#e74c3c,stroke:#333,color:#fff

    style API_FS fill:#9b59b6,stroke:#333,color:#fff
    style API_FS_Status fill:#9b59b6,stroke:#333,color:#fff
    style API_FS_Final fill:#9b59b6,stroke:#333,color:#fff

    style API_Deploy fill:#3498db,stroke:#333,color:#fff
    style API_Svc fill:#3498db,stroke:#333,color:#fff
    style API_CM fill:#3498db,stroke:#333,color:#fff
    style API_PVC fill:#3498db,stroke:#333,color:#fff
    style API_SA fill:#3498db,stroke:#333,color:#fff
    style API_Secrets fill:#3498db,stroke:#333,color:#fff
    style API_Pods fill:#3498db,stroke:#333,color:#fff
    style API_NS fill:#3498db,stroke:#333,color:#fff

    style API_Cron fill:#16a085,stroke:#333,color:#fff

    style API_Roles fill:#d35400,stroke:#333,color:#fff
    style API_CRoles fill:#d35400,stroke:#333,color:#fff
    style API_SAR fill:#d35400,stroke:#333,color:#fff
    style API_TR fill:#d35400,stroke:#333,color:#fff
    style API_Leases fill:#d35400,stroke:#333,color:#fff

    style API_Routes fill:#c0392b,stroke:#333,color:#fff

    style API_Notebooks fill:#8e44ad,stroke:#333,color:#fff
