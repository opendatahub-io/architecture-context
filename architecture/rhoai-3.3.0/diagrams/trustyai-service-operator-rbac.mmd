graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>Namespace: trustyai-operator-system]
    end

    subgraph "ClusterRole Bindings"
        MCRB[manager-rolebinding<br/>ClusterRoleBinding]
        PCRB[proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        LERB[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: trustyai-operator-system]
    end

    subgraph "ClusterRoles"
        MCR[manager-role<br/>ClusterRole]
        PCR[proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        LER[leader-election-role<br/>Role<br/>Namespace: trustyai-operator-system]
    end

    subgraph "Core Resources"
        CoreResources["ConfigMaps, PVCs, Pods<br/>Secrets, ServiceAccounts, Services<br/>Events, PersistentVolumes<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Apps Resources"
        AppsResources["Deployments<br/>Deployments/finalizers<br/>Deployments/status<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "KServe Resources"
        KServeResources["InferenceServices<br/>InferenceServices/finalizers<br/>ServingRuntimes<br/>Verbs: get, list, patch, update, watch"]
    end

    subgraph "Istio Resources"
        IstioResources["VirtualServices<br/>DestinationRules<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "OpenShift Resources"
        RouteResources["Routes<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Prometheus Resources"
        PrometheusResources["ServiceMonitors<br/>Verbs: create, list, watch"]
    end

    subgraph "Kueue Resources"
        KueueResources["Workloads<br/>Workloads/finalizers<br/>Workloads/status<br/>ResourceFlavors, WorkloadPriorityClasses<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "TrustyAI CRDs"
        TrustyAIResources["TrustyAIServices<br/>GuardrailsOrchestrators<br/>LMEvalJobs<br/>NemoGuardrails<br/>+/finalizers, +/status<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "RBAC Resources"
        RBACResources["ClusterRoleBindings<br/>Verbs: create, delete, get, list, update, watch"]
    end

    subgraph "Auth Resources"
        AuthResources["TokenReviews<br/>SubjectAccessReviews<br/>Verbs: create"]
    end

    subgraph "Leader Election Resources"
        LeaderResources["ConfigMaps, Leases, Events<br/>Namespace: trustyai-operator-system<br/>Verbs: get, list, watch, create, update, patch, delete"]
    end

    %% Service Account to Bindings
    SA -->|bound via| MCRB
    SA -->|bound via| PCRB
    SA -->|bound via| LERB

    %% Bindings to Roles
    MCRB -->|grants| MCR
    PCRB -->|grants| PCR
    LERB -->|grants| LER

    %% Manager Role Permissions
    MCR -->|manages| CoreResources
    MCR -->|manages| AppsResources
    MCR -->|manages| KServeResources
    MCR -->|manages| IstioResources
    MCR -->|manages| RouteResources
    MCR -->|manages| PrometheusResources
    MCR -->|manages| KueueResources
    MCR -->|manages| TrustyAIResources
    MCR -->|manages| RBACResources

    %% Proxy Role Permissions
    PCR -->|manages| AuthResources

    %% Leader Election Role Permissions
    LER -->|manages| LeaderResources

    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MCRB fill:#f5a623,stroke:#333
    style PCRB fill:#f5a623,stroke:#333
    style LERB fill:#f5a623,stroke:#333
    style MCR fill:#7ed321,stroke:#333
    style PCR fill:#7ed321,stroke:#333
    style LER fill:#7ed321,stroke:#333
    style CoreResources fill:#dae8fc,stroke:#333
    style AppsResources fill:#dae8fc,stroke:#333
    style KServeResources fill:#dae8fc,stroke:#333
    style IstioResources fill:#dae8fc,stroke:#333
    style RouteResources fill:#dae8fc,stroke:#333
    style PrometheusResources fill:#dae8fc,stroke:#333
    style KueueResources fill:#dae8fc,stroke:#333
    style TrustyAIResources fill:#dae8fc,stroke:#333
    style RBACResources fill:#dae8fc,stroke:#333
    style AuthResources fill:#dae8fc,stroke:#333
