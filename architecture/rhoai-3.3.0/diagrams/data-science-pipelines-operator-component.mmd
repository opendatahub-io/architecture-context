graph TB
    subgraph "Data Science Pipelines Operator (Cluster-Scoped)"
        DSPO[DSPO Controller Manager]
    end

    subgraph "DataSciencePipelinesApplication Instance (Namespace-Scoped)"
        direction TB

        subgraph "API Layer"
            APIServer[DS Pipeline API Server<br/>Port: 8888/8887<br/>REST/gRPC KFP v2 API]
            OAuthProxy[OAuth Proxy<br/>Port: 8443<br/>Authentication]
        end

        subgraph "Controllers"
            PersistenceAgent[Persistence Agent<br/>Workflow metadata sync]
            ScheduledWorkflow[Scheduled Workflow Controller<br/>Recurring pipeline runs]
            ArgoController[Argo Workflow Controller<br/>Namespace-scoped executor]
        end

        subgraph "Optional ML Metadata"
            MLMDgRPC[ML Metadata gRPC<br/>Port: 8080<br/>Artifact lineage]
            MLMDEnvoy[MLMD Envoy Proxy<br/>Port: 9090/8443<br/>mTLS support]
        end

        subgraph "Optional Dev/Test Storage"
            MariaDB[(MariaDB<br/>Port: 3306<br/>Pipeline metadata)]
            Minio[(Minio<br/>Port: 9000<br/>S3-compatible storage)]
        end
    end

    subgraph "Custom Resources"
        DSPACR[DataSciencePipelinesApplication CR]
        PipelineCR[Pipeline CR<br/>v2beta1]
        ScheduledWorkflowCR[ScheduledWorkflow CR]
        WorkflowCR[Argo Workflow CR]
    end

    subgraph "External Services"
        ExternalDB[(External MySQL/MariaDB<br/>Port: 3306)]
        ExternalS3[(External S3 Storage<br/>Port: 443)]
        K8sAPI[Kubernetes API Server<br/>Port: 6443]
    end

    subgraph "Pipeline Execution"
        WorkflowPods[Argo Workflow Pods<br/>Ephemeral pipeline tasks]
    end

    subgraph "ODH Integration"
        ODHDashboard[ODH Dashboard<br/>Pipeline UI]
        Workbenches[Workbenches/Notebooks<br/>KFP SDK clients]
    end

    %% DSPO relationships
    DSPO -->|reconciles| DSPACR
    DSPO -->|creates/manages| APIServer
    DSPO -->|creates/manages| PersistenceAgent
    DSPO -->|creates/manages| ScheduledWorkflow
    DSPO -->|creates/manages| ArgoController
    DSPO -->|creates/manages| MariaDB
    DSPO -->|creates/manages| Minio
    DSPO -->|creates/manages| MLMDgRPC
    DSPO -->|creates/manages| MLMDEnvoy

    %% API relationships
    APIServer -->|persists to| MariaDB
    APIServer -->|or uses| ExternalDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|or uses| ExternalS3
    APIServer -->|creates| WorkflowCR
    APIServer -->|creates| PipelineCR
    OAuthProxy -->|proxies to| APIServer

    %% Controller relationships
    ArgoController -->|watches| WorkflowCR
    ArgoController -->|creates| WorkflowPods
    PersistenceAgent -->|watches| WorkflowCR
    PersistenceAgent -->|updates| MariaDB
    ScheduledWorkflow -->|watches| ScheduledWorkflowCR
    ScheduledWorkflow -->|creates| WorkflowCR

    %% Workflow execution
    WorkflowPods -->|uploads artifacts| Minio
    WorkflowPods -->|or uploads to| ExternalS3
    WorkflowPods -->|tracks metadata| MLMDgRPC

    %% MLMD relationships
    MLMDEnvoy -->|proxies to| MLMDgRPC
    MLMDgRPC -->|persists to| MariaDB

    %% External integrations
    DSPO -->|manages resources via| K8sAPI
    ArgoController -->|creates pods via| K8sAPI
    ODHDashboard -->|accesses| OAuthProxy
    Workbenches -->|submits pipelines to| OAuthProxy

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:3px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style PersistenceAgent fill:#7ed321,stroke:#333
    style ScheduledWorkflow fill:#7ed321,stroke:#333
    style ArgoController fill:#7ed321,stroke:#333
    style MLMDgRPC fill:#bd10e0,stroke:#333
    style MLMDEnvoy fill:#bd10e0,stroke:#333
    style MariaDB fill:#e8e8e8,stroke:#333
    style Minio fill:#e8e8e8,stroke:#333
    style ExternalDB fill:#999,stroke:#333
    style ExternalS3 fill:#999,stroke:#333
    style DSPACR fill:#f5a623,stroke:#333,stroke-width:2px
    style WorkflowPods fill:#50e3c2,stroke:#333
