graph TB
    subgraph "Data Science Pipelines Operator (Cluster-scoped)"
        DSPO[DSPO Controller Manager]
    end

    subgraph "DSPA Instance (Namespace-scoped)"
        subgraph "Core Pipeline Services"
            APIServer[DS Pipeline API Server<br/>REST/gRPC v2beta1]
            PersistenceAgent[Persistence Agent<br/>Workflow Metadata Collector]
            ScheduledWorkflow[Scheduled Workflow Controller<br/>Recurring Pipelines]
        end

        subgraph "Workflow Execution"
            ArgoController[Argo Workflow Controller<br/>Namespace-scoped]
            WorkflowPods[Workflow Pods<br/>Pipeline Task Execution]
        end

        subgraph "ML Metadata (Optional)"
            MLMDgRPC[ML Metadata gRPC Server<br/>Artifact Lineage]
            MLMDEnvoy[MLMD Envoy Proxy<br/>mTLS + OAuth]
        end

        subgraph "Storage Components (Optional Dev/Test)"
            MariaDB[(MariaDB<br/>Pipeline Metadata DB)]
            Minio[(Minio<br/>S3-compatible Storage)]
        end

        subgraph "Security Proxies"
            OAuthProxy[OAuth Proxy<br/>OpenShift Auth]
            RBACProxy[Kube RBAC Proxy<br/>Metrics Auth]
        end
    end

    subgraph "Custom Resources"
        DSPACR[DataSciencePipelinesApplication CR]
        PipelineCR[Pipeline CR]
        PipelineVersionCR[PipelineVersion CR]
        ScheduledWorkflowCR[ScheduledWorkflow CR]
        WorkflowCR[Workflow CR<br/>Argo]
    end

    subgraph "External Services"
        ExternalDB[(External MySQL/MariaDB<br/>Production DB)]
        ExternalS3[(External S3<br/>AWS/Compatible)]
        K8sAPI[Kubernetes API Server]
    end

    subgraph "ODH Integration"
        Dashboard[ODH Dashboard UI]
        Workbenches[Workbenches/Notebooks<br/>KFP SDK]
        Monitoring[OpenShift Monitoring<br/>Prometheus]
    end

    %% Operator reconciliation
    DSPO -->|reconciles| DSPACR
    DSPO -->|creates/manages| APIServer
    DSPO -->|creates/manages| PersistenceAgent
    DSPO -->|creates/manages| ScheduledWorkflow
    DSPO -->|creates/manages| ArgoController
    DSPO -->|creates/manages| MariaDB
    DSPO -->|creates/manages| Minio
    DSPO -->|creates/manages| MLMDgRPC
    DSPO -->|creates/manages| MLMDEnvoy

    %% API Server interactions
    APIServer -->|reads/writes| MariaDB
    APIServer -->|reads/writes| ExternalDB
    APIServer -->|creates| WorkflowCR
    APIServer -->|stores artifacts| Minio
    APIServer -->|stores artifacts| ExternalS3
    APIServer -->|calls| K8sAPI

    %% Workflow execution
    ArgoController -->|watches| WorkflowCR
    ArgoController -->|creates| WorkflowPods
    WorkflowPods -->|reports status| APIServer
    WorkflowPods -->|stores artifacts| Minio
    WorkflowPods -->|stores artifacts| ExternalS3
    WorkflowPods -->|logs lineage| MLMDgRPC

    %% Persistence and scheduling
    PersistenceAgent -->|watches| WorkflowCR
    PersistenceAgent -->|persists metadata| MariaDB
    PersistenceAgent -->|persists metadata| ExternalDB
    ScheduledWorkflow -->|watches| ScheduledWorkflowCR
    ScheduledWorkflow -->|creates runs| APIServer

    %% CRD relationships
    DSPACR -->|defines| APIServer
    User[Data Scientist] -->|creates| PipelineCR
    User -->|creates| PipelineVersionCR
    User -->|creates| ScheduledWorkflowCR
    PipelineVersionCR -->|validated by| DSPO
    APIServer -->|creates| WorkflowCR

    %% Security
    OAuthProxy -->|authenticates| APIServer
    OAuthProxy -->|authenticates| MLMDEnvoy
    RBACProxy -->|protects| APIServer

    %% ODH integrations
    Dashboard -->|UI access| APIServer
    Workbenches -->|KFP SDK| APIServer
    Monitoring -->|scrapes metrics| DSPO
    Monitoring -->|scrapes metrics| APIServer

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:3px
    style APIServer fill:#4a90e2,stroke:#333
    style PersistenceAgent fill:#4a90e2,stroke:#333
    style ScheduledWorkflow fill:#4a90e2,stroke:#333
    style ArgoController fill:#4a90e2,stroke:#333
    style DSPACR fill:#f5a623,stroke:#333
    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style ScheduledWorkflowCR fill:#f5a623,stroke:#333
    style WorkflowCR fill:#f5a623,stroke:#333
    style MariaDB fill:#9013fe,stroke:#333
    style Minio fill:#9013fe,stroke:#333
    style ExternalDB fill:#999,stroke:#333
    style ExternalS3 fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Workbenches fill:#7ed321,stroke:#333
    style Monitoring fill:#7ed321,stroke:#333
    style MLMDgRPC fill:#50e3c2,stroke:#333
    style MLMDEnvoy fill:#50e3c2,stroke:#333
