graph TD
    subgraph "Service Accounts"
        SA[odh-notebook-controller-manager<br/>Controller Namespace]
        NotebookSA[notebook-name<br/>User Namespace]
    end

    subgraph "Cluster-Level RBAC"
        CRB[ClusterRoleBinding<br/>odh-notebook-controller-manager-rolebinding]
        CR[ClusterRole<br/>odh-notebook-controller-manager-role]
    end

    subgraph "Namespace-Level RBAC (Controller Namespace)"
        LeaderRB[RoleBinding<br/>leader-election-rolebinding]
        LeaderRole[Role<br/>leader-election-role]
    end

    subgraph "Namespace-Level RBAC (User Namespace)"
        NotebookRB[RoleBinding<br/>notebook-name-sa-rb]
        DSPARole[Role<br/>dspa-name-dspa<br/>Created by DSPA Operator]
    end

    subgraph "Aggregated User Roles"
        AdminRole[ClusterRole<br/>notebooks-admin<br/>Aggregates to admin]
        EditRole[ClusterRole<br/>notebooks-edit<br/>Aggregates to edit]
        ViewRole[ClusterRole<br/>notebooks-view<br/>Aggregates to view]
    end

    subgraph "API Resources - Kubeflow"
        NotebookRes[notebooks.kubeflow.org<br/>notebooks, status, finalizers]
    end

    subgraph "API Resources - Gateway API"
        HTTPRouteRes[gateway.networking.k8s.io<br/>httproutes]
        RefGrantRes[gateway.networking.k8s.io<br/>referencegrants]
        GatewayRes[gateway.networking.k8s.io<br/>gateways]
    end

    subgraph "API Resources - Core & Networking"
        CoreRes[core<br/>services, serviceaccounts,<br/>secrets, configmaps]
        NetPolRes[networking.k8s.io<br/>networkpolicies, finalizers]
    end

    subgraph "API Resources - RBAC"
        RBACRes[rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings]
        AuthNRes[authentication.k8s.io<br/>tokenreviews]
        AuthZRes[authorization.k8s.io<br/>subjectaccessreviews]
    end

    subgraph "API Resources - OpenShift"
        OAuthRes[oauth.openshift.io<br/>oauthclients]
        ImageRes[image.openshift.io<br/>imagestreams]
        ProxyRes[config.openshift.io<br/>proxies]
        RouteRes[route.openshift.io<br/>routes]
    end

    subgraph "API Resources - Data Science"
        DSPARes[datasciencepipelinesapplications<br/>.opendatahub.io<br/>DSPAs, API subresource]
    end

    subgraph "API Resources - Leader Election"
        ConfigMapRes[core<br/>configmaps]
        LeaseRes[coordination.k8s.io<br/>leases]
        EventRes[core<br/>events]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR
    SA -->|bound via| LeaderRB
    LeaderRB -->|grants| LeaderRole

    NotebookSA -->|bound via| NotebookRB
    NotebookRB -->|grants| DSPARole

    %% ClusterRole Permissions
    CR -->|get, list, watch,<br/>patch, update| NotebookRes
    CR -->|get, list, watch,<br/>create, update,<br/>patch, delete| HTTPRouteRes
    CR -->|get, list, watch,<br/>create, update,<br/>patch, delete| RefGrantRes
    CR -->|get, list, watch| GatewayRes
    CR -->|get, list, watch,<br/>create, update, patch| CoreRes
    CR -->|get, list, watch,<br/>create, update, patch| NetPolRes
    CR -->|get, list, watch,<br/>create, update,<br/>patch, delete| RBACRes
    CR -->|create| AuthNRes
    CR -->|create| AuthZRes
    CR -->|get, list, watch,<br/>update, patch, delete| OAuthRes
    CR -->|get, list, watch| ImageRes
    CR -->|get, list, watch| ProxyRes
    CR -->|get, list, watch| RouteRes
    CR -->|get, list, watch,<br/>create, update,<br/>patch, delete| DSPARes

    %% Leader Election Role Permissions
    LeaderRole -->|get, list, watch,<br/>create, update,<br/>patch, delete| ConfigMapRes
    LeaderRole -->|get, list, watch,<br/>create, update,<br/>patch, delete| LeaseRes
    LeaderRole -->|create, patch| EventRes

    %% Aggregated Roles
    AdminRole -->|all verbs| NotebookRes
    EditRole -->|get, list, watch,<br/>create, delete,<br/>deletecollection,<br/>patch, update| NotebookRes
    ViewRole -->|get, list, watch| NotebookRes

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NotebookSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px
    style DSPARole fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style LeaderRB fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NotebookRB fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style AdminRole fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style EditRole fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style ViewRole fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
