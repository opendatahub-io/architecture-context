graph TD
    subgraph "Service Accounts"
        SA1[odh-notebook-controller-manager<br/>controller namespace]
        SA2["{notebook-name}<br/>user namespace"]
    end

    subgraph "Cluster-Level RBAC"
        CRB1[odh-notebook-controller-manager-rolebinding<br/>ClusterRoleBinding]
        CR1[odh-notebook-controller-manager-role<br/>ClusterRole]

        CR2[notebooks-admin<br/>ClusterRole<br/>aggregates to admin]
        CR3[notebooks-edit<br/>ClusterRole]
        CR4[notebooks-view<br/>ClusterRole]
    end

    subgraph "Namespace-Level RBAC"
        RB1[odh-notebook-controller-leader-election-rolebinding<br/>controller namespace]
        R1[odh-notebook-controller-leader-election-role<br/>controller namespace]

        RB2["{notebook-name}-sa-rb<br/>user namespace"]
        R2["{dspa-name}-dspa<br/>user namespace"]
    end

    subgraph "API Resources - Kubeflow"
        Res1[kubeflow.org<br/>Notebook CR<br/>status, finalizers]
    end

    subgraph "API Resources - Gateway API"
        Res2[gateway.networking.k8s.io<br/>HTTPRoute<br/>ReferenceGrant<br/>Gateway]
    end

    subgraph "API Resources - Core"
        Res3[core<br/>Services<br/>ServiceAccounts<br/>Secrets<br/>ConfigMaps]
    end

    subgraph "API Resources - Networking"
        Res4[networking.k8s.io<br/>NetworkPolicies<br/>finalizers]
    end

    subgraph "API Resources - RBAC"
        Res5[rbac.authorization.k8s.io<br/>Roles<br/>RoleBindings<br/>ClusterRoleBindings]
    end

    subgraph "API Resources - Auth"
        Res6[authentication.k8s.io<br/>TokenReviews]
        Res7[authorization.k8s.io<br/>SubjectAccessReviews]
    end

    subgraph "API Resources - OpenShift"
        Res8[oauth.openshift.io<br/>OAuthClients]
        Res9[image.openshift.io<br/>ImageStreams]
        Res10[config.openshift.io<br/>Proxies]
        Res11[route.openshift.io<br/>Routes]
    end

    subgraph "API Resources - ODH"
        Res12[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication<br/>api]
    end

    subgraph "API Resources - Leader Election"
        Res13[core<br/>ConfigMaps<br/>Events]
        Res14[coordination.k8s.io<br/>Leases]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1
    SA2 -->|bound via| RB2

    %% ClusterRole Bindings
    CRB1 -->|grants| CR1
    RB1 -->|grants| R1
    RB2 -->|grants| R2

    %% Cluster Role Permissions
    CR1 -->|get,list,watch,patch,update| Res1
    CR1 -->|get,list,watch,create,update,patch,delete| Res2
    CR1 -->|get,list,watch,create,update,patch| Res3
    CR1 -->|get,list,watch,create,update,patch| Res4
    CR1 -->|get,list,watch,create,update,patch,delete| Res5
    CR1 -->|create| Res6
    CR1 -->|create| Res7
    CR1 -->|get,list,watch,update,patch,delete| Res8
    CR1 -->|get,list,watch| Res9
    CR1 -->|get,list,watch| Res10
    CR1 -->|get,list,watch| Res11
    CR1 -->|get,list,watch,create,update,patch,delete| Res12

    %% User-facing cluster roles
    CR2 -->|all verbs| Res1
    CR3 -->|get,list,watch,create,delete,deletecollection,patch,update| Res1
    CR4 -->|get,list,watch| Res1

    %% Leader Election Role Permissions
    R1 -->|get,list,watch,create,update,patch,delete| Res13
    R1 -->|get,list,watch,create,update,patch,delete| Res14
    R1 -->|create,patch| Res13

    %% kube-rbac-proxy Authorization
    KubeRBACProxy["kube-rbac-proxy<br/>Authorization<br/>(when inject-auth=true)"]
    KubeRBACProxy -->|SubjectAccessReview<br/>verb: get<br/>resource: notebooks<br/>apiGroup: kubeflow.org| Res7

    %% Styling
    classDef sa fill:#4a90e2,color:#fff
    classDef clusterRole fill:#f5a623,color:#000
    classDef role fill:#f5a623,color:#000
    classDef binding fill:#9b59b6,color:#fff
    classDef resource fill:#7ed321,color:#000
    classDef auth fill:#e74c3c,color:#fff

    class SA1,SA2 sa
    class CR1,CR2,CR3,CR4 clusterRole
    class R1,R2 role
    class CRB1,RB1,RB2 binding
    class Res1,Res2,Res3,Res4,Res5,Res6,Res7,Res8,Res9,Res10,Res11,Res12,Res13,Res14 resource
    class KubeRBACProxy auth
