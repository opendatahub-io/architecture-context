    style HTTPRouteRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RefGrantRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style GatewayRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style CoreRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NetPolRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RBACRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthNRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthZRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style OAuthRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ImageRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ProxyRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RouteRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style DSPARes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ConfigMapRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
