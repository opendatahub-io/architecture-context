graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Ingress/Gateway/Route<br/>443/TCP → 8000/TCP<br/>TLS 1.2+/TLS 1.3<br/>Optional Bearer Token"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Trusted)"]
        direction TB

        subgraph NS_Operator["Namespace: (operator-namespace)"]
            Operator["kuberay-operator<br/>SA: kuberay-operator<br/>runAsNonRoot, no privesc"]
            MetricsService["Metrics Service<br/>8080/TCP HTTP<br/>No auth"]
            HealthService["Health Service<br/>8081/TCP HTTP<br/>No auth"]
            WebhookService["Webhook Service<br/>9443/TCP HTTPS TLS1.2+<br/>Kubernetes admission"]

            subgraph Controllers["Controllers"]
                RayClusterCtrl[RayCluster Controller]
                RayJobCtrl[RayJob Controller]
                RayServiceCtrl[RayService Controller]
                NetPolicyCtrl[NetworkPolicy Controller]
                AuthCtrl[Authentication Controller]
            end
        end

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS1.2+<br/>Bearer Token (SA)"]

        subgraph NS_User["Namespace: (user-namespace)"]
            HeadPod["Ray Head Pod<br/>SA: (cluster)-sa<br/>SCC: run-as-ray-user (UID:1000)"]
            HeadService["Ray Head Service<br/>ClusterIP"]
            WorkerPods["Ray Worker Pods<br/>SA: (cluster)-sa<br/>Autoscaling<br/>SCC: run-as-ray-user"]
            ServeService["Ray Serve Service<br/>8000/TCP HTTP/HTTPS<br/>Optional TLS<br/>Optional Bearer"]
        end

        HeadPod -->|provides| HeadService
        HeadService -->|"GCS: 6379/TCP Redis<br/>Optional mTLS"| WorkerPods
        HeadService -.->|"Dashboard: 8265/TCP HTTP/HTTPS<br/>Optional OAuth"| External_Dashboard
        HeadService -.->|"Client: 10001/TCP gRPC<br/>Optional mTLS"| External_Client

        WorkerPods <-->|"Ray Protocol<br/>Optional mTLS"| HeadPod
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        CertManager["cert-manager API<br/>443/TCP HTTPS TLS1.2+<br/>Bearer Token (SA)"]
        Redis["External Redis<br/>6379/TCP Redis<br/>Optional TLS<br/>Password auth"]
        ContainerRegistry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Pull secrets"]
        ObjectStorage["Object Storage (S3/GCS)<br/>443/TCP HTTPS TLS1.2+<br/>Cloud credentials"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP<br/>No auth"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Optional Bearer Token"| Gateway
    Gateway -->|"HTTP/8000<br/>Optional TLS<br/>Optional Bearer"| ServeService

    %% Operator flows
    Operator -->|contains| Controllers
    Operator -->|exposes| MetricsService
    Operator -->|exposes| HealthService
    Operator -->|exposes| WebhookService

    Controllers -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SA)"| K8sAPI
    K8sAPI -->|"Admission Webhook<br/>HTTPS/443 → 9443<br/>TLS 1.2+"| WebhookService

    AuthCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| CertManager

    %% External service flows
    HeadPod -.->|"Redis/6379<br/>Optional TLS<br/>Password"| Redis
    Operator -->|"Image Pull<br/>HTTPS/443<br/>TLS 1.2+"| ContainerRegistry
    HeadPod -->|"Data Access<br/>HTTPS/443<br/>TLS 1.2+<br/>Cloud creds"| ObjectStorage
    Prometheus -->|"GET /metrics<br/>HTTP/8080<br/>No auth"| MetricsService

    %% Placeholders for dashboard/client (not shown in main flow)
    External_Dashboard["External Dashboard Access"]
    External_Client["External Client Access"]

    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style NetPolicyCtrl fill:#4a90e2,stroke:#333
    style AuthCtrl fill:#4a90e2,stroke:#333
    style K8sAPI fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333
    style ServeService fill:#7ed321,stroke:#333
    style CertManager fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Redis fill:#fff2cc,stroke:#d6b656
    style ContainerRegistry fill:#fff2cc,stroke:#d6b656
    style ObjectStorage fill:#fff2cc,stroke:#d6b656
    style Prometheus fill:#fff2cc,stroke:#d6b656
    style External_Dashboard fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style External_Client fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5

    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef k8s fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef managed fill:#7ed321,stroke:#333,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
