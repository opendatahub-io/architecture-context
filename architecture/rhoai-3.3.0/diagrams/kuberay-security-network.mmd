graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
        Redis["External Redis<br/>6379/TCP"]
        S3["Object Storage<br/>S3/GCS<br/>443/TCP"]
        Registry["Container Registry<br/>443/TCP"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Ingress/Gateway/Route<br/>443/TCP to 8000/TCP<br/>TLS 1.2+ SIMPLE/MUTUAL<br/>Optional Bearer Token"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_Operator["Namespace: kuberay-system"]
            Operator["kuberay-operator<br/>SA: kuberay-operator<br/>8080/TCP HTTP metrics<br/>9443/TCP HTTPS webhook"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            direction TB
            RayHead["Ray Head Pod<br/>SA: cluster-sa<br/>6379/TCP GCS Redis<br/>8265/TCP Dashboard HTTP<br/>10001/TCP Client gRPC"]

            RayWorker1["Ray Worker Pod 1<br/>SA: cluster-sa<br/>Dynamic Ray ports"]

            RayWorker2["Ray Worker Pod N<br/>SA: cluster-sa<br/>Dynamic Ray ports"]
        end

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        CertManager["cert-manager<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        Prometheus["Prometheus<br/>Internal"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Optional Bearer"| Gateway
    Gateway -->|"HTTP/8000<br/>Optional TLS<br/>Optional Auth"| RayHead

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token SA"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token SA"| CertManager
    Prometheus -->|"HTTP/8080<br/>No Auth"| Operator

    %% Ray cluster flows
    RayWorker1 -->|"Redis/6379<br/>Optional mTLS<br/>Optional cert"| RayHead
    RayWorker2 -->|"Redis/6379<br/>Optional mTLS<br/>Optional cert"| RayHead

    RayHead -->|"Redis/6379<br/>Optional TLS<br/>Password"| Redis
    RayHead -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials"| S3

    %% Registry flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secrets"| Registry
    RayHead -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secrets"| Registry
    RayWorker1 -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secrets"| Registry

    %% Kubernetes API interactions
    RayHead -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token SA"| K8sAPI
    RayWorker1 -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token SA"| K8sAPI

    %% Network Policy Isolation
    subgraph NetworkPolicies["Network Policies Optional"]
        NP1[Isolate Ray cluster traffic]
        NP2[Allow operator to Ray pods]
        NP3[Allow ingress to Ray Serve]
    end

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef raypod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,Redis,S3,Registry external
    class Gateway ingress
    class Operator operator
    class RayHead,RayWorker1,RayWorker2 raypod
    class K8sAPI,CertManager,Prometheus k8s
