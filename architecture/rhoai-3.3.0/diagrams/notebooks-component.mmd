    style JupyterTA fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterLLM fill:#4a90e2,stroke:#333,stroke-width:2px
    style CodeServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style RStudio fill:#4a90e2,stroke:#333,stroke-width:2px
