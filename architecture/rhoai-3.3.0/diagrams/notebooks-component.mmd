graph TB
    subgraph "Notebooks Component - Workbench Images"
        subgraph "Jupyter Workbenches"
            JupyterMin[Jupyter Minimal<br/>CPU/CUDA/ROCM]
            JupyterDS[Jupyter DataScience<br/>CPU]
            JupyterPT[Jupyter PyTorch<br/>CUDA/ROCM]
            JupyterTF[Jupyter TensorFlow<br/>CUDA/ROCM]
            JupyterTA[Jupyter TrustyAI<br/>CPU]
            JupyterLLM[Jupyter PyTorch+LLMCompressor<br/>CUDA]
        end

        subgraph "Other IDE Workbenches"
            CodeServer[CodeServer<br/>VS Code in Browser<br/>CPU]
            RStudio[RStudio<br/>CPU/CUDA]
        end

        subgraph "Runtime Images (Elyra Pipelines)"
            RuntimeMin[Runtime Minimal<br/>CPU]
            RuntimeDS[Runtime DataScience<br/>CPU]
            RuntimePT[Runtime PyTorch<br/>CUDA/ROCM]
            RuntimeTF[Runtime TensorFlow<br/>CUDA/ROCM]
            RuntimeLLM[Runtime PyTorch+LLMCompressor<br/>CUDA]
        end

        subgraph "Build Infrastructure"
            BaseImages[Base Images<br/>CPU/CUDA/ROCM<br/>UBI9 + Accelerator Libs]
            Konflux[Konflux CI/CD<br/>Tekton Pipelines]
            PyLock[pylock.toml<br/>Locked Dependencies]
        end

        subgraph "Deployment Artifacts"
            ImageStreams[ImageStream Manifests<br/>Kustomize]
        end
    end

    subgraph "External Components"
        User[Data Scientist]
        Dashboard[ODH Dashboard]
        NotebookController[odh-notebook-controller]
        OAuthProxy[OAuth Proxy Sidecar]
        KubePipelines[Kubeflow Pipelines<br/>Elyra]
        PVC[Persistent Storage<br/>PVC]
        Route[OpenShift Route<br/>HTTPS]
    end

    subgraph "External Registries"
        Quay[quay.io/opendatahub]
        RedHat[registry.redhat.io]
    end

    %% Build flow
    BaseImages -->|base for| JupyterMin
    BaseImages -->|base for| JupyterDS
    BaseImages -->|base for| JupyterPT
    BaseImages -->|base for| JupyterTF
    BaseImages -->|base for| RStudio
    BaseImages -->|base for| CodeServer
    BaseImages -->|base for| RuntimeMin

    PyLock -->|deps for| JupyterMin
    PyLock -->|deps for| JupyterDS
    PyLock -->|deps for| RuntimeMin

    Konflux -->|builds| JupyterMin
    Konflux -->|builds| JupyterDS
    Konflux -->|builds| JupyterPT
    Konflux -->|builds| RuntimeMin
    Konflux -->|publishes to| Quay
    Konflux -->|publishes to| RedHat
    Konflux -->|updates| ImageStreams

    %% User workflow
    User -->|browses images| Dashboard
    Dashboard -->|reads| ImageStreams
    User -->|creates workbench| NotebookController
    NotebookController -->|deploys pod with| JupyterMin
    NotebookController -->|deploys pod with| JupyterDS
    NotebookController -->|deploys pod with| RStudio
    NotebookController -->|creates| OAuthProxy
    NotebookController -->|creates| Route
    NotebookController -->|attaches| PVC

    OAuthProxy -->|protects| JupyterMin
    Route -->|exposes| OAuthProxy

    %% Pipeline workflow
    JupyterMin -->|launches pipeline via| KubePipelines
    KubePipelines -->|executes in| RuntimeMin
    KubePipelines -->|executes in| RuntimePT
    KubePipelines -->|executes in| RuntimeTF

