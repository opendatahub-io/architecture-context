graph TB
    subgraph "Notebooks Component - Workbench Images"
        subgraph "Jupyter Workbenches"
            JupyterMin[Jupyter Minimal<br/>JupyterLab 4.4<br/>Python 3.12]
            JupyterDS[Jupyter DataScience<br/>pandas, sklearn, numpy<br/>Python 3.12]
            JupyterPT[Jupyter PyTorch<br/>PyTorch 2.x<br/>CUDA/ROCM]
            JupyterTF[Jupyter TensorFlow<br/>TensorFlow 2.x<br/>CUDA/ROCM]
            JupyterTA[Jupyter TrustyAI<br/>Explainability Tools<br/>CPU]
            JupyterLLM[Jupyter PyTorch+LLMCompressor<br/>Model Optimization<br/>CUDA]
        end

        subgraph "Alternative IDEs"
            RStudio[RStudio Workbench<br/>R IDE Server<br/>CPU/CUDA]
            CodeServer[CodeServer Workbench<br/>VS Code in Browser<br/>Data Science Tools]
        end

        subgraph "Runtime Images"
            RuntimeMin[Pipeline Runtime Minimal<br/>Core libraries<br/>Python 3.12]
            RuntimeDS[Pipeline Runtime DataScience<br/>pandas, sklearn<br/>Python 3.12]
            RuntimePT[Pipeline Runtime PyTorch<br/>CUDA/ROCM<br/>Python 3.12]
            RuntimeTF[Pipeline Runtime TensorFlow<br/>CUDA/ROCM<br/>Python 3.12]
        end

        subgraph "Base Images"
            BaseCPU[CPU Base<br/>UBI9 Python 3.12]
            BaseCUDA[CUDA Base<br/>CUDA 12.6/12.8/13.0]
            BaseROCM[ROCM Base<br/>ROCM 6.2/6.3/6.4]
        end
    end

    subgraph "Platform Integration"
        Controller[odh-notebook-controller<br/>Deploys Workbenches]
        Dashboard[odh-dashboard<br/>User Interface]
        OAuthProxy[oauth-proxy<br/>Authentication Sidecar]
        Pipelines[Kubeflow Pipelines<br/>Elyra Integration]
        ImageStreams[OpenShift ImageStreams<br/>Image Discovery]
    end

    subgraph "External Dependencies"
        UBI9[UBI9 Python Images]
        JupyterLab[JupyterLab 4.4]
        PyTorch[PyTorch 2.x]
        TensorFlow[TensorFlow 2.x]
        RStudioPkg[RStudio Server]
        CodeServerPkg[code-server]
    end

    subgraph "CI/CD Build"
        Konflux[Konflux Tekton Pipelines<br/>Multi-arch Builds]
        Quay[quay.io/opendatahub<br/>Image Registry]
        RedHatReg[registry.redhat.io<br/>RHOAI Registry]
    end

    %% Base image dependencies
    BaseCPU --> UBI9
    BaseCUDA --> UBI9
    BaseROCM --> UBI9

    %% Workbench builds from base
    JupyterMin --> BaseCPU
    JupyterDS --> BaseCPU
    JupyterPT --> BaseCUDA
    JupyterPT --> BaseROCM
    JupyterTF --> BaseCUDA
    JupyterTF --> BaseROCM
    JupyterTA --> BaseCPU
    JupyterLLM --> BaseCUDA
    RStudio --> BaseCPU
    RStudio --> BaseCUDA
    CodeServer --> BaseCPU

    %% Runtime builds from base
    RuntimeMin --> BaseCPU
    RuntimeDS --> BaseCPU
    RuntimePT --> BaseCUDA
    RuntimePT --> BaseROCM
    RuntimeTF --> BaseCUDA
    RuntimeTF --> BaseROCM

    %% External dependencies
    JupyterMin --> JupyterLab
    JupyterPT --> PyTorch
    JupyterTF --> TensorFlow
    RStudio --> RStudioPkg
    CodeServer --> CodeServerPkg

    %% Platform integration
    Controller -->|deploys pods using| JupyterMin
    Controller -->|deploys pods using| JupyterDS
    Controller -->|deploys pods using| JupyterPT
    Controller -->|deploys pods using| RStudio
    Controller -->|deploys pods using| CodeServer
    Dashboard -->|reads| ImageStreams
    ImageStreams -->|references| JupyterMin
    ImageStreams -->|references| JupyterDS
    ImageStreams -->|references| JupyterPT
    OAuthProxy -->|protects| JupyterMin
    Pipelines -->|executes| RuntimeMin
    Pipelines -->|executes| RuntimePT

    %% Build and publish
    Konflux -->|builds| JupyterMin
    Konflux -->|builds| JupyterDS
    Konflux -->|builds| RuntimeMin
    Konflux -->|publishes to| Quay
    Konflux -->|publishes to| RedHatReg
    ImageStreams -->|pulls from| Quay
    ImageStreams -->|pulls from| RedHatReg

    %% Styling
    style JupyterMin fill:#4a90e2,stroke:#333,color:#fff
    style JupyterDS fill:#4a90e2,stroke:#333,color:#fff
    style JupyterPT fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTF fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTA fill:#4a90e2,stroke:#333,color:#fff
    style JupyterLLM fill:#4a90e2,stroke:#333,color:#fff
    style RStudio fill:#4a90e2,stroke:#333,color:#fff
    style CodeServer fill:#4a90e2,stroke:#333,color:#fff
    style RuntimeMin fill:#7ed321,stroke:#333,color:#000
    style RuntimeDS fill:#7ed321,stroke:#333,color:#000
    style RuntimePT fill:#7ed321,stroke:#333,color:#000
    style RuntimeTF fill:#7ed321,stroke:#333,color:#000
    style Controller fill:#f5a623,stroke:#333,color:#000
    style Dashboard fill:#f5a623,stroke:#333,color:#000
    style OAuthProxy fill:#f5a623,stroke:#333,color:#000
    style Pipelines fill:#f5a623,stroke:#333,color:#000
    style Konflux fill:#bd10e0,stroke:#333,color:#fff
    style UBI9 fill:#999,stroke:#333,color:#fff
    style JupyterLab fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style TensorFlow fill:#999,stroke:#333,color:#fff
