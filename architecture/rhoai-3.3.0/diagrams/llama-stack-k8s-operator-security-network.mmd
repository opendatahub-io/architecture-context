graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI]
        Client[Client Application]
    end

    subgraph Ingress["INGRESS (Optional - exposeRoute: true)"]
        IngressController["Ingress Controller<br/>80/TCP, 443/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.2+"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph OperatorPod["Operator Pod"]
            Controller["Controller Manager<br/>SA: controller-manager<br/>runAsNonRoot, drop ALL caps"]
            MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP"]
            HealthEndpoint["Health Probes<br/>8081/TCP HTTP"]
        end

        MetricsService["Metrics Service<br/>controller-manager-metrics-service<br/>8443/TCP HTTPS TLS<br/>kube-rbac-proxy"]
        OpConfig["ConfigMap<br/>llama-stack-operator-config<br/>Feature flags + image overrides"]
    end

    subgraph UserNamespace["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph LlamaStackPod["Llama Stack Pod"]
            LlamaStack["Llama Stack Server<br/>SA: {instance-name}-sa<br/>SCC: anyuid"]
            Storage["PVC: {instance-name}-pvc<br/>10Gi (default)<br/>/opt/app-root/src/.llama/"]
        end

        LlamaStackService["Service: {instance-name}-service<br/>8321/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.3"]
        NetworkPolicy["NetworkPolicy (optional)<br/>{instance-name}-netpol<br/>Ingress restriction"]
        UserConfig["ConfigMap (optional)<br/>{user-config-name}<br/>Llama Stack config"]
        TLSSecret["Secret (optional)<br/>{instance-name}-tls<br/>TLS certificates"]
    end

    subgraph InferenceProviders["INFERENCE PROVIDERS (Internal ODH/RHOAI)"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No Auth"]
        VLLM["vLLM Server<br/>8000/TCP HTTPS<br/>Optional TLS, Optional Token"]
    end

    subgraph K8sPlatform["KUBERNETES PLATFORM"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
        Prometheus["Prometheus<br/>Metrics Collection"]
        TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap<br/>Trusted CA certs"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token Auth"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secret"]
    end

    %% External flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig| K8sAPI
    Client -->|HTTP/HTTPS<br/>80/443<br/>Optional TLS| IngressController

    %% Ingress flows
    IngressController -->|HTTP/HTTPS<br/>8321<br/>Optional TLS 1.3| LlamaStackService

    %% Operator flows
    K8sAPI -.->|Watch notification| Controller
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Prometheus -->|HTTPS/8443<br/>TLS<br/>Bearer Token| MetricsService
    MetricsService -->|HTTP/8080<br/>Proxied| MetricsEndpoint
    Controller -.->|Watches| OpConfig

    %% Llama Stack flows
    LlamaStackService -->|Routes to| LlamaStack
    LlamaStack -->|HTTP/11434<br/>No Auth| Ollama
    LlamaStack -->|HTTPS/8000<br/>Optional TLS<br/>Optional Token| VLLM
    LlamaStack -.->|Mounts| Storage
    LlamaStack -.->|Mounts optional| UserConfig
    LlamaStack -.->|Mounts optional| TLSSecret
    LlamaStack -.->|Mounts optional| TrustedCA
    NetworkPolicy -.->|Restricts ingress to| LlamaStackService

    %% vLLM external flows
    VLLM -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HuggingFace

    %% Registry flows
    OperatorPod -.->|Pull image<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry
    LlamaStackPod -.->|Pull image<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#cfe2f3,stroke:#3c78d8,stroke-width:2px
    classDef usernamespace fill:#d9ead3,stroke:#6aa84f,stroke-width:2px
    classDef inference fill:#d9d2e9,stroke:#674ea7,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f4cccc,stroke:#cc0000,stroke-width:2px

    class User,Client external
    class IngressController ingress
    class Controller,MetricsEndpoint,HealthEndpoint,MetricsService,OpConfig operator
    class LlamaStack,LlamaStackService,NetworkPolicy,Storage,UserConfig,TLSSecret usernamespace
    class Ollama,VLLM inference
    class K8sAPI,Prometheus,TrustedCA platform
    class HuggingFace,Registry externalservice
