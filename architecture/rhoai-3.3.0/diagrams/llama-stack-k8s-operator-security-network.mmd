graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI]
        Prometheus[Prometheus<br/>ServiceMonitor]
        Client[Client Application]
    end

    subgraph ClusterAPI["CLUSTER API"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph OperatorNS["Namespace: redhat-ods-applications (Operator)"]
        direction TB
        Controller["Controller Manager Pod<br/>SA: controller-manager<br/>Security: runAsNonRoot<br/>Leader Election: lease-based"]
        RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Auth: Bearer Token"]
        Health["Health Probes<br/>8081/TCP HTTP<br/>Auth: None"]

        Controller -->|8080/TCP HTTP<br/>localhost only| RBACProxy
        Controller -->|8081/TCP HTTP| Health
    end

    subgraph UserNS["Namespace: {user-namespace} (Managed Workloads)"]
        direction TB
        LlamaCR[LlamaStackDistribution CR<br/>llamastack.io/v1alpha1]

        subgraph ManagedResources["Managed Resources"]
            LlamaDeployment["Llama Stack Deployment<br/>SA: {instance-name}-sa<br/>SCC: anyuid<br/>Storage: PVC 10Gi"]
            LlamaService["Llama Stack Service<br/>8321/TCP HTTP/HTTPS<br/>Type: ClusterIP<br/>Auth: None/Custom"]
            NetPol["NetworkPolicy<br/>Feature Flag: enabled<br/>Ingress: same NS + operator<br/>+ allowedFrom"]
            IngressRes["Ingress (Optional)<br/>80/TCP, 443/TCP<br/>TLS 1.2+<br/>exposeRoute: true"]
            HPA["HPA (Optional)<br/>CPU/Memory metrics"]
            PDB["PDB (Optional)<br/>Disruption protection"]
        end

        LlamaCR -.->|reconciled by| LlamaDeployment
        LlamaDeployment -->|8321/TCP| LlamaService
        NetPol -.->|protects| LlamaService
        IngressRes -.->|routes to| LlamaService
        HPA -.->|scales| LlamaDeployment
        PDB -.->|protects| LlamaDeployment
    end

    subgraph InferenceProviders["Inference Providers"]
        direction LR
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>Auth: None<br/>Distribution: starter"]
        vLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>Auth: Optional Token<br/>Distribution: remote-vllm"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        HF["HuggingFace Hub<br/>443/TCP HTTPS TLS1.2+<br/>Auth: HF Token<br/>Secret: hf-token-secret"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secret"]
    end

    subgraph ODHInternal["Internal ODH/RHOAI"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap<br/>TLS CA certificates"]
        ServiceMesh["Service Mesh<br/>Istio - Optional"]
    end

    %% External to Cluster
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Auth: kubeconfig| K8sAPI
    Prometheus -->|HTTPS/8443<br/>TLS<br/>Auth: Bearer Token| RBACProxy
    Client -.->|HTTP/80, HTTPS/443<br/>Optional TLS 1.2+<br/>via Ingress| IngressRes

    %% Cluster API flows
    K8sAPI -.->|Watch notification| Controller
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>Auth: SA Token| K8sAPI

    %% RBAC Proxy flows
    RBACProxy -->|HTTPS/6443<br/>TokenReview| K8sAPI

    %% Operator creates resources
    Controller -.->|Creates/Manages| LlamaCR
    Controller -.->|Creates/Manages| LlamaDeployment
    Controller -.->|Creates/Manages| LlamaService
    Controller -.->|Creates/Manages| NetPol
    Controller -.->|Creates/Manages| IngressRes
    Controller -.->|Creates/Manages| HPA
    Controller -.->|Creates/Manages| PDB

    %% Llama Stack egress
    LlamaDeployment -->|HTTP/11434<br/>Auth: None<br/>Inference| Ollama
    LlamaDeployment -->|HTTP/HTTPS/8000<br/>Auth: Optional Token<br/>Inference| vLLM
    vLLM -->|HTTPS/443<br/>TLS 1.2+<br/>Auth: HF Token<br/>Model downloads| HF
    LlamaDeployment -->|HTTPS/443<br/>TLS 1.2+<br/>Auth: Pull Secret<br/>Image pulls| Registry

    %% ODH integrations
    LlamaDeployment -.->|Uses TLS certs| CABundle
    LlamaDeployment -.->|Optional| ServiceMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef clusterapi fill:#e6f3ff,stroke:#0066cc,stroke-width:2px
    classDef operator fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inference fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef odh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User,Prometheus,Client external
    class K8sAPI clusterapi
    class Controller,RBACProxy,Health operator
    class LlamaCR,LlamaDeployment,LlamaService,NetPol,IngressRes,HPA,PDB managed
    class Ollama,vLLM inference
    class HF,Registry externalservice
    class CABundle,ServiceMesh odh
