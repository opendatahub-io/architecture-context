graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>443/TCP to 8443/TCP<br/>TLS 1.3 to TLS 1.2+<br/>reencrypt mode"]
    end

    subgraph ServiceMesh["SERVICE MESH / CLUSTER - Trusted"]
        direction TB

        subgraph NS_Registry["Namespace: registry namespace"]
            direction TB

            subgraph Pod_Registry["model-registry Pod"]
                Proxy["kube-rbac-proxy Sidecar<br/>Port 8443/TCP HTTPS<br/>SubjectAccessReview authz"]
                Registry["model-registry REST<br/>Port 8080/TCP HTTP<br/>localhost only"]
            end

            subgraph Pod_DB["PostgreSQL Pod"]
                DB["PostgreSQL Database<br/>Port 5432/TCP<br/>TLS optional<br/>NetworkPolicy restricted"]
            end

            Service["Service ClusterIP<br/>8443/TCP HTTPS or<br/>8080/TCP HTTP"]
            DBService["Service ClusterIP<br/>5432/TCP PostgreSQL"]
        end
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: operator namespace"]
            Controller["controller-manager<br/>SA: controller-manager"]
            Webhook["Webhook Service<br/>Port 9443/TCP HTTPS<br/>TLS 1.2+ cert-manager<br/>mTLS auth"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExternalDB["External PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ optional"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Legacy mode"]
    end

    %% External Access Flow
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token"| Router
    Router -->|"HTTPS/8443<br/>TLS 1.2+<br/>reencrypt"| Service
    Service -->|"HTTPS/8443<br/>Bearer Token"| Proxy

    %% Authorization Flow
    Proxy -->|"SubjectAccessReview<br/>HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -.->|"allow/deny"| Proxy

    %% Internal Flow
    Proxy -->|"HTTP/8080<br/>localhost<br/>No encryption"| Registry
    Registry -->|"PostgreSQL/5432<br/>TLS optional"| DBService
    DBService -->|forward| DB

    %% External DB alternative
    Registry -.->|"PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ optional"| ExternalDB

    %% Operator Control Flow
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token<br/>CR reconciliation"| K8sAPI
    K8sAPI -->|"Admission Webhook<br/>HTTPS/443 to 9443<br/>mTLS"| Webhook

    %% OAuth legacy
    Proxy -.->|"HTTPS/443<br/>OAuth token<br/>legacy mode"| OAuth

    %% Internal Cluster Access
    InternalPod["Internal Pod<br/>no auth"] -.->|"HTTP/8080<br/>No encryption<br/>No auth"| Service

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class Proxy,Registry,DB,Service,DBService servicemesh
    class Controller,Webhook,K8sAPI controlplane
    class ExternalDB,OAuth externalservice
