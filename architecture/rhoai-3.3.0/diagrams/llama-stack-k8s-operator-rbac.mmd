graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[auth-proxy-rolebinding<br/>ClusterRoleBinding<br/>Namespace: operator NS]
    end

    subgraph "Role Binding"
        RB1[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: operator NS]
    end

    subgraph "ClusterRole: manager-role"
        CR1_Core["Core APIs<br/>- configmaps<br/>- persistentvolumeclaims<br/>- serviceaccounts<br/>- services<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_Apps["apps<br/>- deployments<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_Autoscaling["autoscaling<br/>- horizontalpodautoscalers<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_LlamaStack["llamastack.io<br/>- llamastackdistributions<br/>- llamastackdistributions/finalizers<br/>- llamastackdistributions/status<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_Networking["networking.k8s.io<br/>- ingresses<br/>- networkpolicies<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_Policy["policy<br/>- poddisruptionbudgets<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
        CR1_RBAC["rbac.authorization.k8s.io<br/>- clusterroles (get, list, watch)<br/>- clusterrolebindings (delete, get, list)<br/>- rolebindings (create, delete,<br/>get, list, patch, update, watch)"]
        CR1_Security["security.openshift.io<br/>- securitycontextconstraints<br/>Verbs: use<br/>Resource: anyuid"]
    end

    subgraph "ClusterRole: auth-proxy-role"
        CR2_Auth["authentication.k8s.io<br/>- tokenreviews<br/>Verbs: create"]
        CR2_Authz["authorization.k8s.io<br/>- subjectaccessreviews<br/>Verbs: create"]
    end

    subgraph "Role: leader-election-role"
        R1_Core["Core APIs (Namespace: operator NS)<br/>- configmaps<br/>- events<br/>Verbs: create, get, list,<br/>patch, update, watch, delete"]
        R1_Coordination["coordination.k8s.io (Namespace: operator NS)<br/>- leases<br/>Verbs: create, get, list,<br/>patch, update, watch, delete"]
    end

    subgraph "API Resources (Cluster-wide)"
        API_LlamaStack["llamastack.io<br/>LlamaStackDistribution"]
        API_Apps["apps<br/>Deployment"]
        API_Core["core<br/>ConfigMap, Service,<br/>PVC, ServiceAccount"]
        API_Autoscaling["autoscaling<br/>HorizontalPodAutoscaler"]
        API_Networking["networking.k8s.io<br/>Ingress, NetworkPolicy"]
        API_Policy["policy<br/>PodDisruptionBudget"]
        API_RBAC["rbac.authorization.k8s.io<br/>ClusterRole, ClusterRoleBinding,<br/>RoleBinding"]
        API_Security["security.openshift.io<br/>SecurityContextConstraints"]
    end

    subgraph "Leader Election Resources (Namespace: operator NS)"
        API_Lease["coordination.k8s.io<br/>Lease"]
        API_ConfigMap["core<br/>ConfigMap, Event"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1_Core
    CRB1 -->|grants| CR1_Apps
    CRB1 -->|grants| CR1_Autoscaling
    CRB1 -->|grants| CR1_LlamaStack
    CRB1 -->|grants| CR1_Networking
    CRB1 -->|grants| CR1_Policy
    CRB1 -->|grants| CR1_RBAC
    CRB1 -->|grants| CR1_Security

    CRB2 -->|grants| CR2_Auth
    CRB2 -->|grants| CR2_Authz

    RB1 -->|grants| R1_Core
    RB1 -->|grants| R1_Coordination

    %% Roles to Resources
    CR1_LlamaStack -.->|full CRUD| API_LlamaStack
    CR1_Apps -.->|full CRUD| API_Apps
    CR1_Core -.->|full CRUD| API_Core
    CR1_Autoscaling -.->|full CRUD| API_Autoscaling
    CR1_Networking -.->|full CRUD| API_Networking
    CR1_Policy -.->|full CRUD| API_Policy
    CR1_RBAC -.->|read/delete| API_RBAC
    CR1_Security -.->|use anyuid| API_Security

    R1_Core -.->|full CRUD| API_ConfigMap
    R1_Coordination -.->|full CRUD| API_Lease

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB2 fill:#f5a623,stroke:#333,stroke-width:2px
    style RB1 fill:#f5a623,stroke:#333,stroke-width:2px

    style CR1_Core fill:#7ed321,stroke:#333,stroke-width:2px
    style CR1_Apps fill:#7ed321,stroke:#333,stroke-width:2px
