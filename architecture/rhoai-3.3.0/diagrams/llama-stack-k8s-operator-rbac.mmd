    style CR1_RBAC fill:#7ed321,stroke:#333,stroke-width:2px
    style CR1_Security fill:#7ed321,stroke:#333,stroke-width:2px

    style CR2_Auth fill:#7ed321,stroke:#333,stroke-width:2px
    style CR2_Authz fill:#7ed321,stroke:#333,stroke-width:2px

    style R1_Core fill:#50e3c2,stroke:#333,stroke-width:2px
    style R1_Coordination fill:#50e3c2,stroke:#333,stroke-width:2px

    style API_LlamaStack fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Apps fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Core fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Autoscaling fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Networking fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Policy fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_RBAC fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Security fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_Lease fill:#bd10e0,stroke:#333,stroke-width:2px
    style API_ConfigMap fill:#bd10e0,stroke:#333,stroke-width:2px
