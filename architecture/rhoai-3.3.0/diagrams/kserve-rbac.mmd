graph TB
    subgraph "Service Accounts"
        SA[ServiceAccount<br/>kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB[ClusterRoleBinding<br/>kserve-manager-rolebinding<br/>Binds SA to ClusterRole]
    end

    subgraph "ClusterRole Permissions"
        CR[ClusterRole<br/>kserve-manager-role]
    end

    subgraph "KServe API Resources"
        InferenceService[serving.kserve.io<br/>InferenceService<br/>v1beta1]
        ClusterServingRuntime[serving.kserve.io<br/>ClusterServingRuntime<br/>v1alpha1]
        ServingRuntime[serving.kserve.io<br/>ServingRuntime<br/>v1alpha1]
        InferenceGraph[serving.kserve.io<br/>InferenceGraph<br/>v1alpha1]
        TrainedModel[serving.kserve.io<br/>TrainedModel<br/>v1alpha1]
        LLMInferenceService[serving.kserve.io<br/>LLMInferenceService<br/>v1]
        LLMInferenceServiceConfig[serving.kserve.io<br/>LLMInferenceServiceConfig<br/>v1]
        LocalModelCache[serving.kserve.io<br/>LocalModelCache<br/>v1alpha1]
        ClusterStorageContainer[serving.kserve.io<br/>ClusterStorageContainer<br/>v1alpha1]
    end

    subgraph "Knative Resources"
        KnativeService[serving.knative.dev<br/>Service<br/>Serverless deployment]
    end

    subgraph "Istio Resources"
        VirtualService[networking.istio.io<br/>VirtualService<br/>Traffic routing]
        DestinationRule[networking.istio.io<br/>DestinationRule<br/>Load balancing]
    end

    subgraph "Core Kubernetes Resources"
        Deployments[apps<br/>Deployment<br/>Raw K8s deployment]
        Services[core<br/>Service<br/>ClusterIP/LoadBalancer]
        ServiceAccounts[core<br/>ServiceAccount<br/>Identity]
        Secrets[core<br/>Secret<br/>Credentials/TLS certs]
        ConfigMaps[core<br/>ConfigMap<br/>Configuration]
        Events[core<br/>Event<br/>Audit trail]
        Namespaces[core<br/>Namespace<br/>Read-only]
        Pods[core<br/>Pod<br/>Read-only]
    end

    subgraph "Autoscaling Resources"
        HPA[autoscaling<br/>HorizontalPodAutoscaler<br/>CPU/Memory autoscaling]
        ScaledObject[keda.sh<br/>ScaledObject<br/>Custom metric autoscaling]
    end

    subgraph "Ingress/Routing Resources"
        Ingress[networking.k8s.io<br/>Ingress<br/>Standard K8s ingress]
        Route[route.openshift.io<br/>Route<br/>OpenShift Routes]
        Gateway[gateway.networking.k8s.io<br/>Gateway<br/>Gateway API]
        HTTPRoute[gateway.networking.k8s.io<br/>HTTPRoute<br/>Gateway API routing]
    end

    subgraph "Monitoring Resources"
        ServiceMonitor[monitoring.coreos.com<br/>ServiceMonitor<br/>Prometheus scraping]
        PodMonitor[monitoring.coreos.com<br/>PodMonitor<br/>Prometheus scraping]
        OTelCollector[opentelemetry.io<br/>OpenTelemetryCollector<br/>Metrics collection]
    end

    subgraph "Advanced Resources"
        LeaderWorkerSetRes[leaderworkerset.x-k8s.io<br/>LeaderWorkerSet<br/>Multi-node LLM]
        InferencePool[inference.networking.k8s.io<br/>InferencePool<br/>Inference routing]
        InferenceModel[inference.networking.k8s.io<br/>InferenceModel<br/>Model management]
    end

    subgraph "Admission Resources"
        MutatingWebhook[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration<br/>Webhook registration]
        ValidatingWebhook[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration<br/>Webhook registration]
    end

    subgraph "RBAC Resources"
        ClusterRoleBindings[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>Cluster-wide bindings]
        RoleBindings[rbac.authorization.k8s.io<br/>RoleBinding<br/>Namespace bindings]
        Roles[rbac.authorization.k8s.io<br/>Role<br/>Namespace permissions]
    end

    subgraph "Auth Resources"
        TokenReviews[authentication.k8s.io<br/>TokenReview<br/>Token validation]
        SubjectAccessReviews[authentication.k8s.io<br/>SubjectAccessReview<br/>Permission checks]
    end

    subgraph "OpenShift Security"
        SCC[security.openshift.io<br/>SecurityContextConstraints<br/>openshift-ai-llminferenceservice-scc]
    end

    subgraph "Discovery Resources"
        EndpointSlices[discovery.k8s.io<br/>EndpointSlice<br/>Service endpoints]
    end

    %% Service Account to ClusterRoleBinding
    SA -->|bound via| CRB

    %% ClusterRoleBinding to ClusterRole
    CRB -->|grants| CR

    %% ClusterRole to KServe Resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| InferenceService
    CR -->|create, delete, get, list,<br/>patch, update, watch| ClusterServingRuntime
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServingRuntime
    CR -->|create, delete, get, list,<br/>patch, update, watch| InferenceGraph
    CR -->|create, delete, get, list,<br/>patch, update, watch| TrainedModel
    CR -->|create, delete, get, list,<br/>patch, update, watch| LLMInferenceService
    CR -->|create, delete, get, list,<br/>patch, update, watch| LLMInferenceServiceConfig
    CR -->|get, list, watch| LocalModelCache
    CR -->|create, delete, get, list,<br/>patch, update, watch| ClusterStorageContainer

    %% ClusterRole to Knative
    CR -->|create, delete, get, list,<br/>patch, update, watch| KnativeService

    %% ClusterRole to Istio
    CR -->|create, delete, get, list,<br/>patch, update, watch| VirtualService
    CR -->|create, delete, get, list,<br/>patch, update, watch| DestinationRule

    %% ClusterRole to Core Resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| Deployments
    CR -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts
    CR -->|create, delete, get, list,<br/>patch, update, watch| Secrets
    CR -->|create, delete, get, list,<br/>patch, update, watch| ConfigMaps
    CR -->|create, delete, get, list,<br/>patch, update, watch| Events
    CR -->|get, list, watch| Namespaces
    CR -->|get, list, watch| Pods

    %% ClusterRole to Autoscaling
    CR -->|create, delete, get, list,<br/>patch, update, watch| HPA
    CR -->|create, delete, get, list,<br/>patch, update, watch| ScaledObject

    %% ClusterRole to Ingress/Routing
    CR -->|create, delete, get, list,<br/>patch, update, watch| Ingress
    CR -->|create, delete, get, list,<br/>patch, update, watch| Route
    CR -->|create, delete, get, list,<br/>patch, update, watch| Gateway
    CR -->|create, delete, get, list,<br/>patch, update, watch| HTTPRoute

    %% ClusterRole to Monitoring
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceMonitor
    CR -->|create, delete, get, list,<br/>patch, update, watch| PodMonitor
    CR -->|create, delete, get, list,<br/>patch, update, watch| OTelCollector

    %% ClusterRole to Advanced Resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| LeaderWorkerSetRes
    CR -->|create, delete, get, list,<br/>patch, update, watch| InferencePool
    CR -->|create, delete, get, list,<br/>patch, update, watch| InferenceModel

    %% ClusterRole to Admission Resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| MutatingWebhook
    CR -->|create, delete, get, list,<br/>patch, update, watch| ValidatingWebhook

    %% ClusterRole to RBAC Resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| ClusterRoleBindings
    CR -->|create, delete, get, list,<br/>patch, update, watch| RoleBindings
    CR -->|create, delete, get, list,<br/>patch, update, watch| Roles

    %% ClusterRole to Auth Resources
    CR -->|create| TokenReviews
    CR -->|create| SubjectAccessReviews

    %% ClusterRole to OpenShift Security
    CR -->|use| SCC

    %% ClusterRole to Discovery
    CR -->|get, list, watch| EndpointSlices

