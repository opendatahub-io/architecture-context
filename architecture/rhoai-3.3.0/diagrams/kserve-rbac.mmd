graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRoleBindings"
        CRB_Manager[kserve-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "API Resources - KServe CRDs"
        ISVC[serving.kserve.io<br/>InferenceService]
        CSR[serving.kserve.io<br/>ClusterServingRuntime]
        SR[serving.kserve.io<br/>ServingRuntime]
        IG[serving.kserve.io<br/>InferenceGraph]
        TM[serving.kserve.io<br/>TrainedModel]
        LLM[serving.kserve.io<br/>LLMInferenceService]
        LLMConfig[serving.kserve.io<br/>LLMInferenceServiceConfig]
        LMC[serving.kserve.io<br/>LocalModelCache]
        CSC[serving.kserve.io<br/>ClusterStorageContainer]
    end

    subgraph "API Resources - Knative"
        KnativeService[serving.knative.dev<br/>Service]
    end

    subgraph "API Resources - Istio"
        VS[networking.istio.io<br/>VirtualService]
        DR[networking.istio.io<br/>DestinationRule]
    end

    subgraph "API Resources - Core Kubernetes"
        Services[core<br/>Service]
        ServiceAccounts[core<br/>ServiceAccount]
        Secrets[core<br/>Secret]
        ConfigMaps[core<br/>ConfigMap]
        Events[core<br/>Event]
        Namespaces[core<br/>Namespace]
        Pods[core<br/>Pod]
    end

    subgraph "API Resources - Apps"
        Deployments[apps<br/>Deployment]
        HPAs[autoscaling<br/>HorizontalPodAutoscaler]
    end

    subgraph "API Resources - Networking"
        Ingresses[networking.k8s.io<br/>Ingress]
        Routes[route.openshift.io<br/>Route]
        Gateways[gateway.networking.k8s.io<br/>Gateway]
        HTTPRoutes[gateway.networking.k8s.io<br/>HTTPRoute]
    end

    subgraph "API Resources - KEDA"
        ScaledObjects[keda.sh<br/>ScaledObject]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors[monitoring.coreos.com<br/>ServiceMonitor]
        PodMonitors[monitoring.coreos.com<br/>PodMonitor]
    end

    subgraph "API Resources - OpenTelemetry"
        OTelCollectors[opentelemetry.io<br/>OpenTelemetryCollector]
    end

    subgraph "API Resources - LeaderWorkerSet"
        LWSets[leaderworkerset.x-k8s.io<br/>LeaderWorkerSet]
    end

    subgraph "API Resources - Webhooks"
        MutatingWebhooks[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration]
        ValidatingWebhooks[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration]
    end

    subgraph "API Resources - RBAC"
        CRBs[rbac.authorization.k8s.io<br/>ClusterRoleBinding]
        RoleBindings[rbac.authorization.k8s.io<br/>RoleBinding]
        Roles[rbac.authorization.k8s.io<br/>Role]
    end

    subgraph "API Resources - OpenShift Security"
        SCC[security.openshift.io<br/>SecurityContextConstraints<br/>openshift-ai-llminferenceservice-scc]
    end

