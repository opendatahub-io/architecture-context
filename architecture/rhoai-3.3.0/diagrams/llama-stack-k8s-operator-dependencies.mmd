    %% Internal ODH (optional)
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

