    style Registry fill:#cc6666,stroke:#333,stroke-width:2px,color:#fff
    style HuggingFace fill:#cc6666,stroke:#333,stroke-width:2px,color:#fff
    style K8sAPI fill:#cc6666,stroke:#333,stroke-width:2px,color:#fff

