graph LR
    MLflowOp[MLflow Operator]

    %% External Dependencies (Required)
    MLflowOp -->|cluster platform| K8s[Kubernetes v1.11.3+]
    MLflowOp -->|template rendering| Helm[Helm v3<br/>embedded]
    MLflowOp -->|runtime container| MLflowImage[MLflow v3.6.0<br/>quay.io/opendatahub/mlflow]

    %% External Dependencies (Optional)
    MLflowOp -.->|metadata storage| PostgreSQL[PostgreSQL 9.6+]
    MLflowOp -.->|artifact storage| S3[S3-compatible storage]
    MLflowOp -.->|auto TLS certs| ServiceCA[service-ca-operator]

    %% Internal ODH Dependencies
    MLflowOp -->|external routing| Gateway[data-science-gateway<br/>Gateway API HTTPRoute]
    MLflowOp -->|console integration| OSConsole[OpenShift Console<br/>ConsoleLink CRD]
    MLflowOp -->|metrics| Prometheus[Prometheus<br/>ServiceMonitor]
    MLflowOp -.->|UI access| Dashboard[ODH/RHOAI Dashboard<br/>via Gateway]

    %% Integration Points
    Gateway -->|routes traffic| MLflowOp
    OSConsole -->|application menu| MLflowOp
    Prometheus -->|scrapes| MLflowOp

    %% Kubernetes API
    MLflowOp -->|API server| K8sAPI[Kubernetes API<br/>CRD management<br/>RBAC enforcement]

    %% Build-time Dependencies
    subgraph BuildTime["Build-time Only"]
        Go[Go v1.24.6+]
    end

    MLflowOp -.->|compilation| Go

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style Helm fill:#0f1689,stroke:#333,stroke-width:2px,color:#fff
    style MLflowImage fill:#0194e2,stroke:#333,stroke-width:2px,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff

    %% External optional
    style PostgreSQL fill:#336791,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style S3 fill:#f90,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#000
    style ServiceCA fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    %% Internal ODH
    style Gateway fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style OSConsole fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Prometheus fill:#e6522c,stroke:#333,stroke-width:2px,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#000

    %% Build-time
    style Go fill:#00add8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    %% Legend
    subgraph Legend
        direction LR
        Req[Required]
        Opt[Optional]
        Build[Build-time]
    end

    style Req fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style Opt fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style Build fill:#00add8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
