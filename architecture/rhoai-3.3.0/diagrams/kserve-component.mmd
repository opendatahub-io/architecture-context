graph TB
    subgraph "KServe Control Plane"
        Controller[kserve-controller-manager<br/>Kubernetes Operator]
        Webhook[kserve-webhook-server<br/>Admission Webhook]
        Controller -->|validates/mutates| Webhook
    end

    subgraph "User Namespace"
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        InferenceGraphCR[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
        TrainedModelCR[TrainedModel CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Inference Pod Components"
        StorageInit[storage-initializer<br/>Init Container<br/>Python]
        PredictorContainer[Predictor Runtime<br/>sklearn/pytorch/huggingface/triton<br/>Python]
        AgentSidecar[agent<br/>Sidecar<br/>Go]
        StorageInit -->|downloads models| PredictorContainer
        PredictorContainer -.->|logging/batching| AgentSidecar
    end

    subgraph "InferenceGraph Components"
        Router[router<br/>Go Service]
        Router -->|routes to| PredictorContainer
    end

    subgraph "LLM Components"
        LLMScheduler[llm-scheduler<br/>Go Service<br/>9003/TCP gRPC]
        PrefillWorker[Prefill Worker<br/>LeaderWorkerSet]
        DecodeWorker[Decode Worker<br/>LeaderWorkerSet]
        LLMScheduler -->|schedules| PrefillWorker
        LLMScheduler -->|schedules| DecodeWorker
    end

    subgraph "Local Model Cache"
        LocalModelManager[localmodel-manager<br/>Controller]
        LocalModelNodeAgent[localmodelnode-agent<br/>DaemonSet]
        LocalModelCache[LocalModelCache CR]
        LocalModelManager -->|manages| LocalModelCache
        LocalModelNodeAgent -->|syncs| LocalModelCache
    end

    User[Data Scientist] -->|kubectl create| InferenceServiceCR
    User -->|kubectl create| InferenceGraphCR
    InferenceServiceCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    InferenceGraphCR -->|watched by| Controller
    TrainedModelCR -->|watched by| Controller

    Controller -->|creates| KnativeService[Knative Service]
    Controller -->|creates| Deployment[Deployment<br/>Predictor/Router]
    Controller -->|creates| VirtualService[Istio VirtualService]
    Controller -->|creates| Route[OpenShift Route]

    Deployment -->|contains| StorageInit
    Deployment -->|contains| PredictorContainer
    Deployment -->|contains| AgentSidecar

    StorageInit -->|downloads from| S3[S3/GCS/Azure Storage<br/>443/TCP HTTPS]

    Controller -->|depends on| Istio[Istio<br/>Traffic Management]
    Controller -->|depends on| Knative[Knative Serving<br/>Autoscaling]
    Controller -->|depends on| CertManager[cert-manager<br/>TLS Certificates]

    Controller -->|integrates| ModelRegistry[Model Registry<br/>Internal ODH]
    Controller -->|integrates| Dashboard[ODH Dashboard<br/>UI Management]

    ExternalClient[External Client] -->|HTTPS/443| IstioGateway[Istio IngressGateway]
    IstioGateway -->|routes via| VirtualService
    VirtualService -->|forwards to| PredictorContainer

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style PredictorContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style Istio fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Knative fill:#e8e8e8,stroke:#333,stroke-width:2px
    style CertManager fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px
