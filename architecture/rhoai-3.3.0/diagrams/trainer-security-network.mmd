graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / SDK / kubectl"]
    end

    subgraph APIServer["KUBERNETES API SERVER"]
        API["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>RBAC Enforcement"]
        Webhook["Validating Webhook Server<br/>9443/TCP HTTPS TLS<br/>SA: kubeflow-trainer-controller-manager"]
    end

    subgraph ControlPlane["CONTROL PLANE (opendatahub namespace)"]
        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/trainer:v2.1.0"]
        Prometheus["Prometheus<br/>OpenShift Monitoring<br/>PodMonitor"]
    end

    subgraph WorkloadPlane["WORKLOAD PLANE (user namespaces)"]
        direction TB

        JobSetCtl["JobSet Controller"]
        Scheduler["Scheduler<br/>Volcano/Coscheduling<br/>Gang Scheduling"]

        subgraph TrainingWorkload["Training Workload"]
            Pods["Training Pods<br/>Label: jobset-name={trainjob-name}<br/>Images: odh-training-*"]
            NetPolicy["NetworkPolicy<br/>{trainjob-name}"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>TLS 1.2+<br/>AWS IAM Auth"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>TLS 1.2+<br/>HF Token"]
    end

    %% User flows
    User -->|"HTTPS/6443<br/>TLS 1.3<br/>User credentials"| API

    %% Webhook validation
    API -->|"HTTPS/9443<br/>TLS<br/>mTLS"| Webhook
    Webhook -.->|"validation response"| API

    %% Controller watch
    API -->|"Watch stream<br/>TLS 1.3<br/>ServiceAccount token"| Controller

    %% Controller creates resources
    Controller -->|"HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount token<br/>CREATE JobSets, PodGroups, NetworkPolicies"| API

    %% Metrics scraping
    Prometheus -->|"HTTPS/8080<br/>TLS<br/>No auth"| Controller

    %% JobSet and Scheduling
    API -.->|"Watch JobSet"| JobSetCtl
    JobSetCtl -.->|"CREATE Jobs"| API
    API -.->|"Watch PodGroup"| Scheduler
    Scheduler -.->|"Schedule pods"| Pods

    %% Progression tracking (RHOAI)
    Controller -->|"GET Pods (list)<br/>HTTPS/6443<br/>ServiceAccount token"| API
    Controller -->|"HTTP/28080<br/>GET /metrics<br/>NetworkPolicy restricted"| Pods
    NetPolicy -.->|"restricts access to<br/>controller pods only"| Pods

    %% Inter-pod communication
    Pods <-->|"Dynamic ports<br/>TCP<br/>NCCL/MPI<br/>NetworkPolicy: same jobset-name"| Pods

    %% External storage
    Pods -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Pods -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef apiserver fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workloadplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class API,Webhook apiserver
    class Controller,Prometheus controlplane
    class JobSetCtl,Scheduler,Pods workloadplane
    class NetPolicy security
    class S3,HF externalservice
