graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist / kubectl]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Auth: User credentials"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: trainer:v2.1.0"]

        subgraph ControllerComponents["Controller Components"]
            Webhook["Validating Webhook<br/>9443/TCP HTTPS TLS"]
            TrainJobCtrl["TrainJob Controller"]
            RuntimeCtrl["Runtime Controllers"]
            ProgressTracker["Progression Tracker<br/>(RHOAI)"]
            NetworkPolicyMgr["Network Policy Manager<br/>(RHOAI)"]
        end

        Controller --- Webhook
        Controller --- TrainJobCtrl
        Controller --- RuntimeCtrl
        Controller --- ProgressTracker
        Controller --- NetworkPolicyMgr

        Metrics["Metrics Endpoint<br/>8080/TCP HTTPS TLS<br/>PodMonitor scraping"]
        Health["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]

        Controller --- Metrics
        Controller --- Health
    end

    subgraph TrainingNamespace["TRAINING WORKLOAD NAMESPACE ({user-namespace})"]
        direction TB

        JobSet["JobSet<br/>Multi-node training orchestration"]

        subgraph TrainingPods["Training Pods (GPU Workloads)"]
            Pod0["node-0 (launcher)<br/>Image: odh-training-cuda128<br/>GPU: NVIDIA/AMD"]
            Pod1["node-1 (worker)<br/>GPU workload"]
            Pod2["node-2 (worker)<br/>GPU workload"]
        end

        JobSet --> Pod0
        JobSet --> Pod1
        JobSet --> Pod2

        TrainingMetrics["Metrics Endpoint<br/>28080/TCP HTTP<br/>NetworkPolicy restricted"]
        Pod0 --- TrainingMetrics
        Pod1 --- TrainingMetrics
        Pod2 --- TrainingMetrics

        NetworkPolicy["NetworkPolicy<br/>{trainjob-name}<br/>- Allow: Same JobSet<br/>- Allow: Controller metrics"]
    end

    subgraph Scheduler["GANG SCHEDULING (Optional)"]
        PodGroup["PodGroup<br/>scheduling.volcano.sh"]
        Volcano["Volcano Scheduler<br/>v1.13.1<br/>All-or-nothing scheduling"]

        PodGroup -.-> Volcano
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS1.2+<br/>Auth: HF token"]
        GCS["GCS<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: GCP SA"]
    end

    subgraph Monitoring["MONITORING (RHOAI)"]
        Prometheus["OpenShift Monitoring<br/>Prometheus Operator"]
        PodMonitor["PodMonitor<br/>kubeflow-trainer-controller-manager"]

        Prometheus --> PodMonitor
    end

    %% External → Control Plane
    User -->|kubectl apply TrainJob<br/>6443/TCP HTTPS TLS1.3| APIServer

    %% Control Plane → Operator
    APIServer -->|Validate TrainJob<br/>9443/TCP HTTPS mTLS| Webhook
    APIServer -->|Watch CRDs<br/>ServiceAccount token| TrainJobCtrl

    %% Operator → Control Plane
    TrainJobCtrl -->|Create JobSet, PodGroup<br/>6443/TCP HTTPS TLS1.3<br/>ServiceAccount token| APIServer
    NetworkPolicyMgr -->|Create NetworkPolicy<br/>6443/TCP HTTPS TLS1.3| APIServer

    %% Operator → Training Pods (Progression Tracking)
    ProgressTracker -->|Poll /metrics<br/>28080/TCP HTTP<br/>Every 30s<br/>NetworkPolicy allowed| TrainingMetrics
    ProgressTracker -->|Update annotation<br/>trainer.opendatahub.io/trainerStatus| APIServer

    %% Gang Scheduling
    TrainJobCtrl -.->|Create PodGroup| PodGroup
    Volcano -.->|Schedule all pods<br/>simultaneously| TrainingPods

    %% Training Pods → External Services
    Pod0 -->|Download models/datasets<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / HF token| S3
    Pod1 -->|Download models/datasets<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / HF token| HuggingFace
    Pod2 -.->|Optional| GCS

    %% Inter-pod Communication
    Pod0 <-->|NCCL, MPI, gRPC<br/>Dynamic TCP<br/>NetworkPolicy: Same JobSet| Pod1
    Pod1 <-->|NCCL, MPI, gRPC<br/>Dynamic TCP<br/>NetworkPolicy: Same JobSet| Pod2
    Pod0 <-->|NCCL, MPI, gRPC<br/>Dynamic TCP<br/>NetworkPolicy: Same JobSet| Pod2

    %% Monitoring
    PodMonitor -.->|Scrape metrics<br/>8080/TCP HTTPS TLS| Metrics

    %% NetworkPolicy enforcement
    NetworkPolicy -.->|Restricts ingress| TrainingPods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e6f2ff,stroke:#4a90e2,stroke-width:2px
    classDef operator fill:#fff4e6,stroke:#f5a623,stroke-width:2px
    classDef training fill:#e8f5e9,stroke:#7ed321,stroke-width:2px
    classDef externalservice fill:#fff9e6,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef scheduler fill:#e0f2f1,stroke:#00897b,stroke-width:2px
    classDef rhoai fill:#c8e6c9,stroke:#388e3c,stroke-width:3px

    class User external
    class APIServer controlplane
    class Controller,Webhook,TrainJobCtrl,RuntimeCtrl,Metrics,Health operator
    class ProgressTracker,NetworkPolicyMgr,NetworkPolicy rhoai
    class JobSet,Pod0,Pod1,Pod2,TrainingMetrics training
    class S3,HuggingFace,GCS externalservice
    class Prometheus,PodMonitor monitoring
    class PodGroup,Volcano scheduler
