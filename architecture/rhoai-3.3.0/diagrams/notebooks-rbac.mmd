graph TD
    subgraph "Workbench Pod RBAC"
        WorkbenchSA["ServiceAccount<br/>{workbench-name}-sa<br/>Namespace: {user-namespace}"]
        WorkbenchPerms["Default Namespace Permissions<br/>(inherited from namespace)"]
    end

    subgraph "Workbench Allowed Resources"
        WorkbenchPods["Pods<br/>get, list, watch"]
        WorkbenchCM["ConfigMaps<br/>get, list, watch"]
        WorkbenchSecrets["Secrets<br/>get, list, watch"]
        WorkbenchImageStreams["ImageStreams<br/>get, list<br/>(discover available images)"]
    end

    subgraph "odh-notebook-controller RBAC"
        ControllerSA["ServiceAccount<br/>odh-notebook-controller-manager<br/>Namespace: redhat-ods-applications"]
        ControllerCRB["ClusterRoleBinding<br/>odh-notebook-controller-manager"]
        ControllerCR["ClusterRole<br/>odh-notebook-controller-manager-role"]
    end

    subgraph "Controller Allowed Resources (Cross-Namespace)"
        NotebookCRD["Notebook CRD<br/>serving.kserve.io<br/>get, list, watch, create, update, patch, delete"]
        StatefulSets["StatefulSets<br/>apps/v1<br/>get, list, watch, create, update, patch, delete"]
        Services["Services<br/>core/v1<br/>get, list, watch, create, update, patch, delete"]
        RoutesRes["Routes<br/>route.openshift.io<br/>get, list, watch, create, update, patch, delete"]
        ConfigMaps["ConfigMaps<br/>core/v1<br/>get, list, watch, create, update, patch, delete"]
        SecretsRes["Secrets<br/>core/v1<br/>get, list, watch, create, update, patch, delete"]
        PVCs["PersistentVolumeClaims<br/>core/v1<br/>get, list, watch, create, update, patch"]
        ImageStreamsRes["ImageStreams<br/>image.openshift.io<br/>get, list, watch"]
    end

    subgraph "odh-dashboard RBAC"
        DashboardSA["ServiceAccount<br/>odh-dashboard<br/>Namespace: redhat-ods-applications"]
        DashboardPerms["Permissions"]
    end

    subgraph "Dashboard Allowed Resources"
        DashboardImageStreams["ImageStreams<br/>get, list, watch<br/>(display available images)"]
        DashboardNotebooks["Notebook CRD<br/>create<br/>(trigger workbench creation)"]
    end

    subgraph "Denied Operations (All)"
        Denied["❌ Cluster-admin permissions<br/>❌ Cross-namespace access (workbench SA)<br/>❌ Modify RBAC from workbench<br/>❌ Privileged containers<br/>❌ Host network/PID access"]
    end

    %% Workbench SA permissions
    WorkbenchSA -->|bound to| WorkbenchPerms
    WorkbenchPerms -->|allows| WorkbenchPods
    WorkbenchPerms -->|allows| WorkbenchCM
    WorkbenchPerms -->|allows| WorkbenchSecrets
    WorkbenchPerms -->|allows| WorkbenchImageStreams

    %% Controller SA permissions
    ControllerSA -->|bound via| ControllerCRB
    ControllerCRB -->|grants| ControllerCR
    ControllerCR -->|allows| NotebookCRD
    ControllerCR -->|allows| StatefulSets
    ControllerCR -->|allows| Services
    ControllerCR -->|allows| RoutesRes
    ControllerCR -->|allows| ConfigMaps
    ControllerCR -->|allows| SecretsRes
    ControllerCR -->|allows| PVCs
    ControllerCR -->|allows| ImageStreamsRes

    %% Dashboard SA permissions
    DashboardSA -->|has| DashboardPerms
    DashboardPerms -->|allows| DashboardImageStreams
    DashboardPerms -->|allows| DashboardNotebooks

    %% Styling
    style WorkbenchSA fill:#4a90e2,stroke:#333,color:#fff
    style ControllerSA fill:#4a90e2,stroke:#333,color:#fff
    style DashboardSA fill:#4a90e2,stroke:#333,color:#fff

    style ControllerCR fill:#f5a623,stroke:#333,color:#000
    style WorkbenchPerms fill:#f5a623,stroke:#333,color:#000
    style DashboardPerms fill:#f5a623,stroke:#333,color:#000

    style WorkbenchPods fill:#7ed321,stroke:#333,color:#000
    style WorkbenchCM fill:#7ed321,stroke:#333,color:#000
    style WorkbenchSecrets fill:#7ed321,stroke:#333,color:#000
    style WorkbenchImageStreams fill:#7ed321,stroke:#333,color:#000

    style NotebookCRD fill:#7ed321,stroke:#333,color:#000
    style StatefulSets fill:#7ed321,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style RoutesRes fill:#7ed321,stroke:#333,color:#000
    style ConfigMaps fill:#7ed321,stroke:#333,color:#000
    style SecretsRes fill:#7ed321,stroke:#333,color:#000
    style PVCs fill:#7ed321,stroke:#333,color:#000
    style ImageStreamsRes fill:#7ed321,stroke:#333,color:#000

    style DashboardImageStreams fill:#7ed321,stroke:#333,color:#000
    style DashboardNotebooks fill:#7ed321,stroke:#333,color:#000

    style Denied fill:#e74c3c,stroke:#333,color:#fff
