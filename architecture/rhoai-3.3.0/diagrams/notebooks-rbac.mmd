graph TD
    subgraph "Workbench Pod RBAC"
        WorkbenchSA["Service Account<br/>{workbench-name}-sa<br/>(created by odh-notebook-controller)"]
    end

    subgraph "Runtime Pod RBAC (Elyra Pipelines)"
        PipelineSA["Service Account<br/>pipeline-runner-sa<br/>(created by Kubeflow Pipelines)"]
    end

    subgraph "Default Workbench Permissions (Namespace-Scoped)"
        direction TB
        WorkbenchPerms["Default Permissions:<br/>• Resources: ConfigMaps, Secrets, Pods, Services<br/>• Verbs: get, list (read-only)<br/>• Scope: User namespace only<br/>• No cluster-admin access<br/>• No cross-namespace access"]
    end

    subgraph "Default Pipeline Permissions (Namespace-Scoped)"
        direction TB
        PipelinePerms["Default Permissions:<br/>• Resources: Pods, ConfigMaps, Secrets<br/>• Verbs: get, list, create<br/>• Scope: User namespace only<br/>• Required for pipeline execution"]
    end

    subgraph "Kubernetes API Resources"
        ConfigMaps["ConfigMaps<br/>(namespace-scoped)"]
        Secrets["Secrets<br/>(namespace-scoped)"]
        Pods["Pods<br/>(namespace-scoped)"]
        Services["Services<br/>(namespace-scoped)"]
        ImageStreamAccess["ImageStreams<br/>(read access for discovery)"]
    end

    subgraph "Extended Permissions (User-Configured)"
        direction TB
        UserRoles["Optional RoleBindings:<br/>• Users can grant additional permissions<br/>• Example: PVC read/write access<br/>• Example: Custom app deployments<br/>• Requires user to create RoleBinding<br/>• Still namespace-scoped only"]
    end

    subgraph "Security Notes"
        direction TB
        SecurityNotes["RBAC Security:<br/>• No cluster-level RBAC by default<br/>• Workbenches inherit minimal permissions<br/>• Users cannot escalate to cluster-admin<br/>• OpenShift OAuth enforces user identity<br/>• Service account tokens are namespace-scoped<br/>• ImageStream access is read-only"]
    end

    WorkbenchSA -->|"bound to (auto-created)"| WorkbenchPerms
    PipelineSA -->|"bound to (auto-created)"| PipelinePerms

    WorkbenchPerms -->|"get, list"| ConfigMaps
    WorkbenchPerms -->|"get, list"| Secrets
    WorkbenchPerms -->|"get, list"| Pods
    WorkbenchPerms -->|"get, list"| Services
    WorkbenchPerms -->|"get, list (read-only)"| ImageStreamAccess

    PipelinePerms -->|"get, list, create"| Pods
    PipelinePerms -->|"get, list"| ConfigMaps
    PipelinePerms -->|"get, list"| Secrets

    WorkbenchSA -.->|"optional user-created"| UserRoles
    UserRoles -.->|"grants additional verbs"| ConfigMaps
    UserRoles -.->|"grants additional verbs"| Secrets

    %% Styling
    style WorkbenchSA fill:#4a90e2,color:#fff
    style PipelineSA fill:#7ed321,color:#000
    style WorkbenchPerms fill:#f5a623,color:#000
    style PipelinePerms fill:#f5a623,color:#000
    style ConfigMaps fill:#e1d5e7,color:#000
    style Secrets fill:#e1d5e7,color:#000
    style Pods fill:#e1d5e7,color:#000
    style Services fill:#e1d5e7,color:#000
    style ImageStreamAccess fill:#e1d5e7,color:#000
    style UserRoles fill:#ccc,color:#000
    style SecurityNotes fill:#ffe6cc,color:#000
