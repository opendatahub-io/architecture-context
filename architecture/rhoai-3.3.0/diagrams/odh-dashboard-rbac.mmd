graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Dashboard namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[cluster-monitoring-view<br/>RoleBinding]
    end

    subgraph "ClusterRole: odh-dashboard"
        CR[odh-dashboard<br/>ClusterRole]
    end

    subgraph "System ClusterRoles"
        AuthDelegator[system:auth-delegator<br/>ClusterRole]
        MonitoringView[cluster-monitoring-view<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        CoreRes["Core Resources<br/>━━━━━━━━━━━━━━<br/>configmaps, secrets, pvcs<br/>pods, services, serviceaccounts<br/>namespaces, nodes, endpoints<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph "Storage & Infrastructure"
        Storage["Storage & Machines<br/>━━━━━━━━━━━━━━<br/>storage.k8s.io: storageclasses<br/>machine.openshift.io: machinesets<br/>autoscaling.openshift.io: machineautoscalers<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, update, patch"]
    end

    subgraph "OpenShift Platform"
        OCPRes["OpenShift Resources<br/>━━━━━━━━━━━━━━<br/>config.openshift.io: clusterversions, ingresses<br/>route.openshift.io: routes<br/>console.openshift.io: consolelinks<br/>operator.openshift.io: consoles<br/>user.openshift.io: groups, users<br/>image.openshift.io: imagestreams/layers<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch"]
    end

    subgraph "RBAC Resources"
        RBACRes["RBAC Resources<br/>━━━━━━━━━━━━━━<br/>rbac.authorization.k8s.io:<br/>rolebindings, clusterrolebindings, roles<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, create, patch, delete"]
    end

    subgraph "Operators & CSVs"
        Operators["Operator Resources<br/>━━━━━━━━━━━━━━<br/>operators.coreos.com:<br/>clusterserviceversions, subscriptions<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch"]
    end

    subgraph "ODH Platform CRDs"
        ODHPlatform["ODH Platform<br/>━━━━━━━━━━━━━━<br/>datasciencecluster.opendatahub.io:<br/>  datascienceclusters<br/>dscinitialization.opendatahub.io:<br/>  dscinitializations<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch"]
    end

    subgraph "ML Workload CRDs"
        MLWorkloads["ML Workload CRDs<br/>━━━━━━━━━━━━━━<br/>kubeflow.org: notebooks<br/>serving.kserve.io: inferenceservices<br/>modelregistry.opendatahub.io: modelregistries<br/>feast.dev: featurestores<br/>llamastack.io: llamastackdistributions<br/>nim.opendatahub.io: accounts<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph "Authentication & Authorization"
        AuthZ["Auth Resources<br/>━━━━━━━━━━━━━━<br/>authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews<br/>services.platform.opendatahub.io: auths<br/>━━━━━━━━━━━━━━<br/>Verbs: create, get"]
    end

    subgraph "Hardware & Events"
        HWEvents["Hardware & Events<br/>━━━━━━━━━━━━━━<br/>infrastructure.opendatahub.io: hardwareprofiles<br/>events.k8s.io: events<br/>━━━━━━━━━━━━━━<br/>Verbs: get, list, watch"]
    end

    subgraph "Namespace-scoped Role: odh-dashboard"
        NR["odh-dashboard<br/>Role - Dashboard namespace"]
    end

    subgraph "Namespace Resources"
        NSRes["Namespace Resources<br/>━━━━━━━━━━━━━━<br/>dashboard.opendatahub.io: acceleratorprofiles, odhapplications, odhdocuments<br/>opendatahub.io: odhdashboardconfigs<br/>template.openshift.io: templates<br/>serving.kserve.io: servingruntimes<br/>apps: deployments<br/>apps.openshift.io: deploymentconfigs<br/>build.openshift.io: builds, buildconfigs<br/>image.openshift.io: imagestreams<br/>batch: cronjobs<br/>console.openshift.io: odhquickstarts<br/>━━━━━━━━━━━━━━<br/>Verbs: all on templates & servingruntimes<br/>standard CRUD for others"]
    end

    %% Service Account to Bindings
    SA --> CRB1
    SA --> CRB2
    SA --> CRB3

    %% Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| AuthDelegator
    CRB3 -->|grants| MonitoringView

    %% ClusterRole to Resources
    CR -->|manages| CoreRes
    CR -->|manages| Storage
    CR -->|reads| OCPRes
    CR -->|manages| RBACRes
    CR -->|reads| Operators
    CR -->|reads| ODHPlatform
    CR -->|manages| MLWorkloads
    CR -->|uses| AuthZ
    CR -->|reads| HWEvents

    %% Namespace role
    SA -->|bound via RoleBinding| NR
    NR -->|manages| NSRes

    %% Special delegations
    AuthDelegator -.->|delegates token auth to| K8sAuth[Kubernetes API Server<br/>Token validation]
    MonitoringView -.->|allows metrics from| PromSvc[Prometheus Service<br/>openshift-monitoring]

    %% Styling
