graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User<br/>kubectl/oc client"]
    end

    subgraph K8sLayer["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>RBAC + OAuth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: redhat-ods-operator"]
        direction TB

        subgraph WebhookPod["Webhook Server Pod"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS cert from Service CA<br/>mTLS"]
        end

        subgraph ManagerPods["Operator Manager (3 replicas, leader elected)"]
            Manager1["Manager-1<br/>Leader"]
            Manager2["Manager-2<br/>Standby"]
            Manager3["Manager-3<br/>Standby"]
        end

        subgraph MetricsPod["Metrics Pod"]
            AuthProxy["Auth Proxy<br/>kube-rbac-proxy<br/>8443/TCP<br/>Token validation"]
            MetricsEP["Metrics Endpoint<br/>8080/TCP HTTP"]
            AuthProxy -->|internal| MetricsEP
        end

        HealthProbes["Health Probes<br/>/healthz, /readyz<br/>8081/TCP HTTP<br/>No auth"]
    end

    subgraph ManagedNS["MANAGED NAMESPACES"]
        direction LR

        subgraph AppsNS["redhat-ods-applications"]
            Dashboard["ODH Dashboard"]
            Workbenches["Workbenches"]
            KServe["KServe"]
        end

        subgraph MonNS["redhat-ods-monitoring"]
            Prometheus["Prometheus"]
            Grafana["Grafana"]
        end

        subgraph IstioNS["istio-system (optional)"]
            Istio["Istio Control Plane"]
        end

        subgraph KnativeNS["knative-serving (optional)"]
            Knative["Knative Serving"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitRepos["Component Git Repos<br/>443/TCP HTTPS TLS1.2+<br/>No auth"]
        ContainerReg["Container Registries<br/>443/TCP HTTPS TLS1.2+<br/>Pull secrets"]
        OAuth["OpenShift OAuth<br/>6443/TCP HTTPS TLS1.2+<br/>OAuth token"]
    end

    %% Flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| K8sAPI
    K8sAPI -->|"HTTPS/443→9443<br/>mTLS<br/>Webhook validation"| Webhook
    K8sAPI <-->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token"| Manager1

    Prometheus -->|"HTTP/8443<br/>Bearer token"| AuthProxy
    AuthProxy -->|"TokenReview"| K8sAPI

    Kubelet["Kubelet"] -->|"HTTP/8081<br/>No auth"| HealthProbes

    Manager1 -->|"Creates/manages"| AppsNS
    Manager1 -->|"Creates/manages"| MonNS
    Manager1 -->|"Configures"| IstioNS
    Manager1 -->|"Configures"| KnativeNS

    Manager1 -->|"HTTPS/443<br/>TLS 1.2+"| GitRepos
    Manager1 -->|"HTTPS/443<br/>TLS 1.2+"| ContainerReg
    Manager1 -->|"HTTPS/6443<br/>OAuth"| OAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:3px,color:#fff
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef leader fill:#2ecc71,stroke:#333,stroke-width:2px
    classDef standby fill:#95a5a6,stroke:#333,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalSvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI k8s
    class Webhook,AuthProxy,MetricsEP,HealthProbes operator
    class Manager1 leader
    class Manager2,Manager3 standby
    class Dashboard,Workbenches,KServe,Prometheus,Grafana,Istio,Knative managed
    class GitRepos,ContainerReg,OAuth externalSvc
