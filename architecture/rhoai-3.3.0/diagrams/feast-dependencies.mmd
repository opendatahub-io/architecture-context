    style OpenShift fill:#ee0000,stroke:#333,stroke-width:1px,color:#fff

    %% Internal RHOAI/ODH
    style Routes fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style KubeflowNB fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,stroke-width:2px,color:#fff
