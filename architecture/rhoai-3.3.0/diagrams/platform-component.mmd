    style DSP fill:#4a90e2,stroke:#333,stroke-width:3px
    style Notebooks fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style MLflow fill:#7ed321,stroke:#333,stroke-width:2px
    style Feast fill:#7ed321,stroke:#333,stroke-width:2px
    style Trainer fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainingOperator fill:#f5a623,stroke:#333,stroke-width:2px
    style TrustyAI fill:#bd10e0,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:1px
    style Knative fill:#999,stroke:#333,stroke-width:1px
    style S3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style PostgreSQL fill:#e8e8e8,stroke:#333,stroke-width:1px
