graph TB
    subgraph ControlPlane["Control Plane (redhat-ods-operator)"]
        RHODS[RHODS Operator<br/>v1.6.0]
    end

    subgraph ApplicationLayer["Application Layer (redhat-ods-applications)"]
        Dashboard[ODH Dashboard<br/>v1.21.0<br/>React UI]
        NotebookCtrl[ODH Notebook Controller<br/>v1.27.0]
        ModelCtrl[ODH Model Controller<br/>v1.27.0]
        DSPOp[Data Science Pipelines Operator<br/>v0.0.1]
        ModelRegOp[Model Registry Operator<br/>4fdd8de]
        MLflowOp[MLflow Operator<br/>49b5d8d]
        FeastOp[Feast Operator<br/>98a224e]
        TrainingOp[Training Operator<br/>v1.9.0]
        TrainerOp[Trainer Operator<br/>v2.1.0]
        KubeRayOp[KubeRay Operator<br/>v1.4.2]
        TrustyAIOp[TrustyAI Service Operator<br/>v1.39.0]
        LlamaStackOp[Llama Stack Operator<br/>v0.6.0]
    end

    subgraph WorkloadLayer["Workload Layer (User Namespaces)"]
        Notebooks[Notebooks<br/>JupyterLab/RStudio/VS Code]
        InferenceServices[InferenceServices<br/>Model Serving]
        TrainingJobs[Training Jobs<br/>PyTorch/TensorFlow/JAX]
        Pipelines[ML Pipelines<br/>Argo Workflows]
        FeatureStores[Feature Stores<br/>Feast]
        ModelRegistries[Model Registries]
        MLflowServers[MLflow Tracking Servers]
        RayClusters[Ray Clusters]
        TrustyAIServices[TrustyAI Services]
        LlamaStacks[Llama Stack Servers]
    end

    subgraph ExternalDeps["External Dependencies"]
        Istio[Istio Service Mesh]
        Knative[Knative Serving]
        CertManager[cert-manager]
        S3[S3 Storage]
        Databases[PostgreSQL/MySQL/Redis]
        ContainerReg[Container Registries]
    end

    %% Control Plane relationships
    RHODS -->|manages lifecycle| Dashboard
    RHODS -->|manages lifecycle| NotebookCtrl
    RHODS -->|manages lifecycle| ModelCtrl
    RHODS -->|manages lifecycle| DSPOp
    RHODS -->|manages lifecycle| ModelRegOp
    RHODS -->|manages lifecycle| MLflowOp
    RHODS -->|manages lifecycle| FeastOp
    RHODS -->|manages lifecycle| TrainingOp
    RHODS -->|manages lifecycle| TrainerOp
    RHODS -->|manages lifecycle| KubeRayOp
    RHODS -->|manages lifecycle| TrustyAIOp
    RHODS -->|manages lifecycle| LlamaStackOp

    %% Application Layer to Workload Layer
    Dashboard -->|creates/manages| Notebooks
    Dashboard -->|creates/manages| InferenceServices
    Dashboard -->|creates/manages| Pipelines
    NotebookCtrl -->|deploys| Notebooks
    ModelCtrl -->|extends| InferenceServices
    DSPOp -->|deploys| Pipelines
    ModelRegOp -->|deploys| ModelRegistries
    MLflowOp -->|deploys| MLflowServers
    FeastOp -->|deploys| FeatureStores
    TrainingOp -->|deploys| TrainingJobs
    TrainerOp -->|deploys| TrainingJobs
    KubeRayOp -->|deploys| RayClusters
    TrustyAIOp -->|deploys| TrustyAIServices
    LlamaStackOp -->|deploys| LlamaStacks

    %% Workload integrations
    Notebooks -->|trains models| TrainingJobs
    Notebooks -->|logs experiments| MLflowServers
    Notebooks -->|registers models| ModelRegistries
    Notebooks -->|creates features| FeatureStores
    Pipelines -->|creates| InferenceServices
    Pipelines -->|launches| TrainingJobs
    InferenceServices -->|queries| ModelRegistries
    InferenceServices -->|fetches features| FeatureStores
    TrustyAIServices -->|monitors| InferenceServices
    TrainingJobs -->|stores models| S3
    InferenceServices -->|loads models| S3

    %% External dependencies
    InferenceServices -->|routing/autoscaling| Istio
    InferenceServices -->|routing/autoscaling| Knative
    RHODS -->|TLS certs| CertManager
    ModelRegistries -->|metadata storage| Databases
    MLflowServers -->|metadata storage| Databases
    FeatureStores -->|online/offline stores| Databases
    Pipelines -->|metadata storage| Databases
    Notebooks -->|package downloads| ContainerReg
    TrainingJobs -->|datasets| S3

