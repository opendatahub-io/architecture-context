graph LR
    Trainer[Kubeflow Trainer Operator<br/>v2.1.0]

    %% External Dependencies (Required)
    Trainer -->|orchestration<br/>REQUIRED| Kubernetes[Kubernetes v1.34.1+]
    Trainer -->|multi-node training<br/>REQUIRED| JobSet[JobSet v0.10.1]

    %% External Dependencies (Optional)
    Trainer -.->|gang scheduling<br/>OPTIONAL| Volcano[Volcano Scheduler v1.13.1]
    Trainer -.->|gang scheduling<br/>OPTIONAL| Coscheduling[Coscheduling Plugin v0.34.1]
    Trainer -.->|leader-worker topology<br/>OPTIONAL| LeaderWorkerSet[LeaderWorkerSet latest]
    Trainer -.->|metrics scraping<br/>OPTIONAL RHOAI| PrometheusOp[Prometheus Operator]

    %% Internal ODH Dependencies
    Trainer -->|job queueing<br/>managedBy field| Kueue[Kueue]
    Trainer -.->|secure inter-pod<br/>OPTIONAL| ServiceMesh[OpenShift Service Mesh]
    Trainer -->|controller metrics<br/>PodMonitor| Monitoring[OpenShift Monitoring]

    %% Certificate Management
    Trainer -->|webhook TLS cert<br/>auto-rotation| CertController[cert-controller OPA]

    %% External Services (Training Pods)
    JobSet -->|model storage<br/>AWS IAM auth| S3[S3 Storage]
    JobSet -->|pre-trained models<br/>HF token auth| HuggingFace[HuggingFace Hub]
    JobSet -.->|cloud storage<br/>GCP SA auth| GCS[Google Cloud Storage]

    %% Integration Points
    Dashboard[ODH Dashboard] -.->|UI management<br/>TrainJob CRUD| Trainer
    Pipelines[Data Science Pipelines] -.->|auto deployment<br/>pipeline integration| Trainer
    ModelRegistry[Model Registry] -.->|model metadata<br/>future integration| Trainer

    %% API Server integration
    Trainer -->|CRD watch<br/>resource creation| K8sAPI[Kubernetes API Server]
    JobSet -->|job creation<br/>pod scheduling| K8sAPI

    %% Scheduler integration
    Volcano -.->|PodGroup watch<br/>all-or-nothing| K8sAPI
    Coscheduling -.->|PodGroup watch<br/>all-or-nothing| K8sAPI

    %% Built-in Runtimes
    subgraph Runtimes["Built-in Training Runtimes (RHOAI)"]
        TorchCUDA[torch-distributed<br/>PyTorch CUDA 12.8]
        TorchROCm[torch-distributed-rocm<br/>PyTorch ROCm 6.4]
        TrainingHub[training-hub<br/>HuggingFace Transformers]
        DeepSpeed[deepspeed-distributed<br/>DeepSpeed ZeRO]
        MLX[mlx-distributed<br/>Apple Silicon]
    end

    Trainer -.->|ClusterTrainingRuntime| Runtimes

    %% RHOAI Extensions
    subgraph RHOAIExt["RHOAI Extensions"]
        ProgressTracker[Progression Tracker<br/>Metrics polling]
        NetworkPolicyMgr[Network Policy Manager<br/>Pod isolation]
        PodMonitor[PodMonitor<br/>Controller metrics]
    end

    Trainer --- RHOAIExt

