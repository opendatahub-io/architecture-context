graph LR
    Trainer[Kubeflow Trainer Operator]

    %% External Dependencies (Required)
    Trainer -->|platform| K8s[Kubernetes 1.34.1+]
    Trainer -->|creates JobSets| JobSet[JobSet v0.10.1]

    %% External Dependencies (Optional)
    Trainer -.->|gang scheduling| Volcano[Volcano Scheduler v1.13.1]
    Trainer -.->|gang scheduling| Coscheduling[Coscheduling Plugin v0.34.1]
    Trainer -.->|leader-worker topology| LeaderWorkerSet[LeaderWorkerSet]

    %% Internal ODH Dependencies
    Trainer -->|metrics scraping| Prometheus[OpenShift Monitoring<br/>Prometheus Operator]
    Trainer -.->|queue management| Kueue[Kueue]
    Trainer -.->|mTLS inter-pod| ServiceMesh[OpenShift Service Mesh]

    %% Integration Points
    K8s -->|API server| Trainer
    JobSet -->|creates Jobs/Pods| K8s
    Volcano -->|scheduler plugin| K8s
    Coscheduling -->|scheduler plugin| K8s
    Prometheus -->|PodMonitor| Trainer

    %% External Services
    Trainer -->|training pods access| S3[S3 Storage]
    Trainer -->|training pods access| HF[HuggingFace Hub]

    %% Controller internals
    subgraph "Trainer Components"
        direction TB
        TrainJobCtl[TrainJob Controller]
        RuntimeCtl[TrainingRuntime Controller]
        ProgressTracker[Progression Tracker<br/>RHOAI]
        NetPolicyMgr[NetworkPolicy Manager<br/>RHOAI]
    end

    Trainer -.->|contains| TrainJobCtl
    Trainer -.->|contains| RuntimeCtl
    Trainer -.->|contains| ProgressTracker
    Trainer -.->|contains| NetPolicyMgr

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px
    style K8s fill:#999,stroke:#333,stroke-width:2px
    style JobSet fill:#999,stroke:#333,stroke-width:2px
    style Volcano fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Coscheduling fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style LeaderWorkerSet fill:#ccc,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px
    style Kueue fill:#b8e986,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style ServiceMesh fill:#b8e986,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px
    style HF fill:#f5a623,stroke:#333,stroke-width:2px
    style ProgressTracker fill:#7ed321,stroke:#333,stroke-width:2px
    style NetPolicyMgr fill:#7ed321,stroke:#333,stroke-width:2px
