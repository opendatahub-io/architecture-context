graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Applications /<br/>Training Jobs /<br/>Data Scientists]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Edge TLS)"]
        RouteOnline["Route: {name}-online<br/>443/TCP → 80/443<br/>TLS 1.2+ Edge"]
        RouteOffline["Route: {name}-offline<br/>443/TCP → 80/443<br/>TLS 1.2+ Edge"]
        RouteRegistry["Route: {name}-registry<br/>443/TCP → 80/443<br/>TLS 1.2+ Edge"]
        RouteUI["Route: {name}-ui<br/>443/TCP → 80/443<br/>TLS 1.2+ Edge"]
    end

    subgraph ServiceLayer["SERVICE LAYER (Kubernetes Services)"]
        SvcOnline["Service: {name}-online<br/>ClusterIP<br/>80→6566 (HTTP)<br/>443→6567 (HTTPS)"]
        SvcOffline["Service: {name}-offline<br/>ClusterIP<br/>80→8815 (HTTP)<br/>443→8816 (HTTPS)"]
        SvcRegistry["Service: {name}-registry<br/>ClusterIP<br/>80→6570 (gRPC)<br/>443→6571 (gRPC TLS)"]
        SvcRegistryREST["Service: {name}-registry-rest<br/>ClusterIP<br/>80→6572 (REST)<br/>443→6573 (REST TLS)"]
        SvcUI["Service: {name}-ui<br/>ClusterIP<br/>80→8888 (HTTP)<br/>443→8443 (HTTPS)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Feature Store Pods)"]
        direction TB

        subgraph NS_User["{user-namespace}"]
            OnlinePod["Online Feature Server<br/>SA: {name}-online-sa<br/>Ports: 6566, 6567, 8000<br/>Auth: OIDC/mTLS/RBAC"]
            OfflinePod["Offline Feature Server<br/>SA: {name}-offline-sa<br/>Ports: 8815, 8816, 8000<br/>Auth: OIDC/mTLS"]
            RegistryPod["Registry Server<br/>SA: {name}-registry-sa<br/>Ports: 6570-6573<br/>Auth: OIDC/mTLS/RBAC"]
            UIPod["UI Server<br/>SA: {name}-ui-sa<br/>Ports: 8888, 8443"]
        end
    end

    subgraph Storage["STORAGE BACKENDS (Data Layer)"]
        direction LR
        SQLite[("SQLite (PVC)<br/>Local File")]
        PostgreSQL[("PostgreSQL<br/>5432/TCP<br/>TLS 1.2+<br/>Password Auth")]
        Redis[("Redis<br/>6379/TCP<br/>TLS 1.2+<br/>Password Auth")]
        S3[("S3/Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM")]
    end

    subgraph Operator["OPERATOR CONTROL PLANE (feast-operator-system)"]
        FeastOp["Feast Operator<br/>SA: controller-manager<br/>Metrics: 8443/TCP HTTPS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>SA Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWT Validation"]
        Prometheus["Prometheus<br/>Scrapes: 8000, 8443<br/>HTTP/HTTPS"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer/mTLS| RouteOnline
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer/mTLS| RouteOffline
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer/mTLS| RouteRegistry
    Client -->|HTTPS/443<br/>TLS 1.2+| RouteUI

    %% Ingress to Services
    RouteOnline -->|Edge TLS Term| SvcOnline
    RouteOffline -->|Edge TLS Term| SvcOffline
    RouteRegistry -->|Edge TLS Term| SvcRegistry
    RouteRegistry -->|Edge TLS Term| SvcRegistryREST
    RouteUI -->|Edge TLS Term| SvcUI

    %% Services to Pods
    SvcOnline -->|HTTP/HTTPS| OnlinePod
    SvcOffline -->|HTTP/HTTPS| OfflinePod
    SvcRegistry -->|gRPC/gRPC TLS| RegistryPod
    SvcRegistryREST -->|HTTP/HTTPS| RegistryPod
    SvcUI -->|HTTP/HTTPS| UIPod

    %% Pods to Storage
    OnlinePod -->|TLS 1.2+ optional<br/>Password| PostgreSQL
    OnlinePod -->|TLS 1.2+ optional<br/>Password| Redis
    OnlinePod -->|Local| SQLite
    OnlinePod -->|gRPC<br/>TLS 1.2+| RegistryPod

    OfflinePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    OfflinePod -->|gRPC<br/>TLS 1.2+| RegistryPod

    RegistryPod -->|TLS 1.2+ optional<br/>Password| PostgreSQL
    RegistryPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    RegistryPod -->|Local| SQLite

    UIPod -->|REST API| RegistryPod

    %% Operator flows
    FeastOp -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    FeastOp -.->|creates/manages| OnlinePod
    FeastOp -.->|creates/manages| OfflinePod
    FeastOp -.->|creates/manages| RegistryPod
    FeastOp -.->|creates/manages| UIPod

    %% External Services
    OnlinePod -.->|HTTPS/443<br/>JWT validation| OIDC
    OfflinePod -.->|HTTPS/443<br/>JWT validation| OIDC
    RegistryPod -.->|HTTPS/443<br/>JWT validation| OIDC

    Prometheus -->|HTTP/8000<br/>Scrape metrics| OnlinePod
    Prometheus -->|HTTP/8000<br/>Scrape metrics| OfflinePod
    Prometheus -->|HTTPS/8443<br/>Scrape metrics| FeastOp

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#e1bee7,stroke:#8e24aa,stroke-width:2px
    classDef externalservice fill:#ffccbc,stroke:#e64a19,stroke-width:2px

    class Client external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class SvcOnline,SvcOffline,SvcRegistry,SvcRegistryREST,SvcUI service
    class OnlinePod,OfflinePod,RegistryPod,UIPod application
    class SQLite,PostgreSQL,Redis,S3 storage
    class FeastOp,K8sAPI operator
    class OIDC,Prometheus externalservice
