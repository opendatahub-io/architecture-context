graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        DataScientist[Data Scientist]
        MLApp[ML Application /<br/>Training Job]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        RouteOnline["OpenShift Route<br/>(name)-online<br/>443/TCP → 80/TCP<br/>TLS Edge Termination"]
        RouteOffline["OpenShift Route<br/>(name)-offline<br/>443/TCP → 80/TCP<br/>TLS Edge Termination"]
        RouteRegistry["OpenShift Route<br/>(name)-registry<br/>443/TCP → 80/TCP<br/>TLS Edge Termination"]
        RouteUI["OpenShift Route<br/>(name)-ui<br/>443/TCP → 80/TCP<br/>TLS Edge Termination"]
    end

    subgraph Cluster["INTERNAL CLUSTER NETWORK (Trusted)"]
        direction TB

        subgraph NS_User["Namespace: (user-namespace)"]
            direction TB

            Online["Online Feature Server<br/>Deployment: (name)-online<br/>Image: odh-feature-server<br/>SA: (name)-online<br/><br/>Ports:<br/>6566/TCP HTTP<br/>6567/TCP HTTPS/gRPC TLS1.2+<br/>8000/TCP Metrics<br/><br/>Auth: Bearer/mTLS/K8s RBAC"]

            Offline["Offline Feature Server<br/>Deployment: (name)-offline<br/>Image: odh-feature-server<br/>SA: (name)-offline<br/><br/>Ports:<br/>8815/TCP HTTP<br/>8816/TCP HTTPS TLS1.2+<br/>8000/TCP Metrics<br/><br/>Auth: Bearer/mTLS/K8s RBAC"]

            Registry["Registry Server<br/>Deployment: (name)-registry<br/>Image: odh-feature-server<br/>SA: (name)-registry<br/><br/>Ports:<br/>6570/TCP gRPC<br/>6571/TCP gRPC TLS1.2+<br/>6572/TCP REST HTTP<br/>6573/TCP REST HTTPS<br/><br/>Auth: Bearer/mTLS/K8s RBAC"]

            UI["UI Server<br/>Deployment: (name)-ui<br/>Image: odh-feature-server<br/>SA: (name)-ui<br/><br/>Ports:<br/>8888/TCP HTTP<br/>8443/TCP HTTPS TLS1.2+"]

            CronJob["CronJob<br/>Materialization<br/>Image: origin-cli:4.17<br/>SA: (name)-cronjob"]

            SQLite["(SQLite Database<br/>PVC: (name)-registry - 5Gi<br/>PVC: (name)-online - 5Gi<br/>Encryption: At-rest via PVC)"]
        end

        subgraph NS_Operator["Namespace: feast-operator-system"]
            Operator["Feast Operator<br/>Deployment: feast-operator-controller-manager<br/>Image: odh-feast-operator<br/>SA: controller-manager<br/><br/>Ports:<br/>8443/TCP HTTPS Metrics<br/>8081/TCP HTTP Health"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.3<br/>Auth: Service Account Token"]
    end

    subgraph Storage["STORAGE BACKENDS (External)"]
        PostgreSQL[(PostgreSQL<br/>5432/TCP<br/>Protocol: PostgreSQL<br/>Encryption: TLS 1.2+<br/>Auth: Username/Password)]

        Redis[(Redis<br/>6379/TCP<br/>Protocol: Redis<br/>Encryption: TLS 1.2+<br/>Auth: Password)]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM<br/>Purpose: Offline data, registry"]

        OIDC["OIDC Provider<br/>443/TCP HTTPS TLS1.2+<br/>Purpose: JWT validation"]

        Git["Git Repository<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Token/SSH<br/>Purpose: Feature sync"]

        Prometheus["Prometheus<br/>Scrapes: 8000/TCP, 8443/TCP<br/>Purpose: Metrics"]
    end

    %% External to Ingress
    DataScientist -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteUI
    MLApp -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteOnline
    MLApp -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteOffline
    DataScientist -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteRegistry

    %% Ingress to Internal
    RouteOnline -->|HTTP/80<br/>or HTTPS/443| Online
    RouteOffline -->|HTTP/80<br/>or HTTPS/443| Offline
    RouteRegistry -->|HTTP/80<br/>or HTTPS/443| Registry
    RouteUI -->|HTTP/80<br/>or HTTPS/443| UI

    %% Internal service communication
    Online -->|gRPC 6570/6571<br/>TLS 1.2+ optional<br/>Bearer/mTLS| Registry
    Offline -->|gRPC 6570/6571<br/>TLS 1.2+ optional<br/>Bearer/mTLS| Registry
    CronJob -->|HTTP/6566 or HTTPS/6567<br/>Materialize endpoint| Online
    Online -->|HTTP/8815 or HTTPS/8816<br/>Fetch offline data| Offline

    %% Storage connections
    Online -->|Read/Write| SQLite
    Registry -->|Read/Write| SQLite
    Online -->|PostgreSQL Protocol<br/>5432/TCP TLS1.2+<br/>Password auth| PostgreSQL
    Registry -->|PostgreSQL Protocol<br/>5432/TCP TLS1.2+<br/>Password auth| PostgreSQL
    Online -->|Redis Protocol<br/>6379/TCP TLS1.2+<br/>Password auth| Redis
    Offline -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Registry -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    %% External services
    Online -->|HTTPS/443<br/>Token validation| OIDC
    Offline -->|HTTPS/443<br/>Token validation| OIDC
    Registry -->|HTTPS/443<br/>Token validation| OIDC
    Registry -->|HTTPS/443<br/>TLS 1.2+<br/>Token/SSH| Git
    Prometheus -->|HTTP/8000<br/>Scrape metrics| Online
    Prometheus -->|HTTP/8000<br/>Scrape metrics| Offline
    Prometheus -->|HTTPS/8443<br/>Scrape metrics| Operator

    %% Operator management
    Operator -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    Operator -.->|Manages| Online
    Operator -.->|Manages| Offline
    Operator -.->|Manages| Registry
    Operator -.->|Manages| UI
    Operator -.->|Manages| CronJob

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#333

    class DataScientist,MLApp external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class Online,Offline,Registry,UI,CronJob,SQLite,K8sAPI internal
    class Operator operator
    class PostgreSQL,Redis storage
    class S3,OIDC,Git,Prometheus externalservice
