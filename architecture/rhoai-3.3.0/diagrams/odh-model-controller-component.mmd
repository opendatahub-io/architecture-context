    style MetricsServer fill:#4a90e2
    style HealthServer fill:#4a90e2

    style InferenceServiceCR fill:#f5a623
    style InferenceGraphCR fill:#f5a623
    style AccountCR fill:#f5a623

    style Route fill:#7ed321
    style ServiceMonitor fill:#7ed321
