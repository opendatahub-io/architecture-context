graph TB
    subgraph "odh-model-controller Component"
        Controller[Controller Manager]
        ISController[InferenceService Controller]
        IGController[InferenceGraph Controller]
        SRController[ServingRuntime Controller]
        LLMController[LLM InferenceService Controller]
        NIMController[NIM Account Controller]
        CMController[ConfigMap Controller]
        SecretController[Secret Controller]
        PodController[Pod Controller]
        Webhook[Webhook Server<br/>9443/TCP HTTPS]
        MetricsServer[Metrics Server<br/>8080/TCP HTTP]
        HealthServer[Health Server<br/>8081/TCP HTTP]

        Controller --> ISController
        Controller --> IGController
        Controller --> SRController
        Controller --> LLMController
        Controller --> NIMController
        Controller --> CMController
        Controller --> SecretController
        Controller --> PodController
        Controller --> Webhook
        Controller --> MetricsServer
        Controller --> HealthServer
    end

    subgraph "CRDs Managed"
        AccountCR[Account CR<br/>nim.opendatahub.io/v1]
    end

    subgraph "CRDs Watched"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        InferenceGraphCR[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        LLMInferenceServiceCR[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
        RouteCR[Route<br/>route.openshift.io/v1]
        ServiceMonitorCR[ServiceMonitor<br/>monitoring.coreos.com/v1]
        TriggerAuthCR[TriggerAuthentication<br/>keda.sh/v1alpha1]
    end

    subgraph "Resources Created"
        Route[OpenShift Route]
        NetworkPolicy[NetworkPolicy]
        RBAC[ServiceAccounts<br/>Roles<br/>RoleBindings]
        ServiceMonitor[ServiceMonitor]
        TriggerAuth[TriggerAuthentication]
        EnvoyFilter[EnvoyFilter]
        AuthPolicy[AuthPolicy]
        Template[OpenShift Template<br/>NIM Runtimes]
    end

    subgraph "External Dependencies"
        KServe[KServe v0.15.1]
        K8sAPI[Kubernetes API]
        OpenShift[OpenShift Routes]
        Prometheus[Prometheus Operator]
        KEDA[KEDA v2.x]
        Istio[Istio Service Mesh]
        Kuadrant[Kuadrant]
        NGCAPI[NVIDIA NGC API]
    end

    subgraph "Internal ODH Dependencies"
        ODHOperator[opendatahub-operator]
        ModelRegistry[Model Registry]
    end

    User[User] -->|creates| InferenceServiceCR
    User -->|creates| AccountCR

    InferenceServiceCR -->|watched by| ISController
    InferenceGraphCR -->|watched by| IGController
    ServingRuntimeCR -->|watched by| SRController
    LLMInferenceServiceCR -->|watched by| LLMController
    AccountCR -->|watched by| NIMController

    ISController -->|creates| Route
    ISController -->|creates| NetworkPolicy
    ISController -->|creates| RBAC
    ISController -->|creates| ServiceMonitor
    ISController -->|creates| TriggerAuth
    ISController -->|creates| EnvoyFilter
    ISController -->|creates| AuthPolicy

    NIMController -->|creates| Template
    NIMController -->|validates via| NGCAPI

    Webhook -->|validates/mutates| InferenceServiceCR
    Webhook -->|validates/mutates| InferenceGraphCR
    Webhook -->|validates| AccountCR

    Controller -->|integrates| KServe
    Controller -->|calls| K8sAPI
    Controller -->|integrates| OpenShift
    Controller -->|integrates| Prometheus
    Controller -->|integrates| KEDA
    Controller -->|integrates| Istio
    Controller -->|integrates| Kuadrant

    Controller -->|reads| ODHOperator
    Controller -.->|optional| ModelRegistry

    MetricsServer -->|scraped by| Prometheus

