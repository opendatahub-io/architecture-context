graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
        LeaderElectionRB[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "Roles"
        CR[kuberay-operator<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Pods["core<br/>pods, pods/status, pods/proxy<br/>get, list, watch, create, update, patch, delete"]
        Services["core<br/>services, services/status, services/proxy<br/>get, list, watch, create, update, patch, delete"]
        ConfigMaps["core<br/>configmaps, serviceaccounts, secrets, endpoints, events<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments<br/>get, list, watch, patch, update"]
    end

    subgraph "Batch API Resources"
        Jobs["batch<br/>jobs<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Ray API Resources"
        RayClusters["ray.io<br/>rayclusters, rayclusters/status, rayclusters/finalizers<br/>get, list, watch, create, update, patch, delete"]
        RayJobs["ray.io<br/>rayjobs, rayjobs/status, rayjobs/finalizers<br/>get, list, watch, create, update, patch, delete"]
        RayServices["ray.io<br/>rayservices, rayservices/status, rayservices/finalizers<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Networking API Resources"
        Networking["networking.k8s.io<br/>ingresses, networkpolicies, ingressclasses<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "OpenShift API Resources"
        Routes["route.openshift.io<br/>routes<br/>get, list, watch, create, update, patch, delete"]
        Config["config.openshift.io<br/>authentications, oauths<br/>get, list, watch"]
    end

    subgraph "cert-manager API Resources"
        Certificates["cert-manager.io<br/>certificates, issuers<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Gateway API Resources"
        Gateway["gateway.networking.k8s.io<br/>httproutes, referencegrants, gateways<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "RBAC API Resources"
        RBACResources["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles, clusterrolebindings<br/>get, list, watch, create, update, delete"]
    end

    subgraph "Coordination API Resources"
        Leases["coordination.k8s.io<br/>leases<br/>get, list, create, update"]
    end

    %% Service Account bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderElectionRB

    %% Role bindings
    CRB -->|grants| CR
    LeaderElectionRB -->|grants| LeaderRole

    %% ClusterRole permissions
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Deployments
    CR -->|permissions| Jobs
    CR -->|permissions| RayClusters
    CR -->|permissions| RayJobs
    CR -->|permissions| RayServices
    CR -->|permissions| Networking
    CR -->|permissions| Routes
    CR -->|permissions| Config
    CR -->|permissions| Certificates
    CR -->|permissions| Gateway
    CR -->|permissions| RBACResources
    CR -->|permissions| Leases

    %% Leader election role
    LeaderRole -->|permissions| Leases

