graph TD
    subgraph "Service Account"
        SA[kuberay-operator<br/>Namespace: kuberay-system]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kuberay-operator<br/>ClusterRoleBinding]
        CRB2[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kuberay-operator<br/>ClusterRole]
        LER[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Core"
        CorePods["core/pods<br/>pods/status<br/>pods/proxy"]
        CoreServices["core/services<br/>services/status<br/>services/proxy"]
        CoreConfig["core/serviceaccounts<br/>core/configmaps<br/>core/events<br/>core/secrets<br/>core/endpoints"]
    end

    subgraph "API Resources - Apps & Batch"
        AppsDeployments["apps/deployments"]
        BatchJobs["batch/jobs"]
    end

    subgraph "API Resources - Ray CRDs"
        RayCRDs["ray.io/rayclusters<br/>ray.io/rayjobs<br/>ray.io/rayservices"]
        RayStatus["ray.io/rayclusters/status<br/>ray.io/rayjobs/status<br/>ray.io/rayservices/status"]
        RayFinalizers["ray.io/rayclusters/finalizers<br/>ray.io/rayjobs/finalizers<br/>ray.io/rayservices/finalizers"]
    end

    subgraph "API Resources - Networking"
        Networking["networking.k8s.io/ingresses<br/>networking.k8s.io/networkpolicies<br/>networking.k8s.io/ingressclasses"]
        Routes["route.openshift.io/routes"]
        GatewayAPI["gateway.networking.k8s.io/httproutes<br/>gateway.networking.k8s.io/referencegrants<br/>gateway.networking.k8s.io/gateways"]
    end

    subgraph "API Resources - Certificates"
        Certs["cert-manager.io/certificates<br/>cert-manager.io/issuers"]
    end

    subgraph "API Resources - RBAC"
        RBACResources["rbac.authorization.k8s.io/roles<br/>rbac.authorization.k8s.io/rolebindings<br/>rbac.authorization.k8s.io/clusterroles<br/>rbac.authorization.k8s.io/clusterrolebindings"]
    end

    subgraph "API Resources - Coordination"
        Leases["coordination.k8s.io/leases"]
    end

    subgraph "API Resources - OpenShift Config"
        OSConfig["config.openshift.io/authentications<br/>config.openshift.io/oauths"]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| LER

    %% ClusterRole Permissions - Core
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| CorePods
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| CoreServices
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| CoreConfig

    %% ClusterRole Permissions - Apps & Batch
    CR -->|get, list, watch<br/>patch, update| AppsDeployments
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| BatchJobs

    %% ClusterRole Permissions - Ray CRDs
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| RayCRDs
    CR -->|get, patch, update| RayStatus
    CR -->|update| RayFinalizers

    %% ClusterRole Permissions - Networking
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| Networking
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| Routes
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| GatewayAPI

    %% ClusterRole Permissions - Certificates
    CR -->|get, list, watch<br/>create, update<br/>patch, delete| Certs

    %% ClusterRole Permissions - RBAC
    CR -->|get, list, watch<br/>create, update, delete| RBACResources

    %% ClusterRole Permissions - Coordination
    CR -->|get, list<br/>create, update| Leases

    %% ClusterRole Permissions - OpenShift Config
    CR -->|get, list, watch| OSConfig

    %% Leader Election Role
    LER -->|get, list, create<br/>update| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#7ed321,stroke:#333,stroke-width:2px
    style LER fill:#7ed321,stroke:#333,stroke-width:2px
    style CorePods fill:#e1d5e7,stroke:#333
    style CoreServices fill:#e1d5e7,stroke:#333
    style CoreConfig fill:#e1d5e7,stroke:#333
    style AppsDeployments fill:#e1d5e7,stroke:#333
    style BatchJobs fill:#e1d5e7,stroke:#333
    style RayCRDs fill:#d5e8d4,stroke:#333,stroke-width:2px
    style RayStatus fill:#d5e8d4,stroke:#333,stroke-width:2px
    style RayFinalizers fill:#d5e8d4,stroke:#333,stroke-width:2px
    style Networking fill:#e1d5e7,stroke:#333
    style Routes fill:#e1d5e7,stroke:#333
    style GatewayAPI fill:#e1d5e7,stroke:#333
    style Certs fill:#e1d5e7,stroke:#333
    style RBACResources fill:#e1d5e7,stroke:#333
    style Leases fill:#e1d5e7,stroke:#333
    style OSConfig fill:#e1d5e7,stroke:#333
