graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["data-science-gateway<br/>openshift-ingress namespace<br/>443/TCP → 8443/TCP<br/>TLS 1.3<br/>Path: /mlflow/*"]
        HTTPRoute[HTTPRoute<br/>Gateway API]
    end

    subgraph Platform["APPLICATION LAYER (Trusted)"]
        direction TB

        subgraph NS_Platform["Namespace: opendatahub OR redhat-ods-applications"]
            direction TB

            subgraph Operator["MLflow Operator"]
                OpController["Controller<br/>SA: controller-manager<br/>Go Operator"]
                OpMetrics["Metrics Service<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token Auth"]
                OpHealth["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
            end

            subgraph MLflowInstance["MLflow Server Instance"]
                MLflowPod["MLflow Server Pod<br/>SA: mlflow-sa<br/>Image: mlflow:v3.6.0<br/>UID: 1001 (non-root)<br/>seccomp: RuntimeDefault"]
                MLflowSvc["Service: mlflow<br/>ClusterIP 8443/TCP<br/>HTTPS TLS 1.3<br/>Bearer Token (kubernetes-auth)"]
                MLflowPVC["PersistentVolumeClaim<br/>2Gi (local mode)<br/>sqlite + file storage"]
                MLflowTLS["Secret: mlflow-tls<br/>kubernetes.io/tls<br/>Auto-rotated by service-ca"]
            end

            NetworkPol["NetworkPolicy<br/>Allow TCP/8443<br/>from all namespaces"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+"]
        ServiceCA["service-ca-operator<br/>(OpenShift)<br/>TLS Provisioning"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>Bearer Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional - Production)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Username/Password<br/>Backend/Registry Store"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM/Access Keys<br/>Artifact Storage"]
    end

    %% User Access Flow
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Gateway
    Gateway -->|Path-based routing<br/>/mlflow/*| HTTPRoute
    HTTPRoute -->|HTTPS/8443<br/>TLS 1.3<br/>Bearer Token| MLflowSvc
    MLflowSvc -->|Internal routing| MLflowPod
    MLflowPod -->|self_subject_access_review<br/>HTTPS/6443<br/>SA Token| K8sAPI

    %% Operator Flows
    OpController -->|Watch MLflow CRs<br/>Create/Update resources<br/>HTTPS/6443<br/>SA Token| K8sAPI
    OpController -->|Manages| MLflowPod
    OpController -->|Creates| HTTPRoute

    %% Monitoring
    Prometheus -->|GET /metrics<br/>HTTPS/8443<br/>Bearer Token| OpMetrics

    %% TLS Provisioning
    ServiceCA -.->|Provisions/rotates| MLflowTLS
    MLflowTLS -->|Mounted by| MLflowPod

    %% Storage
    MLflowPVC -->|Mounted at /mlflow| MLflowPod

    %% External Services (Optional)
    MLflowPod -.->|PostgreSQL/5432<br/>TLS 1.2+<br/>User/Pass<br/>Optional| PostgreSQL
    MLflowPod -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>Optional| S3

    %% Network Policy
    NetworkPol -.->|Restricts ingress<br/>to TCP/8443| MLflowSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway,HTTPRoute ingress
    class OpController,OpMetrics,OpHealth,MLflowPod,MLflowSvc,MLflowPVC,MLflowTLS,NetworkPol platform
    class K8sAPI,ServiceCA,Prometheus controlplane
    class PostgreSQL,S3 externalservice

    %% Legend
    subgraph Legend[" "]
        L1["Solid line = Required"]
        L2["Dashed line = Optional"]
    end

    style Legend fill:#f5f5f5,stroke:#ccc,stroke-width:1px
