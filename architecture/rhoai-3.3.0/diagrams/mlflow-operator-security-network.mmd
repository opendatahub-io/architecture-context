graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser /<br/>MLflow Client]
    end

    subgraph Ingress["INGRESS DMZ - OpenShift Router"]
        Gateway["data-science-gateway<br/>openshift-ingress<br/>443/TCP to 8443/TCP<br/>TLS 1.3"]
        HTTPRoute["HTTPRoute<br/>Path: /mlflow/*"]

        Gateway -->|routes via| HTTPRoute
    end

    subgraph AppNamespace["APPLICATION NAMESPACE<br/>opendatahub or redhat-ods-applications"]
        direction TB

        subgraph MLflowWorkload["MLflow Workload"]
            MLflowService["MLflow Service<br/>ClusterIP<br/>8443/TCP HTTPS"]
            MLflowPod["MLflow Pod<br/>Image: quay.io/opendatahub/mlflow:master<br/>SA: mlflow-sa<br/>Non-root UID 1001<br/>Read-only rootfs"]
            TLSSecret["Secret: mlflow-tls<br/>service-ca-operator<br/>Auto-rotate"]

            MLflowService -->|target| MLflowPod
            MLflowPod -.->|mounts| TLSSecret
        end

        subgraph Storage["Storage Optional"]
            PVC["PersistentVolumeClaim<br/>2Gi dev mode"]
            DBSecret["Secret: mlflow-db-credentials<br/>PostgreSQL URI"]
            AWSSecret["Secret: aws-credentials<br/>AWS keys"]

            MLflowPod -.->|mounts| PVC
            MLflowPod -.->|reads| DBSecret
            MLflowPod -.->|reads| AWSSecret
        end

        NetworkPolicy["NetworkPolicy: mlflow<br/>Ingress: Allow TCP/8443<br/>Egress: Allow all"]

        NetworkPolicy -.->|protects| MLflowPod
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE<br/>opendatahub or redhat-ods-applications"]
        direction TB

        Operator["MLflow Operator<br/>Controller Pod<br/>SA: controller-manager<br/>Non-root<br/>Capabilities: ALL dropped<br/>Seccomp: RuntimeDefault"]
        OpMetrics["controller-manager-metrics-service<br/>ClusterIP<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]

        Operator -->|exposes| OpMetrics
    end

    subgraph K8sCluster["KUBERNETES CLUSTER"]
        K8sAPI["Kubernetes API<br/>kubernetes.default.svc<br/>6443/TCP HTTPS TLS1.2+"]
        OSConsole["OpenShift Console<br/>ConsoleLink integration"]
        Prometheus["Prometheus<br/>Metrics collection"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP<br/>TLS 1.2+ optional<br/>Username/Password"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access Keys"]
    end

    %% User flows
    User -->|HTTPS/443<br/>Bearer Token| Gateway
    HTTPRoute -->|HTTPS/8443<br/>Bearer Token| MLflowService

    %% MLflow authentication
    MLflowPod -->|self_subject_access_review<br/>HTTPS/6443<br/>SA Token| K8sAPI

    %% MLflow external dependencies
    MLflowPod -.->|PostgreSQL/5432<br/>TLS optional<br/>User/Pass| PostgreSQL
    MLflowPod -.->|HTTPS/443<br/>TLS1.2+<br/>AWS IAM| S3

    %% Operator flows
    Operator -->|Watch/Create Resources<br/>HTTPS/6443<br/>SA Token| K8sAPI
    Operator -->|Creates| HTTPRoute
    Operator -->|Creates| OSConsole

    %% Monitoring
    Prometheus -->|GET /metrics<br/>HTTPS/8443<br/>Bearer Token| OpMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef appns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway,HTTPRoute ingress
    class MLflowService,MLflowPod,PVC,NetworkPolicy appns
    class Operator,OpMetrics operns
    class K8sAPI,OSConsole,Prometheus k8s
    class PostgreSQL,S3 externalsvc
    class TLSSecret,DBSecret,AWSSecret secret
