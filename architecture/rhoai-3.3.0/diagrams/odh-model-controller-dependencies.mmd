graph LR
    ODHModelController[odh-model-controller<br/>Operator]

    %% External Dependencies - Required
    ODHModelController -->|"extends<br/>(required)"| KServe[KServe v0.15.1]
    ODHModelController -->|"orchestration<br/>(required)"| Kubernetes[Kubernetes v1.11.3+]
    ODHModelController -->|"Routes, Templates<br/>(required)"| OpenShift[OpenShift v4.11+]

    %% External Dependencies - Optional
    ODHModelController -.->|"metrics<br/>(optional)"| PrometheusOp[Prometheus Operator]
    ODHModelController -.->|"autoscaling<br/>(optional)"| KEDA[KEDA v2.x]
    ODHModelController -.->|"webhook certs<br/>(optional)"| CertManager[cert-manager]
    ODHModelController -.->|"auth policies<br/>(optional)"| Kuadrant[Kuadrant]
    ODHModelController -.->|"authorization<br/>(optional)"| Authorino[Authorino]
    ODHModelController -.->|"service mesh<br/>(optional)"| Istio[Istio]

    %% Internal ODH Dependencies
    ODHModelController -->|"config CRDs<br/>(reads)"| ODHOperator[opendatahub-operator<br/>DataScienceCluster<br/>DSCInitialization]
    ODHModelController -.->|"model metadata<br/>(optional)"| ModelRegistry[Model Registry]

    %% External Service Dependencies
    ODHModelController -->|"NIM validation<br/>(API calls)"| NGCAPI[NVIDIA NGC API<br/>443/TCP HTTPS]

    %% KServe Dependencies (context)
    KServe -->|uses| Istio
    KServe -->|uses| KnativeServing[Knative Serving v1.12+]
    KServe -->|integrates| S3[S3 Storage]

    %% Serving Runtime Dependencies
    subgraph ServingRuntimes["Serving Runtime Templates"]
        vLLM[vLLM v0.11.2<br/>CUDA, ROCm, CPU, Gaudi]
        OVMS[OpenVINO Model Server<br/>v2025.4]
        MLServer[MLServer 1.7.1<br/>SKLearn, XGBoost]
        Caikit[Caikit v0.27.7<br/>caikit-nlp v0.5.8]
        TGIS[Text Generation Inference<br/>commit 8a8c55d]
    end

    ODHModelController -.->|"manages templates"| ServingRuntimes

    %% Resource Creation
    subgraph ResourcesCreated["Resources Created/Managed"]
        Routes[OpenShift Routes]
        NetworkPolicies[NetworkPolicies]
        RBACResources[RBAC<br/>ServiceAccounts<br/>Roles<br/>RoleBindings]
        ServiceMonitors[ServiceMonitors<br/>PodMonitors]
        TriggerAuths[TriggerAuthentications]
        EnvoyFilters[EnvoyFilters]
        AuthPolicies[AuthPolicies]
        NIMTemplates[NIM Templates]
    end

    ODHModelController -.->|creates| ResourcesCreated

    %% Styling
    style ODHModelController fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External - Required
    style KServe fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style Kubernetes fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style OpenShift fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff

    %% External - Optional
    style PrometheusOp fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style KEDA fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style CertManager fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Kuadrant fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Authorino fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Istio fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    %% External Services
    style NGCAPI fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    %% KServe dependencies
    style KnativeServing fill:#999,stroke:#333,stroke-width:1px,color:#fff

    %% Serving Runtimes
    style ServingRuntimes fill:#e8e8e8,stroke:#333,stroke-width:2px
    style vLLM fill:#fff,stroke:#666,stroke-width:1px
    style OVMS fill:#fff,stroke:#666,stroke-width:1px
    style MLServer fill:#fff,stroke:#666,stroke-width:1px
    style Caikit fill:#fff,stroke:#666,stroke-width:1px
    style TGIS fill:#fff,stroke:#666,stroke-width:1px

    %% Resources Created
    style ResourcesCreated fill:#d5e8d4,stroke:#333,stroke-width:2px
    style Routes fill:#fff,stroke:#666,stroke-width:1px
    style NetworkPolicies fill:#fff,stroke:#666,stroke-width:1px
    style RBACResources fill:#fff,stroke:#666,stroke-width:1px
    style ServiceMonitors fill:#fff,stroke:#666,stroke-width:1px
    style TriggerAuths fill:#fff,stroke:#666,stroke-width:1px
    style EnvoyFilters fill:#fff,stroke:#666,stroke-width:1px
    style AuthPolicies fill:#fff,stroke:#666,stroke-width:1px
    style NIMTemplates fill:#fff,stroke:#666,stroke-width:1px
