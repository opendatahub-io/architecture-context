graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Clients<br/>Data Scientists, Applications"]
    end

    subgraph Ingress["INGRESS LAYER (DMZ)"]
        Router["OpenShift Router / Gateway<br/>443/TCP HTTPS TLS 1.2+<br/>TLS Termination/Reencrypt"]
        Gateway["data-science-gateway<br/>Gateway API HTTPRoute<br/>TLS 1.3"]
    end

    subgraph ControlPlane["CONTROL PLANE (redhat-ods-operator)"]
        RHODS["RHODS Operator<br/>SA: rhods-operator-controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Webhooks: 9443/TCP HTTPS TLS<br/>Replicas: 3 (leader election)"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER (redhat-ods-applications)"]
        Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>8443/TCP HTTPS<br/>kube-rbac-proxy OAuth<br/>Replicas: 2"]
        NotebookCtrl["Notebook Controller<br/>SA: odh-notebook-controller<br/>Metrics: 8080/TCP HTTP<br/>Webhooks: 9443/TCP HTTPS"]
        ModelCtrl["Model Controller<br/>SA: odh-model-controller<br/>Metrics: 8080/TCP HTTP"]
        Operators["Component Operators<br/>Model Registry, MLflow, Feast,<br/>Training, Trainer, KubeRay,<br/>TrustyAI, Llama Stack, DSP<br/>Metrics: 8080/8443 TCP"]
    end

    subgraph UserWorkloads["USER WORKLOAD NAMESPACES (Multi-tenant)"]
        direction TB

        subgraph NSNotebooks["Notebooks"]
            Notebook["Jupyter/RStudio/VS Code<br/>SA: {notebook-name}<br/>OAuth Proxy: 8443/TCP HTTPS<br/>App: 8080/TCP HTTP<br/>HTTPRoute: /notebook/{ns}/{name}<br/>NetworkPolicy: Gateway ingress only"]
        end

        subgraph NSInference["InferenceServices"]
            InferenceService["KServe Predictor<br/>SA: {isvc}-sa<br/>8000/TCP HTTP/HTTPS<br/>Istio mTLS (PERMISSIVE/STRICT)<br/>Knative autoscaling<br/>NetworkPolicy: Istio Gateway ingress"]
        end

        subgraph NSTraining["Training Jobs"]
            TrainingJob["PyTorchJob/TrainJob<br/>SA: {job}-sa<br/>Multi-node gang scheduling<br/>Inter-worker: TCP (no encryption)<br/>NetworkPolicy: Pod-to-pod within job"]
        end

        subgraph NSPipelines["ML Pipelines"]
            Pipeline["Argo Workflows<br/>SA: pipeline-runner<br/>API: 8888/TCP HTTP (Bearer)<br/>NetworkPolicy: API, S3 egress"]
        end

        subgraph NSRegistry["Model Registry"]
            ModelReg["Model Registry<br/>SA: {registry}-sa<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Route: {registry}-{ns}.apps.cluster"]
        end

        subgraph NSMLflow["MLflow"]
            MLflow["MLflow Server<br/>SA: {mlflow}-sa<br/>8443/TCP HTTPS<br/>K8s auth kube-rbac-proxy<br/>HTTPRoute: /mlflow/*"]
        end

        subgraph NSFeast["Feast"]
            Feast["Feast Feature Store<br/>SA: {feast}-sa<br/>Online: 6566/TCP gRPC/HTTP<br/>Offline: 8815/TCP HTTP<br/>Auth: Bearer/mTLS optional"]
        end

        subgraph NSTrustyAI["TrustyAI"]
            TrustyAI["TrustyAI Service<br/>SA: {trustyai}-sa<br/>8080/TCP HTTPS<br/>Istio mTLS<br/>Monitors InferenceServices"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM/Access Keys"]
        DB["PostgreSQL/MySQL/Redis<br/>5432/3306/6379 TCP<br/>Auth: Username/Password<br/>TLS optional"]
        ContainerReg["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secret"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Token"]
        NGC["NVIDIA NGC<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: NGC API Key"]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional - Istio)"]
        Istio["Istio Control Plane<br/>Namespace: istio-system<br/>mTLS: PERMISSIVE/STRICT<br/>VirtualServices, DestinationRules<br/>AuthorizationPolicies"]
    end

    %% External to Ingress
    Client -->|HTTPS/443 TLS 1.2+<br/>OAuth Bearer Token| Router
    Client -->|HTTPS/443 TLS 1.3<br/>OAuth Bearer Token| Gateway

    %% Ingress to Application Layer
    Router -->|HTTPS/8443 Reencrypt<br/>OAuth token| Dashboard
    Gateway -->|HTTPS/8443 TLS 1.3<br/>OAuth token| Notebook
    Gateway -->|HTTPS/8443 TLS 1.3<br/>K8s auth| MLflow
    Router -->|HTTPS/8000 Edge/Passthrough<br/>Bearer optional| InferenceService

    %% Control Plane to Application Layer
    RHODS -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Dashboard
    RHODS -->|Kubernetes API HTTPS/443<br/>SA JWT Token| NotebookCtrl
    RHODS -->|Kubernetes API HTTPS/443<br/>SA JWT Token| ModelCtrl
    RHODS -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Operators

    %% Application Layer to User Workloads
    Dashboard -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Notebook
    Dashboard -->|Kubernetes API HTTPS/443<br/>SA JWT Token| InferenceService
    Dashboard -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Pipeline
    NotebookCtrl -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Notebook
    ModelCtrl -->|Kubernetes API HTTPS/443<br/>SA JWT Token| InferenceService
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| ModelReg
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| MLflow
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Feast
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| TrainingJob
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| TrustyAI
    Operators -->|Kubernetes API HTTPS/443<br/>SA JWT Token| Pipeline

    %% User Workload Integrations
    Notebook -->|HTTPS/8443<br/>K8s auth| MLflow
    Notebook -->|HTTPS/8443<br/>kube-rbac-proxy| ModelReg
    TrainingJob -->|HTTPS/8443<br/>K8s auth| MLflow
    Pipeline -->|Kubernetes API HTTPS/443<br/>SA JWT| InferenceService
    Pipeline -->|Kubernetes API HTTPS/443<br/>SA JWT| TrainingJob
    InferenceService -->|HTTPS/8443<br/>kube-rbac-proxy| ModelReg
    InferenceService -->|HTTP/6566 gRPC<br/>Bearer/mTLS| Feast
    TrustyAI -->|HTTP/8000 mTLS<br/>Service Identity| InferenceService

    %% User Workloads to External Services
    Notebook -->|HTTPS/443 TLS 1.2+<br/>AWS IAM/Keys| S3
    Notebook -->|HTTPS/443 TLS 1.2+<br/>API Token| HuggingFace
    Notebook -->|HTTPS/443 TLS 1.2+<br/>None| ContainerReg
    InferenceService -->|HTTPS/443 TLS 1.2+<br/>AWS IAM/Keys| S3
    TrainingJob -->|HTTPS/443 TLS 1.2+<br/>AWS IAM/Keys| S3
    TrainingJob -->|HTTPS/443 TLS 1.2+<br/>API Token| HuggingFace
    Pipeline -->|HTTPS/443 TLS 1.2+<br/>AWS IAM/Keys| S3
    ModelReg -->|PostgreSQL/5432<br/>Username/Password<br/>TLS optional| DB
    MLflow -->|PostgreSQL/5432<br/>Username/Password<br/>TLS optional| DB
    MLflow -->|HTTPS/443 TLS 1.2+<br/>AWS IAM/Keys| S3
    Feast -->|PostgreSQL/5432, Redis/6379<br/>Username/Password<br/>TLS optional| DB
    TrustyAI -->|PostgreSQL/5432<br/>Username/Password<br/>TLS optional| DB
    Pipeline -->|MySQL/3306<br/>Username/Password<br/>TLS optional| DB
    ModelCtrl -->|HTTPS/443 TLS 1.2+<br/>NGC API Key| NGC

    %% Service Mesh
    Istio -.->|mTLS Workload Certs<br/>Auto-rotation| InferenceService
    Istio -.->|mTLS Workload Certs<br/>Auto-rotation| TrustyAI
    Istio -.->|mTLS Workload Certs<br/>Auto-rotation| Pipeline

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef controlplane fill:#e74c3c,stroke:#c0392b,stroke-width:3px,color:#fff
    classDef application fill:#3498db,stroke:#2980b9,stroke-width:3px,color:#fff
    classDef workload fill:#2ecc71,stroke:#27ae60,stroke-width:2px,color:#fff
    classDef externalservice fill:#f39c12,stroke:#e67e22,stroke-width:2px
    classDef servicemesh fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff

    class Client external
    class Router,Gateway ingress
    class RHODS controlplane
    class Dashboard,NotebookCtrl,ModelCtrl,Operators application
    class Notebook,InferenceService,TrainingJob,Pipeline,ModelReg,MLflow,Feast,TrustyAI workload
    class S3,DB,ContainerReg,HuggingFace,NGC externalservice
    class Istio servicemesh
