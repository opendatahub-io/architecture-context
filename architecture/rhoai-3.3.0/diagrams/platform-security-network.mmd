graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS LAYER (DMZ)"]
        Router["OpenShift Router<br/>Gateway API<br/>443/TCP HTTPS<br/>TLS 1.2+ (edge/reencrypt)<br/>OAuth"]
        IstioGW["Istio Gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ SIMPLE<br/>RequestAuthentication"]
    end

    subgraph PlatformNS["APPLICATION LAYER - Namespace: redhat-ods-applications"]
        direction TB

        Dashboard["ODH Dashboard<br/>8443/TCP HTTPS<br/>OAuth Proxy<br/>SA: odh-dashboard"]
        MLflow["MLflow Server<br/>8443/TCP HTTPS<br/>TLS 1.3<br/>kube-rbac-proxy<br/>SA: mlflow"]
        ModelRegistry["Model Registry<br/>8443/8080/TCP HTTPS/HTTP<br/>TLS 1.2+ (reencrypt)<br/>kube-rbac-proxy<br/>SA: model-registry-{name}"]
        Feast["Feast Servers<br/>6566/6572/8815/TCP HTTP/HTTPS<br/>Optional mTLS<br/>Bearer/OIDC Auth"]
        Operators["Platform Operators<br/>(KServe, DSP, Trainer, etc.)<br/>ServiceAccount Tokens"]
    end

    subgraph UserNS["APPLICATION LAYER - Namespace: {user-namespace}"]
        direction TB

        Notebook["Notebook StatefulSet<br/>8888/TCP HTTP<br/>OAuth Proxy Sidecar<br/>SA: {notebook-name}"]
        Predictor["InferenceService Pod<br/>8080/TCP HTTP<br/>mTLS PERMISSIVE<br/>SA: {isvc-name}-sa"]
        TrainJob["TrainJob Pods<br/>Multi-node Training<br/>NCCL inter-pod<br/>NetworkPolicy Isolated<br/>SA: trainjob-{name}"]
        DSPPods["Data Science Pipeline<br/>Argo Workflow Pods<br/>Per-step Pods<br/>SA: pipeline-runner"]
        TrustyAI["TrustyAI Service<br/>8080/TCP Metrics<br/>Monitors InferenceServices<br/>Prometheus Integration"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM IRSA / Access Keys"]
        PostgreSQL["PostgreSQL/MySQL<br/>External Databases<br/>5432/3306/TCP<br/>TLS<br/>Username/Password"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF API Token optional"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>NGC API Key"]
        PyPI["PyPI / Registries<br/>pypi.org, quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Public / Pull Secrets"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Tokens"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| Router
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Optional Bearer| IstioGW

    %% Ingress to Platform
    Router -->|HTTPS/8443<br/>TLS reencrypt| Dashboard
    Router -->|HTTPS/8443<br/>TLS 1.3| MLflow
    Router -->|HTTPS/8443<br/>TLS reencrypt| ModelRegistry
    Router -->|HTTP/8888<br/>OAuth Proxy| Notebook
    Router -->|HTTPS/443<br/>Optional TLS| Feast

    IstioGW -->|HTTP/8080<br/>mTLS PERMISSIVE| Predictor

    %% Platform Components to K8s API
    Dashboard -->|HTTPS/6443<br/>User Impersonation<br/>Bearer Token| K8sAPI
    Operators -->|HTTPS/6443<br/>ServiceAccount Token| K8sAPI
    Notebook -->|HTTPS/6443<br/>Bearer Token| K8sAPI
    DSPPods -->|HTTPS/6443<br/>ServiceAccount Token| K8sAPI

    %% Platform to External Services
    MLflow -->|PostgreSQL/5432<br/>TLS<br/>DB Password| PostgreSQL
    MLflow -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    ModelRegistry -->|PostgreSQL/MySQL<br/>5432/3306<br/>TLS<br/>DB Password| PostgreSQL

    Feast -->|PostgreSQL/5432<br/>TLS<br/>DB Password| PostgreSQL
    Feast -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    %% User Namespace to Platform
    Notebook -->|HTTPS/5000<br/>Bearer Token| MLflow
    Notebook -->|HTTPS/8443<br/>Bearer Token| ModelRegistry
    Notebook -->|HTTP/6566<br/>Bearer/mTLS| Feast
    Notebook -->|HTTPS/443<br/>TLS 1.2+| S3
    Notebook -->|HTTPS/443<br/>TLS 1.2+| PyPI
    Notebook -->|HTTPS/443<br/>TLS 1.2+| HuggingFace

    %% Predictor to External
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials IRSA| S3
    Predictor -->|HTTP/6566<br/>Bearer/mTLS| Feast

    %% TrainJob to External
    TrainJob -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HuggingFace
    TrainJob -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    TrainJob -->|HTTPS/5000<br/>Bearer Token| MLflow
    TrainJob -->|NCCL<br/>Plaintext<br/>Inter-pod| TrainJob

    %% DSP Pods
    DSPPods -->|HTTPS/443<br/>TLS 1.2+| S3
    DSPPods -->|Create InferenceService| K8sAPI

    %% TrustyAI
    TrustyAI -->|Monitor Metrics| Predictor
    TrustyAI -->|PostgreSQL/5432<br/>TLS| PostgreSQL

    %% Model Controller (NGC)
    Operators -->|HTTPS/443<br/>TLS 1.2+<br/>NGC API Key| NGC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#333
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef userNS fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class Client external
    class Router,IstioGW ingress
    class Dashboard,MLflow,ModelRegistry,Feast,Operators platform
    class Notebook,Predictor,TrainJob,DSPPods,TrustyAI userNS
    class S3,PostgreSQL,HuggingFace,NGC,PyPI,K8sAPI externalService
