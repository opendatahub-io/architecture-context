graph TD
    subgraph Operator["DSPO Operator - Cluster-scoped"]
        direction LR
        SA_Controller["ServiceAccount<br/>controller-manager"]
        CRB_Manager["ClusterRoleBinding<br/>manager-rolebinding"]
        CR_Manager["ClusterRole<br/>manager-role"]
    end

    subgraph NamespaceScope["DSPA Instance - Namespace-scoped Service Accounts"]
        direction LR
        SA_API["ServiceAccount<br/>ds-pipeline-NAME"]
        SA_Persist["ServiceAccount<br/>ds-pipeline-persistenceagent-NAME"]
        SA_Scheduled["ServiceAccount<br/>ds-pipeline-scheduledworkflow-NAME"]
        SA_Argo["ServiceAccount<br/>ds-pipeline-argo-NAME"]
        SA_Runner["ServiceAccount<br/>pipeline-runner-NAME"]
    end

    subgraph Bindings["DSPA Instance - Role Bindings"]
        direction LR
        RB_API["RoleBinding<br/>ds-pipeline-NAME"]
        RB_Persist["RoleBinding<br/>ds-pipeline-persistenceagent-NAME"]
        RB_Scheduled["RoleBinding<br/>ds-pipeline-scheduledworkflow-NAME"]
        RB_Argo["RoleBinding<br/>argo-NAME"]
        RB_Runner["RoleBinding<br/>pipeline-runner-NAME"]
    end

    subgraph NSRoles["DSPA Instance - Roles"]
        direction LR
        R_API["Role<br/>ds-pipeline-NAME"]
        R_Persist["Role<br/>ds-pipeline-persistenceagent-NAME"]
        R_Scheduled["Role<br/>ds-pipeline-scheduledworkflow-NAME"]
        R_Argo["Role<br/>ds-pipeline-argo-role-NAME"]
        R_Runner["Role<br/>ds-pipeline-pipeline-runner-role-NAME"]
    end

    subgraph ClusterResources["API Resources - Cluster-scoped CRDs"]
        direction TB
        DSPA_CR["datasciencepipelinesapplications<br/>opendatahub.io"]
        Pipeline_CR["pipelines<br/>kubeflow.org"]
        PipelineVersion_CR["pipelineversions<br/>kubeflow.org"]
        Workflow_CR["workflows<br/>argoproj.io"]
        ScheduledWorkflow_CR["scheduledworkflows<br/>kubeflow.org"]
        Routes["routes<br/>route.openshift.io"]
        NetworkPolicies["networkpolicies<br/>networking.k8s.io"]
        ServiceMonitors["servicemonitors<br/>monitoring.coreos.com"]
        InferenceServices["inferenceservices<br/>serving.kserve.io"]
    end

    subgraph NSResources["API Resources - Namespace-scoped"]
        direction TB
        ConfigMaps["configmaps"]
        Secrets["secrets"]
        ServiceAccounts["serviceaccounts"]
        PVCs["persistentvolumeclaims"]
        Services["services"]
        Pods["pods<br/>pods/exec<br/>pods/log"]
        Deployments["deployments<br/>apps"]
        ReplicaSets["replicasets<br/>apps"]
        Jobs["jobs<br/>batch"]
        RBACRoles["roles<br/>rbac.authorization.k8s.io"]
        RBACBindings["rolebindings<br/>rbac.authorization.k8s.io"]
        ClusterRolesDef["clusterroles<br/>rbac.authorization.k8s.io"]
        ClusterRoleBindingsDef["clusterrolebindings<br/>rbac.authorization.k8s.io"]
    end

    %% DSPO Controller bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    %% DSPO Controller permissions - CRDs
    CR_Manager -->|all verbs| DSPA_CR
    CR_Manager -->|all verbs| Pipeline_CR
    CR_Manager -->|all verbs| PipelineVersion_CR
    CR_Manager -->|all verbs| Workflow_CR
    CR_Manager -->|all verbs| ScheduledWorkflow_CR
    CR_Manager -->|all verbs| Routes
    CR_Manager -->|all verbs| NetworkPolicies
    CR_Manager -->|all verbs| ServiceMonitors
    CR_Manager -->|create,delete,get,list,patch| InferenceServices

    %% DSPO Controller permissions - Core resources
    CR_Manager -->|all verbs| ConfigMaps
    CR_Manager -->|all verbs| Secrets
    CR_Manager -->|all verbs| ServiceAccounts
    CR_Manager -->|all verbs| PVCs
    CR_Manager -->|all verbs| Services
    CR_Manager -->|get,list,delete| Pods
    CR_Manager -->|all verbs| Deployments
    CR_Manager -->|all verbs| ReplicaSets
    CR_Manager -->|all verbs| Jobs
    CR_Manager -->|all verbs| RBACRoles
    CR_Manager -->|all verbs| RBACBindings
    CR_Manager -->|all verbs| ClusterRolesDef
    CR_Manager -->|all verbs| ClusterRoleBindingsDef

    %% API Server bindings and permissions
    SA_API -->|bound via| RB_API
    RB_API -->|grants| R_API
    R_API -->|get,list,watch| ConfigMaps
    R_API -->|get,list,watch| Secrets
    R_API -->|get,list,watch| Services

    %% Persistence Agent bindings and permissions
    SA_Persist -->|bound via| RB_Persist
    RB_Persist -->|grants| R_Persist
    R_Persist -->|watch| Workflow_CR
    R_Persist -->|update| ConfigMaps

    %% Scheduled Workflow Controller bindings and permissions
    SA_Scheduled -->|bound via| RB_Scheduled
    RB_Scheduled -->|grants| R_Scheduled
    R_Scheduled -->|watch| ScheduledWorkflow_CR
    R_Scheduled -->|create| Workflow_CR

    %% Argo Controller bindings and permissions
    SA_Argo -->|bound via| RB_Argo
    RB_Argo -->|grants| R_Argo
    R_Argo -->|watch,manage| Workflow_CR
    R_Argo -->|create,manage| Pods
    R_Argo -->|manage| ConfigMaps

    %% Pipeline Runner bindings and permissions
    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -->|execute tasks| Pods
    R_Runner -->|access| Secrets
    R_Runner -->|access| ConfigMaps

    %% Styling - Service Accounts
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style SA_API fill:#4a90e2,stroke:#333
    style SA_Persist fill:#4a90e2,stroke:#333
    style SA_Scheduled fill:#4a90e2,stroke:#333
    style SA_Argo fill:#4a90e2,stroke:#333
    style SA_Runner fill:#4a90e2,stroke:#333

    %% Styling - Roles
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:3px
    style R_API fill:#f5a623,stroke:#333
    style R_Persist fill:#f5a623,stroke:#333
    style R_Scheduled fill:#f5a623,stroke:#333
    style R_Argo fill:#f5a623,stroke:#333
    style R_Runner fill:#f5a623,stroke:#333

    %% Styling - RoleBindings
    style CRB_Manager fill:#50e3c2,stroke:#333,stroke-width:2px
    style RB_API fill:#50e3c2,stroke:#333
    style RB_Persist fill:#50e3c2,stroke:#333
    style RB_Scheduled fill:#50e3c2,stroke:#333
    style RB_Argo fill:#50e3c2,stroke:#333
    style RB_Runner fill:#50e3c2,stroke:#333

    %% Styling - CRDs
    style DSPA_CR fill:#7ed321,stroke:#333
    style Pipeline_CR fill:#7ed321,stroke:#333
    style PipelineVersion_CR fill:#7ed321,stroke:#333
    style Workflow_CR fill:#7ed321,stroke:#333
    style ScheduledWorkflow_CR fill:#7ed321,stroke:#333
