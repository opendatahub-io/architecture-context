graph TD
    subgraph "Cluster-Scoped RBAC"
        direction TB

        OperatorSA["ServiceAccount<br/>controller-manager<br/>Namespace: dspo-operator"]

        ClusterRoleBinding["ClusterRoleBinding<br/>manager-rolebinding"]

        ClusterRole["ClusterRole<br/>manager-role"]

        subgraph "ClusterRole Permissions"
            direction LR

            DSPA_APIs["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>datasciencepipelinesapplications/finalizers<br/>datasciencepipelinesapplications/status<br/>Verbs: create, delete, get, list, patch, update, watch"]

            KFP_APIs["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>Verbs: create, delete, get, list, patch, update, watch"]

            Argo_APIs["argoproj.io<br/>workflows, workflowartifactgctasks, workflowtaskresults<br/>Verbs: create, delete, get, list, patch, update, watch, *"]

            Core_Resources["Core Resources<br/>configmaps, secrets, serviceaccounts, pvcs, services<br/>pods, pods/exec, pods/log<br/>Verbs: create, delete, get, list, patch, update, watch, *"]

            Apps_Resources["apps<br/>deployments, replicasets<br/>Verbs: create, delete, get, list, patch, update, watch, *"]

            RBAC_Resources["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles, clusterrolebindings<br/>Verbs: create, delete, get, list, patch, update, watch"]

            Route_Resources["route.openshift.io<br/>routes<br/>Verbs: create, delete, get, list, patch, update, watch"]

            Network_Resources["networking.k8s.io<br/>networkpolicies<br/>Verbs: create, delete, get, list, patch, update, watch"]

            Monitoring_Resources["monitoring.coreos.com<br/>servicemonitors<br/>Verbs: create, delete, get, list, patch, update, watch"]

            KServe_Resources["serving.kserve.io<br/>inferenceservices<br/>Verbs: create, delete, get, list, patch"]

            Batch_Resources["batch<br/>jobs<br/>Verbs: create, delete, get, list, patch, update, watch, *"]

            Webhook_Resources["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>Verbs: create, delete, get, list, patch, update, watch"]
        end

        AggregateRole["ClusterRole<br/>aggregate-dspa-admin-view<br/>Label: rbac.authorization.k8s.io/aggregate-to-admin"]
    end

    subgraph "Namespace-Scoped RBAC (Per DSPA Instance)"
        direction TB

        subgraph "API Server"
            APISvcAcct["ServiceAccount<br/>ds-pipeline-NAME"]
            APIRole["Role<br/>ds-pipeline-NAME"]
            APIRoleBinding["RoleBinding<br/>rolebinding.ds-pipeline-NAME"]
        end

        subgraph "Persistence Agent"
            PersAgentSvcAcct["ServiceAccount<br/>ds-pipeline-persistenceagent-NAME"]
            PersAgentRole["Role<br/>ds-pipeline-persistenceagent-NAME"]
            PersAgentRoleBinding["RoleBinding<br/>rolebinding.ds-pipeline-persistenceagent-NAME"]
        end

        subgraph "Scheduled Workflow Controller"
            SchedulerSvcAcct["ServiceAccount<br/>ds-pipeline-scheduledworkflow-NAME"]
            SchedulerRole["Role<br/>ds-pipeline-scheduledworkflow-NAME"]
            SchedulerRoleBinding["RoleBinding<br/>rolebinding.ds-pipeline-scheduledworkflow-NAME"]
        end

        subgraph "Argo Workflow Controller"
            ArgoSvcAcct["ServiceAccount<br/>ds-pipeline-argo-NAME"]
            ArgoRole["Role<br/>ds-pipeline-argo-role-NAME"]
            ArgoRoleBinding["RoleBinding<br/>rolebinding.argo-NAME"]
        end

        subgraph "Pipeline Runner (Task Execution)"
            RunnerSvcAcct["ServiceAccount<br/>pipeline-runner-NAME"]
            RunnerRole["Role<br/>ds-pipeline-pipeline-runner-role-NAME"]
            RunnerRoleBinding["RoleBinding<br/>rolebinding.pipeline-runner-NAME"]
        end
    end

    subgraph "Kubernetes Resources"
        direction LR

        K8s_DSPA["DSPA CRs"]
        K8s_Pipelines["Pipeline/PipelineVersion CRs"]
        K8s_Workflows["Workflow CRs"]
        K8s_Pods["Pods"]
        K8s_Deployments["Deployments"]
        K8s_Services["Services"]
        K8s_ConfigMaps["ConfigMaps"]
        K8s_Secrets["Secrets"]
        K8s_Routes["Routes"]
        K8s_NetworkPolicies["NetworkPolicies"]
        K8s_ServiceMonitors["ServiceMonitors"]
        K8s_Jobs["Jobs"]
    end

    %% Cluster-scoped bindings
    OperatorSA -->|bound via| ClusterRoleBinding
    ClusterRoleBinding -->|grants| ClusterRole

    ClusterRole -->|permissions| DSPA_APIs
    ClusterRole -->|permissions| KFP_APIs
    ClusterRole -->|permissions| Argo_APIs
    ClusterRole -->|permissions| Core_Resources
    ClusterRole -->|permissions| Apps_Resources
    ClusterRole -->|permissions| RBAC_Resources
    ClusterRole -->|permissions| Route_Resources
    ClusterRole -->|permissions| Network_Resources
    ClusterRole -->|permissions| Monitoring_Resources
    ClusterRole -->|permissions| KServe_Resources
    ClusterRole -->|permissions| Batch_Resources
    ClusterRole -->|permissions| Webhook_Resources

    %% Cluster role to resources
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_DSPA
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_Pipelines
    ClusterRole -->|create, delete, get, list, patch, update, watch, *| K8s_Workflows
    ClusterRole -->|create, delete, get, list, patch, update, watch, *| K8s_Pods
    ClusterRole -->|create, delete, get, list, patch, update, watch, *| K8s_Deployments
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_Services
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_ConfigMaps
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_Secrets
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_Routes
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_NetworkPolicies
    ClusterRole -->|create, delete, get, list, patch, update, watch| K8s_ServiceMonitors
    ClusterRole -->|create, delete, get, list, patch, update, watch, *| K8s_Jobs

    %% Namespace-scoped bindings - API Server
    APISvcAcct -->|bound via| APIRoleBinding
    APIRoleBinding -->|grants| APIRole
    APIRole -->|namespace-scoped permissions| K8s_Pods
    APIRole -->|namespace-scoped permissions| K8s_Workflows

    %% Namespace-scoped bindings - Persistence Agent
    PersAgentSvcAcct -->|bound via| PersAgentRoleBinding
    PersAgentRoleBinding -->|grants| PersAgentRole
    PersAgentRole -->|watch workflows| K8s_Workflows
    PersAgentRole -->|update status| K8s_Pipelines

    %% Namespace-scoped bindings - Scheduler
    SchedulerSvcAcct -->|bound via| SchedulerRoleBinding
    SchedulerRoleBinding -->|grants| SchedulerRole
    SchedulerRole -->|create workflows| K8s_Workflows
    SchedulerRole -->|manage scheduled workflows| K8s_Pipelines

    %% Namespace-scoped bindings - Argo
    ArgoSvcAcct -->|bound via| ArgoRoleBinding
    ArgoRoleBinding -->|grants| ArgoRole
    ArgoRole -->|create/delete pods| K8s_Pods
    ArgoRole -->|watch workflows| K8s_Workflows
    ArgoRole -->|access configmaps/secrets| K8s_ConfigMaps
    ArgoRole -->|access configmaps/secrets| K8s_Secrets

    %% Namespace-scoped bindings - Pipeline Runner
    RunnerSvcAcct -->|bound via| RunnerRoleBinding
    RunnerRoleBinding -->|grants| RunnerRole
    RunnerRole -->|execute pipeline tasks| K8s_Pods
    RunnerRole -->|access secrets| K8s_Secrets

    %% Aggregate role
    AggregateRole -->|view permissions| K8s_DSPA
    AggregateRole -->|view permissions| K8s_Pipelines

