        SA_ModelRegistry[model-registry-operator]
        SA_MLflow[mlflow-operator]
        SA_Feast[feast-operator]
        SA_Trainer[kubeflow-trainer-controller-manager]
        SA_TrainingOp[training-operator]
        SA_TrustyAI[trustyai-operator]
        SA_KubeRay[kuberay-operator]
    end

    subgraph "ClusterRoles"
        CR_Dashboard[odh-dashboard]
        CR_KServe[kserve-manager-role]
        CR_ModelCtrl[odh-model-controller-role]
        CR_DSP[manager-role<br/>DSP]
        CR_NotebookCtrl[manager-role<br/>Notebook Controller]
        CR_ModelRegistry[manager-role<br/>Model Registry]
        CR_MLflow[manager-role<br/>MLflow]
        CR_Feast[manager-role<br/>Feast]
        CR_Trainer[kubeflow-trainer-controller-manager]
        CR_TrainingOp[training-operator]
        CR_TrustyAI[manager-role<br/>TrustyAI]
        CR_KubeRay[kuberay-operator]
    end

    subgraph "API Resources - Custom Resources"
        API_Notebooks[kubeflow.org<br/>Notebook]
        API_InferenceServices[serving.kserve.io<br/>InferenceService]
        API_ServingRuntimes[serving.kserve.io<br/>ServingRuntime]
        API_DSPA[datasciencepipelinesapplications<br/>.opendatahub.io<br/>DataSciencePipelinesApplication]
        API_Workflows[argoproj.io<br/>Workflow]
        API_HTTPRoutes[gateway.networking.k8s.io<br/>HTTPRoute]
        API_ModelRegistry[modelregistry.opendatahub.io<br/>ModelRegistry]
        API_MLflow[mlflow.opendatahub.io<br/>MLflow]
        API_FeatureStore[feast.dev<br/>FeatureStore]
        API_TrainJob[trainer.kubeflow.org<br/>TrainJob]
        API_PyTorchJob[kubeflow.org<br/>PyTorchJob/TFJob/XGBoostJob]
        API_TrustyAI[trustyai.opendatahub.io<br/>TrustyAIService]
        API_RayClusters[ray.io<br/>RayCluster/RayJob/RayService]
    end

    subgraph "API Resources - Core K8s"
        API_Deployments[apps<br/>Deployment]
        API_Services[core<br/>Service]
        API_Routes[route.openshift.io<br/>Route]
        API_VirtualServices[networking.istio.io<br/>VirtualService]
        API_ServiceMonitors[monitoring.coreos.com<br/>ServiceMonitor]
        API_JobSets[jobset.x-k8s.io<br/>JobSet]
        API_NetworkPolicies[networking.k8s.io<br/>NetworkPolicy]
    end

    %% Service Account to ClusterRole bindings
    SA_Dashboard -->|ClusterRoleBinding| CR_Dashboard
    SA_KServe -->|ClusterRoleBinding| CR_KServe
    SA_ModelCtrl -->|ClusterRoleBinding| CR_ModelCtrl
    SA_DSP -->|ClusterRoleBinding| CR_DSP
    SA_NotebookCtrl -->|ClusterRoleBinding| CR_NotebookCtrl
    SA_ModelRegistry -->|ClusterRoleBinding| CR_ModelRegistry
    SA_MLflow -->|ClusterRoleBinding| CR_MLflow
    SA_Feast -->|ClusterRoleBinding| CR_Feast
    SA_Trainer -->|ClusterRoleBinding| CR_Trainer
    SA_TrainingOp -->|ClusterRoleBinding| CR_TrainingOp
    SA_TrustyAI -->|ClusterRoleBinding| CR_TrustyAI
    SA_KubeRay -->|ClusterRoleBinding| CR_KubeRay

    %% Dashboard permissions
    CR_Dashboard -->|create,delete,get,list,patch,update,watch| API_Notebooks
    CR_Dashboard -->|get,list,watch| API_InferenceServices

    %% KServe permissions
    CR_KServe -->|all verbs| API_InferenceServices
    CR_KServe -->|all verbs| API_ServingRuntimes
    CR_KServe -->|create,delete,get,list,patch,update,watch| API_Deployments
    CR_KServe -->|create,delete,get,list,patch,update,watch| API_Services
    CR_KServe -->|all verbs| API_VirtualServices

    %% Model Controller permissions
    CR_ModelCtrl -->|get,list,patch,update,watch| API_InferenceServices
    CR_ModelCtrl -->|get,list,patch,update,watch| API_ServingRuntimes
    CR_ModelCtrl -->|create,delete,get,list,patch,update,watch| API_Routes
    CR_ModelCtrl -->|create,delete,get,list,patch,update,watch| API_ServiceMonitors

    %% Data Science Pipelines permissions
    CR_DSP -->|all verbs| API_DSPA
    CR_DSP -->|all verbs| API_Workflows

    %% Notebook Controller permissions
    CR_NotebookCtrl -->|create,delete,get,list,patch,update,watch| API_HTTPRoutes
    CR_NotebookCtrl -->|get,list,watch,patch,update| API_Notebooks

    %% Model Registry permissions
    CR_ModelRegistry -->|all verbs| API_ModelRegistry
    CR_ModelRegistry -->|create,delete,get,list,patch,update,watch| API_Services
    CR_ModelRegistry -->|create,delete,get,list,patch,update,watch| API_Deployments

    %% MLflow permissions
    CR_MLflow -->|all verbs| API_MLflow
    CR_MLflow -->|create,delete,get,list,patch,update,watch| API_Deployments
    CR_MLflow -->|create,delete,get,list,patch,update,watch| API_Routes

    %% Feast permissions
    CR_Feast -->|all verbs| API_FeatureStore
    CR_Feast -->|create,delete,get,list,patch,update,watch| API_Deployments

    %% Trainer permissions
    CR_Trainer -->|all verbs| API_TrainJob
    CR_Trainer -->|create,get,list,patch,update,watch| API_JobSets
    CR_Trainer -->|create,delete,get,list,patch,update,watch| API_NetworkPolicies

    %% Training Operator permissions
    CR_TrainingOp -->|all verbs| API_PyTorchJob

    %% TrustyAI permissions
    CR_TrustyAI -->|all verbs| API_TrustyAI
    CR_TrustyAI -->|get,list,patch,update,watch| API_InferenceServices

    %% KubeRay permissions
    CR_KubeRay -->|all verbs| API_RayClusters

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef cr fill:#f5a623,stroke:#333,stroke-width:2px,color:#333
    classDef crd fill:#7ed321,stroke:#333,stroke-width:2px,color:#333
    classDef core fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

