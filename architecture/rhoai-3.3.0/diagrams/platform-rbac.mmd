    class CR_Dashboard,CR_KServe,CR_ModelCtrl,CR_DSP,CR_NotebookCtrl,CR_ModelRegistry,CR_MLflow,CR_Feast,CR_Trainer,CR_TrainingOp,CR_TrustyAI,CR_KubeRay cr
    class API_Notebooks,API_InferenceServices,API_ServingRuntimes,API_DSPA,API_Workflows,API_HTTPRoutes,API_ModelRegistry,API_MLflow,API_FeatureStore,API_TrainJob,API_PyTorchJob,API_TrustyAI,API_RayClusters crd
    class API_Deployments,API_Services,API_Routes,API_VirtualServices,API_ServiceMonitors,API_JobSets,API_NetworkPolicies core
