graph TB
    subgraph "TrustyAI Service Operator"
        Operator[Operator Controller]
        Webhook[Conversion Webhook<br/>v1alpha1 → v1]
        RBACProxy[Kube-RBAC-Proxy<br/>Sidecar]

        Operator -->|serves| Webhook
        Operator -->|secured by| RBACProxy
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>v1/v1alpha1]
        LMEvalJobCR[LMEvalJob CR<br/>v1alpha1]
        GuardrailsOrchestratorCR[GuardrailsOrchestrator CR<br/>v1alpha1]
        NemoGuardrailsCR[NemoGuardrails CR<br/>v1alpha1]
    end

    subgraph "Managed Deployments"
        TrustyAIService[TrustyAI Service<br/>Deployment]
        GuardrailsOrchestrator[Guardrails Orchestrator<br/>Deployment]
        NemoGuardrails[Nemo Guardrails<br/>Deployment]
        LMEvalJob[LM Evaluation Job<br/>Job/Pod]
    end

    subgraph "Storage Backends"
        PVC[PersistentVolumeClaim<br/>Filesystem Storage]
        Database[(Database<br/>PostgreSQL/MySQL)]
    end

    subgraph "External Dependencies"
        KServe[KServe<br/>InferenceService]
        Istio[Istio<br/>VirtualService/DestinationRule]
        Prometheus[Prometheus<br/>ServiceMonitor]
        Kueue[Kueue<br/>Workload Queueing]
        OpenShift[OpenShift<br/>Routes]
    end

    %% CR to Operator
    User[User] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsOrchestratorCR
    User -->|creates| NemoGuardrailsCR

    TrustyAIServiceCR -->|watched by| Operator
    LMEvalJobCR -->|watched by| Operator
    GuardrailsOrchestratorCR -->|watched by| Operator
    NemoGuardrailsCR -->|watched by| Operator

    %% Operator creates resources
    Operator -->|creates| TrustyAIService
    Operator -->|creates| GuardrailsOrchestrator
    Operator -->|creates| NemoGuardrails
    Operator -->|creates| LMEvalJob
    Operator -->|creates| PVC

    %% TrustyAI Service connections
    TrustyAIService -->|stores data| PVC
    TrustyAIService -->|stores data| Database
    TrustyAIService -->|monitors| KServe

    %% Guardrails connections
    GuardrailsOrchestrator -->|patches| KServe
    GuardrailsOrchestrator -->|routes to| KServe

    %% LM Eval connections
    LMEvalJob -->|queued by| Kueue

    %% Operator integrations
    Operator -->|creates| Istio
    Operator -->|creates| Prometheus
    Operator -->|creates| OpenShift

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333
    style RBACProxy fill:#4a90e2,stroke:#333
    style TrustyAIServiceCR fill:#f5a623,stroke:#333
    style LMEvalJobCR fill:#f5a623,stroke:#333
    style GuardrailsOrchestratorCR fill:#f5a623,stroke:#333
    style NemoGuardrailsCR fill:#f5a623,stroke:#333
    style TrustyAIService fill:#7ed321,stroke:#333
    style GuardrailsOrchestrator fill:#7ed321,stroke:#333
    style NemoGuardrails fill:#7ed321,stroke:#333
    style LMEvalJob fill:#7ed321,stroke:#333
    style PVC fill:#bd10e0,stroke:#333
    style Database fill:#bd10e0,stroke:#333
    style KServe fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style OpenShift fill:#999,stroke:#333
