graph TB
    subgraph "ODH Dashboard Component"
        direction TB

        subgraph "Frontend Layer"
            UI[React 18 + PatternFly 6 SPA<br/>Port: 8443/HTTPS]
            MF[Module Federation Support<br/>/_mf/* endpoints]
        end

        subgraph "Backend Layer"
            Backend[Node.js/Fastify API Server<br/>Port: 8080/HTTP]
            WSS[WebSocket Server<br/>/wss/k8s/* endpoints]
        end

        subgraph "Authentication Layer"
            Proxy[kube-rbac-proxy<br/>Port: 8443/HTTPS<br/>OAuth enforcement]
        end

        subgraph "Micro-frontends (Modular Architecture)"
            MRUI[Model Registry UI<br/>Port: 8043/HTTPS]
            GenAIUI[GenAI UI<br/>Port: 8143/HTTPS]
            MaaSUI[MaaS UI<br/>Port: 8243/HTTPS]
        end

        UI --> Backend
        UI -.->|module federation| MF
        MF -.->|federated remote| MRUI
        MF -.->|federated remote| GenAIUI
        MF -.->|federated remote| MaaSUI
        Backend --> WSS
        Proxy -->|forwards with impersonation| Backend
    end

    subgraph "Custom Resource Definitions"
        OdhApp[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhDoc[OdhDocument<br/>dashboard.opendatahub.io/v1]
        OdhQuick[OdhQuickStart<br/>console.openshift.io/v1]
    end

    subgraph "External Dependencies"
        OSAuth[OpenShift OAuth Server]
        K8sAPI[Kubernetes API Server<br/>443/HTTPS]
        Prom[Prometheus<br/>9091/HTTPS]
    end

    subgraph "Internal ODH Dependencies"
        Operator[ODH/RHODS Operator<br/>DataScienceCluster, DSCInitialization]
        Notebooks[Kubeflow Notebooks<br/>Notebook CRD]
        KServe[KServe<br/>InferenceService, ServingRuntime]
        ModelReg[Model Registry Operator<br/>ModelRegistry CRD]
        Feast[Feast Operator<br/>FeatureStore CRD]
    end

    subgraph "External Services"
        S3[S3-compatible Storage<br/>443/HTTPS]
        ImageReg[Image Registries<br/>443/HTTPS]
    end

    User[User Browser] -->|HTTPS/443<br/>OAuth Bearer Token| Proxy
    Proxy -->|OAuth validation| OSAuth
    Proxy -->|TokenReview| K8sAPI
    Backend -->|CRUD operations<br/>ServiceAccount + Impersonation| K8sAPI
    WSS -->|Watch streams| K8sAPI
    Backend -->|Metrics queries| Prom

    Backend -->|watches| OdhApp
    Backend -->|manages| OdhConfig
    Backend -->|reads| OdhDoc
    Backend -->|reads| OdhQuick

    Backend -->|watches| Operator
    Backend -->|creates/manages| Notebooks
    Backend -->|watches| KServe
    Backend -->|manages| ModelReg
    Backend -->|watches| Feast

    MRUI -->|uses| ModelReg
    Backend -.->|image pulls| ImageReg
    Backend -.->|model storage| S3

    style UI fill:#4a90e2,stroke:#333,stroke-width:2px
    style Backend fill:#4a90e2,stroke:#333,stroke-width:2px
    style Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style MRUI fill:#7ed321,stroke:#333
    style GenAIUI fill:#7ed321,stroke:#333
    style MaaSUI fill:#7ed321,stroke:#333
    style OdhApp fill:#d0d0d0,stroke:#333
    style OdhConfig fill:#d0d0d0,stroke:#333
    style OdhDoc fill:#d0d0d0,stroke:#333
    style OdhQuick fill:#d0d0d0,stroke:#333
    style OSAuth fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prom fill:#999,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelReg fill:#7ed321,stroke:#333
    style Feast fill:#7ed321,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style ImageReg fill:#e8e8e8,stroke:#333
