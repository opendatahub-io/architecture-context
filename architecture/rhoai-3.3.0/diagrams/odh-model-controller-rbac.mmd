    subgraph AuthResources["Authentication Resources<br/>authentication.k8s.io, authorization.k8s.io"]
        TokenReviews[TokenReviews<br/>authentication.k8s.io]
        SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io]
    end

    subgraph AuthorinoResources["Authorino Resources"]
        Authorinos[Authorinos<br/>operator.authorino.kuadrant.io]
    end

