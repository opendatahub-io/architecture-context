graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router/Gateway<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>HSTS enabled"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER (Trusted)"]
        direction TB
        Proxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>8444/TCP Health<br/>OAuth enforcement<br/>SA: odh-dashboard"]
    end

    subgraph AppLayer["APPLICATION LAYER (Trusted)"]
        direction TB

        Backend["Dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP<br/>User: 1001 (non-root)<br/>SA: odh-dashboard"]

        subgraph Endpoints["API Endpoints"]
            REST["/api/* - REST APIs<br/>HTTP/8080"]
            WSS["/wss/k8s/* - WebSocket<br/>ws://8080"]
            Health["/api/health<br/>HTTP/8080"]
        end

        Backend --> REST
        Backend --> WSS
        Backend --> Health
    end

    subgraph MicroFE["MICRO-FRONTENDS (Modular Architecture)"]
        direction TB

        MRUI["Model Registry UI<br/>8043/TCP HTTPS<br/>x-forwarded-access-token<br/>User: 1001, DROP ALL caps"]
        GenAI["GenAI UI<br/>8143/TCP HTTPS<br/>x-forwarded-access-token<br/>User: 1001, DROP ALL caps"]
        MaaS["MaaS UI<br/>8243/TCP HTTPS<br/>x-forwarded-access-token<br/>User: 1001, DROP ALL caps"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OAuth["OpenShift OAuth<br/>443/TCP HTTPS<br/>User authentication"]
        Prom["Prometheus<br/>openshift-monitoring<br/>9091/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalSvcs["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
        Registry["Image Registries<br/>443/TCP HTTPS<br/>Image pull secrets"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token"| Router
    Router -->|"HTTPS/8443<br/>TLS reencrypt"| Proxy

    Proxy -->|"OAuth validation<br/>HTTPS/443<br/>TLS 1.2+"| OAuth
    Proxy -->|"TokenReview<br/>HTTPS/443<br/>SA token"| K8sAPI
    Proxy -->|"HTTP/8080<br/>localhost only<br/>Impersonation headers"| Backend

    Backend -->|"CRUD operations<br/>HTTPS/443<br/>SA token + Impersonation"| K8sAPI
    Backend -->|"PromQL queries<br/>HTTPS/9091<br/>SA token"| Prom
    Backend -->|"Module federation<br/>HTTPS/8043<br/>Token forwarding"| MRUI
    Backend -->|"Module federation<br/>HTTPS/8143<br/>Token forwarding"| GenAI
    Backend -->|"Module federation<br/>HTTPS/8243<br/>Token forwarding"| MaaS

    Backend -.->|"Model storage<br/>HTTPS/443<br/>AWS creds"| S3
    Backend -.->|"Image pulls<br/>HTTPS/443<br/>Pull secrets"| Registry

    MRUI -.->|"Backend API<br/>User token"| K8sAPI
    GenAI -.->|"Backend API<br/>User token"| K8sAPI
    MaaS -.->|"Backend API<br/>User token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef auth fill:#f5a623,stroke:#d79b00,stroke-width:3px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef microfe fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class Proxy auth
    class Backend,REST,WSS,Health app
    class MRUI,GenAI,MaaS microfe
    class K8sAPI,OAuth,Prom k8s
    class S3,Registry externalsvc
