graph TB
    subgraph "MLflow Operator Component"
        Controller[MLflow Operator Controller<br/>Go Operator]
        HelmEngine[Embedded Helm Chart<br/>Template Engine]
        HTTPRouteCtl[HTTPRoute Controller]
        ConsoleLinkCtl[ConsoleLink Controller]

        Controller -->|uses| HelmEngine
        Controller -->|manages| HTTPRouteCtl
        Controller -->|manages| ConsoleLinkCtl
    end

    subgraph "Watched Resources"
        MLflowCR[MLflow CR<br/>mlflow.opendatahub.io/v1]
    end

    subgraph "Created Resources - Per MLflow Instance"
        MLflowServer[MLflow Server<br/>Python Application<br/>v3.6.0]
        Service[Service<br/>ClusterIP 8443/TCP]
        Deployment[Deployment<br/>MLflow Server Pod]
        PVC[PersistentVolumeClaim<br/>2Gi default]
        Secret[Secret<br/>mlflow-tls]
        SA[ServiceAccount<br/>mlflow-sa]
        HTTPRoute[HTTPRoute<br/>Gateway API]
        ConsoleLink[ConsoleLink<br/>OpenShift Console]
        NetworkPolicy[NetworkPolicy<br/>Port 8443]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        Gateway[data-science-gateway<br/>Gateway API]
        Console[OpenShift Console]
        ServiceCA[service-ca-operator<br/>TLS Provisioning]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    subgraph "Optional External Services"
        PostgreSQL[PostgreSQL<br/>5432/TCP<br/>Backend Store]
        S3[S3-compatible Storage<br/>443/TCP HTTPS<br/>Artifacts]
    end

    %% User workflow
    User[User] -->|creates| MLflowCR
    MLflowCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|renders via Helm| Deployment
    Controller -->|creates| Service
    Controller -->|creates| PVC
    Controller -->|creates| SA
    Controller -->|creates| NetworkPolicy
    HTTPRouteCtl -->|creates| HTTPRoute
    ConsoleLinkCtl -->|creates| ConsoleLink

    %% Deployment relationship
    Deployment -->|deploys| MLflowServer
    Service -->|routes to| MLflowServer
    ServiceCA -->|provisions| Secret
    Secret -->|mounted by| MLflowServer
    SA -->|used by| MLflowServer
    PVC -->|mounted by| MLflowServer

    %% External integrations
    HTTPRoute -->|registers with| Gateway
    ConsoleLink -->|registers with| Console
    Controller -->|watches/creates| K8sAPI
    Prometheus -->|scrapes metrics| Controller

    %% MLflow server egress
    MLflowServer -.->|optional| PostgreSQL
    MLflowServer -.->|optional| S3
    MLflowServer -->|auth checks| K8sAPI

    %% User access flow
    User -->|accesses via| Gateway
    Gateway -->|routes to| Service

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style MLflowServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style MLflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style Gateway fill:#7ed321,stroke:#333,stroke-width:2px
    style Console fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:1px
    style ServiceCA fill:#999,stroke:#333,stroke-width:1px
    style PostgreSQL fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style S3 fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
