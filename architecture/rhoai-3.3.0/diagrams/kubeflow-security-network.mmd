graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS (Gateway API - openshift-ingress)"]
        Gateway["Data Science Gateway<br/>Type: Gateway API v1<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge Termination"]
    end

    subgraph ControlPlane["CONTROL PLANE (redhat-ods-applications)"]
        direction TB

        subgraph Controller["ODH Notebook Controller Pod"]
            ControllerApp["Controller Manager<br/>SA: odh-notebook-controller-manager"]
            WebhookSvc["Webhook Service<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (service-ca)"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>8081/TCP HTTP"]
        end

        HTTPRouteRes["HTTPRoute Resources<br/>nb-{ns}-{name}<br/>Path: /notebook/{ns}/{name}"]
        RefGrant["ReferenceGrant<br/>Cross-Namespace Permission"]
    end

    subgraph UserNamespace["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph NotebookPod["Notebook Pod"]
            direction LR
            RBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>SubjectAccessReview Auth"]
            NotebookContainer["Jupyter Notebook<br/>8888/TCP HTTP<br/>No Encryption"]
        end

        RBACProxySvc["Service: {name}-kube-rbac-proxy<br/>8443/TCP ClusterIP"]
        NotebookSvc["Service: {name}<br/>80/TCP → 8888/TCP ClusterIP"]

        NetPol1["NetworkPolicy: {name}-ctrl-np<br/>Allow 8888/TCP from controller ns"]
        NetPol2["NetworkPolicy: {name}-kube-rbac-proxy-np<br/>Allow 8443,8444/TCP from controller ns"]

        NotebookSA["ServiceAccount: {name}"]
        TLSSecret["Secret: {name}-tls-proxy-serving-cert<br/>Type: kubernetes.io/tls<br/>Auto-rotate: 30 days"]
        DSPASecret["Secret: {name}-{dspa}-token<br/>Type: Opaque<br/>Pipeline API Token"]
    end

    subgraph K8sCore["KUBERNETES CORE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth<br/>mTLS for Webhooks"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ServiceCA["OpenShift Service CA<br/>TLS Certificate Provisioning<br/>Auto-rotate: 30 days"]
        KubeflowCtrl["Kubeflow Notebook Controller<br/>Creates StatefulSets & Services"]
        DSPOperator["Data Science Pipelines Operator<br/>DSPA CRs"]
        ImageRegistry["Image Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secrets"]
        DSPIPipeline["DS Pipeline API<br/>8888/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    %% User Flow (with auth)
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| Gateway
    Gateway -->|HTTPRoute Routing<br/>Path Match| HTTPRouteRes
    HTTPRouteRes -->|Backend Reference<br/>Cross-Namespace| RBACProxySvc
    RBACProxySvc -->|ClusterIP 8443| RBACProxy
    RBACProxy -->|SubjectAccessReview<br/>HTTPS/443<br/>Check 'get' on Notebook CR| APIServer
    RBACProxy -->|HTTP/8888<br/>localhost<br/>No encryption| NotebookContainer

    %% User Flow (without auth)
    Gateway -.->|Direct Backend<br/>No Auth| NotebookSvc
    NotebookSvc -.->|ClusterIP 80→8888| NotebookContainer

    %% Controller Operations
    ControllerApp -->|Watch Notebooks<br/>Create Resources<br/>HTTPS/443<br/>SA Token| APIServer
    ControllerApp -->|Creates| HTTPRouteRes
    ControllerApp -->|Creates| RefGrant
    ControllerApp -->|Creates| NetPol1
    ControllerApp -->|Creates| NetPol2
    ControllerApp -->|Creates| NotebookSA
    ControllerApp -->|Creates| DSPASecret

    %% Webhook Flow
    APIServer -->|POST /mutate-notebook-v1<br/>HTTPS/443<br/>mTLS client cert| WebhookSvc
    WebhookSvc -->|Mutated Spec<br/>Inject sidecar| APIServer

    %% External Dependencies
    ServiceCA -->|Provisions & Rotates<br/>Annotation-based| TLSSecret
    ServiceCA -->|Provisions| WebhookSvc
    KubeflowCtrl -->|Creates| NotebookSvc
    KubeflowCtrl -->|Creates StatefulSet| NotebookPod
    DSPOperator -->|DSPA CRs| ControllerApp

    %% Notebook Egress
    NotebookContainer -.->|API Calls<br/>HTTPS/443<br/>SA Token| APIServer
    NotebookContainer -.->|Pipeline Access<br/>HTTPS/8888<br/>Bearer Token| DSPIPipeline
    NotebookContainer -.->|Image Pulls<br/>HTTPS/443<br/>Pull Secret| ImageRegistry

    %% ReferenceGrant enabling cross-namespace
    RefGrant -.->|Permits| HTTPRouteRes

    %% Network Policy enforcement
    NetPol1 -.->|Enforces Ingress| NotebookContainer
    NetPol2 -.->|Enforces Ingress| RBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef usernamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8score fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class ControllerApp,WebhookSvc,MetricsSvc,HTTPRouteRes,RefGrant controlplane
    class NotebookPod,RBACProxy,NotebookContainer,RBACProxySvc,NotebookSvc,NetPol1,NetPol2,NotebookSA,TLSSecret,DSPASecret usernamespace
    class APIServer k8score
    class ServiceCA,KubeflowCtrl,DSPOperator,ImageRegistry,DSPIPipeline externalservice
