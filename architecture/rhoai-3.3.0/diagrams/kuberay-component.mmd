graph TB
    subgraph "KubeRay Operator"
        Operator[kuberay-operator<br/>Deployment]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        NetPolicyCtrl[NetworkPolicy Controller]
        AuthCtrl[Authentication Controller]
        MutatingWH[Mutating Webhook<br/>9443/TCP HTTPS]
        ValidatingWH[Validating Webhook<br/>9443/TCP HTTPS]

        Operator -->|manages| RayClusterCtrl
        Operator -->|manages| RayJobCtrl
        Operator -->|manages| RayServiceCtrl
        Operator -->|manages| NetPolicyCtrl
        Operator -->|manages| AuthCtrl
        Operator -->|hosts| MutatingWH
        Operator -->|hosts| ValidatingWH
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Ray Cluster Resources"
        HeadPod[Ray Head Pod<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP]
        WorkerPods[Ray Worker Pods<br/>Autoscaling enabled]
        HeadService["(cluster)-head-svc<br/>ClusterIP"]
        ServeService["(service)-serve-svc<br/>8000/TCP HTTP"]

        HeadPod -->|provides| HeadService
        WorkerPods -->|connect to| HeadPod
    end

    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    MutatingWH -->|mutates| RayClusterCR
    ValidatingWH -->|validates| RayClusterCR

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadService
    RayServiceCtrl -->|creates| ServeService

    NetPolicyCtrl -->|creates| NetPolicies[NetworkPolicies]
    AuthCtrl -->|creates| Certificates[TLS Certificates]

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus<br/>Metrics scraping]
        GatewayAPI[Gateway API<br/>Optional]
        Redis[External Redis<br/>GCS fault tolerance]
    end

    RayClusterCtrl -->|manages resources| K8sAPI
    RayJobCtrl -->|manages resources| K8sAPI
    RayServiceCtrl -->|manages resources| K8sAPI
    AuthCtrl -->|requests certs| CertManager
    Operator -->|exposes metrics| Prometheus
    RayServiceCtrl -->|creates routes| GatewayAPI
    HeadPod -.->|optional HA| Redis

    subgraph "Internal ODH Integration"
        Dashboard[ODH Dashboard]
        ModelRegistry[Model Registry]
        DSPipelines[Data Science Pipelines]
    end

    Dashboard -.->|displays| RayClusterCR
    ModelRegistry -.->|uses for training| RayClusterCR
    DSPipelines -.->|executes jobs| RayJobCR

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style GatewayAPI fill:#999,stroke:#333
    style Redis fill:#999,stroke:#333
    style Dashboard fill:#d5e8d4,stroke:#333
    style ModelRegistry fill:#d5e8d4,stroke:#333
    style DSPipelines fill:#d5e8d4,stroke:#333
