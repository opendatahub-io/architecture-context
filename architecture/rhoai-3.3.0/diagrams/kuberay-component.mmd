    style RayJobCR fill:#f5a623
    style RayServiceCR fill:#f5a623
    style RayHead fill:#7ed321
    style RayWorker1 fill:#7ed321
    style RayWorker2 fill:#7ed321
    style RayWorkerN fill:#7ed321
    style K8sAPI fill:#e8e8e8
