graph TB
    subgraph "KubeRay Operator"
        Operator[kuberay-operator<br/>Deployment]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        NetworkPolicyCtrl[NetworkPolicy Controller]
        AuthCtrl[Authentication Controller]
        MutatingWH[Mutating Webhook<br/>9443/TCP HTTPS]
        ValidatingWH[Validating Webhook<br/>9443/TCP HTTPS]

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
        Operator --> NetworkPolicyCtrl
        Operator --> AuthCtrl
        Operator --> MutatingWH
        Operator --> ValidatingWH
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Workloads"
        RayHead[Ray Head Pod<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP]
        RayWorker1[Ray Worker Pod 1]
        RayWorker2[Ray Worker Pod 2]
        RayWorkerN[Ray Worker Pod N]

        RayWorker1 -.->|Ray Protocol| RayHead
        RayWorker2 -.->|Ray Protocol| RayHead
        RayWorkerN -.->|Ray Protocol| RayHead
    end

    subgraph "Kubernetes Resources"
        Service[Services<br/>ClusterIP]
        NetworkPolicy[Network Policies]
        Ingress[Ingress/Route]
        Certificate[Certificates<br/>cert-manager]
    end

    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| RayHead
    RayClusterCtrl -->|creates| RayWorker1
    RayClusterCtrl -->|creates| RayWorker2
    RayClusterCtrl -->|creates| RayWorkerN
    RayClusterCtrl -->|creates| Service

    NetworkPolicyCtrl -->|creates| NetworkPolicy
    AuthCtrl -->|creates| Certificate
    RayClusterCtrl -->|creates| Ingress

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        CertManager[cert-manager<br/>443/TCP HTTPS]
        Redis[External Redis<br/>6379/TCP Optional]
        ObjectStorage[Object Storage<br/>S3/GCS 443/TCP]
    end

    RayClusterCtrl -->|REST API| K8sAPI
    RayJobCtrl -->|REST API| K8sAPI
    RayServiceCtrl -->|REST API| K8sAPI
    AuthCtrl -->|CRD API| CertManager
    RayHead -->|Optional GCS HA| Redis
    RayHead -->|Data access| ObjectStorage

    subgraph "Internal ODH Integration"
        Dashboard[ODH Dashboard]
        ModelRegistry[Model Registry]
        DSPipelines[Data Science Pipelines]
    end

    Dashboard -.->|UI mgmt| RayClusterCR
    ModelRegistry -.->|Distributed training| RayClusterCR
    DSPipelines -.->|Job execution| RayJobCR

    style Operator fill:#4a90e2
    style RayClusterCtrl fill:#4a90e2
    style RayJobCtrl fill:#4a90e2
    style RayServiceCtrl fill:#4a90e2
