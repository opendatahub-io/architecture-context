graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>operator namespace"]
        SA_Registry["registry-name-sa<br/>registry namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
        CRB_Proxy[proxy-rolebinding]
    end

    subgraph "Role Bindings"
        RB_Leader["leader-election-rolebinding<br/>operator namespace"]
        RB_User["registry-user binding<br/>registry namespace"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Proxy[proxy-role]
        CR_Admin[modelregistry-admin-role]
        CR_Editor[modelregistry-editor-role]
        CR_Viewer[modelregistry-viewer-role]
    end

    subgraph "Roles"
        R_Leader["leader-election-role<br/>operator namespace"]
        R_User["registry-user role<br/>registry namespace"]
    end

    subgraph "API Resources - ModelRegistry Operator"
        direction TB
        MR_CRD["modelregistry.opendatahub.io<br/>ModelRegistry<br/>v1alpha1, v1beta1"]
        MR_Status["modelregistry.opendatahub.io<br/>ModelRegistry/status"]
        MR_Finalizers["modelregistry.opendatahub.io<br/>ModelRegistry/finalizers"]
    end

    subgraph "API Resources - Kubernetes Core"
        direction TB
        Core_Services["core<br/>services, serviceaccounts<br/>configmaps, secrets, pvcs"]
        Core_Pods["core<br/>endpoints, pods, pods/log"]
        Core_Events["core<br/>events"]
        Apps_Deploy["apps<br/>deployments"]
        Net_Policy["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph "API Resources - RBAC"
        RBAC_Resources["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterrolebindings"]
        Auth_Reviews["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "API Resources - OpenShift"
        OCP_Routes["route.openshift.io<br/>routes, routes/custom-host"]
        OCP_Groups["user.openshift.io<br/>groups"]
        OCP_Ingress["config.openshift.io<br/>ingresses"]
    end

    subgraph "API Resources - Platform"
        Platform_Components["components.platform<br/>.opendatahub.io<br/>modelregistries"]
        Platform_Services["services.platform<br/>.opendatahub.io<br/>auths"]
    end

    subgraph "API Resources - Other"
        Migration["migration.k8s.io<br/>storageversionmigrations"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader

    %% ClusterRole Bindings
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy

    %% Role Bindings
    RB_Leader -->|grants| R_Leader
    RB_User -->|grants| R_User

    %% ClusterRole Permissions - manager-role
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_CRD
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_Status
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_Finalizers
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Services
    CR_Manager -->|get,list,watch| Core_Pods
    CR_Manager -->|create,patch| Core_Events
    CR_Manager -->|get,list,watch,create,update,patch,delete| Apps_Deploy
    CR_Manager -->|get,list,watch,create,update,patch,delete| Net_Policy
    CR_Manager -->|get,list,watch,create,update,patch,delete| RBAC_Resources
    CR_Manager -->|create| Auth_Reviews
    CR_Manager -->|get,list,watch,create,update,patch,delete| OCP_Routes
    CR_Manager -->|get,list,watch,create,update,patch,delete| OCP_Groups
    CR_Manager -->|get,list,watch| OCP_Ingress
    CR_Manager -->|get,list,watch,create,update,patch,delete| Migration
    CR_Manager -->|get,list,watch| CRDs
    CR_Manager -->|get,list,watch| Platform_Components
    CR_Manager -->|get,list,watch| Platform_Services

    %% User ClusterRoles
    CR_Admin -->|get,list,watch,create,update,patch,delete| MR_CRD
    CR_Editor -->|get,list,watch,create,update,patch| MR_CRD
    CR_Viewer -->|get,list,watch| MR_CRD

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Registry fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623
    style CR_Proxy fill:#f5a623
    style CR_Admin fill:#7ed321
    style CR_Editor fill:#7ed321
    style CR_Viewer fill:#7ed321
    style MR_CRD fill:#d0d0d0
    style MR_Status fill:#d0d0d0
    style MR_Finalizers fill:#d0d0d0
    style Core_Services fill:#e8e8e8
    style Core_Pods fill:#e8e8e8
    style Apps_Deploy fill:#e8e8e8
