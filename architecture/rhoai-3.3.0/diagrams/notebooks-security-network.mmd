graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist<br/>Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP (ext) → 8443/TCP (int)<br/>TLS 1.2+ edge termination"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB

        OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>Enforces OpenShift OAuth"]

        JupyterServer["Jupyter Server<br/>8888/TCP HTTP<br/>Auth: DISABLED<br/>User: UID 1001 (non-root)<br/>Image: odh-workbench-jupyter-*"]

        Service["ClusterIP Service<br/>{workbench-name}-notebook<br/>8888/TCP"]

        OAuthProxy -->|"HTTP/8888<br/>No encryption<br/>(internal pod)"| JupyterServer
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>6443/TCP HTTPS TLS1.2+<br/>Token validation"]

        PyPI["pypi.org<br/>443/TCP HTTPS TLS1.2+<br/>Package downloads"]

        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access Keys"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Service Account Token<br/>RBAC: namespace-scoped"]

        KubePipelines["Kubeflow Pipelines API<br/>8888/TCP HTTP<br/>Bearer Token"]
    end

    subgraph RuntimePods["RUNTIME PODS (Elyra Pipeline)"]
        RuntimePod["Runtime Image Pod<br/>User: UID 1001<br/>SA: pipeline-runner-sa<br/>Image: odh-pipeline-runtime-*"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (initial)"| Router

    %% Ingress to Pod
    Router -->|"HTTPS/8443<br/>TLS 1.2+<br/>OAuth redirect if needed"| OAuthProxy

    %% OAuth validation
    OAuthProxy -.->|"HTTPS/6443<br/>TLS 1.2+<br/>OAuth token exchange"| OAuthServer

    %% Service routing
    Router -.->|"routes to"| Service
    Service -.->|"targets"| OAuthProxy

    %% Workbench egress
    JupyterServer -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| PyPI
    JupyterServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3
    JupyterServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    JupyterServer -->|"HTTP/8888<br/>No encryption<br/>Bearer Token"| KubePipelines

    %% Pipeline execution
    KubePipelines -->|"Creates pod via K8s API"| RuntimePod
    RuntimePod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds from secret"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,JupyterServer,Service workbench
    class OAuthServer,PyPI,S3,K8sAPI,KubePipelines externalservice
    class RuntimePod runtime
