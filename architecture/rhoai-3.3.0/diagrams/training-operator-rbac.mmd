graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "Cluster-Level RBAC"
        CRB[ClusterRoleBinding<br/>training-operator]
        CR[ClusterRole<br/>training-operator]
    end

    subgraph "Namespace-Level RBAC (opendatahub)"
        RB[RoleBinding<br/>training-operator-webhook]
        R[Role<br/>training-operator-webhook]
    end

    subgraph "Core API Resources"
        Pods[Pods<br/>create, delete, get, list,<br/>patch, update, watch]
        PodsExec[Pods/exec<br/>create]
        Services[Services<br/>create, delete, get,<br/>list, watch]
        ConfigMaps[ConfigMaps<br/>create, list, update, watch]
        Events[Events<br/>create, delete, get, list,<br/>patch, update, watch]
        SAs[ServiceAccounts<br/>create, get, list, watch]
        Secrets[Secrets<br/>get, list, watch<br/>⚠️ NAMESPACE-SCOPED ONLY]
    end

    subgraph "Training Job CRDs (kubeflow.org/v1)"
        PyTorchJob[PyTorchJob<br/>Full CRUD + status + finalizers]
        TFJob[TFJob<br/>Full CRUD + status + finalizers]
        XGBoostJob[XGBoostJob<br/>Full CRUD + status + finalizers]
        MPIJob[MPIJob<br/>Full CRUD + status + finalizers]
        JAXJob[JAXJob<br/>Full CRUD + status + finalizers]
        PaddleJob[PaddleJob<br/>Full CRUD + status + finalizers]
    end

    subgraph "Autoscaling Resources"
        HPAs[HorizontalPodAutoscalers<br/>autoscaling<br/>Full CRUD]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPG[PodGroups<br/>scheduling.volcano.sh<br/>Full CRUD]
        SchedulerPG[PodGroups<br/>scheduling.x-k8s.io<br/>Full CRUD]
    end

    subgraph "Networking Resources"
        NetPol[NetworkPolicies<br/>networking.k8s.io<br/>Full CRUD]
    end

    subgraph "RBAC Management"
        Roles[Roles<br/>rbac.authorization.k8s.io<br/>create, list, update, watch]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io<br/>create, list, update, watch]
    end

    subgraph "Admission Control"
        VWC[ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io<br/>get, list, update, watch]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Role Bindings to Roles
    CRB -->|grants| CR
    RB -->|grants| R

    %% ClusterRole Permissions
    CR -->|full CRUD| PyTorchJob
