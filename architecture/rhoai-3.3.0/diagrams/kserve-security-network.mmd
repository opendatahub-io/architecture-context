graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Gateway["Istio IngressGateway<br/>or OpenShift Router<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ Termination<br/>RequestAuthentication JWT"]
    end

    subgraph ControlPlane["CONTROL PLANE - Namespace: kserve"]
        direction TB

        Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Metrics: 8443/TCP - OAuth Proxy<br/>Health: 8081/TCP"]

        Webhook["kserve-webhook-server<br/>SA: kserve-controller-manager<br/>Port: 9443/TCP → Service 443/TCP<br/>TLS: kserve-webhook-server-cert<br/>mTLS with API Server"]

        LocalModelMgr["localmodel-manager<br/>SA: localmodel-manager<br/>Manages local model cache"]

        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]

        Controller -->|"Watch/Create Resources<br/>Bearer Token"| APIServer
        APIServer -->|"Validate/Mutate Webhooks<br/>mTLS client cert"| Webhook
        LocalModelMgr -->|"Create Jobs<br/>Bearer Token"| APIServer
    end

    subgraph ServiceMesh["SERVICE MESH - Namespace: user-namespace"]
        direction TB

        subgraph InferencePod["InferenceService Predictor Pod"]
            direction LR
            PredictorContainer["Predictor Container<br/>Port: 8000/TCP<br/>Runtime: sklearn/xgboost/<br/>pytorch/huggingface/triton"]
            StorageInitContainer["storage-initializer<br/>Init Container<br/>Downloads models"]
            AgentSidecar["agent Sidecar<br/>Logging batching metrics<br/>Port: 9081/TCP"]
            IstioSidecar["istio-proxy Sidecar<br/>mTLS enforcement<br/>Inbound: 8000/TCP to app"]
        end

        PredictorService["Predictor Service<br/>ClusterIP or Knative Service<br/>8000/TCP<br/>SA: isvc-name-sa"]

        VirtualService["VirtualService<br/>Host: isvc-ns.domain<br/>TLS Mode: SIMPLE<br/>AuthorizationPolicy optional"]

        subgraph RouterPod["Router Pod - InferenceGraph"]
            RouterContainer["Router Container<br/>Port: 8000/TCP<br/>Routes multi-model pipelines<br/>Propagates Bearer Token"]
        end

        RouterService["Router Service<br/>ClusterIP 8000/TCP<br/>SA: graph-name-sa"]

        subgraph LLMPods["LLM Disaggregated Architecture"]
            direction LR
            LLMRouter["LLM Router<br/>8000/TCP HTTP/HTTPS"]
            LLMScheduler["LLM Scheduler<br/>9003/TCP gRPC<br/>SA: llm-isvc-scheduler-sa"]
            PrefillWorker["Prefill Worker<br/>8000/TCP HTTP/gRPC<br/>LeaderWorkerSet<br/>SCC: openshift-ai-llminferenceservice-scc"]
            DecodeWorker["Decode Worker<br/>8001/TCP HTTP/gRPC<br/>LeaderWorkerSet<br/>SCC: openshift-ai-llminferenceservice-scc"]
        end

        LLMRouter -->|"gRPC/HTTP2<br/>mTLS optional"| LLMScheduler
        LLMScheduler -->|"gRPC<br/>mTLS optional"| PrefillWorker
        LLMScheduler -->|"gRPC<br/>mTLS optional"| DecodeWorker
    end

    subgraph NodeLevel["NODE-LEVEL COMPONENTS"]
        DaemonSet["localmodelnode-agent<br/>DaemonSet on each node<br/>Manages local disk cache"]

        LocalPV["Local PersistentVolume<br/>Node Disk Cache<br/>fsGroup: 1000"]

        DownloadJob["Download Job Pod<br/>storage-initializer<br/>Pulls models to local PV"]

        DaemonSet -.->|"Manages"| LocalPV
        DownloadJob -->|"Writes models"| LocalPV
        InferencePod -.->|"Mounts - fast access"| LocalPV
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM or Access Keys"]

        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Workload Identity or SA Key"]

        Azure["Azure Blob Storage<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Azure credentials"]

        Eventing["Knative Eventing Broker<br/>8080/TCP HTTP<br/>TLS via Istio optional"]
    end

    subgraph ODHIntegrations["ODH/RHOAI INTEGRATIONS"]
        Dashboard["ODH Dashboard<br/>UI for InferenceService mgmt"]
        ModelRegistry["Model Registry<br/>Model metadata storage"]
        Pipelines["Data Science Pipelines<br/>MLflow/S3 integration"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token optional"| Gateway

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/HTTPS 8000<br/>mTLS STRICT/PERMISSIVE<br/>Bearer Token propagated"| VirtualService
    VirtualService -->|"mTLS optional<br/>Service Identity"| PredictorService
    PredictorService -->|"Route to pod"| InferencePod

    Gateway -->|"HTTP/HTTPS 8000<br/>mTLS optional"| RouterService
    RouterService -->|"Route to pod"| RouterPod

    Gateway -->|"HTTP/HTTPS 8000<br/>mTLS optional"| LLMRouter

    %% Router to other InferenceServices
    RouterPod -.->|"Call pipeline steps<br/>Bearer Token propagated"| PredictorService

    %% Storage downloads
    StorageInitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage credentials"| S3
    StorageInitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage credentials"| GCS
    StorageInitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage credentials"| Azure

    DownloadJob -->|"HTTPS/443<br/>Storage credentials"| S3
    DownloadJob -->|"HTTPS/443<br/>Storage credentials"| GCS
    DownloadJob -->|"HTTPS/443<br/>Storage credentials"| Azure

    %% Logging
    PredictorContainer -.->|"HTTP/8080<br/>TLS via Istio optional"| Eventing

    %% Controller integrations
    Controller -.->|"Creates/Manages"| InferencePod
    Controller -.->|"Creates/Manages"| RouterPod
    Controller -.->|"Creates/Manages"| LLMPods

    %% ODH integrations
    Dashboard -.->|"Creates InferenceService<br/>via K8s API"| APIServer
    ModelRegistry -.->|"Model metadata"| InferencePod
    Pipelines -.->|"Model artifacts"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef servicemesh fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef nodelevel fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f5f5f5,stroke:#666,stroke-width:2px
    classDef odhintegration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class Controller,Webhook,LocalModelMgr,APIServer controlplane
    class InferencePod,PredictorService,VirtualService,RouterPod,RouterService,LLMRouter,LLMScheduler,PrefillWorker,DecodeWorker servicemesh
    class DaemonSet,LocalPV,DownloadJob nodelevel
    class S3,GCS,Azure,Eventing externalservice
    class Dashboard,ModelRegistry,Pipelines odhintegration
