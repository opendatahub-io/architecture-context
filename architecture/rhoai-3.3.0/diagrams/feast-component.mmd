graph TB
    subgraph "Feast Operator System"
        Operator[Feast Operator<br/>Manages FeatureStore CRs]
    end

    subgraph "Feast Feature Store Components"
        OnlineServer[Online Feature Server<br/>Port: 6566/6567<br/>FastAPI + gRPC]
        OfflineServer[Offline Feature Server<br/>Port: 8815/8816<br/>FastAPI]
        RegistryServer[Registry Server<br/>Port: 6570/6571 gRPC<br/>Port: 6572/6573 REST]
        UIServer[UI Server<br/>Port: 8888/8443<br/>React/TypeScript]
        ClientCM[Client ConfigMap<br/>feature_store.yaml]
        CronJob[CronJob<br/>Optional Materialization]
    end

    subgraph "Custom Resources"
        FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1]
    end

    subgraph "Storage Backends"
        SQLite[(SQLite<br/>Default Embedded Store)]
        PostgreSQL[(PostgreSQL<br/>Optional Persistent Store)]
        Redis[(Redis<br/>Optional Online Store)]
        S3[(S3/Object Storage<br/>Offline Data)]
    end

    subgraph "External Integrations"
        Notebooks[Kubeflow Notebooks]
        Routes[OpenShift Routes]
        Prometheus[Prometheus]
        OIDC[OIDC Provider]
    end

    User[ML Engineer] -->|creates| FeatureStoreCR
    FeatureStoreCR -->|watched by| Operator

    Operator -->|deploys| OnlineServer
    Operator -->|deploys| OfflineServer
    Operator -->|deploys| RegistryServer
    Operator -->|deploys| UIServer
    Operator -->|creates| ClientCM
    Operator -->|creates| CronJob

    OnlineServer -->|stores features| SQLite
    OnlineServer -->|stores features| PostgreSQL
    OnlineServer -->|stores features| Redis
    OnlineServer -->|fetches metadata| RegistryServer

    OfflineServer -->|reads data| S3
    OfflineServer -->|fetches metadata| RegistryServer

    RegistryServer -->|stores metadata| SQLite
    RegistryServer -->|stores metadata| PostgreSQL
    RegistryServer -->|stores metadata| S3

    CronJob -->|triggers materialization| OnlineServer
    OnlineServer -->|reads from| OfflineServer

    UIServer -->|queries| RegistryServer

    Operator -->|creates| Routes
    Operator -->|watches| Notebooks
    Operator -->|injects config| ClientCM

    OnlineServer -->|metrics| Prometheus
    OfflineServer -->|metrics| Prometheus
    Operator -->|metrics| Prometheus

    OnlineServer -.->|validates tokens| OIDC
    OfflineServer -.->|validates tokens| OIDC
    RegistryServer -.->|validates tokens| OIDC

