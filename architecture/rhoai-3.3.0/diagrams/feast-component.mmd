graph TB
    subgraph "Feast Feature Store Platform"
        Operator[Feast Operator<br/>Go Operator]

        subgraph "Feature Servers"
            Online[Online Feature Server<br/>Python FastAPI<br/>6566/6567 HTTP/gRPC]
            Offline[Offline Feature Server<br/>Python FastAPI<br/>8815/8816 HTTP]
            Registry[Registry Server<br/>Python gRPC/REST<br/>6570/6571/6572/6573]
            UI[UI Server<br/>React/TypeScript<br/>8888/8443 HTTP/HTTPS]
        end

        ConfigMap[Client ConfigMap<br/>feature_store.yaml]
        CronJob[CronJob<br/>Materialization Tasks]
    end

    subgraph "Custom Resources"
        FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1]
    end

    subgraph "Storage Backends"
        SQLite[(SQLite<br/>Default Embedded)]
        PostgreSQL[(PostgreSQL<br/>Optional Persistent)]
        Redis[(Redis<br/>Optional High-Perf)]
        S3[(S3/Object Storage<br/>Optional Offline)]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API]
        OpenShiftRoutes[OpenShift Routes]
        Prometheus[Prometheus]
        OIDC[OIDC Provider]
        KubeflowNB[Kubeflow Notebooks]
    end

    %% User interactions
    User[Data Scientist] -->|creates| FeatureStoreCR
    User -->|feast CLI/SDK| Registry
    MLApp[ML Application] -->|real-time inference| Online
    TrainingJob[Training Job] -->|historical features| Offline

    %% Operator management
    FeatureStoreCR -->|watched by| Operator
    Operator -->|creates/manages| Online
    Operator -->|creates/manages| Offline
    Operator -->|creates/manages| Registry
    Operator -->|creates/manages| UI
    Operator -->|creates/manages| ConfigMap
    Operator -->|creates| CronJob
    Operator -->|manages| K8sAPI
    Operator -->|creates routes| OpenShiftRoutes

    %% Feature server interactions
    Online -->|fetch metadata| Registry
    Offline -->|fetch metadata| Registry
    Online -->|read/write| SQLite
    Online -->|read/write| PostgreSQL
    Online -->|read/write| Redis
    Offline -->|read| S3
    Registry -->|persist metadata| SQLite
    Registry -->|persist metadata| PostgreSQL
    Registry -->|persist metadata| S3
    CronJob -->|trigger materialization| Online
    Online -->|fetch offline data| Offline

    %% Integration points
    Operator -->|inject config| KubeflowNB
    Online -->|expose metrics| Prometheus
    Offline -->|expose metrics| Prometheus
    Operator -->|expose metrics| Prometheus
    Online -->|validate tokens| OIDC
    Registry -->|validate tokens| OIDC

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style Online fill:#7ed321,stroke:#333,stroke-width:2px
    style Offline fill:#7ed321,stroke:#333,stroke-width:2px
    style Registry fill:#7ed321,stroke:#333,stroke-width:2px
    style UI fill:#7ed321,stroke:#333,stroke-width:2px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style SQLite fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style OpenShiftRoutes fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style OIDC fill:#999,stroke:#333
    style KubeflowNB fill:#999,stroke:#333
