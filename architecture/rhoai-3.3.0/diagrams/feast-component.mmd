    style OnlineServer fill:#7ed321,stroke:#333,stroke-width:2px
    style OfflineServer fill:#7ed321,stroke:#333,stroke-width:2px
    style RegistryServer fill:#7ed321,stroke:#333,stroke-width:2px
    style UIServer fill:#7ed321,stroke:#333,stroke-width:2px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style SQLite fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Routes fill:#d0d0d0,stroke:#333
    style Notebooks fill:#d0d0d0,stroke:#333
    style Prometheus fill:#d0d0d0,stroke:#333
    style OIDC fill:#d0d0d0,stroke:#333
