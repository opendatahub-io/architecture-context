%% Security Network Diagram - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["OpenShift Route / HTTPRoute<br/>443/TCP<br/>TLS 1.2+ (Edge Termination)<br/>Created by ODH Notebook Controller"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction LR
        AuthProxy["Auth Proxy Sidecar<br/>(oauth-proxy / kube-rbac-proxy)<br/>Injected by ODH Notebook Controller<br/>Per-user RBAC"]
        subgraph Containers["Workbench Containers"]
            Jupyter["Jupyter<br/>8888/TCP<br/>UID 1001"]
            CodeServer["code-server<br/>8080/TCP<br/>UID 1001"]
            RStudio["RStudio<br/>8787/TCP<br/>UID 1001"]
        end
        AuthProxy -->|HTTP| Jupyter
        AuthProxy -->|HTTP| CodeServer
        AuthProxy -->|HTTP| RStudio
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        K8sAPI["OpenShift API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        PyPI["PyPI / Package Registries<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        QuayEgress["quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        UserEndpoints["User-defined Endpoints<br/>Various ports/protocols"]
    end

    subgraph BuildInfra["BUILD INFRASTRUCTURE (Konflux)"]
        Konflux["Konflux Tekton Pipelines<br/>Clair + ClamAV + SAST scanning"]
    end

    subgraph ImageRegistry["CONTAINER IMAGE REGISTRY"]
        Quay["quay.io/modh/*<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull/Push Secrets"]
    end

    subgraph SourceCode["SOURCE CODE"]
        GitHub["GitHub<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Route

    %% Ingress to Workbench
    Route -->|"HTTP/8888,8080,8787<br/>Auth: Proxy Sidecar"| AuthProxy

    %% Workbench Egress
    Containers -->|"HTTPS/443<br/>SA Token"| K8sAPI
    Containers -->|"HTTPS/443"| PyPI
    Containers -->|"HTTPS/443"| QuayEgress
    Containers -->|"Various"| UserEndpoints

    %% Build flows
    GitHub -->|"Webhook/443<br/>Webhook Secret"| Konflux
    Konflux -->|"HTTPS/443<br/>Git Credentials"| GitHub
    Konflux -->|"HTTPS/443<br/>Push Secret"| Quay

    %% Image pull
    Quay -->|"HTTPS/443<br/>Pull Secret"| WorkbenchPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef registry fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route ingress
    class AuthProxy,Jupyter,CodeServer,RStudio workbench
    class K8sAPI,PyPI,QuayEgress,UserEndpoints egress
    class Konflux build
    class Quay,GitHub registry
