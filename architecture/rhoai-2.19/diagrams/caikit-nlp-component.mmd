graph TB
    subgraph CaikitNLP["caikit-nlp Runtime"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal[TextGeneration<br/>Local HF Transformers]
            TextGenTGIS[TextGenerationTGIS<br/>Remote via TGIS]
            PeftPT[PeftPromptTuning<br/>Prompt Tuning / MPT]
            PeftPTTGIS[PeftPromptTuningTGIS<br/>Remote PEFT via TGIS]
        end

        subgraph Embedding["Embedding & Reranking Modules"]
            EmbeddingMod[EmbeddingModule<br/>sentence-transformers]
            CrossEncoder[CrossEncoderModule<br/>Cross-encoder Reranking]
        end

        subgraph Classification["Classification Modules"]
            SeqClass[SequenceClassification]
            FilteredSpan[FilteredSpanClassification]
        end

        subgraph Tokenization["Tokenization"]
            RegexSplitter[RegexSentenceSplitter]
        end

        subgraph Resources["Model Resources"]
            PretrainedBase[PretrainedModelBase]
            CausalLM[HFAutoCausalLM]
            Seq2SeqLM[HFAutoSeq2SeqLM]
            SeqClassifier[HFAutoSeqClassifier]
            PretrainedBase --> CausalLM
            PretrainedBase --> Seq2SeqLM
            PretrainedBase --> SeqClassifier
        end

        subgraph ModelMgmt["Model Management"]
            TGISFinder[TGISAutoFinder]
        end

        subgraph Servers["Runtime Servers"]
            HTTPServer["HTTP Server<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>Port 8085/TCP"]
        end
    end

    %% Server connections to modules
    HTTPServer -->|routes to| TextGenLocal
    HTTPServer -->|routes to| EmbeddingMod
    HTTPServer -->|routes to| SeqClass
    GRPCServer -->|routes to| TextGenTGIS
    GRPCServer -->|routes to| PeftPT
    GRPCServer -->|routes to| EmbeddingMod
    GRPCServer -->|routes to| CrossEncoder

    %% Resource usage
    TextGenLocal -->|loads| CausalLM
    TextGenLocal -->|loads| Seq2SeqLM
    PeftPT -->|fine-tunes| CausalLM
    SeqClass -->|loads| SeqClassifier

    %% External dependencies
    Client[Client / Platform] -->|HTTP 8080| HTTPServer
    Client -->|gRPC 8085| GRPCServer

    TextGenTGIS -->|gRPC| TGIS[TGIS Server]
    PeftPTTGIS -->|gRPC| TGIS
    TGISFinder -->|discovers| TGIS

    CausalLM -->|downloads| HFHub[HuggingFace Hub]

    KServe[KServe / ModelMesh] -->|deploys| CaikitNLP
    ModelStorage[Model Storage<br/>PVC / S3] -->|mounts| CaikitNLP

    %% Styling
    style CaikitNLP fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style TextGen fill:#bbdefb,stroke:#1976d2
    style Embedding fill:#bbdefb,stroke:#1976d2
    style Classification fill:#bbdefb,stroke:#1976d2
    style Tokenization fill:#bbdefb,stroke:#1976d2
    style Resources fill:#c8e6c9,stroke:#388e3c
    style ModelMgmt fill:#c8e6c9,stroke:#388e3c
    style Servers fill:#fff9c4,stroke:#f9a825

    style HTTPServer fill:#fff176,stroke:#f9a825
    style GRPCServer fill:#fff176,stroke:#f9a825
    style TGIS fill:#e0e0e0,stroke:#616161
    style HFHub fill:#e0e0e0,stroke:#616161
    style KServe fill:#a5d6a7,stroke:#388e3c
    style ModelStorage fill:#ffcc80,stroke:#ef6c00
    style Client fill:#f5f5f5,stroke:#9e9e9e
