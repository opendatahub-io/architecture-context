// ML Metadata (MLMD) - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Runs ML pipelines that generate metadata"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving metadata associated with ML pipeline workflows" {
            grpcServer = container "metadata_store_server" "Main gRPC server binary serving MetadataStoreService API" "C++ / gRPC" "8080/TCP"
            serviceImpl = container "MetadataStoreServiceImpl" "Thread-safe gRPC service handler for all RPC methods" "C++"
            metadataStore = container "MetadataStore" "Core library managing CRUD on Artifacts, Executions, Contexts, Events, and lineage" "C++"
            metadataAccessObject = container "MetadataAccessObject" "Database abstraction layer for RDBMS backends" "C++"
        }

        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration platform (primary MLMD consumer)" "Internal RHOAI"
        dspOperator = softwareSystem "DSP Operator" "Deploys and manages DSP components including MLMD sidecar" "Internal RHOAI"

        mysql = softwareSystem "MySQL / MariaDB" "Relational database for persistent metadata storage" "External"
        postgresql = softwareSystem "PostgreSQL" "Alternative relational database backend" "External"

        // Relationships
        datascientist -> dsp "Runs ML pipelines via"
        dsp -> mlmd "Stores/retrieves pipeline metadata" "gRPC/HTTP2 :8080"
        dspOperator -> mlmd "Deploys as sidecar container"

        mlmd -> mysql "Stores metadata" "MySQL protocol :3306"
        mlmd -> postgresql "Stores metadata (alternative)" "PostgreSQL protocol :5432"

        // Internal container relationships
        grpcServer -> serviceImpl "Delegates RPC calls"
        serviceImpl -> metadataStore "CRUD operations"
        metadataStore -> metadataAccessObject "Database queries"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
