/*
 * Kubeflow Notebook Controller - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/kubeflow.md
 */

workspace {
    model {
        user = person "Data Scientist / User" "Creates and manages Jupyter Notebook servers via Notebook CRs"

        kubeflow = softwareSystem "Kubeflow Notebook Controller" "Kubernetes controller that manages lifecycle of Jupyter Notebook servers by reconciling Notebook CRs into StatefulSets, Services, and optionally Istio VirtualServices" {
            notebookReconciler = container "NotebookReconciler" "Reconciles Notebook CRs into StatefulSets, Services, and optionally Istio VirtualServices" "Go Controller (controller-runtime)"
            cullingReconciler = container "CullingReconciler" "Monitors notebook idle time via Jupyter API and stops idle notebooks by setting stop annotations" "Go Controller"
            metricsCollector = container "Metrics Collector" "Exposes notebook_running, notebook_create_total, notebook_culling_total metrics" "Prometheus client_golang"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for resource management" "External"
        istio = softwareSystem "Istio" "Service mesh for traffic routing via VirtualServices (optional)" "External"
        odhNotebookCtrl = softwareSystem "odh-notebook-controller" "Complementary controller adding OpenShift-specific features (OAuth, Routes, NetworkPolicy)" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science workspaces" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        jupyterNotebooks = softwareSystem "Jupyter Notebook Servers" "Running notebook instances managed by the controller" "Managed"

        # Relationships
        user -> kubeflow "Creates Notebook CRs via kubectl/Dashboard"
        user -> odhDashboard "Manages notebooks via UI"
        odhDashboard -> k8sAPI "Creates Notebook CRs" "HTTPS/443"

        kubeflow -> k8sAPI "CRUD operations on StatefulSets, Services, Notebooks, VirtualServices" "HTTPS/443 TLS 1.2+"
        kubeflow -> istio "Creates VirtualService CRs for traffic routing (when USE_ISTIO=true)" "Kubernetes CRD"
        kubeflow -> jupyterNotebooks "Polls /api/kernels and /api/terminals for idle detection" "HTTP/80"

        odhNotebookCtrl -> k8sAPI "Watches Notebook CRs, creates Routes, OAuth proxies, NetworkPolicies" "HTTPS/443"
        prometheus -> kubeflow "Scrapes metrics" "HTTP/8080"

        # Internal container relationships
        notebookReconciler -> k8sAPI "Creates StatefulSets, Services, VirtualServices" "HTTPS/443"
        cullingReconciler -> jupyterNotebooks "Polls idle status" "HTTP/80"
        cullingReconciler -> k8sAPI "Updates Notebook annotations" "HTTPS/443"
    }

    views {
        systemContext kubeflow "SystemContext" {
            include *
            autoLayout
        }

        container kubeflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
