graph TB
    subgraph KubeCluster["KUBERNETES CLUSTER (Internal)"]
        direction TB

        subgraph DSPPod["DATA SCIENCE PIPELINES POD<br/>Namespace: dsp-namespace"]
            direction LR

            DSP["DSP API Server<br/>(ds-pipeline-*)<br/>Primary MLMD Client"]
