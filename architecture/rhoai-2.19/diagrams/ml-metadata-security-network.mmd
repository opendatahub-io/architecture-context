    end

    %% Internal flow (pod-local)
    DSP -->|"gRPC/HTTP2 :8080<br/>Default: Plaintext<br/>Optional: TLS/mTLS<br/>(SSLConfig + client_verify)"| MLMD

    %% Egress to databases
