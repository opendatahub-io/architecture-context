/*
 * C4 Context Diagram: Text Generation Inference Server (TGIS)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        client = person "API Client" "Application or service sending text generation requests"

        tgis = softwareSystem "Text Generation Inference Server (TGIS)" "High-performance text generation inference server for LLMs with gRPC and HTTP APIs" {
            launcher = container "text-generation-launcher" "Process orchestrator: starts model server shards and router, manages lifecycle and signals" "Rust Binary"
            router = container "text-generation-router" "External-facing gRPC and HTTP server: request validation, tokenization, batching, response assembly" "Rust (Axum + Tonic)"
            serverShard = container "text-generation-server" "Model inference engine: loads models, runs PyTorch inference on GPU, serves internal gRPC API" "Python gRPC Server"
            clientLib = container "text-generation-client" "Client library for router to communicate with server shards over UDS" "Rust gRPC Client"
            cudaKernels = container "Custom CUDA Kernels" "Optimized GPU kernels for inference operations" "C++/CUDA"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Deployment orchestration for inference runtimes" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal"
        otlpCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing via OTLP" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model weight download (offline at runtime)" "External"
        modelStorage = softwareSystem "Model Storage (PVC/S3)" "Model weight storage" "Infrastructure"

        /* External relationships */
        client -> tgis "Sends text generation requests" "gRPC/8033, Optional TLS/mTLS"
        kserve -> tgis "Deploys and manages as inference runtime"
        tgis -> prometheus "Exposes metrics" "HTTP/3000"
        tgis -> otlpCollector "Exports traces" "gRPC (optional)"
        tgis -> hfHub "Downloads model weights (disabled at runtime)" "HTTPS/443"
        tgis -> modelStorage "Loads model weights" "Volume mount"

        /* Internal relationships */
        launcher -> router "Spawns and manages process"
        launcher -> serverShard "Spawns and manages shard processes"
        router -> clientLib "Uses for shard communication"
        clientLib -> serverShard "Internal inference requests" "gRPC/UDS plaintext"
        serverShard -> cudaKernels "GPU-accelerated inference" "CUDA"
    }

    views {
        systemContext tgis "SystemContext" {
            include *
            autoLayout
        }

        container tgis "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
            }
            element "Internal RHOAI" {
                background #7ed321
            }
            element "Infrastructure" {
                background #f5a623
            }
        }
    }
}
