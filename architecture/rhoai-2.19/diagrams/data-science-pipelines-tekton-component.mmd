%% Component Structure Diagram - Data Science Pipelines Tekton
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "Data Science Pipelines Tekton"
        direction TB

        subgraph "API Layer"
            APIServer["ds-pipeline<br/>(API Server)<br/>REST 8888/TCP<br/>gRPC 8887/TCP"]
            CacheServer["cache-server<br/>(Mutating Webhook)<br/>443/TCP HTTPS"]
        end

        subgraph "Controllers"
            ScheduledWF["ds-pipeline-scheduledworkflow<br/>(ScheduledWorkflow Controller)"]
            ViewerCRD["ds-pipeline-viewer-crd<br/>(Viewer Controller)"]
        end

        subgraph "Agents"
            PersistenceAgent["ds-pipeline-persistenceagent<br/>(Persistence Agent)"]
            MetadataWriter["metadata-writer<br/>(MLMD Writer)"]
        end

        subgraph "Frontend"
            UI["ds-pipeline-ui<br/>Port 3000"]
            OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS"]
            OAuthProxy -->|proxies to| UI
        end

        subgraph "Metadata Services"
            MLMDServer["metadata-grpc-server<br/>8080/TCP gRPC"]
            MetadataEnvoy["metadata-envoy<br/>9090/TCP gRPC"]
            MetadataEnvoy -->|proxies to| MLMDServer
        end

        subgraph "Visualization"
            VizServer["ds-pipeline-visualizationserver<br/>8888/TCP HTTP"]
        end
    end

    %% CRDs
    ScheduledWFCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    PipelineRunCR["PipelineRun CR<br/>tekton.dev"]
    TaskRunCR["TaskRun CR<br/>tekton.dev"]

    %% External Dependencies
    TektonPipelines["Tekton Pipelines<br/>>= 0.41.0"]
    MySQL["MySQL/MariaDB<br/>3306/TCP"]
    MinIO["MinIO/S3<br/>9000/TCP"]
    K8sAPI["Kubernetes API<br/>443/TCP"]

    %% Internal Dependencies
    ODHDashboard["ODH Dashboard"]
    Prometheus["Prometheus"]

    %% Flows
    UI -->|REST calls| APIServer
    APIServer -->|creates| PipelineRunCR
    APIServer -->|creates| ScheduledWFCR
    APIServer -->|reads/writes| MySQL
    APIServer -->|artifacts| MinIO
    APIServer -->|viz requests| VizServer

    ScheduledWFCR -->|watched by| ScheduledWF
    ScheduledWF -->|creates| PipelineRunCR

    PipelineRunCR -->|executed by| TektonPipelines
    PipelineRunCR -->|watched by| PersistenceAgent
    PersistenceAgent -->|syncs status| APIServer

    PipelineRunCR -->|watched by| MetadataWriter
    TaskRunCR -->|watched by| MetadataWriter
    MetadataWriter -->|writes metadata| MetadataEnvoy
    MLMDServer -->|stores in| MySQL

    ViewerCR -->|watched by| ViewerCRD

    CacheServer -->|checks cache| MySQL

    APIServer -->|CRD ops| K8sAPI
    ODHDashboard -.->|integrates| APIServer
    Prometheus -.->|scrapes /metrics| APIServer

