// vLLM C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/vllm.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM models for inference"
        appDeveloper = person "Application Developer" "Integrates LLM inference into applications via API"

        vllm = softwareSystem "vLLM" "High-throughput, memory-efficient LLM inference and serving engine with OpenAI-compatible API" {
            openaiServer = container "OpenAI API Server" "FastAPI-based HTTP server exposing OpenAI-compatible REST API" "Python FastAPI" "Web Server"
            tgisAdapter = container "TGIS gRPC Adapter" "gRPC service wrapping vLLM with TGIS protocol via vllm-tgis-adapter" "Python gRPC" "Web Server"
            llmEngine = container "vLLM Engine" "Core inference engine with PagedAttention, continuous batching, ZeroMQ IPC" "Python"
            gpuWorkers = container "GPU Workers" "Per-GPU worker processes for tensor-parallel and pipeline-parallel inference" "Python/CUDA/ROCm"
            cudaKernels = container "CUDA Kernels" "Custom GPU kernels for attention, quantization, MoE, custom all-reduce" "C++/CUDA"
        }

        kserve = softwareSystem "KServe" "Model serving orchestration and autoscaling platform" "Internal RHOAI"
        caikit = softwareSystem "Caikit" "Inference protocol interop via TGIS gRPC protocol" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact metadata and retrieval" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal Platform"

        istio = softwareSystem "Istio / Gateway API" "Service mesh and ingress gateway for traffic management" "External Platform"
        huggingface = softwareSystem "HuggingFace Hub" "Model and tokenizer repository" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Model artifact storage (S3, MinIO, etc.)" "External"
        rayCluster = softwareSystem "Ray Cluster" "Distributed computing for pipeline parallelism" "External"
        nvidiaGPU = softwareSystem "NVIDIA GPU (CUDA 12.4)" "GPU computation hardware" "Infrastructure"
        amdGPU = softwareSystem "AMD GPU (ROCm 6.3.4)" "GPU computation hardware" "Infrastructure"

        // User interactions
        user -> kserve "Deploys InferenceService with vLLM runtime"
        appDeveloper -> vllm "POST /v1/chat/completions, /v1/completions, /v1/embeddings" "HTTPS/443"

        // Internal container relationships
        openaiServer -> llmEngine "Forwards inference requests" "ZeroMQ IPC"
        tgisAdapter -> openaiServer "Translates gRPC to HTTP" "HTTP/8000"
        llmEngine -> gpuWorkers "Dispatches model execution" "In-process/NCCL"
        gpuWorkers -> cudaKernels "Executes GPU operations" "In-process"

        // Platform integrations
        kserve -> vllm "Manages as InferenceService runtime" "HTTP/8000, gRPC/8033"
        vllm -> istio "Ingress traffic routing" "HTTP"
        prometheus -> vllm "Scrapes metrics" "HTTP/8000 /metrics"
        vllm -> caikit "gRPC protocol compatibility via TGIS adapter" "gRPC/8033"
        vllm -> modelRegistry "Fetches model metadata" "API"

        // External dependencies
        vllm -> huggingface "Downloads models and tokenizers" "HTTPS/443"
        vllm -> s3Storage "Downloads model artifacts" "HTTPS/443"
        vllm -> rayCluster "Distributed inference coordination" "TCP/6379"
        gpuWorkers -> nvidiaGPU "GPU computation" "PCIe/NVLink"
        gpuWorkers -> amdGPU "GPU computation" "PCIe"
    }

    views {
        systemContext vllm "SystemContext" {
            include *
            autoLayout
        }

        container vllm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Platform" {
                background #775599
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal Platform" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #e74c3c
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Web Server" {
                shape WebBrowser
            }
        }
    }
}
