graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Platform["PLATFORM GATEWAY"]
        KServe["KServe / ModelMesh<br/>Platform Auth<br/>Container Lifecycle"]
    end

    subgraph Runtime["CAIKIT-NLP RUNTIME<br/>Container: quay.io/modh/caikit-nlp<br/>User: caikit (UID 1001)"]
        direction TB

        HTTPServer["HTTP Server<br/>8080/TCP<br/>TLS (configurable)<br/>Auth: Platform-delegated"]
        GRPCServer["gRPC Server<br/>8085/TCP<br/>mTLS (configurable)<br/>Auth: Certificate-based"]

        subgraph HTTPEndpoints["HTTP Endpoints"]
            E1["/api/v1/task/text-generation"]
            E2["/api/v1/task/embedding"]
            E3["/api/v1/task/sentence-similarity"]
            E4["/api/v1/task/rerank"]
            E5["/api/v1/task/text-classification"]
            E6["/ (health)"]
        end

        subgraph GRPCServices["gRPC Services"]
            G1["caikit.runtime.TextGeneration"]
            G2["caikit.runtime.Embedding"]
            G3["caikit.runtime.SentenceSimilarity"]
            G4["caikit.runtime.Rerank"]
            G5["caikit.runtime.Tokenization"]
            G6["grpc.health.v1.Health"]
        end

        HTTPServer --> HTTPEndpoints
        GRPCServer --> GRPCServices
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        TGIS["TGIS Server<br/>8033-8034/TCP gRPC<br/>TLS/mTLS (configurable)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token (optional)"]
    end

    subgraph Storage["MODEL STORAGE"]
        PVC["PVC / S3<br/>Volume Mount: /caikit/<br/>Filesystem Access"]
    end

    %% Flows
    Client -->|"HTTPS / gRPC<br/>TLS<br/>Platform Auth"| KServe
    KServe -->|"HTTP/8080<br/>TLS (configurable)<br/>RUNTIME_TLS_SERVER_KEY/CERT"| HTTPServer
    KServe -->|"gRPC/8085<br/>mTLS (configurable)<br/>RUNTIME_TLS_CLIENT_CERT"| GRPCServer
    GRPCServer -->|"gRPC/8033-8034<br/>TLS/mTLS<br/>ca_cert_file + client_cert/key"| TGIS
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>API Token"| HFHub
    PVC -.->|"Volume Mount"| Runtime

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef server fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class KServe platform
    class HTTPServer,GRPCServer server
    class TGIS,HFHub externalservice
    class PVC storage
