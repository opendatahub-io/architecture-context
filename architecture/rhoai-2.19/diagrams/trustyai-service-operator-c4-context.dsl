// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates ML models, evaluates model fairness, and runs LM evaluations"
        mlops = person "MLOps Engineer" "Deploys and manages AI/ML services on OpenShift"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller Go operator managing TrustyAI explainability services, LM evaluation jobs, and guardrails orchestration" {
            tasController = container "TAS Controller" "Reconciles TrustyAIService CRs; manages deployments with OAuth proxy, routes, ServiceMonitors, PVCs; patches InferenceServices with InferenceLoggers" "Go Controller"
            lmesController = container "LMES Controller" "Reconciles LMEvalJob CRs; creates evaluation pods with driver sidecars; manages job lifecycle states" "Go Controller"
            jobMgrController = container "JobMgr Controller" "Creates Kueue Workload CRs for resource-aware LMEvalJob scheduling" "Go Controller"
            gorchController = container "GORCH Controller" "Reconciles GuardrailsOrchestrator CRs; deploys orchestrator with optional vLLM gateway and regex detector" "Go Controller"
            operatorManager = container "Operator Manager" "Main entrypoint; configures controller-runtime with leader election; selectively enables controllers via --enable-services" "Go Binary"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Kubernetes-native model serving with InferenceService CRDs" "External"
        kueue = softwareSystem "Kueue" "Kubernetes-native workload scheduling and resource management" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh providing mTLS and traffic management (optional)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor CRDs" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authentication via oauth-proxy sidecar and SAR checks" "Internal Platform"
        openshiftServingCerts = softwareSystem "OpenShift Service Serving Certificates" "Automatic TLS certificate provisioning via annotations" "Internal Platform"
        certManager = softwareSystem "cert-manager" "TLS certificate lifecycle management" "External"

        database = softwareSystem "Database" "Relational database for TrustyAI data persistence (optional)" "External Service"
        s3Storage = softwareSystem "S3 Storage" "S3-compatible storage for LMEval offline data" "External Service"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry trace and metrics collection endpoint" "External Service"
        modelEndpoints = softwareSystem "Model Endpoints" "ML model serving endpoints for evaluation and guardrails" "External Service"

        // User interactions
        datascientist -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator CRs via kubectl/UI"
        mlops -> trustyaiOperator "Deploys and configures AI governance services"

        // Operator dependencies
        trustyaiOperator -> kserve "Patches InferenceServices with InferenceLoggers for payload logging" "HTTPS/443"
        trustyaiOperator -> kueue "Creates Workload CRs for resource-aware job scheduling" "Kubernetes API"
        trustyaiOperator -> istio "Creates DestinationRules and VirtualServices (optional)" "Kubernetes API"
        trustyaiOperator -> prometheus "Creates ServiceMonitors for fairness metrics collection" "HTTP/80"
        trustyaiOperator -> openshiftOAuth "Deploys oauth-proxy sidecars for service authentication" "HTTPS/8443"
        trustyaiOperator -> openshiftServingCerts "Uses annotation-based TLS certificate provisioning"

        // Egress to external services
        trustyaiOperator -> database "Stores model monitoring data (DATABASE mode)" "JDBC, optional TLS"
        trustyaiOperator -> s3Storage "Downloads evaluation data (offline mode)" "HTTPS/443"
        trustyaiOperator -> otlpCollector "Exports guardrails traces and metrics" "HTTP/gRPC"
        trustyaiOperator -> modelEndpoints "Sends evaluation and guardrails requests" "HTTP/HTTPS"

        // Inbound from KServe
        kserve -> trustyaiOperator "Sends inference payloads via InferenceLogger" "HTTPS/443"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal Platform" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
