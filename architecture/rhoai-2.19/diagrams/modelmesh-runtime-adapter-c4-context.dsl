// C4 Context Diagram: modelmesh-runtime-adapter
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/modelmesh-runtime-adapter.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys ML models via InferenceService CRs"
        mlEngineer = person "ML Engineer" "Configures model serving runtimes and storage"

        modelmeshRuntimeAdapter = softwareSystem "ModelMesh Runtime Adapter" "Sidecar container providing model storage retrieval and runtime-specific protocol adaptation" {
            puller = container "model-serving-puller" "Intercepts ModelRuntime gRPC calls, downloads models from storage, forwards to runtime adapter" "Go gRPC Server/Client" {
                tags "Adapter"
            }
            pullmanLib = container "pullman" "Pluggable storage provider framework for S3, GCS, Azure, HTTP, PVC" "Go Library" {
                tags "Adapter"
            }
            tritonAdapter = container "model-mesh-triton-adapter" "Translates ModelRuntime gRPC to Triton GRPCInferenceService" "Go gRPC Server" {
                tags "Adapter"
            }
            mlserverAdapter = container "model-mesh-mlserver-adapter" "Translates ModelRuntime gRPC to MLServer dataplane gRPC" "Go gRPC Server" {
                tags "Adapter"
            }
            ovmsAdapter = container "model-mesh-ovms-adapter" "Translates ModelRuntime gRPC to OVMS HTTP REST config/reload API" "Go gRPC Server" {
                tags "Adapter"
            }
            torchserveAdapter = container "model-mesh-torchserve-adapter" "Translates ModelRuntime gRPC to TorchServe Management/Inference gRPC APIs" "Go gRPC Server" {
                tags "Adapter"
            }
        }

        modelmesh = softwareSystem "ModelMesh" "Intelligent model routing and caching layer" "Internal RHOAI" {
            tags "Internal"
        }
        modelmeshServing = softwareSystem "ModelMesh Serving Controller" "Manages model serving runtime configurations" "Internal RHOAI" {
            tags "Internal"
        }

        triton = softwareSystem "Triton Inference Server" "NVIDIA GPU-optimized inference server" "External Runtime" {
            tags "Runtime"
        }
        mlserver = softwareSystem "Seldon MLServer" "Python-based inference server supporting sklearn, xgboost, etc." "External Runtime" {
            tags "Runtime"
        }
        ovms = softwareSystem "OpenVINO Model Server" "Intel inference server optimized for OpenVINO models" "External Runtime" {
            tags "Runtime"
        }
        torchserve = softwareSystem "TorchServe" "PyTorch model serving framework" "External Runtime" {
            tags "Runtime"
        }

        s3 = softwareSystem "S3 / IBM COS" "S3-compatible object storage for model artifacts" "External Storage" {
            tags "ExternalStorage"
        }
        gcs = softwareSystem "Google Cloud Storage" "GCP object storage for model artifacts" "External Storage" {
            tags "ExternalStorage"
        }
        azure = softwareSystem "Azure Blob Storage" "Azure object storage for model artifacts" "External Storage" {
            tags "ExternalStorage"
        }
        httpStorage = softwareSystem "HTTP/HTTPS Endpoints" "Generic HTTP storage for model artifacts" "External Storage" {
            tags "ExternalStorage"
        }

        // Relationships
        modelmesh -> modelmeshRuntimeAdapter "Sends model lifecycle calls (load/unload/status)" "gRPC/8084"
        modelmeshServing -> modelmeshRuntimeAdapter "Configures runtime adapter image" "ConfigMap"

        puller -> pullmanLib "Uses for storage downloads"
        puller -> tritonAdapter "Forwards model operations" "gRPC/8085"
        puller -> mlserverAdapter "Forwards model operations" "gRPC/8085"
        puller -> ovmsAdapter "Forwards model operations" "gRPC/8085"
        puller -> torchserveAdapter "Forwards model operations" "gRPC/8085"

        tritonAdapter -> triton "Model load/unload, metadata" "gRPC/8001"
        mlserverAdapter -> mlserver "Model load/unload" "gRPC/8001"
        ovmsAdapter -> ovms "Config reload" "HTTP/8001"
        torchserveAdapter -> torchserve "Model registration, inference" "gRPC/7071, 7070"

        modelmeshRuntimeAdapter -> s3 "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        modelmeshRuntimeAdapter -> gcs "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        modelmeshRuntimeAdapter -> azure "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        modelmeshRuntimeAdapter -> httpStorage "Downloads model artifacts" "HTTP(S)/80-443"

        dataScientist -> modelmesh "Deploys models" "InferenceService CR"
        mlEngineer -> modelmeshServing "Configures runtimes" "ServingRuntime CR"
    }

    views {
        systemContext modelmeshRuntimeAdapter "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshRuntimeAdapter "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Runtime" {
                background #e1d5e7
                color #333333
            }
            element "ExternalStorage" {
                background #999999
                color #ffffff
            }
            element "Adapter" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
