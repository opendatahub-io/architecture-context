// Kueue C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Submits ML training jobs and batch workloads"
        admin = person "Platform Admin" "Configures queues, quotas, and fair-sharing policies"

        kueue = softwareSystem "Kueue" "Kubernetes-native job queueing system managing workload admission based on quota and fair-sharing policies" {
            controllerManager = container "Controller Manager" "Main binary managing all controllers, scheduler, webhooks, and metrics server" "Go (controller-runtime)"
            scheduler = container "Scheduler" "Evaluates pending workloads against available quota and makes admission decisions" "Go Component"
            webhookServer = container "Webhook Server" "Mutating and validating admission webhooks for Kueue CRDs and integrated job types" "HTTPS/9443"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics with authenticated access" "HTTPS/8443"
            internalCertMgr = container "Internal Cert Manager" "Self-signed certificate management for webhook and visibility server TLS" "Go Component"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for CRD management, webhook callbacks, leader election" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and alerting via ServiceMonitor" "External"

        kubeflowTraining = softwareSystem "Kubeflow Training Operator" "Manages distributed training jobs (PyTorchJob, TFJob, MPIJob, etc.)" "Internal ODH"
        kuberay = softwareSystem "KubeRay Operator" "Manages Ray workloads (RayJob, RayCluster)" "Internal ODH"
        jobsetCtrl = softwareSystem "JobSet Controller" "Manages JobSet workloads" "Internal ODH"
        codeflare = softwareSystem "CodeFlare AppWrapper" "Manages AppWrapper workloads" "Internal ODH"
        clusterAutoscaler = softwareSystem "Cluster Autoscaler" "ProvisioningRequest API for node provisioning" "External"

        // Relationships - External
        user -> kueue "Submits jobs via kubectl" "HTTPS/443"
        admin -> kueue "Configures ClusterQueues, ResourceFlavors, quotas" "HTTPS/443"
        kueue -> k8sAPI "CRD watches, status updates, leader election" "HTTPS/443"
        k8sAPI -> kueue "Webhook callbacks for job admission" "HTTPS/443->9443"
        prometheus -> kueue "Scrapes metrics" "HTTPS/8443"
        kueue -> clusterAutoscaler "ProvisioningRequest for node provisioning (feature-gated)" "HTTPS/443"

        // Relationships - Internal ODH
        kueue -> kubeflowTraining "Manages queueing for training jobs via CRD watch + webhooks"
        kueue -> kuberay "Manages queueing for Ray workloads via CRD watch + webhooks"
        kueue -> jobsetCtrl "Manages queueing for JobSet workloads via CRD watch + webhooks"
        kueue -> codeflare "Manages queueing for AppWrapper workloads via external framework"

        // Container-level relationships
        controllerManager -> scheduler "Contains"
        controllerManager -> webhookServer "Contains"
        controllerManager -> metricsServer "Contains"
        internalCertMgr -> webhookServer "Provisions TLS certificates"
        scheduler -> k8sAPI "Admission decisions, workload status updates" "HTTPS/443"
        webhookServer -> k8sAPI "Webhook responses" "HTTPS/443"
        metricsServer -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
    }

    views {
        systemContext kueue "SystemContext" {
            include *
            autoLayout
        }

        container kueue "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
