// ModelMesh Serving - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and deploys ML models for inference"
        admin = person "Platform Admin" "Configures serving runtimes and cluster settings"

        modelmeshServing = softwareSystem "ModelMesh Serving" "Kubernetes operator managing multi-model serving runtimes via KServe API, backed by ModelMesh distributed serving framework" {
            controller = container "modelmesh-controller" "Main Go operator managing ServingRuntimes, Predictors, InferenceServices; reconciles Deployments and Services" "Go (controller-runtime)"
            webhook = container "Validating Webhook" "Validates ServingRuntime and ClusterServingRuntime CREATE/UPDATE operations" "Go Service, :9443/TCP"
            servingRuntimeReconciler = container "ServingRuntimeReconciler" "Reconciles ServingRuntime/ClusterServingRuntime CRDs into runtime Deployments with sidecars" "Go Controller"
            predictorReconciler = container "PredictorReconciler" "Reconciles Predictor/InferenceService CRs by managing vmodel registrations via gRPC" "Go Controller"
            serviceReconciler = container "ServiceReconciler" "Creates/manages headless Kubernetes Services and ServiceMonitor CRs per namespace" "Go Controller"
            eventStream = container "ModelMeshEventStream" "Watches etcd for model/vmodel state changes and generates reconciliation events" "Go"
            modelmeshSidecar = container "ModelMesh Sidecar" "Distributed model serving framework: model routing, caching, lifecycle, inter-pod gRPC" "Java, gRPC :8033"
            restProxy = container "REST Proxy Sidecar" "Translates HTTP/REST inference requests to gRPC for ModelMesh" ":8008/TCP"
            oauthProxy = container "oauth-proxy Sidecar" "OpenShift OAuth proxy providing authentication for inference endpoints" "HTTPS :8443"
            puller = container "Storage Puller Sidecar" "Fetches model artifacts from S3/GCS/PVC storage into runtime pods" "gRPC :8086"
        }

        etcd = softwareSystem "etcd" "Distributed key-value store for ModelMesh model registry and coordination" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane API for CRD watch/reconcile and resource management" "External"
        objectStorage = softwareSystem "S3/GCS Object Storage" "Model artifact storage backend" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authentication and token validation for inference endpoints" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection from controller and runtime pods" "Internal Platform"

        // Inference runtimes (internal)
        ovms = softwareSystem "OpenVINO Model Server" "Inference runtime for OpenVINO IR and ONNX models" "Internal ODH"
        triton = softwareSystem "Triton Inference Server" "Inference runtime for various model formats" "Internal ODH"
        mlserver = softwareSystem "MLServer" "Inference runtime for sklearn, XGBoost, LightGBM models" "Internal ODH"

        // User interactions
        dataScientist -> modelmeshServing "Creates Predictor/InferenceService CRs via kubectl/Dashboard"
        dataScientist -> oauthProxy "Sends inference requests" "HTTPS/8443"
        admin -> modelmeshServing "Creates ServingRuntime/ClusterServingRuntime CRs"

        // Internal flows
        controller -> servingRuntimeReconciler "Delegates runtime reconciliation"
        controller -> predictorReconciler "Delegates predictor reconciliation"
        controller -> serviceReconciler "Delegates service reconciliation"
        controller -> eventStream "Receives etcd events"
        servingRuntimeReconciler -> modelmeshSidecar "Creates runtime pods with sidecars"
        predictorReconciler -> modelmeshSidecar "Registers vmodels via gRPC" "gRPC/8033"
        oauthProxy -> restProxy "Forwards authenticated requests" "HTTP/8008"
        restProxy -> modelmeshSidecar "REST to gRPC translation" "gRPC/8033"
        modelmeshSidecar -> puller "Triggers model loading" "gRPC/8086"

        // External dependencies
        controller -> etcd "Watches model/vmodel state changes" "gRPC/2379"
        controller -> k8sAPI "Watches CRDs, manages resources" "HTTPS/6443"
        modelmeshSidecar -> etcd "Model registry coordination" "gRPC/2379"
        puller -> objectStorage "Downloads model artifacts" "HTTPS/443"
        oauthProxy -> openshiftOAuth "Validates OAuth tokens" "HTTPS/443"
        prometheus -> controller "Scrapes controller metrics" "HTTP/8080"
        prometheus -> modelmeshSidecar "Scrapes runtime metrics" "HTTP/2112"

        // Runtime backends
        modelmeshSidecar -> ovms "Inference requests" "gRPC"
        modelmeshSidecar -> triton "Inference requests" "gRPC"
        modelmeshSidecar -> mlserver "Inference requests" "gRPC"
    }

    views {
        systemContext modelmeshServing "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Internal Platform" {
                background #85bbf0
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
