/*
 * Feast C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/feast.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist / ML Engineer" "Creates feature definitions and retrieves features for ML models"
        mlApp = person "ML Application" "Production application consuming online features"

        feast = softwareSystem "Feast" "Feature store platform for managing and serving ML features" {
            operator = container "Feast Operator" "Manages FeatureStore CRs; creates Deployments, Services, ConfigMaps, PVCs, RBAC, Routes" "Go Operator (controller-runtime)"
            onlineServer = container "Feature Server (Python)" "Serves online features via HTTP REST API" "Python FastAPI/Uvicorn"
            goServer = container "Feature Server (Go)" "Alternative Go-based gRPC/HTTP feature server" "Go gRPC Service"
            offlineServer = container "Offline Store" "Serves historical features via Arrow Flight RPC" "Python Service"
            registryServer = container "Registry Server" "Manages feature metadata (entities, feature views, data sources)" "Python gRPC Service"
            uiServer = container "UI Server" "Web UI for exploring feature store definitions" "Python/React"
            initContainer = container "feast-init" "Initializes feast project directory" "Init Container"
        }

        k8sApi = softwareSystem "Kubernetes API Server" "Cluster control plane" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller for external access" "External"
        redis = softwareSystem "Redis" "In-memory data store for online features" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for online/offline/registry persistence" "External"
        snowflake = softwareSystem "Snowflake" "Cloud data warehouse for online/offline/registry persistence" "External"
        s3 = softwareSystem "S3/GCS Storage" "Object storage for registry file persistence" "External"
        oidcProvider = softwareSystem "OIDC Provider" "OpenID Connect identity provider for authorization" "External"
        gitRepo = softwareSystem "Git Repository" "Source for feature definitions" "External"

        # User interactions
        dataScientist -> feast "Manages feature definitions via Feast CLI/SDK"
        dataScientist -> registryServer "CRUD feature metadata" "gRPC/6570"
        dataScientist -> uiServer "Explores feature definitions" "HTTPS/443"
        mlApp -> onlineServer "Retrieves online features" "HTTP/6566 or HTTPS/6567"

        # Operator interactions
        operator -> k8sApi "Reconciles FeatureStore CRs, creates K8s resources" "HTTPS/443"

        # Service to backend interactions
        onlineServer -> redis "Reads/writes online features" "Redis/6379"
        onlineServer -> postgresql "Reads/writes online features" "PostgreSQL/5432"
        offlineServer -> postgresql "Queries historical features" "PostgreSQL/5432"
        offlineServer -> snowflake "Queries historical features" "HTTPS/443"
        registryServer -> postgresql "Stores feature metadata" "PostgreSQL/5432"
        registryServer -> s3 "Persists registry files" "HTTPS/443"

        # Init container
        initContainer -> gitRepo "Clones feature definitions" "HTTPS/443"

        # Auth
        onlineServer -> k8sApi "K8s RBAC auth checks (TokenReview)" "HTTPS/443"
        onlineServer -> oidcProvider "OIDC JWT validation" "HTTPS/443"

        # External access
        openshiftRouter -> uiServer "Routes external traffic to UI" "HTTPS/443 TLS Passthrough"
    }

    views {
        systemContext feast "SystemContext" {
            include *
            autoLayout
        }

        container feast "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
