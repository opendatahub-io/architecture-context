// C4 Context Diagram - odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and deploys ML models via InferenceService CRs"
        admin = person "Platform Admin" "Configures NIM accounts and data connections"

        odhModelController = softwareSystem "odh-model-controller" "Manages lifecycle of OpenShift resources for KServe, ModelMesh, and NIM model serving" {
            isvcController = container "InferenceService Controller" "Watches InferenceService CRs, delegates to mode-specific reconcilers (Serverless, RawDeployment, ModelMesh)" "Go Controller"
            igController = container "InferenceGraph Controller" "Watches InferenceGraph CRs, reconciles Authorino AuthConfig resources" "Go Controller"
            srController = container "ServingRuntime Controller" "Watches ServingRuntime CRs, manages monitoring RoleBindings and Ray TLS certs" "Go Controller"
            cmController = container "ConfigMap Controller" "Propagates ODH global CA certs to KServe-specific ConfigMaps" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into unified storage-config" "Go Controller"
            podController = container "Pod Controller" "Generates per-pod Ray TLS certificates for multi-node serving" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM integration: API key validation, model data, pull secrets, templates" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating/validating webhooks for Pods, InferenceServices, InferenceGraphs, NIM Accounts, Knative Services" "Go Admission Webhooks" "9443/TCP TLS"
        }

        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform" "External"
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for traffic management, mTLS, and authorization" "External"
        authorino = softwareSystem "Authorino" "External authorization service for model serving" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller for external route access" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and monitoring" "External"
        certManager = softwareSystem "OpenShift service-ca" "Certificate provisioning for webhook TLS" "External"

        modelRegistry = softwareSystem "Model Registry" "Stores model metadata" "Internal ODH"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform management" "Internal ODH"
        dsc = softwareSystem "DataScienceCluster / DSCInitialization" "RHOAI platform configuration CRDs" "Internal ODH"

        nvidiaNCG = softwareSystem "NVIDIA NGC API" "NIM model data and API key validation" "External Service"
        nvcr = softwareSystem "NVIDIA Container Registry (nvcr.io)" "NIM container images" "External Service"

        // User relationships
        user -> odhModelController "Creates InferenceService/InferenceGraph CRs via kubectl/API"
        admin -> odhModelController "Creates NIM Account CRs and data connection Secrets"

        // ODH Model Controller relationships
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph CRs" "HTTPS/6443"
        odhModelController -> istio "Manages Gateway servers, PeerAuthentications, Telemetries, ServiceMeshMembers" "HTTPS/6443"
        odhModelController -> authorino "Creates AuthConfig CRs for model serving authorization" "HTTPS/6443"
        odhModelController -> openshiftRouter "Creates Routes for external model serving access" "HTTPS/6443"
        odhModelController -> prometheus "Creates ServiceMonitors, PodMonitors, RoleBindings" "HTTPS/6443"
        odhModelController -> modelRegistry "Optional sync of InferenceService metadata" "HTTPS (varies)"
        odhModelController -> dsc "Reads DSC/DSCI for component state and capabilities" "HTTPS/6443"
        odhModelController -> nvidiaNCG "NIM model data retrieval and API key validation" "HTTPS/443"
        odhModelController -> nvcr "NIM container image pull secret creation" "HTTPS/443"
        odhModelController -> certManager "Webhook TLS cert provisioning via annotation" "Auto"

        // Incoming
        dashboard -> odhModelController "Creates data connection Secrets with opendatahub.io labels"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
