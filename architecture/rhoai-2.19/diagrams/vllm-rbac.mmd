graph TD
    %% vLLM RBAC / Security Diagram
    %% Generated by: Claude Opus 4.6
    %% Source: architecture/rhoai-2.19/vllm.md
    %% Note: vLLM is a containerized application, not an operator
    %% This diagram shows the security model and auth mechanisms
    subgraph ContainerSecurity["Container Security"]
        Container["vLLM Container<br/>UID: 2000 (non-root)<br/>GID: 0 (root group)<br/>Home: /home/vllm<br/>umask: 002"]
    end

    subgraph Authentication["Authentication Mechanisms"]
        direction TB
        APIKeyAuth["API Key Auth<br/>(VLLM_API_KEY / --api-key)<br/>Bearer Token in Authorization header"]
        NoAuth["No Auth Required<br/>(health/metrics endpoints)"]
    end

    subgraph Endpoints["Endpoint Authorization"]
        direction TB

        subgraph Protected["/v1/* Endpoints (Auth Optional)"]
            ChatAPI["/v1/chat/completions"]
            CompletionsAPI["/v1/completions"]
            EmbeddingsAPI["/v1/embeddings"]
            ModelsAPI["/v1/models"]
            ScoreAPI["/v1/score"]
            RerankAPI["/v1/rerank, /v2/rerank"]
            AudioAPI["/v1/audio/transcriptions"]
            LoRALoad["/v1/load_lora_adapter"]
            LoRAUnload["/v1/unload_lora_adapter"]
        end

        subgraph Public["Public Endpoints (No Auth)"]
            Health["/health"]
            Ping["/ping"]
            Metrics["/metrics"]
            Version["/version"]
            Tokenize["/tokenize"]
            Detokenize["/detokenize"]
            Pooling["/pooling"]
        end
    end

    subgraph Secrets["Secrets Management"]
        HFToken["HuggingFace Token<br/>Type: Opaque (env var)<br/>Purpose: Model downloads<br/>Rotation: Manual"]
        S3Creds["S3 Credentials<br/>Type: Opaque (env vars)<br/>S3_ACCESS_KEY_ID<br/>S3_SECRET_ACCESS_KEY<br/>Rotation: Manual"]
        SSLCert["SSL Key/Cert<br/>Type: kubernetes.io/tls<br/>Purpose: TLS termination<br/>Rotation: Auto (watchfiles)"]
        VLLMAPIKey["VLLM API Key<br/>Type: Opaque (env var)<br/>Purpose: Bearer auth<br/>Rotation: Manual"]
    end

    subgraph KServeRBAC["RBAC (Managed by KServe)"]
        KServeSA["KServe Service Account<br/>(manages vLLM lifecycle)"]
        KServeRole["KServe ClusterRole<br/>(InferenceService CRUD)"]
    end

    %% Auth flows
    APIKeyAuth -->|"enforced when<br/>VLLM_API_KEY set"| Protected
    NoAuth -->|"always accessible"| Public

    %% Secret usage
    HFToken -->|"HF_TOKEN env"| Container
    S3Creds -->|"env vars"| Container
    SSLCert -->|"--ssl-keyfile<br/>--ssl-certfile"| Container
    VLLMAPIKey -->|"VLLM_API_KEY env"| APIKeyAuth

    %% KServe manages RBAC
    KServeSA -->|"bound via"| KServeRole
    KServeRole -->|"manages"| Container

    %% Styling
    style Container fill:#4a90e2,color:#fff
    style APIKeyAuth fill:#e74c3c,color:#fff
    style NoAuth fill:#27ae60,color:#fff
    style HFToken fill:#f5a623,color:#fff
    style S3Creds fill:#f5a623,color:#fff
    style SSLCert fill:#f5a623,color:#fff
    style VLLMAPIKey fill:#f5a623,color:#fff
    style KServeSA fill:#7ed321,color:#fff
    style KServeRole fill:#7ed321,color:#fff
