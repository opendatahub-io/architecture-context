%% TrustyAI Service Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph OperatorPod["TrustyAI Service Operator Pod"]
        Manager["Operator Manager<br/>/manager binary<br/>Go 1.21"]
        TASCtrl["TAS Controller<br/>TrustyAIService Reconciler"]
        LMESCtrl["LMES Controller<br/>LMEvalJob Reconciler"]
        JobMgrCtrl["JobMgr Controller<br/>Kueue Workload Manager"]
        GORCHCtrl["GORCH Controller<br/>GuardrailsOrchestrator Reconciler"]
        Manager -->|"--enable-services"| TASCtrl
        Manager -->|"--enable-services"| LMESCtrl
        Manager -->|"--enable-services"| JobMgrCtrl
        Manager -->|"--enable-services"| GORCHCtrl
    end

    %% CRDs
    TrustyAICR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1"]
    LMEvalCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GorchCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% TAS Controller outputs
    TrustyAICR -->|"watched by"| TASCtrl
    TASCtrl -->|creates| TASDeployment["TrustyAI Deployment<br/>+ oauth-proxy sidecar"]
    TASCtrl -->|creates| TASService["Service + TLS Service"]
    TASCtrl -->|creates| TASRoute["OpenShift Route<br/>reencrypt TLS"]
    TASCtrl -->|creates| TASPVC["PVC<br/>Data Storage"]
    TASCtrl -->|creates| TASServiceMonitor["ServiceMonitor<br/>Prometheus"]
    TASCtrl -->|patches| InferenceService["KServe InferenceService<br/>InferenceLogger"]
    TASCtrl -->|creates conditionally| IstioResources["Istio DestinationRule<br/>+ VirtualService"]

    %% LMES Controller outputs
    LMEvalCR -->|"watched by"| LMESCtrl
    LMESCtrl -->|creates| EvalPod["LMEval Pod<br/>lm-eval + driver sidecar"]
    LMESCtrl -->|creates| EvalPVC["PVC<br/>Output Storage"]

    %% JobMgr Controller outputs
    JobMgrCtrl -->|creates| KueueWorkload["Kueue Workload CR"]

    %% GORCH Controller outputs
    GorchCR -->|"watched by"| GORCHCtrl
    GORCHCtrl -->|creates| GORCHDeployment["Orchestrator Deployment<br/>+ optional vLLM gateway<br/>+ regex detector"]
    GORCHCtrl -->|creates| GORCHService["Orchestrator Service"]
    GORCHCtrl -->|creates| GORCHRoutes["OpenShift Routes<br/>HTTP + Health"]

    %% External Dependencies
    TASCtrl -->|depends on| KServe["KServe / ModelMesh"]
    JobMgrCtrl -->|depends on| Kueue["Kueue"]
    TASCtrl -->|optional| Istio["Istio Service Mesh"]
    Manager -->|depends on| PromOperator["Prometheus Operator"]

