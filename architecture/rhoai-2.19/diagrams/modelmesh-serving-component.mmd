%% ModelMesh Serving - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>(Go Operator)"]
        SRReconciler["ServingRuntimeReconciler"]
        PReconciler["PredictorReconciler"]
        SvcReconciler["ServiceReconciler"]
        EventStream["ModelMeshEventStream"]
        Webhook["ValidatingWebhook<br/>:9443/TCP"]

        Controller --> SRReconciler
        Controller --> PReconciler
        Controller --> SvcReconciler
        Controller --> EventStream
        Controller --> Webhook
    end

    subgraph "Runtime Pod (per ServingRuntime)"
        MM["ModelMesh Sidecar<br/>(Java, gRPC :8033)"]
        RESTProxy["REST Proxy Sidecar<br/>(:8008)"]
        OAuthProxy["oauth-proxy Sidecar<br/>(:8443 HTTPS)"]
        Puller["Storage Puller Sidecar<br/>(:8086)"]
        Runtime["Model Runtime<br/>(OVMS/Triton/MLServer/TorchServe)"]

        OAuthProxy -->|HTTP :8008| RESTProxy
        RESTProxy -->|gRPC :8033| MM
        MM -->|gRPC| Runtime
        MM -->|gRPC :8086| Puller
    end

    %% CRDs
    User[Data Scientist] -->|creates| PredictorCR["Predictor CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| ISCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    Admin[Admin] -->|creates| SRCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    Admin -->|creates| CSRCR["ClusterServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]

    PredictorCR -->|watched by| PReconciler
    ISCR -->|watched by| PReconciler
    SRCR -->|watched by| SRReconciler
    CSRCR -->|watched by| SRReconciler
    SRCR -->|validated by| Webhook
    CSRCR -->|validated by| Webhook

    %% Controller creates resources
    SRReconciler -->|creates/manages| RuntimePodDep["Runtime Deployment"]
    SRReconciler -->|creates| EtcdSecret["etcd Secret<br/>(per namespace)"]
    SRReconciler -->|creates| HPA["HorizontalPodAutoscaler"]
    SvcReconciler -->|creates| HeadlessSvc["Headless Service<br/>(modelmesh-serving)"]
    SvcReconciler -->|creates| ServiceMonitor["ServiceMonitor CR"]
    PReconciler -->|registers vmodel via gRPC| MM

    %% External dependencies
    EventStream -->|watches| etcd["etcd<br/>:2379/TCP gRPC"]
    MM -->|coordinates| etcd
    Puller -->|fetches models| S3["S3/GCS Object Storage<br/>:443 HTTPS"]
    Controller -->|API calls| K8sAPI["Kubernetes API<br/>:6443 HTTPS"]
    OAuthProxy -->|validates tokens| OpenShiftOAuth["OpenShift OAuth<br/>:443 HTTPS"]

    %% Prometheus
    Prometheus["Prometheus"] -->|scrapes :2112| RuntimePodDep
    Prometheus -->|scrapes :8080| Controller

