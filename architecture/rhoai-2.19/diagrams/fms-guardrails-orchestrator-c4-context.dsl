/*
 * C4 Context Diagram: FMS Guardrails Orchestrator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/fms-guardrails-orchestrator.md
 */

workspace {
    model {
        clientApp = person "Client Application" "Platform service or application requiring guardrails on LLM interactions"

        guardrailsOrchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestration server for invoking content safety detectors on text generation model input and output" {
            mainServer = container "Main API Server" "Handles guardrails API requests (v1 and v2)" "Rust/axum 0.8.1, 8033/TCP"
            healthServer = container "Health Server" "Health/liveness probes" "Rust/axum, 8034/TCP plaintext"
            generationClient = container "GenerationClient" "gRPC client for text generation backends" "tonic 0.12.3"
            openaiClient = container "OpenAiClient" "HTTP client for OpenAI-compatible servers" "reqwest 0.12.12"
            detectorClients = container "Detector Clients" "HTTP clients for content safety detection" "reqwest 0.12.12"
            chunkerClient = container "ChunkerClient" "gRPC client for text chunking" "tonic 0.12.3"
            config = container "OrchestratorConfig" "YAML-based backend service configuration" "serde"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - fmaas.GenerationService" "Internal"
        caikitNlp = softwareSystem "caikit-nlp" "Text generation via caikit NLP API" "Internal"
        detectorServers = softwareSystem "Detector Servers" "Content safety detection (HAP, PII, etc.)" "Internal"
        chunkerServers = softwareSystem "Chunker Servers" "Text chunking/tokenization via caikit" "Internal"
        openaiServer = softwareSystem "OpenAI-compatible Server" "Chat completions generation (vLLM)" "Internal"
        otlpCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing and metrics" "External"

        /* Relationships */
        clientApp -> guardrailsOrchestrator "Sends guardrails requests" "HTTP/HTTPS 8033/TCP, TLS/mTLS optional"

        mainServer -> generationClient "Delegates generation"
        mainServer -> openaiClient "Delegates chat completions"
        mainServer -> detectorClients "Delegates detection"
        mainServer -> chunkerClient "Delegates chunking"
        config -> mainServer "Configures backends"

        generationClient -> tgis "Text generation" "gRPC, TLS/mTLS"
        generationClient -> caikitNlp "Text generation" "gRPC, TLS/mTLS"
        openaiClient -> openaiServer "Chat completions" "HTTP/HTTPS /v1/chat/completions"
        detectorClients -> detectorServers "Content safety detection" "HTTP/HTTPS, TLS/mTLS"
        chunkerClient -> chunkerServers "Text chunking" "gRPC, TLS/mTLS"
        guardrailsOrchestrator -> otlpCollector "Exports traces and metrics" "OTLP gRPC/HTTP 4317/4318"
    }

    views {
        systemContext guardrailsOrchestrator "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsOrchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #f5a623
                color #ffffff
                shape Person
            }
            element "Container" {
                background #5ba5e6
                color #ffffff
            }
        }
    }
}
