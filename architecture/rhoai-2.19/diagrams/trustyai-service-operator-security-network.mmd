%% TrustyAI Service Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["External User / Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        TASRoute["TrustyAI Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>OAuth Required"]
        GORCHRouteHTTP["Guardrails HTTP Route<br/>443/TCP → 8032-8033/TCP<br/>TLS Edge<br/>No Auth"]
        GORCHRouteHealth["Guardrails Health Route<br/>443/TCP → 8034/TCP<br/>TLS Edge"]
    end

    subgraph ClusterNetwork["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>OpenShift SAR: pods/get"]
            TASContainer["TrustyAI Service<br/>8080/TCP HTTP<br/>4443/TCP HTTPS (internal)"]
            OAuthProxy -->|"HTTP/8080<br/>plaintext (localhost)"| TASContainer
        end

        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            OrchestratorContainer["Orchestrator<br/>8032/8033/TCP HTTP<br/>8034/TCP Health"]
            VLLMGateway["vLLM Gateway (optional)<br/>8033/TCP"]
            RegexDetector["Regex Detector (optional)<br/>8080/TCP"]
        end

        subgraph LMEvalPod["LMEval Pod (ephemeral)"]
            LMEvalContainer["lm-eval Container"]
            DriverSidecar["Driver Sidecar<br/>Job lifecycle"]
        end

        subgraph OperatorPod["Operator Pod"]
            ManagerContainer["Manager<br/>8080/TCP metrics<br/>8081/TCP health"]
            KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>tokenreviews + SAR"]
        end

        IS["KServe InferenceService<br/>Patched with InferenceLogger"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    subgraph OptionalMesh["OPTIONAL: ISTIO SERVICE MESH"]
        DestRule["DestinationRule<br/>TLS SIMPLE port 443"]
        VirtSvc["VirtualService<br/>Redirect 80 → 443"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database["Database<br/>configurable/TCP<br/>JDBC<br/>Optional TLS (verify-ca)<br/>Username/Password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS<br/>AccessKey/SecretKey"]
        OTLP["OTLP Collector<br/>configurable/TCP<br/>HTTP/gRPC"]
        ModelEndpoint["Model Endpoints<br/>configurable<br/>HTTP/HTTPS"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OAuth"| TASRoute
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| GORCHRouteHTTP
    User -->|"HTTPS/443<br/>TLS Edge"| GORCHRouteHealth

    %% Ingress to services
    TASRoute -->|"HTTPS/8443<br/>TLS<br/>SAR: pods/get"| OAuthProxy
    GORCHRouteHTTP -->|"HTTP/8032-8033<br/>plaintext"| OrchestratorContainer
    GORCHRouteHealth -->|"HTTP/8034<br/>plaintext"| OrchestratorContainer

    %% Internal flows
    IS -->|"HTTPS/443<br/>TLS (internal cert)<br/>Inference payloads"| TASContainer
    Prometheus -->|"HTTP/80<br/>plaintext<br/>trustyai_spd, trustyai_dir"| TASContainer
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>kube-rbac-proxy"| KubeRBACProxy

    %% Egress flows
    TASContainer -->|"JDBC<br/>Optional TLS<br/>DB credentials"| Database
    LMEvalContainer -->|"HTTPS/443<br/>TLS<br/>AccessKey/SecretKey"| S3
    LMEvalContainer -->|"configurable<br/>HTTP/HTTPS"| ModelEndpoint
    OrchestratorContainer -->|"configurable<br/>HTTP/HTTPS"| ModelEndpoint
    OrchestratorContainer -->|"configurable<br/>HTTP/gRPC"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef mesh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class TASRoute,GORCHRouteHTTP,GORCHRouteHealth ingress
    class OAuthProxy,TASContainer,OrchestratorContainer,VLLMGateway,RegexDetector,LMEvalContainer,DriverSidecar,ManagerContainer,KubeRBACProxy,IS,Prometheus internal
