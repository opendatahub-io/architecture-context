/*
 * Model Registry Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/model-registry-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / Admin" "Creates and manages Model Registry instances via kubectl or ODH Dashboard"

        modelRegistryOperator = softwareSystem "Model Registry Operator" "Kubernetes operator managing lifecycle of Model Registry instances with optional Istio service mesh integration" {
            controllerManager = container "controller-manager" "Reconciles ModelRegistry CRs, manages deployments, services, routes, Istio resources" "Go Operator (controller-runtime, Kubebuilder v4)"
            mutatingWebhook = container "Mutating Webhook" "Defaults ModelRegistry spec fields (ports, TLS, images, Istio config)" "Admission Webhook (9443/TCP HTTPS)"
            validatingWebhook = container "Validating Webhook" "Validates database config, Istio settings, namespace restrictions, unique registry names" "Admission Webhook (9443/TCP HTTPS)"
            restContainer = container "REST Proxy" "Translates HTTP REST requests to gRPC calls to MLMD server" "Go Service (8080/TCP HTTP)"
            grpcContainer = container "MLMD gRPC Server" "ML Metadata gRPC server for model artifact management" "C++ Service (9090/TCP gRPC)"
        }

        odhOperator = softwareSystem "opendatahub-operator / rhods-operator" "Parent operator that deploys model-registry-operator via kustomize overlays" "Internal ODH"
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for mTLS, traffic management, and authorization" "External"
        authorino = softwareSystem "Authorino" "Authentication and authorization via AuthConfig CRD (TokenReview + SubjectAccessReview)" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for ML metadata storage" "External"
        mysql = softwareSystem "MySQL" "Relational database for ML metadata storage (alternative)" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management, TokenReview, SubjectAccessReview" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        certManager = softwareSystem "cert-manager / OpenShift Serving Certs" "TLS certificate provisioning for webhooks and metrics" "External"

        # Relationships
        user -> modelRegistryOperator "Creates ModelRegistry CR via kubectl" "HTTPS/443"
        odhOperator -> modelRegistryOperator "Deploys operator via kustomize overlays"

        controllerManager -> mutatingWebhook "Registers"
        controllerManager -> validatingWebhook "Registers"
        controllerManager -> restContainer "Creates deployment containing"
        controllerManager -> grpcContainer "Creates deployment containing"

        restContainer -> grpcContainer "gRPC calls" "gRPC/9090 localhost"
        grpcContainer -> postgresql "Stores/retrieves ML metadata" "PostgreSQL/5432 Configurable SSL"
        grpcContainer -> mysql "Stores/retrieves ML metadata" "MySQL/3306 Configurable SSL"

        controllerManager -> k8sAPI "CRUD operations, TokenReview, discovery" "HTTPS/443 TLS"
        controllerManager -> istio "Creates VirtualService, DestinationRule, Gateway, AuthorizationPolicy" "HTTPS/443 TLS"
        controllerManager -> authorino "Creates AuthConfig resources" "HTTPS/443 TLS"

        prometheus -> modelRegistryOperator "Scrapes operator metrics" "HTTPS/8443 TLS"
        certManager -> modelRegistryOperator "Provisions TLS certificates"
    }

    views {
        systemContext modelRegistryOperator "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistryOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
