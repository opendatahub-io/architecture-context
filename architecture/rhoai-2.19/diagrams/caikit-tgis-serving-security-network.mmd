%% Security Network Diagram: Caikit-TGIS-Serving
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["knative-ingress-gateway<br/>Istio Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>wildcard-certs"]
        LocalGW["knative-local-gateway<br/>Istio Gateway<br/>8081/TCP HTTP<br/>plaintext<br/>Cluster-internal only"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            QueueProxy["Knative Queue-Proxy / Activator<br/>8012/TCP"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            subgraph Pod["ServingRuntime Pod"]
                direction TB
                IstioSidecar["Istio Sidecar Proxy<br/>mTLS enforcement<br/>Excluded: 8444, 8022"]
                Caikit["Caikit transformer-container<br/>HTTP: 8080/TCP<br/>gRPC: 8085/TCP (h2c)<br/>Metrics: 8086/TCP"]
                TGIS["TGIS kserve-container<br/>gRPC: 8033/TCP<br/>Model: /mnt/models/artifacts/"]
            end
            MetricsSvc["caikit-metrics Service<br/>ClusterIP 8086/TCP<br/>PeerAuth PERMISSIVE"]
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor scrape"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/Minio Storage<br/>9000/TCP or 443/TCP<br/>HTTP/HTTPS<br/>AWS IAM credentials"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>TLS certificate"| Gateway
    Gateway -->|"HTTP/8012<br/>mTLS STRICT<br/>Istio PeerAuth"| QueueProxy
    LocalGW -->|"HTTP/8081<br/>plaintext<br/>cluster-internal"| QueueProxy

    %% Internal mesh flows
    QueueProxy -->|"HTTP/8080 or gRPC/8085<br/>plaintext (pod-local)"| Caikit
    Caikit -->|"gRPC/8033<br/>plaintext (pod-local)<br/>No auth"| TGIS

    %% Metrics
    Prometheus -->|"HTTP/8086<br/>plaintext<br/>PERMISSIVE mTLS<br/>NetworkPolicy: allow-from-openshift-monitoring-ns"| MetricsSvc
    MetricsSvc --> Caikit

    %% Storage
    Pod -->|"S3 API<br/>9000 or 443/TCP<br/>Configurable TLS<br/>AWS credentials (storage-config Secret)"| S3

