graph TD
    subgraph "Pipeline Execution"
        DSP_SA["Data Science Pipelines<br/>Service Account"]
    end

    subgraph "Model Serving Service Accounts"
        MixtralSA["mixtral-sa"]
        PrometheusSA["prometheus-sa"]
    end

    subgraph "NFS Service Account"
        NFSSA["nfs-server-sa"]
    end

    subgraph "Role Bindings"
        MixtralRB["mixtral-view<br/>Namespace: user-project"]
        PrometheusRB["prometheus-view<br/>Namespace: user-project"]
        NFSAnyuidRB["nfs-server-sa-anyuid<br/>Namespace: nfs"]
        NFSPrivRB["nfs-server-sa-privileged<br/>Namespace: nfs"]
    end

    subgraph "Roles"
        MixtralRole["mixtral-view-role<br/>(Role)"]
        PrometheusRole["prometheus-view-role<br/>(Role)"]
        AnyuidCR["system:openshift:scc:anyuid<br/>(ClusterRole)"]
        PrivilegedCR["system:openshift:scc:privileged<br/>(ClusterRole)"]
    end

    subgraph "API Resources"
        MixtralIS["serving.kserve.io<br/>InferenceService: mixtral"]
        PrometheusIS["serving.kserve.io<br/>InferenceService: prometheus"]
        AnyuidSCC["SecurityContextConstraint<br/>anyuid"]
        PrivSCC["SecurityContextConstraint<br/>privileged"]
    end

    subgraph "Secrets Accessed"
        TeacherSecret["teacher-secret (Opaque)<br/>endpoint, model_name, api_token"]
        JudgeSecret["judge-secret (Opaque)<br/>endpoint, model_name, api_token"]
        TaxonomySecret["taxonomy-repo-secret (Opaque)<br/>GIT_USERNAME, GIT_TOKEN,<br/>GIT_SSH_KEY"]
        OCISecret["OCI push secret<br/>(dockerconfigjson)"]
        HFSecret["hugging-face-token (Opaque)<br/>HF_TOKEN"]
    end

    %% Pipeline SA accesses secrets
    DSP_SA -->|"reads at runtime"| TeacherSecret
    DSP_SA -->|"reads at runtime"| JudgeSecret
    DSP_SA -->|"reads at runtime"| TaxonomySecret
    DSP_SA -->|"reads at runtime"| OCISecret
    DSP_SA -->|"reads at runtime"| HFSecret

    %% Mixtral RBAC chain
    MixtralSA -->|bound via| MixtralRB
    MixtralRB -->|grants| MixtralRole
    MixtralRole -->|"get"| MixtralIS

    %% Prometheus RBAC chain
    PrometheusSA -->|bound via| PrometheusRB
    PrometheusRB -->|grants| PrometheusRole
    PrometheusRole -->|"get"| PrometheusIS

    %% NFS RBAC chain
    NFSSA -->|bound via| NFSAnyuidRB
    NFSAnyuidRB -->|grants| AnyuidCR
    AnyuidCR -->|"use"| AnyuidSCC
    NFSSA -->|bound via| NFSPrivRB
    NFSPrivRB -->|grants| PrivilegedCR
    PrivilegedCR -->|"use"| PrivSCC

