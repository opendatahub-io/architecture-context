// C4 Context Diagram for Notebooks (Workbench Images)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/notebooks.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Uses interactive workbench environments for ML/AI experimentation"
        clusterAdmin = person "Cluster Admin" "Manages OpenShift cluster and RHOAI platform deployment"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images for Jupyter, code-server, and RStudio workbench environments" {
            jupyterImages = container "Jupyter Notebook Images" "Minimal, Data Science, TrustyAI, GPU (CUDA/ROCm) variants" "Container Image (UBI9 + Python 3.11)"
            codeServerImage = container "code-server Image" "VS Code web IDE (code-server 4.98) with Python 3.11" "Container Image (UBI9)"
            rstudioImage = container "RStudio Server Image" "RStudio IDE with R 4.4 and Python 3.11" "Container Image (BuildConfig on cluster)"
            runtimeImages = container "Elyra Runtime Images" "Minimal, Data Science, PyTorch, TensorFlow runtime variants" "Container Image (UBI9)"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream and BuildConfig definitions for OpenShift deployment" "YAML / Kustomize"
        }

        // Internal ODH Components
        notebookController = softwareSystem "ODH Notebook Controller" "Manages lifecycle of workbench pods, injects auth sidecars" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "User interface for selecting and launching workbenches" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys ImageStream manifests to OpenShift" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines / Elyra" "Pipeline orchestration using runtime images" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Distributed training SDK bundled in data science images" "Internal RHOAI"

        // External Systems
        quayRegistry = softwareSystem "quay.io/modh Container Registry" "Stores pre-built workbench and runtime images" "External"
        ubi9Registry = softwareSystem "Red Hat UBI9 Registry" "Base container images (registry.access.redhat.com)" "External"
        konflux = softwareSystem "Konflux / Tekton CI/CD" "Builds, scans, signs, and publishes container images" "External"
        openShiftAPI = softwareSystem "OpenShift API Server" "Kubernetes/OpenShift cluster API" "External"
        pypi = softwareSystem "PyPI" "Python package index for runtime package installation" "External"
        s3Storage = softwareSystem "S3 / Object Storage" "Pipeline data artifact storage" "External"
        gitHub = softwareSystem "GitHub" "Source repository for Dockerfiles and manifests" "External"

        // Relationships - User interactions
        dataScientist -> rhoaiDashboard "Selects workbench type and launches environment" "HTTPS/443"
        dataScientist -> notebooks "Uses interactive IDE (Jupyter/code-server/RStudio)" "HTTPS/443 via auth proxy"
        clusterAdmin -> rhoaiOperator "Deploys RHOAI platform including notebook manifests"

        // Internal relationships
        notebookController -> notebooks "Launches workbench pods using these images" "Kubernetes API"
        rhoaiDashboard -> kustomizeManifests "Reads ImageStream annotations to display available workbenches" "Kubernetes API"
        rhoaiOperator -> kustomizeManifests "Deploys ImageStream/BuildConfig manifests" "Kustomize"
        dsPipelines -> runtimeImages "Executes pipeline nodes using runtime images" "Kubernetes API"

        // External dependencies
        notebooks -> openShiftAPI "oc CLI commands from within notebook" "HTTPS/6443"
        notebooks -> pypi "Install additional Python packages" "HTTPS/443"
        notebooks -> s3Storage "User data access, pipeline artifacts" "HTTPS/443"
        konflux -> notebooks "Builds and scans container images" "Tekton Pipelines"
        konflux -> quayRegistry "Pushes built images" "HTTPS/443"
        notebookController -> quayRegistry "Pulls workbench images" "HTTPS/443"
        konflux -> ubi9Registry "Pulls base images" "HTTPS/443"
        konflux -> gitHub "Fetches Dockerfiles and build context" "HTTPS/443"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
