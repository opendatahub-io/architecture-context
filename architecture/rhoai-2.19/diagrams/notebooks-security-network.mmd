%% Security Network Diagram for Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.19/notebooks.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Dashboard["RHOAI Dashboard<br/>443/TCP<br/>TLS 1.2+<br/>OAuth2"]
        Route["OpenShift Route / HTTPRoute<br/>+ Auth Proxy Sidecar<br/>443/TCP external<br/>TLS Termination"]
    end

    subgraph Internal["INTERNAL (Cluster Network)"]
        direction TB

        subgraph NS_User["Namespace: {user-data-science-project}"]
            AuthProxy["Auth Proxy Sidecar<br/>(oauth-proxy / kube-rbac-proxy)<br/>OAuth2 / RBAC validation"]
            Workbench["Workbench Pod<br/>UID: 1001 (non-root)<br/>UBI9 base, signed + SBOM<br/>8888/TCP | 8080/TCP | 8787/TCP"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+"]
        NotebookCtrl["ODH Notebook Controller<br/>Creates pods, injects sidecars"]
    end

    subgraph BuildTime["CI/CD (Build Time)"]
        Konflux["Konflux / Tekton<br/>Clair, ClamAV, Snyk,<br/>Coverity, rpms-signature-scan"]
        QuayIO["quay.io/modh Registry<br/>443/TCP, TLS 1.2+<br/>27 shipped images"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PyPI["PyPI / pip<br/>443/TCP<br/>TLS 1.2+"]
        OCP_API["OpenShift API<br/>6443/TCP<br/>TLS 1.2+"]
        S3["S3 / Object Storage<br/>443/TCP<br/>TLS 1.2+"]
        GitHub["GitHub<br/>443/TCP<br/>TLS 1.2+"]
        RHEL_Reg["registry.access.redhat.com<br/>443/TCP<br/>TLS 1.2+"]
    end

    %% User access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2"| Dashboard
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"Notebook CR event"| NotebookCtrl
    NotebookCtrl -->|"Create pod +<br/>inject auth sidecar"| AuthProxy

    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2/RBAC"| Route
    Route -->|"Forward to sidecar"| AuthProxy
    AuthProxy -->|"HTTP/8888 or 8080 or 8787<br/>localhost (no encryption)<br/>Pre-authenticated"| Workbench

    %% Egress from workbench
    Workbench -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (SA)"| OCP_API
    Workbench -->|"HTTPS/443<br/>TLS 1.2+<br/>None"| PyPI
    Workbench -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| S3

    %% Build time
    Konflux -->|"Build + scan +<br/>sign images"| QuayIO
    NotebookCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| QuayIO

    %% RStudio on-cluster build
    Konflux -->|"HTTPS/443<br/>Public repo"| GitHub
    Konflux -->|"HTTPS/443<br/>Pull secret"| RHEL_Reg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef buildtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Dashboard,Route ingress
    class AuthProxy,Workbench,K8sAPI,NotebookCtrl internal
    class Konflux,QuayIO buildtime
    class PyPI,OCP_API,S3,GitHub,RHEL_Reg externalservice
