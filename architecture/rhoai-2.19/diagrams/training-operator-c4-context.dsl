// Training Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages distributed training jobs"
        pipeline = person "Data Science Pipeline" "Automated ML workflow that submits training jobs"

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages distributed ML training jobs on Kubernetes (PyTorch, TensorFlow, MPI, XGBoost, PaddlePaddle, JAX)" {
            controllerManager = container "Controller Manager" "Main controller-runtime manager; registers per-framework reconcilers" "Go Operator"
            pytorchController = container "PyTorchJob Controller" "Manages PyTorchJob lifecycle: Pods, Services, NetworkPolicies, HPAs" "Reconciler"
            tfController = container "TFJob Controller" "Manages TFJob lifecycle: Pods and Services" "Reconciler"
            mpiController = container "MPIJob Controller" "Manages MPIJob lifecycle: launcher/worker Pods, ConfigMaps" "Reconciler"
            xgboostController = container "XGBoostJob Controller" "Manages XGBoostJob lifecycle: Pods and Services" "Reconciler"
            paddleController = container "PaddleJob Controller" "Manages PaddleJob lifecycle: Pods and Services" "Reconciler"
            jaxController = container "JAXJob Controller" "Manages JAXJob lifecycle: Pods and Services" "Reconciler"
            webhookServer = container "Validating Webhooks" "Validates CREATE/UPDATE on training job CRDs" "Admission Webhook"
            certManager = container "Cert Manager" "Self-manages TLS certificates for webhook server" "OPA cert-controller"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for coordinated pod placement" "External Optional"
        schedulerPlugins = softwareSystem "Scheduler-Plugins" "Gang scheduling via scheduler-plugins PodGroups" "External Optional"
        kueue = softwareSystem "Kueue" "Queue management for training workloads" "External Optional"

        // Relationships
        user -> trainingOperator "Creates training job CRs (PyTorchJob, TFJob, etc.) via kubectl"
        pipeline -> trainingOperator "Submits training jobs programmatically"
        trainingOperator -> k8sAPI "CRUD on Pods, Services, CRDs, NetworkPolicies, HPAs, PodGroups" "HTTPS/443 TLS 1.2+"
        k8sAPI -> trainingOperator "Admission webhook calls" "HTTPS/9443 TLS"
        prometheus -> trainingOperator "Scrapes operator metrics" "HTTP/8080"
        trainingOperator -> volcano "Creates PodGroups for gang scheduling" "CRD"
        trainingOperator -> schedulerPlugins "Creates PodGroups for gang scheduling" "CRD"
        trainingOperator -> kueue "Queue management integration" "CRD"

        // Internal container relationships
        controllerManager -> pytorchController "registers"
        controllerManager -> tfController "registers"
        controllerManager -> mpiController "registers"
        controllerManager -> xgboostController "registers"
        controllerManager -> paddleController "registers"
        controllerManager -> jaxController "registers"
        controllerManager -> webhookServer "registers"
        certManager -> webhookServer "rotates TLS certificates"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #bbbbbb
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
