// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/model-registry.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Registers models, tracks versions, manages artifacts"
        admin = person "Platform Admin" "Manages Model Registry deployment and RBAC"

        modelRegistry = softwareSystem "Model Registry" "Central metadata repository for ML model registrations, versions, and artifacts (REST + gRPC APIs)" {
            restProxy = container "REST API Proxy" "OpenAPI v1alpha3 REST proxy translating HTTP to MLMD gRPC" "Go Service" "Port 8080/TCP"
            mlmdServer = container "MLMD gRPC Server" "Core metadata storage backend (ml_metadata_store_server)" "C++ gRPC Service" "Port 9090/TCP"
            uiBFF = container "UI Backend-for-Frontend" "Kubernetes-aware REST API for the web UI with SAR checks" "Go Service" "Port 8080/TCP"
            uiFrontend = container "UI Frontend" "Web UI for browsing and managing registered models" "React/TypeScript SPA"
            pythonClient = container "Python Client" "Python SDK (v0.2.15) for programmatic access" "Python Library"
            csiInitializer = container "CSI Storage Initializer" "Downloads models via model-registry:// URI scheme for KServe" "Go CLI"
        }

        // External Dependencies
        mysql = softwareSystem "MySQL" "Relational database backend (8.0+)" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database backend (13+)" "External"
        istio = softwareSystem "Istio Service Mesh" "mTLS, traffic routing, authorization policies" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for service discovery and RBAC" "External"
        modelStorage = softwareSystem "Model Storage (S3/GCS)" "Object storage for model artifacts" "External"

        // Internal ODH Dependencies
        kserve = softwareSystem "KServe / Model Serving" "Serverless ML inference platform" "Internal RHOAI"
        dashboard = softwareSystem "ODH/RHOAI Dashboard" "Platform management UI" "Internal RHOAI"

        // Relationships - User interactions
        user -> modelRegistry "Registers models, creates versions, manages artifacts"
        user -> uiFrontend "Browses and manages models via web UI"
        user -> pythonClient "Programmatic access via Python SDK"
        admin -> k8sApi "Configures RBAC and deployment"

        // Internal container relationships
        uiFrontend -> uiBFF "API calls" "HTTP/8080"
        uiBFF -> restProxy "Forwards requests" "HTTP/8080"
        uiBFF -> k8sApi "SAR checks, service discovery" "HTTPS/443"
        restProxy -> mlmdServer "Translates REST to gRPC" "gRPC/9090"
        pythonClient -> restProxy "REST API calls" "HTTP/8080"
        csiInitializer -> restProxy "Fetches model artifact metadata" "HTTP/8080"
        csiInitializer -> modelStorage "Downloads model artifacts" "HTTPS/443"

        // Database backends (conditional)
        mlmdServer -> mysql "Persists metadata" "MySQL/3306"
        mlmdServer -> postgresql "Persists metadata" "PostgreSQL/5432"

        // External integrations
        modelRegistry -> istio "mTLS, VirtualService, AuthorizationPolicy"
        kserve -> csiInitializer "ClusterStorageContainer model-registry:// URI"
        dashboard -> uiFrontend "UI integration"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
