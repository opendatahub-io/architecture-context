%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Cluster["CLUSTER NETWORK"]
        direction TB

        subgraph ControllerNS["Namespace: controller (modelmesh-controller)"]
            Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>:8080 metrics, :8081 health"]
            WebhookSvc["Webhook Service<br/>:9443/TCP HTTPS<br/>Auth: API server cert"]
        end

        subgraph UserNS["Namespace: user-ns (modelmesh-enabled)"]
            HeadlessSvc["Headless Service: modelmesh-serving<br/>:8033 gRPC | :8008 REST | :8443 OAuth | :2112 metrics"]

            subgraph RuntimePod["Runtime Pod"]
                OAuthProxy["oauth-proxy<br/>:8443/TCP HTTPS TLS<br/>Auth: OpenShift OAuth SAR<br/>Cert: model-serving-proxy-tls"]
                RESTProxy["REST Proxy<br/>:8008/TCP HTTP<br/>(pod-internal)"]
                ModelMesh["ModelMesh (Java)<br/>:8033/TCP gRPC TLS(opt)<br/>:8080/TCP gRPC (mesh internal)<br/>:8089/TCP health"]
                PullerSidecar["Storage Puller<br/>:8086/TCP gRPC<br/>(pod-internal)"]
                ModelRuntime["Model Runtime<br/>(OVMS/Triton/MLServer)<br/>gRPC (pod-internal)"]
            end
        end

        subgraph EtcdNS["Namespace: etcd"]
            Etcd["model-mesh-etcd<br/>:2379/TCP gRPC<br/>TLS (optional)<br/>Auth: Username/Password"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/GCS Storage<br/>:443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access Keys"]
        OAuthServer["OpenShift OAuth Server<br/>:443/TCP HTTPS<br/>Token validation"]
        K8sAPI["Kubernetes API<br/>:6443/TCP HTTPS<br/>Auth: ServiceAccount token"]
    end

    %% External flows
    Client -->|"HTTPS :8443<br/>TLS<br/>OAuth Token (SAR)"| OAuthProxy
    Client -.->|"gRPC :8033<br/>TLS (optional)<br/>mTLS (optional)"| ModelMesh

    %% Internal pod flows
    OAuthProxy -->|"HTTP :8008<br/>plaintext (localhost)"| RESTProxy
    RESTProxy -->|"gRPC :8033<br/>plaintext (localhost)"| ModelMesh
    ModelMesh -->|"gRPC (pod-internal)"| ModelRuntime
    ModelMesh -->|"gRPC :8086<br/>(pod-internal)"| PullerSidecar

    %% Controller flows
    Controller -->|"gRPC :8033<br/>TLS (opt) / mTLS (opt)<br/>vmodel registration"| ModelMesh
    Controller -->|"gRPC Watch :2379<br/>TLS (opt)<br/>Username/Password"| Etcd

    %% Runtime pod flows
    ModelMesh -->|"gRPC :2379<br/>TLS (optional)<br/>Username/Password"| Etcd
    PullerSidecar -->|"HTTPS :443<br/>TLS 1.2+<br/>IAM / Access Keys"| S3
    OAuthProxy -->|"HTTPS :443<br/>Token validation"| OAuthServer
    Controller -->|"HTTPS :6443<br/>TLS<br/>SA token"| K8sAPI

