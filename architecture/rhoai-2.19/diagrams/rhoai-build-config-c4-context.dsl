// RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        developer = person "Developer / Release Engineer" "Pushes bundle patches, CSV updates, and release artifacts"
        clusterAdmin = person "Cluster Administrator" "Installs and manages RHOAI operator via OLM"

        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration repository defining RHOAI operator bundle, FBC fragments, and image references for all RHOAI 2.19 components" {
            bundle = container "OLM Operator Bundle" "CSV, CRDs, RBAC manifests, metadata for rhods-operator" "YAML Manifests"
            catalog = container "FBC Fragments" "File-Based Catalog definitions per OCP version (v4.14-v4.19)" "YAML/Dockerfile"
            config = container "Build Configuration" "Image registry mappings, supported OCP versions, PNC configs" "YAML"
            tektonPipelines = container "Tekton PipelineRuns" "Konflux CI/CD pipeline definitions for bundle and FBC builds" "Tekton YAML"
            githubActions = container "GitHub Actions Workflows" "Bundle processing, FBC generation, nightly builds" "GitHub Actions YAML"
            integrationTests = container "Enterprise Contract Tests" "Supply chain verification pipeline" "Tekton YAML"
            releaseArtifacts = container "Release Artifacts" "Production release manifests and FBC release configs" "YAML"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Core RHOAI platform operator that manages all AI/ML components" "Internal RHOAI"

        // External Systems
        github = softwareSystem "GitHub" "Source code hosting and CI/CD triggers" "External"
        konflux = softwareSystem "Konflux CI/CD" "Build system for container images and operator bundles" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator discovery, installation, and upgrade management" "External"
        quay = softwareSystem "quay.io" "Container image registry for built artifacts" "External"
        redhatRegistry = softwareSystem "registry.redhat.io" "Production container image registry" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Supply chain security policy verification" "External"
        pnc = softwareSystem "PNC (Project Newcastle)" "Java-based component build system (ModelMesh, TrustyAI)" "External"
        slack = softwareSystem "Slack" "Build failure notifications" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target platform for operator deployment (v4.14-v4.19)" "External"

        // Relationships
        developer -> rhoaiBuildConfig "Pushes bundle patches, CSV updates, release artifacts"
        developer -> github "Pushes code changes"

        rhoaiBuildConfig -> konflux "Triggers bundle and FBC builds via Tekton PipelineRuns" "HTTPS/443"
        rhoaiBuildConfig -> quay "Publishes built bundle and FBC fragment images" "HTTPS/443"
        rhoaiBuildConfig -> redhatRegistry "References production container images in CSV" "HTTPS/443"
        rhoaiBuildConfig -> enterpriseContract "Verifies supply chain security policies"
        rhoaiBuildConfig -> pnc "Builds Java components (ModelMesh, TrustyAI)" "HTTPS/443"
        rhoaiBuildConfig -> slack "Sends build failure notifications" "HTTPS/443"
        rhoaiBuildConfig -> rhodsOperator "Defines operator bundle manifests for"

        olm -> rhoaiBuildConfig "Consumes FBC catalog and bundle for operator installation"
        clusterAdmin -> olm "Installs RHOAI operator"
        olm -> ocp "Deploys rhods-operator onto"
        rhodsOperator -> ocp "Manages AI/ML components on"

        github -> konflux "Webhook triggers on push" "HTTPS/443"
        github -> rhoaiBuildConfig "Hosts repository"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
