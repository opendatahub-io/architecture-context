// RHOAI Operator (rhods-operator) - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        admin = person "Platform Admin" "Installs and configures RHOAI platform on OpenShift"
        datascientist = person "Data Scientist" "Creates and deploys ML models, notebooks, pipelines"
        sre = person "SRE / Operations" "Monitors platform health and manages alerts"

        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Platform operator for Red Hat OpenShift AI - manages lifecycle of all AI/ML components" {
            controllerManager = container "Controller Manager" "Main operator binary with DSC/DSCI controllers and component sub-controllers" "Go (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates singleton constraints on DSC/DSCI CRs; sets defaults" "Go (Admission Webhook)"
            secretGenerator = container "SecretGenerator" "Auto-generates random and OAuth secrets based on annotations" "Go Controller"
            certGenerator = container "CertConfigmapGenerator" "Manages trusted CA bundle configmaps across namespaces" "Go Controller"
            monitoringStack = container "Monitoring Stack" "Prometheus, Alertmanager, Blackbox Exporter for managed RHOAI" "Prometheus/Alertmanager"
        }

        // External Dependencies
        ocp = softwareSystem "OpenShift Container Platform" "Target platform (v4.14-v4.19)" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and lifecycle management" "External"
        serviceMesh = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for traffic management and mTLS" "External"
        serverless = softwareSystem "OpenShift Serverless (Knative)" "Serverless autoscaling for KServe" "External"
        authorino = softwareSystem "Authorino Operator" "External authorization for Service Mesh" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management" "External"

        // Internal ODH Components (managed by operator)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches (Jupyter)" "Notebook workbench management" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML model serving" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving runtime" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare" "Distributed compute framework" "Internal RHOAI"
        ray = softwareSystem "Ray" "Distributed compute framework" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing system" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI" "Model explainability service" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "ML model artifact registry" "Internal RHOAI"
        trainingOp = softwareSystem "Training Operator" "Distributed training jobs" "Internal RHOAI"
        modelController = softwareSystem "Model Controller" "Inference service management" "Internal RHOAI"

        // External Services
        modelStorage = softwareSystem "Model Storage (S3/PVC)" "Model artifact storage" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API endpoint" "External"

        // Relationships - Admin
        admin -> rhoaiOperator "Creates DSCInitialization & DataScienceCluster CRs via kubectl"
        sre -> rhoaiOperator "Monitors via Prometheus/Alertmanager Routes" "HTTPS/443"
        datascientist -> dashboard "Accesses RHOAI Dashboard" "HTTPS/443"
        datascientist -> kserve "Deploys and queries ML models" "HTTPS/443"

        // Operator -> External Dependencies
        rhoaiOperator -> ocp "Runs on" "HTTPS/6443"
        olm -> rhoaiOperator "Installs and manages operator lifecycle"
        rhoaiOperator -> serviceMesh "Configures Istio Gateways, EnvoyFilters, AuthorizationPolicies"
        rhoaiOperator -> serverless "Configures KnativeServing for KServe"
        rhoaiOperator -> authorino "Creates AuthConfigs for KServe authz"
        rhoaiOperator -> certManager "Optional TLS certificate management"
        rhoaiOperator -> k8sAPI "Controller-runtime API calls" "HTTPS/6443"

        // Operator -> Managed Components
        rhoaiOperator -> dashboard "Deploys via Kustomize manifests"
        rhoaiOperator -> workbenches "Deploys via Kustomize manifests"
        rhoaiOperator -> kserve "Deploys via Kustomize manifests"
        rhoaiOperator -> modelmesh "Deploys via Kustomize manifests"
        rhoaiOperator -> dsp "Deploys via Kustomize manifests"
        rhoaiOperator -> codeflare "Deploys via Kustomize manifests"
        rhoaiOperator -> ray "Deploys via Kustomize manifests"
        rhoaiOperator -> kueue "Deploys via Kustomize manifests"
        rhoaiOperator -> trustyai "Deploys via Kustomize manifests"
        rhoaiOperator -> modelRegistry "Deploys via Kustomize manifests"
        rhoaiOperator -> trainingOp "Deploys via Kustomize manifests"
        rhoaiOperator -> modelController "Deploys via Kustomize manifests"

        // KServe -> External
        kserve -> modelStorage "Downloads model artifacts" "HTTPS/443"
        kserve -> serviceMesh "Uses for traffic routing and mTLS"
        kserve -> serverless "Uses for autoscaling"

        // Internal container relationships
        controllerManager -> webhookServer "Validates/mutates CRs" "HTTPS/9443"
        controllerManager -> monitoringStack "Deploys and configures"
    }

    views {
        systemContext rhoaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #d79b00
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
