/*
 * LM Evaluation Harness - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Configures and triggers model evaluation jobs"
        mlEngineer = person "ML Engineer" "Reviews evaluation results and model performance"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Python framework for evaluating generative language models across standardized benchmarks and custom tasks. Runs as a Kubernetes batch Job (ta-lmes-job container)." {
            cli = container "lm_eval CLI" "Entry point for running model evaluations" "Python CLI (lm_eval.__main__)"
            evaluator = container "Evaluator" "Core evaluation orchestration - loads models, runs tasks, aggregates results" "Python Module"
            modelBackends = container "Model Backends" "Pluggable model adapters: HuggingFace, vLLM, OpenAI API, WatsonX, GGUF" "Python Modules"
            taskFramework = container "Task Framework" "Defines evaluation tasks with configurable prompts, datasets, and metrics" "Python + YAML"
            metricsLibrary = container "Metrics Library" "56+ bundled evaluation metrics (accuracy, BLEU, ROUGE, F1, perplexity)" "Python Modules"
            unitxtIntegration = container "Unitxt Integration" "Modular text data preparation and evaluation" "Python Module"
            s3Downloader = container "S3 Downloader" "Downloads model/data artifacts from S3-compatible storage" "Python Script"
            evalTracker = container "Evaluation Tracker" "Logs evaluation parameters and results" "Python Module"
            cachingSystem = container "Caching System" "SQLite-based caching for model responses" "SQLite"
        }

        lmesOperator = softwareSystem "TrustyAI LMES Operator" "Orchestrates LM evaluation jobs by creating Kubernetes Job resources" "Internal RHOAI"
        s3Storage = softwareSystem "S3-compatible Object Storage" "Model artifact and dataset storage" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model, tokenizer, and dataset repository" "External"
        openaiAPI = softwareSystem "OpenAI-compatible API" "Remote model inference endpoints" "External"
        watsonxAI = softwareSystem "IBM WatsonX AI" "IBM remote model inference service" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster orchestration and Job management" "Platform"

        # Relationships - External
        dataScientist -> lmesOperator "Configures evaluation parameters"
        mlEngineer -> lmEvalHarness "Reviews evaluation results"
        lmesOperator -> k8sAPI "Creates Job resources" "HTTPS/6443, TLS 1.2+, ServiceAccount token"
        k8sAPI -> lmEvalHarness "Schedules Job Pod"

        # Relationships - Egress
        lmEvalHarness -> s3Storage "Downloads model artifacts and datasets" "HTTPS/443, TLS 1.2+, AWS IAM"
        lmEvalHarness -> hfHub "Downloads models, tokenizers, datasets; uploads results" "HTTPS/443, TLS 1.2+, HF Token"
        lmEvalHarness -> openaiAPI "Remote model inference" "HTTPS/443, TLS 1.2+, API Key Bearer"
        lmEvalHarness -> watsonxAI "Remote model inference" "HTTPS/443, TLS 1.2+, API Key"

        # Internal relationships
        cli -> evaluator "Invokes"
        evaluator -> modelBackends "Loads model adapters"
        evaluator -> taskFramework "Runs evaluation tasks"
        evaluator -> metricsLibrary "Computes metrics"
        evaluator -> unitxtIntegration "Prepares text data"
        evaluator -> evalTracker "Tracks results"
        evaluator -> cachingSystem "Caches responses"
        modelBackends -> s3Storage "Downloads models" "HTTPS/443"
        modelBackends -> hfHub "Downloads models" "HTTPS/443"
        modelBackends -> openaiAPI "Inference requests" "HTTPS/443"
        modelBackends -> watsonxAI "Inference requests" "HTTPS/443"
        s3Downloader -> s3Storage "Downloads artifacts" "HTTPS/443"
        evalTracker -> hfHub "Uploads results" "HTTPS/443"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
