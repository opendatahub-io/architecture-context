%% RBAC Visualization: Caikit-TGIS-Serving
%% Generated by: Claude Opus 4.6
%% Note: This component does not define its own RBAC resources.
%% RBAC is managed by KServe operator, OpenShift Service Mesh, and user ServiceAccounts.

graph TD
    subgraph "Caikit-TGIS-Serving RBAC Model"
        direction TB

        subgraph "Service Accounts"
            SA_User["sa<br/>(user-defined in InferenceService CR)<br/>Namespace: user-namespace"]
            SA_KServe["kserve-controller-manager<br/>Namespace: kserve"]
        end

        subgraph "KServe Operator RBAC (External)"
            CRB_KServe["kserve-manager-rolebinding<br/>(ClusterRoleBinding)"]
            CR_KServe["kserve-manager-role<br/>(ClusterRole)"]
        end

        subgraph "KServe CRD Resources"
            ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
            InferenceService["serving.kserve.io<br/>InferenceService"]
        end

        subgraph "Kubernetes Core Resources"
            Pods["core<br/>Pods"]
            Services["core<br/>Services"]
            Secrets["core<br/>Secrets<br/>(storage-config)"]
        end

        subgraph "Istio Service Mesh RBAC"
            PeerAuth["PeerAuthentication<br/>caikit-metrics<br/>STRICT default<br/>PERMISSIVE on 8086"]
            SMCP["ServiceMeshControlPlane<br/>minimal profile<br/>mTLS data plane"]
            SMMR["ServiceMeshMemberRoll<br/>Enrolls user namespaces"]
        end

        subgraph "Network Policies"
            NP_UWM["allow-from-openshift-monitoring-ns<br/>Allows Prometheus scraping<br/>From: openshift-user-workload-monitoring"]
        end

        %% Relationships
        SA_KServe -->|"bound via"| CRB_KServe
        CRB_KServe -->|"grants"| CR_KServe
        CR_KServe -->|"get,list,watch<br/>create,update,patch,delete"| ServingRuntime
        CR_KServe -->|"get,list,watch<br/>create,update,patch,delete"| InferenceService
        CR_KServe -->|"get,list,watch<br/>create,update,patch,delete"| Pods
        CR_KServe -->|"get,list,watch<br/>create,update,patch,delete"| Services

        SA_User -->|"get"| Secrets
        SA_User -->|"referenced in"| InferenceService

        PeerAuth -->|"enforces mTLS on"| Pods
        SMMR -->|"enrolls namespace"| Pods
        NP_UWM -->|"allows ingress to"| Pods
    end

