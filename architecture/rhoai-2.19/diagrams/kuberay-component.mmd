%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "KubeRay Operator"
        direction TB
        RCController["RayCluster Controller"]
        RJController["RayJob Controller"]
        RSController["RayService Controller"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS"]
        BatchMgr["Batch Scheduler Manager<br/>(Volcano / Yunikorn)"]

        RJController -->|creates| RCController
        RSController -->|creates| RCController
    end

    %% CRDs
    User["User / Admin"] -->|creates| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    User -->|creates| RayJobCR["RayJob CR<br/>ray.io/v1"]
    User -->|creates| RayServiceCR["RayService CR<br/>ray.io/v1"]

    RayClusterCR -->|watched by| RCController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController

    %% Webhook validation
    RayClusterCR -.->|validates| Webhook

    %% Resources created by RayCluster Controller
    RCController -->|creates| HeadPod["Ray Head Pod<br/>Ports: 6379, 8265, 10001, 8080, 8000"]
    RCController -->|creates| WorkerPods["Ray Worker Pods"]
    RCController -->|creates| HeadSvc["Head Service<br/>{cluster}-head-svc"]
    RCController -->|creates| ServeSvc["Serve Service<br/>{cluster}-serve-svc<br/>8000/TCP"]
    RCController -->|creates| HeadlessSvc["Headless Worker Service<br/>{cluster}-headless-worker-svc"]
    RCController -->|creates| IngressRoute["Ingress / Route<br/>Dashboard 8265/TCP"]

    %% RayJob Controller actions
    RJController -->|submits job via| Dashboard["Ray Head Dashboard<br/>8265/TCP HTTP"]
    RJController -->|creates| SubmitterJob["K8s Job<br/>(Job Submitter)"]

    %% RayService Controller actions
    RSController -->|deploys serve config via| Dashboard

    %% External Dependencies
    RCController -->|depends on| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    BatchMgr -.->|integrates| Volcano["Volcano Scheduler"]
    BatchMgr -.->|integrates| Yunikorn["Yunikorn Scheduler"]
    Webhook -.->|certs from| CertManager["cert-manager"]

    %% Internal Dependencies
    RCController -->|auto-detects| OpenShift["OpenShift API<br/>(Route support)"]

    %% Metrics
    Prometheus["Prometheus"] -->|scrapes| Metrics["Metrics Endpoint<br/>8080/TCP HTTP"]

