// C4 Context Diagram - OpenVINO Model Server (OVMS)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/openvino_model_server.md

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries ML models for inference"
        mlEngineer = person "ML Engineer" "Configures model serving pipelines and monitors performance"

        ovms = softwareSystem "OpenVINO Model Server" "High-performance C++ inference server built on OpenVINO, serving AI/ML models via gRPC and REST APIs" {
            grpcServer = container "gRPC Server Module" "Serves TFS and KServe v2 gRPC inference APIs" "C++ / gRPC" "Component"
            httpServer = container "HTTP Server Module" "Serves REST APIs (TFS v1, KServe v2, OpenAI v3, metrics)" "C++ / HTTP" "Component"
            servableManager = container "Servable Manager" "Manages model lifecycle, loading, versioning, and hot-reload" "C++" "Component"
            modelManager = container "Model Manager" "Handles model instances, version policies, and DAG pipelines" "C++" "Component"
            mediapipeExecutor = container "MediaPipe Graph Executor" "Executes complex processing pipelines (LLM, embeddings, rerank)" "C++ / MediaPipe" "Component"
            openvinoRuntime = container "OpenVINO Runtime" "Core inference engine for model execution" "C++ / OpenVINO 2025.0" "Component"
            openvinoGenAI = container "OpenVINO GenAI" "LLM text generation with continuous batching" "C++ / OpenVINO 2025.0" "Component"
            metricsModule = container "Metrics Module" "Exposes Prometheus-compatible metrics" "C++" "Component"
        }

        kserve = softwareSystem "KServe" "Deploys OVMS as InferenceService runtime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Uses OVMS as serving runtime for multi-model serving" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Tracks model metadata and versions" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "Internal RHOAI"

        s3 = softwareSystem "S3-Compatible Storage" "Model artifact storage (AWS S3, MinIO)" "External"
        azure = softwareSystem "Azure Blob Storage" "Model artifact storage on Azure" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage on GCP" "External"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic management, and network security" "External"

        // User interactions
        datascientist -> ovms "Sends inference requests" "gRPC/9178, HTTP/REST"
        mlEngineer -> ovms "Configures models and monitors" "REST API, /metrics"

        // Platform orchestration
        kserve -> ovms "Deploys and manages as inference container" "Container orchestration"
        modelmesh -> ovms "Routes inference requests" "gRPC/9178"
        modelRegistry -> ovms "Models referenced by OVMS may be tracked here" "Indirect"

        // External services
        ovms -> s3 "Downloads model artifacts" "HTTPS/443, TLS 1.2+, AWS IAM"
        ovms -> azure "Downloads model artifacts" "HTTPS/443, TLS 1.2+, Connection String"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443, TLS 1.2+, Service Account"
        ovms -> istio "Traffic routed through mesh" "mTLS STRICT"

        // Monitoring
        prometheus -> ovms "Scrapes metrics" "HTTP GET /metrics"

        // Internal container relationships
        grpcServer -> openvinoRuntime "Executes inference" "in-process"
        httpServer -> openvinoRuntime "Executes inference" "in-process"
        httpServer -> mediapipeExecutor "Routes OpenAI requests" "in-process"
        mediapipeExecutor -> openvinoGenAI "LLM generation" "in-process"
        servableManager -> modelManager "Registers models" "in-process"
        modelManager -> openvinoRuntime "Loads models" "in-process"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
