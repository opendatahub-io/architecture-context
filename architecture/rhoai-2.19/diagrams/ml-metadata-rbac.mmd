%% Generated by: Claude Opus 4.6
%% Note: MLMD does not define its own Kubernetes RBAC resources.
%% RBAC is managed by the DSP Operator that deploys this sidecar.
%% This diagram shows the security/access model instead.
graph TD
    subgraph "Deployment Model"
        DSPOperator["DSP Operator<br/>(manages RBAC)"]
    end

    subgraph "Pod Security Context"
        DSPPod["Data Science Pipelines Pod"]
        SA["ServiceAccount<br/>(managed by DSP Operator)"]
    end

    subgraph "MLMD Access Control"
        direction TB
        DefaultMode["Default Mode<br/>InsecureServerCredentials<br/>(No Auth)"]
        TLSMode["TLS Mode<br/>SSLConfig provided<br/>(Server-side TLS)"]
        mTLSMode["mTLS Mode<br/>SSLConfig + client_verify=true<br/>(Mutual TLS)"]
    end

    subgraph "gRPC Endpoints (All RPCs)"
        PutOps["Put Operations<br/>PutArtifacts, PutExecutions,<br/>PutContexts, PutEvents,<br/>PutExecution (atomic),<br/>PutLineageSubgraph"]
        GetOps["Get Operations<br/>GetArtifacts, GetExecutions,<br/>GetContexts, GetEvents,<br/>GetLineageSubgraph,<br/>GetArtifactsByContext, ..."]
        TypeOps["Type Operations<br/>PutArtifactType, PutExecutionType,<br/>PutContextType, GetArtifactType,<br/>GetExecutionType, GetContextType"]
    end

    subgraph "Secrets"
        DBCreds["Database Credentials<br/>Type: Opaque<br/>Provisioned by: DSP Operator"]
        SSLCerts["SSL Certificates<br/>Type: TLS<br/>server_key, server_cert, custom_ca<br/>Provisioned by: User / cert-manager"]
        MySQLSSL["MySQL SSL Options<br/>Type: Opaque<br/>Client cert/key/CA<br/>Provisioned by: User"]
        PgSSL["PostgreSQL SSL Options<br/>Type: Opaque<br/>Client cert/key/password<br/>Provisioned by: User"]
    end

    DSPOperator -->|"deploys & configures"| DSPPod
    DSPOperator -->|"creates"| SA
