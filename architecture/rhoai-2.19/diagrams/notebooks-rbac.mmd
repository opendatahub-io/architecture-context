graph TD
    subgraph UserAuth["User Authentication"]
        User["Data Scientist<br/>(OpenShift User)"]
    end

    subgraph AuthEnforcement["Authentication Enforcement"]
        OAuthProxy["oauth-proxy sidecar<br/>(RHOAI 2.x)"]
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x)"]
    end

    subgraph NotebookControllerRBAC["ODH Notebook Controller RBAC"]
        CtrlSA["ServiceAccount:<br/>notebook-controller-manager"]
        CtrlCRB["ClusterRoleBinding:<br/>notebook-controller-manager"]
        CtrlCR["ClusterRole:<br/>notebook-controller-role"]
    end

    subgraph WorkbenchRBAC["Workbench Pod RBAC"]
        WbSA["ServiceAccount:<br/>{notebook-name}-sa<br/>(per-workbench)"]
    end

    subgraph Resources["Managed Resources"]
        NotebookCR["Notebook CR<br/>(kubeflow.org)"]
        Pods["Workbench Pods"]
        Services["ClusterIP Services"]
        Routes["Routes / HTTPRoutes"]
        ImageStreams["ImageStreams<br/>opendatahub.io/notebook-image: true"]
    end

    subgraph ContainerSecurity["Container Security"]
        NonRoot["Non-root execution<br/>UID: 1001"]
        UBI9["UBI9 Base Image<br/>Security patched"]
        Scanning["Image Scanning<br/>Clair, ClamAV, Snyk,<br/>Coverity, rpms-signature-scan"]
        Signed["Image Signing + SBOM"]
    end

    subgraph Secrets["Secrets"]
        RHELSub["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription<br/>for RStudio BuildConfig<br/>Provisioned: Manual/Admin<br/>Auto-Rotate: No"]
    end

    %% Authentication flow
    User -->|"OAuth2 login"| OAuthProxy
    User -->|"OAuth2 login"| KubeRBACProxy
    OAuthProxy -->|"validates identity<br/>+ authorization"| Pods
    KubeRBACProxy -->|"validates identity<br/>+ RBAC check"| Pods

    %% Controller RBAC
    CtrlSA -->|"bound via"| CtrlCRB
    CtrlCRB -->|"grants"| CtrlCR
    CtrlCR -->|"create, update, delete"| NotebookCR
    CtrlCR -->|"create, update, delete"| Pods
    CtrlCR -->|"create, update, delete"| Services
    CtrlCR -->|"create, update, delete"| Routes
    CtrlCR -->|"get, list, watch"| ImageStreams

    %% Workbench SA
    WbSA -->|"limited cluster access<br/>via ServiceAccount token"| Pods

    %% Secret usage
    RHELSub -.->|"used by<br/>RStudio BuildConfig"| Pods

    %% Container security
    Pods --- NonRoot
    Pods --- UBI9
    Pods --- Scanning
    Pods --- Signed

    %% Styling
    style User fill:#4a90e2,color:#fff
    style OAuthProxy fill:#f5a623,color:#fff
    style KubeRBACProxy fill:#f5a623,color:#fff
    style CtrlSA fill:#4a90e2,color:#fff
    style CtrlCR fill:#f5a623,color:#fff
    style WbSA fill:#4a90e2,color:#fff
    style NotebookCR fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style Routes fill:#7ed321,color:#fff
    style ImageStreams fill:#7ed321,color:#fff
    style NonRoot fill:#e8e8e8,stroke:#333
    style UBI9 fill:#e8e8e8,stroke:#333
    style Scanning fill:#e8e8e8,stroke:#333
    style Signed fill:#e8e8e8,stroke:#333
    style RHELSub fill:#ff6b6b,color:#fff
