%% Data Science Pipelines - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB
        APIServer["ml-pipeline<br/>(API Server)<br/>Go Service<br/>REST :8888 / gRPC :8887"]
        PersistenceAgent["ml-pipeline-persistenceagent<br/>Go Agent"]
        ScheduledWF["ml-pipeline-scheduledworkflow<br/>Go Controller"]
        ViewerCRD["ml-pipeline-viewer-crd<br/>Go Controller"]
        CacheServer["cache-server<br/>Mutating Webhook<br/>:8443/HTTPS"]
        UI["ml-pipeline-ui<br/>Node.js/React<br/>:3000"]
        VizServer["ml-pipeline-visualizationserver<br/>Python Service<br/>:8888"]
        Driver["driver<br/>V2 DAG Orchestrator<br/>Go Binary"]
        Launcher["launcher-v2<br/>V2 Step Launcher<br/>Go Binary"]
    end

    subgraph Metadata["ML Metadata"]
        MetadataGRPC["metadata-grpc-server<br/>gRPC :8080"]
        MetadataEnvoy["metadata-envoy<br/>Envoy Proxy :9090"]
        MetadataEnvoy -->|proxy| MetadataGRPC
    end

    subgraph CRDs["Custom Resources"]
        SWF_CR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
        Viewer_CR["Viewer CR<br/>kubeflow.org/v1beta1"]
    end

    %% User interactions
    User[User / Dashboard] -->|REST/gRPC| APIServer
    User -->|HTTP :80| UI

    %% Internal component interactions
    APIServer -->|creates| SWF_CR
    PersistenceAgent -->|watches workflows<br/>reports status| APIServer
    ScheduledWF -->|reconciles| SWF_CR
    ScheduledWF -->|creates runs| APIServer
    ViewerCRD -->|reconciles| Viewer_CR
    UI -->|API calls| APIServer
    UI -->|visualizations| VizServer
    Driver -->|creates TaskRuns| K8sAPI
    Launcher -->|logs metadata| MetadataGRPC
    Launcher -->|artifact I/O| S3

    %% External dependencies
    APIServer -->|CRUD| DB[(MySQL/PostgreSQL<br/>:3306/:5432)]
    APIServer -->|artifacts| S3[S3/MinIO<br/>Object Store]
    APIServer -->|workflow mgmt| K8sAPI[Kubernetes API<br/>:443/HTTPS]
    CacheServer -->|cache check| DB

    %% Workflow engines
    APIServer -->|creates| TektonPR[Tekton PipelineRun]
    APIServer -->|creates| ArgoWF[Argo Workflow]

    %% DSPO
    DSPO[data-science-pipelines-operator] -->|deploys & manages| DSP

