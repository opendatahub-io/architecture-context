/*
 * C4 Context Diagram for ilab-on-ocp (InstructLab on OCP)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/ilab-on-ocp.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Configures and triggers InstructLab fine-tuning pipelines"
        platformAdmin = person "Platform Admin" "Configures DSPA and InstructLab managed pipelines"

        ilabOnOcp = softwareSystem "InstructLab on OCP (ilab-on-ocp)" "KFP v2 pipeline for LLM fine-tuning: synthetic data generation, distributed training, and model evaluation" {
            pipeline = container "InstructLab Pipeline" "Main KFP v2 pipeline orchestrating SDG, training, evaluation, and model output" "Python (KFP)"
            sdgComponent = container "SDG Component" "Generates synthetic training data using InstructLab SDG with a teacher model" "Python"
            trainingComponent = container "Training Component" "Launches distributed PyTorchJobs for two-phase model training" "Python"
            evalComponents = container "Evaluation Components" "MT-Bench and MMLU evaluation with vLLM serving and judge model" "Python"
            utilsComponent = container "Utilities" "Prerequisites validation, model upload to OCI, Model Registry integration" "Python"
            runtimeImage = container "Runtime Container Image" "odh-ml-pipelines-runtime-generic - embeds pipeline code and dependencies" "Container"
        }

        dspa = softwareSystem "Data Science Pipelines (DSPA)" "Pipeline orchestration, scheduling, artifact storage via KFP v2 API" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform for teacher and judge model serving" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Distributed multi-node multi-GPU training via PyTorchJob CRs" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model metadata registration and versioning" "Internal RHOAI"
        knative = softwareSystem "OpenShift Serverless (Knative)" "Serverless infrastructure required by KServe" "Internal RHOAI"
        serviceMesh = softwareSystem "OpenShift Service Mesh v2" "Traffic routing and mTLS for KServe" "Internal RHOAI"
        authorino = softwareSystem "Red Hat Authorino" "Authentication for KServe endpoints" "Internal RHOAI"
        gpuOperator = softwareSystem "NVIDIA GPU Operator" "GPU device plugin for training and evaluation nodes" "External"

        gitRepo = softwareSystem "Git Repository" "Taxonomy source repository for synthetic data generation" "External"
        ociRegistry = softwareSystem "OCI Registry" "Container/model artifact registry for ModelCar images" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model download hub (optional)" "External"
        s3Storage = softwareSystem "S3/MinIO Storage" "Pipeline artifact storage (via DSPA)" "External"

        // User interactions
        dataScientist -> ilabOnOcp "Triggers pipeline execution and reviews results"
        platformAdmin -> dspa "Configures DataSciencePipelinesApplication with InstructLab enabled"

        // Internal pipeline flows
        pipeline -> sdgComponent "Orchestrates SDG phase"
        pipeline -> trainingComponent "Orchestrates training phase"
        pipeline -> evalComponents "Orchestrates evaluation phase"
        pipeline -> utilsComponent "Uses for prereqs, upload, registration"

        // System dependencies
        ilabOnOcp -> dspa "Pipeline orchestration" "KFP v2 REST API / HTTPS"
        ilabOnOcp -> kserve "Teacher & judge model serving" "InferenceService CR / HTTPS"
        ilabOnOcp -> trainingOperator "Distributed training" "PyTorchJob CR / HTTPS"
        ilabOnOcp -> modelRegistry "Model registration" "REST API / HTTPS/443"
        kserve -> knative "Serverless serving infrastructure"
        kserve -> serviceMesh "Traffic routing and mTLS"
        kserve -> authorino "Endpoint authentication"

        // External dependencies
        ilabOnOcp -> gitRepo "Clone taxonomy" "HTTPS/443 or SSH/22"
        ilabOnOcp -> ociRegistry "Push/pull ModelCar images" "HTTPS/443"
        ilabOnOcp -> huggingface "Download base models (optional)" "HTTPS/443"
        dspa -> s3Storage "Pipeline artifact storage" "S3 API / HTTPS/443"
        ilabOnOcp -> gpuOperator "GPU resources for training and evaluation"
    }

    views {
        systemContext ilabOnOcp "SystemContext" {
            include *
            autoLayout
        }

        container ilabOnOcp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
