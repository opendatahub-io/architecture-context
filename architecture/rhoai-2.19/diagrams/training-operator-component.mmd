            CertMgr["Cert Manager<br/>(OPA cert-controller)"]
            Metrics["Metrics Endpoint<br/>Port 8080/TCP"]
            Health["Health Probes<br/>Port 8081/TCP"]
        end

        Manager --> PyTorch
        Manager --> TF
        Manager --> MPI
        Manager --> XGBoost
        Manager --> Paddle
        Manager --> JAX
        Manager --> Webhook
        CertMgr -->|rotates TLS certs| Webhook
