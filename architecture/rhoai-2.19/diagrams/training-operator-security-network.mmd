graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Pipeline"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        subgraph OperatorPod["training-operator Pod"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-managed CA)<br/>SA: training-operator"]
            MetricsEP["Metrics Endpoint<br/>8080/TCP HTTP<br/>plaintext"]
            HealthEP["Health Probes<br/>8081/TCP HTTP<br/>plaintext"]
        end
        WebhookSvc["kubeflow-training-operator Service<br/>ClusterIP 443→9443<br/>HTTPS TLS"]
    end

    subgraph UserNS["USER NAMESPACES (Training Jobs)"]
        direction TB
        Workers["Worker Pods<br/>(dynamically created)"]
        HeadlessSvc["Headless Services<br/>ClusterIP headless<br/>Framework-specific/TCP"]
        NetPol["NetworkPolicy<br/>(PyTorchJob isolation)"]
    end

    subgraph Monitoring["MONITORING (openshift-monitoring)"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-managed)<br/>API server client cert"| WebhookSvc
    WebhookSvc --> WebhookSrv

    %% Operator to API
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRUD: Pods, Services,<br/>CRDs, NetworkPolicies,<br/>HPAs, PodGroups"| K8sAPI

    %% Operator creates resources
    OperatorPod -.->|"creates"| Workers
    OperatorPod -.->|"creates"| HeadlessSvc
    OperatorPod -.->|"creates"| NetPol

    %% Worker communication
    Workers -->|"DNS/53 UDP<br/>plaintext"| HeadlessSvc
    Workers -->|"Framework-specific/TCP<br/>plaintext<br/>NetworkPolicy restricted"| Workers

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>No auth"| MetricsEP

