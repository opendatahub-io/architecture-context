    Operator -->|"TCP/6379<br/>plaintext<br/>No Auth<br/>Health check"| HeadPod

    %% Worker to Head
    WorkerPods -->|"TCP/6379<br/>plaintext<br/>No Auth<br/>GCS connection"| HeadPod

