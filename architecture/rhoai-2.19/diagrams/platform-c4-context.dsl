// C4 Context Diagram - Red Hat OpenShift AI (RHOAI) 2.19
// Generated by Claude Opus 4.6

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Develops and trains ML models using notebooks and pipelines"
        mlEngineer = person "ML Engineer" "Deploys and manages model serving endpoints"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform configuration and lifecycle"

        // RHOAI Platform
        rhoai = softwareSystem "Red Hat OpenShift AI" "Enterprise MLOps platform for the full AI/ML lifecycle" {
            rhodsOperator = container "rhods-operator" "Central OLM operator managing all RHOAI components via DataScienceCluster and DSCInitialization CRDs" "Go 1.21 Operator"
            dashboard = container "odh-dashboard" "Web UI (React SPA + Node.js BFF) for managing workbenches, model serving, pipelines" "TypeScript/React + Node.js/Fastify"
            kserve = container "KServe" "Single-model serving controller with Serverless (Knative/Istio) and RawDeployment modes" "Go 1.21 Operator"
            modelmeshServing = container "ModelMesh Serving" "Multi-model serving controller with ModelMesh sidecar injection" "Go 1.21 Operator"
            modelmesh = container "ModelMesh" "Distributed LRU cache sidecar for multi-model serving" "Java 17 Sidecar"
            odhModelController = container "ODH Model Controller" "Manages Routes, Gateways, NetworkPolicies, AuthConfigs for model serving" "Go 1.21 Controller"
            dspOperator = container "DSP Operator" "Manages DataSciencePipelinesApplication CRs deploying pipeline infrastructure" "Go 1.21 Operator"
            dspApiServer = container "DSP API Server" "KFP v2 backend with REST and gRPC APIs" "Go 1.21 Service"
            argoWorkflows = container "Argo Workflows" "Workflow engine for pipeline task execution" "Go 1.23"
            mlMetadata = container "ML Metadata" "gRPC server for ML artifact/execution/context metadata" "C++ Service"
            notebookController = container "Notebook Controller" "Manages Notebook CRD lifecycle: StatefulSets, Services, idle culling" "Go 1.21 Controller"
            codeflareOperator = container "CodeFlare Operator" "Manages RayCluster OAuth/networking with AppWrapper CRD" "Go 1.21 Operator"
            kuberay = container "KubeRay" "Manages RayCluster/RayJob/RayService CRDs" "Go 1.22 Operator"
            kueue = container "Kueue" "Job queueing system for resource quota management and fair scheduling" "Go 1.23 Controller"
            trainingOperator = container "Training Operator" "Kubeflow Training Operator with PyTorchJob, TFJob, MPIJob, etc." "Go 1.23 Operator"
            modelRegistryOp = container "Model Registry Operator" "Manages ModelRegistry CRs with REST+gRPC+UI containers" "Go 1.21 Operator"
            modelRegistry = container "Model Registry" "Go REST proxy + MLMD gRPC backend + UI for model versioning" "Go + TypeScript Service"
            trustyaiOperator = container "TrustyAI Operator" "Multi-controller operator managing TrustyAIService, LMEvalJob, GuardrailsOrchestrator" "Go 1.21 Operator"
            trustyai = container "TrustyAI Service" "Fairness metrics, drift detection, LIME/SHAP explainability" "Java 17 (Quarkus)"
            guardrails = container "Guardrails Orchestrator" "Orchestrates content safety detectors on LLM input/output" "Rust 1.84 Service"
            lmEval = container "LM Evaluation Harness" "LLM evaluation across 60+ benchmarks" "Python Job"
            feast = container "Feast" "Feature store with online/offline/registry servers and K8s operator" "Go 1.22 + Python 3.11"
            ilabOnOcp = container "InstructLab Pipeline" "KFP pipeline for synthetic data generation and distributed training" "Python KFP v2"
            inferenceRuntimes = container "Inference Runtimes" "vLLM, vLLM-Gaudi, OVMS, TGIS, Caikit-TGIS" "Python/C++/Rust"
        }

        // External Platform Dependencies (Tier 0)
        ocp = softwareSystem "OpenShift Container Platform" "Container orchestration platform (v4.14-v4.19)" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and lifecycle management" "External"
        serviceMesh = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for traffic routing and mTLS" "External"
        serverless = softwareSystem "OpenShift Serverless (Knative)" "Scale-to-zero autoscaling for model endpoints" "External"
        authorino = softwareSystem "Red Hat Authorino (Kuadrant)" "External authorization for model serving" "External"
        gpuOperator = softwareSystem "NVIDIA GPU Operator" "GPU device plugin for CUDA workloads" "External"

        // External Services
        s3Storage = softwareSystem "S3-compatible Storage" "Model artifacts, pipeline artifacts, training data" "External Service"
        containerRegistry = softwareSystem "Container Registries" "quay.io, registry.redhat.io for container images" "External Service"
        huggingface = softwareSystem "HuggingFace Hub" "Model and tokenizer downloads" "External Service"
        mariadb = softwareSystem "MariaDB" "Pipeline metadata persistence" "External Service"
        etcd = softwareSystem "etcd" "Distributed coordination for ModelMesh" "External Service"
        postgresql = softwareSystem "PostgreSQL" "Persistence for Model Registry and Feast" "External Service"
        redis = softwareSystem "Redis" "Online store backend for Feast" "External Service"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry metrics and traces" "External Service"

        // User relationships
        dataScientist -> dashboard "Manages workbenches, pipelines, models via browser"
        dataScientist -> kserve "Creates InferenceService via kubectl/API"
        dataScientist -> notebookController "Creates Notebook CRs for development environments"
        mlEngineer -> kserve "Deploys model serving endpoints"
        mlEngineer -> modelmeshServing "Deploys multi-model serving endpoints"
        mlEngineer -> modelRegistry "Registers and tracks model versions"
        platformAdmin -> rhodsOperator "Configures DataScienceCluster CR"
        platformAdmin -> dashboard "Manages platform settings"

        // Platform operator relationships
        rhodsOperator -> olm "Installed and managed by OLM"
        rhodsOperator -> dashboard "Deploys via Kustomize"
        rhodsOperator -> kserve "Deploys via Kustomize"
        rhodsOperator -> modelmeshServing "Deploys via Kustomize"
        rhodsOperator -> odhModelController "Deploys via Kustomize"
        rhodsOperator -> dspOperator "Deploys via Kustomize"
        rhodsOperator -> notebookController "Deploys via Kustomize"
        rhodsOperator -> codeflareOperator "Deploys via Kustomize"
        rhodsOperator -> kuberay "Deploys via Kustomize"
        rhodsOperator -> kueue "Deploys via Kustomize"
        rhodsOperator -> trainingOperator "Deploys via Kustomize"
        rhodsOperator -> modelRegistryOp "Deploys via Kustomize"
        rhodsOperator -> trustyaiOperator "Deploys via Kustomize"
        rhodsOperator -> feast "Deploys via Kustomize"

        // External dependency relationships
        kserve -> serviceMesh "Uses for traffic routing and mTLS"
        kserve -> serverless "Uses for scale-to-zero autoscaling"
        kserve -> authorino "Uses for external authorization" "AuthConfig CRD"
        kserve -> inferenceRuntimes "Creates ServingRuntime pods"
        modelmeshServing -> modelmesh "Injects as sidecar"
        modelmesh -> etcd "Distributed coordination" "gRPC/2379"
        modelRegistryOp -> modelRegistry "Deploys REST+gRPC+UI"
        modelRegistryOp -> serviceMesh "Uses for mTLS" "Istio"
        modelRegistryOp -> authorino "Uses for external authorization"
        modelRegistry -> mlMetadata "Metadata storage backend" "gRPC/9090"
        modelRegistry -> postgresql "Persistence" "TCP/5432"

        // Pipeline relationships
        dspOperator -> dspApiServer "Deploys" "Deployment"
        dspOperator -> argoWorkflows "Deploys" "Deployment"
        dspOperator -> mlMetadata "Deploys" "Deployment"
        dspApiServer -> argoWorkflows "Pipeline execution" "Workflow CR"
        dspApiServer -> mlMetadata "Artifact metadata" "gRPC/8080"
        dspApiServer -> mariadb "Pipeline metadata" "TCP/3306"
        dspApiServer -> s3Storage "Pipeline artifacts" "HTTPS/443"
        ilabOnOcp -> dspApiServer "Pipeline orchestration" "KFP v2 API"
        ilabOnOcp -> kserve "Teacher/judge model serving" "InferenceService CR"
        ilabOnOcp -> trainingOperator "Distributed training" "PyTorchJob CR"
        ilabOnOcp -> modelRegistry "Model registration" "REST API"

        // Distributed compute relationships
        codeflareOperator -> kuberay "Ray cluster management" "RayCluster CR"
        kueue -> trainingOperator "Job queueing" "Workload integration"
        kueue -> kuberay "Job queueing" "Workload integration"

        // AI Safety relationships
        trustyaiOperator -> trustyai "Deploys service"
        trustyaiOperator -> lmEval "Creates evaluation jobs"
        trustyaiOperator -> guardrails "Deploys service"
        guardrails -> inferenceRuntimes "Text generation" "gRPC/HTTP"

        // External service relationships
        inferenceRuntimes -> s3Storage "Model weight downloads" "HTTPS/443"
        inferenceRuntimes -> huggingface "Model/tokenizer downloads" "HTTPS/443"
        inferenceRuntimes -> gpuOperator "GPU access" "CUDA/ROCm"
        feast -> redis "Online store" "TCP/6379"
        feast -> postgresql "Persistence" "TCP/5432"
        guardrails -> otlpCollector "Telemetry" "gRPC/4317"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
