/*
 * C4 Context Diagram: vllm-gaudi
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.19/vllm-gaudi.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits inference requests to deployed LLM models"

        vllmGaudi = softwareSystem "vllm-gaudi" "High-throughput LLM inference serving optimized for Intel Gaudi HPU accelerators, providing OpenAI-compatible and gRPC endpoints" {
            openaiServer = container "OpenAI API Server" "Primary HTTP entrypoint serving OpenAI-compatible REST API for inference" "Python FastAPI" "Component"
            tgisAdapter = container "vllm-tgis-adapter" "Secondary gRPC entrypoint providing TGIS protocol compatibility" "Python gRPC" "Component"
            asyncEngine = container "AsyncLLMEngine" "Asynchronous inference engine with continuous batching and PagedAttention" "Python" "Component"
            mqEngine = container "MQ Engine" "Inter-process communication between API frontend and engine backend" "ZeroMQ IPC" "Component"
            scheduler = container "Scheduler" "Manages request queuing, batching, preemption, and KV cache allocation" "Python" "Component"
            modelExecutor = container "Model Executor" "Manages model loading, weight distribution, and execution across devices" "Python" "Component"
            hpuWorker = container "HPU Worker" "Executes model inference on Intel Gaudi accelerators" "Python/C++" "Component"
            habanaPlugin = container "Habana Plugin" "Intel Gaudi software stack integration" "habana-torch-plugin" "Component"
            prometheusMetrics = container "Prometheus Metrics" "Exposes vLLM-specific metrics (latency, throughput, cache usage)" "Python" "Component"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Deploys and manages vllm-gaudi as inference serving containers" "Internal RHOAI"
        serviceMesh = softwareSystem "Service Mesh / Gateway" "Routes external traffic to inference endpoints, TLS termination" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Cluster monitoring and metrics collection" "Internal"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection (optional)" "Internal"
        s3Storage = softwareSystem "S3-compatible Storage" "Model weight artifact storage" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model/tokenizer repository (disabled in production)" "External"
        gaudiHardware = softwareSystem "Intel Gaudi Accelerator" "HPU hardware for AI inference acceleration (Gaudi 2/3)" "Hardware"

        /* User interactions */
        user -> vllmGaudi "Sends inference requests (chat, completions, embeddings)" "HTTPS/443"

        /* Internal container relationships */
        openaiServer -> asyncEngine "Submits requests" "Python"
        tgisAdapter -> asyncEngine "Submits requests" "Python in-process"
        asyncEngine -> mqEngine "Request/response" "ZMQ IPC"
        mqEngine -> scheduler "Schedule requests" "Python"
        scheduler -> modelExecutor "Execute inference" "Python"
        modelExecutor -> hpuWorker "Run on HPU" "PyTorch/Habana"
        hpuWorker -> habanaPlugin "HPU operations" "habana-torch-plugin"
        openaiServer -> prometheusMetrics "Exports metrics" "Python"

        /* External relationships */
        kserve -> vllmGaudi "Deploys and manages lifecycle" "Kubernetes API"
        serviceMesh -> vllmGaudi "Routes traffic, TLS termination" "HTTP/8000, gRPC/8033"
        prometheus -> vllmGaudi "Scrapes /metrics endpoint" "HTTP/8000"
        vllmGaudi -> otelCollector "Exports traces (optional)" "OTLP HTTP/gRPC"
        vllmGaudi -> s3Storage "Downloads model weights" "HTTPS/443 AWS IAM"
        vllmGaudi -> huggingfaceHub "Downloads models (disabled: HF_HUB_OFFLINE=1)" "HTTPS/443"
        hpuWorker -> gaudiHardware "Executes inference computations" "PCIe/Habana runtime"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #85bbf0
                color #ffffff
            }
            element "Hardware" {
                background #ff6b6b
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
