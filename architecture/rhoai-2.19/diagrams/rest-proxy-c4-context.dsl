// REST Proxy - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/rest-proxy.md

workspace {
    model {
        client = person "ML Client" "Sends inference requests using KServe V2 REST protocol"

        restProxy = softwareSystem "REST Proxy (odh-mm-rest-proxy)" "Reverse-proxy sidecar translating KServe V2 REST inference requests into gRPC calls" {
            proxyServer = container "REST Proxy Server" "Reverse-proxy translating REST to gRPC using grpc-gateway" "Go HTTP Service"
            jsonMarshaler = container "CustomJSONPb Marshaler" "Custom JSON marshaler/unmarshaler for tensor data serialization" "Go Library"
            grpcGateway = container "GRPCInferenceService Gateway" "Auto-generated reverse proxy stubs from protobuf definitions" "Generated gRPC-Gateway"
        }

        modelMeshServing = softwareSystem "ModelMesh Serving" "Multi-model serving platform providing gRPC inference API" "Internal ODH"
        modelMeshController = softwareSystem "ModelMesh Serving Controller" "Manages ModelMesh deployments and configures REST Proxy sidecar image" "Internal ODH"
        certManager = softwareSystem "cert-manager" "Certificate management for optional TLS" "External"

        // System-level relationships
        client -> restProxy "Sends REST inference requests" "HTTP/HTTPS 8008/TCP"
        restProxy -> modelMeshServing "Forwards as gRPC calls" "gRPC 8033/TCP (localhost)"
        modelMeshController -> restProxy "Configures sidecar image via ConfigMap" "model-serving-config"
        certManager -> restProxy "Provisions TLS certificates" "TLS key/cert pair"

        // Container-level relationships
        client -> proxyServer "POST /v2/models/{name}/infer, GET /v2/models/{name}" "HTTP/HTTPS 8008/TCP"
        proxyServer -> jsonMarshaler "Decodes/encodes tensor JSON"
        proxyServer -> grpcGateway "Routes REST to gRPC"
        grpcGateway -> modelMeshServing "gRPC ModelInfer, ModelMetadata" "gRPC 8033/TCP"
    }

    views {
        systemContext restProxy "SystemContext" {
            include *
            autoLayout
        }

        container restProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
