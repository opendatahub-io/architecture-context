// KServe C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/kserve.md

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist" "Creates and deploys ML models using InferenceService CRs"
        mlEngineer = person "ML Engineer" "Configures serving runtimes and inference pipelines"
        apiClient = person "API Client" "Sends inference requests to deployed models"

        // KServe System
        kserve = softwareSystem "KServe" "Kubernetes-native serverless ML inference platform with autoscaling, canary rollouts, and multi-framework support" {
            controllerManager = container "kserve-controller-manager" "Main controller managing InferenceService, TrainedModel, InferenceGraph, LocalModel CRs" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Mutating and validating webhooks for InferenceService, TrainedModel, InferenceGraph, ServingRuntime CRs, and Pod mutation" "Go (port 9443/TCP HTTPS)"
            storageInitializer = container "Storage Initializer" "Init container that downloads model artifacts from cloud storage (S3, GCS, Azure) or OCI registries" "Go/Python Init Container"
            kserveAgent = container "kserve-agent" "Logger/batcher sidecar injected into inference pods for request logging and batching" "Go Sidecar"
            kserveRouter = container "kserve-router" "Inference graph router that handles DAG-based request routing between inference services" "Go Service"
            oauthProxy = container "oauth-proxy" "OpenShift oauth-proxy sidecar for authentication on raw deployment mode (port 8443/TCP)" "Sidecar"
            pythonRuntimes = container "Python Serving Runtimes" "Model serving runtimes: sklearn, xgboost, pytorch, tensorflow, triton, huggingface" "Python Services"
        }

        // External Dependencies
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform (>= 1.25.0)" "External"
        istio = softwareSystem "Istio Service Mesh" "Ingress traffic management via VirtualServices and Gateways (1.23.x)" "External"
        knative = softwareSystem "Knative Serving" "Serverless scale-to-zero and autoscaling (0.42.x)" "External"
        certManager = softwareSystem "cert-manager" "Webhook TLS certificate management (v1)" "External"
        openshift = softwareSystem "OpenShift" "Route API for external route exposure, OAuth for authentication" "External"

        // External Storage Services
        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, MinIO, etc.)" "External Storage"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External Storage"
        azureBlob = softwareSystem "Azure Blob Storage" "Model artifact storage" "External Storage"
        ociRegistry = softwareSystem "OCI Container Registry" "Modelcar OCI image storage" "External Storage"

        // Internal ODH Components
        odhDashboard = softwareSystem "ODH Dashboard" "UI for managing inference services" "Internal RHOAI"
        dsci = softwareSystem "DSC Initialization (DSCI)" "Platform configuration via DSCInitialization CR" "Internal RHOAI"

        // Relationships - User interactions
        dataScientist -> kserve "Creates InferenceService, TrainedModel CRs" "kubectl / API"
        mlEngineer -> kserve "Configures ServingRuntimes, InferenceGraphs" "kubectl / API"
        apiClient -> kserve "Sends inference requests" "HTTPS/443"

        // Relationships - Internal
        controllerManager -> webhookServer "Registers webhooks"
        controllerManager -> kubernetes "Manages resources (Deployments, Services, Ingresses)" "HTTPS/443 SA Token"

        // Relationships - External dependencies
        kserve -> istio "Traffic routing via VirtualServices and mTLS" "VirtualService CRD"
        kserve -> knative "Serverless autoscaling and scale-to-zero" "Knative Service CRD"
        kserve -> certManager "Webhook TLS certificate provisioning" "Certificate CRD"
        kserve -> openshift "Route creation, OAuth authentication" "Route CRD, OAuth"

        // Relationships - Storage
        storageInitializer -> s3 "Downloads model artifacts" "HTTPS/443 AWS IAM"
        storageInitializer -> gcs "Downloads model artifacts" "HTTPS/443 GCP SA"
        storageInitializer -> azureBlob "Downloads model artifacts" "HTTPS/443 Azure creds"
        storageInitializer -> ociRegistry "Pulls modelcar OCI images" "HTTPS/443 Registry creds"

        // Relationships - Internal RHOAI
        odhDashboard -> kserve "UI management of inference services"
        dsci -> kserve "Platform configuration"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Storage" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
