/*
 * C4 Context Diagram: Caikit-TGIS-Serving
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates InferenceService CRs to deploy LLM models for inference"

        caikitTgisServing = softwareSystem "Caikit-TGIS-Serving" "LLM inference serving layer combining Caikit AI runtime with TGIS backend on OpenShift AI" {
            caikitRuntime = container "Caikit Runtime" "Serves HTTP/gRPC inference APIs, manages model lifecycle via caikit-nlp" "Python 3.11, caikit 0.27.7" "transformer-container"
            tgisEngine = container "TGIS Engine" "Text Generation Inference Server - loads and runs LLM model weights" "Python, TGIS" "kserve-container"
            storageInitializer = container "Storage Initializer" "Downloads model artifacts from S3/Minio at pod startup" "KServe init-container"
            istioSidecar = container "Istio Sidecar Proxy" "Enforces mTLS, traffic management" "Envoy Proxy"
        }

        kserve = softwareSystem "KServe" "Manages ServingRuntime and InferenceService CRDs, orchestrates model serving lifecycle" "Internal RHOAI"
        knativeServing = softwareSystem "OpenShift Serverless (Knative Serving)" "Provides serverless autoscaling, revision management, traffic routing" "Internal RHOAI"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Provides mTLS, ingress gateway, traffic management" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection from openshift-user-workload-monitoring" "Internal OpenShift"

        s3Storage = softwareSystem "S3/Minio Storage" "Model artifact storage backend" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for CRD management" "External"

        // Relationships
        user -> caikitTgisServing "Sends inference requests via HTTP/gRPC" "HTTPS/443"
        user -> kserve "Creates InferenceService CRs via kubectl" "HTTPS/6443"

        caikitRuntime -> tgisEngine "Sends inference requests" "gRPC/8033 plaintext (pod-local)"
        storageInitializer -> s3Storage "Downloads model artifacts" "S3 API, 9000/443 TCP"

        kserve -> caikitTgisServing "Manages serving lifecycle" "CRD API"
        kserve -> knativeServing "Creates Knative Services" "CRD API"
        kserve -> k8sAPI "Manages CRDs" "HTTPS/6443"

        knativeServing -> caikitTgisServing "Routes traffic, manages autoscaling" "HTTP/8012"
        istio -> caikitTgisServing "Provides mTLS, ingress gateway" "mTLS"

        prometheus -> caikitTgisServing "Scrapes metrics" "HTTP/8086 plaintext"

        caikitTgisServing -> s3Storage "Loads model artifacts at startup" "S3 API, HTTP/HTTPS"
    }

    views {
        systemContext caikitTgisServing "SystemContext" {
            include *
            autoLayout
            description "System context showing Caikit-TGIS-Serving in the RHOAI ecosystem"
        }

        container caikitTgisServing "Containers" {
            include *
            autoLayout
            description "Container view showing internal structure of the ServingRuntime pod"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal OpenShift" {
                background #85C1E9
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
