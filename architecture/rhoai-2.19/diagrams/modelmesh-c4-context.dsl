// ModelMesh C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/modelmesh.md

workspace {
    model {
        controller = person "modelmesh-serving Controller" "Manages ModelMesh deployments via K8s operator"
        client = person "Inference Client" "Sends gRPC inference requests to served models"

        modelMesh = softwareSystem "ModelMesh" "Distributed LRU cache and intelligent routing layer for high-scale, high-density model serving" {
            sidecarModelMesh = container "SidecarModelMesh" "Core sidecar process managing model lifecycle, routing, and inter-pod coordination" "Java 17"
            modelMeshApi = container "ModelMeshApi" "External gRPC API for model management and inference passthrough" "gRPC Server, Port 8033"
            litelinks = container "Litelinks RPC" "Intra-cluster pod-to-pod communication for distributed cache" "IBM Litelinks, Port 8080"
            vmodelManager = container "VModelManager" "Virtual model aliases for blue-green deployments" "Java"
            typeConstraintMgr = container "TypeConstraintManager" "Type-based constraints for heterogeneous runtime placement" "Java"
            payloadProcessor = container "PayloadProcessor" "Pluggable inference payload logging/forwarding" "Java"
            healthProbe = container "Health Probe Server" "Readiness and liveness HTTP endpoints" "HTTP, Port 8089"
            preStopServer = container "PreStop Server" "Graceful shutdown coordination" "HTTP, Port 8090"
            metricsSubsystem = container "Metrics Subsystem" "Prometheus/StatsD metrics exposition" "Port 2112/8126"
        }

        modelRuntime = softwareSystem "Model Runtime" "Co-located container implementing ModelRuntime gRPC interface (triton, mlserver, ovms, torchserve)" "Internal"
        etcd = softwareSystem "etcd" "Distributed key-value store for cluster state, model registry, and dynamic configuration" "External"
        modelmeshServing = softwareSystem "modelmesh-serving" "Kubernetes operator managing ServingRuntimes and InferenceServices" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        kubernetesAPI = softwareSystem "Kubernetes API" "Pod metadata injection via Downward API" "External"

        // Relationships
        client -> modelMesh "Sends inference requests" "gRPC/8033, TLS, mTLS optional"
        controller -> modelMesh "Registers/manages models" "gRPC/8033, TLS"
        modelmeshServing -> modelMesh "Manages Deployment, Service, ConfigMaps" "Kubernetes API"

        modelMesh -> modelRuntime "Loads/unloads models, inference" "gRPC/8085 or UDS, plaintext"
        modelMesh -> etcd "Stores model registry, cluster state" "gRPC/2379, TLS, Cert auth"
        prometheus -> modelMesh "Scrapes metrics" "HTTPS/2112, TLS self-signed"
        kubernetesAPI -> modelMesh "Injects pod metadata" "Downward API"

        // Internal relationships
        sidecarModelMesh -> modelMeshApi "Manages"
        sidecarModelMesh -> litelinks "Inter-pod routing"
        sidecarModelMesh -> vmodelManager "VModel operations"
        sidecarModelMesh -> typeConstraintMgr "Placement decisions"
        modelMeshApi -> payloadProcessor "Payload logging"
    }

    views {
        systemContext modelMesh "SystemContext" {
            include *
            autoLayout
        }

        container modelMesh "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
