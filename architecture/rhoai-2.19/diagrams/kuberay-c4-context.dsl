// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Ray clusters, jobs, and serving deployments"
        admin = person "Platform Admin" "Deploys and configures KubeRay operator"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and serving deployments on Kubernetes/OpenShift" {
            rcController = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker pods, services, ingress/routes" "Go (controller-runtime)"
            rjController = container "RayJob Controller" "Reconciles RayJob CRs: creates RayClusters, submits jobs via Dashboard API" "Go (controller-runtime)"
            rsController = container "RayService Controller" "Reconciles RayService CRs: manages Ray Serve deployments with zero-downtime upgrades" "Go (controller-runtime)"
            webhook = container "Validating Webhook" "Validates RayCluster CR creation and updates" "Go Admission Webhook" "Optional"
            batchSchedulerMgr = container "Batch Scheduler Manager" "Integrates with Volcano and Yunikorn for gang scheduling" "Go Plugin"
        }

        k8sApi = softwareSystem "Kubernetes API Server" "Container orchestration control plane" "External"
        openshift = softwareSystem "OpenShift" "OpenShift platform with Route and SCC support" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management for webhooks" "External"
        volcano = softwareSystem "Volcano Scheduler" "Batch/gang scheduling for Ray workloads" "External"
        redis = softwareSystem "Redis" "GCS fault tolerance external storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        rayCluster = softwareSystem "Ray Cluster" "Head and worker pods running Ray distributed framework" "Managed"

        // User interactions
        user -> kuberay "Creates RayCluster/RayJob/RayService CRs" "kubectl / HTTPS 443"
        admin -> kuberay "Deploys operator via RHOAI Operator" "Kustomize"

        // Operator to external systems
        kuberay -> k8sApi "CRD watch, pod/service CRUD, RBAC management" "HTTPS/443 TLS 1.2+"
        kuberay -> rayCluster "Job submission, serve config, health checks" "HTTP/8265, TCP/6379"
        kuberay -> openshift "Creates Routes for Dashboard access" "HTTPS/443 TLS 1.2+"
        kuberay -> certManager "Obtains webhook TLS certificates" "K8s API"
        kuberay -> volcano "Creates PodGroup CRs for gang scheduling" "HTTPS/443 TLS 1.2+"
        rayCluster -> redis "GCS fault tolerance storage" "TCP/6379"

        // Monitoring
        prometheus -> kuberay "Scrapes operator metrics" "HTTP/8080"
        prometheus -> rayCluster "Scrapes Ray cluster metrics" "HTTP/8080"

        // Internal container relationships
        rjController -> rcController "Creates RayCluster for job execution"
        rsController -> rcController "Creates RayCluster for serve deployment"
        rcController -> k8sApi "Creates pods, services, ingress/routes" "HTTPS/443"
        rjController -> rayCluster "Submits jobs via Dashboard REST API" "HTTP/8265"
        rsController -> rayCluster "Deploys serve config via Dashboard" "HTTP/8265"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Managed" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Optional" {
                background #85bbf0
                color #ffffff
                border dashed
            }
        }
    }
}
