// C4 Context Diagram - Data Science Pipelines Tekton
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages ML pipelines, experiments, and runs"

        dspTekton = softwareSystem "Data Science Pipelines Tekton" "Kubeflow Pipelines backend adapted to use Tekton for ML pipeline orchestration" {
            apiServer = container "ds-pipeline (API Server)" "Pipeline CRUD, run management, experiment management" "Go HTTP/gRPC Service" {
                tags "Core"
            }
            persistenceAgent = container "Persistence Agent" "Watches Tekton PipelineRuns/TaskRuns, syncs status to API server" "Go Agent" {
                tags "Core"
            }
            scheduledWorkflow = container "ScheduledWorkflow Controller" "Manages ScheduledWorkflow CRD, creates PipelineRuns on schedule" "Go Controller" {
                tags "Core"
            }
            cacheServer = container "Cache Server" "Mutating admission webhook for task-level caching" "Go Webhook Server" {
                tags "Core"
            }
            ui = container "ds-pipeline-ui" "Web UI for managing pipelines, experiments, runs" "TypeScript/Node.js" {
                tags "Frontend"
            }
            oauthProxy = container "OAuth Proxy" "OpenShift OAuth proxy sidecar for UI authentication" "Sidecar" {
                tags "Security"
            }
            vizServer = container "Visualization Server" "Renders pipeline output visualizations" "Python Service" {
                tags "Core"
            }
            viewerCRD = container "Viewer CRD Controller" "Manages Viewer CRD, creates TensorBoard deployments" "Go Controller" {
                tags "Core"
            }
            mlmdServer = container "ML Metadata Server" "ML Metadata gRPC store" "gRPC Service" {
                tags "Metadata"
            }
            metadataEnvoy = container "Metadata Envoy" "Envoy proxy for MLMD gRPC service" "Envoy Proxy" {
                tags "Metadata"
            }
            metadataWriter = container "Metadata Writer" "Watches Tekton runs, writes execution metadata to MLMD" "Python Agent" {
                tags "Metadata"
            }
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine (PipelineRun/TaskRun CRDs)" "External" {
            tags "External"
        }
        mysql = softwareSystem "MySQL/MariaDB" "Pipeline metadata, cache, and MLMD storage" "External" {
            tags "External"
        }
        minio = softwareSystem "MinIO/S3" "S3-compatible object store for pipeline artifacts" "External" {
            tags "External"
        }
        ocp = softwareSystem "OpenShift Platform" "OAuth, Routes, serving certs" "External" {
            tags "External"
        }
        k8sApi = softwareSystem "Kubernetes API" "CRD operations and RBAC" "External" {
            tags "External"
        }

        odhDashboard = softwareSystem "ODH Dashboard" "Dashboard integration tiles and quickstarts" "Internal RHOAI" {
            tags "Internal"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "Internal RHOAI" {
            tags "Internal"
        }

        // User interactions
        user -> dspTekton "Creates pipelines, runs experiments via UI or API"
        user -> ui "Manages pipelines via web browser" "HTTPS/443"

        // Internal container interactions
        oauthProxy -> ui "Proxies authenticated requests" "HTTP/3000"
        ui -> apiServer "REST API calls" "HTTP/8888"
        apiServer -> mysql "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores/retrieves artifacts" "HTTP/9000"
        apiServer -> k8sApi "Creates PipelineRun, TaskRun CRDs" "HTTPS/443"
        apiServer -> vizServer "Requests visualizations" "HTTP/8888"
        persistenceAgent -> k8sApi "Watches PipelineRun/TaskRun status" "HTTPS/443"
        persistenceAgent -> apiServer "Syncs workflow status" "HTTP/8888"
        scheduledWorkflow -> k8sApi "Watches ScheduledWorkflows, creates PipelineRuns" "HTTPS/443"
        cacheServer -> mysql "Checks/stores cache entries" "MySQL/3306"
        metadataWriter -> k8sApi "Watches PipelineRun/TaskRun events" "HTTPS/443"
        metadataWriter -> metadataEnvoy "Writes execution metadata" "gRPC/9090"
        metadataEnvoy -> mlmdServer "Proxies gRPC requests" "gRPC/8080"
        mlmdServer -> mysql "Stores ML metadata" "MySQL/3306"

        // External interactions
        dspTekton -> tekton "Uses for workflow execution" "Kubernetes API/HTTPS"
        dspTekton -> mysql "Persists metadata and cache" "MySQL/3306"
        dspTekton -> minio "Stores pipeline artifacts" "HTTP/9000"
        ocp -> oauthProxy "Provides OAuth authentication" "HTTPS"
        k8sApi -> cacheServer "Invokes mutating webhook on pod creation" "HTTPS/443"
        odhDashboard -> dspTekton "Integrates via OdhApplication CRs" "N/A"
        prometheus -> apiServer "Scrapes metrics" "HTTP/8888"
    }

    views {
        systemContext dspTekton "SystemContext" {
            include *
            autoLayout
        }

        container dspTekton "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Core" {
                background #4a90e2
                color #ffffff
            }
            element "Frontend" {
                background #4a90e2
                color #ffffff
            }
            element "Security" {
                background #e74c3c
                color #ffffff
            }
            element "Metadata" {
                background #9b59b6
                color #ffffff
            }
        }
    }
}
