// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.19/argo-workflows.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages ML workflow pipelines"

        argoWorkflows = softwareSystem "Argo Workflows" "Kubernetes-native workflow engine for orchestrating containerized ML/data pipeline steps" {
            controller = container "Workflow Controller" "Watches Workflow CRDs, creates/manages pods for workflow steps, handles leader election and GC" "Go Binary (Deployment)"
            server = container "Argo Server" "Provides gRPC + REST API (grpc-gateway on port 2746), serves web UI, handles SSO/auth" "Go Binary (Deployment)"
            executor = container "argoexec" "Executor sidecar injected into workflow step pods; handles artifact upload/download and output capture" "Go Binary (Sidecar)"
            webUI = container "Argo Workflows UI" "Web-based UI for workflow visualization, submission, and management" "React/TypeScript SPA"
        }

        dsp = softwareSystem "Data Science Pipelines" "Creates Workflow CRs to execute pipeline steps" "Internal RHOAI"
        argoEvents = softwareSystem "Argo Events" "Optional event-driven workflow triggering via EventSource/Sensor CRDs" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for pod/resource/CRD management" "External"
        s3 = softwareSystem "S3-compatible Storage" "Artifact repository (S3, Minio, GCS, Azure Blob)" "External"
        postgresql = softwareSystem "PostgreSQL/MySQL" "Optional workflow archive persistence" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication provider" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection system" "External"

        // User interactions
        user -> server "Submits/manages workflows via API or Web UI" "HTTPS/2746"
        server -> webUI "Serves" "HTTP"

        // Internal interactions
        dsp -> argoWorkflows "Creates Workflow CRs" "Kubernetes API"
        argoEvents -> argoWorkflows "Triggers workflows via events" "CRD/API"

        // Controller flows
        controller -> k8sAPI "Watches CRDs, creates pods, manages lifecycle" "HTTPS/443"
        server -> k8sAPI "CRUD operations on CRDs" "HTTPS/443"
        executor -> k8sAPI "Reports pod status and outputs" "HTTPS/443"

        // External service flows
        executor -> s3 "Uploads/downloads artifacts" "HTTPS/443"
        controller -> postgresql "Archives workflow records" "TCP/5432 or 3306"
        server -> postgresql "Queries archived workflows" "TCP/5432 or 3306"
        server -> oidcProvider "SSO token validation" "HTTPS/443"
        prometheus -> controller "Scrapes metrics" "HTTP/9090"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
