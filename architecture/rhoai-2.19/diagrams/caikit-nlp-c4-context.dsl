/*
 * C4 Context Diagram for caikit-nlp
 * Generated by: Claude Opus 4.6
 *
 * View with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   Or: https://structurizr.com/dsl
 */

workspace {

    model {
        datascientist = person "Data Scientist" "Deploys and queries NLP models for inference and fine-tuning"
        mlEngineer = person "ML Engineer" "Configures model serving infrastructure and runtime settings"

        caikitNlp = softwareSystem "caikit-nlp" "Python NLP library providing text generation, embeddings, reranking, classification via Caikit framework" {
            httpServer = container "HTTP Server" "REST API serving NLP tasks on port 8080" "Python / Caikit Runtime" "Server"
            grpcServer = container "gRPC Server" "gRPC API serving NLP tasks on port 8085" "Python / Caikit Runtime" "Server"
            textGenModule = container "TextGeneration Module" "Local text generation via HuggingFace Transformers" "Python Module"
            textGenTGISModule = container "TextGenerationTGIS Module" "Remote text generation via TGIS backend" "Python Module"
            embeddingModule = container "Embedding Module" "Text embeddings and reranking via sentence-transformers" "Python Module"
            peftModule = container "PEFT Module" "Parameter-efficient fine-tuning (prompt tuning, MPT)" "Python Module"
            classificationModule = container "Classification Module" "Sequence and token classification" "Python Module"
            tgisAutoFinder = container "TGISAutoFinder" "Auto-discovers TGIS-backed models" "Python Module"
            modelResources = container "Model Resources" "HuggingFace pretrained model wrappers" "Python Module"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server for large language model inference" "External"
        kserve = softwareSystem "KServe / ModelMesh" "Model serving infrastructure that deploys and manages runtime containers" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model artifact repository for downloading pre-trained models" "External"
        modelStorage = softwareSystem "Model Storage" "PVC or S3-based storage for model artifacts" "External"
        caikitFramework = softwareSystem "Caikit Framework" "Core AI framework providing runtime, module system, and data models" "External"

        # User interactions
        datascientist -> caikitNlp "Sends inference requests (text generation, embedding, rerank)" "HTTP/8080, gRPC/8085"
        mlEngineer -> kserve "Configures model serving" "Kubernetes API"

        # Platform interactions
        kserve -> caikitNlp "Deploys and manages runtime containers" "Container Lifecycle"

        # Internal container interactions
        httpServer -> textGenModule "Routes text generation requests" "In-process"
        httpServer -> embeddingModule "Routes embedding requests" "In-process"
        httpServer -> classificationModule "Routes classification requests" "In-process"
        grpcServer -> textGenTGISModule "Routes remote text generation" "In-process"
        grpcServer -> embeddingModule "Routes embedding requests" "In-process"
        grpcServer -> peftModule "Routes training requests" "In-process"
        textGenModule -> modelResources "Loads HF models" "In-process"
        textGenTGISModule -> tgisAutoFinder "Discovers TGIS models" "In-process"
        peftModule -> modelResources "Loads base models for tuning" "In-process"

        # External interactions
        caikitNlp -> tgis "Remote text generation inference" "gRPC/8033-8034, TLS/mTLS"
        caikitNlp -> huggingfaceHub "Downloads model artifacts" "HTTPS/443, TLS 1.2+"
        caikitNlp -> modelStorage "Loads and saves model artifacts" "Filesystem / Volume Mount"
        caikitNlp -> caikitFramework "Uses runtime, module system, data models" "Python API (in-process)"
    }

    views {
        systemContext caikitNlp "SystemContext" {
            include *
            autoLayout
        }

        container caikitNlp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Server" {
                shape RoundedBox
                background #f5a623
                color #ffffff
            }
        }
    }

}
