graph TD
    subgraph PlatformRBAC["Platform-Managed RBAC (KServe / ModelMesh)"]
        direction TB
        PlatformSA["Platform Service Account<br/>(managed by KServe/ModelMesh)"]
        PlatformCRB["Platform ClusterRoleBinding"]
        PlatformCR["Platform ClusterRole<br/>(manages pod lifecycle)"]

        PlatformSA -->|"bound via"| PlatformCRB
        PlatformCRB -->|"grants"| PlatformCR
    end

    subgraph RuntimeSecurity["caikit-nlp Runtime Security Model"]
        direction TB

        subgraph Container["Container Security"]
            RuntimeUser["Runtime User<br/>caikit (UID 1001, GID 0)"]
            BaseImage["Base Image<br/>ubi9/ubi-minimal:latest"]
        end

        subgraph TransportSecurity["Transport Security"]
            HTTPAuth["HTTP Server (8080/TCP)<br/>Auth: None (platform-delegated)<br/>Encryption: TLS (configurable)"]
            GRPCAuth["gRPC Server (8085/TCP)<br/>Auth: Certificate-based<br/>Encryption: mTLS (configurable)"]
        end

        subgraph TLSSecrets["TLS Secrets (Environment Variables)"]
            ServerKey["RUNTIME_TLS_SERVER_KEY<br/>Server TLS private key<br/>Provisioned by: Platform / cert-manager"]
            ServerCert["RUNTIME_TLS_SERVER_CERT<br/>Server TLS certificate<br/>Provisioned by: Platform / cert-manager"]
            ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>Client cert for mTLS verification<br/>Provisioned by: Platform / cert-manager"]
        end

        subgraph TGISSecrets["TGIS Connection Secrets"]
            CACert["TGIS ca_cert_file<br/>CA cert for TLS verification"]
            TGISClientCert["TGIS client_cert_file<br/>Client cert for mTLS"]
            TGISClientKey["TGIS client_key_file<br/>Client key for mTLS"]
        end
    end

    subgraph AuthFlow["Authentication Flow"]
        ExternalClient["External Client"] -->|"Platform Auth<br/>(KServe managed)"| PlatformGW["KServe Gateway"]
        PlatformGW -->|"TLS"| HTTPAuth
        PlatformGW -->|"mTLS"| GRPCAuth
    end

    %% Connections
    PlatformCR -->|"manages pods running"| Container
    ServerKey -->|"configures"| HTTPAuth
    ServerCert -->|"configures"| HTTPAuth
    ServerKey -->|"configures"| GRPCAuth
    ServerCert -->|"configures"| GRPCAuth
    ClientCert -->|"configures"| GRPCAuth

    %% Styling
    style PlatformRBAC fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style RuntimeSecurity fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Container fill:#e1d5e7,stroke:#9673a6
    style TransportSecurity fill:#dae8fc,stroke:#6c8ebf
    style TLSSecrets fill:#fff2cc,stroke:#d6b656
    style TGISSecrets fill:#f8cecc,stroke:#b85450
    style AuthFlow fill:#f5f5f5,stroke:#999

    style PlatformSA fill:#4a90e2,stroke:#333,color:#fff
    style PlatformCR fill:#f5a623,stroke:#333,color:#fff
    style RuntimeUser fill:#7ed321,stroke:#333,color:#fff
    style ExternalClient fill:#f5f5f5,stroke:#999
    style PlatformGW fill:#ffe6cc,stroke:#d79b00
