graph TD
    subgraph "Service Accounts"
        SA["codeflare-operator-controller-manager<br/>Namespace: operator-namespace"]
        RaySA["raycluster-oauth-proxy<br/>Namespace: raycluster-namespace<br/>Per RayCluster"]
    end

    subgraph "ClusterRole Bindings"
        CRB[codeflare-operator-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings Namespaced"
        LeaderRB["codeflare-operator-leader-election-rolebinding<br/>Namespace: operator-namespace"]
    end

    subgraph "ClusterRole: codeflare-operator-manager-role"
        direction TB

        subgraph CoreResources["Core Resources - api group empty"]
            CorePerms["pods, services, secrets,<br/>serviceaccounts, events, nodes<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph AppsResources["Apps Resources - api group apps"]
            AppsPerms["deployments, statefulsets<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph BatchResources["Batch Resources - api group batch"]
            BatchPerms["jobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RayCRDs["Ray CRDs - api group ray.io"]
            RayPerms["rayclusters, rayclusters-status,<br/>rayclusters-finalizers, rayjobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph CodeFlareCRDs["CodeFlare CRDs - workload.codeflare.dev"]
            CFPerms["appwrappers, appwrappers-status,<br/>appwrappers-finalizers<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph KueueCRDs["Kueue CRDs - kueue.x-k8s.io"]
            KueuePerms["workloads, workloads-status,<br/>workloads-finalizers,<br/>resourceflavors,<br/>workloadpriorityclasses<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph NetworkResources["Network Resources - networking.k8s.io"]
            NetPerms["ingresses, networkpolicies<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RouteResources["Route Resources - route.openshift.io"]
            RoutePerms["routes, routes-custom-host<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RBACResources["RBAC Resources - rbac.authorization.k8s.io"]
            RBACPerms["clusterrolebindings<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph WebhookResources["Webhook Resources - admissionregistration.k8s.io"]
            WebhookPerms["mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations<br/>Verbs: get, list, watch, update"]
        end

        subgraph CRDResources["CRD Resources - apiextensions.k8s.io"]
            CRDPerms["customresourcedefinitions<br/>Verbs: get, list, watch"]
        end

        subgraph AuthResources["Auth Resources"]
            AuthPerms["tokenreviews - authentication.k8s.io: create<br/>subjectaccessreviews - authorization.k8s.io: create"]
        end

        subgraph OpenShiftResources["OpenShift Resources - config.openshift.io"]
            OCPPerms["ingresses<br/>Verbs: get"]
        end

        subgraph ODHResources["ODH Resources - dscinitialization.opendatahub.io"]
            ODHPerms["dscinitializations<br/>Verbs: get, list, watch"]
        end

        subgraph KubeflowResources["Kubeflow Resources - kubeflow.org"]
            KFPerms["pytorchjobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph SchedulingResources["Scheduling Resources"]
            SchedPerms["priorityclasses - scheduling.k8s.io: get, list, watch<br/>podgroups - scheduling.sigs.k8s.io,<br/>scheduling.x-k8s.io:<br/>get, list, watch, create, update, patch, delete"]
        end
    end

    subgraph "Role: codeflare-operator-leader-election-role"
        LeaderPerms["configmaps, leases<br/>coordination.k8s.io<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph "API Resources"
        direction LR
        K8sCore[Core API<br/>pods, services, secrets]
        K8sApps[Apps API<br/>deployments, statefulsets]
        RayCR[RayCluster CRD<br/>ray.io-v1]
        AppWrapperCR[AppWrapper CRD<br/>workload.codeflare.dev-v1beta2]
        KueueCR[Kueue Workload CRD<br/>kueue.x-k8s.io]
        Ingress["Ingress and Route API<br/>networking.k8s.io,<br/>route.openshift.io"]
        Webhooks[Webhook Configs<br/>admissionregistration.k8s.io]
        OAuthProxy[OAuth Proxy SA<br/>Per RayCluster]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderRB
    CRB -->|grants| CorePerms
    CRB -->|grants| AppsPerms
    CRB -->|grants| BatchPerms
    CRB -->|grants| RayPerms
    CRB -->|grants| CFPerms
    CRB -->|grants| KueuePerms
    CRB -->|grants| NetPerms
    CRB -->|grants| RoutePerms
    CRB -->|grants| RBACPerms
    CRB -->|grants| WebhookPerms
    CRB -->|grants| CRDPerms
    CRB -->|grants| AuthPerms
    CRB -->|grants| OCPPerms
    CRB -->|grants| ODHPerms
    CRB -->|grants| KFPerms
    CRB -->|grants| SchedPerms

    LeaderRB -->|grants| LeaderPerms

    %% Permissions to resources
    CorePerms -.->|allows CRUD| K8sCore
    AppsPerms -.->|allows CRUD| K8sApps
    RayPerms -.->|allows CRUD| RayCR
    CFPerms -.->|allows CRUD| AppWrapperCR
    KueuePerms -.->|allows CRUD| KueueCR
    NetPerms -.->|allows CRUD| Ingress
    RoutePerms -.->|allows CRUD| Ingress
    WebhookPerms -.->|allows watch-update| Webhooks
    RBACPerms -.->|allows CRUD| OAuthProxy

    %% Ray OAuth SA created by operator
    SA -->|creates| RaySA
    RaySA -.->|OpenShift OAuth<br/>token validation| OAuthProxy

