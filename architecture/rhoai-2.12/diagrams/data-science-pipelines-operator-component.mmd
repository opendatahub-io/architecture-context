graph TB
    subgraph "Data Science Pipelines Operator"
        ControllerManager[Controller Manager<br/>Reconciles DSPA CRs]
    end

    subgraph "DSPA Instance Components (per namespace)"
        APIServer[DS Pipelines API Server<br/>8888/TCP HTTP, 8887/TCP gRPC<br/>8443/TCP HTTPS via OAuth]
        PersistenceAgent[Persistence Agent<br/>Syncs workflow state]
        ScheduledWorkflow[Scheduled Workflow Controller<br/>Manages scheduled runs]

        subgraph "Optional Components"
            MariaDB[(MariaDB<br/>3306/TCP<br/>Pipeline metadata)]
            Minio[(Minio<br/>9000/TCP<br/>Artifact storage)]
            UI[ML Pipelines UI<br/>8443/TCP HTTPS via OAuth]
            MLMDGrpc[ML Metadata gRPC<br/>Variable/TCP]
            MLMDEnvoy[ML Metadata Envoy<br/>9090/TCP gRPC<br/>8443/TCP HTTPS via OAuth]
        end
    end

    subgraph "Custom Resources"
        DSPACR[DataSciencePipelinesApplication CR<br/>v1alpha1]
        ScheduledWorkflowCR[ScheduledWorkflow CR<br/>Secondary CRD]
    end

    subgraph "Workflow Engines"
        ArgoWorkflows[Argo Workflows<br/>v2 pipelines]
        Tekton[OpenShift Pipelines/Tekton<br/>v1 pipelines - deprecated]
    end

    subgraph "External Dependencies"
        ExternalS3[External S3 Storage<br/>443/TCP HTTPS]
        ExternalDB[External MySQL/MariaDB<br/>3306/TCP]
        OAuth[OpenShift OAuth<br/>Authentication]
        ServiceCA[Service CA Operator<br/>TLS Certificates]
    end

    subgraph "ODH Integration"
        Dashboard[ODH Dashboard<br/>UI Integration]
        DSCluster[DataScienceCluster CR<br/>Platform Management]
    end

    User[User/SDK] -->|creates| DSPACR
    DSPACR -->|watched by| ControllerManager
    ControllerManager -->|deploys| APIServer
    ControllerManager -->|deploys| PersistenceAgent
    ControllerManager -->|deploys| ScheduledWorkflow
    ControllerManager -->|conditionally deploys| MariaDB
    ControllerManager -->|conditionally deploys| Minio
    ControllerManager -->|conditionally deploys| UI
    ControllerManager -->|conditionally deploys| MLMDGrpc
    ControllerManager -->|conditionally deploys| MLMDEnvoy

    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|or uses| ExternalS3
    APIServer -->|or uses| ExternalDB
    APIServer -->|creates workflows| ArgoWorkflows
    APIServer -->|creates pipelines| Tekton

    PersistenceAgent -->|syncs state to| MariaDB
    ScheduledWorkflow -->|creates| ScheduledWorkflowCR

    UI -->|calls| APIServer
    MLMDGrpc -->|stores metadata| MariaDB
    MLMDEnvoy -->|proxies to| MLMDGrpc

    APIServer -->|protected by| OAuth
    UI -->|protected by| OAuth
    MLMDEnvoy -->|protected by| OAuth

    ControllerManager -->|provisions TLS| ServiceCA
    Dashboard -->|integrates| UI
    DSCluster -->|manages| ControllerManager

    style ControllerManager fill:#4a90e2
    style APIServer fill:#4a90e2
    style PersistenceAgent fill:#4a90e2
    style ScheduledWorkflow fill:#4a90e2
    style DSPACR fill:#f5a623
    style ScheduledWorkflowCR fill:#f5a623
    style MariaDB fill:#7ed321
    style Minio fill:#7ed321
    style UI fill:#7ed321
    style MLMDGrpc fill:#7ed321
    style MLMDEnvoy fill:#7ed321
    style ArgoWorkflows fill:#e8e8e8
    style Tekton fill:#e8e8e8
    style ExternalS3 fill:#e8e8e8
    style ExternalDB fill:#e8e8e8
    style OAuth fill:#e8e8e8
    style ServiceCA fill:#e8e8e8
    style Dashboard fill:#7ed321
    style DSCluster fill:#7ed321
