graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: operator-namespace]
    end

    subgraph "Cluster-Level Permissions"
        direction TB
        CRB1[ClusterRoleBinding:<br/>odh-dashboard]
        CRB2[ClusterRoleBinding:<br/>odh-dashboard-auth-delegator]
        CRB3[ClusterRoleBinding:<br/>odh-dashboard-image-puller]

        CR1[ClusterRole:<br/>odh-dashboard]
        CR2[ClusterRole:<br/>system:auth-delegator]
        CR3[ClusterRole:<br/>system:image-puller]
    end

    subgraph "Namespace-Level Permissions"
        direction TB
        RB1[RoleBinding:<br/>odh-dashboard<br/>operator-namespace]
        RB2[RoleBinding:<br/>odh-dashboard-cluster-monitoring-view<br/>openshift-monitoring]

        R1[Role:<br/>odh-dashboard]
        R2[ClusterRole:<br/>cluster-monitoring-view]
    end

    subgraph "Cluster Resources (ClusterRole: odh-dashboard)"
        direction LR
        subgraph CR1_Resources["API Resources"]
            Nodes[nodes<br/>get, list]
            Machines[machineautoscalers, machinesets<br/>get, list]
            ClusterVer[clusterversions<br/>get, watch, list]
            CSV[clusterserviceversices, subscriptions<br/>get, list, watch]
            ConfigMaps[configmaps, pvcs, secrets<br/>create, delete, get, list, patch, update, watch]
            Routes[routes<br/>get, list, watch]
            ConsoleLinks[consolelinks<br/>get, list, watch]
            Users[groups, users<br/>get, list, watch]
            Core[pods, serviceaccounts, services<br/>get, list, watch]
            Namespaces[namespaces<br/>get, list, watch, create, update, patch, delete]
            RBAC[rolebindings, clusterrolebindings, roles<br/>get, list, watch, create, update, patch, delete]
            Events[events<br/>get, list, watch]
            Notebooks[notebooks kubeflow.org<br/>get, list, watch, create, update, patch, delete]
            DSC[datascienceclusters<br/>list, watch, get]
            DSCI[dscinitializations<br/>list, watch, get]
            MR[modelregistries<br/>get, list, watch, create, update, patch, delete]
        end
    end

    subgraph "Namespace Resources (Role: odh-dashboard)"
        direction LR
        subgraph R1_Resources["API Resources"]
            AccelProfiles[acceleratorprofiles<br/>create, get, list, update, patch, delete]
            NsRoutes[routes<br/>get, list, watch]
            KfDefs[kfdefs<br/>get, list, watch]
            Jobs[cronjobs, jobs<br/>create, delete, get, list, patch, update, watch]
            ImageStreams[imagestreams<br/>create, get, list, update, patch, delete]
            Builds[builds, buildconfigs<br/>get, list, watch, create, patch, delete]
            Deployments[deployments<br/>patch, update]
            DeploymentConfigs[deploymentconfigs<br/>get, list, watch, create, update, patch, delete]
            DashboardConfigs[odhdashboardconfigs<br/>get, list, watch, create, update, patch, delete]
            NsNotebooks[notebooks<br/>get, list, watch, create, update, patch, delete]
            OdhApps[odhapplications, odhdocuments<br/>get, list]
            QuickStarts[odhquickstarts<br/>get, list]
            Templates[templates<br/>all verbs]
            ServingRuntimes[servingruntimes<br/>all verbs]
        end
    end

    subgraph "Additional Namespace Roles"
        direction TB
        R3[Role:<br/>odh-dashboard-model-serving-role]
        R4[Role:<br/>odh-dashboard-fetch-accelerators]
        R5[Role:<br/>odh-dashboard-fetch-builds-images]

        InferenceServices[inferenceservices<br/>create, delete, deletecollection, get, list, patch, update, watch]
        ServingRuntimesRead[servingruntimes, clusterservingruntimes<br/>get, list, watch]
        AccelRead[acceleratorprofiles<br/>get, list, watch]
        BuildsRead[imagestreams, buildconfigs, builds<br/>get, list, watch]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    SA -->|bound via| RB2

    %% ClusterRoleBindings to ClusterRoles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% RoleBindings to Roles
    RB1 -->|grants| R1
    RB2 -->|grants| R2

    %% ClusterRole to Resources
    CR1 -.->|accesses| CR1_Resources

    %% Role to Resources
    R1 -.->|accesses| R1_Resources

    %% Additional Roles to Resources
    R3 -.->|accesses| InferenceServices
    R3 -.->|accesses| ServingRuntimesRead
    R4 -.->|accesses| AccelRead
    R5 -.->|accesses| BuildsRead

    %% Special Permissions
    CR2 -.->|enables| TokenReview[Token Validation<br/>subjectaccessreviews.create]
    CR3 -.->|enables| ImagePull[Image Pulling<br/>secrets.get]
    R2 -.->|enables| MetricsQuery[Prometheus Metrics<br/>Query thanos-querier]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R4 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style R5 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CRB1 fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style CRB3 fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style RB1 fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style RB2 fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
