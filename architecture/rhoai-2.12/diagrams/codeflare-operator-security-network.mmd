graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser[User Browser]
        User[User<br/>kubectl/oc]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressRoute["Ingress/Route<br/>Ray Dashboard<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge/Passthrough"]
    end

    subgraph RayClusterNamespace["NAMESPACE: {raycluster-namespace}"]
        direction TB

        subgraph RayHeadPod["Ray Head Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>OAuth validation"]
            Dashboard["Ray Dashboard<br/>8080/TCP HTTP<br/>localhost only"]
            RayHead["Ray Head Process<br/>6379/TCP, 10001/TCP<br/>mTLS enabled"]
        end

        subgraph RayWorkerPods["Ray Worker Pods"]
            RayWorker["Ray Worker Process<br/>10001/TCP<br/>mTLS enabled"]
        end

        HeadService["Service: {raycluster}-head-svc<br/>ClusterIP<br/>443/TCP → 8443"]

        OAuthProxy -->|8080/TCP HTTP<br/>localhost| Dashboard
        RayHead <-->|6379/TCP, 10001/TCP<br/>mTLS TLS 1.2+<br/>Client cert auth| RayWorker
    end

    subgraph OperatorNamespace["NAMESPACE: {operator-namespace}"]
        direction TB

        subgraph OperatorPod["CodeFlare Operator Manager Pod<br/>SA: codeflare-operator-controller-manager"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No auth"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        WebhookService["Service: codeflare-operator-webhook-service<br/>ClusterIP<br/>443/TCP → 9443"]
        MetricsService["Service: codeflare-operator-manager-metrics<br/>ClusterIP<br/>8080/TCP"]
    end

    subgraph ControlPlane["CONTROL PLANE (Cluster-scoped)"]
        direction TB
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>User + SA token auth"]
        OpenShiftOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>OAuth client auth"]
        OpenShiftAPI["OpenShift API<br/>config.openshift.io<br/>443/TCP HTTPS<br/>SA token auth"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES (Cluster-scoped)"]
        direction TB
        KubeRay["KubeRay Operator<br/>RayCluster CRD manager<br/>Required"]
        Kueue["Kueue<br/>Workload queue mgmt<br/>Optional"]
        CertManager["cert-manager /<br/>OCP cert-controller<br/>Webhook cert provisioning<br/>Required"]
        Prometheus["Prometheus<br/>Metrics scraping<br/>Optional"]
    end

    %% External to Ingress
    Browser -->|HTTPS/443<br/>TLS 1.2+<br/>No auth<br/>OAuth redirect| IngressRoute
    User -->|HTTPS/443<br/>TLS 1.2+<br/>User credentials| APIServer

    %% Ingress to Application
    IngressRoute -->|HTTPS/8443<br/>TLS 1.2+<br/>No auth| HeadService
    HeadService -->|HTTPS/8443| OAuthProxy

    %% OAuth flow
    OAuthProxy -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth client creds| OpenShiftOAuth

    %% Operator to Control Plane
    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>SA token| APIServer
    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>SA token| OpenShiftAPI

    %% API Server to Webhook
    APIServer -->|HTTPS/443<br/>TLS 1.2+ mTLS<br/>API Server cert| WebhookService
    WebhookService -->|HTTPS/9443<br/>mTLS| Webhook

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No auth<br/>/metrics| MetricsService
    MetricsService -->|HTTP/8080| Metrics

    %% Dependencies
    KubeRay -->|Manages<br/>RayCluster CRD| APIServer
    Kueue -->|Manages<br/>Workload CRD| APIServer
    CertManager -->|Provisions<br/>webhook certs| OperatorPod

    %% Network Policies
    RayHeadPod -.->|NetworkPolicy<br/>Ingress: 8443, 8080/TCP| IngressRoute
    RayWorker -.->|NetworkPolicy<br/>Egress: All to head| RayHead

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externaldep fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Browser,User external
    class IngressRoute ingress
    class RayHeadPod,RayWorkerPods,HeadService,OAuthProxy,Dashboard,RayHead,RayWorker application
    class OperatorPod,Webhook,Metrics,Health,WebhookService,MetricsService operator
    class APIServer,OpenShiftOAuth,OpenShiftAPI controlplane
    class KubeRay,Kueue,CertManager,Prometheus externaldep
