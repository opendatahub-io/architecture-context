graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist /<br/>External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Router["OpenShift Router<br/>443/TCP → varies<br/>TLS 1.2+ Reencrypt/Edge"]
        Gateway["Istio Ingress Gateway<br/>knative-ingress-gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.3 → mTLS"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio - mTLS PERMISSIVE/STRICT)"]
        direction TB

        subgraph NS_Platform["Namespace: redhat-ods-applications"]
            direction TB
            Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>8443/TCP HTTPS<br/>OAuth Proxy"]
            DSPOp["DS Pipelines API<br/>8888/TCP HTTP<br/>8443/TCP HTTPS (Route)"]
            KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager<br/>Webhook: 9443/TCP HTTPS<br/>Metrics: 8080/TCP HTTP"]
            ModelCtrl["ODH Model Controller<br/>SA: odh-model-controller<br/>Creates Routes/VirtualServices"]
        end

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>8012/TCP HTTP<br/>mTLS in mesh"]
        end

        subgraph NS_User["Namespace: {user-namespace} (Data Science Project)"]
            direction TB

            Notebook["Notebook Workbench<br/>SA: {notebook}-sa<br/>8888/TCP HTTP (JupyterLab)<br/>8443/TCP HTTPS (OAuth Proxy)<br/>NetworkPolicy: Egress S3/PyPI/Git"]

            Predictor["KServe Predictor Pod<br/>SA: {inferenceservice}-sa<br/>8080/TCP HTTP inference<br/>9000/TCP gRPC inference<br/>mTLS STRICT mode<br/>Storage Init: S3/GCS/Azure"]

            TrainingPods["PyTorchJob Training Pods<br/>SA: default-editor<br/>Master: 23456/TCP<br/>Workers: TCP (plaintext)<br/>Egress: S3 HTTPS"]

            RayPods["RayCluster Pods<br/>Head: GCS 6379/TCP, Dashboard 8265/TCP<br/>Workers: mTLS to head<br/>OAuth Proxy: 8443/TCP"]

            TrustyAI["TrustyAI Service<br/>SA: {trustyai}-sa<br/>8080/TCP HTTP API<br/>8443/TCP HTTPS (OAuth Proxy)<br/>Storage: PVC or DB"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Keys"]

        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account JSON"]

        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Account Keys / SAS"]

        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS"]

        Registries["Container Registries<br/>registry.redhat.io, quay.io<br/>443/TCP HTTPS<br/>Pull Secrets"]

        Git["Git Services<br/>github.com, gitlab.com<br/>443/TCP HTTPS/SSH<br/>SSH Keys / PAT"]

        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc:443<br/>TLS 1.2+<br/>ServiceAccount Tokens"]

        ExtDB["External Databases<br/>MariaDB: 3306/TCP<br/>PostgreSQL: 5432/TCP<br/>TLS optional"]
    end

    subgraph Infrastructure["PLATFORM INFRASTRUCTURE"]
        direction LR
        Istio["Istio Control Plane<br/>Maistra/Istio 1.19+<br/>Namespace: istio-system<br/>SPIFFE certs"]
        Knative["Knative Serving<br/>Serverless platform<br/>Namespace: knative-serving"]
        OAuth["OpenShift OAuth<br/>Bearer Token (JWT)<br/>TokenReview + SAR"]
        Prometheus["Prometheus Stack<br/>9091/TCP HTTPS<br/>Namespace: redhat-ods-monitoring"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token| Router
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer/Anonymous| Gateway

    %% Ingress to Service Mesh
    Router -->|HTTPS/8443<br/>OAuth Token| Dashboard
    Router -->|HTTPS/8443<br/>OAuth Token| Notebook
    Router -->|HTTPS/8443<br/>OAuth Token| RayPods
    Router -->|HTTPS/8443<br/>OAuth Token| TrustyAI
    Router -->|HTTP/8888<br/>mTLS| DSPOp

    Gateway -->|mTLS STRICT<br/>Service Identity| Activator
    Activator -->|mTLS<br/>8080/TCP| Predictor

    %% Dashboard proxying
    Dashboard -->|HTTP/8888<br/>Internal| DSPOp
    Dashboard -->|HTTP/8080<br/>Internal| TrustyAI
    Dashboard -->|Kubernetes API<br/>HTTPS/6443| K8sAPI

    %% KServe flows
    KServeCtrl -->|Kubernetes API<br/>HTTPS/6443| K8sAPI
    KServeCtrl -->|Creates| Predictor
    ModelCtrl -->|Watches InferenceService| KServeCtrl
    ModelCtrl -->|Creates Routes| Router
    ModelCtrl -->|Creates VirtualServices| Gateway

    %% Workbench flows
    Notebook -->|HTTPS/443<br/>AWS SDK| S3
    Notebook -->|HTTPS/443| PyPI
    Notebook -->|HTTPS/443<br/>SSH| Git

    %% Predictor flows
    Predictor -->|HTTPS/443<br/>AWS IAM/Keys| S3
    Predictor -->|HTTPS/443<br/>Service Account| GCS
    Predictor -->|HTTPS/443<br/>Account Keys| Azure
    Predictor -->|HTTPS mTLS| TrustyAI

    %% Training flows
    TrainingPods -->|TCP plaintext<br/>Inter-worker comm| TrainingPods
    TrainingPods -->|HTTPS/443<br/>AWS SDK| S3

    %% Ray flows
    RayPods -->|mTLS<br/>6379/TCP GCS| RayPods
    RayPods -->|TCP/10001<br/>Ray client| RayPods

    %% TrustyAI flows
    TrustyAI -->|Filesystem or<br/>PostgreSQL/MySQL| ExtDB
    TrustyAI -->|HTTP/8080<br/>/metrics| Prometheus

    %% Infrastructure dependencies
    KServeCtrl -->|Depends on| Knative
    KServeCtrl -->|Depends on| Istio
    Predictor -->|mTLS via| Istio
    Dashboard -->|Authenticates via| OAuth
    Notebook -->|OAuth Proxy| OAuth
    RayPods -->|OAuth Proxy| OAuth
    TrustyAI -->|OAuth Proxy| OAuth

    %% Operators to K8s API
    KServeCtrl -->|ServiceAccount Token<br/>HTTPS/6443| K8sAPI
    ModelCtrl -->|ServiceAccount Token<br/>HTTPS/6443| K8sAPI
    DSPOp -->|ServiceAccount Token<br/>HTTPS/6443| K8sAPI

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>ServiceMonitor<br/>Scrape /metrics| KServeCtrl
    Prometheus -->|HTTP/8080<br/>ServiceMonitor| Predictor
    Prometheus -->|HTTP/8080<br/>ServiceMonitor| TrustyAI

    %% Container image pulls
    Notebook -->|HTTPS/443<br/>Image Pull Secrets| Registries
    Predictor -->|HTTPS/443<br/>Image Pull Secrets| Registries

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infrastructure fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Router,Gateway ingress
    class Dashboard,DSPOp,KServeCtrl,ModelCtrl,Activator,Notebook,Predictor,TrainingPods,RayPods,TrustyAI servicemesh
    class S3,GCS,Azure,PyPI,Registries,Git,K8sAPI,ExtDB externalservice
    class Istio,Knative,OAuth,Prometheus infrastructure
