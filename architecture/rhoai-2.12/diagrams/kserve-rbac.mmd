graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kserve-manager-rolebinding<br/>Namespace: kserve]
        CRB2[kserve-leader-election-rolebinding<br/>Namespace: kserve]
        CRB3[kserve-proxy-rolebinding<br/>Namespace: kserve]
    end

    subgraph "ClusterRoles"
        CR1[kserve-manager-role<br/>Primary Controller Role]
        CR2[kserve-leader-election-role<br/>Leader Election]
        CR3[kserve-proxy-role<br/>Proxy Access]
    end

    subgraph "KServe CRDs - serving.kserve.io"
        IS[InferenceService<br/>inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status]
        SR[ServingRuntime<br/>servingruntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status]
        CSR[ClusterServingRuntime<br/>clusterservingruntimes<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status]
        CSC[ClusterStorageContainer<br/>clusterstoragecontainers]
        IG[InferenceGraph<br/>inferencegraphs<br/>inferencegraphs/finalizers<br/>inferencegraphs/status]
        TM[TrainedModel<br/>trainedmodels<br/>trainedmodels/status]
    end

    subgraph "Knative CRDs - serving.knative.dev"
        KS[Knative Service<br/>services<br/>services/finalizers<br/>services/status]
    end

    subgraph "Istio CRDs - networking.istio.io"
        VS[VirtualService<br/>virtualservices<br/>virtualservices/finalizers<br/>virtualservices/status]
    end

    subgraph "Core Kubernetes Resources"
        Deploy[Deployments<br/>apps]
        HPA[HorizontalPodAutoscalers<br/>autoscaling]
        Svc[Services<br/>core]
        Secrets[Secrets<br/>core]
        CM[ConfigMaps<br/>core]
        Events[Events<br/>core]
        NS[Namespaces<br/>core<br/>read-only: get, list, watch]
        Pods[Pods<br/>core<br/>read-only: get, list, watch]
        Ingress[Ingresses<br/>networking.k8s.io]
    end

    subgraph "Webhook Configurations"
        MWC[MutatingWebhookConfigurations<br/>admissionregistration.k8s.io]
        VWC[ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io]
    end

    subgraph "Leader Election Resources"
        LECM[ConfigMaps for Leader Election<br/>core<br/>verbs: create, get, update]
        LEEvents[Events for Leader Election<br/>core<br/>verbs: create]
        Leases[Leases<br/>coordination.k8s.io<br/>verbs: create, get, update]
    end

    %% Service Account to ClusterRoleBindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% ClusterRoleBindings to ClusterRoles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% kserve-manager-role permissions (CR1)
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| IS
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| SR
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| CSR
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| CSC
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| IG
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| TM

    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KS
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| VS

    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Deploy
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| HPA
    CR1 -->|create, delete, get, list,<br/>patch, update| Svc
    CR1 -->|create, delete, get, list,<br/>patch, update| Secrets
    CR1 -->|create, delete, get, list,<br/>patch, update| CM
    CR1 -->|get, list, watch| NS
    CR1 -->|get, list, watch| Pods
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Ingress
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| MWC
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| VWC

    %% kserve-leader-election-role permissions (CR2)
    CR2 -->|create, get, update| LECM
    CR2 -->|create| LEEvents
    CR2 -->|create, get, update| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style CRB2 fill:#50e3c2,stroke:#333,stroke-width:2px
    style CRB3 fill:#50e3c2,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:3px,color:#fff
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff

    style IS fill:#7ed321,stroke:#333,stroke-width:2px
    style SR fill:#7ed321,stroke:#333,stroke-width:2px
    style CSR fill:#7ed321,stroke:#333,stroke-width:2px
