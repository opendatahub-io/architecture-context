    style HPA fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Svc fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Secrets fill:#e8e8e8,stroke:#333,stroke-width:2px
    style CM fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Events fill:#e8e8e8,stroke:#333,stroke-width:2px
    style NS fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Pods fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Ingress fill:#e8e8e8,stroke:#333,stroke-width:2px

