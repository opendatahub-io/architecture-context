graph TB
    subgraph "KubeRay Operator"
        Operator[kuberay-operator]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        Webhook[Validating Webhook]

        Operator -->|manages| RayClusterCtrl
        Operator -->|manages| RayJobCtrl
        Operator -->|manages| RayServiceCtrl
        Operator -->|validates| Webhook
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Resources (Created by Operator)"
        HeadPod[Ray Head Pod<br/>GCS + Dashboard + Client]
        WorkerPods[Ray Worker Pods]
        HeadService[Head Service<br/>ClusterIP: 6379, 8265, 10001, 8080]
        ServeService[Serve Service<br/>ClusterIP: 8000]
        HeadlessService[Headless Worker Service]
        MetricsService[Metrics Service<br/>ClusterIP: 8080]

        HeadPod -->|coordinates| WorkerPods
        HeadService -->|routes to| HeadPod
        ServeService -->|routes to| HeadPod
        ServeService -->|routes to| WorkerPods
        HeadlessService -->|routes to| WorkerPods
        MetricsService -->|routes to| Operator
    end

    subgraph "Optional Components"
        Autoscaler[Ray Autoscaler<br/>Sidecar in Head Pod]
        VolcanoScheduler[Volcano Scheduler<br/>Gang Scheduling]
        CertManager[cert-manager<br/>TLS Certificates]
    end

    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadService
    RayServiceCtrl -->|creates| ServeService
    RayClusterCtrl -->|creates| HeadlessService

    RayClusterCtrl -.->|optional| Autoscaler
    RayClusterCtrl -.->|optional| VolcanoScheduler
    Webhook -.->|optional| CertManager

    Operator -->|API calls| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
    Operator -->|health check| HeadPod
    Prometheus[Prometheus] -->|scrapes| MetricsService

    WorkerPods -->|connect to GCS| HeadPod

    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Autoscaler fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
    style VolcanoScheduler fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
    style CertManager fill:#d3d3d3,stroke:#333,stroke-dasharray: 5 5
