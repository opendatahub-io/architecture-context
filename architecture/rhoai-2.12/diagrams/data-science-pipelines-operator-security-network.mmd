graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/SDK Client]
        Browser[User Browser]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge"]
        APIRoute["ds-pipeline-{name} Route<br/>8443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
        UIRoute["ds-pipeline-ui-{name} Route<br/>8443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph DMZ["DMZ (OAuth Proxy - Authentication Layer)"]
        direction TB
        APIOAuth["OAuth Proxy (API)<br/>8443/TCP HTTPS<br/>Service CA cert<br/>OAuth2 Bearer Token<br/>SA: ds-pipeline-{name}"]
        UIOAuth["OAuth Proxy (UI)<br/>8443/TCP HTTPS<br/>Service CA cert<br/>OAuth2 Bearer Token<br/>SA: ds-pipeline-{name}"]
    end

    subgraph AppLayer["APPLICATION LAYER (DSPA Instance)"]
        direction TB

        subgraph NS_DSPA["Namespace: {dspa-namespace}"]
            APIServer["DS Pipelines API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>SA: ds-pipeline-{name}"]
            UIServer["ML Pipelines UI<br/>3000/TCP HTTP<br/>SA: ds-pipeline-{name}"]
            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}"]
            ScheduledWorkflow["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-{name}"]

            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>No encryption<br/>User/Pass auth<br/>PVC: 10Gi<br/>NetworkPolicy: mariadb-{name}"]

            Minio["Minio<br/>9000/TCP HTTP<br/>No encryption<br/>Access/Secret Key"]

            subgraph MLMD["ML Metadata (Optional)"]
                MLMDEnvoy["MLMD Envoy<br/>9090/TCP gRPC"]
                MLMDServer["MLMD gRPC Server<br/>Variable/TCP gRPC"]
            end

            RunnerPods["Pipeline Runner Pods<br/>SA: argo"]
        end
    end

    subgraph Workflows["Workflow Engines"]
        Argo["Argo Workflows Controller<br/>v2 pipelines<br/>K8s API 443/TCP HTTPS"]
        Tekton["Tekton Controller<br/>v1 pipelines - deprecated<br/>K8s API 443/TCP HTTPS"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        direction TB
        Operator["Data Science Pipelines Operator<br/>NS: opendatahub<br/>SA: controller-manager<br/>Ports: 8080/TCP metrics, 8081/TCP health"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        ExternalS3["External S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM or Access/Secret Keys"]
        ExternalDB["External MySQL/MariaDB<br/>3306/TCP MySQL<br/>TLS optional<br/>Username/Password"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        ServiceCA["Service CA Operator<br/>Provisions TLS certs"]
        OAuthService["OpenShift OAuth<br/>Token validation"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| Router
    Browser -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| Router

    %% Ingress to DMZ
    Router -->|HTTPS/8443<br/>Reencrypt| APIRoute
    Router -->|HTTPS/8443<br/>Reencrypt| UIRoute
    APIRoute -->|HTTPS/8443<br/>Service CA| APIOAuth
    UIRoute -->|HTTPS/8443<br/>Service CA| UIOAuth

    %% DMZ to Application
    APIOAuth -->|Validate token| OAuthService
    UIOAuth -->|Validate token| OAuthService
    APIOAuth -->|HTTP/8888<br/>Localhost<br/>Delegated auth| APIServer
    UIOAuth -->|HTTP/3000<br/>Localhost<br/>Delegated auth| UIServer

    %% Application Layer Flows
    APIServer -->|MySQL/3306<br/>No encryption<br/>User/Pass| MariaDB
    APIServer -->|HTTP/9000<br/>No encryption<br/>Access/Secret Key| Minio
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>K8s API| Argo
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>K8s API| Tekton

    UIServer -->|HTTP/8888<br/>Internal<br/>SA Token| APIServer

    PersistenceAgent -->|MySQL/3306<br/>User/Pass| MariaDB

    ScheduledWorkflow -->|HTTPS/443<br/>K8s API<br/>SA Token| K8sAPI

    Argo -->|Create pods<br/>SA Token| RunnerPods
    Tekton -->|Create pods<br/>SA Token| RunnerPods

    RunnerPods -->|HTTP/9000<br/>Access/Secret Key| Minio
    RunnerPods -->|gRPC/9090<br/>No auth| MLMDEnvoy

    MLMDEnvoy -->|gRPC<br/>No encryption| MLMDServer
    MLMDServer -->|MySQL/3306<br/>User/Pass| MariaDB

    %% External Services
    APIServer -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Keys| ExternalS3
    APIServer -.->|MySQL/3306<br/>TLS optional<br/>User/Pass| ExternalDB
    RunnerPods -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Keys| ExternalS3

    %% Operator
    Operator -->|HTTPS/443<br/>K8s API<br/>SA Token| K8sAPI
    Operator -->|Creates/manages| APIServer
    Operator -->|Creates/manages| MariaDB
    Operator -->|Creates/manages| Minio

    Prometheus -->|HTTP/8080<br/>SA Token| Operator

    %% Platform Services
    ServiceCA -->|Provisions certs| APIOAuth
    ServiceCA -->|Provisions certs| UIOAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef dmz fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,Browser external
    class Router,APIRoute,UIRoute ingress
    class APIOAuth,UIOAuth dmz
    class APIServer,UIServer,PersistenceAgent,ScheduledWorkflow,MariaDB,Minio,MLMDEnvoy,MLMDServer,RunnerPods application
    class Argo,Tekton application
    class Operator,Prometheus operator
    class ExternalS3,ExternalDB externalservice
    class K8sAPI,ServiceCA,OAuthService platform
