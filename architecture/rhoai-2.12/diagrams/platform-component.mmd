graph TB
    subgraph "Red Hat OpenShift AI 2.12 Platform"
        subgraph "Core Orchestration"
            RHODSOp[RHODS Operator<br/>v1.6.0]
            DSC[DataScienceCluster CR]
            DSCInit[DSCInitialization CR]
        end

        subgraph "User Interface Layer"
            Dashboard[ODH Dashboard<br/>v1.21.0]
            DashboardConfig[OdhDashboardConfig CR]
        end

        subgraph "Workbench Layer"
            NotebookCtrl[ODH Notebook Controller<br/>v1.27.0]
            NotebookCR[Notebook CRs]
            Workbenches[Workbench Images<br/>JupyterLab/RStudio/VS Code]
        end

        subgraph "Model Serving Layer"
            KServe[KServe<br/>81bf82134]
            ModelMesh[ModelMesh Serving<br/>v1.27.0]
            ModelCtrl[ODH Model Controller<br/>v1.27.0]
            InferenceService[InferenceService CRs]
            ServingRuntime[ServingRuntime CRs]
        end

        subgraph "ML Pipelines Layer"
            DSPOp[Data Science Pipelines Operator<br/>6bcc644]
            DSPA[DataSciencePipelinesApplication CR]
            ArgoWorkflows[Argo Workflows]
            MLMD[ML Metadata gRPC]
        end

        subgraph "Distributed Training Layer"
            TrainingOp[Training Operator<br/>c7d4e1b4]
            PyTorchJob[PyTorchJob/TFJob/MPIJob CRs]
        end

        subgraph "Distributed Computing Layer"
            CodeFlare[CodeFlare Operator<br/>4e58587]
            KubeRay[KubeRay Operator<br/>b0225b36]
            RayCluster[RayCluster CRs]
            AppWrapper[AppWrapper CRs]
        end

        subgraph "Resource Management Layer"
            Kueue[Kueue<br/>v0.7.0]
            ClusterQueue[ClusterQueue/LocalQueue CRs]
            Workload[Workload CRs]
        end

        subgraph "Explainability Layer"
            TrustyAI[TrustyAI Service Operator<br/>1.17.0]
            TrustyAIService[TrustyAIService CRs]
        end

        subgraph "Platform Infrastructure"
            direction LR
            Istio[Istio Service Mesh<br/>1.19+]
            Knative[Knative Serving<br/>1.12+]
            OAuth[OpenShift OAuth]
            Prometheus[Prometheus Stack]
        end
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        S3[S3 Storage]
        Registry[Container Registries]
        GitRepo[Git Repositories]
    end

    %% Core orchestration flows
    RHODSOp -->|creates| DSC
    RHODSOp -->|creates| DSCInit
    RHODSOp -->|deploys| Dashboard
    RHODSOp -->|deploys| KServe
    RHODSOp -->|deploys| ModelMesh
    RHODSOp -->|deploys| ModelCtrl
    RHODSOp -->|deploys| DSPOp
    RHODSOp -->|deploys| NotebookCtrl
    RHODSOp -->|deploys| CodeFlare
    RHODSOp -->|deploys| KubeRay
    RHODSOp -->|deploys| Kueue
    RHODSOp -->|deploys| TrainingOp
    RHODSOp -->|deploys| TrustyAI
    RHODSOp -->|fetches manifests| GitRepo

    %% Dashboard integrations
    Dashboard -->|proxies| DSPOp
    Dashboard -->|proxies| TrustyAI
    Dashboard -->|creates| NotebookCR
    Dashboard -->|creates| InferenceService
    Dashboard -->|creates| DSPA
    Dashboard -->|uses| DashboardConfig

    %% Notebook flows
    NotebookCtrl -->|watches| NotebookCR
    NotebookCtrl -->|deploys| Workbenches
    NotebookCtrl -->|injects| OAuth

    %% Model serving flows
    KServe -->|manages| InferenceService
    KServe -->|uses| ServingRuntime
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    ModelMesh -->|manages| InferenceService
    ModelCtrl -->|watches| InferenceService
    ModelCtrl -->|creates routes for| KServe
    ModelCtrl -->|creates routes for| ModelMesh
    ModelCtrl -->|integrates| Istio
    ModelCtrl -->|integrates| Prometheus

    %% Pipeline flows
    DSPOp -->|creates| DSPA
    DSPOp -->|deploys| ArgoWorkflows
    DSPOp -->|deploys| MLMD
    DSPA -->|stores artifacts| S3

    %% Training flows
    TrainingOp -->|creates| PyTorchJob
    TrainingOp -->|integrates| Kueue

    %% Ray flows
    CodeFlare -->|watches| RayCluster
    CodeFlare -->|creates| AppWrapper
    CodeFlare -->|injects OAuth| OAuth
    KubeRay -->|manages| RayCluster
    AppWrapper -->|integrates| Kueue

    %% Kueue flows
    Kueue -->|creates| ClusterQueue
    Kueue -->|creates| Workload
    Kueue -->|watches| PyTorchJob
    Kueue -->|watches| RayCluster

    %% TrustyAI flows
    TrustyAI -->|creates| TrustyAIService
    TrustyAI -->|patches| InferenceService
    TrustyAI -->|integrates| Prometheus

    %% External dependencies
    KServe -->|downloads models| S3
    ModelMesh -->|downloads models| S3
    Workbenches -->|pulls images| Registry
    RHODSOp -->|manages| K8sAPI
    Dashboard -->|authenticates| OAuth

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef cr fill:#f5a623,stroke:#333,stroke-width:2px
    classDef infra fill:#7ed321,stroke:#333,stroke-width:2px
    classDef external fill:#999,stroke:#333,stroke-width:2px
    classDef workload fill:#bd10e0,stroke:#333,stroke-width:2px

    class RHODSOp,Dashboard,NotebookCtrl,KServe,ModelMesh,ModelCtrl,DSPOp,TrainingOp,CodeFlare,KubeRay,Kueue,TrustyAI operator
    class DSC,DSCInit,DashboardConfig,NotebookCR,InferenceService,ServingRuntime,DSPA,PyTorchJob,RayCluster,AppWrapper,ClusterQueue,Workload,TrustyAIService cr
    class Istio,Knative,OAuth,Prometheus infra
    class K8sAPI,S3,Registry,GitRepo external
    class Workbenches,ArgoWorkflows,MLMD workload
