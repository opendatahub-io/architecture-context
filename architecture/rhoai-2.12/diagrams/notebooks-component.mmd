graph TB
    subgraph "Notebooks Component (Workbench Images)"
        subgraph "Base Layer"
            BaseUBI9[Base UBI9 Python 3.9<br/>oc CLI + micropipenv]
            BaseCUDA[CUDA Base<br/>NVIDIA CUDA 11.8/12.1]
            BaseROCm[ROCm Base<br/>AMD ROCm]
            BaseHabana[Habana Base<br/>Intel SynapseAI]
            BaseIntel[Intel Base<br/>Intel GPU/ML]
        end

        subgraph "Jupyter Images"
            JupyterMinimal[Jupyter Minimal<br/>JupyterLab 3.6<br/>Notebook 6.5]
            JupyterDataScience[Jupyter Data Science<br/>Pandas, NumPy, Scikit-learn<br/>Elyra, KFP, CodeFlare]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.2 + CUDA 12.1<br/>Tensorboard]
            JupyterTensorFlow[Jupyter TensorFlow<br/>TensorFlow + CUDA<br/>Keras]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainability & Fairness]
            JupyterMinimalGPU[Jupyter Minimal GPU<br/>CUDA + JupyterLab]
        end

        subgraph "Alternative IDEs"
            RStudio[RStudio Server<br/>R 4.3 + Python 3.9]
            CodeServer[VS Code Server<br/>code-server + oc]
        end

        subgraph "Runtime Images"
            RuntimeMinimal[Runtime Minimal<br/>Python only]
            RuntimeDataScience[Runtime Data Science<br/>Libraries only]
            RuntimePyTorch[Runtime PyTorch]
            RuntimeTensorFlow[Runtime TensorFlow]
        end

        subgraph "Build System"
            Makefile[Makefile<br/>Multi-stage builds]
            Manifests[Kustomize Manifests<br/>ImageStreams + BuildConfigs]
            CIScripts[CI/CD Scripts<br/>Validation + Security Scanning]
        end
    end

    subgraph "External Dependencies"
        UBI9Base[UBI9 Python 3.9<br/>registry.access.redhat.com]
        JupyterLab[JupyterLab 3.6]
        PyTorch[PyTorch 2.2]
        TensorFlow[TensorFlow]
        CUDA[CUDA Toolkit 12.1]
        Elyra[Elyra/ODH-Elyra 3.16]
        KFP[Kubeflow Pipelines 2.7]
    end

    subgraph "Internal ODH Dependencies"
        NotebookController[ODH Notebook Controller<br/>Launches notebook pods]
        Dashboard[ODH Dashboard<br/>Displays available images]
        ImageStreams[OpenShift ImageStreams<br/>Versioned image references]
        BuildConfig[OpenShift BuildConfig<br/>On-cluster builds]
        KubeflowPipelines[Kubeflow Pipelines<br/>Runtime integration]
    end

    subgraph "Container Registries"
        Quay[Quay.io<br/>quay.io/opendatahub/workbench-images]
        InternalRegistry[OpenShift Image Registry]
    end

    User[User/Data Scientist] -->|selects image| Dashboard
    Dashboard -->|reads metadata| ImageStreams
    NotebookController -->|launches pods using| JupyterDataScience
    NotebookController -->|launches pods using| JupyterPyTorch
    NotebookController -->|launches pods using| RStudio

    BaseUBI9 --> JupyterMinimal
    JupyterMinimal --> JupyterDataScience
    JupyterMinimal --> JupyterTrustyAI
    BaseCUDA --> JupyterMinimalGPU
    JupyterMinimalGPU --> JupyterPyTorch
    JupyterMinimalGPU --> JupyterTensorFlow
    BaseUBI9 --> RStudio
    BaseUBI9 --> CodeServer

    JupyterMinimal --> RuntimeMinimal
    JupyterDataScience --> RuntimeDataScience
    JupyterPyTorch --> RuntimePyTorch
    JupyterTensorFlow --> RuntimeTensorFlow

    Makefile -->|builds| JupyterDataScience
    Makefile -->|builds| JupyterPyTorch
    Makefile -->|pushes to| Quay
    Manifests -->|creates| ImageStreams
    Manifests -->|creates| BuildConfig
    BuildConfig -->|builds RHEL variants| RStudio
    BuildConfig -->|pushes to| InternalRegistry

    UBI9Base -.->|base for| BaseUBI9
    JupyterLab -.->|installed in| JupyterMinimal
    PyTorch -.->|installed in| JupyterPyTorch
    TensorFlow -.->|installed in| JupyterTensorFlow
    CUDA -.->|installed in| BaseCUDA
    Elyra -.->|installed in| JupyterDataScience
    KFP -.->|SDK in| JupyterDataScience

    RuntimeDataScience -->|executes in| KubeflowPipelines
    CIScripts -->|validates| Manifests
    CIScripts -->|scans| JupyterDataScience

    style JupyterDataScience fill:#4a90e2,stroke:#333,stroke-width:3px
    style JupyterPyTorch fill:#4a90e2,stroke:#333,stroke-width:3px
    style NotebookController fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Quay fill:#f5a623,stroke:#333
    style User fill:#e8e8e8,stroke:#333
