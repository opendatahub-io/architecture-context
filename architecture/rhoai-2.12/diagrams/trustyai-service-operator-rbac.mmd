graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: operator-namespace]
        SA_Proxy["{instance}-proxy<br/>Namespace: {namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Scope: Cluster]
        CRB_Proxy["{instance}-{namespace}-proxy-rolebinding<br/>Scope: Cluster"]
        RB_Leader[leader-election-rolebinding<br/>Scope: Namespace]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Proxy[proxy-role]
        R_Leader[leader-election-role]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps["configmaps"]
        Core_Events["events"]
        Core_Pods["pods"]
        Core_Secrets["secrets"]
        Core_SA["serviceaccounts"]
        Core_Services["services"]
        Core_PVC["persistentvolumeclaims"]
        Core_PV["persistentvolumes"]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments["deployments<br/>deployments/finalizers<br/>deployments/status"]
    end

    subgraph "API Resources - KServe"
        KServe_IS["inferenceservices<br/>inferenceservices/finalizers"]
        KServe_SR["servingruntimes<br/>servingruntimes/status"]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAI_Service["trustyaiservices<br/>trustyaiservices/status<br/>trustyaiservices/finalizers"]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_SM["servicemonitors"]
    end

    subgraph "API Resources - OpenShift"
        Route_Routes["routes"]
    end

    subgraph "API Resources - RBAC"
        RBAC_CRB["clusterrolebindings"]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases["leases"]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReview["tokenreviews"]
        Auth_SAR["subjectaccessreviews"]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    SA_Proxy -->|bound via| CRB_Proxy

    %% ClusterRoleBindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    %% Manager Role Permissions
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_ConfigMaps
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_Events
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_Pods
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_Secrets
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_SA
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_Services
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_PVC
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Core_PV

    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Apps_Deployments

    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| KServe_IS
    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| KServe_SR

    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| TrustyAI_Service

    CR_Manager -->|"create, list, watch"| Monitoring_SM

    CR_Manager -->|"get, list, watch,<br/>create, update, patch, delete"| Route_Routes

    CR_Manager -->|"get, list, watch,<br/>create, update, delete"| RBAC_CRB

    CR_Manager -->|"get, create, update"| Coord_Leases

    %% Proxy Role Permissions
    CR_Proxy -->|"create"| Auth_TokenReview
    CR_Proxy -->|"create"| Auth_SAR

    %% Leader Election Role Permissions
    R_Leader -->|"get, create, update"| Coord_Leases

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    class SA_Controller,SA_Proxy serviceAccount
    class CRB_Manager,CRB_Proxy,RB_Leader binding
    class CR_Manager,CR_Proxy,R_Leader role
    class Core_ConfigMaps,Core_Events,Core_Pods,Core_Secrets,Core_SA,Core_Services,Core_PVC,Core_PV resource
    class Apps_Deployments resource
    class KServe_IS,KServe_SR resource
    class TrustyAI_Service resource
    class Monitoring_SM resource
    class Route_Routes resource
    class RBAC_CRB resource
    class Coord_Leases resource
    class Auth_TokenReview,Auth_SAR resource
