graph LR
    Kubeflow[ODH Notebook Controller]

    %% External OpenShift Dependencies
    Kubeflow -->|"Routes for<br/>external access"| Router[OpenShift Router API<br/>route.openshift.io/v1<br/>REQUIRED]
    Kubeflow -->|"TLS cert<br/>provisioning"| ServiceCA[OpenShift Service CA<br/>service.beta annotation<br/>REQUIRED]
    Kubeflow -->|"User authentication<br/>OAuth proxy"| OAuth[OpenShift OAuth Server<br/>OAuth 2.0<br/>REQUIRED]
    Kubeflow -->|"Cluster proxy<br/>configuration"| ConfigAPI[OpenShift Config API<br/>config.openshift.io/v1<br/>REQUIRED]
    Kubeflow -->|"Image reference<br/>resolution"| ImageStream[OpenShift ImageStream API<br/>image.openshift.io/v1<br/>REQUIRED]

    %% Core Kubernetes Dependencies
    Kubeflow -->|"Container<br/>orchestration"| K8s[Kubernetes API<br/>v1.29.0+<br/>REQUIRED]
    Kubeflow -->|"Network<br/>isolation"| NetPolicy[NetworkPolicy API<br/>networking.k8s.io/v1<br/>REQUIRED]

    %% Internal ODH Dependencies (same cluster)
    Kubeflow -->|"Watches same<br/>Notebook CRD"| KubeflowUpstream[Kubeflow Notebook Controller<br/>Creates StatefulSets<br/>REQUIRED]
    Kubeflow -->|"Watches<br/>odh-trusted-ca-bundle"| ODHOperator[ODH Operator<br/>Provides CA ConfigMap<br/>REQUIRED]

    %% Integration Points (bidirectional)
    Dashboard[ODH Dashboard] -.->|"UI for managing<br/>notebooks"| Kubeflow
    Pipelines[Data Science Pipelines] -.->|"Auto-deploy<br/>models"| Kubeflow

    %% Observability
    Kubeflow -->|"Metrics export<br/>HTTP/8080"| Prometheus[Prometheus<br/>Monitoring]

    %% External Services
    Kubeflow -->|"Pull OAuth proxy<br/>and notebook images<br/>HTTPS/443"| Registry[Container Registries<br/>registry.redhat.io<br/>quay.io]

    %% Runtime Sidecar Dependency
    Kubeflow -->|"Injected into<br/>notebook pods"| OAuthProxySidecar[OAuth Proxy Sidecar<br/>ose-oauth-proxy<br/>REQUIRED at Runtime]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External OpenShift (required, external)
    style Router fill:#d79b00,stroke:#333,stroke-width:2px
    style ServiceCA fill:#d79b00,stroke:#333,stroke-width:2px
    style OAuth fill:#d79b00,stroke:#333,stroke-width:2px
    style ConfigAPI fill:#d79b00,stroke:#333,stroke-width:2px
    style ImageStream fill:#d79b00,stroke:#333,stroke-width:2px

    %% Core K8s (required, external)
    style K8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style NetPolicy fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH (required, internal)
    style KubeflowUpstream fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px

    %% Integration points (optional, internal)
    style Dashboard fill:#bd10e0,stroke:#333,stroke-width:2px
    style Pipelines fill:#bd10e0,stroke:#333,stroke-width:2px

    %% Observability
    style Prometheus fill:#e24a33,stroke:#333,stroke-width:2px

    %% External services
    style Registry fill:#999,stroke:#333,stroke-width:2px
    style OAuthProxySidecar fill:#f5a623,stroke:#333,stroke-width:2px
