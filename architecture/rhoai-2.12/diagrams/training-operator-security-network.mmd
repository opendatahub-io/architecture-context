graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Python SDK<br/>kubeflow-training"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>RBAC + ServiceAccount Tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Operator["Training Operator Controller<br/>SA: training-operator<br/>Replicas: 1<br/>Istio: Disabled<br/>Security: non-root, no privilege escalation"]

        subgraph Controllers["Internal Controllers"]
            PyTorchCtrl[PyTorch Controller]
            TFCtrl[TensorFlow Controller]
            MPICtrl[MPI Controller]
            MXNetCtrl[MXNet Controller]
            XGBoostCtrl[XGBoost Controller]
            PaddleCtrl[PaddlePaddle Controller]
        end

        Webhook["Webhook Server<br/>mTLS<br/>Cert: webhook-server-cert"]

        MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth (ClusterIP)"]
        HealthEndpoint["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph UserNS["TRAINING JOB NAMESPACES ({user-namespace})"]
        direction TB

        TrainingPods["Training Pods<br/>PyTorch/TF/MPI/MXNet/XGBoost/Paddle<br/>Roles: Master/Worker/Launcher/PS<br/>Framework-specific networking"]
        Services["Services<br/>Service discovery"]
        ConfigMaps["ConfigMaps<br/>Training config"]
        HPA["HorizontalPodAutoscaler<br/>PyTorch Elastic only<br/>Metrics-based scaling"]
    end

    subgraph GangScheduling["OPTIONAL: GANG SCHEDULING"]
        PodGroup["PodGroup CRD<br/>scheduling.volcano.sh/v1beta1<br/>OR scheduling.x-k8s.io/v1alpha1"]
        Volcano["Volcano Scheduler<br/>OR scheduler-plugins<br/>Atomic pod scheduling"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>No Auth"]
        PodMonitor["PodMonitor<br/>Prometheus Operator"]
    end

    subgraph Egress["EGRESS (External Services)"]
        Registry["Container Registries<br/>443/TCP HTTPS TLS1.2+<br/>Image Pull Secrets"]
    end

    %% User flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials or<br/>ServiceAccount token"| APIServer

    %% API Server to Operator
    APIServer -->|"Watch/List Events<br/>TLS 1.2+<br/>ServiceAccount Token (JWT)"| Operator

    %% Operator to API Server
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Create/Update resources"| APIServer

    %% Webhook validation
    APIServer -->|"mTLS<br/>Validate/Mutate CRs"| Webhook

    %% Operator creates resources
    Operator -->|creates/manages| TrainingPods
    Operator -->|creates| Services
    Operator -->|creates| ConfigMaps
    Operator -->|creates| HPA
    Operator -->|creates| PodGroup

    %% Gang scheduling
    PodGroup -->|watched by| Volcano
    Volcano -->|"schedules atomically via"| APIServer

    %% Metrics collection
    Prometheus -->|"HTTP/8080<br/>No Auth<br/>Scrape metrics"| MetricsEndpoint
    PodMonitor -->|configures| Prometheus

    %% Training pods communication
    TrainingPods -->|"Framework-specific<br/>gRPC/TCP/NCCL<br/>Varies encryption"| TrainingPods

    %% Egress
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull images"| Registry
    TrainingPods -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull images"| Registry

    %% Health checks
    Operator -->|exposes| HealthEndpoint
    Operator -->|exposes| MetricsEndpoint

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef control fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class APIServer control
    class Operator,Webhook,MetricsEndpoint,HealthEndpoint,PyTorchCtrl,TFCtrl,MPICtrl,MXNetCtrl,XGBoostCtrl,PaddleCtrl operator
    class TrainingPods,Services,ConfigMaps,HPA workload
    class PodGroup,Volcano optional
    class Prometheus,PodMonitor monitoring
    class Registry egress
