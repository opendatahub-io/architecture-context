graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>notebook-[name]<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ Edge Termination<br/>[notebook-namespace].[cluster-domain]"]
    end

    subgraph NotebookPod["APPLICATION POD (Trusted - User Namespace)"]
        direction TB

        subgraph Pod["Pod: notebook-[name]<br/>Namespace: {user-namespace}<br/>SA: default or custom"]
            OAuthProxy["OAuth Proxy Sidecar<br/>Port: 8888/TCP<br/>Validates OAuth tokens"]
            JupyterContainer["JupyterLab Container<br/>UID: 1001 non-root<br/>Port: 8888/TCP HTTP<br/>Image: quay.io/opendatahub/workbench-images:jupyter-datascience-*"]
        end
    end

    subgraph PackageManagement["EGRESS - Package Management"]
        PyPI["PyPI.org<br/>pypi.org<br/>443/TCP HTTPS TLS1.2+<br/>No auth"]
    end

    subgraph DataAccess["EGRESS - Data Access"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM Keys (Boto3)"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP TLS optional<br/>Username/Password<br/>psycopg 3.1"]
        MySQL["MySQL Database<br/>3306/TCP TLS optional<br/>Username/Password<br/>MySQL Connector 8.0/8.3"]
        MongoDB["MongoDB<br/>27017/TCP TLS optional<br/>Username/Password<br/>PyMongo 4.5/4.6"]
    end

    subgraph K8sIntegration["EGRESS - Kubernetes API"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token<br/>oc CLI, KFP SDK"]
    end

    subgraph MLPipelines["EGRESS - ML Pipelines"]
        KFP["Kubeflow Pipelines API<br/>kubeflow or odh-pipelines ns<br/>8888/TCP HTTPS TLS1.2+<br/>Bearer Token<br/>Elyra 3.16, KFP SDK 2.7"]
    end

    subgraph SourceControl["EGRESS - Source Control"]
        Git["Git Repositories<br/>github.com, gitlab.com<br/>443/TCP HTTPS/SSH TLS1.2+<br/>SSH Keys / PAT"]
    end

    subgraph Registries["EGRESS - Container Registries"]
        Quay["Quay.io / Registries<br/>443/TCP HTTPS TLS1.2+<br/>Registry Token"]
    end

    %% Ingress Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route
    Route -->|HTTP/8888<br/>TLS terminated| OAuthProxy
    OAuthProxy -->|HTTP/8888<br/>localhost<br/>Proxied auth| JupyterContainer

    %% Egress Flows
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| PyPI
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM Keys| S3
    JupyterContainer -->|PostgreSQL/5432<br/>TLS optional<br/>Username/Password| PostgreSQL
    JupyterContainer -->|MySQL/3306<br/>TLS optional<br/>Username/Password| MySQL
    JupyterContainer -->|MongoDB/27017<br/>TLS optional<br/>Username/Password| MongoDB
    JupyterContainer -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    JupyterContainer -->|HTTPS/8888<br/>TLS 1.2+<br/>Bearer Token| KFP
    JupyterContainer -->|HTTPS/SSH 443<br/>TLS 1.2+/SSH<br/>SSH Keys/PAT| Git
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>Registry Token| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Route ingress
    class OAuthProxy,JupyterContainer pod
    class PyPI,S3,PostgreSQL,MySQL,MongoDB,K8sAPI,KFP,Git,Quay egress
