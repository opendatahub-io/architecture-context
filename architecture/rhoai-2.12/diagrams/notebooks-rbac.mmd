graph TD
    subgraph "Service Accounts"
        SA_Notebook["notebook-name-sa<br/>or default SA<br/>User Namespace"]
        SA_Controller["notebook-controller-sa<br/>ODH Namespace"]
    end

    subgraph "Role Bindings"
        RB_Notebook["notebook-controller-rolebinding<br/>Binds SA to Role"]
    end

    subgraph "Roles/ClusterRoles"
        Role_NotebookController["notebook-controller-role<br/>ClusterRole/Role"]
    end

    subgraph "Kubernetes API Resources - Core"
        Pods["Pods<br/>core/v1"]
        Services["Services<br/>core/v1"]
        PVCs["PersistentVolumeClaims<br/>core/v1"]
    end

    subgraph "Kubernetes API Resources - Apps"
        Deployments["Deployments<br/>apps/v1"]
        StatefulSets["StatefulSets<br/>apps/v1"]
    end

    subgraph "OpenShift Resources"
        Routes["Routes<br/>route.openshift.io"]
    end

    subgraph "Kubeflow Resources"
        NotebookCRs["Notebooks<br/>kubeflow.org"]
    end

    subgraph "Authentication & Authorization"
        OAuthProxy["OAuth Proxy<br/>Validates user access<br/>OpenShift OAuth"]
        JupyterToken["Jupyter Token Auth<br/>Token-based auth<br/>Configured by controller"]
    end

    subgraph "External Access Control"
        User["User/Data Scientist<br/>Must have namespace access"]
        OpenShiftOAuth["OpenShift OAuth Server<br/>Validates OAuth tokens"]
    end

    %% Service Account Bindings
    SA_Notebook -->|bound via| RB_Notebook
    RB_Notebook -->|grants| Role_NotebookController

    %% RBAC Permissions
    Role_NotebookController -->|get, list, watch, create, delete| Pods
    Role_NotebookController -->|get, list, watch, create, delete| Services
    Role_NotebookController -->|get, list, watch, create, delete| PVCs
    Role_NotebookController -->|get, list, watch| Deployments
    Role_NotebookController -->|get, list, watch| StatefulSets
    Role_NotebookController -->|get, list, watch, create, delete| Routes
    Role_NotebookController -->|get, list, watch, create, update, patch, delete| NotebookCRs

    %% Authentication Flow
    User -->|HTTPS/443 OAuth Token| OAuthProxy
    OAuthProxy -->|validates with| OpenShiftOAuth
    OpenShiftOAuth -->|checks namespace RBAC| User
    OAuthProxy -->|proxies to| JupyterToken
    JupyterToken -->|grants access to| Pods

    %% Controller Actions
    SA_Controller -->|manages| NotebookCRs
    SA_Controller -->|creates/deletes| Pods
    SA_Controller -->|creates/deletes| Services
    SA_Controller -->|creates/deletes| Routes

    %% Annotations
    Note1["Note: RBAC is managed by<br/>ODH Notebook Controller<br/>Notebooks component does not<br/>define RBAC directly"]
    Note2["Note: User must have<br/>namespace access via<br/>OpenShift RBAC to<br/>access notebook pods"]

    %% Styling
    style SA_Notebook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Role_NotebookController fill:#f5a623,stroke:#333,stroke-width:2px
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style StatefulSets fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style NotebookCRs fill:#7ed321,stroke:#333
    style OAuthProxy fill:#e8e8e8,stroke:#333
    style JupyterToken fill:#e8e8e8,stroke:#333
    style User fill:#e8e8e8,stroke:#333
    style OpenShiftOAuth fill:#e8e8e8,stroke:#333
    style Note1 fill:#fff,stroke:#999,stroke-dasharray: 5 5
    style Note2 fill:#fff,stroke:#999,stroke-dasharray: 5 5
