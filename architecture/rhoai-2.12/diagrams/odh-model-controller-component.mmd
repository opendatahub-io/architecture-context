graph TB
    subgraph "ODH Model Controller"
        MainReconciler[InferenceService Reconciler]

        subgraph "Mode-Specific Reconcilers"
            ModelMeshRec[ModelMesh Reconciler]
            ServerlessRec[KServe Serverless Reconciler]
            RawRec[KServe Raw Reconciler]
        end

        subgraph "Resource Reconcilers"
            StorageRec[Storage Secret Reconciler]
            CAReconciler[Custom CA Cert Reconciler]
            MonitoringRec[Monitoring Reconciler]
            ModelRegRec[Model Registry Reconciler]
        end

        subgraph "Service Mesh Integration"
            RouteRec[Route Reconciler]
            VirtualServiceRec[VirtualService Reconciler]
            GatewayRec[Gateway Reconciler]
            AuthConfigRec[AuthConfig Reconciler]
            PeerAuthRec[PeerAuthentication Reconciler]
            ServiceMeshRec[ServiceMeshMember Reconciler]
            NetworkPolicyRec[NetworkPolicy Reconciler]
            TelemetryRec[Telemetry Reconciler]
        end

        Webhook[Knative Service Validator]

        MainReconciler -->|delegates to| ModelMeshRec
        MainReconciler -->|delegates to| ServerlessRec
        MainReconciler -->|delegates to| RawRec

        ServerlessRec -->|creates| RouteRec
        ServerlessRec -->|creates| VirtualServiceRec
        ServerlessRec -->|updates| GatewayRec
        ServerlessRec -->|creates| AuthConfigRec
        ServerlessRec -->|creates| PeerAuthRec
        ServerlessRec -->|creates| ServiceMeshRec
        ServerlessRec -->|creates| NetworkPolicyRec
        ServerlessRec -->|creates| TelemetryRec
    end

    subgraph "Watched CRDs"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        SecretsCR[Secrets<br/>core/v1]
    end

    subgraph "Created/Managed Resources"
        RouteCR[Route<br/>route.openshift.io/v1]
        VirtualServiceCR[VirtualService<br/>networking.istio.io/v1beta1]
        GatewayCR[Gateway<br/>networking.istio.io/v1beta1]
        PeerAuthCR[PeerAuthentication<br/>security.istio.io/v1beta1]
        AuthConfigCR[AuthConfig<br/>authorino.kuadrant.io/v1beta2]
        ServiceMonitorCR[ServiceMonitor<br/>monitoring.coreos.com/v1]
        PodMonitorCR[PodMonitor<br/>monitoring.coreos.com/v1]
        ServiceMeshMemberCR[ServiceMeshMember<br/>maistra.io/v1]
        NetworkPolicyCR[NetworkPolicy<br/>networking.k8s.io/v1]
        TelemetryCR[Telemetry<br/>telemetry.istio.io/v1alpha1]
    end

    subgraph "External Dependencies"
        KServeController[KServe Controller]
        K8sAPI[Kubernetes API Server]
        IstioCP[Istio Control Plane]
        Authorino[Authorino]
        PrometheusOp[Prometheus Operator]
        KnativeServing[Knative Serving]
    end

    InferenceServiceCR -->|watched by| MainReconciler
    ServingRuntimeCR -->|watched by| MainReconciler
    SecretsCR -->|watched by| StorageRec

    RouteRec -->|creates| RouteCR
    VirtualServiceRec -->|creates| VirtualServiceCR
    GatewayRec -->|updates| GatewayCR
    PeerAuthRec -->|creates| PeerAuthCR
    AuthConfigRec -->|creates| AuthConfigCR
    MonitoringRec -->|creates| ServiceMonitorCR
    MonitoringRec -->|creates| PodMonitorCR
    ServiceMeshRec -->|creates| ServiceMeshMemberCR
    NetworkPolicyRec -->|creates| NetworkPolicyCR
    TelemetryRec -->|creates| TelemetryCR

    MainReconciler -->|API calls| K8sAPI
    MainReconciler -->|coordinates| KServeController
    VirtualServiceCR -->|configured by| IstioCP
    GatewayCR -->|configured by| IstioCP
    PeerAuthCR -->|configured by| IstioCP
    AuthConfigCR -->|processed by| Authorino
    ServiceMonitorCR -->|used by| PrometheusOp
    Webhook -->|validates| KnativeServing

