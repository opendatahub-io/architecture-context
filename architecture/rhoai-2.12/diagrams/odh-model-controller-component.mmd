    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style RouteCR fill:#7ed321,stroke:#333
    style VirtualServiceCR fill:#7ed321,stroke:#333
    style AuthConfigCR fill:#7ed321,stroke:#333
    style KServeController fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style IstioCP fill:#e8e8e8,stroke:#333
    style Authorino fill:#e8e8e8,stroke:#333
