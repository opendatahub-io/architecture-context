graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (reencrypt)"]
    end

    subgraph Service["ODH DASHBOARD SERVICE (ClusterIP)"]
        direction TB

        subgraph Pod["odh-dashboard Pod"]
            direction LR
            OAuthProxy["OAuth Proxy Container<br/>Port: 8443/TCP HTTPS<br/>TLS: dashboard-proxy-tls<br/>Auth: OpenShift OAuth 2.0"]
            Backend["Dashboard Backend<br/>Port: 8080/TCP HTTP<br/>Framework: Node.js Fastify<br/>SA: odh-dashboard"]

            OAuthProxy -->|HTTP/8080<br/>localhost<br/>Bearer Token| Backend
        end
    end

    subgraph K8sInfra["KUBERNETES INFRASTRUCTURE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        OSAuth["OpenShift OAuth<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth Client Secret"]
    end

    subgraph Monitoring["MONITORING (openshift-monitoring)"]
        Prometheus["Thanos Querier<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]
    end

    subgraph ODHServices["ODH INTERNAL SERVICES"]
        direction TB
        Pipelines["Data Science Pipelines<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (User)"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP/HTTPS<br/>Varies<br/>Bearer Token (User)"]
        MLMD["ML Metadata (MLMD)<br/>8080/TCP HTTP/HTTPS<br/>Varies<br/>Bearer Token (User)"]
        TrustyAI["TrustyAI Service<br/>8080/TCP HTTP/HTTPS<br/>Varies<br/>Bearer Token (User)"]
    end

    subgraph Secrets["SECRETS & CONFIGMAPS"]
        direction TB
        ProxyTLS["dashboard-proxy-tls<br/>Type: kubernetes.io/tls<br/>Provisioner: service-ca<br/>Auto-rotate: 90d"]
        OAuthConfig["dashboard-oauth-config-generated<br/>Type: Opaque<br/>Cookie encryption secret"]
        OAuthClient["dashboard-oauth-client-generated<br/>Type: Opaque<br/>OAuth client credentials"]
        TrustedCA["odh-trusted-ca-bundle<br/>Type: ConfigMap<br/>Trusted CAs"]
        ODHCA["odh-ca-cert<br/>Type: ConfigMap<br/>ODH platform CA"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router

    %% Ingress to Service
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>Reencrypt| OAuthProxy

    %% OAuth Flow
    OAuthProxy -->|HTTPS/6443<br/>TLS 1.2+<br/>OAuth Client Secret| OSAuth

    %% Backend to Infrastructure
    Backend -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Backend -->|HTTPS/9091<br/>TLS 1.2+<br/>ServiceAccount Token| Prometheus

    %% Backend to ODH Services (Proxy)
    Backend -->|HTTPS/8443<br/>TLS 1.2+<br/>User Token Passthrough| Pipelines
    Backend -->|HTTP-HTTPS/8080<br/>Varies<br/>User Token Passthrough| ModelRegistry
    Backend -->|HTTP-HTTPS/8080<br/>Varies<br/>User Token Passthrough| MLMD
    Backend -->|HTTP-HTTPS/8080<br/>Varies<br/>User Token Passthrough| TrustyAI

    %% Secret Mounts
    ProxyTLS -.->|mount: /etc/tls/private| OAuthProxy
    OAuthConfig -.->|mount: /etc/oauth/config| OAuthProxy
    OAuthClient -.->|mount: /etc/oauth/client| OAuthProxy
    TrustedCA -.->|mount: /etc/pki/tls/certs| OAuthProxy
    TrustedCA -.->|mount: /etc/pki/tls/certs| Backend
    ODHCA -.->|mount: /etc/pki/tls/certs| OAuthProxy
    ODHCA -.->|mount: /etc/pki/tls/certs| Backend

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef infrastructure fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef odhservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router ingress
    class OAuthProxy,Backend service
    class K8sAPI,OSAuth,Prometheus infrastructure
    class Pipelines,ModelRegistry,MLMD,TrustyAI odhservice
    class ProxyTLS,OAuthConfig,OAuthClient,TrustedCA,ODHCA secret
