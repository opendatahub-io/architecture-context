graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
        RayClient[Ray Client Remote]
    end

    subgraph Ingress["INGRESS (DMZ) - Optional"]
        IngressRoute["Kubernetes Ingress /<br/>OpenShift Route<br/>443/TCP HTTPS<br/>TLS 1.2+ (Edge/Passthrough)<br/>Auth: Application-level (optional)"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE"]
        direction TB

        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>UID: 65532 (non-root)<br/>UBI9 base"]

        OpMetrics["Metrics Service<br/>8080/TCP HTTP<br/>Auth: None"]

        Webhook["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: K8s API<br/>Endpoint: /validate-ray-io-v1-raycluster"]

        Operator -.->|exposes| OpMetrics
        Operator -.->|exposes| Webhook
    end

    subgraph UserNamespace["RAY CLUSTER NAMESPACE: {user-namespace}"]
        direction TB

        subgraph HeadPodBox["Ray Head Pod"]
            HeadPod["SA: {raycluster-name}-sa<br/>UID: 1000<br/>Image: rayproject/ray"]
            GCS["GCS Server<br/>6379/TCP<br/>⚠️ UNENCRYPTED, NO AUTH"]
            Dashboard["Dashboard<br/>8265/TCP HTTP<br/>⚠️ NO AUTH"]
            ClientSvc["Client Server<br/>10001/TCP<br/>⚠️ UNENCRYPTED, NO AUTH"]
            ServeHead["Serve<br/>8000/TCP HTTP<br/>⚠️ NO AUTH"]
            Metrics["Metrics<br/>8080/TCP HTTP"]
        end

        HeadService["Head Service (ClusterIP)<br/>{raycluster-name}-head-svc<br/>Ports: 6379, 8265, 10001, 8080"]

        subgraph WorkerPodBox["Ray Worker Pod(s)"]
            WorkerPod["SA: {raycluster-name}-sa<br/>UID: 1000<br/>Replicas: 0-N"]
            WorkerProcess["Worker Process"]
            ServeWorker["Serve Replicas<br/>8000/TCP HTTP"]
        end

        ServeSvc["Serve Service (ClusterIP)<br/>{rayservice-name}-serve-svc<br/>8000/TCP HTTP"]

        HeadService -.->|routes to| HeadPod
        ServeSvc -.->|routes to| ServeHead
        ServeSvc -.->|routes to| ServeWorker
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS 1.3<br/>Auth: ServiceAccount Token"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secret"]
        ExternalStorage["External Storage (Optional)<br/>GCS Fault Tolerance<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Credentials/IAM"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>App-level Auth| IngressRoute
    RayClient -->|HTTPS/443<br/>TLS 1.2+<br/>App-level Auth| IngressRoute

    %% Ingress flows
    IngressRoute -->|HTTP/8265<br/>⚠️ UNENCRYPTED| HeadService
    IngressRoute -->|HTTP/8000<br/>⚠️ UNENCRYPTED| ServeSvc

    %% Operator flows
    Operator -->|HTTPS/443<br/>TLS 1.3<br/>ServiceAccount Token<br/>ClusterRole: kuberay-operator| K8sAPI
    Operator -->|HTTP/8265<br/>Health Check<br/>⚠️ NO AUTH| HeadService
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>K8s API Auth| Webhook

    %% Ray internal communication
    WorkerPod -->|TCP/6379<br/>⚠️ UNENCRYPTED<br/>⚠️ NO AUTH<br/>GCS Connection| HeadPod

    %% External service flows
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry
    HeadPod -.->|HTTPS/443<br/>Optional<br/>TLS 1.2+<br/>Creds/IAM| ExternalStorage
    Prometheus -->|HTTP/8080<br/>Metrics Scrape<br/>⚠️ NO AUTH| OpMetrics
    Prometheus -.->|HTTP/8080<br/>Ray Metrics| HeadService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef raycluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,RayClient external
    class IngressRoute ingress
    class Operator,OpMetrics,Webhook operator
    class HeadPod,WorkerPod,HeadService,ServeSvc,GCS,Dashboard,ClientSvc,ServeHead,ServeWorker raycluster
    class K8sAPI,Registry,ExternalStorage,Prometheus externalservice
