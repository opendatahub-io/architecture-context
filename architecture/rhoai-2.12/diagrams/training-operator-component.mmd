graph TB
    subgraph "Training Operator Component"
        Controller[training-operator<br/>Main Controller]
        PyTorchCtrl[PyTorch Controller<br/>Reconciler]
        TFCtrl[TensorFlow Controller<br/>Reconciler]
        MPICtrl[MPI Controller<br/>Reconciler]
        MXNetCtrl[MXNet Controller<br/>Reconciler]
        XGBoostCtrl[XGBoost Controller<br/>Reconciler]
        PaddleCtrl[PaddlePaddle Controller<br/>Reconciler]
        Webhook[Webhook Server<br/>Admission Webhook]

        Controller -->|manages| PyTorchCtrl
        Controller -->|manages| TFCtrl
        Controller -->|manages| MPICtrl
        Controller -->|manages| MXNetCtrl
        Controller -->|manages| XGBoostCtrl
        Controller -->|manages| PaddleCtrl
        Controller -->|validates/mutates| Webhook
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        MXJob[MXJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Kubernetes Resources"
        Pods[Training Pods]
        Services[Services]
        ConfigMaps[ConfigMaps]
        HPA[HorizontalPodAutoscaler<br/>PyTorch Elastic]
        PodGroup[PodGroup<br/>Gang Scheduling]
    end

    subgraph "External Systems"
        User[User/Python SDK]
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        Prometheus[Prometheus<br/>8080/TCP HTTP]
        Volcano[Volcano Scheduler<br/>Optional]
        SchedulerPlugins[scheduler-plugins<br/>Optional]
    end

    %% User interactions
    User -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| MPIJob
    User -->|creates| MXJob
    User -->|creates| XGBoostJob
    User -->|creates| PaddleJob

    %% Controller watches CRDs
    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    MPIJob -->|watched by| MPICtrl
    MXJob -->|watched by| MXNetCtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    PaddleJob -->|watched by| PaddleCtrl

    %% Controllers create resources
    PyTorchCtrl -->|creates/manages| Pods
    PyTorchCtrl -->|creates| HPA
    TFCtrl -->|creates/manages| Pods
    MPICtrl -->|creates/manages| Pods
    MXNetCtrl -->|creates/manages| Pods
    XGBoostCtrl -->|creates/manages| Pods
    PaddleCtrl -->|creates/manages| Pods

    Controller -->|creates| Services
    Controller -->|creates| ConfigMaps
    Controller -->|creates| PodGroup

    %% External integrations
    Controller -->|communicates via| K8sAPI
    Prometheus -->|scrapes metrics| Controller
    PodGroup -->|used by| Volcano
    PodGroup -->|used by| SchedulerPlugins

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style PyTorchCtrl fill:#4a90e2,stroke:#333
    style TFCtrl fill:#4a90e2,stroke:#333
    style MPICtrl fill:#4a90e2,stroke:#333
    style MXNetCtrl fill:#4a90e2,stroke:#333
    style XGBoostCtrl fill:#4a90e2,stroke:#333
    style PaddleCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333

    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style MXJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333

    style K8sAPI fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Volcano fill:#999,stroke:#333
    style SchedulerPlugins fill:#999,stroke:#333
