graph LR
    TrainingOp[Training Operator<br/>Kubeflow Training Operator]

    %% External Dependencies (Required)
    TrainingOp -->|"platform<br/>required"| K8s[Kubernetes 1.25+]

    %% External Dependencies (Optional)
    TrainingOp -.->|"gang scheduling<br/>optional"| Volcano[Volcano v1beta1]
    TrainingOp -.->|"gang scheduling<br/>optional"| SchedulerPlugins[scheduler-plugins v1alpha1]
    TrainingOp -.->|"webhook TLS<br/>optional"| CertManager[cert-manager]
    TrainingOp -.->|"metrics<br/>optional"| Prometheus[Prometheus]

    %% Internal ODH Dependencies
    TrainingOp -->|"deployed by"| ODHOperator[opendatahub-operator]
    TrainingOp -->|"monitored by"| ODHMonitoring[ODH Monitoring<br/>PodMonitor]

    %% External Services
    TrainingOp -->|"pulls images"| ContainerRegistry[Container Registries<br/>HTTPS/443 TLS1.2+]

    %% Integration Points - Kubernetes Resources
    K8s -->|"provides"| CRDFramework[CRD Framework]
    K8s -->|"provides"| PodOrchestration[Pod Orchestration]
    K8s -->|"provides"| ServiceDiscovery[Service Discovery]

    TrainingOp -->|"creates/manages"| TrainingPods[Training Pods<br/>PyTorch/TF/MPI/etc]
    TrainingOp -->|"creates"| Services[Kubernetes Services]
    TrainingOp -->|"creates"| ConfigMaps[ConfigMaps]
    TrainingOp -->|"creates"| HPA[HorizontalPodAutoscaler<br/>PyTorch Elastic]
    TrainingOp -->|"creates"| PodGroups[PodGroup CRD<br/>Gang Scheduling]

    %% User-facing integrations
    User[Data Scientists / ML Engineers] -->|"creates jobs via"| PythonSDK[Python SDK<br/>kubeflow-training]
    PythonSDK -->|"TrainingClient API"| TrainingOp
    User -->|"kubectl apply"| TrainingOp

    %% Custom Resources
    TrainingOp -->|"watches/reconciles"| PyTorchJob[PyTorchJob CRD<br/>kubeflow.org/v1]
    TrainingOp -->|"watches/reconciles"| TFJob[TFJob CRD<br/>kubeflow.org/v1]
    TrainingOp -->|"watches/reconciles"| MPIJob[MPIJob CRD<br/>kubeflow.org/v1]
    TrainingOp -->|"watches/reconciles"| MXJob[MXJob CRD<br/>kubeflow.org/v1]
    TrainingOp -->|"watches/reconciles"| XGBoostJob[XGBoostJob CRD<br/>kubeflow.org/v1]
    TrainingOp -->|"watches/reconciles"| PaddleJob[PaddleJob CRD<br/>kubeflow.org/v1]

