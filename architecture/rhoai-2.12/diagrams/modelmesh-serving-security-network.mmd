graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Client Application]
    end

    subgraph Ingress["INGRESS (Optional - User-defined)"]
        Route["Route/Ingress<br/>443/TCP → 8008/8033<br/>Optional TLS (SIMPLE)"]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional mTLS via Istio)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            Service["modelmesh-serving Service<br/>ClusterIP<br/>8033/TCP gRPC, 8008/TCP HTTP, 2112/TCP metrics"]

            subgraph RuntimePod["ModelMesh Runtime Pod<br/>SA: modelmesh-serving-sa"]
                direction TB
                RESTProxy["REST Proxy<br/>8008/TCP HTTP"]
                ModelMesh["ModelMesh<br/>8033/TCP gRPC inference<br/>8080/TCP internal<br/>2112/TCP metrics"]
                ModelServer["Model Server<br/>MLServer/Triton/OpenVINO<br/>8001-8090/TCP gRPC"]
                Puller["Storage Puller<br/>Init/Sidecar"]

                RESTProxy -->|"8033/TCP<br/>gRPC<br/>No Auth"| ModelMesh
                ModelMesh -->|"8001-8090/TCP<br/>gRPC<br/>No Auth"| ModelServer
                Puller -->|"Shared Volume<br/>emptyDir"| ModelServer
            end

            Service -->|Forward| RESTProxy
            Service -->|Forward| ModelMesh
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph NS_System["Namespace: system (e.g., redhat-ods-applications)"]
            Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>Replicas: 1 (HA: 3)"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+"]
            MetricsSvc["controller-manager-metrics-service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]

        Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
        K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>mTLS"| Webhook
        Controller -.->|exposes| MetricsSvc
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Etcd["Etcd Service v3.x<br/>2379/TCP gRPC<br/>TLS 1.2+ (optional)<br/>mTLS/Password"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Access Keys"]
        Prometheus["Prometheus<br/>Metrics Collection"]
    end

    %% Flows
    Client -->|"HTTP/8008 or gRPC/8033<br/>No Auth (default)<br/>Optional TLS via Route"| Route
    Route -->|"HTTP/8008 or gRPC/8033<br/>No Encryption (internal)<br/>Optional Service Mesh mTLS"| Service

    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Access Keys"| S3

    Controller -->|"gRPC/2379<br/>TLS 1.2+ (optional)<br/>mTLS/Password"| Etcd

    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>ServiceAccount Token"| MetricsSvc
    Prometheus -->|"HTTP/2112<br/>No Auth"| Service

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class Service,RESTProxy,ModelMesh,ModelServer,Puller servicemesh
    class Controller,Webhook,MetricsSvc,K8sAPI controlplane
    class Etcd,S3,Prometheus externalservice
