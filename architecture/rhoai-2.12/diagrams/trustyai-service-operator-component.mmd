graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller Manager<br/>Deployment]
        Webhook[Liveness/Readiness<br/>8081/TCP]
        Controller -->|health checks| Webhook
    end

    subgraph "TrustyAI Service Instance"
        TrustyAIService[TrustyAI Service<br/>Quarkus App<br/>8080/TCP]
        OAuthProxy[OAuth Proxy Sidecar<br/>8443/TCP]
        ServiceMonitor[ServiceMonitor CR]
        Route[OpenShift Route<br/>443/TCP Reencrypt]

        OAuthProxy -->|proxies to| TrustyAIService
        ServiceMonitor -->|scrapes| TrustyAIService
        Route -->|routes to| OAuthProxy
    end

    subgraph "Storage Backends"
        PVC[PVC Storage<br/>CSV Format<br/>ReadWriteOnce]
        Database[External Database<br/>PostgreSQL/MariaDB/MySQL]
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    User[User] -->|creates| TrustyAIServiceCR
    TrustyAIServiceCR -->|watched by| Controller
    Controller -->|creates/manages| TrustyAIService
    Controller -->|creates| OAuthProxy
    Controller -->|creates| ServiceMonitor
    Controller -->|creates| Route
    Controller -->|provisions| PVC

    TrustyAIService -->|writes data| PVC
    TrustyAIService -->|writes data| Database

    subgraph "Integration Points"
        KServeIS[KServe InferenceService]
        ModelMesh[ModelMesh Serving]
        Prometheus[Prometheus]
    end

    Controller -->|patches| KServeIS
    Controller -->|patches| ModelMesh
    KServeIS -->|sends payloads| TrustyAIService
    ModelMesh -->|sends payloads| TrustyAIService
    Prometheus -->|scrapes metrics| ServiceMonitor

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP]
        OpenShiftOAuth[OpenShift OAuth<br/>443/TCP]
        CertManager[cert-manager /<br/>OpenShift Cert Service]
    end

    Controller -->|reconciles| K8sAPI
    OAuthProxy -->|validates tokens| OpenShiftOAuth
    Route -->|certificate| CertManager

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style KServeIS fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
    style OpenShiftOAuth fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
    style PVC fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Database fill:#e8e8e8,stroke:#333,stroke-width:2px
