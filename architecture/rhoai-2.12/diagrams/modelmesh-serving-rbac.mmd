graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>Namespace: system]
        SA_Runtime[modelmesh-serving-sa<br/>Namespace: user-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding]
        CRB_LeaderElection[leader-election-rolebinding]
        CRB_AuthProxy[auth-proxy-rolebinding]
    end

    subgraph "Namespace Role Bindings"
        RB_SCC[restricted-scc-rolebinding<br/>Namespace: user-namespace]
    end

    subgraph "ClusterRole Permissions"
        CR_Controller[modelmesh-controller-role]
        CR_LeaderElection[leader-election-role]
        CR_AuthProxy[auth-proxy-role]
        CR_SCC[restricted-scc-role]
    end

    subgraph "API Resources - Core"
        R_ConfigMaps[ConfigMaps<br/>core/v1]
        R_Secrets[Secrets<br/>core/v1]
        R_Services[Services<br/>core/v1]
        R_Endpoints[Endpoints<br/>core/v1]
        R_PVCs[PersistentVolumeClaims<br/>core/v1]
        R_Namespaces[Namespaces<br/>core/v1]
    end

    subgraph "API Resources - Apps"
        R_Deployments[Deployments<br/>apps/v1]
    end

    subgraph "API Resources - KServe"
        R_InferenceServices[InferenceServices<br/>serving.kserve.io/v1beta1]
        R_Predictors[Predictors<br/>serving.kserve.io/v1alpha1]
        R_ServingRuntimes[ServingRuntimes<br/>serving.kserve.io/v1alpha1]
        R_ClusterServingRuntimes[ClusterServingRuntimes<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "API Resources - Autoscaling & Monitoring"
        R_HPAs[HorizontalPodAutoscalers<br/>autoscaling/v2]
        R_ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com/v1]
    end

    subgraph "API Resources - Auth"
        R_TokenReviews[TokenReviews<br/>authentication.k8s.io/v1]
        R_SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io/v1]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_AuthProxy
    SA_Runtime -->|bound via| RB_SCC

    %% ClusterRole Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_SCC -->|grants| CR_SCC

    %% modelmesh-controller-role Permissions
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_ConfigMaps
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_Secrets
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_Services
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_Endpoints
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_PVCs
    CR_Controller -->|"get, list, watch,<br/>patch, update"| R_Namespaces
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_Deployments
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_InferenceServices
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_Predictors
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_ServingRuntimes
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_ClusterServingRuntimes
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>delete"| R_HPAs
    CR_Controller -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_ServiceMonitors

    %% leader-election-role Permissions
    CR_LeaderElection -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| R_ConfigMaps

    %% auth-proxy-role Permissions
    CR_AuthProxy -->|create| R_TokenReviews
    CR_AuthProxy -->|create| R_SubjectAccessReviews

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Runtime fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_SCC fill:#f5a623,stroke:#333,stroke-width:2px
    style R_InferenceServices fill:#7ed321,stroke:#333,stroke-width:2px
    style R_Predictors fill:#7ed321,stroke:#333,stroke-width:2px
    style R_ServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px
    style R_ClusterServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px
