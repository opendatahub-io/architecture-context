graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-operator]
    end

    subgraph "ClusterRole Bindings"
        CRB[controller-manager-rolebinding<br/>Cluster-wide]
        LEB[leader-election-rolebinding<br/>Operator namespace]
    end

    subgraph "ClusterRole Permissions"
        CR[controller-manager-role<br/>ClusterRole]
    end

    subgraph "ODH/RHOAI Custom Resources"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster, status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization, status, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        Features[features.opendatahub.io<br/>FeatureTracker, status<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Core Kubernetes Resources"
        CoreNS[Core API<br/>Namespaces, finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        CoreRes[Core API<br/>ConfigMaps, Secrets, ServiceAccounts,<br/>Services, Pods, Events<br/>Verbs: create, delete, get, list, patch, update, watch]
        Apps[apps API<br/>Deployments, ReplicaSets, StatefulSets<br/>Verbs: create, delete, get, list, patch, update, watch]
        RBAC[rbac.authorization.k8s.io<br/>ClusterRoles, ClusterRoleBindings,<br/>Roles, RoleBindings<br/>Verbs: create, delete, get, list, patch, update, watch]
        Batch[batch API<br/>Jobs, CronJobs<br/>Verbs: create, delete, get, list, patch, update, watch]
        CRDs[apiextensions.k8s.io<br/>CustomResourceDefinitions<br/>Verbs: create, delete, get, list, patch, watch]
    end

    subgraph "Networking Resources"
        Routes[route.openshift.io<br/>Routes<br/>Verbs: create, delete, get, list, patch, update, watch]
        NetPolicies[networking.k8s.io<br/>NetworkPolicies, Ingresses<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Service Mesh Resources"
        Maistra[maistra.io<br/>ServiceMeshControlPlanes,<br/>ServiceMeshMemberRolls,<br/>ServiceMeshMembers<br/>Verbs: create, get, list, patch, update, use, watch]
        IstioNet[networking.istio.io<br/>Gateways, VirtualServices, EnvoyFilters<br/>Verbs: create, delete, get, list, patch, update, watch]
        IstioSec[security.istio.io<br/>AuthorizationPolicies<br/>Verbs: create, delete, get, list, patch, update, watch]
        AuthorinoRes[authorino.kuadrant.io<br/>AuthConfigs<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "KServe / Knative Resources"
        KServeRes[serving.kserve.io<br/>InferenceServices, ServingRuntimes,<br/>ClusterServingRuntimes<br/>Verbs: create, delete, get, list, patch, update, watch]
        KnativeRes[operator.knative.dev<br/>KnativeServings<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Monitoring Resources"
        MonRes[monitoring.coreos.com<br/>ServiceMonitors, PodMonitors,<br/>PrometheusRules, Prometheuses,<br/>Alertmanagers<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Pipeline / ML Resources"
        TektonRes[tekton.dev<br/>All Tekton Resources<br/>Verbs: create, delete, get, list, patch, update, watch]
        RayRes[ray.io<br/>RayClusters, RayJobs, RayServices<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "OpenShift Resources"
        Console[console.openshift.io<br/>ConsoleLinks, ODHQuickStarts<br/>Verbs: create, delete, get, patch]
        OAuth[oauth.openshift.io<br/>OAuthClients<br/>Verbs: create, delete, get, list, patch, update, watch]
        SCC[security.openshift.io<br/>SecurityContextConstraints<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "OLM Resources"
        OLM[operators.coreos.com<br/>ClusterServiceVersions, Subscriptions<br/>Verbs: delete, get, list, update, watch]
    end

    subgraph "Webhook Resources"
        Webhooks[admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations,<br/>MutatingWebhookConfigurations<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LEB
    CRB -->|grants| CR
    LEB -->|grants| LeaderRole[leader-election-role<br/>Role]

    %% ClusterRole Permissions
    CR -->|full CRUD| DSC
    CR -->|full CRUD| DSCI
    CR -->|full CRUD| Features
    CR -->|full CRUD| CoreNS
    CR -->|full CRUD| CoreRes
    CR -->|full CRUD| Apps
    CR -->|full CRUD| RBAC
    CR -->|full CRUD| Batch
    CR -->|create, delete, get, list, patch, watch| CRDs
    CR -->|full CRUD| Routes
    CR -->|full CRUD| NetPolicies
    CR -->|create, get, list, patch, update, use, watch| Maistra
    CR -->|full CRUD| IstioNet
    CR -->|full CRUD| IstioSec
    CR -->|full CRUD| AuthorinoRes
    CR -->|full CRUD| KServeRes
    CR -->|full CRUD| KnativeRes
    CR -->|full CRUD| MonRes
    CR -->|full CRUD| TektonRes
    CR -->|full CRUD| RayRes
    CR -->|create, delete, get, patch| Console
    CR -->|full CRUD| OAuth
    CR -->|full CRUD| SCC
    CR -->|delete, get, list, update, watch| OLM
    CR -->|full CRUD| Webhooks

    %% Monitoring Service Account
    subgraph "Monitoring RBAC"
        PromSA[prometheus<br/>SA in redhat-ods-monitoring]
        PromRB[prometheus-scraper<br/>RoleBinding in component namespaces]
        PromRole[prometheus-scraper<br/>Role]

        PromSA -->|bound via| PromRB
        PromRB -->|grants| PromRole
        PromRole -->|allows scraping| MetricsEndpoints[Metrics Endpoints<br/>in component namespaces]
    end

