graph TD
    subgraph "Service Accounts"
        SA[odh-model-controller<br/>ServiceAccount<br/>Namespace: opendatahub /<br/>redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-rolebinding<br/>ClusterRoleBinding]
        CRB2[odh-model-controller-auth-proxy-rolebinding<br/>ClusterRoleBinding]
        RB[odh-model-controller-leader-election-rolebinding<br/>RoleBinding<br/>Namespace: controller namespace]
    end

    subgraph "Cluster Roles"
        CR[odh-model-controller-role<br/>ClusterRole]
        AuthProxy[auth-proxy-role<br/>ClusterRole]
        LeaderElection[leader-election-role<br/>Role]
    end

    subgraph "Core Resources"
        ConfigMaps[ConfigMaps<br/>create, delete, get,<br/>list, patch, update, watch]
        Secrets[Secrets<br/>create, delete, get,<br/>list, patch, update, watch]
        ServiceAccounts[ServiceAccounts<br/>create, delete, get,<br/>list, patch, update, watch]
        Services[Services<br/>create, delete, get,<br/>list, patch, update, watch]
        Endpoints[Endpoints<br/>create, get, list,<br/>patch, update, watch]
        Namespaces[Namespaces<br/>create, get, list,<br/>patch, update, watch]
        Pods[Pods<br/>create, get, list,<br/>patch, update, watch]
    end

    subgraph "KServe Resources"
        InferenceServices[InferenceServices<br/>serving.kserve.io<br/>get, list, update, watch]
        InferenceServiceFinalizers[InferenceServices/finalizers<br/>get, list, update, watch]
        ServingRuntimes[ServingRuntimes<br/>serving.kserve.io<br/>create, get, list,<br/>update, watch]
        ServingRuntimeFinalizers[ServingRuntimes/finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "Istio Resources"
        VirtualServices[VirtualServices<br/>networking.istio.io<br/>create, delete, get, list,<br/>patch, update, watch]
        VirtualServiceFinalizers[VirtualServices/finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        Gateways[Gateways<br/>networking.istio.io<br/>get, list, patch,<br/>update, watch]
        PeerAuthentications[PeerAuthentications<br/>security.istio.io<br/>create, delete, get, list,<br/>patch, update, watch]
        AuthorizationPolicies[AuthorizationPolicies<br/>security.istio.io<br/>get, list]
        Telemetries[Telemetries<br/>telemetry.istio.io<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "Service Mesh Resources"
        ServiceMeshMembers[ServiceMeshMembers<br/>maistra.io<br/>create, delete, get, list,<br/>patch, update, watch]
        ServiceMeshMemberRolls[ServiceMeshMemberRolls<br/>maistra.io<br/>get, list, watch]
        ServiceMeshControlPlanes[ServiceMeshControlPlanes<br/>maistra.io<br/>get, list, use, watch]
    end

    subgraph "OpenShift Resources"
        Routes[Routes<br/>route.openshift.io<br/>create, delete, get, list,<br/>patch, update, watch]
        RoutesCustomHost[Routes/custom-host<br/>route.openshift.io<br/>create]
    end

    subgraph "Networking Resources"
        NetworkPolicies[NetworkPolicies<br/>networking.k8s.io<br/>create, delete, get, list,<br/>patch, update, watch]
        Ingresses[Ingresses<br/>networking.k8s.io, extensions<br/>get, list, watch]
    end

    subgraph "Monitoring Resources"
        ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com<br/>create, delete, get, list,<br/>patch, update, watch]
        PodMonitors[PodMonitors<br/>monitoring.coreos.com<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "Authorino Resources"
        AuthConfigs[AuthConfigs<br/>authorino.kuadrant.io<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "ODH Platform Resources"
        DataScienceClusters[DataScienceClusters<br/>datasciencecluster.opendatahub.io<br/>get, list, watch]
        DSCInitializations[DSCInitializations<br/>dscinitialization.opendatahub.io<br/>get, list, watch]
    end

    subgraph "RBAC Resources"
        ClusterRoleBindings[ClusterRoleBindings<br/>rbac.authorization.k8s.io<br/>create, delete, get, list,<br/>patch, update, watch]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "Auth Proxy Permissions"
        TokenReviews[TokenReviews<br/>authentication.k8s.io<br/>create]
        SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io<br/>create]
    end

    subgraph "Leader Election Resources"
        LeaderElectionConfigMaps[ConfigMaps<br/>Leases<br/>get, create, update]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| AuthProxy
    RB -->|grants| LeaderElection

    %% ClusterRole Permissions - Core
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Secrets
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Services
    CR -->|permissions| Endpoints
    CR -->|permissions| Namespaces
    CR -->|permissions| Pods

    %% ClusterRole Permissions - KServe
    CR -->|permissions| InferenceServices
    CR -->|permissions| InferenceServiceFinalizers
    CR -->|permissions| ServingRuntimes
    CR -->|permissions| ServingRuntimeFinalizers

    %% ClusterRole Permissions - Istio
    CR -->|permissions| VirtualServices
    CR -->|permissions| VirtualServiceFinalizers
    CR -->|permissions| Gateways
    CR -->|permissions| PeerAuthentications
    CR -->|permissions| AuthorizationPolicies
    CR -->|permissions| Telemetries

    %% ClusterRole Permissions - Service Mesh
    CR -->|permissions| ServiceMeshMembers
    CR -->|permissions| ServiceMeshMemberRolls
    CR -->|permissions| ServiceMeshControlPlanes

    %% ClusterRole Permissions - OpenShift
    CR -->|permissions| Routes
    CR -->|permissions| RoutesCustomHost

    %% ClusterRole Permissions - Networking
    CR -->|permissions| NetworkPolicies
    CR -->|permissions| Ingresses

    %% ClusterRole Permissions - Monitoring
    CR -->|permissions| ServiceMonitors
    CR -->|permissions| PodMonitors

    %% ClusterRole Permissions - Authorino
    CR -->|permissions| AuthConfigs

    %% ClusterRole Permissions - ODH Platform
    CR -->|permissions| DataScienceClusters
    CR -->|permissions| DSCInitializations

    %% ClusterRole Permissions - RBAC
    CR -->|permissions| ClusterRoleBindings
    CR -->|permissions| RoleBindings

    %% Auth Proxy Role Permissions
    AuthProxy -->|permissions| TokenReviews
    AuthProxy -->|permissions| SubjectAccessReviews

    %% Leader Election Role Permissions
    LeaderElection -->|permissions| LeaderElectionConfigMaps

