graph TB
    subgraph "CodeFlare Operator"
        Manager[codeflare-operator-manager<br/>Deployment]
        RayController[RayCluster Controller]
        AppWrapperController["AppWrapper Controller<br/>Optional"]
        MutatingWebhook[Mutating Webhook<br/>9443/TCP HTTPS]
        ValidatingWebhook[Validating Webhook<br/>9443/TCP HTTPS]
        CertManager[Certificate Manager<br/>cert-controller]

        Manager --> RayController
        Manager --> AppWrapperController
        Manager --> MutatingWebhook
        Manager --> ValidatingWebhook
        Manager --> CertManager
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1<br/>KubeRay]
        AppWrapperCR[AppWrapper CR<br/>workload.codeflare.dev/v1beta2]
    end

    subgraph "Created Resources"
        Services["Services<br/>RayCluster Head and Worker"]
        Secrets["Secrets<br/>CA, OAuth TLS, Webhook Certs"]
        NetworkPolicies[NetworkPolicies<br/>Ray Communication]
        IngressRoute["Ingress or Route<br/>Dashboard Access"]
        ServiceAccounts[ServiceAccounts<br/>OAuth Proxy]
    end

    subgraph "External Dependencies"
        KubeRay[KubeRay Operator<br/>v1.1.1]
        Kueue[Kueue<br/>v0.7.0 ODH fork]
        CertController["cert-manager or<br/>OCP cert-controller"]
        Istio["Istio Service Mesh<br/>Optional"]
    end

    subgraph "Internal ODH RHOAI Dependencies"
        ODHOperator[opendatahub-operator<br/>DSCInitialization]
        Prometheus[Prometheus<br/>ServiceMonitor]
        OpenShiftOAuth[OpenShift OAuth<br/>Dashboard Auth]
        OpenShiftRoutes[OpenShift Routes API<br/>route.openshift.io/v1]
    end

    User["User<br/>kubectl or oc"] -->|creates| RayClusterCR
    User -->|creates| AppWrapperCR

    RayClusterCR -->|watched by| KubeRay
    RayClusterCR -->|mutated by| MutatingWebhook
    RayClusterCR -->|validated by| ValidatingWebhook
    RayClusterCR -->|reconciled by| RayController

    AppWrapperCR -->|mutated by| MutatingWebhook
    AppWrapperCR -->|validated by| ValidatingWebhook
    AppWrapperCR -->|reconciled by| AppWrapperController

    RayController -->|creates| Services
    RayController -->|creates| Secrets
    RayController -->|creates| NetworkPolicies
    RayController -->|creates| IngressRoute
    RayController -->|creates| ServiceAccounts

    AppWrapperController -->|creates| KueueWorkload[Kueue Workload CR]
    KueueWorkload -->|managed by| Kueue

    CertManager -->|manages| Secrets
    CertController -->|provisions| Secrets

    Manager -->|watches| ODHOperator
    Manager -->|exports to| Prometheus

    MutatingWebhook -->|injects| OAuthProxy[OAuth Proxy Sidecar]
    MutatingWebhook -->|injects| mTLSInit[mTLS Init Containers]

    OAuthProxy -->|authenticates via| OpenShiftOAuth
    IngressRoute -->|uses| OpenShiftRoutes

    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px
    style RayController fill:#4a90e2,stroke:#333
    style AppWrapperController fill:#4a90e2,stroke:#333
    style MutatingWebhook fill:#f5a623,stroke:#333
    style ValidatingWebhook fill:#f5a623,stroke:#333
    style RayClusterCR fill:#7ed321,stroke:#333
    style AppWrapperCR fill:#7ed321,stroke:#333
    style KubeRay fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style CertController fill:#999,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style OpenShiftOAuth fill:#7ed321,stroke:#333
    style OpenShiftRoutes fill:#7ed321,stroke:#333
