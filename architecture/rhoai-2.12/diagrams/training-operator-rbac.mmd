graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[training-operator<br/>ClusterRole]
    end

    subgraph "User-Facing Roles"
        EditRole[training-edit<br/>ClusterRole]
        ViewRole[training-view<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Pods[Pods<br/>core/v1]
        PodsExec[Pods/exec<br/>core/v1]
        Services[Services<br/>core/v1]
        ConfigMaps[ConfigMaps<br/>core/v1]
        Events[Events<br/>core/v1]
        ServiceAccounts[ServiceAccounts<br/>core/v1]
    end

    subgraph "Training Job CRDs"
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v1]
        MXJob[MXJob<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob<br/>kubeflow.org/v1]
    end

    subgraph "Status Subresources"
        PyTorchJobStatus[PyTorchJob/status<br/>kubeflow.org/v1]
        TFJobStatus[TFJob/status<br/>kubeflow.org/v1]
        MPIJobStatus[MPIJob/status<br/>kubeflow.org/v1]
        MXJobStatus[MXJob/status<br/>kubeflow.org/v1]
        XGBoostJobStatus[XGBoostJob/status<br/>kubeflow.org/v1]
        PaddleJobStatus[PaddleJob/status<br/>kubeflow.org/v1]
    end

    subgraph "Finalizers"
        PyTorchJobFinalizers[PyTorchJob/finalizers<br/>kubeflow.org/v1]
        TFJobFinalizers[TFJob/finalizers<br/>kubeflow.org/v1]
        MPIJobFinalizers[MPIJob/finalizers<br/>kubeflow.org/v1]
        MXJobFinalizers[MXJob/finalizers<br/>kubeflow.org/v1]
        XGBoostJobFinalizers[XGBoostJob/finalizers<br/>kubeflow.org/v1]
        PaddleJobFinalizers[PaddleJob/finalizers<br/>kubeflow.org/v1]
    end

    subgraph "Autoscaling Resources"
        HPA[HorizontalPodAutoscaler<br/>autoscaling/v2]
    end

    subgraph "RBAC Resources"
        Roles[Roles<br/>rbac.authorization.k8s.io/v1]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io/v1]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPodGroup[PodGroup<br/>scheduling.volcano.sh/v1beta1]
        SchedulerPluginsPodGroup[PodGroup<br/>scheduling.x-k8s.io/v1alpha1]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Operator permissions - Core resources
    CR -->|create, delete, get, list,<br/>patch, update, watch| Pods
    CR -->|create| PodsExec
    CR -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR -->|create, delete, get, list,<br/>patch, update, watch| ConfigMaps
    CR -->|create, delete, get, list,<br/>patch, update, watch| Events
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts

    %% Operator permissions - Training CRDs
    CR -->|create, delete, get, list,<br/>patch, update, watch| PyTorchJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| TFJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| MPIJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| MXJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| XGBoostJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| PaddleJob

    %% Operator permissions - Status subresources
    CR -->|get, patch, update| PyTorchJobStatus
    CR -->|get, patch, update| TFJobStatus
    CR -->|get, patch, update| MPIJobStatus
    CR -->|get, patch, update| MXJobStatus
    CR -->|get, patch, update| XGBoostJobStatus
    CR -->|get, patch, update| PaddleJobStatus

    %% Operator permissions - Finalizers
    CR -->|update| PyTorchJobFinalizers
    CR -->|update| TFJobFinalizers
    CR -->|update| MPIJobFinalizers
    CR -->|update| MXJobFinalizers
    CR -->|update| XGBoostJobFinalizers
    CR -->|update| PaddleJobFinalizers

    %% Operator permissions - Autoscaling
    CR -->|create, delete, get, list,<br/>patch, update, watch| HPA

    %% Operator permissions - RBAC
    CR -->|create, list, update, watch| Roles
    CR -->|create, list, update, watch| RoleBindings

    %% Operator permissions - Gang scheduling
    CR -->|create, delete, get, list,<br/>patch, update, watch| VolcanoPodGroup
    CR -->|create, delete, get, list,<br/>patch, update, watch| SchedulerPluginsPodGroup

    %% User-facing roles - Edit
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| PyTorchJob
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| TFJob
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| MPIJob
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| MXJob
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| XGBoostJob
    EditRole -->|create, delete, get, list,<br/>patch, update, watch| PaddleJob
    EditRole -->|get| PyTorchJobStatus
    EditRole -->|get| TFJobStatus
    EditRole -->|get| MPIJobStatus
    EditRole -->|get| MXJobStatus
    EditRole -->|get| XGBoostJobStatus
    EditRole -->|get| PaddleJobStatus

    %% User-facing roles - View
    ViewRole -->|get, list, watch| PyTorchJob
    ViewRole -->|get, list, watch| TFJob
    ViewRole -->|get, list, watch| MPIJob
    ViewRole -->|get, list, watch| MXJob
    ViewRole -->|get, list, watch| XGBoostJob
    ViewRole -->|get, list, watch| PaddleJob
    ViewRole -->|get| PyTorchJobStatus
    ViewRole -->|get| TFJobStatus
    ViewRole -->|get| MPIJobStatus
    ViewRole -->|get| MXJobStatus
    ViewRole -->|get| XGBoostJobStatus
    ViewRole -->|get| PaddleJobStatus

