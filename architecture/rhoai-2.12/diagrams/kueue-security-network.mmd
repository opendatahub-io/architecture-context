graph TB
    subgraph External["EXTERNAL - User Access"]
        User[User/Application]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Auth: Bearer Token / Client Cert"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE - opendatahub"]
        direction TB

        subgraph Controller["kueue-controller-manager - Deployment"]
            direction LR
            ControllerPod["Controller Pod<br/>UID: 65532:65532<br/>UBI9 Image<br/>CPU: 500m / Mem: 512Mi"]
        end

        subgraph Services["Network Services"]
            WebhookSvc["kueue-webhook-service<br/>ClusterIP 443→9443/TCP<br/>HTTPS TLS mTLS<br/>Cert: kueue-webhook-server-cert"]
            MetricsSvcUnauth["kueue-metrics-service<br/>ClusterIP 8080/TCP<br/>HTTP - no auth"]
            MetricsSvcAuth["kueue-controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS TLS1.2+ Bearer Token<br/>kube-rbac-proxy"]
            VisibilitySvc["kueue-visibility-server<br/>ClusterIP 443→8082/TCP<br/>HTTPS TLS RBAC<br/>Cert: kueue-visibility-server-cert"]
        end

        subgraph HealthProbes["Health Endpoints"]
            Health["8081/TCP HTTP<br/>/healthz, /readyz<br/>No auth - internal"]
        end

        ControllerPod -->|serves| WebhookSvc
        ControllerPod -->|serves| MetricsSvcUnauth
        ControllerPod -->|serves| MetricsSvcAuth
        ControllerPod -->|serves| VisibilitySvc
        ControllerPod -->|exposes| Health
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        CertMgr["cert-manager<br/>TLS Certificate Provisioning<br/>Auto-rotation"]
        Prometheus["Prometheus<br/>Metrics Collection"]
        Autoscaler["Cluster Autoscaler<br/>autoscaling.x-k8s.io<br/>ProvisioningRequests"]
    end

    subgraph Workloads["INTEGRATED WORKLOAD TYPES"]
        Jobs["Kubernetes Jobs<br/>batch/v1"]
        KubeflowJobs["TFJob, PyTorchJob, MPIJob<br/>kubeflow.org"]
        RayJobs["RayJob, RayCluster<br/>ray.io"]
        JobSets["JobSet<br/>jobset.x-k8s.io"]
    end

    subgraph CustomResources["KUEUE CUSTOM RESOURCES"]
        ClusterQueue["ClusterQueue<br/>kueue.x-k8s.io/v1beta1"]
        LocalQueue["LocalQueue<br/>kueue.x-k8s.io/v1beta1"]
        WorkloadCRD["Workload<br/>kueue.x-k8s.io/v1beta1"]
        ResourceFlavor["ResourceFlavor<br/>kueue.x-k8s.io/v1beta1"]
    end

    %% User flows
    User -->|HTTPS 6443<br/>Bearer Token| K8sAPI
    User -->|Query visibility API<br/>via K8s proxy| K8sAPI

    %% API Server to webhook
    K8sAPI -->|Admission webhook<br/>HTTPS 9443 mTLS<br/>on Job creation| WebhookSvc

    %% Controller to API Server
    ControllerPod -->|Watch/List/Update<br/>HTTPS 6443 TLS1.2+<br/>ServiceAccount Token| K8sAPI

    %% Controller to autoscaler
    ControllerPod -->|Create ProvisioningRequest<br/>HTTPS 6443 TLS1.2+<br/>ServiceAccount Token| Autoscaler

    %% API Server to visibility
    K8sAPI -->|Proxy requests<br/>HTTPS 8082 TLS<br/>SA delegation| VisibilitySvc

    %% Metrics collection
    Prometheus -->|Scrape metrics<br/>HTTP 8080 - no auth| MetricsSvcUnauth
    Prometheus -.->|Scrape metrics<br/>HTTPS 8443 - Bearer| MetricsSvcAuth

    %% Certificate provisioning
    CertMgr -->|Provision TLS certs<br/>Auto-rotate| WebhookSvc
    CertMgr -->|Provision TLS certs<br/>Auto-rotate| VisibilitySvc

    %% Workload integration
    Jobs -->|Intercepted by webhook| WebhookSvc
    KubeflowJobs -->|Intercepted by webhook| WebhookSvc
    RayJobs -->|Intercepted by webhook| WebhookSvc
    JobSets -->|Intercepted by webhook| WebhookSvc

    %% Controller manages CRDs
    ControllerPod -->|Creates/Updates| WorkloadCRD
    ControllerPod -->|Evaluates quota| ClusterQueue
    ControllerPod -->|Watches| LocalQueue
    ControllerPod -->|Uses| ResourceFlavor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef services fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef externaldep fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workloads fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef crds fill:#f5a623,stroke:#333,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class ControllerPod,Controller,Services,HealthProbes,KueueNamespace kueuens
    class WebhookSvc,MetricsSvcUnauth,MetricsSvcAuth,VisibilitySvc services
    class CertMgr,Prometheus,Autoscaler externaldep
    class Jobs,KubeflowJobs,RayJobs,JobSets workloads
    class ClusterQueue,LocalQueue,WorkloadCRD,ResourceFlavor crds
