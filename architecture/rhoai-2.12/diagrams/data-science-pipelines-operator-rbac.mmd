graph TD
    subgraph "Operator Namespace Service Accounts"
        SA_Operator[controller-manager]
    end

    subgraph "DSPA Instance Service Accounts"
        SA_API["ds-pipeline-(name)"]
        SA_Argo[argo]
        SA_Persistence["ds-pipeline-persistenceagent-(name)"]
        SA_Scheduled["ds-pipeline-scheduledworkflow-(name)"]
        SA_UI["ds-pipeline-ui-(name)"]
    end

    subgraph "Cluster Roles"
        CR_Manager[manager-role<br/>Full DSPA lifecycle management]
        CR_LeaderElection[leader-election-role<br/>Operator HA]
        CR_AggregateEdit[aggregate-dspa-edit<br/>DSPA create/update/delete]
        CR_AggregateView[aggregate-dspa-view<br/>DSPA read-only]
    end

    subgraph "Namespace Roles (per DSPA)"
        R_Argo[argo-role<br/>Workflow management]
        R_Persistence[ds-pipeline-persistenceagent-role<br/>Workflow status sync]
        R_Scheduled[ds-pipeline-scheduledworkflow-role<br/>Scheduled workflow mgmt]
        R_UI[ds-pipeline-ui-role<br/>UI operations]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager[role-binding]
        CRB_LeaderElection[leader-election-role-binding]
    end

    subgraph "Namespace Role Bindings (per DSPA)"
        RB_Argo[argo-role-binding]
        RB_Persistence[ds-pipeline-persistenceagent-binding]
        RB_Scheduled[ds-pipeline-scheduledworkflow-binding]
        RB_UI[ds-pipeline-ui-binding]
    end

    subgraph "API Resources - DSPA"
        API_DSPA[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication<br/>ScheduledWorkflow]
    end

    subgraph "API Resources - Workflows"
        API_Argo[argoproj.io<br/>Workflow, WorkflowTaskResult<br/>WorkflowTemplate, CronWorkflow]
        API_Tekton[tekton.dev<br/>Pipeline, PipelineRun<br/>Task, TaskRun]
    end

    subgraph "API Resources - Core Kubernetes"
        API_Core[Core Resources<br/>Pod, ConfigMap, Secret<br/>Service, ServiceAccount<br/>PersistentVolumeClaim<br/>Event]
        API_Apps[apps<br/>Deployment<br/>ReplicaSet]
        API_Batch[batch<br/>Job]
        API_RBAC[rbac.authorization.k8s.io<br/>Role, RoleBinding<br/>ClusterRole, ClusterRoleBinding]
        API_Network[networking.k8s.io<br/>NetworkPolicy<br/>Ingress]
    end

    subgraph "API Resources - OpenShift"
        API_Route[route.openshift.io<br/>Route]
        API_Image[image.openshift.io<br/>ImageStreamTag]
    end

    subgraph "API Resources - Monitoring"
        API_Monitor[monitoring.coreos.com<br/>ServiceMonitor]
    end

    subgraph "API Resources - Other ML Components"
        API_Kubeflow[kubeflow.org<br/>*]
        API_Seldon[machinelearning.seldon.io<br/>SeldonDeployment]
        API_Ray[ray.io<br/>RayCluster, RayJob, RayService]
        API_CodeFlare[workload.codeflare.dev<br/>AppWrapper]
        API_Snapshot[snapshot.storage.k8s.io<br/>VolumeSnapshot]
    end

    %% Operator SA to Cluster Role Bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_LeaderElection

    %% Cluster Role Bindings to Cluster Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| CR_LeaderElection

    %% DSPA Instance SA to Role Bindings
    SA_Argo -->|bound via| RB_Argo
    SA_Persistence -->|bound via| RB_Persistence
    SA_Scheduled -->|bound via| RB_Scheduled
    SA_UI -->|bound via| RB_UI

    %% Role Bindings to Roles
    RB_Argo -->|grants| R_Argo
    RB_Persistence -->|grants| R_Persistence
    RB_Scheduled -->|grants| R_Scheduled
    RB_UI -->|grants| R_UI

    %% Manager Role Permissions (Cluster-wide)
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_DSPA
    CR_Manager -->|create,delete,get,list,patch,update,watch,*| API_Apps
    CR_Manager -->|create,delete,get,list,patch,update,watch,*| API_Core
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_Route
    CR_Manager -->|create,delete,get,list,update,watch,patch| API_RBAC
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_Network
    CR_Manager -->|*,create,patch| API_Argo
    CR_Manager -->|*| API_Tekton
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_Monitor
    CR_Manager -->|*| API_Batch
    CR_Manager -->|get| API_Image
    CR_Manager -->|*| API_Kubeflow
    CR_Manager -->|*| API_Seldon
    CR_Manager -->|create,delete,get,list,patch| API_Ray
    CR_Manager -->|create,delete,deletecollection,get,list,patch,update,watch| API_CodeFlare
    CR_Manager -->|create,delete,get| API_Snapshot

    %% Leader Election Role Permissions
    CR_LeaderElection -->|get,list,watch,create,update,patch,delete| API_Core

    %% Argo Role Permissions (Namespace-scoped)
    R_Argo -->|*| API_Argo
    R_Argo -->|*| API_Core

    %% Aggregate Roles
    CR_AggregateEdit -->|create,delete,deletecollection,get,list,patch,update,watch| API_DSPA
    CR_AggregateView -->|get,list,watch| API_DSPA

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_API fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Argo fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Persistence fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Scheduled fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_UI fill:#4a90e2,stroke:#333,stroke-width:2px

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AggregateEdit fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AggregateView fill:#f5a623,stroke:#333,stroke-width:2px

    style R_Argo fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Persistence fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Scheduled fill:#f5a623,stroke:#333,stroke-width:2px
    style R_UI fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB_Manager fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB_LeaderElection fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB_Argo fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB_Persistence fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB_Scheduled fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB_UI fill:#e8e8e8,stroke:#333,stroke-width:1px

    style API_DSPA fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Argo fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Tekton fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Core fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Apps fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Batch fill:#7ed321,stroke:#333,stroke-width:2px
    style API_RBAC fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Network fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Route fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Image fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Monitor fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Kubeflow fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Seldon fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Ray fill:#7ed321,stroke:#333,stroke-width:2px
    style API_CodeFlare fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Snapshot fill:#7ed321,stroke:#333,stroke-width:2px
