graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.3"]
        Route["TrustyAI Route<br/>443/TCP HTTPS<br/>Reencrypt Mode"]
    end

    subgraph AppLayer["APPLICATION LAYER (OAuth Protected)"]
        direction TB

        subgraph NS_TrustyAI["Namespace: {namespace}"]
            direction TB

            subgraph Pod_TrustyAI["TrustyAI Service Pod"]
                OAuthProxy["OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS<br/>SA: {instance}-proxy<br/>Image: ose-oauth-proxy"]
                TrustyAIApp["TrustyAI Service<br/>Port: 8080/TCP HTTP<br/>UID: 65532 (non-root)<br/>Caps: ALL dropped<br/>Image: trustyai-service"]
            end

            Service_TLS["Service: {instance}-tls<br/>443/TCP → 8443/TCP<br/>Service Serving Cert"]
            Service_Internal["Service: {instance}<br/>80/TCP → 8080/TCP<br/>443/TCP → 4443/TCP"]
        end
    end

    subgraph Storage["STORAGE LAYER"]
        PVC["PVC Storage<br/>ReadWriteOnce<br/>CSV Format"]
        Database["External Database<br/>PostgreSQL/MariaDB/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ optional<br/>Auth: DB Credentials"]
    end

    subgraph Monitoring["MONITORING & METRICS"]
        ServiceMonitor["ServiceMonitor CR<br/>/q/metrics endpoint"]
        Prometheus["Prometheus<br/>80/TCP HTTP<br/>Scrape interval: 4s"]
    end

    subgraph Integration["INTEGRATION POINTS (Service Mesh)"]
        KServe["KServe InferenceService<br/>443/TCP HTTPS<br/>TLS 1.2+ mTLS"]
        ModelMesh["ModelMesh Serving<br/>443/TCP HTTPS<br/>TLS 1.2+ mTLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth Client Auth"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        CertService["OpenShift Cert Service<br/>Service Serving Cert"]
    end

    subgraph Operator["OPERATOR CONTROL PLANE"]
        OperatorPod["TrustyAI Operator<br/>Namespace: {operator-namespace}<br/>SA: controller-manager<br/>Image: trustyai-service-operator"]
        TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1"]
    end

    %% External User Flow
    Client -->|HTTPS/443<br/>TLS 1.3| Router
    Router -->|HTTPS/443<br/>Reencrypt| Route
    Route -->|HTTPS/443<br/>Service Serving Cert| Service_TLS
    Service_TLS -->|HTTPS/8443| OAuthProxy

    %% OAuth Validation
    OAuthProxy <-->|HTTPS/443<br/>TLS 1.2+<br/>Token Validation| OAuthServer

    %% Internal Request Flow
    OAuthProxy -->|HTTP/8080<br/>localhost<br/>Token Validated| TrustyAIApp

    %% Storage
    TrustyAIApp -->|Filesystem| PVC
    TrustyAIApp -->|PostgreSQL/MySQL<br/>TLS 1.2+ optional<br/>DB Credentials| Database

    %% Metrics
    Service_Internal -->|HTTP/80| TrustyAIApp
    ServiceMonitor -->|monitors| Service_Internal
    Prometheus -->|HTTP/80<br/>scrapes| ServiceMonitor

    %% Integration
    KServe -->|HTTPS/443<br/>TLS 1.2+ mTLS<br/>Inference Payloads| TrustyAIApp
    ModelMesh -->|HTTPS/443<br/>TLS 1.2+ mTLS<br/>Payload Data| TrustyAIApp

    %% Operator Flow
    OperatorPod -->|watches/reconciles| TrustyAIServiceCR
    OperatorPod -->|HTTPS/443<br/>ServiceAccount Token| K8sAPI
    OperatorPod -.->|creates| Pod_TrustyAI
    OperatorPod -.->|creates| Service_TLS
    OperatorPod -.->|creates| Service_Internal
    OperatorPod -.->|creates| Route
    OperatorPod -.->|creates| ServiceMonitor
    OperatorPod -.->|patches| KServe
    OperatorPod -.->|patches| ModelMesh

    %% Certificate Management
    CertService -.->|provisions| Service_TLS
    CertService -.->|provisions| Service_Internal

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#d4e1f5,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Router,Route ingress
    class OAuthProxy,TrustyAIApp,Service_TLS,Service_Internal app
    class PVC,Database storage
    class ServiceMonitor,Prometheus monitoring
    class KServe,ModelMesh integration
    class OAuthServer,K8sAPI,CertService externalservice
    class OperatorPod,TrustyAIServiceCR operator
