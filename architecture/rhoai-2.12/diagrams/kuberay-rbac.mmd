graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>Namespace: operator-ns]
        RaySA["{raycluster-name}-sa<br/>Namespace: user-ns<br/>(Auto-created)"]
    end

    subgraph "Cluster-Level RBAC"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "Namespace-Level RBAC"
        LeaderRB[leader-election-role-binding<br/>RoleBinding<br/>Namespace: operator-ns]
        LeaderRole[leader-election-role<br/>Role<br/>Namespace: operator-ns]
        RayRB["{raycluster-name}-rb<br/>RoleBinding<br/>Namespace: user-ns<br/>(Auto-created)"]
        RayRole["{raycluster-name}-role<br/>Role<br/>Namespace: user-ns<br/>(Auto-created)"]
    end

    subgraph "API Resources - Core"
        Pods["Pods, Pods/Status<br/>API: core/v1"]
        Services["Services, Services/Status<br/>API: core/v1"]
        ServiceAccounts["ServiceAccounts<br/>API: core/v1"]
        Events["Events<br/>API: core/v1"]
        Endpoints["Endpoints<br/>API: core/v1"]
    end

    subgraph "API Resources - Batch"
        Jobs["Jobs<br/>API: batch/v1"]
    end

    subgraph "API Resources - Networking"
        Ingresses["Ingresses, IngressClasses<br/>API: networking.k8s.io/v1<br/>extensions/v1beta1"]
    end

    subgraph "API Resources - Ray CRDs"
        RayClusters["RayClusters<br/>RayClusters/Status<br/>RayClusters/Finalizers<br/>API: ray.io/v1"]
        RayJobs["RayJobs<br/>RayJobs/Status<br/>RayJobs/Finalizers<br/>API: ray.io/v1"]
        RayServices["RayServices<br/>RayServices/Status<br/>RayServices/Finalizers<br/>API: ray.io/v1"]
    end

    subgraph "API Resources - RBAC"
        Roles["Roles, RoleBindings<br/>API: rbac.authorization.k8s.io/v1"]
    end

    subgraph "API Resources - OpenShift"
        Routes["Routes<br/>API: route.openshift.io/v1"]
    end

    subgraph "API Resources - Coordination"
        Leases["Leases<br/>API: coordination.k8s.io/v1"]
    end

    %% ClusterRole Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% ClusterRole Permissions
    CR -->|create, delete, get, list, patch, update, watch| Jobs
    CR -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| Pods
    CR -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR -->|create, delete, get, list, watch| ServiceAccounts
    CR -->|create, delete, get, list,<br/>patch, update, watch| Events
    CR -->|get, list| Endpoints
    CR -->|create, delete, get, list,<br/>patch, update, watch| Ingresses
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayClusters
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayJobs
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayServices
    CR -->|create, delete, get, list,<br/>update, watch| Roles
    CR -->|create, delete, get, list,<br/>patch, update, watch| Routes
    CR -->|create, get, list, update| Leases

    %% Leader Election Role Binding
    SA -->|bound via| LeaderRB
    LeaderRB -->|grants| LeaderRole
    LeaderRole -->|create, get, list, update| Leases

    %% Ray Cluster ServiceAccount (Auto-created)
    RaySA -.->|bound via| RayRB
    RayRB -.->|grants| RayRole
    RayRole -.->|permissions for<br/>Ray workloads| Pods

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style RaySA fill:#85bbf0,stroke:#333,stroke-dasharray: 5 5

    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style LeaderRB fill:#f5a623,stroke:#333
    style LeaderRole fill:#f5a623,stroke:#333

    style RayRB fill:#dae8fc,stroke:#333,stroke-dasharray: 5 5
    style RayRole fill:#dae8fc,stroke:#333,stroke-dasharray: 5 5

    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style Endpoints fill:#7ed321,stroke:#333

    style Jobs fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333

    style RayClusters fill:#bd10e0,stroke:#333,stroke-width:2px
    style RayJobs fill:#bd10e0,stroke:#333,stroke-width:2px
    style RayServices fill:#bd10e0,stroke:#333,stroke-width:2px

    style Roles fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
