graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kueue-leader-election-rolebinding<br/>RoleBinding in opendatahub]
    end

    subgraph "ClusterRole: kueue-manager-role"
        direction TB
        CR[kueue-manager-role]

        CoreAPI["Core API - empty string<br/>events, limitranges, namespaces,<br/>pods, pods/finalizers, pods/status,<br/>podtemplates, secrets"]
        AdmissionReg["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations"]
        AutoscalingAPI["autoscaling.x-k8s.io<br/>provisioningrequests,<br/>provisioningrequests/status"]
        BatchAPI["batch<br/>jobs, jobs/status, jobs/finalizers"]
        JobSetAPI["jobset.x-k8s.io<br/>jobsets, jobsets/status,<br/>jobsets/finalizers"]
        KubeflowAPI["kubeflow.org<br/>mpijobs, pytorchjobs, tfjobs,<br/>xgboostjobs, mxjobs, paddlejobs<br/>all with /status, /finalizers"]
        RayAPI["ray.io<br/>rayjobs, rayjobs/status,<br/>rayjobs/finalizers,<br/>rayclusters, rayclusters/status,<br/>rayclusters/finalizers"]
        KueueAPI["kueue.x-k8s.io<br/>admissionchecks, clusterqueues,<br/>localqueues, workloads,<br/>resourceflavors, workloadpriorityclasses,<br/>provisioningrequestconfigs,<br/>multikueueclusters, multikueueconfigs<br/>all with /status, /finalizers"]

        CR -->|grants access to| CoreAPI
        CR -->|grants access to| AdmissionReg
        CR -->|grants access to| AutoscalingAPI
        CR -->|grants access to| BatchAPI
        CR -->|grants access to| JobSetAPI
        CR -->|grants access to| KubeflowAPI
        CR -->|grants access to| RayAPI
        CR -->|grants access to| KueueAPI
    end

    subgraph "User-Facing Roles (RBAC for users)"
        direction LR
        BatchAdmin[kueue-batch-admin-role<br/>ClusterRole - Aggregated<br/>All verbs on Kueue resources]
        BatchUser[kueue-batch-user-role<br/>ClusterRole<br/>get, list, create on<br/>localqueues, workloads]

        CQViewer[kueue-clusterqueue-viewer-role<br/>get, list, watch clusterqueues]
        CQEditor[kueue-clusterqueue-editor-role<br/>create, delete, get, list, patch,<br/>update, watch clusterqueues]

        LQViewer[kueue-localqueue-viewer-role<br/>get, list, watch localqueues]
        LQEditor[kueue-localqueue-editor-role<br/>create, delete, get, list, patch,<br/>update, watch localqueues]

        WorkloadViewer[kueue-workload-viewer-role<br/>get, list, watch workloads]
        WorkloadEditor[kueue-workload-editor-role<br/>create, delete, get, list, patch,<br/>update, watch workloads]

        RFViewer[kueue-resourceflavor-viewer-role<br/>get, list, watch resourceflavors]
        RFEditor[kueue-resourceflavor-editor-role<br/>create, delete, get, list, patch,<br/>update, watch resourceflavors]
    end

    subgraph "User Assignments"
        DefaultSA[default ServiceAccount<br/>Namespace: opendatahub]
        UserBinding[kueue-batch-user-rolebinding<br/>RoleBinding in opendatahub]

        DefaultSA -->|bound via| UserBinding
        UserBinding -->|grants| BatchUser
    end

    %% Main flow
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    CRB1 -->|grants| CR
    CRB2 -->|grants| LeaderElection[kueue-leader-election-role<br/>RoleBinding for leader election]

    %% Verbs annotation
    CoreAPI -.->|Verbs| Verbs1[create, delete, get, list,<br/>patch, update, watch]
    BatchAPI -.->|Verbs| Verbs2[get, list, watch, update,<br/>patch, delete]
    KueueAPI -.->|Verbs| Verbs3[create, delete, get, list,<br/>patch, update, watch]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB2 fill:#7ed321,stroke:#333,stroke-width:2px
    style CoreAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style BatchAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style KueueAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style KubeflowAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RayAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style BatchAdmin fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style BatchUser fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style DefaultSA fill:#d5e8d4,stroke:#82b366,stroke-width:2px
