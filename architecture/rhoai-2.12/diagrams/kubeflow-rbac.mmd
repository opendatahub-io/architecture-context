graph TD
    subgraph "Service Accounts"
        SA1[odh-notebook-controller-manager<br/>Namespace: controller namespace]
        SA2["{notebook-name}-sa<br/>Namespace: user namespace<br/>(Created per notebook)"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (Namespaced)"
        RB1[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: controller namespace]
    end

    subgraph "ClusterRoles"
        CR1[manager-role<br/>ClusterRole]
        CR2[notebooks-view<br/>ClusterRole<br/>Aggregates to: view]
        CR3[notebooks-edit<br/>ClusterRole<br/>Aggregates to: edit]
    end

    subgraph "Roles (Namespaced)"
        R1[leader-election-role<br/>Role<br/>Namespace: controller namespace]
    end

    subgraph "API Resources - Kubeflow"
        API1[kubeflow.org<br/>Notebooks]
        API2[kubeflow.org<br/>Notebooks/status]
        API3[kubeflow.org<br/>Notebooks/finalizers]
    end

    subgraph "API Resources - OpenShift"
        API4[route.openshift.io<br/>Routes]
        API5[config.openshift.io<br/>Proxies]
        API6[image.openshift.io<br/>ImageStreams]
    end

    subgraph "API Resources - Core"
        API7[core<br/>Services]
        API8[core<br/>ServiceAccounts]
        API9[core<br/>Secrets]
        API10[core<br/>ConfigMaps]
    end

    subgraph "API Resources - Networking"
        API11[networking.k8s.io<br/>NetworkPolicies]
    end

    subgraph "API Resources - Coordination"
        API12[coordination.k8s.io<br/>Leases]
        API13[core<br/>Events]
    end

    %% Service Account to Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    RB1 -->|grants| R1

    %% ClusterRole: manager-role permissions
    CR1 -->|"get, list, watch,<br/>patch, update"| API1
    CR1 -->|"get, list, watch,<br/>patch, update"| API2
    CR1 -->|"get, list, watch,<br/>patch, update"| API3
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API4
    CR1 -->|"get, list, watch"| API5
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API7
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API8
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API9
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API10
    CR1 -->|"get, list, watch,<br/>create, update, patch"| API11

    %% ClusterRole: notebooks-view permissions
    CR2 -->|"get, list, watch"| API1
    CR2 -->|"get, list, watch"| API2

    %% ClusterRole: notebooks-edit permissions
    CR3 -->|"get, list, watch,<br/>create, delete,<br/>deletecollection,<br/>patch, update"| API1
    CR3 -->|"get, list, watch,<br/>create, delete,<br/>deletecollection,<br/>patch, update"| API2

    %% Role: leader-election-role permissions
    R1 -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| API10
    R1 -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| API12
    R1 -->|"create, patch"| API13

    %% OAuth Proxy Authorization (runtime)
    subgraph "OAuth Proxy Authorization (Runtime)"
        OAuthProxy[OAuth Proxy Sidecar<br/>in notebook pod]
        SAR[SubjectAccessReview API<br/>authorization.k8s.io]
        UserToken[User Bearer Token]
    end

    OAuthProxy -->|"--openshift-sar flag<br/>Resource: notebooks.kubeflow.org/{name}<br/>Verb: get"| SAR
    UserToken -->|"Passed to SAR"| SAR
    SAR -->|"Checks if user can"| API1
    CR2 -.->|"Grants view permission"| SAR
    CR3 -.->|"Grants edit permission"| SAR

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef apiResource fill:#e8e8e8,stroke:#333,stroke-width:1px
    classDef oauth fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    class SA1,SA2 serviceAccount
    class CRB1,RB1 binding
    class CR1,CR2,CR3,R1 role
    class API1,API2,API3,API4,API5,API6,API7,API8,API9,API10,API11,API12,API13 apiResource
    class OAuthProxy,SAR,UserToken oauth
