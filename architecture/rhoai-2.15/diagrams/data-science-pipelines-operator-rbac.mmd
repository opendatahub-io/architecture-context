graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: dspo-namespace"]
        SA_API["ds-pipeline-name<br/>Namespace: dspa-namespace"]
        SA_Runner["pipeline-runner-name<br/>Namespace: dspa-namespace"]
        SA_PAgent["ds-pipeline-persistenceagent-name<br/>Namespace: dspa-namespace"]
        SA_ScheduledWF["ds-pipeline-scheduledworkflow-name<br/>Namespace: dspa-namespace"]
        SA_WFController["ds-pipeline-workflow-controller-name<br/>Namespace: dspa-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
    end

    subgraph "Role Bindings per DSPA namespace"
        RB_API["ds-pipeline-name"]
        RB_Runner["pipeline-runner-name"]
        RB_PAgent["ds-pipeline-persistenceagent-name"]
        RB_ScheduledWF["ds-pipeline-scheduledworkflow-name"]
        RB_WFController["ds-pipeline-workflow-controller-name"]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager["manager-role<br/>ClusterRole"]
    end

    subgraph "Role Permissions per namespace"
        R_API["ds-pipeline<br/>Role"]
        R_Runner["pipeline-runner<br/>Role"]
        R_PAgent["ds-pipeline-persistenceagent<br/>Role"]
        R_ScheduledWF["ds-pipeline-scheduledworkflow<br/>Role"]
        R_WFController["ds-pipeline-workflow-controller<br/>Role"]
    end

    subgraph "API Resources - DSPO Controller"
        DSPA_CR["datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication"]
        Argo_WF["argoproj.io<br/>Workflow, CronWorkflow, WorkflowTemplate"]
        Tekton_All["tekton.dev<br/>all resources v1 only"]
        Core_Res["apps, core<br/>Deployments, Services, ConfigMaps, Secrets"]
        RBAC_Res["rbac.authorization.k8s.io<br/>Roles, RoleBindings, ClusterRoles"]
        Route_Res["route.openshift.io<br/>Routes"]
        NetPol_Res["networking.k8s.io<br/>NetworkPolicies"]
        Monitor_Res["monitoring.coreos.com<br/>ServiceMonitors"]
        Job_Res["batch<br/>Jobs"]
        KF_Res["kubeflow.org<br/>all resources"]
        Ray_Res["ray.io<br/>RayClusters, RayJobs, RayServices"]
    end

    subgraph "API Resources - API Server"
        API_Pods["core<br/>Pods, Pods/log"]
        API_Config["core<br/>ConfigMaps, Secrets, Services"]
        API_Deploy["apps<br/>Deployments"]
        API_Workflows["argoproj.io<br/>Workflows"]
    end

    subgraph "API Resources - Pipeline Runner"
        Runner_Pods["core<br/>Pods, Pods/log"]
        Runner_Secrets["core<br/>Secrets list only"]
        Runner_Workflows["argoproj.io<br/>Workflows, WorkflowTemplates"]
    end

    subgraph "API Resources - Other Components"
        PAgent_Res[Workflow status resources]
        ScheduledWF_Res[CronWorkflow resources]
        WFController_Res[Workflow execution resources]
    end

    %% DSPO Controller bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|all verbs| DSPA_CR
    CR_Manager -->|all verbs| Argo_WF
    CR_Manager -->|all verbs v1 only| Tekton_All
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Res
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_Res
    CR_Manager -->|create,delete,get,list,patch,update,watch| Route_Res
    CR_Manager -->|create,delete,get,list,patch,update,watch| NetPol_Res
    CR_Manager -->|create,delete,get,list,patch,update,watch| Monitor_Res
    CR_Manager -->|all verbs| Job_Res
    CR_Manager -->|all verbs| KF_Res
    CR_Manager -->|create,delete,get,list,patch| Ray_Res

    %% API Server bindings
    SA_API -->|bound via| RB_API
    RB_API -->|grants| R_API
    R_API -->|get,list,watch,create,delete| API_Pods
    R_API -->|get,list,watch,create,delete| API_Config
    R_API -->|get,list,watch| API_Deploy
    R_API -->|get,list,watch,create,update,patch,delete| API_Workflows

    %% Pipeline Runner bindings
    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -->|get,list,watch,create,delete| Runner_Pods
    R_Runner -->|list only - Added 2024-10| Runner_Secrets
    R_Runner -->|get,list,watch,create,update,patch,delete| Runner_Workflows

    %% Other component bindings
    SA_PAgent -->|bound via| RB_PAgent
    RB_PAgent -->|grants| R_PAgent
    R_PAgent -->|workflow status sync| PAgent_Res

    SA_ScheduledWF -->|bound via| RB_ScheduledWF
    RB_ScheduledWF -->|grants| R_ScheduledWF
    R_ScheduledWF -->|cron management| ScheduledWF_Res

    SA_WFController -->|bound via| RB_WFController
    RB_WFController -->|grants| R_WFController
    R_WFController -->|workflow execution| WFController_Res

