graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / ODH Dashboard]
    end

    subgraph Ingress["INGRESS (Optional)"]
        Route["Ingress / OpenShift Route<br/>443/TCP → 8265/8000/TCP<br/>Optional TLS 1.2+<br/>User-configured Auth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted - Network Policy Isolation)"]
        direction TB

        subgraph Namespace_ODH["Namespace: opendatahub"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Ports: 8080, 8081/TCP"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>RBAC Enforcement"]

        subgraph Namespace_User["Namespace: {user-namespace}"]
            HeadPod["Ray Head Pod<br/>SA: {raycluster-name}-sa<br/>UID: 1000 (SCC: run-as-ray-user)<br/>GCS: 6379/TCP Redis (plaintext)<br/>Dashboard: 8265/TCP HTTP (plaintext)<br/>Client: 10001/TCP gRPC (plaintext)<br/>Serve: 8000/TCP HTTP (plaintext)"]

            WorkerPods["Ray Worker Pods<br/>SA: {raycluster-name}-sa<br/>UID: 1000 (SCC: run-as-ray-user)<br/>runAsNonRoot, Drop ALL caps"]

            Autoscaler["Autoscaler Sidecar<br/>(Optional, in Head Pod)"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>No Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        ExternalRedis["External Redis<br/>6379/TCP<br/>Optional TLS<br/>Password Auth<br/>(GCS Fault Tolerance)"]

        ContainerRegistry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secrets"]

        Volcano["Volcano Scheduler<br/>443/TCP HTTPS TLS1.2+<br/>Gang Scheduling<br/>(Optional)"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>User Credentials| K8sAPI
    User -.->|HTTPS/443<br/>Optional TLS| Route
    Route -.->|HTTP/8000 or 8265<br/>Plaintext<br/>Optional Auth| HeadPod

    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>RBAC| K8sAPI

    K8sAPI -->|Create/Watch| HeadPod
    K8sAPI -->|Create/Watch| WorkerPods

    HeadPod -->|Redis/6379<br/>Plaintext<br/>Internal| WorkerPods

    HeadPod -->|Local Access| Autoscaler
    Autoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    Prometheus -->|HTTP/8080<br/>No Auth<br/>Scrape| Operator

    HeadPod -.->|Redis/6379<br/>Optional TLS<br/>Password| ExternalRedis
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| ContainerRegistry
    Operator -.->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class Operator,K8sAPI,HeadPod,WorkerPods,Autoscaler clusterinternal
    class Prometheus monitoring
    class ExternalRedis,ContainerRegistry,Volcano externalservice

    %% Annotations
    classDef annotation fill:#fff,stroke:none,color:#666

    Warning1["⚠️ Ray uses plaintext protocols:<br/>Redis, HTTP, gRPC (no encryption)"]
    Warning2["⚠️ Dashboard/Serve auth is optional<br/>(user-configured)"]

    class Warning1,Warning2 annotation
