graph TB
    subgraph "Kueue System"
        Controller[Controller Manager<br/>Deployment]
        Webhook[Webhook Server<br/>Port 9443/TCP HTTPS]
        Visibility[Visibility Server<br/>Port 8082/TCP HTTPS]
        Scheduler[Scheduler<br/>In-Process Service]
        Cache[Cache<br/>In-Memory Store]
        QueueMgr[Queue Manager<br/>In-Process Service]
        AdmissionCheck[Admission Check Controllers<br/>Provisioning, MultiKueue]

        Controller -->|uses| Scheduler
        Controller -->|updates| Cache
        Controller -->|manages| QueueMgr
        Controller -->|coordinates| AdmissionCheck
        Visibility -->|queries| QueueMgr
        Scheduler -->|reads| Cache
    end

    subgraph "Kueue CRDs"
        Workload[Workload<br/>kueue.x-k8s.io/v1beta1]
        ClusterQueue[ClusterQueue<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue<br/>kueue.x-k8s.io/v1beta1]
        ResourceFlavor[ResourceFlavor<br/>kueue.x-k8s.io/v1beta1]
        AdmissionCheckCR[AdmissionCheck<br/>kueue.x-k8s.io/v1beta1]
        WorkloadPriority[WorkloadPriorityClass<br/>kueue.x-k8s.io/v1beta1]
    end

    subgraph "Job Types Supported"
        BatchJob[Batch Job<br/>batch/v1]
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v1]
        RayJob[RayJob<br/>ray.io/v1]
        RayCluster[RayCluster<br/>ray.io/v1]
        JobSet[JobSet<br/>jobset.x-k8s.io/v1alpha2]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus<br/>Metrics 8080/TCP]
        ClusterAutoscaler[Cluster Autoscaler<br/>Optional]
    end

    User[User/Controller] -->|creates jobs| BatchJob
    User -->|creates jobs| PyTorchJob
    User -->|creates jobs| TFJob

    Webhook -->|validates/mutates| BatchJob
    Webhook -->|validates/mutates| PyTorchJob
    Webhook -->|validates/mutates| TFJob
    Webhook -->|validates/mutates| MPIJob
    Webhook -->|validates/mutates| RayJob
    Webhook -->|validates/mutates| RayCluster
    Webhook -->|validates/mutates| JobSet

    Controller -->|watches/manages| Workload
    Controller -->|watches| ClusterQueue
    Controller -->|watches| LocalQueue
    Controller -->|watches| ResourceFlavor
    Controller -->|watches| AdmissionCheckCR
    Controller -->|watches| WorkloadPriority

    Controller -->|watches/manages| BatchJob
    Controller -->|watches/manages| PyTorchJob
    Controller -->|watches/manages| TFJob
    Controller -->|watches/manages| MPIJob
    Controller -->|watches/manages| RayJob
    Controller -->|watches/manages| RayCluster
    Controller -->|watches/manages| JobSet

    Controller -->|API calls| K8sAPI
    Webhook -->|called by| K8sAPI
    Visibility -->|proxied via| K8sAPI
    CertManager -->|provides certs| Webhook
    Prometheus -->|scrapes| Controller
    AdmissionCheck -->|creates| ClusterAutoscaler

