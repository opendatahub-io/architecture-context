graph TB
    subgraph "Notebooks Component (Workbench Images)"
        BaseImages[Base Images<br/>UBI9/RHEL9/C9S + Python]
        JupyterImages[Jupyter Notebooks<br/>JupyterLab 3.x/4.2]
        RuntimeImages[Runtime Images<br/>Elyra Pipeline Execution]
        CodeServer[Code Server<br/>VS Code Web IDE]
        RStudio[RStudio Server<br/>R IDE]
        GPUImages[GPU-Accelerated Images<br/>CUDA/ROCm/Intel/Habana]
        BuildSystem[Build System<br/>Makefile/Podman]

        BuildSystem -->|builds| BaseImages
        BaseImages -->|extends| JupyterImages
        BaseImages -->|extends| RuntimeImages
        BaseImages -->|extends| CodeServer
        BaseImages -->|extends| RStudio
        BaseImages -->|extends| GPUImages
    end

    subgraph "External Dependencies"
        UBI9[Red Hat UBI9]
        Python[Python 3.9/3.11]
        JupyterLab[JupyterLab]
        PyTorch[PyTorch 2.x]
        TensorFlow[TensorFlow 2.x]
        CUDA[NVIDIA CUDA 11.8/12.x]
        ROCm[AMD ROCm 5.x/6.x]
    end

    subgraph "ODH Integration"
        NotebookController[ODH Notebook Controller]
        Dashboard[ODH Dashboard]
        OAuthProxy[OAuth Proxy]
        ImageRegistry[OpenShift Image Registry]
        ElyraService[Elyra Pipeline Service]
        ModelRegistry[Model Registry]
    end

    subgraph "Deployment Resources"
        ImageStream[ImageStream CR<br/>image.openshift.io/v1]
        BuildConfig[BuildConfig CR<br/>build.openshift.io/v1]
        NotebookCR[Notebook CR<br/>kubeflow.org]
    end

    %% External Dependencies
    BaseImages -.->|based on| UBI9
    JupyterImages -.->|includes| Python
    JupyterImages -.->|includes| JupyterLab
    JupyterImages -.->|includes| PyTorch
    JupyterImages -.->|includes| TensorFlow
    GPUImages -.->|includes| CUDA
    GPUImages -.->|includes| ROCm

    %% Deployment Flow
    BuildSystem -->|publishes to| ImageRegistry
    ImageRegistry -->|defines| ImageStream
    Dashboard -->|reads annotations from| ImageStream
    NotebookController -->|watches| NotebookCR
    NotebookCR -->|references| ImageStream
    NotebookController -->|creates pod with| JupyterImages
    NotebookController -->|creates pod with| CodeServer
    NotebookController -->|creates pod with| RStudio
    NotebookController -->|injects| OAuthProxy

    %% Pipeline Integration
    ElyraService -->|executes| RuntimeImages
    JupyterImages -->|trains models| ModelRegistry

    %% User Interaction
    User[Data Scientist] -->|creates| NotebookCR
    User -->|selects image via| Dashboard

