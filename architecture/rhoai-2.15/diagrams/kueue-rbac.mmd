graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: kueue-system]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding]
        CRB2[kueue-leader-election-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[kueue-manager-role]
        CR2[kueue-batch-admin-role]
        CR3[kueue-batch-user-role]
        CR4[kueue-leader-election-role]
    end

    subgraph "API Resources - Core"
        Core1[core/events, limitranges, namespaces<br/>Verbs: get, list, watch, create, patch, update]
        Core2[core/pods<br/>Verbs: delete, get, list, patch, update, watch]
        Core3[core/pods/finalizers, pods/status<br/>Verbs: get, update, patch]
        Core4[core/secrets<br/>Verbs: get, list, update, watch]
    end

    subgraph "API Resources - Batch"
        Batch1[batch/jobs<br/>Verbs: get, list, patch, update, watch]
        Batch2[batch/jobs/finalizers, jobs/status<br/>Verbs: get, patch, update]
    end

    subgraph "API Resources - Kueue"
        Kueue1[kueue.x-k8s.io/workloads<br/>Verbs: create, delete, get, list, patch, update, watch]
        Kueue2[kueue.x-k8s.io/clusterqueues<br/>Verbs: create, delete, get, list, patch, update, watch]
        Kueue3[kueue.x-k8s.io/localqueues<br/>Verbs: create, delete, get, list, patch, update, watch]
        Kueue4[kueue.x-k8s.io/admissionchecks<br/>Verbs: create, delete, get, list, patch, update, watch]
        Kueue5[kueue.x-k8s.io/resourceflavors<br/>Verbs: create, delete, get, list, patch, update, watch]
        Kueue6[kueue.x-k8s.io/workloadpriorityclasses<br/>Verbs: get, list, watch]
        Kueue7[kueue.x-k8s.io/multikueueclusters<br/>Verbs: get, list, watch]
        Kueue8[kueue.x-k8s.io/multikueueconfigs<br/>Verbs: get, list, watch]
    end

    subgraph "API Resources - KubeFlow"
        KF1[kubeflow.org/pytorchjobs, tfjobs, mpijobs<br/>Verbs: get, list, patch, update, watch]
        KF2[kubeflow.org/*/finalizers, */status<br/>Verbs: get, update]
    end

    subgraph "API Resources - Ray"
        Ray1[ray.io/rayjobs, rayclusters<br/>Verbs: get, list, patch, update, watch]
        Ray2[ray.io/*/finalizers, */status<br/>Verbs: get, update]
    end

    subgraph "API Resources - JobSet"
        JS1[jobset.x-k8s.io/jobsets<br/>Verbs: get, list, patch, update, watch]
        JS2[jobset.x-k8s.io/jobsets/finalizers, jobsets/status<br/>Verbs: get, patch, update]
    end

    subgraph "API Resources - Autoscaling"
        Auto1[autoscaling.x-k8s.io/provisioningrequests<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Admission Registration"
        Adm1[admissionregistration.k8s.io/mutatingwebhookconfigurations<br/>Verbs: get, list, update, watch]
        Adm2[admissionregistration.k8s.io/validatingwebhookconfigurations<br/>Verbs: get, list, update, watch]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR4

    %% Manager Role Permissions
    CR1 -->|manages| Core1
    CR1 -->|manages| Core2
    CR1 -->|manages| Core3
    CR1 -->|manages| Core4
    CR1 -->|manages| Batch1
    CR1 -->|manages| Batch2
    CR1 -->|manages| Kueue1
    CR1 -->|manages| Kueue2
    CR1 -->|manages| Kueue3
    CR1 -->|manages| Kueue4
    CR1 -->|manages| Kueue5
    CR1 -->|reads| Kueue6
    CR1 -->|reads| Kueue7
    CR1 -->|reads| Kueue8
    CR1 -->|manages| KF1
    CR1 -->|manages| KF2
    CR1 -->|manages| Ray1
    CR1 -->|manages| Ray2
    CR1 -->|manages| JS1
    CR1 -->|manages| JS2
    CR1 -->|manages| Auto1
    CR1 -->|manages| Adm1
    CR1 -->|manages| Adm2

    %% Admin/User Roles (for reference)
    CR2 -.->|admin access| Kueue2
    CR2 -.->|admin access| Kueue3
    CR2 -.->|admin access| Kueue5

    CR3 -.->|user access| Kueue3
    CR3 -.->|user access| Kueue1

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333
    style CR3 fill:#f5a623,stroke:#333
    style CR4 fill:#f5a623,stroke:#333
    style CRB1 fill:#7ed321,stroke:#333
    style CRB2 fill:#7ed321,stroke:#333
    style Kueue1 fill:#bd10e0,stroke:#333,color:#fff
    style Kueue2 fill:#bd10e0,stroke:#333,color:#fff
    style Kueue3 fill:#bd10e0,stroke:#333,color:#fff
    style Kueue4 fill:#bd10e0,stroke:#333,color:#fff
    style Kueue5 fill:#bd10e0,stroke:#333,color:#fff
