graph TD
    subgraph "Operator Service Account"
        SA_Op[ServiceAccount<br/>controller-manager<br/>Namespace: operator-ns]
    end

    subgraph "TrustyAI Service Account"
        SA_Proxy["ServiceAccount<br/>(name)-proxy<br/>Namespace: (namespace)"]
    end

    subgraph "Operator ClusterRole Bindings"
        CRB_Manager[ClusterRoleBinding<br/>manager-rolebinding]
        CRB_AuthProxy[ClusterRoleBinding<br/>auth-proxy-rolebinding]
        RB_Leader[RoleBinding<br/>leader-election-rolebinding<br/>Namespace: system]
    end

    subgraph "TrustyAI Service RoleBinding"
        RB_Proxy["RoleBinding<br/>(name)-proxy<br/>Namespace: (namespace)"]
    end

    subgraph "ClusterRole: manager-role"
        CR_Manager[ClusterRole<br/>manager-role]

        subgraph "Core Resources"
            Perm_Core["• configmaps: *<br/>• events: create,patch,update<br/>• pods: *<br/>• secrets: *<br/>• serviceaccounts: *<br/>• services: *<br/>• persistentvolumeclaims: *<br/>• persistentvolumes: get,list,watch"]
        end

        subgraph "Apps Resources"
            Perm_Apps["• deployments: *<br/>• deployments/finalizers: update<br/>• deployments/status: get,patch,update"]
        end

        subgraph "API Extensions"
            Perm_APIExt["• customresourcedefinitions: get,list,watch"]
        end

        subgraph "Coordination"
            Perm_Coord["• leases: create,get,update"]
        end

        subgraph "Monitoring"
            Perm_Monitor["• servicemonitors: create,list,watch"]
        end

        subgraph "Istio"
            Perm_Istio["• destinationrules: *<br/>• virtualservices: *"]
        end

        subgraph "RBAC"
            Perm_RBAC["• clusterrolebindings: *"]
        end

        subgraph "OpenShift"
            Perm_Route["• routes: *"]
        end

        subgraph "KServe"
            Perm_KServe["• inferenceservices: get,list,patch,update,watch<br/>• inferenceservices/finalizers: *<br/>• servingruntimes: *<br/>• servingruntimes/status: get,patch,update"]
        end

        subgraph "TrustyAI CRDs"
            Perm_TrustyAI["• trustyaiservices: *<br/>• trustyaiservices/finalizers: update<br/>• trustyaiservices/status: get,patch,update"]
        end

        CR_Manager --- Perm_Core
        CR_Manager --- Perm_Apps
        CR_Manager --- Perm_APIExt
        CR_Manager --- Perm_Coord
        CR_Manager --- Perm_Monitor
        CR_Manager --- Perm_Istio
        CR_Manager --- Perm_RBAC
        CR_Manager --- Perm_Route
        CR_Manager --- Perm_KServe
        CR_Manager --- Perm_TrustyAI
    end

    subgraph "ClusterRole: auth-proxy-role"
        CR_AuthProxy[ClusterRole<br/>auth-proxy-role]

        subgraph "Auth Resources"
            Perm_Auth["• pods: get<br/>• tokenreviews: create<br/>• subjectaccessreviews: create"]
        end

        CR_AuthProxy --- Perm_Auth
    end

    subgraph "Role: leader-election-role"
        R_Leader[Role<br/>leader-election-role<br/>Namespace: system]

        subgraph "Leader Election"
            Perm_Leader["• leases: get,create,update"]
        end

        R_Leader --- Perm_Leader
    end

    subgraph "ClusterRole: OAuth Proxy"
        CR_Proxy["ClusterRole<br/>Pods Get<br/>(built-in)"]

        subgraph "Proxy Permissions"
            Perm_Proxy["• pods: get<br/>Namespace: (namespace)"]
        end

        CR_Proxy --- Perm_Proxy
    end

    subgraph "API Resources - Managed by Operator"
        API_TrustyAI[TrustyAIService CRD<br/>trustyai.opendatahub.io/v1alpha1]
        API_InfSvc[InferenceService CRD<br/>serving.kserve.io]
        API_ServingRT[ServingRuntime CRD<br/>serving.kserve.io]
        API_Deploy[Deployments<br/>apps/v1]
        API_Service[Services<br/>core/v1]
        API_Route[Routes<br/>route.openshift.io]
        API_PVC[PersistentVolumeClaims<br/>core/v1]
        API_SM[ServiceMonitors<br/>monitoring.coreos.com]
        API_VS[VirtualServices<br/>networking.istio.io]
        API_DR[DestinationRules<br/>networking.istio.io]
    end

    subgraph "OAuth Subject Access Review"
        SAR[Subject Access Review<br/>Check for OAuth Proxy]
        SAR_Check["User must have:<br/>Namespace: (namespace)<br/>Resource: pods<br/>Verb: get"]

        SAR --- SAR_Check
    end

    %% Bindings
    SA_Op -->|bound via| CRB_Manager
    SA_Op -->|bound via| CRB_AuthProxy
    SA_Op -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_Leader -->|grants| R_Leader

    SA_Proxy -->|bound via| RB_Proxy
    RB_Proxy -->|grants| CR_Proxy

    %% Permissions to resources
    CR_Manager -->|full control| API_TrustyAI
    CR_Manager -->|patch/watch| API_InfSvc
    CR_Manager -->|full control| API_ServingRT
    CR_Manager -->|full control| API_Deploy
    CR_Manager -->|full control| API_Service
    CR_Manager -->|full control| API_Route
    CR_Manager -->|full control| API_PVC
    CR_Manager -->|create/list/watch| API_SM
    CR_Manager -->|full control| API_VS
    CR_Manager -->|full control| API_DR

    CR_AuthProxy -->|token validation| SAR

    CR_Proxy -->|enforces| SAR_Check

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Proxy fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style API_TrustyAI fill:#7ed321,stroke:#333
    style API_InfSvc fill:#7ed321,stroke:#333
    style API_ServingRT fill:#7ed321,stroke:#333
    style API_Deploy fill:#7ed321,stroke:#333
    style API_Service fill:#7ed321,stroke:#333
    style API_Route fill:#7ed321,stroke:#333
    style API_PVC fill:#7ed321,stroke:#333
    style API_SM fill:#7ed321,stroke:#333
    style API_VS fill:#7ed321,stroke:#333
    style API_DR fill:#7ed321,stroke:#333
    style SAR fill:#e74c3c,stroke:#333,stroke-width:2px
    style SAR_Check fill:#e74c3c,stroke:#333
