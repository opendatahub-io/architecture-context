graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User/CI]
    end

    subgraph ControlPlane["KUBERNETES API SERVER (Trusted Control Plane)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.3<br/>RBAC Enforcement"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB

        WebhookSvc["Webhook Service<br/>ClusterIP<br/>443/TCP → 9443/TCP<br/>TLS 1.2+ (Service CA)"]

        OperatorPod["RHOAI Operator Pod<br/>SA: rhods-operator-controller-manager<br/>User: 1001 (non-root)"]

        subgraph Controllers["Controllers"]
            DSCCtrl[DataScienceCluster<br/>Controller]
            DSCICtrl[DSCInitialization<br/>Controller]
            SecretGen[SecretGenerator]
            CertGen[CertConfigMap<br/>Generator]
        end

        MetricsSvc["Metrics Service<br/>8443/TCP → 8080/TCP<br/>HTTP + kube-rbac-proxy<br/>Bearer Token"]

        HealthEndpoints["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]

        OperatorPod --> Controllers
        OperatorPod --> WebhookSvc
        OperatorPod --> MetricsSvc
        OperatorPod --> HealthEndpoints
    end

    subgraph MonitoringNS["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        direction TB

        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>10443/TCP HTTPS mTLS<br/>Bearer Token"]

        Alertmanager["Alertmanager<br/>9093/TCP → 10443/TCP<br/>HTTPS TLS1.2+ mTLS"]

        BlackboxExp["Blackbox Exporter<br/>9115/TCP HTTP"]
    end

    subgraph ComponentNS["COMPONENT NAMESPACES (Generated)"]
        direction TB

        Dashboard["ODH Dashboard<br/>NS: redhat-ods-applications"]
        KServe["KServe<br/>NS: redhat-ods-applications"]
        ModelMesh["ModelMesh<br/>NS: redhat-ods-applications"]
        Pipelines["Data Science Pipelines<br/>NS: redhat-ods-applications"]
        Workbenches["Workbenches<br/>NS: redhat-ods-applications"]
        OtherComponents["CodeFlare, Ray, Kueue,<br/>Training Operator, TrustyAI,<br/>Model Registry"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES (Conditional)"]
        direction TB

        ServiceMesh["Service Mesh (Istio)<br/>NS: istio-system<br/>Required: KServe, ModelMesh"]

        Knative["Knative Serving<br/>NS: knative-serving<br/>Required: KServe"]

        Authorino["Authorino<br/>Required: Model serving auth"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.3<br/>User credentials| K8sAPI

    K8sAPI -->|HTTPS/9443<br/>mTLS<br/>Webhook validation| WebhookSvc
    WebhookSvc -->|HTTPS/443<br/>TLS 1.3<br/>ServiceAccount Token| K8sAPI

    K8sAPI -->|Watch CRs<br/>HTTPS/443<br/>ServiceAccount Token| Controllers
    Controllers -->|Manage resources<br/>HTTPS/443<br/>ServiceAccount Token| K8sAPI

    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| Dashboard
    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| KServe
    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| ModelMesh
    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| Pipelines
    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| Workbenches
    Controllers -->|Deploy manifests<br/>HTTPS/443<br/>ServiceAccount Token| OtherComponents

    DSCICtrl -->|Configure<br/>ServiceMeshMember CRD| ServiceMesh
    DSCICtrl -->|Deploy stack<br/>HTTPS/443| Prometheus
    DSCICtrl -->|Deploy stack<br/>HTTPS/443| Alertmanager
    DSCICtrl -->|Deploy stack<br/>HTTPS/443| BlackboxExp

    Prometheus -->|GET /metrics<br/>HTTP/8443<br/>Bearer Token| MetricsSvc
    Prometheus -->|Scrape metrics<br/>Various ports<br/>Bearer Token| Dashboard
    Prometheus -->|Scrape metrics<br/>Various ports<br/>Bearer Token| KServe

    KServe -.->|Requires| ServiceMesh
    KServe -.->|Requires| Knative
    ModelMesh -.->|Requires| ServiceMesh
    KServe -.->|Auth integration| Authorino

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef components fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externaldeps fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class K8sAPI controlplane
    class WebhookSvc,OperatorPod,Controllers,DSCCtrl,DSCICtrl,SecretGen,CertGen,MetricsSvc,HealthEndpoints operator
    class Prometheus,Alertmanager,BlackboxExp monitoring
    class Dashboard,KServe,ModelMesh,Pipelines,Workbenches,OtherComponents components
    class ServiceMesh,Knative,Authorino externaldeps
