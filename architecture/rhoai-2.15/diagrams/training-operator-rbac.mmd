graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[training-operator<br/>ClusterRole]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR

    subgraph "Core API Group (v1)"
        Pods[Pods<br/>create, delete, get, list,<br/>patch, update, watch]
        PodsExec[Pods/exec<br/>create]
        Services[Services<br/>create, delete, get,<br/>list, watch]
        ServiceAccounts[ServiceAccounts<br/>create, get, list, watch]
        Events[Events<br/>create, delete, get, list,<br/>patch, update, watch]
        ConfigMaps[ConfigMaps<br/>create, list, update, watch]
    end

    CR -->|permissions| Pods
    CR -->|permissions| PodsExec
    CR -->|permissions| Services
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Events
    CR -->|permissions| ConfigMaps

    subgraph "kubeflow.org API Group"
        PyTorchJobs[PyTorchJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        PyTorchJobsStatus[PyTorchJobs/status<br/>get, patch, update]
        PyTorchJobsFinalizers[PyTorchJobs/finalizers<br/>update]

        TFJobs[TFJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        TFJobsStatus[TFJobs/status<br/>get, patch, update]
        TFJobsFinalizers[TFJobs/finalizers<br/>update]

        MPIJobs[MPIJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        MPIJobsStatus[MPIJobs/status<br/>get, patch, update]
        MPIJobsFinalizers[MPIJobs/finalizers<br/>update]

        XGBoostJobs[XGBoostJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        XGBoostJobsStatus[XGBoostJobs/status<br/>get, patch, update]
        XGBoostJobsFinalizers[XGBoostJobs/finalizers<br/>update]

        MXJobs[MXJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        MXJobsStatus[MXJobs/status<br/>get, patch, update]
        MXJobsFinalizers[MXJobs/finalizers<br/>update]

        PaddleJobs[PaddleJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        PaddleJobsStatus[PaddleJobs/status<br/>get, patch, update]
        PaddleJobsFinalizers[PaddleJobs/finalizers<br/>update]
    end

    CR -->|permissions| PyTorchJobs
    CR -->|permissions| PyTorchJobsStatus
    CR -->|permissions| PyTorchJobsFinalizers
    CR -->|permissions| TFJobs
    CR -->|permissions| TFJobsStatus
    CR -->|permissions| TFJobsFinalizers
    CR -->|permissions| MPIJobs
    CR -->|permissions| MPIJobsStatus
    CR -->|permissions| MPIJobsFinalizers
    CR -->|permissions| XGBoostJobs
    CR -->|permissions| XGBoostJobsStatus
    CR -->|permissions| XGBoostJobsFinalizers
    CR -->|permissions| MXJobs
    CR -->|permissions| MXJobsStatus
    CR -->|permissions| MXJobsFinalizers
    CR -->|permissions| PaddleJobs
    CR -->|permissions| PaddleJobsStatus
    CR -->|permissions| PaddleJobsFinalizers

    subgraph "autoscaling API Group"
        HPAs[HorizontalPodAutoscalers<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    CR -->|permissions| HPAs

    subgraph "rbac.authorization.k8s.io API Group"
        Roles[Roles<br/>create, list, update, watch]
        RoleBindings[RoleBindings<br/>create, list, update, watch]
    end

    CR -->|permissions| Roles
    CR -->|permissions| RoleBindings

    subgraph "Gang Scheduling (Optional)"
        VolcanoPodGroups[PodGroups<br/>scheduling.volcano.sh<br/>create, delete, get, list,<br/>patch, update, watch]
        K8sPodGroups[PodGroups<br/>scheduling.x-k8s.io<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    CR -.->|optional permissions| VolcanoPodGroups
    CR -.->|optional permissions| K8sPodGroups

    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

