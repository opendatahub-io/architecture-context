graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → (name)-tls:443<br/>TLS 1.2+ Edge + Reencrypt"]
        Route["OpenShift Route: (name)<br/>Reencrypt Mode<br/>Insecure: Redirect"]
    end

    subgraph ApplicationTier["APPLICATION TIER (Authenticated)"]
        direction TB

        subgraph Services["Kubernetes Services"]
            TLSService["(name)-tls Service<br/>ClusterIP<br/>443/TCP → 8443/TCP<br/>TLS Secret: (name)-tls"]
            HTTPService["(name) Service<br/>ClusterIP<br/>80/TCP → 8080/TCP (metrics)<br/>443/TCP → 4443/TCP (internal TLS)"]
        end

        subgraph TrustyAIPod["TrustyAI Service Pod<br/>Namespace: (namespace)"]
            direction LR
            OAuthProxy["OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS<br/>TLS 1.2+<br/>OpenShift OAuth<br/>SA: (name)-proxy<br/>SAR: pods.get in (ns)"]
            TrustyAIContainer["TrustyAI Service<br/>Port: 8080/TCP HTTP<br/>Localhost only<br/>Health: /q/health/*<br/>Metrics: /q/metrics"]
        end

        Prometheus["Prometheus<br/>Scrape Interval: 4s<br/>Bearer Token Auth<br/>ServiceMonitor"]
    end

    subgraph OperatorTier["OPERATOR TIER (Control Plane)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>Ports: 8080/TCP (metrics)<br/>8081/TCP (health)"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio - Optional)"]
        direction TB
        VirtualService["VirtualService: (name)<br/>Match: port 80/TCP<br/>Rewrite: port 443/TCP"]
        DestinationRule["DestinationRule: (name)<br/>TLS Mode: SIMPLE"]
        InferenceService["InferenceService (Patched)<br/>MM_PAYLOAD_PROCESSORS<br/>Sends inference data"]
    end

    subgraph StorageTier["STORAGE TIER"]
        direction LR

        subgraph PVCMode["Option 1: PVC Storage"]
            PVC["PersistentVolumeClaim<br/>(name)-pvc<br/>Size: user-defined<br/>AccessMode: RWO<br/>Mount: /inputs<br/>Format: CSV"]
        end

        subgraph DBMode["Option 2: Database Storage"]
            Database["PostgreSQL/MariaDB<br/>5432/TCP or 3306/TCP<br/>JDBC over TLS 1.2+<br/>Auth: User/Pass + CA Cert<br/>Secret: (name)-db-credentials<br/>CA: (name)-db-ca"]
        end
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|Route Lookup| Route
    Route -->|HTTPS/443<br/>TLS Reencrypt| TLSService

    %% Application tier flows
    TLSService -->|HTTPS/8443<br/>TLS 1.2+<br/>OAuth Challenge| OAuthProxy
    OAuthProxy -->|HTTP/8080<br/>Localhost<br/>Proxied Auth| TrustyAIContainer

    %% Metrics flow
    Prometheus -->|HTTP/80<br/>Bearer Token| HTTPService
    HTTPService -->|HTTP/8080<br/>/q/metrics| TrustyAIContainer

    %% Operator flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    K8sAPI -->|Watches/Manages| TrustyAIPod
    K8sAPI -->|Watches/Manages| Services

    %% Service mesh flows
    InferenceService -->|"HTTP/80 or HTTPS/443<br/>mTLS (in mesh)<br/>SA Token"| VirtualService
    VirtualService -->|Apply Rules| DestinationRule
    DestinationRule -->|Route to| TrustyAIContainer

    %% Storage flows
    TrustyAIContainer -.->|Filesystem I/O<br/>CSV files<br/>Pod SecurityContext| PVC
    TrustyAIContainer -.->|JDBC/5432 or 3306<br/>TLS 1.2+<br/>User/Pass + CA| Database

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef mesh fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router,Route ingress
    class TLSService,HTTPService,OAuthProxy,TrustyAIContainer,Prometheus application
    class Operator,K8sAPI operator
    class VirtualService,DestinationRule,InferenceService mesh
    class PVC,Database storage
