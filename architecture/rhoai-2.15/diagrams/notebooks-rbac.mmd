graph TD
    subgraph "Service Accounts"
        SA1[notebook-sa<br/>User Namespace]
        SA2[odh-notebook-controller<br/>ODH Namespace]
        SA3[default<br/>User Namespace]
    end

    subgraph "Role Bindings"
        RB1[notebook-sa-binding<br/>User Namespace]
        RB2[image-puller-binding<br/>User Namespace]
    end

    subgraph "Roles & ClusterRoles"
        CR1[ClusterRole:<br/>system:image-puller]
        CR2[ClusterRole:<br/>notebook-controller-role]
        R1[Role: default<br/>Namespace-scoped]
    end

    subgraph "API Resources - Kubeflow"
        K1[kubeflow.org<br/>notebooks]
    end

    subgraph "API Resources - Core"
        C1["Core API<br/>configmaps"]
        C2["Core API<br/>secrets"]
        C3["Core API<br/>persistentvolumeclaims"]
        C4["Core API<br/>pods"]
        C5["Core API<br/>services"]
    end

    subgraph "Permissions"
        P1[get, list, watch,<br/>create, update,<br/>patch, delete]
        P2[get, list, watch]
        P3[get, list]
    end

    %% Service Account to Role Bindings
    SA1 -->|bound via| RB1
    SA3 -->|bound via| RB2

    %% Role Bindings to Roles
    RB1 -->|grants| R1
    RB2 -->|grants| CR1

    %% Notebook Controller
    SA2 -->|has permissions| CR2

    %% Roles to Resources
    CR1 -->|P3| C4
    CR1 -->|P3| C5

    CR2 -->|P1| K1

    R1 -->|P2| C1
    R1 -->|P2| C2
    R1 -->|P2| C3

    %% Additional Context
    NotebookPod[Notebook Pod<br/>Uses notebook-sa]
    NotebookPod -.->|runs with| SA1

    Controller[ODH Notebook Controller]
    Controller -.->|runs with| SA2

    %% Authentication Flow
    User[User] -->|creates| NotebookCR[Notebook CR]
    NotebookCR -->|watched by| Controller
    Controller -->|creates pod using| NotebookPod

    %% OAuth Authorization
    subgraph "OAuth Authorization"
        OAuth[OAuth Proxy Sidecar]
        Policy[Policy: User must be<br/>notebook owner or have<br/>namespace access]
    end

    NotebookPod -->|protected by| OAuth
    OAuth -->|enforces| Policy
    User -->|authenticated by| OAuth

    %% Styling
    style SA1 fill:#4a90e2,color:#fff
    style SA2 fill:#4a90e2,color:#fff
    style SA3 fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623
    style CR2 fill:#f5a623
    style R1 fill:#f5a623
    style K1 fill:#7ed321
    style C1 fill:#7ed321
    style C2 fill:#7ed321
    style C3 fill:#7ed321
    style C4 fill:#7ed321
    style C5 fill:#7ed321
    style NotebookPod fill:#dae8fc,stroke:#6c8ebf
    style Controller fill:#dae8fc,stroke:#6c8ebf
    style OAuth fill:#ffe6cc,stroke:#d79b00
    style Policy fill:#ffe6cc,stroke:#d79b00
