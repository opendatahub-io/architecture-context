graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist / CI System]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>User + ServiceAccount Auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        TrainingOp["Training Operator Pod<br/>SA: training-operator<br/>Replicas: 1<br/>Leader Election Enabled<br/>Istio: Disabled"]

        subgraph OpServices["Services"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>mTLS with API Server"]
            MetricsSrv["Metrics Server<br/>8080/TCP HTTP<br/>No Auth"]
            HealthSrv["Health Probe Server<br/>8081/TCP HTTP<br/>No Auth"]
        end

        TrainingOp --> WebhookSrv
        TrainingOp --> MetricsSrv
        TrainingOp --> HealthSrv
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph TrainingJobs["Training Job Resources"]
            JobCRs["Job CRs<br/>PyTorchJob, TFJob, MPIJob, etc.<br/>kubeflow.org/v1"]
            MasterPod["Training Master Pod<br/>SA: default or custom<br/>Port: Framework-specific"]
            WorkerPods["Training Worker Pods<br/>SA: default or custom<br/>Communication: Master-Worker"]
            JobSvc["Kubernetes Service<br/>Internal Communication"]
        end

        JobCRs --> MasterPod
        JobCRs --> WorkerPods
        MasterPod <-->|Framework Protocol<br/>23456/TCP PyTorch<br/>2222/TCP TF<br/>No Encryption| WorkerPods
        JobSvc --> MasterPod
        JobSvc --> WorkerPods
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM Auth"]
        NFS["NFS Storage<br/>NFS Protocol<br/>Network/Kerberos Auth"]
        ContainerReg["Container Registry<br/>443/TCP HTTPS<br/>Image Pull Secret"]
        Volcano["Volcano Scheduler (Optional)<br/>6443/TCP HTTPS<br/>ServiceAccount Token"]
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>8080/TCP HTTP"]
        Kubelet["Kubelet<br/>8081/TCP HTTP"]
    end

    %% External to Control Plane
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User Credentials| K8sAPI

    %% Control Plane to Operator
    K8sAPI <-->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS| WebhookSrv
    TrainingOp -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Operator to User Namespace
    TrainingOp -.->|creates/watches<br/>via K8s API| JobCRs
    TrainingOp -.->|creates<br/>via K8s API| MasterPod
    TrainingOp -.->|creates<br/>via K8s API| WorkerPods
    TrainingOp -.->|creates<br/>via K8s API| JobSvc

    %% Training Pods to External Services
    MasterPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    WorkerPods -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    MasterPod -->|NFS<br/>Network Auth| NFS
    WorkerPods -->|NFS<br/>Network Auth| NFS
    MasterPod -->|HTTPS/443<br/>Image Pull| ContainerReg
    WorkerPods -->|HTTPS/443<br/>Image Pull| ContainerReg

    %% Optional Gang Scheduling
    TrainingOp -.->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRs| Volcano

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No Auth| MetricsSrv
    Kubelet -->|HTTP/8081<br/>Healthz/Readyz| HealthSrv

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservices fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class TrainingOp,WebhookSrv,MetricsSrv,HealthSrv operatorns
    class JobCRs,MasterPod,WorkerPods,JobSvc userns
    class S3,NFS,ContainerReg,Volcano externalservices
    class Prometheus,Kubelet monitoring
