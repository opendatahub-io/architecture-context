graph TB
    subgraph "Training Operator Component"
        Manager[training-operator<br/>Go Binary]

        subgraph "Job Controllers"
            PyTorchCtrl[PyTorchJob Controller<br/>Elastic Scaling Support]
            TFCtrl[TFJob Controller<br/>Parameter Server Architecture]
            MPICtrl[MPIJob Controller<br/>MPI/Horovod Support]
            XGBoostCtrl[XGBoostJob Controller]
            MXNetCtrl[MXNetJob Controller]
            PaddleCtrl[PaddleJob Controller]
        end

        subgraph "Supporting Services"
            WebhookSrv[Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+]
            MetricsSrv[Metrics Server<br/>8080/TCP HTTP]
            HealthSrv[Health Probe Server<br/>8081/TCP HTTP]
        end

        Manager --> PyTorchCtrl
        Manager --> TFCtrl
        Manager --> MPICtrl
        Manager --> XGBoostCtrl
        Manager --> MXNetCtrl
        Manager --> PaddleCtrl
        Manager --> WebhookSrv
        Manager --> MetricsSrv
        Manager --> HealthSrv
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        MXNetJobCR[MXNetJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Managed Resources"
        Pods[Training Pods<br/>Master + Workers]
        Services[Kubernetes Services<br/>Internal Communication]
        ConfigMaps[ConfigMaps<br/>Job Configuration]
    end

    User[Data Scientist] -->|kubectl apply| PyTorchJobCR
    User -->|kubectl apply| TFJobCR
    User -->|kubectl apply| MPIJobCR
    User -->|kubectl apply| XGBoostJobCR
    User -->|kubectl apply| MXNetJobCR
    User -->|kubectl apply| PaddleJobCR

    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MXNetJobCR -->|watched by| MXNetCtrl
    PaddleJobCR -->|watched by| PaddleCtrl

    PyTorchCtrl -->|creates/manages| Pods
    TFCtrl -->|creates/manages| Pods
    MPICtrl -->|creates/manages| Pods
    XGBoostCtrl -->|creates/manages| Pods
    MXNetCtrl -->|creates/manages| Pods
    PaddleCtrl -->|creates/manages| Pods

    PyTorchCtrl -->|creates| Services
    TFCtrl -->|creates| Services
    MPICtrl -->|creates| Services

    PyTorchCtrl -->|creates| ConfigMaps
    TFCtrl -->|creates| ConfigMaps

    subgraph "Optional Dependencies"
        Volcano[Volcano Scheduler<br/>Gang Scheduling]
        SchedulerPlugins[scheduler-plugins<br/>Gang Scheduling]
        CertManager[cert-manager<br/>Webhook Certificates]
    end

    Manager -.->|optional| Volcano
    Manager -.->|optional| SchedulerPlugins
    WebhookSrv -.->|certificate| CertManager

    subgraph "External Integrations"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Scraping]
        ContainerReg[Container Registry<br/>443/TCP HTTPS]
    end

    Manager -->|REST API<br/>TLS 1.2+| K8sAPI
    WebhookSrv <-->|validation/mutation<br/>mTLS| K8sAPI
    Prometheus -->|scrapes /metrics<br/>HTTP| MetricsSrv
    Pods -->|pull images| ContainerReg

