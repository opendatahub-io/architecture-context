graph TD
    subgraph "Service Account"
        SA[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "API Resources - Ray CRDs"
        RayClusterCRD["ray.io/v1<br/>RayCluster<br/>(+ status, finalizers)"]
        RayJobCRD["ray.io/v1<br/>RayJob<br/>(+ status, finalizers)"]
        RayServiceCRD["ray.io/v1<br/>RayService<br/>(+ status, finalizers)"]
    end

    subgraph "API Resources - Core"
        Pods["core<br/>Pods, Pods/Status"]
        Services["core<br/>Services, Services/Status"]
        ServiceAccounts["core<br/>ServiceAccounts"]
        Events["core<br/>Events"]
        Endpoints["core<br/>Endpoints"]
    end

    subgraph "API Resources - Batch"
        Jobs["batch<br/>Jobs"]
    end

    subgraph "API Resources - RBAC"
        Roles["rbac.authorization.k8s.io<br/>Roles"]
        RoleBindings["rbac.authorization.k8s.io<br/>RoleBindings"]
    end

    subgraph "API Resources - Networking"
        Ingresses["networking.k8s.io<br/>Ingresses, IngressClasses"]
        IngressesExt["extensions<br/>Ingresses"]
    end

    subgraph "API Resources - OpenShift"
        Routes["route.openshift.io<br/>Routes"]
    end

    subgraph "API Resources - Coordination"
        Leases["coordination.k8s.io<br/>Leases<br/>(Leader Election)"]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - Ray CRDs
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| RayClusterCRD
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| RayJobCRD
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| RayServiceCRD

    %% Permissions - Core
    CR -->|"create, delete, deletecollection,<br/>get, list, patch, update, watch"| Pods
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| Services
    CR -->|"create, delete, get,<br/>list, watch"| ServiceAccounts
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| Events
    CR -->|"get, list"| Endpoints

    %% Permissions - Batch
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| Jobs

    %% Permissions - RBAC
    CR -->|"create, delete, get,<br/>list, update, watch"| Roles
    CR -->|"create, delete, get,<br/>list, update, watch"| RoleBindings

    %% Permissions - Networking
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| Ingresses
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| IngressesExt

    %% Permissions - OpenShift
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| Routes

    %% Permissions - Coordination
    CR -->|"create, get, list, update"| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#7ed321,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style RayClusterCRD fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style RayJobCRD fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style RayServiceCRD fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    style Pods fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Services fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ServiceAccounts fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Events fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Endpoints fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    style Jobs fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    style Roles fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style RoleBindings fill:#f8cecc,stroke:#b85450,stroke-width:2px

    style Ingresses fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style IngressesExt fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    style Routes fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    style Leases fill:#f9f9f9,stroke:#999,stroke-width:2px
