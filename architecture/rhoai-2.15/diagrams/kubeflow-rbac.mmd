graph TB
    subgraph "Service Accounts"
        SA[odh-notebook-controller-manager<br/>Namespace: redhat-ods-applications]
        NotebookSA["{notebook-name}-sa<br/>Namespace: {user-namespace}<br/>(Created per notebook)"]
    end

    subgraph "ClusterRole Bindings"
        CRB[manager-rolebinding<br/>Scope: Cluster-wide]
    end

    subgraph "Role Bindings"
        RB[leader-election-rolebinding<br/>Scope: Controller namespace]
    end

    subgraph "ClusterRoles"
        ManagerRole[manager-role<br/>Cluster-wide permissions]
        LeaderRole[leader-election-role<br/>Leader election permissions]
        NotebookEditRole[notebooks-edit<br/>Full notebook management]
        NotebookViewRole[notebooks-view<br/>Read-only notebook access]
    end

    subgraph "API Resources - Kubeflow"
        NotebookCRD[kubeflow.org/v1<br/>Notebook]
        NotebookStatus[kubeflow.org/v1<br/>Notebook/status]
        NotebookFinalizers[kubeflow.org/v1<br/>Notebook/finalizers]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io<br/>Routes]
        Proxies[config.openshift.io<br/>Proxies]
    end

    subgraph "API Resources - Core"
        Services[core<br/>Services]
        ServiceAccounts[core<br/>ServiceAccounts]
        Secrets[core<br/>Secrets]
        ConfigMaps[core<br/>ConfigMaps]
        Events[core<br/>Events]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies[networking.k8s.io<br/>NetworkPolicies]
    end

    subgraph "API Resources - Coordination"
        Leases[coordination.k8s.io<br/>Leases]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Bindings to Roles
    CRB -->|grants| ManagerRole
    RB -->|grants| LeaderRole

    %% Manager Role Permissions
    ManagerRole -->|"get, list, watch, patch"| NotebookCRD
    ManagerRole -->|get| NotebookStatus
    ManagerRole -->|update| NotebookFinalizers
    ManagerRole -->|"get, list, watch, create, update, patch"| Routes
    ManagerRole -->|"get, list, watch"| Proxies
    ManagerRole -->|"get, list, watch, create, update, patch"| Services
    ManagerRole -->|"get, list, watch, create, update, patch"| ServiceAccounts
    ManagerRole -->|"get, list, watch, create, update, patch"| Secrets
    ManagerRole -->|"get, list, watch, create, update, patch"| ConfigMaps
    ManagerRole -->|"get, list, watch, create, update, patch"| NetworkPolicies

    %% Leader Election Role Permissions
    LeaderRole -->|"get, list, watch, create, update, patch"| ConfigMaps
    LeaderRole -->|"get, list, watch, create, update, patch"| Leases
    LeaderRole -->|"create, patch"| Events

    %% Notebook Edit/View Roles (for users)
    NotebookEditRole -->|"get, list, watch, create, delete, deletecollection, patch, update"| NotebookCRD
    NotebookEditRole -->|"get, list, watch, create, delete, deletecollection, patch, update"| NotebookStatus
    NotebookViewRole -->|"get, list, watch"| NotebookCRD
    NotebookViewRole -->|"get, list, watch"| NotebookStatus

    %% Notebook ServiceAccount (created per notebook)
    NotebookSA -.->|"OAuth proxy uses for SAR"| NotebookCRD

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NotebookSA fill:#4a90e2,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5,color:#fff

    style CRB fill:#f5a623,stroke:#333,color:#000
    style RB fill:#f5a623,stroke:#333,color:#000

    style ManagerRole fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style LeaderRole fill:#e74c3c,stroke:#333,color:#fff
    style NotebookEditRole fill:#9b59b6,stroke:#333,color:#fff
    style NotebookViewRole fill:#9b59b6,stroke:#333,color:#fff

    style NotebookCRD fill:#7ed321,stroke:#333,color:#000
    style NotebookStatus fill:#7ed321,stroke:#333,color:#000
    style NotebookFinalizers fill:#7ed321,stroke:#333,color:#000

    style Routes fill:#e00000,stroke:#333,color:#fff
    style Proxies fill:#e00000,stroke:#333,color:#fff

    style Services fill:#326ce5,stroke:#333,color:#fff
    style ServiceAccounts fill:#326ce5,stroke:#333,color:#fff
    style Secrets fill:#326ce5,stroke:#333,color:#fff
    style ConfigMaps fill:#326ce5,stroke:#333,color:#fff
    style Events fill:#326ce5,stroke:#333,color:#fff

    style NetworkPolicies fill:#16a085,stroke:#333,color:#fff
    style Leases fill:#95a5a6,stroke:#333,color:#fff
