graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Termination<br/>Re-encrypt to OAuth Proxy"]
    end

    subgraph UserNamespace["USER NAMESPACE (Isolated)"]
        direction TB

        subgraph NotebookPod["Notebook Pod"]
            direction LR
            OAuth["OAuth Proxy Sidecar<br/>SA: notebook-sa<br/>Port: 8443/TCP (HTTPS)<br/>Auth: OAuth2 OpenShift"]
            Workbench["JupyterLab/Code Server/RStudio<br/>Port: 8888/8080/8787 (HTTP)<br/>User: UID 1001 (non-root)"]
        end

        PVC["Persistent Volume Claim<br/>/opt/app-root/src<br/>Encryption at rest (CSI-dependent)"]

        Service["ClusterIP Service<br/>notebook-{name}-tls<br/>8443/TCP"]
    end

    subgraph ODHNamespace["ODH/RHOAI NAMESPACE"]
        NotebookController["Notebook Controller<br/>SA: odh-notebook-controller<br/>Manages Notebook CRs"]
        Dashboard["ODH Dashboard<br/>Discovers ImageStreams"]
        ImageRegistry["Image Registry<br/>5000/TCP HTTP (internal)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PyPI["PyPI (pypi.org)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: None"]
        QuayIO["Quay.io Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secret"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM/Keys"]
        GitHub["GitHub/GitLab<br/>443/TCP HTTPS, 22/TCP SSH<br/>Auth: SSH Keys/Tokens"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP mTLS<br/>Auth: Service Account"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["OpenShift API<br/>6443/TCP HTTPS TLS 1.3<br/>Auth: Service Account Token"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+ Edge<br/>Session Cookie| Route
    Route -->|HTTPS/8443<br/>Re-encrypted<br/>OAuth Token| OAuth
    OAuth -->|HTTP/8888<br/>Localhost<br/>Proxy Headers| Workbench
    Workbench -.->|RW Access| PVC
    Service -->|Routes to| OAuth
    Route -.->|Backed by| Service

    %% Control Plane
    NotebookController -->|Creates/Manages| NotebookPod
    NotebookController -->|Reads| ImageRegistry
    Dashboard -->|Lists Images| ImageRegistry

    %% Egress
    Workbench -->|HTTPS/443<br/>TLS 1.2+| PyPI
    Workbench -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Auth| S3
    Workbench -->|HTTPS/443, SSH/22<br/>Keys/Tokens| GitHub
    Workbench -->|HTTP/8080<br/>mTLS| ModelRegistry
    Workbench -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI

    NotebookController -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    ImageRegistry -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| QuayIO

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef usernamespace fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef odhnamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef clusterservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route ingress
    class NotebookPod,OAuth,Workbench,PVC,Service usernamespace
    class NotebookController,Dashboard,ImageRegistry odhnamespace
    class PyPI,QuayIO,S3,GitHub,ModelRegistry externalservice
    class K8sAPI clusterservice
