graph TB
    subgraph "ODH Dashboard Component"
        Frontend[React Frontend<br/>PatternFly UI]
        Backend[Node.js/Fastify Backend<br/>Port: 8080/TCP]
        OAuthProxy[OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS]
        StaticAssets[Static Assets<br/>CSS, JS, Images]

        Frontend -->|serves| StaticAssets
        OAuthProxy -->|proxies| Frontend
        OAuthProxy -->|proxies| Backend
    end

    subgraph "Custom Resources Managed"
        OdhDashboardConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhApplication[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhDocument[OdhDocument<br/>dashboard.opendatahub.io/v1]
        OdhQuickStart[OdhQuickStart<br/>console.openshift.io/v1]
        AcceleratorProfile[AcceleratorProfile<br/>dashboard.opendatahub.io/v1]
    end

    subgraph "External Access"
        User[User Browser]
        Route[OpenShift Route<br/>443/TCP HTTPS TLS 1.2+]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
        OAuthServer[OpenShift OAuth Server<br/>443/TCP HTTPS]
        PrometheusAPI[Prometheus<br/>9091/TCP HTTPS]
        ImageRegistry[OpenShift Image Registry<br/>443/TCP HTTPS]
    end

    subgraph "Internal ODH Dependencies"
        DSC[DataScienceCluster Operator]
        DSCI[DSCInitialization Operator]
        KServe[KServe]
        Notebooks[Kubeflow Notebooks]
        ModelRegistry[Model Registry Operator]
        Console[OpenShift Console]
    end

    %% User flows
    User -->|HTTPS/443| Route
    Route -->|TLS reencrypt| OAuthProxy

    %% Authentication
    OAuthProxy -->|OAuth flow| OAuthServer

    %% Backend interactions
    Backend -->|API operations| K8sAPI
    Backend -->|metrics queries| PrometheusAPI
    Backend -->|image management| ImageRegistry

    %% CRD interactions
    Backend -->|watch/create/update| OdhDashboardConfig
    Backend -->|read| OdhApplication
    Backend -->|read| OdhDocument
    Backend -->|read| OdhQuickStart
    Backend -->|manage| AcceleratorProfile

    %% Component integrations
    Backend -->|monitor DSC status| DSC
    Backend -->|monitor DSCI status| DSCI
    Backend -->|manage InferenceServices| KServe
    Backend -->|manage Notebook CRs| Notebooks
    Backend -->|manage ModelRegistry CRs| ModelRegistry
    Backend -->|create ConsoleLink| Console

    %% Styling
    style Frontend fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Backend fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style OdhDashboardConfig fill:#7ed321,stroke:#333
    style OdhApplication fill:#7ed321,stroke:#333
    style OdhDocument fill:#7ed321,stroke:#333
    style OdhQuickStart fill:#7ed321,stroke:#333
    style AcceleratorProfile fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style OAuthServer fill:#999,stroke:#333
    style PrometheusAPI fill:#999,stroke:#333
    style ImageRegistry fill:#999,stroke:#333
    style DSC fill:#7ed321,stroke:#333
    style DSCI fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style Console fill:#7ed321,stroke:#333
