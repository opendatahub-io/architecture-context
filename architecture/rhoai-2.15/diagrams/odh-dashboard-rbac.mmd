graph TB
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: Dashboard NS]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard]
        CRB2[odh-dashboard-monitoring]
        CRB3[system:auth-delegator]
        CRB4[odh-dashboard-image-puller]
    end

    subgraph "ClusterRole"
        CR[odh-dashboard<br/>Cluster-wide permissions]
        CRMonitoring[cluster-monitoring-view<br/>Prometheus access]
        CRAuthDelegator[system:auth-delegator<br/>OAuth token validation]
        CRImagePuller[system:image-puller<br/>Image registry access]
    end

    subgraph "Role Binding (Namespace)"
        RB[odh-dashboard<br/>Namespace: Dashboard NS]
    end

    subgraph "Role (Namespace)"
        R[odh-dashboard<br/>Namespace-scoped permissions<br/>Dashboard NS]
    end

    subgraph "Cluster-wide API Resources"
        direction TB

        subgraph CoreAPI["Core API (v1)"]
            Nodes[nodes<br/>get, list]
            ConfigMaps[configmaps<br/>create, delete, get, list, patch, update, watch]
            PVCs[persistentvolumeclaims<br/>create, delete, get, list, patch, update, watch]
            Secrets[secrets<br/>create, delete, get, list, patch, update, watch]
            Pods[pods<br/>get, list, watch]
            SAs[serviceaccounts<br/>get, list, watch]
            Services[services<br/>get, list, watch]
            Namespaces[namespaces<br/>get, list, watch, create, update, patch, delete]
            Events[events<br/>get, list, watch]
        end

        subgraph StorageAPI["storage.k8s.io"]
            StorageClasses[storageclasses<br/>update, patch]
        end

        subgraph MachineAPI["machine.openshift.io, autoscaling.openshift.io"]
            MachineAutoscalers[machineautoscalers<br/>get, list]
            MachineSets[machinesets<br/>get, list]
        end

        subgraph ConfigAPI["config.openshift.io"]
            ClusterVersions[clusterversions<br/>get, watch, list]
        end

        subgraph OperatorsAPI["operators.coreos.com"]
            CSVs[clusterserviceversions<br/>get, list, watch]
            Subscriptions[subscriptions<br/>get, list, watch]
        end

        subgraph ImageAPI["image.openshift.io"]
            ImageLayers[imagestreams/layers<br/>get]
        end

        subgraph RouteAPI["route.openshift.io"]
            Routes[routes<br/>get, list, watch]
        end

        subgraph ConsoleAPI["console.openshift.io"]
            ConsoleLinks[consolelinks<br/>get, list, watch]
        end

        subgraph UserAPI["user.openshift.io"]
            Groups[groups<br/>get, list, watch]
            Users[users<br/>get, list, watch]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            RoleBindings[rolebindings<br/>get, list, watch, create, update, patch, delete]
            ClusterRoleBindings[clusterrolebindings<br/>get, list, watch, create, update, patch, delete]
            Roles[roles<br/>get, list, watch, create, update, patch, delete]
        end

        subgraph KubeflowAPI["kubeflow.org"]
            NotebooksCR[notebooks<br/>get, list, watch, create, update, patch, delete]
        end

        subgraph DSCAPI["datasciencecluster.opendatahub.io"]
            DSCs[datascienceclusters<br/>list, watch, get]
        end

        subgraph DSCIAPI["dscinitialization.opendatahub.io"]
            DSCIs[dscinitializations<br/>list, watch, get]
        end

        subgraph KServeAPI["serving.kserve.io"]
            InferenceServices[inferenceservices<br/>get, list, watch]
        end

        subgraph ModelRegistryAPI["modelregistry.opendatahub.io"]
            ModelRegistries[modelregistries<br/>get, list, watch, create, update, patch, delete]
        end
    end

    subgraph "Namespace-scoped API Resources (Dashboard NS)"
        direction TB

        subgraph DashboardAPI["dashboard.opendatahub.io"]
            AcceleratorProfiles[acceleratorprofiles<br/>create, get, list, update, patch, delete]
            OdhApplications[odhapplications<br/>get, list]
            OdhDocuments[odhdocuments<br/>get, list]
        end

        subgraph ConsoleNSAPI["console.openshift.io"]
            QuickStarts[odhquickstarts<br/>get, list]
        end

        subgraph RouteNSAPI["route.openshift.io"]
            RoutesNS[routes<br/>get, list, watch]
        end

        subgraph BatchAPI["batch"]
            CronJobs[cronjobs<br/>create, delete, get, list, patch, update, watch]
            Jobs[jobs, jobs/status<br/>create, delete, get, list, patch, update, watch]
        end

        subgraph ImageNSAPI["image.openshift.io"]
            ImageStreams[imagestreams<br/>create, get, list, update, patch, delete]
        end

        subgraph BuildAPI["build.openshift.io"]
            Builds[builds<br/>get, list, watch, create, patch, delete]
            BuildConfigs[buildconfigs, buildconfigs/instantiate<br/>get, list, watch, create, patch, delete]
        end

        subgraph AppsAPI["apps, apps.openshift.io"]
            Deployments[deployments<br/>patch, update]
            DeploymentConfigs[deploymentconfigs, deploymentconfigs/instantiate<br/>get, list, watch, create, update, patch, delete]
        end

        subgraph OdhAPI["opendatahub.io"]
            OdhDashboardConfigs[odhdashboardconfigs<br/>get, list, watch, create, update, patch, delete]
        end

        subgraph NotebooksNSAPI["kubeflow.org"]
            NotebooksNS[notebooks<br/>get, list, watch, create, update, patch, delete]
        end

        subgraph TemplateAPI["template.openshift.io"]
            Templates[templates<br/>* all verbs]
        end

        subgraph ServingAPI["serving.kserve.io"]
            ServingRuntimes[servingruntimes<br/>* all verbs]
        end
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4
    SA -->|bound via| RB

    CRB1 -->|grants| CR
    CRB2 -->|grants| CRMonitoring
    CRB3 -->|grants| CRAuthDelegator
    CRB4 -->|grants| CRImagePuller
    RB -->|grants| R

