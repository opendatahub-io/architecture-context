graph LR
    subgraph "Core Platform"
        RHOAIOp[RHOAI Operator<br/>rhods-operator]
    end

    subgraph "RHOAI Components"
        Dashboard[ODH Dashboard<br/>v1.21.0-18]
        Notebooks[Workbenches<br/>2024.1]
        NotebookCtrl[ODH Notebook Controller<br/>v1.27.0]
        KServe[KServe<br/>v0.12.1]
        ModelCtrl[ODH Model Controller<br/>v1.27.0-rhods-478]
        ModelMesh[ModelMesh Serving<br/>v1.27.0-rhods-267]
        DSP[Data Science Pipelines<br/>8330c1e]
        Training[Training Operator<br/>80efa250]
        CodeFlare[CodeFlare Operator<br/>v1.10.0]
        KubeRay[KubeRay Operator<br/>v1.1.0]
        Kueue[Kueue<br/>v0.8.1]
        ModelReg[Model Registry Operator<br/>dc70e33]
        TrustyAI[TrustyAI Operator<br/>v1.17.0]
    end

    subgraph "OpenShift Platform Services"
        K8sAPI[Kubernetes API Server]
        Istio[OpenShift Service Mesh<br/>Istio 1.20+]
        Knative[OpenShift Serverless<br/>Knative 1.12+]
        OAuth[OpenShift OAuth]
        Prometheus[OpenShift Monitoring<br/>Prometheus]
        Routes[OpenShift Routes]
        ServiceCA[OpenShift Service CA]
        Authorino[Authorino<br/>Token Auth]
    end

    subgraph "External Storage & Services"
        S3[S3-Compatible Storage<br/>AWS/MinIO/GCS/Azure]
        PostgreSQL[PostgreSQL/MySQL<br/>Metadata DB]
        etcd[etcd<br/>ModelMesh Routing]
        Registries[Container Registries<br/>quay.io, registry.redhat.io]
        PyPI[PyPI<br/>pypi.org]
    end

    subgraph "Optional Services"
        Volcano[Volcano<br/>Gang Scheduling]
        ExternalRedis[External Redis<br/>Ray GCS HA]
    end

    %% RHOAI Operator deploys all components
    RHOAIOp -->|deploys| Dashboard
    RHOAIOp -->|deploys| NotebookCtrl
    RHOAIOp -->|deploys| KServe
    RHOAIOp -->|deploys| ModelCtrl
    RHOAIOp -->|deploys| ModelMesh
    RHOAIOp -->|deploys| DSP
    RHOAIOp -->|deploys| Training
    RHOAIOp -->|deploys| CodeFlare
    RHOAIOp -->|deploys| KubeRay
    RHOAIOp -->|deploys| Kueue
    RHOAIOp -->|deploys| ModelReg
    RHOAIOp -->|deploys| TrustyAI

    %% Platform service dependencies (critical)
    RHOAIOp -->|manages CRs| K8sAPI
    Dashboard -->|API calls| K8sAPI
    NotebookCtrl -->|API calls| K8sAPI
    KServe -->|API calls| K8sAPI
    ModelCtrl -->|API calls| K8sAPI
    ModelMesh -->|API calls| K8sAPI
    DSP -->|API calls| K8sAPI
    Training -->|API calls| K8sAPI
    CodeFlare -->|API calls| K8sAPI
    KubeRay -->|API calls| K8sAPI
    Kueue -->|API calls| K8sAPI
    ModelReg -->|API calls| K8sAPI
    TrustyAI -->|API calls| K8sAPI

    %% Istio (Service Mesh) dependencies
    KServe -->|traffic mgmt<br/>mTLS| Istio
    ModelMesh -.->|optional<br/>mTLS| Istio
    ModelReg -->|traffic mgmt<br/>mTLS<br/>AuthZ| Istio
    TrustyAI -->|VirtualServices<br/>payload logging| Istio

    %% Knative dependencies
    KServe -->|serverless<br/>autoscaling| Knative

    %% OAuth dependencies
    Dashboard -->|user auth| OAuth
    NotebookCtrl -->|OAuth proxy| OAuth
    CodeFlare -->|Ray dashboard<br/>auth| OAuth
    TrustyAI -->|OAuth proxy| OAuth

    %% Prometheus monitoring
    Dashboard -->|queries<br/>metrics| Prometheus
    KServe -->|exports<br/>metrics| Prometheus
    ModelMesh -->|exports<br/>metrics| Prometheus
    Training -->|exports<br/>metrics| Prometheus
    KubeRay -->|exports<br/>metrics| Prometheus
    TrustyAI -->|exports<br/>metrics| Prometheus
    DSP -->|exports<br/>metrics| Prometheus

    %% OpenShift Routes
    Dashboard -->|external<br/>access| Routes
    NotebookCtrl -->|creates<br/>Routes| Routes
    ModelCtrl -->|creates<br/>Routes| Routes
    CodeFlare -->|creates<br/>Routes| Routes
    ModelReg -->|creates<br/>Routes| Routes
    TrustyAI -->|creates<br/>Routes| Routes
    DSP -->|creates<br/>Routes| Routes

    %% Service CA for certificates
    NotebookCtrl -->|TLS certs| ServiceCA
    KServe -->|TLS certs| ServiceCA
    ModelMesh -->|TLS certs| ServiceCA
    DSP -->|TLS certs| ServiceCA
    Training -->|TLS certs| ServiceCA
    CodeFlare -->|TLS certs| ServiceCA
    ModelReg -->|TLS certs| ServiceCA
    TrustyAI -->|TLS certs| ServiceCA

    %% Authorino authentication
    KServe -->|token auth| Authorino
    ModelCtrl -->|creates<br/>AuthConfigs| Authorino
    ModelReg -->|token auth| Authorino

    %% Storage dependencies
    KServe -->|model<br/>artifacts| S3
    ModelMesh -->|model<br/>artifacts| S3
    DSP -->|pipeline<br/>artifacts| S3
    Notebooks -->|datasets<br/>artifacts| S3
    Training -->|training data<br/>checkpoints| S3
    KubeRay -->|datasets| S3

    DSP -->|pipeline<br/>metadata| PostgreSQL
    ModelReg -->|model<br/>metadata| PostgreSQL
    TrustyAI -->|inference<br/>data| PostgreSQL

    ModelMesh -->|routing<br/>metadata| etcd

    %% Registry dependencies
    Notebooks -->|Python<br/>packages| PyPI
    DSP -->|Python<br/>packages| PyPI
    Dashboard -->|container<br/>images| Registries
    KServe -->|runtime<br/>images| Registries
    ModelMesh -->|runtime<br/>images| Registries
    Training -->|runtime<br/>images| Registries
    KubeRay -->|runtime<br/>images| Registries

    %% Inter-component dependencies
    Dashboard -->|UI mgmt| KServe
    Dashboard -->|UI mgmt| NotebookCtrl
    Dashboard -->|UI mgmt| ModelReg
    Dashboard -->|UI mgmt| DSP

    NotebookCtrl -->|manages| Notebooks

    ModelCtrl -->|extends| KServe

    Notebooks -->|deploys| KServe
    Notebooks -->|submits| DSP
    Notebooks -->|registers| ModelReg

    DSP -->|deploys| KServe
    DSP -->|registers| ModelReg

    TrustyAI -->|patches| KServe

    Kueue -->|admits| Training
    Kueue -->|admits| KubeRay

    CodeFlare -->|enhances| KubeRay

    %% Optional dependencies
    Training -.->|optional<br/>gang sched| Volcano
    KubeRay -.->|optional<br/>GCS HA| ExternalRedis

    %% Styling
    classDef coreOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    classDef component fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef platform fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef storage fill:#50e3c2,stroke:#333,stroke-width:2px,color:#000
    classDef optional fill:#f5a623,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5,color:#000

    class RHOAIOp coreOp
    class Dashboard,Notebooks,NotebookCtrl,KServe,ModelCtrl,ModelMesh,DSP,Training,CodeFlare,KubeRay,Kueue,ModelReg,TrustyAI component
    class K8sAPI,Istio,Knative,OAuth,Prometheus,Routes,ServiceCA,Authorino platform
    class S3,PostgreSQL,etcd,Registries,PyPI storage
    class Volcano,ExternalRedis optional
