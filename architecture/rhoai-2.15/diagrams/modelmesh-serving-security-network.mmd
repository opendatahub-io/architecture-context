graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[User/System]
        Client[Inference Client]
    end

    subgraph K8sAPI["KUBERNETES API - Trust Boundary"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC"]
    end

    subgraph Controller["CONTROLLER PLANE - Trusted"]
        direction TB

        subgraph NS_Controller["Namespace: modelmesh-serving"]
            Controller_Pod["modelmesh-controller<br/>SA: modelmesh-controller<br/>50m-1 CPU / 96Mi-512Mi RAM"]
            Webhook_Pod["Validation Webhook<br/>9443/TCP HTTPS<br/>mTLS cert validation"]
            Metrics_Service["Metrics Service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
        end
    end

    subgraph DataPlane["DATA PLANE - Trusted User Namespaces"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            RuntimePod["ModelMesh Runtime Pod<br/>SA: modelmesh-serving-sa<br/>Replicas: 2"]

            subgraph RuntimeContainers["Containers"]
                ModelMesh_Container["modelmesh<br/>8085/TCP mgmt<br/>2112/TCP metrics<br/>300m-3 CPU / 448Mi RAM"]
                Adapter_Container["runtime-adapter<br/>8001/TCP gRPC"]
                Runtime_Container["Model Server<br/>triton/mlserver/ovms/torchserve<br/>8001/TCP gRPC<br/>500m-5 CPU / 1Gi RAM"]
                REST_Container["REST Proxy - optional<br/>8008/TCP HTTP/HTTPS<br/>50m-1 CPU / 96Mi-512Mi RAM"]
            end

            Service_K8s["Service: modelmesh-serving<br/>ClusterIP/Headless<br/>8033/TCP gRPC<br/>8008/TCP HTTP/HTTPS"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        etcd["etcd Cluster<br/>2379/TCP HTTP/HTTPS<br/>TLS optional<br/>Client cert optional<br/>Secret: model-serving-etcd"]
        S3["S3/MinIO Storage<br/>443/9000 TCP HTTPS/HTTP<br/>TLS configurable<br/>AWS SigV4 or Keys<br/>Secret: storage-config"]
        Prometheus["Prometheus<br/>Metrics scraping<br/>8443/TCP HTTPS with Token<br/>2112/TCP HTTP"]
    end

    subgraph ServiceMesh["SERVICE MESH - Optional"]
        Istio["Istio Envoy Sidecars<br/>mTLS STRICT<br/>PeerAuthentication<br/>AuthorizationPolicy"]
    end

    %% External to API
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| APIServer
    Client -->|gRPC/8033 or HTTP/8008<br/>mTLS/TLS optional<br/>Token optional| Service_K8s

    %% API to Webhook
    APIServer -->|HTTPS/9443<br/>mTLS<br/>API Server cert| Webhook_Pod
    Webhook_Pod -->|Validation result| APIServer

    %% API to Controller
    APIServer -->|Watch events<br/>CRD notifications| Controller_Pod
    Controller_Pod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create/Update resources| APIServer

    %% Controller to etcd
    Controller_Pod -->|HTTP/HTTPS 2379<br/>TLS optional<br/>Client cert optional| etcd

    %% Service to Runtime
    Service_K8s -->|Routes to| RuntimePod
    RuntimePod -->|Contains| ModelMesh_Container
    RuntimePod -->|Contains| Adapter_Container
    RuntimePod -->|Contains| Runtime_Container
    RuntimePod -->|Contains| REST_Container

    %% Runtime internal communication
    REST_Container -->|gRPC/8033<br/>Localhost| ModelMesh_Container
    ModelMesh_Container -->|gRPC/8085<br/>Localhost| Adapter_Container
    Adapter_Container -->|gRPC/8001<br/>Localhost| Runtime_Container

    %% Runtime to External Services
    ModelMesh_Container -->|HTTP/HTTPS 2379<br/>TLS optional| etcd
    Runtime_Container -->|HTTPS/HTTP 443/9000<br/>TLS configurable<br/>AWS SigV4 or Keys| S3

    %% Metrics
    Prometheus -->|HTTPS/8443<br/>ServiceAccount Token| Metrics_Service
    Metrics_Service -->|Proxies| Controller_Pod
    Prometheus -->|HTTP/2112| ModelMesh_Container

    %% Service Mesh integration
    Service_K8s -.->|Optional mTLS| Istio
    RuntimePod -.->|Sidecar injection| Istio

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,Client external
    class APIServer k8sapi
    class Controller_Pod,Webhook_Pod,Metrics_Service controller
    class RuntimePod,ModelMesh_Container,Adapter_Container,Runtime_Container,REST_Container,Service_K8s dataplane
    class etcd,S3,Prometheus externalservice
    class Istio servicemesh
