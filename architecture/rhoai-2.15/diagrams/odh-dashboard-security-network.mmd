graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph ServiceMesh["SERVICE MESH (Trusted - Dashboard Namespace)"]
        direction TB

        subgraph DashboardPod["Dashboard Pod"]
            OAuthProxy["OAuth Proxy Container<br/>Port: 8443/TCP HTTPS<br/>Cert: dashboard-proxy-tls<br/>SA: odh-dashboard"]
            Backend["Dashboard Backend Container<br/>Port: 8080/TCP HTTP<br/>Runtime: Node.js 18 / Fastify<br/>SA: odh-dashboard"]
        end

        Service["Service: odh-dashboard<br/>ClusterIP<br/>8443/TCP"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>OAuth 2.0 Flow"]
    end

    subgraph InternalServices["INTERNAL SERVICES (OpenShift Cluster)"]
        Prometheus["Prometheus<br/>prometheus-k8s.openshift-monitoring.svc<br/>9091/TCP HTTPS TLS 1.2+<br/>SA Token"]
        ImageRegistry["OpenShift Image Registry<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token"]
        ModelRegistry["Model Registry Services<br/>{namespace}.svc<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        KServe["KServe InferenceServices<br/>{namespace}.svc<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ISV["Partner ISV Services<br/>443/TCP HTTPS TLS 1.2+<br/>Auth Varies"]
    end

    %% Network flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token cookie| Route
    Route -->|HTTPS/8443<br/>TLS 1.2+ service cert<br/>Bearer Token| Service
    Service -->|8443| OAuthProxy
    OAuthProxy -->|OAuth validation<br/>HTTPS/443 TLS 1.2+| OAuthServer
    OAuthProxy -->|HTTP/8080 localhost<br/>Bearer Token header<br/>Auth skipped: /metrics| Backend

    Backend -->|HTTPS/443 TLS 1.2+<br/>ServiceAccount Token<br/>RBAC: ClusterRole + Role| K8sAPI
    Backend -->|HTTPS/9091 TLS 1.2+<br/>SA Token<br/>RBAC: cluster-monitoring-view| Prometheus
    Backend -->|HTTPS/443 TLS 1.2+<br/>SA Token<br/>RBAC: system:image-puller| ImageRegistry
    Backend -->|HTTPS/443 TLS 1.2+<br/>Bearer Token| ModelRegistry
    Backend -->|HTTPS/443 TLS 1.2+<br/>Bearer Token| KServe
    Backend -->|HTTPS/443 TLS 1.2+<br/>Auth Varies| ISV

    %% Metrics scraping (reverse direction)
    Prometheus -.->|Scrape /metrics<br/>HTTPS/443 via Route<br/>Auth skipped| Route

    %% Annotations
    note1[/"Secrets:<br/>- dashboard-proxy-tls (TLS cert, auto-rotate)<br/>- dashboard-oauth-config-generated (cookie secret)<br/>- dashboard-oauth-client-generated (OAuth client)"/]
    note2[/"RBAC:<br/>ClusterRole: odh-dashboard<br/>Role: odh-dashboard (namespace)<br/>ClusterRoleBindings: 4<br/>RoleBinding: 1 (namespace)"/]
    note3[/"Deployment:<br/>Replicas: 2 (anti-affinity)<br/>Resources: 500m-1000m CPU, 1Gi-2Gi mem<br/>Health: TCP 8080, HTTPS 8443"/]

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef note fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Route ingress
    class Service,OAuthProxy,Backend,DashboardPod servicemesh
    class K8sAPI,OAuthServer controlplane
    class Prometheus,ImageRegistry,ModelRegistry,KServe internal
    class ISV externalservice
    class note1,note2,note3 note
