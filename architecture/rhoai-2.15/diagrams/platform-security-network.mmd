graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientists<br/>External Clients]
    end

    subgraph Ingress["INGRESS TIER"]
        direction TB

        subgraph Routes["OpenShift Routes"]
            DashboardRoute["Dashboard Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt<br/>OAuth"]
            NotebookRoute["Notebook Routes<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Reencrypt<br/>OAuth"]
            PipelineRoute["Pipeline UI Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt<br/>OAuth"]
            RayRoute["Ray Dashboard Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt<br/>OAuth"]
            TrustyAIRoute["TrustyAI Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt<br/>OAuth"]
        end

        subgraph IstioGW["Istio Gateway (istio-system)"]
            KServeGW["KServe Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ Passthrough<br/>Authorino"]
            ModelMeshGW["ModelMesh Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ Passthrough<br/>None/Authorino"]
            ModelRegGW["Model Registry Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ Passthrough<br/>Authorino"]
        end
    end

    subgraph Controllers["APPLICATION CONTROLLER TIER<br/>(redhat-ods-applications)"]
        direction LR

        DashboardPod["Dashboard Pods<br/>SA: odh-dashboard<br/>8080/8443 TCP"]
        NotebookCtrl["Notebook Controller<br/>SA: odh-notebook-controller-sa<br/>9443/TCP Webhook"]
        KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager<br/>9443/TCP Webhook"]
        ModelCtrl["ODH Model Controller<br/>SA: odh-model-controller"]
        OtherCtrl["Other Operators<br/>(ModelMesh, Training, CodeFlare,<br/>KubeRay, Kueue, Model Reg,<br/>TrustyAI, DSP)"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph UserNS["User Workload Tier ({user-namespaces})"]
            direction TB

            NotebookPod["Jupyter Notebook<br/>SA: {notebook-name}<br/>8888/TCP JupyterLab<br/>OAuth Proxy 8443/TCP<br/>PVC: {notebook-name}-pvc"]

            PredictorPod["KServe Predictor<br/>SA: {isvc-name}-sa<br/>8080/TCP HTTP mTLS<br/>8081/TCP gRPC<br/>Init: storage-initializer<br/>Sidecar: istio-proxy"]

            ModelMeshPod["ModelMesh Predictor<br/>SA: modelmesh-serving-sa<br/>8033/TCP gRPC<br/>2112/TCP metrics"]

            DSPStack["DSP Stack<br/>API Server: 8888/8887 TCP<br/>MariaDB: 3306/TCP<br/>Minio: 9000/TCP<br/>OAuth Proxy: 8443/TCP"]

            TrainingPod["Training Job Pods<br/>SA: {job-name}-sa<br/>Variable ports<br/>(PyTorch/TF/MPI)"]

            RayCluster["Ray Cluster<br/>Head: 6379/8265/10001 TCP<br/>Workers: Dynamic<br/>OAuth Proxy: 8443/TCP<br/>mTLS: CodeFlare CA"]

            ModelRegPod["Model Registry<br/>SA: model-registry-{name}<br/>8080/TCP REST<br/>9090/TCP gRPC<br/>Sidecar: istio-proxy<br/>Authorino ext-authz"]

            TrustyAIPod["TrustyAI Service<br/>SA: trustyai-service-{name}<br/>8080/TCP API<br/>OAuth Proxy: 8443/TCP<br/>Storage: PVC/PostgreSQL"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        S3["S3 Storage<br/>(AWS/MinIO/GCS/Azure)<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / Access Keys"]

        Database["PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ optional<br/>Username/Password"]

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Tokens"]

        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS TLS 1.2+<br/>User Credentials/IdP"]

        Registries["Package Registries<br/>(pypi.org, quay.io)<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secrets"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| DashboardRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| NotebookRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| PipelineRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RayRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| TrustyAIRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| KServeGW
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>None/Bearer| ModelMeshGW
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| ModelRegGW

    %% Ingress to Controllers
    DashboardRoute -->|HTTP/8443<br/>OAuth Validated| DashboardPod
    PipelineRoute -->|HTTP/8443<br/>OAuth Validated| DSPStack

    %% Ingress to Service Mesh
    NotebookRoute -->|HTTP/8443<br/>OAuth Validated| NotebookPod
    RayRoute -->|HTTP/8443<br/>OAuth Validated| RayCluster
    TrustyAIRoute -->|HTTP/8443<br/>OAuth Validated| TrustyAIPod

    KServeGW -->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity| PredictorPod
    ModelMeshGW -->|gRPC/8033<br/>mTLS/Plaintext| ModelMeshPod
    ModelRegGW -->|HTTP/8080 gRPC/9090<br/>mTLS STRICT<br/>Authorino| ModelRegPod

    %% Controllers to Workloads
    NotebookCtrl -->|Manages| NotebookPod
    KServeCtrl -->|Manages| PredictorPod
    ModelCtrl -->|Extends| PredictorPod
    OtherCtrl -->|Manages| ModelMeshPod
    OtherCtrl -->|Manages| TrainingPod
    OtherCtrl -->|Manages| RayCluster
    OtherCtrl -->|Manages| ModelRegPod
    OtherCtrl -->|Manages| TrustyAIPod

    %% Workload to External Services
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+ AWS IAM| S3
    PredictorPod -->|HTTPS/443<br/>TLS 1.2+ AWS IAM| S3
    ModelMeshPod -->|HTTPS/443<br/>TLS 1.2+ AWS IAM| S3
    TrainingPod -->|HTTPS/443<br/>TLS 1.2+ AWS IAM| S3
    DSPStack -->|HTTPS/443<br/>TLS 1.2+ AWS IAM| S3

    DSPStack -->|MySQL/3306<br/>TLS optional<br/>Username/Password| Database
    ModelRegPod -->|PostgreSQL/5432<br/>TLS optional<br/>Username/Password| Database
    TrustyAIPod -->|PostgreSQL/5432<br/>TLS optional<br/>Username/Password| Database

    DashboardPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    NotebookCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    KServeCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    ModelCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    OtherCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| OAuthServer
    RayCluster -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| OAuthServer
    TrustyAIPod -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| OAuthServer

    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registries
    DSPStack -->|HTTPS/443<br/>TLS 1.2+<br/>None| Registries

    %% Inter-workload communication
    NotebookPod -->|gRPC/9090<br/>mTLS STRICT<br/>Bearer Token| ModelRegPod
    DSPStack -->|HTTP/8080<br/>K8s API| PredictorPod
    TrustyAIPod -->|HTTP/8080<br/>mTLS| PredictorPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef servicemesh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class DashboardRoute,NotebookRoute,PipelineRoute,RayRoute,TrustyAIRoute,KServeGW,ModelMeshGW,ModelRegGW ingress
    class DashboardPod,NotebookCtrl,KServeCtrl,ModelCtrl,OtherCtrl controller
    class NotebookPod,PredictorPod,ModelMeshPod,DSPStack,TrainingPod,RayCluster,ModelRegPod,TrustyAIPod servicemesh
    class S3,Database,K8sAPI,OAuthServer,Registries externalservice
