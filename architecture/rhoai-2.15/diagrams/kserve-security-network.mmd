graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+ Termination<br/>AuthorizationPolicy<br/>Bearer Token Validation"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Scale-from-zero"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            subgraph PredictorPod["Predictor Pod"]
                StorageInit["Init: storage-initializer<br/>Downloads model artifacts"]
                ModelServer["Container: model-server<br/>sklearn/xgboost/pytorch/etc<br/>Port: 8080/TCP"]
                Agent["Sidecar: kserve-agent<br/>logging/batching (optional)"]
                IstioProxy1["Sidecar: istio-proxy<br/>automatic mTLS"]

                StorageInit -.->|loads| ModelServer
            end

            subgraph TransformerPod["Transformer Pod (optional)"]
                TransformerContainer["Container: transformer<br/>Port: 8080/TCP"]
                IstioProxy2["Sidecar: istio-proxy"]
            end

            subgraph ExplainerPod["Explainer Pod (optional)"]
                ExplainerContainer["Container: explainer<br/>alibi/art<br/>Port: 8080/TCP"]
                IstioProxy3["Sidecar: istio-proxy"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/GCS/Azure Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / GCP SA / Azure Creds"]
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: kserve)"]
        Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>8081/TCP: healthz/readyz (HTTP)<br/>8443/TCP: metrics (HTTPS)"]
        Webhook["kserve-webhook-server<br/>9443/TCP HTTPS mTLS<br/>Cert: kserve-webhook-server-cert"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token/None"| Gateway

    %% Ingress → Service Mesh
    Gateway -->|"HTTP/80<br/>mTLS STRICT<br/>Service Identity"| Activator
    Activator -->|"HTTP/8080<br/>mTLS<br/>Service Identity"| ModelServer

    %% Internal Service Mesh Flows
    TransformerContainer -->|"HTTP/8080<br/>mTLS"| ModelServer
    ExplainerContainer -->|"HTTP/8080<br/>mTLS"| ModelServer

    %% Storage Initialization
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/GCP SA/Azure"| S3

    %% Control Plane Flows
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token"| K8sAPI
    Webhook -->|"HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>mTLS<br/>Admission Webhooks"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px

    class Client external
    class Gateway ingress
    class Activator,PredictorPod,TransformerPod,ExplainerPod,ModelServer,TransformerContainer,ExplainerContainer,StorageInit,Agent,IstioProxy1,IstioProxy2,IstioProxy3 servicemesh
    class S3 externalservice
    class Controller,Webhook,K8sAPI controlplane
