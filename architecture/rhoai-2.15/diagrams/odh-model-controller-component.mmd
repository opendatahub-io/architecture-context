graph TB
    subgraph "ODH Model Controller"
        Controller[odh-model-controller<br/>Main Controller Manager]
        Webhook[Knative Service Validator<br/>Webhook Server]

        subgraph "Reconcilers"
            OSISReconciler[OpenshiftInferenceService<br/>Reconciler]
            StorageReconciler[StorageSecret<br/>Reconciler]
            CAReconciler[KServeCustomCACert<br/>Reconciler]
            MonitoringReconciler[Monitoring<br/>Reconciler]
            ModelRegReconciler[ModelRegistry<br/>Reconciler]
        end

        Controller --> OSISReconciler
        Controller --> StorageReconciler
        Controller --> CAReconciler
        Controller --> MonitoringReconciler
        Controller --> ModelRegReconciler
    end

    subgraph "Watched CRDs"
        InferenceService[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        DataScienceCluster[DataScienceCluster<br/>datasciencecluster.opendatahub.io/v1]
        DSCInit[DSCInitialization<br/>dscinitialization.opendatahub.io/v1]
    end

    subgraph "Created Resources"
        Route[OpenShift Routes<br/>External Access]
        VirtualService[Istio VirtualServices<br/>Traffic Routing]
        PeerAuth[PeerAuthentications<br/>mTLS Configuration]
        AuthConfig[AuthConfig<br/>Authorino Policies]
        ServiceMonitor[ServiceMonitors<br/>Prometheus Integration]
        NetworkPolicy[NetworkPolicies<br/>Traffic Control]
        SMM[ServiceMeshMembers<br/>Mesh Integration]
    end

    subgraph "Serving Runtime Templates"
        vLLM[vLLM Runtime<br/>LLM Inference]
        TGIS[TGIS Runtime<br/>Text Generation]
        Caikit[Caikit Runtime<br/>Framework Serving]
        OVMS[OpenVINO Model Server<br/>Multi-Model Serving]
    end

    subgraph "External Dependencies"
        KServe[KServe Controller<br/>Core InferenceService Mgmt]
        Istio[Istio Service Mesh<br/>Traffic & mTLS]
        Knative[Knative Serving<br/>Serverless Platform]
        Authorino[Authorino<br/>Authentication]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    %% Watching relationships
    InferenceService -->|watched by| OSISReconciler
    ServingRuntime -->|managed by| OSISReconciler
    DataScienceCluster -->|read by| Controller
    DSCInit -->|read by| Controller

    %% Creation relationships
    OSISReconciler -->|creates| Route
    OSISReconciler -->|creates| VirtualService
    OSISReconciler -->|creates| PeerAuth
    OSISReconciler -->|creates| AuthConfig
    MonitoringReconciler -->|creates| ServiceMonitor
    OSISReconciler -->|creates| NetworkPolicy
    OSISReconciler -->|creates| SMM

    %% Runtime template management
    Controller -->|deploys| vLLM
    Controller -->|deploys| TGIS
    Controller -->|deploys| Caikit
    Controller -->|deploys| OVMS

    %% External integrations
    Controller -->|co-manages| KServe
    OSISReconciler -->|integrates| Istio
    OSISReconciler -->|validates for| Knative
    OSISReconciler -->|configures| Authorino
    MonitoringReconciler -->|configures| Prometheus

    %% Webhook validation
    Webhook -->|validates| Knative

