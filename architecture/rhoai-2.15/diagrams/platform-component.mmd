graph TB
    subgraph "Platform Operator Tier"
        RHOAIOp[RHOAI Operator<br/>rhods-operator]
    end

    subgraph "Application Controller Tier"
        Dashboard[ODH Dashboard<br/>v1.21.0-18]
        NotebookCtrl[ODH Notebook Controller<br/>v1.27.0]
        ModelCtrl[ODH Model Controller<br/>v1.27.0-rhods-478]
        KServeCtrl[KServe Controller<br/>v0.12.1]
        ModelMeshCtrl[ModelMesh Controller<br/>v1.27.0-rhods-267]
        DSPOp[DSP Operator<br/>8330c1e]
        TrainingOp[Training Operator<br/>80efa250]
        CodeFlareOp[CodeFlare Operator<br/>v1.10.0]
        KubeRayOp[KubeRay Operator<br/>v1.1.0]
        KueueCtrl[Kueue Controller<br/>v0.8.1]
        ModelRegOp[Model Registry Operator<br/>dc70e33]
        TrustyAIOp[TrustyAI Operator<br/>v1.17.0]
    end

    subgraph "User Workload Tier"
        Notebooks[Jupyter/RStudio/VSCode<br/>Workbenches]
        InferenceService[KServe InferenceServices<br/>Serverless Model Serving]
        ModelMesh[ModelMesh Predictors<br/>Multi-Model Serving]
        Pipelines[Data Science Pipelines<br/>Kubeflow/Argo]
        TrainingJobs[Training Jobs<br/>PyTorch/TF/MPI/XGBoost]
        RayClusters[Ray Clusters<br/>Distributed Computing]
        ModelRegistry[Model Registry<br/>ML Metadata]
        TrustyAI[TrustyAI Services<br/>AI Explainability]
    end

    subgraph "Platform Services"
        Istio[Istio Service Mesh<br/>Traffic + mTLS]
        Knative[Knative Serving<br/>Serverless]
        OAuth[OpenShift OAuth<br/>Authentication]
        Prometheus[Prometheus<br/>Monitoring]
        Routes[OpenShift Routes<br/>Ingress]
        Authorino[Authorino<br/>Token Auth]
    end

    subgraph "External Storage"
        S3[S3/Object Storage<br/>Models + Artifacts]
        PostgreSQL[PostgreSQL/MySQL<br/>Metadata]
        etcd[etcd<br/>ModelMesh Routing]
    end

    %% Operator relationships
    RHOAIOp -->|deploys| Dashboard
    RHOAIOp -->|deploys| NotebookCtrl
    RHOAIOp -->|deploys| ModelCtrl
    RHOAIOp -->|deploys| KServeCtrl
    RHOAIOp -->|deploys| ModelMeshCtrl
    RHOAIOp -->|deploys| DSPOp
    RHOAIOp -->|deploys| TrainingOp
    RHOAIOp -->|deploys| CodeFlareOp
    RHOAIOp -->|deploys| KubeRayOp
    RHOAIOp -->|deploys| KueueCtrl
    RHOAIOp -->|deploys| ModelRegOp
    RHOAIOp -->|deploys| TrustyAIOp

    %% Controller to workload relationships
    NotebookCtrl -->|manages| Notebooks
    KServeCtrl -->|manages| InferenceService
    ModelCtrl -->|extends| InferenceService
    ModelMeshCtrl -->|manages| ModelMesh
    DSPOp -->|manages| Pipelines
    TrainingOp -->|manages| TrainingJobs
    CodeFlareOp -->|enhances| RayClusters
    KubeRayOp -->|manages| RayClusters
    ModelRegOp -->|manages| ModelRegistry
    TrustyAIOp -->|manages| TrustyAI

    %% Platform service dependencies
    InferenceService -->|uses| Knative
    InferenceService -->|uses| Istio
    ModelRegistry -->|uses| Istio
    ModelMesh -->|uses| Istio
    TrustyAI -->|uses| Istio

    Notebooks -->|uses| Routes
    InferenceService -->|uses| Routes
    ModelMesh -->|uses| Routes
    Pipelines -->|uses| Routes
    RayClusters -->|uses| Routes
    ModelRegistry -->|uses| Routes
    TrustyAI -->|uses| Routes

    Dashboard -->|uses| OAuth
    Notebooks -->|uses| OAuth
    RayClusters -->|uses| OAuth
    TrustyAI -->|uses| OAuth

    InferenceService -->|uses| Authorino
    ModelRegistry -->|uses| Authorino

    %% Storage dependencies
    InferenceService -->|loads from| S3
    ModelMesh -->|loads from| S3
    Pipelines -->|stores to| S3
    Notebooks -->|reads/writes| S3

    Pipelines -->|stores to| PostgreSQL
    ModelRegistry -->|stores to| PostgreSQL
    TrustyAI -->|stores to| PostgreSQL

    ModelMesh -->|routes via| etcd

    %% Monitoring
    Dashboard -->|queries| Prometheus
    KServeCtrl -->|exports to| Prometheus
    ModelMeshCtrl -->|exports to| Prometheus
    TrainingOp -->|exports to| Prometheus
    KubeRayOp -->|exports to| Prometheus
    TrustyAIOp -->|exports to| Prometheus

    %% Integration flows
    Dashboard -->|UI mgmt| KServeCtrl
    Dashboard -->|UI mgmt| NotebookCtrl
    Dashboard -->|UI mgmt| ModelRegistry
    Dashboard -->|UI mgmt| Pipelines

    Notebooks -->|deploys| InferenceService
    Notebooks -->|submits| Pipelines
    Notebooks -->|registers| ModelRegistry

    Pipelines -->|deploys| InferenceService
    Pipelines -->|registers| ModelRegistry

    TrustyAIOp -->|patches| InferenceService

    KueueCtrl -->|admits| TrainingJobs
    KueueCtrl -->|admits| RayClusters

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef controller fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef workload fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef platform fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef storage fill:#50e3c2,stroke:#333,stroke-width:2px,color:#000

    class RHOAIOp operator
    class Dashboard,NotebookCtrl,ModelCtrl,KServeCtrl,ModelMeshCtrl,DSPOp,TrainingOp,CodeFlareOp,KubeRayOp,KueueCtrl,ModelRegOp,TrustyAIOp controller
    class Notebooks,InferenceService,ModelMesh,Pipelines,TrainingJobs,RayClusters,ModelRegistry,TrustyAI workload
    class Istio,Knative,OAuth,Prometheus,Routes,Authorino platform
    class S3,PostgreSQL,etcd storage
