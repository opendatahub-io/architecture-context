graph LR
    KServe[KServe Operator<br/>v0.12.1]

    %% External Dependencies
    KServe -->|"traffic mgmt<br/>VirtualService/Gateway"| Istio[Istio Service Mesh<br/>1.19+<br/>REQUIRED]
    KServe -->|"serverless autoscaling<br/>Knative Service CRD"| Knative[Knative Serving<br/>0.39.3<br/>OPTIONAL]
    KServe -->|"TLS cert mgmt<br/>(not used in RHOAI)"| CertManager[cert-manager<br/>Latest<br/>OPTIONAL]
    KServe -->|"metrics scraping<br/>/metrics endpoint"| Prometheus[Prometheus<br/>Latest<br/>OPTIONAL]
    KServe -->|"container platform"| Kubernetes[Kubernetes<br/>1.28+<br/>REQUIRED]

    %% Internal ODH/RHOAI Dependencies
    KServe -->|"mTLS, traffic routing<br/>VirtualService, Gateway"| ServiceMesh[Service Mesh - Istio<br/>INTERNAL]
    KServe -->|"auth tokens<br/>Bearer Token"| OAuth[OpenShift OAuth<br/>INTERNAL]
    KServe -.->|"model metadata<br/>HTTP/9090 gRPC"| ModelRegistry[Model Registry<br/>OPTIONAL INTERNAL]
    KServe -.->|"UI management<br/>REST API"| Dashboard[ODH Dashboard<br/>INTERNAL]

    %% Integration Points
    Dashboard -->|"creates/manages<br/>InferenceService CR"| KServe
    Pipelines[Data Science Pipelines<br/>INTERNAL] -.->|"auto-deploy models<br/>InferenceService CR"| KServe
    KnativeEventing[Knative Eventing<br/>OPTIONAL] -.->|"request/response logging<br/>CloudEvents/HTTP"| KServe

    %% External Services
    KServe -->|"model artifacts<br/>HTTPS/443"| S3[S3-compatible Storage<br/>PRIMARY]
    KServe -->|"model artifacts<br/>HTTPS/443"| GCS[Google Cloud Storage<br/>OPTIONAL]
    KServe -->|"model artifacts<br/>HTTPS/443"| Azure[Azure Blob Storage<br/>OPTIONAL]
    KServe -->|"CRUD operations<br/>HTTPS/6443"| K8sAPI[Kubernetes API Server<br/>REQUIRED]

