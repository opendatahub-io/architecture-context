graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ passthrough"]
        Gateway["Istio Ingress Gateway<br/>Namespace: istio-system<br/>80/443 TCP<br/>TLS: SIMPLE/MUTUAL/ISTIO_MUTUAL"]

        Router --> Gateway
    end

    subgraph Authorization["AUTHORIZATION LAYER"]
        Authorino["Authorino<br/>50051/TCP gRPC<br/>mTLS (ISTIO_MUTUAL)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS1.2+"]

        Authorino -->|TokenReview<br/>SubjectAccessReview| K8sAPI
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Registry["Namespace: {registry-namespace}"]
            Service["Model Registry Service<br/>ClusterIP<br/>8080/TCP (REST)<br/>9090/TCP (gRPC)"]

            subgraph Pod["Model Registry Pod<br/>SA: {registry-name}"]
                EnvoySidecar["Envoy Sidecar<br/>mTLS termination"]
                RestContainer["REST Container<br/>8080/TCP HTTP<br/>quay.io/opendatahub/model-registry"]
                GrpcContainer["gRPC Container<br/>9090/TCP gRPC<br/>quay.io/opendatahub/mlmd-grpc-server"]

                EnvoySidecar -->|"localhost<br/>no encryption"| RestContainer
                RestContainer -->|"localhost 9090<br/>plaintext gRPC"| GrpcContainer
            end

            Service --> EnvoySidecar
        end
    end

    subgraph OperatorControlPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: {operator-namespace}"]
            OperatorPod["Controller Manager<br/>SA: controller-manager"]
            WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS1.2+ mTLS"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>TLS1.2+ mTLS"]

            OperatorPod --> WebhookSvc
            OperatorPod --> MetricsSvc
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (optional sslmode)<br/>Auth: user/pass + optional client cert"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS (optional SSL)<br/>Auth: user/pass + optional client cert"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% Main flow with Istio
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Router
    Gateway -->|"gRPC/50051<br/>mTLS<br/>ext-authz"| Authorino
    Gateway -->|"HTTP 8080 or gRPC 9090<br/>mTLS (ISTIO_MUTUAL)"| Service

    %% Database connections
    GrpcContainer -->|"PostgreSQL/5432<br/>TLS (optional)<br/>user/pass"| PostgreSQL
    GrpcContainer -->|"MySQL/3306<br/>TLS (optional)<br/>user/pass"| MySQL

    %% Operator flows
    OperatorPod -->|"HTTPS/443<br/>TLS1.2+<br/>SA token"| K8sAPI
    K8sAPIWebhook[Kubernetes API<br/>Admission] -->|"HTTPS/443<br/>mTLS"| WebhookSvc
    Prometheus -->|"HTTPS/8443<br/>mTLS"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authz fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router,Gateway ingress
    class Authorino,K8sAPI authz
    class Service,EnvoySidecar,RestContainer,GrpcContainer,Pod servicemesh
    class OperatorPod,WebhookSvc,MetricsSvc operator
    class PostgreSQL,MySQL,Prometheus externalservice
