graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>Controller ServiceAccount]
        SA_Runtime[modelmesh-serving-sa<br/>Runtime Pods ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB_LeaderElection[leader-election-rolebinding<br/>RoleBinding]
        CRB_Proxy[proxy-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Controller[modelmesh-controller-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_AuthProxy[auth-proxy-role<br/>ClusterRole]
    end

    subgraph "API Resources - serving.kserve.io"
        direction TB
        API_InferenceService[InferenceService<br/>v1beta1]
        API_Predictor[Predictor<br/>v1alpha1]
        API_ServingRuntime[ServingRuntime<br/>v1alpha1]
        API_ClusterServingRuntime[ClusterServingRuntime<br/>v1alpha1]
        API_Status[Status & Finalizers<br/>Sub-resources]
    end

    subgraph "API Resources - Core"
        direction TB
        Core_ConfigMaps[ConfigMaps]
        Core_Secrets[Secrets]
        Core_Services[Services]
        Core_Namespaces[Namespaces]
        Core_Endpoints[Endpoints]
        Core_PVCs[PersistentVolumeClaims]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[Deployments]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - Autoscaling"
        Autoscaling_HPA[HorizontalPodAutoscalers]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[Leases<br/>coordination.k8s.io]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReviews[TokenReviews<br/>authentication.k8s.io]
        Auth_SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io]
    end

    %% ServiceAccount to ClusterRoleBindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_Proxy

    %% ClusterRoleBindings to ClusterRoles
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_Proxy -->|grants| CR_AuthProxy

    %% ClusterRole Permissions - Controller Role
    CR_Controller -->|get, list, watch, create, update, patch, delete| API_InferenceService
    CR_Controller -->|get, list, watch, create, update, patch, delete| API_Predictor
    CR_Controller -->|get, list, watch, create, update, patch, delete| API_ServingRuntime
    CR_Controller -->|get, list, watch, create, update, patch, delete| API_ClusterServingRuntime
    CR_Controller -->|get, patch, update| API_Status

    CR_Controller -->|create, delete, get, list, patch, update, watch| Core_ConfigMaps
    CR_Controller -->|create, delete, get, list, patch, update, watch| Core_Secrets
    CR_Controller -->|create, delete, get, list, patch, update, watch| Core_Services
    CR_Controller -->|get, list, watch| Core_Namespaces
    CR_Controller -->|get, list, watch| Core_Endpoints
    CR_Controller -->|get, list, watch| Core_PVCs

    CR_Controller -->|create, delete, get, list, patch, update, watch| Apps_Deployments
    CR_Controller -->|create, delete, get, list, patch, update, watch| Monitoring_ServiceMonitors
    CR_Controller -->|get, list, watch, create, delete, update| Autoscaling_HPA

    %% Leader Election Role
    CR_LeaderElection -->|get, list, watch, create, update, patch, delete| Core_ConfigMaps
    CR_LeaderElection -->|get, list, watch, create, update, patch, delete| Coord_Leases

    %% Auth Proxy Role
    CR_AuthProxy -->|create| Auth_TokenReviews
    CR_AuthProxy -->|create| Auth_SubjectAccessReviews

    %% Runtime ServiceAccount (minimal permissions)
    SA_Runtime -.->|implicit| Core_Secrets
    SA_Runtime -.->|storage access| Core_Secrets

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Runtime fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CRB_Controller fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
    style CRB_LeaderElection fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
    style CRB_Proxy fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000

    style API_InferenceService fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style API_Predictor fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style API_ServingRuntime fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style API_ClusterServingRuntime fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style API_Status fill:#7ed321,stroke:#333,stroke-width:1px,color:#000

    style Core_ConfigMaps fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000
    style Core_Secrets fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000
    style Core_Services fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000
    style Core_Namespaces fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000
    style Core_Endpoints fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000
    style Core_PVCs fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000

    style Apps_Deployments fill:#d5e8d4,stroke:#333,stroke-width:1px,color:#000
    style Monitoring_ServiceMonitors fill:#d5e8d4,stroke:#333,stroke-width:1px,color:#000
    style Autoscaling_HPA fill:#d5e8d4,stroke:#333,stroke-width:1px,color:#000
    style Coord_Leases fill:#d5e8d4,stroke:#333,stroke-width:1px,color:#000

    style Auth_TokenReviews fill:#ffe6cc,stroke:#333,stroke-width:1px,color:#000
    style Auth_SubjectAccessReviews fill:#ffe6cc,stroke:#333,stroke-width:1px,color:#000
