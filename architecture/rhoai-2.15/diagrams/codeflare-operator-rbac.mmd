graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA1[controller-manager<br/>Namespace: redhat-ods-applications]
        SA2["{raycluster}-oauth-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB1[manager-rolebinding]
        CRB2["{raycluster}-oauth-binding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR1[manager-role]
        CR2["system:auth-delegator<br/>(built-in)"]
    end

    subgraph APIResources["API Resources & Permissions"]
        direction TB

        subgraph Core["Core Resources"]
            Core1["pods, services, secrets,<br/>serviceaccounts, events, nodes<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Apps["Apps Resources"]
            Apps1["deployments, statefulsets<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Batch["Batch Resources"]
            Batch1["jobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Networking["Networking Resources"]
            Net1["ingresses, networkpolicies<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RBAC["RBAC Resources"]
            RBAC1["clusterrolebindings<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph OpenShift["OpenShift Resources"]
            OS1["routes, routes/custom-host<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
            OS2["config.openshift.io/ingresses<br/>Verbs: get"]
        end

        subgraph Ray["Ray Resources"]
            Ray1["rayclusters, rayclusters/status,<br/>rayclusters/finalizers, rayjobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph CodeFlare["CodeFlare Resources"]
            CF1["appwrappers, appwrappers/status,<br/>appwrappers/finalizers<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Kueue["Kueue Resources"]
            Kueue1["workloads, workloads/status,<br/>workloads/finalizers,<br/>clusterqueues, resourceflavors,<br/>workloadpriorityclasses<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Kubeflow["Kubeflow Resources"]
            KF1["pytorchjobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Scheduling["Scheduling Resources"]
            Sched1["podgroups (various API groups)<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
            Sched2["priorityclasses<br/>Verbs: get, list, watch"]
        end

        subgraph Admission["Admission Resources"]
            Adm1["mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations<br/>Verbs: get, list, watch, update"]
        end

        subgraph CRDs["CRD Resources"]
            CRD1["customresourcedefinitions<br/>Verbs: get, list, watch"]
        end

        subgraph ODH["ODH Resources"]
            ODH1["dscinitializations<br/>Verbs: get, list, watch"]
        end

        subgraph Auth["Auth Resources"]
            Auth1["tokenreviews,<br/>subjectaccessreviews<br/>Verbs: create"]
        end
    end

    subgraph OAuthPermissions["OAuth Proxy Permissions"]
        OAuth1["Delegate authentication<br/>to OpenShift OAuth"]
    end

    %% Bindings
    SA1 -->|bound via| CRB1
    CRB1 -->|grants| CR1

    SA2 -->|bound via| CRB2
    CRB2 -->|grants| CR2

    %% Permissions
    CR1 -->|manages| Core1
    CR1 -->|manages| Apps1
    CR1 -->|manages| Batch1
    CR1 -->|manages| Net1
    CR1 -->|manages| RBAC1
    CR1 -->|manages| OS1
    CR1 -->|reads| OS2
    CR1 -->|manages| Ray1
    CR1 -->|manages| CF1
    CR1 -->|manages| Kueue1
    CR1 -->|manages| KF1
    CR1 -->|manages| Sched1
    CR1 -->|reads| Sched2
    CR1 -->|updates| Adm1
    CR1 -->|reads| CRD1
    CR1 -->|reads| ODH1
    CR1 -->|creates| Auth1

    CR2 -->|enables| OAuth1

    %% Styling
    style SA1 fill:#4a90e2,color:#fff
    style SA2 fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623,color:#000
    style CR2 fill:#f5a623,color:#000
    style CRB1 fill:#7ed321,color:#000
    style CRB2 fill:#7ed321,color:#000

    style Core1 fill:#e8e8e8,stroke:#333,color:#000
    style Apps1 fill:#e8e8e8,stroke:#333,color:#000
    style Batch1 fill:#e8e8e8,stroke:#333,color:#000
    style Net1 fill:#e8e8e8,stroke:#333,color:#000
    style RBAC1 fill:#e8e8e8,stroke:#333,color:#000
    style OS1 fill:#e8e8e8,stroke:#333,color:#000
    style OS2 fill:#e8e8e8,stroke:#333,color:#000
    style Ray1 fill:#bd10e0,stroke:#333,color:#fff
    style CF1 fill:#bd10e0,stroke:#333,color:#fff
    style Kueue1 fill:#e8e8e8,stroke:#333,color:#000
    style KF1 fill:#e8e8e8,stroke:#333,color:#000
    style Sched1 fill:#e8e8e8,stroke:#333,color:#000
    style Sched2 fill:#e8e8e8,stroke:#333,color:#000
    style Adm1 fill:#e8e8e8,stroke:#333,color:#000
    style CRD1 fill:#e8e8e8,stroke:#333,color:#000
    style ODH1 fill:#7ed321,stroke:#333,color:#000
    style Auth1 fill:#e8e8e8,stroke:#333,color:#000
    style OAuth1 fill:#50e3c2,stroke:#333,color:#000
