graph TB
    subgraph External["EXTERNAL (Cluster Users)"]
        User[User/Controller]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+"]
    end

    subgraph ServiceNamespace["SERVICE (Namespace: opendatahub)"]
        direction TB

        subgraph KueuePod["Kueue Controller Manager Pod"]
            direction TB
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS<br/>Auth: API Server mTLS"]
            Visibility["Visibility Server<br/>8082/TCP HTTPS TLS<br/>Auth: Kubernetes RBAC"]
            Health["Health/Metrics<br/>8081/TCP HTTP<br/>8080/TCP HTTP"]
            Controller["Controller Components<br/>Scheduler, Cache, Queue Manager"]
            AdmCheck["Admission Check Controllers<br/>Provisioning, MultiKueue"]

            Controller -.->|in-process| Webhook
            Controller -.->|in-process| Visibility
            Controller -.->|in-process| Health
            Controller -.->|in-process| AdmCheck
        end

        WebhookSvc["Service: kueue-webhook-service<br/>ClusterIP 443→9443<br/>HTTPS TLS"]
        VisibilitySvc["Service: kueue-visibility-server<br/>ClusterIP 443→8082<br/>HTTPS TLS"]
        MetricsSvc["Service: kueue-metrics-service<br/>ClusterIP 8080→8080<br/>HTTP"]

        WebhookSvc -->|routes to| Webhook
        VisibilitySvc -->|routes to| Visibility
        MetricsSvc -->|routes to| Health
    end

    subgraph Monitoring["MONITORING (INTERNAL)"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        CertManager["cert-manager<br/>TLS cert provisioning"]
        RemoteCluster["Remote Kubernetes Clusters<br/>6443/TCP HTTPS TLS 1.2+<br/>MultiKueue"]
        Autoscaler["Cluster Autoscaler<br/>ProvisioningRequest API"]
        Cloud["Cloud Provider API<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token or Kubeconfig| APIServer

    APIServer -->|POST /mutate-*, /validate-*<br/>HTTPS/9443<br/>TLS<br/>API Server mTLS| WebhookSvc
    APIServer -->|GET /apis/visibility.kueue.x-k8s.io/v1alpha1/*<br/>HTTPS/8082<br/>TLS<br/>RBAC| VisibilitySvc

    Controller -->|Watch/Manage CRDs, Jobs, Pods<br/>HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| APIServer

    Prometheus -->|Scrape metrics<br/>HTTP/8080<br/>None| MetricsSvc

    Controller -->|Certificate API<br/>HTTPS/6443<br/>TLS<br/>ServiceAccount Token| CertManager
    CertManager -.->|Provisions certs| Webhook

    AdmCheck -->|Create ProvisioningRequests<br/>HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| APIServer
    APIServer -->|Provision nodes<br/>Varies| Autoscaler
    Autoscaler -->|API calls<br/>HTTPS/443<br/>TLS 1.2+<br/>Cloud Credentials| Cloud

    Controller -->|Distribute workloads<br/>HTTPS/6443<br/>TLS 1.2+<br/>Kubeconfig credentials| RemoteCluster
    RemoteCluster -.->|Sync status<br/>HTTPS/6443<br/>TLS 1.2+| Controller

    %% Trust zones styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlPlane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class APIServer controlPlane
    class KueuePod,Webhook,Visibility,Health,Controller,AdmCheck,WebhookSvc,VisibilitySvc,MetricsSvc service
    class Prometheus monitoring
    class CertManager,RemoteCluster,Autoscaler,Cloud externalService
