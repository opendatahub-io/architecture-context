graph TB
    subgraph "TrustyAI Service Operator"
        Controller[TrustyAI Service Operator Controller]
        ServiceMonitor[ServiceMonitor Controller]
        InferenceHandler[InferenceService Handler]
        Storage[Storage Manager]
        RouteCtrl[Route Controller]
        IstioCtrl[Istio Integration Controller]

        Controller -->|manages| ServiceMonitor
        Controller -->|manages| InferenceHandler
        Controller -->|manages| Storage
        Controller -->|manages| RouteCtrl
        Controller -->|manages| IstioCtrl
    end

    subgraph "Managed TrustyAI Service Pod"
        TrustyAIContainer[TrustyAI Service Container<br/>quay.io/trustyai/trustyai-service]
        OAuthProxy[OAuth Proxy Sidecar<br/>ose-oauth-proxy]
    end

    User[User] -->|creates| TrustyAICR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    TrustyAICR -->|watched by| Controller

    Controller -->|creates/manages| Deployment[TrustyAI Service Deployment]
    Controller -->|creates/manages| Services["Services<br/>(name), (name)-tls"]
    Controller -->|creates/manages| Route[OpenShift Route]
    Controller -->|creates/manages| PVC[PersistentVolumeClaim]
    Controller -->|creates/manages| ServiceMonitorRes[ServiceMonitor]
    Controller -->|creates/manages| VirtualService[Istio VirtualService]
    Controller -->|creates/manages| DestinationRule[Istio DestinationRule]

    Deployment -->|contains| TrustyAIContainer
    Deployment -->|contains| OAuthProxy

    InferenceHandler -->|patches| InferenceService[KServe InferenceService]
    InferenceHandler -->|patches| ServingRuntime[KServe ServingRuntime]

    TrustyAIContainer -->|stores data| PVC
    TrustyAIContainer -->|or connects to| Database[(PostgreSQL/MariaDB)]

    Controller -->|integrates with| Prometheus[Prometheus]
    Controller -->|depends on| K8sAPI[Kubernetes API]
    Controller -->|integrates with| OpenShift[OpenShift<br/>Routes, OAuth, Certs]
    Controller -->|integrates with| Istio[Istio Service Mesh]

    InferenceService -->|sends inference data| TrustyAIContainer

    Prometheus -->|scrapes via| ServiceMonitorRes
    ServiceMonitorRes -->|targets| TrustyAIContainer

    style Controller fill:#4a90e2
    style ServiceMonitor fill:#4a90e2
    style InferenceHandler fill:#4a90e2
    style Storage fill:#4a90e2
    style RouteCtrl fill:#4a90e2
    style IstioCtrl fill:#4a90e2
    style TrustyAICR fill:#f5a623
    style TrustyAIContainer fill:#7ed321
    style OAuthProxy fill:#7ed321
    style K8sAPI fill:#e8e8e8
    style OpenShift fill:#e8e8e8
    style Istio fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style Database fill:#f5a623
