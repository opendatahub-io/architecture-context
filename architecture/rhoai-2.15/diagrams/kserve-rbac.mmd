graph TD
    subgraph "Service Account"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB[kserve-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kserve-leader-election-rolebinding<br/>RoleBinding - kserve namespace]
    end

    subgraph "ClusterRole Permissions"
        CR[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "API Resources: serving.kserve.io"
        InferenceService["InferenceService<br/>v1beta1"]
        ServingRuntime["ServingRuntime<br/>v1alpha1"]
        ClusterServingRuntime["ClusterServingRuntime<br/>v1alpha1"]
        InferenceGraph["InferenceGraph<br/>v1alpha1"]
        TrainedModel["TrainedModel<br/>v1alpha1"]
        ClusterStorageContainer["ClusterStorageContainer<br/>v1alpha1"]
    end

    subgraph "API Resources: Kubernetes Core"
        Services["Services<br/>core/v1"]
        ConfigMaps["ConfigMaps<br/>core/v1"]
        Events["Events<br/>core/v1"]
        Secrets["Secrets<br/>core/v1"]
        Namespaces["Namespaces<br/>core/v1"]
        Pods["Pods<br/>core/v1"]
        ServiceAccounts["ServiceAccounts<br/>core/v1"]
    end

    subgraph "API Resources: Apps/Networking"
        Deployments["Deployments<br/>apps/v1"]
        KnativeServices["Knative Services<br/>serving.knative.dev"]
        VirtualServices["VirtualServices<br/>networking.istio.io"]
        Ingresses["Ingresses<br/>networking.k8s.io"]
        HPAs["HorizontalPodAutoscalers<br/>autoscaling/v2"]
    end

    subgraph "API Resources: Admission"
        MutatingWebhooks["MutatingWebhookConfigurations<br/>admissionregistration.k8s.io"]
        ValidatingWebhooks["ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| CRB2
    CRB -->|grants| CR
    CRB2 -->|grants leader election| CR

    %% Permissions - serving.kserve.io
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| InferenceService
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| ServingRuntime
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| ClusterServingRuntime
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| InferenceGraph
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /status"| TrainedModel
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| ClusterStorageContainer

    %% Permissions - Kubernetes Core
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| Services
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| ConfigMaps
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| Events
    CR -->|"create, delete, get,<br/>patch, update"| Secrets
    CR -->|"get, list, watch"| Namespaces
    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| ServiceAccounts

    %% Permissions - Apps/Networking
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| Deployments
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| KnativeServices
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch, /finalizers,<br/>/status"| VirtualServices
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| Ingresses
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| HPAs

    %% Permissions - Admission
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| MutatingWebhooks
    CR -->|"create, delete, get,<br/>list, patch, update,<br/>watch"| ValidatingWebhooks

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    style InferenceService fill:#7ed321,stroke:#333,stroke-width:2px
    style ServingRuntime fill:#7ed321,stroke:#333,stroke-width:2px
    style ClusterServingRuntime fill:#7ed321,stroke:#333,stroke-width:2px
    style InferenceGraph fill:#7ed321,stroke:#333,stroke-width:2px
    style TrainedModel fill:#7ed321,stroke:#333,stroke-width:2px
    style ClusterStorageContainer fill:#7ed321,stroke:#333,stroke-width:2px

    style Services fill:#50e3c2,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#50e3c2,stroke:#333,stroke-width:2px
    style Events fill:#50e3c2,stroke:#333,stroke-width:2px
    style Secrets fill:#50e3c2,stroke:#333,stroke-width:2px
    style Namespaces fill:#50e3c2,stroke:#333,stroke-width:2px
    style Pods fill:#50e3c2,stroke:#333,stroke-width:2px
    style ServiceAccounts fill:#50e3c2,stroke:#333,stroke-width:2px

    style Deployments fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style KnativeServices fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style VirtualServices fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style Ingresses fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style HPAs fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff

    style MutatingWebhooks fill:#f5a623,stroke:#333,stroke-width:2px
    style ValidatingWebhooks fill:#f5a623,stroke:#333,stroke-width:2px
