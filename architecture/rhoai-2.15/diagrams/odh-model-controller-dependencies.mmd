graph LR
    ODHModelController[ODH Model Controller]

    %% External Dependencies (Required)
    ODHModelController -->|"CRD management<br/>co-manages InferenceServices"| KServe[KServe v0.12.1<br/>REQUIRED]
    ODHModelController -->|"external access<br/>creates Routes"| OpenShiftRoute[OpenShift Route API v3.9.0+<br/>REQUIRED]
    ODHModelController -->|"K8s API client<br/>controller framework"| ControllerRuntime[controller-runtime v0.16.3<br/>REQUIRED]

    %% External Dependencies (Conditional - Service Mesh)
    ODHModelController -->|"autoscaling platform<br/>Serverless mode only"| KnativeServing[Knative Serving v0.39.3<br/>CONDITIONAL]
    ODHModelController -.->|"traffic mgmt, mTLS<br/>creates VirtualServices"| IstioMesh[Istio Service Mesh v1.19.4<br/>CONDITIONAL]
    ODHModelController -.->|"OpenShift mesh impl<br/>creates ServiceMeshMembers"| Maistra[Red Hat Service Mesh<br/>Maistra<br/>CONDITIONAL]
    ODHModelController -.->|"auth/authz policies<br/>creates AuthConfigs"| Authorino[Authorino v0.15.0<br/>CONDITIONAL]
    ODHModelController -.->|"TLS certificates<br/>webhook cert mgmt"| CertManager[cert-manager v1.13.0+<br/>CONDITIONAL]

    %% External Dependencies (Optional)
    ODHModelController -.->|"metrics collection<br/>creates ServiceMonitors"| PrometheusOp[Prometheus Operator v0.64.1<br/>OPTIONAL]

    %% Internal ODH Dependencies
    ODHModelController -->|"primary component<br/>watches InferenceServices"| KServeController[KServe Controller<br/>Internal ODH]
    ODHModelController -->|"runtime templates<br/>ConfigMap labels"| ODHDashboard[ODH Dashboard<br/>Internal ODH]
    ODHModelController -.->|"model lineage<br/>gRPC API calls"| ModelRegistry[Model Registry<br/>Internal ODH]
    ODHModelController -->|"platform config<br/>reads DSC/DSCInit"| ODHOperator[ODH Operator<br/>Internal ODH]

    %% Integration Points
    DataSciencePipelines[Data Science Pipelines<br/>Internal ODH] -->|"auto-deploy models<br/>creates InferenceServices"| ODHModelController
    ODHDashboard -->|"UI management<br/>discovers runtimes"| ODHModelController

    %% External Services
    ODHModelController -.->|"K8s API calls<br/>CRUD operations"| K8sAPI[Kubernetes API Server<br/>Infrastructure]
    ODHModelController -.->|"webhook validation<br/>Knative Service checks"| K8sAPI

    %% Deployment Mode Dependencies
    subgraph DeploymentModes["Deployment Mode Dependencies"]
        direction TB
        ModelMesh["Mode 1: ModelMesh<br/>Multi-model serving"]
        KServeServerless["Mode 2: KServe Serverless<br/>Knative + Service Mesh"]
        KServeRaw["Mode 3: KServe Raw<br/>Direct K8s deployment"]
    end

    ODHModelController --> DeploymentModes
    ModelMesh -.->|requires| KServe
    ModelMesh -.->|requires| OpenShiftRoute
    KServeServerless -.->|requires| KServe
    KServeServerless -.->|requires| KnativeServing
    KServeServerless -.->|requires| IstioMesh
    KServeServerless -.->|optional| Authorino
    KServeServerless -.->|optional| PrometheusOp
    KServeRaw -.->|requires| KServe
    KServeRaw -.->|requires| OpenShiftRoute

    %% Serving Runtime Templates
    subgraph RuntimeTemplates["Serving Runtime Templates"]
        direction TB
        vLLM["vLLM<br/>LLM Inference<br/>GPU Required"]
        TGIS["TGIS<br/>Text Generation<br/>GPU Required"]
        Caikit["Caikit<br/>Framework Serving<br/>GPU Optional"]
        OVMS["OpenVINO Model Server<br/>Multi-format<br/>GPU Optional"]
    end

    ODHModelController -->|"deploys templates<br/>creates ServingRuntimes"| RuntimeTemplates

