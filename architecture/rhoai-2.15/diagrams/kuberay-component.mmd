graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator<br/>Deployment]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]

        Operator -->|reconciles| RayClusterCtrl
        Operator -->|reconciles| RayJobCtrl
        Operator -->|reconciles| RayServiceCtrl
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Ray Cluster"
        HeadPod[Ray Head Pod<br/>GCS + Dashboard + Client]
        WorkerPods[Ray Worker Pods<br/>Distributed Compute]
        Autoscaler[Autoscaler Sidecar<br/>Optional]

        HeadPod -->|coordinates| WorkerPods
        HeadPod -->|runs| Autoscaler
    end

    subgraph "Kubernetes Resources"
        Pods[Pods]
        Services[Services]
        Ingress[Ingress/Routes]
        RBAC[Roles/RoleBindings]
    end

    User[User/ODH Dashboard] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| Services

    RayJobCtrl -->|creates| RayClusterCR
    RayJobCtrl -->|submits jobs to| HeadPod

    RayServiceCtrl -->|creates| RayClusterCR
    RayServiceCtrl -->|deploys to| HeadPod
    RayServiceCtrl -->|creates| Ingress

    Operator -->|manages| Pods
    Operator -->|manages| Services
    Operator -->|manages| RBAC

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API]
        Prometheus[Prometheus]
        Volcano[Volcano<br/>Optional]
        ExternalRedis[External Redis<br/>Optional GCS FT]
    end

    Operator -->|watches/creates| K8sAPI
    Operator -->|exposes metrics| Prometheus
    Operator -.->|gang scheduling| Volcano
    HeadPod -.->|fault tolerance| ExternalRedis

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Volcano fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style ExternalRedis fill:#ccc,stroke:#333,stroke-dasharray: 5 5
