graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        UserBrowser[User Browser]
        RayClientPod[Ray Client Pod]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift)"]
        Router["OpenShift Router<br/>443/TCP TLS 1.2+"]
        Route["RayCluster Route<br/>443/TCP HTTPS<br/>Reencrypt"]
    end

    subgraph ClusterNetwork["SERVICE MESH / CLUSTER NETWORK (Trusted)"]
        direction TB

        subgraph UserNamespace["Namespace: user-namespace"]
            direction TB
            OAuthService["OAuth Proxy Service<br/>443/TCP oauth-proxy<br/>TLS service-ca"]
            RayClientService["Ray Client Service<br/>10001/TCP<br/>mTLS"]

            subgraph RayHeadPod["Ray Head Pod"]
                OAuthContainer["OAuth Proxy<br/>443/TCP external<br/>8443/TCP mTLS"]
                DashboardContainer["Ray Dashboard<br/>8265/TCP HTTP<br/>localhost only"]
                RayHeadContainer["Ray Head<br/>10001/TCP mTLS<br/>8265/TCP"]
            end

            RayWorkers["Ray Worker Pods<br/>NetworkPolicy: workers-nwp"]
        end

        subgraph OperatorNamespace["Namespace: redhat-ods-applications"]
            Operator["CodeFlare Operator<br/>SA: controller-manager"]
            WebhookService["Webhook Service<br/>443/TCP to 9443/TCP<br/>TLS 1.2+ mTLS"]
            MetricsService["Metrics Service<br/>8080/TCP<br/>TLS or None"]
        end

        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    subgraph ExternalServices["EGRESS TO EXTERNAL"]
        KueueAPI["Kueue API<br/>6443/TCP HTTPS<br/>SA token"]
    end

    %% External to Ingress
    UserBrowser -->|HTTPS 443 TLS1.2+| Router
    Router -->|HTTPS 443 Reencrypt| Route
    Route -->|HTTPS 443 service-ca| OAuthService

    %% OAuth Flow
    OAuthService -->|HTTPS 443 OAuth| OAuthServer
    OAuthService --> OAuthContainer
    OAuthContainer -->|HTTP 8265 localhost| DashboardContainer

    %% Ray Client Flow
    RayClientPod -->|HTTP 10001 mTLS| RayClientService
    RayClientService --> RayHeadContainer

    %% Operator Flows
    Operator -->|HTTPS 6443 SA token| K8sAPI
    K8sAPI -->|HTTPS 9443 mTLS| WebhookService

    %% Metrics Flow
    Prometheus -->|HTTPS 8080 Bearer| MetricsService

    %% Integration Flows
    Operator -->|HTTPS 6443 SA token| KueueAPI

    %% Internal communication
    RayHeadContainer -.->|Ray mTLS| RayWorkers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class UserBrowser,RayClientPod external
    class Router,Route ingress
    class OAuthService,RayClientService,RayHeadPod,OAuthContainer,DashboardContainer,RayHeadContainer,RayWorkers,OAuthServer,K8sAPI,Prometheus trusted
    class Operator,WebhookService,MetricsService operator
    class KueueAPI externalservice
