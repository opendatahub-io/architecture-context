graph TD
    subgraph "Operator Service Accounts"
        SA_Controller[controller-manager<br/>SA in operator namespace]
    end

    subgraph "Operator ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
        CRB_Leader[leader-election-rolebinding]
        CRB_AuthProxy[auth-proxy-rolebinding]
    end

    subgraph "Operator ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Leader[leader-election-role<br/>ClusterRole]
        CR_AuthProxy[auth-proxy-role<br/>ClusterRole]
    end

    subgraph "ModelRegistry CRD Resources"
        CRD_MR[modelregistry.opendatahub.io<br/>ModelRegistry]
        CRD_MRStatus[modelregistry.opendatahub.io<br/>ModelRegistry/status]
        CRD_MRFinalizer[modelregistry.opendatahub.io<br/>ModelRegistry/finalizers]
    end

    subgraph "Managed Kubernetes Resources"
        Apps_Deployments[apps<br/>Deployments]
        Core_Services[core<br/>Services]
        Core_SA[core<br/>ServiceAccounts]
        Core_Pods[core<br/>Pods]
        Core_Events[core<br/>Events]
        RBAC_Roles[rbac.authorization.k8s.io<br/>Roles]
        RBAC_RoleBindings[rbac.authorization.k8s.io<br/>RoleBindings]
    end

    subgraph "Istio Resources"
        Istio_Gateways[networking.istio.io<br/>Gateways]
        Istio_VS[networking.istio.io<br/>VirtualServices]
        Istio_DR[networking.istio.io<br/>DestinationRules]
        Istio_AuthzPolicy[security.istio.io<br/>AuthorizationPolicies]
    end

    subgraph "Authorino Resources"
        Auth_AuthConfigs[authorino.kuadrant.io<br/>AuthConfigs]
    end

    subgraph "OpenShift Resources"
        OCP_Routes[route.openshift.io<br/>Routes]
        OCP_Groups[user.openshift.io<br/>Groups]
        OCP_Ingresses[config.openshift.io<br/>Ingresses]
    end

    subgraph "Leader Election Resources"
        Core_ConfigMaps[core<br/>ConfigMaps]
        Coord_Leases[coordination.k8s.io<br/>Leases]
    end

    subgraph "Authentication Resources"
        Auth_TokenReviews[authentication.k8s.io<br/>TokenReviews]
        Authz_SAR[authorization.k8s.io<br/>SubjectAccessReviews]
    end

    subgraph "Per-ModelRegistry Resources"
        direction TB
        SA_Registry["{registry-name}<br/>ServiceAccount<br/>created per MR"]
        Role_Registry["registry-user-{registry-name}<br/>Role namespace"]
        RB_Registry["{registry-name}-rolebinding<br/>RoleBinding"]
        Core_ServiceGet[core<br/>Services GET only]
    end

    subgraph "User-facing Roles"
        CR_Editor[modelregistry-editor-role<br/>ClusterRole]
        CR_Viewer[modelregistry-viewer-role<br/>ClusterRole]
        User[Platform User]
    end

    %% Operator RBAC Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Leader
    SA_Controller -->|bound via| CRB_AuthProxy

    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_AuthProxy -->|grants| CR_AuthProxy

    %% Manager Role Permissions
    CR_Manager -->|create,delete,get,list,patch,update,watch| CRD_MR
    CR_Manager -->|get,patch,update| CRD_MRStatus
    CR_Manager -->|update| CRD_MRFinalizer
    CR_Manager -->|create,delete,get,list,patch,update,watch| Apps_Deployments
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Services
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_SA
    CR_Manager -->|get,list,watch| Core_Pods
    CR_Manager -->|create,patch| Core_Events
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_Roles
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_RoleBindings
    CR_Manager -->|create,delete,get,list,patch,update,watch| Istio_Gateways
    CR_Manager -->|create,delete,get,list,patch,update,watch| Istio_VS
    CR_Manager -->|create,delete,get,list,patch,update,watch| Istio_DR
    CR_Manager -->|create,delete,get,list,patch,update,watch| Istio_AuthzPolicy
    CR_Manager -->|create,delete,get,list,patch,update,watch| Auth_AuthConfigs
    CR_Manager -->|create,delete,get,list,patch,update,watch| OCP_Routes
    CR_Manager -->|create,delete,get,list,patch,update,watch| OCP_Groups
    CR_Manager -->|get,list,watch| OCP_Ingresses

    %% Leader Election Role Permissions
    CR_Leader -->|get,list,watch,create,update,patch,delete| Core_ConfigMaps
    CR_Leader -->|get,list,watch,create,update,patch,delete| Coord_Leases
    CR_Leader -->|create,patch| Core_Events

    %% Auth Proxy Role Permissions
    CR_AuthProxy -->|create| Auth_TokenReviews
    CR_AuthProxy -->|create| Authz_SAR

    %% Per-Registry RBAC
    SA_Registry -->|bound via| RB_Registry
    RB_Registry -->|grants| Role_Registry
    Role_Registry -->|get| Core_ServiceGet

    %% User-facing Roles
    CR_Editor -->|create,delete,get,list,patch,update,watch| CRD_MR
    CR_Viewer -->|get,list,watch| CRD_MR
    User -.->|bound to optional| CR_Editor
    User -.->|bound to optional| CR_Viewer

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Registry fill:#7ed321
    style CR_Manager fill:#f5a623
    style CR_Leader fill:#f5a623
    style CR_AuthProxy fill:#f5a623
    style CR_Editor fill:#f5a623
    style CR_Viewer fill:#f5a623
    style Role_Registry fill:#f5a623
    style CRD_MR fill:#e06666
    style CRD_MRStatus fill:#e06666
    style CRD_MRFinalizer fill:#e06666
