graph TB
    subgraph "Training Operator Component"
        Controller[Training Operator Controller]
        PyTorchCtrl[PyTorch Controller]
        TFCtrl[TensorFlow Controller]
        MPICtrl[MPI Controller]
        XGBoostCtrl[XGBoost Controller]
        MXNetCtrl[MXNet Controller]
        PaddleCtrl[PaddlePaddle Controller]

        Controller -->|reconciles| PyTorchCtrl
        Controller -->|reconciles| TFCtrl
        Controller -->|reconciles| MPICtrl
        Controller -->|reconciles| XGBoostCtrl
        Controller -->|reconciles| MXNetCtrl
        Controller -->|reconciles| PaddleCtrl

        MetricsEndpoint[Metrics Endpoint<br/>:8080/metrics]
        HealthEndpoint[Health Endpoint<br/>:8081/healthz]
        ReadyEndpoint[Readiness Endpoint<br/>:8081/readyz]

        Controller -->|exposes| MetricsEndpoint
        Controller -->|exposes| HealthEndpoint
        Controller -->|exposes| ReadyEndpoint
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        MXJob[MXJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Worker/Master Pods]
        Services[Training Services<br/>port 23456 PyTorch]
        ConfigMaps[ConfigMaps]
        HPA[HorizontalPodAutoscaler]
        PodGroups[PodGroups<br/>Gang Scheduling]
    end

    User[User/Data Scientist] -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| MPIJob
    User -->|creates| XGBoostJob
    User -->|creates| MXJob
    User -->|creates| PaddleJob

    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    MPIJob -->|watched by| MPICtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    MXJob -->|watched by| MXNetCtrl
    PaddleJob -->|watched by| PaddleCtrl

    PyTorchCtrl -->|creates| Pods
    PyTorchCtrl -->|creates| Services
    PyTorchCtrl -->|creates| ConfigMaps
    Controller -->|creates| HPA
    Controller -->|creates| PodGroups

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Scraping]
        Volcano[Volcano Scheduler<br/>Gang Scheduling]
        SchedulerPlugins[Scheduler Plugins<br/>Gang Scheduling]
    end

    Controller -->|watches/manages| K8sAPI
    Prometheus -->|scrapes| MetricsEndpoint
    Controller -.->|optional| Volcano
    Controller -.->|optional| SchedulerPlugins

    subgraph "Python SDK"
        SDK[kubeflow-training 1.7.0<br/>TrainingClient API]
    end

    SDK -->|creates| PyTorchJob
    SDK -->|creates| TFJob
    SDK -->|creates| MPIJob

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style PyTorchCtrl fill:#4a90e2,stroke:#333
    style TFCtrl fill:#4a90e2,stroke:#333
    style MPICtrl fill:#4a90e2,stroke:#333
    style XGBoostCtrl fill:#4a90e2,stroke:#333
    style MXNetCtrl fill:#4a90e2,stroke:#333
    style PaddleCtrl fill:#4a90e2,stroke:#333
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style MXJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style SchedulerPlugins fill:#e8e8e8,stroke:#333
    style SDK fill:#7ed321,stroke:#333
