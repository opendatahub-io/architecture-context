graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding<br/>Cluster-scoped]
        CRB2[kueue-proxy-rolebinding<br/>Cluster-scoped]
        CRB3[kueue-leader-election-rolebinding<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRoles"
        CR1[kueue-manager-role<br/>Manages Kueue CRDs + Jobs]
        CR2[kueue-proxy-role<br/>Token/Access Reviews]
        CR3[kueue-leader-election-role<br/>Leader Election]
    end

    subgraph "Kueue CRD Resources"
        CRD1[kueue.x-k8s.io<br/>ClusterQueue, LocalQueue<br/>Workload, ResourceFlavor<br/>AdmissionCheck]
        CRD2[kueue.x-k8s.io<br/>WorkloadPriorityClass<br/>ProvisioningRequestConfig]
    end

    subgraph "Core Resources"
        Core1[core<br/>events, pods, namespaces<br/>limitranges, secrets]
        Core2[core<br/>pods/finalizers<br/>pods/status]
    end

    subgraph "Job Framework Resources"
        Job1[batch/jobs<br/>jobs/status<br/>jobs/finalizers]
        Job2[kubeflow.org<br/>mpijobs, pytorchjobs, tfjobs<br/>mxjobs, paddlejobs, xgboostjobs]
        Job3[ray.io<br/>rayjobs, rayclusters]
        Job4[jobset.x-k8s.io<br/>jobsets, jobsets/status]
        Job5[workload.codeflare.dev<br/>AppWrapper]
    end

    subgraph "Autoscaling Resources"
        Auto1[autoscaling.x-k8s.io<br/>provisioningrequests<br/>provisioningrequests/status]
    end

    subgraph "Admission & Flow Control"
        Admission1[admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>validatingwebhookconfigurations]
        Flow1[flowcontrol.apiserver.k8s.io<br/>flowschemas<br/>prioritylevelconfigurations]
    end

    subgraph "Auth Resources"
        Auth1[authentication.k8s.io<br/>tokenreviews]
        Auth2[authorization.k8s.io<br/>subjectaccessreviews]
    end

    subgraph "User-Facing Roles (End Users)"
        UserRole1[kueue-batch-user-role<br/>get, list, watch, create, update<br/>localqueues]
        UserRole2[kueue-batch-admin-role<br/>full access to all Kueue resources]
        UserRole3[kueue-clusterqueue-editor-role<br/>edit ClusterQueues]
        UserRole4[kueue-clusterqueue-viewer-role<br/>view ClusterQueues]
        UserRole5[kueue-localqueue-editor-role<br/>edit LocalQueues]
        UserRole6[kueue-localqueue-viewer-role<br/>view LocalQueues]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% Manager Role Permissions
    CR1 -->|"create, delete, get, list,<br/>patch, update, watch"| CRD1
    CR1 -->|"create, delete, get, list,<br/>patch, update, watch"| CRD2
    CR1 -->|"get, list, watch,<br/>create, patch, update"| Core1
    CR1 -->|"get, patch, update"| Core2
    CR1 -->|"get, list, patch,<br/>update, watch"| Job1
    CR1 -->|"get, list, patch,<br/>update, watch"| Job2
    CR1 -->|"get, list, patch,<br/>update, watch"| Job3
    CR1 -->|"get, list, patch,<br/>update, watch"| Job4
    CR1 -.->|watches| Job5
    CR1 -->|"create, delete, get, list,<br/>patch, update, watch"| Auto1
    CR1 -->|"get, list, update, watch"| Admission1
    CR1 -->|"list, watch,<br/>patch (status only)"| Flow1

    %% Proxy Role Permissions
    CR2 -->|create| Auth1
    CR2 -->|create| Auth2

    %% User-facing roles (not bound to SA, for end users)
    UserRole1 -.->|user access| CRD1
    UserRole2 -.->|admin access| CRD1
    UserRole3 -.->|edit| CRD1
    UserRole4 -.->|view| CRD1
    UserRole5 -.->|edit| CRD1
    UserRole6 -.->|view| CRD1

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px

    style CRD1 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRD2 fill:#7ed321,stroke:#333,stroke-width:2px
    style Core1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Core2 fill:#7ed321,stroke:#333,stroke-width:2px
    style Job1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Job2 fill:#7ed321,stroke:#333,stroke-width:2px
    style Job3 fill:#7ed321,stroke:#333,stroke-width:2px
    style Job4 fill:#7ed321,stroke:#333,stroke-width:2px
    style Job5 fill:#7ed321,stroke:#333,stroke-width:2px
    style Auto1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Admission1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Flow1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Auth1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Auth2 fill:#7ed321,stroke:#333,stroke-width:2px

    style UserRole1 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UserRole2 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UserRole3 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UserRole4 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UserRole5 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UserRole6 fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
