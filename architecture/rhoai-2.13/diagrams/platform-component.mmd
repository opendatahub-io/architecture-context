graph TB
    subgraph "RHOAI Platform 2.13"
        subgraph "Platform Orchestration"
            RHODS[RHODS Operator<br/>v1.6.0-2256]
            Dashboard[ODH Dashboard<br/>v1.21.0-18]
        end

        subgraph "Development Environments"
            NotebookCtrl[Notebook Controller<br/>v1.27.0-376]
            Workbenches[Workbench Images<br/>Jupyter/VS Code/RStudio]
        end

        subgraph "Model Serving"
            KServe[KServe Controller<br/>v0.12.1]
            ModelMesh[ModelMesh Serving<br/>v1.27.0-292]
            ODHModelCtrl[ODH Model Controller<br/>v1.27.0-527]
        end

        subgraph "ML Pipelines & Training"
            DSP[Data Science Pipelines<br/>Operator]
            TrainingOp[Training Operator<br/>PyTorch/TF/MPI/XGBoost]
        end

        subgraph "Distributed Computing"
            CodeFlare[CodeFlare Operator<br/>AppWrapper/Security]
            KubeRay[KubeRay Operator<br/>v1.1.0]
            Kueue[Kueue<br/>Job Queueing]
        end

        subgraph "AI Operations"
            TrustyAI[TrustyAI Operator<br/>v1.17.0]
        end
    end

    subgraph "External Platform Dependencies"
        K8sAPI[Kubernetes API Server]
        OpenShiftOAuth[OpenShift OAuth]
        Prometheus[Prometheus]
        Istio[Istio Service Mesh]
        Knative[Knative Serving]
        S3[S3 Storage]
    end

    subgraph "User Workloads"
        Notebooks[Notebook Pods<br/>StatefulSets]
        InferenceServices[InferenceService Pods<br/>Model Servers]
        Pipelines[Pipeline Runs<br/>Argo/Tekton Workflows]
        TrainingJobs[Training Jobs<br/>PyTorchJob/TFJob/MPIJob]
        RayClusters[Ray Clusters<br/>Head + Workers]
    end

    %% Platform orchestration flows
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| NotebookCtrl
    RHODS -->|deploys| KServe
    RHODS -->|deploys| ModelMesh
    RHODS -->|deploys| DSP
    RHODS -->|deploys| TrainingOp
    RHODS -->|deploys| CodeFlare
    RHODS -->|deploys| KubeRay
    RHODS -->|deploys| Kueue
    RHODS -->|deploys| TrustyAI

    %% Dashboard interactions
    Dashboard -->|creates| NotebookCR[Notebook CRs]
    Dashboard -->|creates| InferenceServiceCR[InferenceService CRs]
    Dashboard -->|creates| DSPACR[DSPA CRs]

    %% Notebook workflow
    NotebookCR -->|watched by| NotebookCtrl
    NotebookCtrl -->|creates| Notebooks
    NotebookCtrl -->|uses| Workbenches

    %% Model serving workflow
    InferenceServiceCR -->|watched by| KServe
    InferenceServiceCR -->|watched by| ODHModelCtrl
    KServe -->|creates| InferenceServices
    ODHModelCtrl -->|creates Routes/VirtualServices for| InferenceServices
    ModelMesh -->|alternative serving| InferenceServices

    %% Pipeline workflow
    DSPACR -->|watched by| DSP
    DSP -->|creates| Pipelines

    %% Training workflow
    TrainingOp -->|creates| TrainingJobs
    TrainingJobs -->|queued by| Kueue

    %% Distributed computing workflow
    CodeFlare -->|watches| RayClusters
    KubeRay -->|creates| RayClusters
    RayClusters -->|queued by| Kueue
    CodeFlare -->|injects OAuth/mTLS| RayClusters

    %% Model monitoring
    TrustyAI -->|patches| InferenceServices
    TrustyAI -->|monitors| InferenceServices

    %% External dependencies
    RHODS -->|reconciles| K8sAPI
    Dashboard -->|authenticates via| OpenShiftOAuth
    KServe -->|uses| Knative
    KServe -->|uses| Istio
    ODHModelCtrl -->|uses| Istio
    InferenceServices -->|loads models from| S3
    TrustyAI -->|exposes metrics to| Prometheus

