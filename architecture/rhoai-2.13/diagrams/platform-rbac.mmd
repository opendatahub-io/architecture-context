    %% ClusterRoleBinding grants ClusterRole
    CRB_RHODS -->|grants| CR_RHODS
    CRB_Dashboard -->|grants| CR_Dashboard
    CRB_KServe -->|grants| CR_KServe
    CRB_ODHModel -->|grants| CR_ODHModel
    CRB_Notebook -->|grants| CR_Notebook
    CRB_Training -->|grants| CR_Training
    CRB_CodeFlare -->|grants| CR_CodeFlare
    CRB_KubeRay -->|grants| CR_KubeRay
    CRB_Kueue -->|grants| CR_Kueue
    CRB_DSP -->|grants| CR_DSP
    CRB_TrustyAI -->|grants| CR_TrustyAI

    %% RHODS Operator permissions (ALL RESOURCES)
    CR_RHODS -->|manages ALL platform resources| API_DSC
    CR_RHODS -->|manages ALL platform resources| API_DSCI
    CR_RHODS -->|manages ALL operators| API_Deployment
    CR_RHODS -->|manages ALL namespaces| API_Namespace

    %% Dashboard permissions
    CR_Dashboard -->|manages| API_Notebook
    CR_Dashboard -->|manages| API_InferenceService
    CR_Dashboard -->|manages| API_DSPA
    CR_Dashboard -->|manages| API_Secret

    %% KServe permissions
    CR_KServe -->|manages| API_InferenceService
    CR_KServe -->|creates| API_KnativeService
    CR_KServe -->|creates| API_VirtualService
    CR_KServe -->|manages| API_ServingRuntime
    CR_KServe -->|manages| API_Secret

    %% ODH Model Controller permissions
    CR_ODHModel -->|watches| API_InferenceService
    CR_ODHModel -->|creates| API_Route
    CR_ODHModel -->|creates| API_VirtualService
    CR_ODHModel -->|creates| API_PeerAuth
    CR_ODHModel -->|creates| API_ServiceMonitor
    CR_ODHModel -->|aggregates| API_Secret

    %% Notebook Controller permissions
    CR_Notebook -->|manages| API_Notebook
    CR_Notebook -->|creates| API_StatefulSet
    CR_Notebook -->|creates| API_Service
    CR_Notebook -->|creates| API_Route
    CR_Notebook -->|creates| API_VirtualService

    %% Training Operator permissions
    CR_Training -->|manages| API_PyTorchJob
    CR_Training -->|manages| API_TFJob
    CR_Training -->|manages| API_MPIJob
    CR_Training -->|manages| API_XGBoostJob

    %% CodeFlare permissions
    CR_CodeFlare -->|manages| API_AppWrapper
    CR_CodeFlare -->|watches| API_RayCluster
    CR_CodeFlare -->|integrates| API_LocalQueue

    %% KubeRay permissions
    CR_KubeRay -->|manages| API_RayCluster
    CR_KubeRay -->|manages| API_RayJob
    CR_KubeRay -->|creates| API_Route
    CR_KubeRay -->|creates| API_Deployment

    %% Kueue permissions
    CR_Kueue -->|manages| API_ClusterQueue
    CR_Kueue -->|manages| API_LocalQueue
    CR_Kueue -->|queues| API_PyTorchJob
    CR_Kueue -->|queues| API_TFJob
    CR_Kueue -->|queues| API_RayJob
    CR_Kueue -->|queues| API_AppWrapper

    %% DSP permissions
    CR_DSP -->|manages| API_DSPA
    CR_DSP -->|creates| API_Workflow
    CR_DSP -->|creates| API_Pipeline
    CR_DSP -->|creates| API_Deployment
    CR_DSP -->|creates| API_Service

    %% TrustyAI permissions
    CR_TrustyAI -->|manages| API_TrustyAIService
    CR_TrustyAI -->|patches| API_InferenceService
    CR_TrustyAI -->|creates| API_ServiceMonitor

    %% User-facing roles
    Role_Edit -->|creates/manages| API_Notebook
    Role_Edit -->|creates/manages| API_InferenceService
    Role_Edit -->|creates/manages| API_DSPA
    Role_Edit -->|creates/manages| API_PyTorchJob
    Role_Edit -->|creates/manages| API_Secret

    Role_View -->|reads: GET,LIST,WATCH| API_Notebook
    Role_View -->|reads: GET,LIST,WATCH| API_InferenceService

    Role_Admin -->|full namespace admin| API_Namespace

