graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[odh-dashboard-cluster-monitoring-view<br/>ClusterRoleBinding]
        CRB4[odh-dashboard-image-puller<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]
        SystemAuthDelegator[system:auth-delegator<br/>ClusterRole]
        ClusterMonitoringView[cluster-monitoring-view<br/>ClusterRole]
        SystemImagePuller[system:image-puller<br/>ClusterRole]
    end

    subgraph "Role Binding"
        RB[odh-dashboard<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Namespaced Role"
        R[odh-dashboard<br/>Role<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Cluster-Scoped Resources"
        Nodes[core/nodes<br/>get, list]
        ClusterVersions[config.openshift.io/clusterversions<br/>get, watch, list]
        CSV[operators.coreos.com/clusterserviceversions<br/>get, list, watch]
        Routes[route.openshift.io/routes<br/>get, list, watch]
        ConsoleLinks[console.openshift.io/consolelinks<br/>get, list, watch]
        Users[user.openshift.io/users, groups<br/>get, list, watch]
        Namespaces[core/namespaces<br/>get, list, watch, create, update, patch, delete]
        RBAC[rbac.authorization.k8s.io/rolebindings, roles<br/>get, list, watch, create, update, patch, delete]
        Events[events.k8s.io/events<br/>get, list, watch]
        Notebooks[kubeflow.org/notebooks<br/>get, list, watch, create, update, patch, delete]
        DSC[datasciencecluster.opendatahub.io/datascienceclusters<br/>list, watch, get]
        DSCI[dscinitialization.opendatahub.io/dscinitializations<br/>list, watch, get]
        ModelRegistries[modelregistry.opendatahub.io/modelregistries<br/>get, list, watch, create, update, patch, delete]
        MachineAutoscalers[machine.openshift.io/machineautoscalers<br/>get, list]
        ImageStreamLayers[image.openshift.io/imagestreams/layers<br/>get]
        CoreResources[core/configmaps, secrets, pvcs<br/>pods, services, serviceaccounts<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Namespace-Scoped Resources"
        AcceleratorProfiles[dashboard.opendatahub.io/acceleratorprofiles<br/>create, get, list, update, patch, delete]
        OdhDashboardConfigs[opendatahub.io/odhdashboardconfigs<br/>get, list, watch, create, update, patch, delete]
        OdhApplications[dashboard.opendatahub.io/odhapplications<br/>get, list]
        OdhDocuments[dashboard.opendatahub.io/odhdocuments<br/>get, list]
        OdhQuickStarts[console.openshift.io/odhquickstarts<br/>get, list]
        ImageStreams[image.openshift.io/imagestreams<br/>create, get, list, update, patch, delete]
        Builds[build.openshift.io/builds, buildconfigs<br/>get, list, watch, create, patch, delete]
        Jobs[batch/cronjobs, jobs<br/>create, delete, get, list, patch, update, watch]
        Deployments[apps/deployments<br/>patch, update]
        Templates[template.openshift.io/templates<br/>all verbs]
        ServingRuntimes[serving.kserve.io/servingruntimes<br/>all verbs]
        NSRoutes[route.openshift.io/routes<br/>get, list, watch]
        KFDefs[kfdef.apps.kubeflow.org/kfdefs<br/>get, list, watch]
        NSNotebooks[kubeflow.org/notebooks<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4
    SA -->|bound via| RB

    %% ClusterRole Bindings to ClusterRoles
    CRB1 -->|grants| CR
    CRB2 -->|grants| SystemAuthDelegator
    CRB3 -->|grants| ClusterMonitoringView
    CRB4 -->|grants| SystemImagePuller

    %% Role Binding to Role
    RB -->|grants| R

    %% ClusterRole to Cluster Resources
    CR -->|access| Nodes
    CR -->|access| ClusterVersions
    CR -->|access| CSV
    CR -->|access| Routes
    CR -->|access| ConsoleLinks
    CR -->|access| Users
    CR -->|access| Namespaces
    CR -->|access| RBAC
    CR -->|access| Events
    CR -->|access| Notebooks
    CR -->|access| DSC
    CR -->|access| DSCI
    CR -->|access| ModelRegistries
    CR -->|access| MachineAutoscalers
    CR -->|access| ImageStreamLayers
    CR -->|access| CoreResources

    %% Role to Namespace Resources
    R -->|access| AcceleratorProfiles
    R -->|access| OdhDashboardConfigs
    R -->|access| OdhApplications
    R -->|access| OdhDocuments
    R -->|access| OdhQuickStarts
    R -->|access| ImageStreams
    R -->|access| Builds
    R -->|access| Jobs
    R -->|access| Deployments
    R -->|access| Templates
    R -->|access| ServingRuntimes
    R -->|access| NSRoutes
    R -->|access| KFDefs
    R -->|access| NSNotebooks

