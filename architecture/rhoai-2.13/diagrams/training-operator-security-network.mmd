graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[User / Data Scientist<br/>Python SDK / kubectl]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["Training Operator Pod<br/>SA: training-operator<br/>UID: 65532 (non-root)<br/>FIPS: Enabled<br/>Istio: Disabled"]

        MetricsPort["Metrics Endpoint<br/>8080/TCP HTTP<br/>No auth"]
        HealthPort["Health/Readiness<br/>8081/TCP HTTP<br/>No auth"]

        Operator --- MetricsPort
        Operator --- HealthPort
    end

    subgraph UserNS["USER NAMESPACES (Training Workloads)"]
        direction TB

        subgraph PyTorchJob["PyTorch Training Job"]
            Master["Master Pod<br/>23456/TCP<br/>TCP (no encryption)"]
            Worker1["Worker Pod 1<br/>23456/TCP"]
            Worker2["Worker Pod 2<br/>23456/TCP"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Storage["Object Storage<br/>S3/etc<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Job credentials"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>Pull secrets"]
        Prometheus["Prometheus<br/>Metrics scraping"]
    end

    subgraph OptionalGang["OPTIONAL GANG SCHEDULING"]
        Volcano["Volcano Scheduler<br/>scheduling.volcano.sh<br/>443/TCP HTTPS"]
        SchedulerPlugins["Scheduler Plugins<br/>scheduling.x-k8s.io<br/>443/TCP HTTPS"]
    end

    %% User flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% Operator flows
    K8sAPI <-->|Watch/Manage<br/>ServiceAccount Token| Operator
    Operator -->|Create/Update<br/>Pods, Services, ConfigMaps| K8sAPI
    Operator -.->|Optional<br/>PodGroups| Volcano
    Operator -.->|Optional<br/>PodGroups| SchedulerPlugins

    %% Training job flows
    Operator -->|Creates| Master
    Operator -->|Creates| Worker1
    Operator -->|Creates| Worker2

    Master <-->|TCP/23456<br/>No encryption<br/>No auth| Worker1
    Master <-->|TCP/23456<br/>No encryption<br/>No auth| Worker2
    Worker1 <-->|TCP/23456<br/>Gradient exchange| Worker2

    %% External access
    Master -->|HTTPS/443<br/>TLS 1.2+<br/>Job credentials| Storage
    Worker1 -->|HTTPS/443<br/>Dataset download| Storage
    Worker2 -->|HTTPS/443<br/>Checkpoint save| Storage

    Operator -->|HTTPS/443<br/>Pull images| Registry
    Master -->|HTTPS/443<br/>Pull images| Registry

    Prometheus -->|HTTP/8080<br/>Scrape metrics<br/>No auth| MetricsPort
    K8sAPI -->|HTTP/8081<br/>Health checks| HealthPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,MetricsPort,HealthPort operator
    class Master,Worker1,Worker2 workload
    class Storage,Registry,Prometheus externalservice
    class Volcano,SchedulerPlugins optional
