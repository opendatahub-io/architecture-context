graph LR
    KServe["KServe<br/>Model Serving Platform<br/>v0.12.1"]

    %% External Dependencies (Required & Optional)
    subgraph "External Dependencies"
        K8s["Kubernetes 1.25+<br/>Required<br/>Container orchestration"]
        Knative["Knative Serving 0.39+<br/>Optional<br/>Serverless autoscaling"]
        Istio["Istio 1.19+<br/>Optional<br/>Service mesh, VirtualServices"]
        CertManager["cert-manager<br/>Recommended<br/>TLS certificate provisioning"]
        Prometheus["Prometheus<br/>Optional<br/>Metrics collection"]
    end

    %% Internal ODH Dependencies
    subgraph "Internal ODH Dependencies"
        ModelController["odh-model-controller<br/>Creates InferenceServices"]
        Dashboard["odh-dashboard<br/>UI management"]
        ServiceMesh["Service Mesh OSSM<br/>mTLS & AuthZ policies"]
        ModelRegistry["Model Registry<br/>Model metadata storage"]
    end

    %% External Services
    subgraph "External Services"
        S3["S3 Compatible Storage<br/>AWS S3 / Minio<br/>Model artifacts"]
        GCS["Google Cloud Storage<br/>GCP GCS<br/>Model artifacts"]
        HTTP["HTTP(S) Endpoints<br/>Model download URLs"]
        CloudEvents["CloudEvents Sink<br/>Request/response logs"]
    end

    %% Integration Points
    subgraph "Integration APIs"
        KnativeAPI["Knative API<br/>serving.knative.dev/v1<br/>Services"]
        IstioAPI["Istio API<br/>networking.istio.io/v1beta1<br/>VirtualServices"]
        K8sAPI["Kubernetes API<br/>Deployments, Services<br/>ConfigMaps, Secrets"]
        CertAPI["cert-manager API<br/>Certificate CRD"]
    end

    %% Core Dependencies
    KServe -->|platform| K8s
    KServe -->|serverless scaling| Knative
    KServe -->|traffic routing| Istio
    KServe -->|webhook certs| CertManager
    KServe -.->|metrics export| Prometheus

    %% Internal ODH Integrations
    ModelController -->|creates CRs| KServe
    Dashboard -->|manages via API| KServe
    ServiceMesh -->|protects| KServe
    KServe -.->|model references| ModelRegistry

    %% External Service Connections
    KServe -->|download models<br/>HTTPS/443<br/>AWS SigV4| S3
    KServe -->|download models<br/>HTTPS/443<br/>GCP IAM| GCS
    KServe -->|download models<br/>HTTP/HTTPS| HTTP
    KServe -.->|send logs<br/>HTTP/HTTPS<br/>CloudEvents v1.0| CloudEvents

    %% API Integration Details
    KServe -->|create/manage| KnativeAPI
    KServe -->|create/manage| IstioAPI
    KServe -->|watch/CRUD| K8sAPI
    KServe -->|request certs| CertAPI

    KnativeAPI -.->|provided by| Knative
    IstioAPI -.->|provided by| Istio
    K8sAPI -.->|provided by| K8s
    CertAPI -.->|provided by| CertManager

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style K8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style Knative fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
    style Prometheus fill:#e6522c,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH
    style ModelController fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px

    %% External Services
    style S3 fill:#ff9900,stroke:#333,stroke-width:2px
    style GCS fill:#4285f4,stroke:#333,stroke-width:2px,color:#fff
    style HTTP fill:#f5a623,stroke:#333,stroke-width:2px
    style CloudEvents fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff

    %% Integration APIs
    style KnativeAPI fill:#ddd,stroke:#333,stroke-width:1px
    style IstioAPI fill:#ddd,stroke:#333,stroke-width:1px
    style K8sAPI fill:#ddd,stroke:#333,stroke-width:1px
    style CertAPI fill:#ddd,stroke:#333,stroke-width:1px
