graph TD
    subgraph "Service Accounts"
        SA_Manager[controller-manager<br/>Operator ServiceAccount]
        SA_Proxy["{name}-proxy<br/>Per-Service ServiceAccount"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_AuthProxy[auth-proxy-client-clusterrolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader[leader-election-rolebinding<br/>RoleBinding - Operator NS]
        RB_OAuthProxy["{name}-proxy-rolebinding<br/>Per-Service RoleBinding"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_AuthProxy[auth-proxy-client-clusterrole<br/>ClusterRole]
    end

    subgraph "Roles"
        R_Leader[leader-election-role<br/>Role - Operator NS]
    end

    subgraph "API Resources - TrustyAI"
        API_TrustyAI[trustyai.opendatahub.io<br/>TrustyAIService<br/>TrustyAIService/status<br/>TrustyAIService/finalizers]
    end

    subgraph "API Resources - Apps"
        API_Apps[apps<br/>Deployments<br/>Deployments/status<br/>Deployments/finalizers]
    end

    subgraph "API Resources - Core"
        API_Core[Core Resources<br/>Services, ConfigMaps<br/>Pods, Secrets<br/>ServiceAccounts, PVCs<br/>PVs - read-only<br/>Events]
    end

    subgraph "API Resources - Monitoring"
        API_Monitoring[monitoring.coreos.com<br/>ServiceMonitors]
    end

    subgraph "API Resources - OpenShift"
        API_Routes[route.openshift.io<br/>Routes]
    end

    subgraph "API Resources - KServe"
        API_KServe[serving.kserve.io<br/>InferenceServices<br/>InferenceServices/finalizers<br/>ServingRuntimes<br/>ServingRuntimes/status]
    end

    subgraph "API Resources - RBAC"
        API_RBAC[rbac.authorization.k8s.io<br/>ClusterRoleBindings]
    end

    subgraph "API Resources - Coordination"
        API_Coordination[coordination.k8s.io<br/>Leases]
    end

    subgraph "API Resources - Auth"
        API_Auth[authentication.k8s.io<br/>TokenReviews<br/><br/>authorization.k8s.io<br/>SubjectAccessReviews]
    end

    %% Manager Role Bindings
    SA_Manager -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    %% Manager Permissions
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_TrustyAI
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Apps
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Core
    CR_Manager -->|create, list, watch| API_Monitoring
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Routes
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_KServe
    CR_Manager -->|get, list, watch,<br/>create, update, delete| API_RBAC
    CR_Manager -->|get, create, update| API_Coordination

    %% Auth Proxy Role Bindings
    SA_Manager -->|bound via| CRB_AuthProxy
    CRB_AuthProxy -->|grants| CR_AuthProxy
    CR_AuthProxy -->|create| API_Auth

    %% Leader Election Role Bindings
    SA_Manager -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader
    R_Leader -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Core
    R_Leader -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Coordination

    %% OAuth Proxy Service Account
    SA_Proxy -->|bound via| RB_OAuthProxy
    RB_OAuthProxy -->|grants<br/>OAuth SAR permissions| API_Auth

    %% Styling
    style SA_Manager fill:#4a90e2,color:#fff
    style SA_Proxy fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623
    style CR_AuthProxy fill:#f5a623
    style R_Leader fill:#f5a623
    style API_TrustyAI fill:#7ed321
    style API_Apps fill:#7ed321
    style API_Core fill:#7ed321
    style API_Monitoring fill:#7ed321
    style API_Routes fill:#7ed321
    style API_KServe fill:#7ed321
    style API_RBAC fill:#7ed321
    style API_Coordination fill:#7ed321
    style API_Auth fill:#7ed321
