graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/GitOps Client]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth/ServiceAccount tokens<br/>RBAC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>redhat-ods-operator"]
        direction TB

        subgraph OperatorPod["RHODS Operator Pod<br/>SA: controller-manager<br/>Security: runAsNonRoot, no privesc"]
            DSCCtrl[DataScienceCluster Controller]
            DSCICtrl[DSCInitialization Controller]
            SecretGen[SecretGenerator Controller]
            CertGen[CertConfigmapGenerator Controller]
        end

        MetricsSvc["controller-manager-metrics-service<br/>ClusterIP<br/>8443/TCP → 8080/TCP<br/>HTTP (no encryption)<br/>ServiceAccount Token"]

        OperatorPod -->|8080/TCP HTTP| MetricsSvc
    end

    subgraph MonitoringNS["MONITORING NAMESPACE<br/>redhat-ods-monitoring"]
        direction TB

        Prometheus["Prometheus<br/>SA: prometheus<br/>9091/TCP HTTPS<br/>TLS (service-ca)<br/>mTLS"]
        Alertmanager["Alertmanager<br/>9093/TCP HTTP<br/>No encryption"]

        Prometheus -->|9091/TCP HTTPS<br/>mTLS| Alertmanager
    end

    subgraph Router["OPENSHIFT ROUTER (Ingress)"]
        PromRoute["prometheus-route<br/>443/TCP HTTPS<br/>TLS passthrough<br/>OpenShift OAuth"]
        AMRoute["alertmanager-route<br/>443/TCP HTTPS<br/>TLS edge<br/>OpenShift OAuth"]
    end

    subgraph ManagedNS["MANAGED NAMESPACES"]
        AppsNS["redhat-ods-applications<br/>Dashboard, Notebooks, KServe,<br/>ModelMesh, etc.<br/>OAuth clients provisioned<br/>Trusted CA bundles"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public repos"]
        Quay["Quay.io<br/>quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public images"]
        RHIO["Red Hat Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secret"]
    end

    %% External to Control Plane
    User -->|6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth/kubeconfig| K8sAPI

    %% Control Plane to Operator
    K8sAPI <-->|Watch/API calls<br/>HTTPS TLS 1.2+<br/>ServiceAccount token<br/>RBAC| OperatorPod

    %% Operator to External Services
    OperatorPod -->|443/TCP HTTPS<br/>TLS 1.2+<br/>Public repos| GitHub
    OperatorPod -->|443/TCP HTTPS<br/>TLS 1.2+| Quay
    OperatorPod -->|443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secret| RHIO

    %% Metrics Collection
    Prometheus -->|8443/TCP HTTP<br/>ServiceAccount token| MetricsSvc

    %% Operator to Managed Namespaces
    OperatorPod -->|via K8s API<br/>6443/TCP HTTPS| AppsNS

    %% Routes
    Prometheus -.->|internal| PromRoute
    Alertmanager -.->|internal| AMRoute

    User -->|443/TCP HTTPS<br/>OpenShift OAuth| PromRoute
    User -->|443/TCP HTTPS<br/>OpenShift OAuth| AMRoute

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0277bd,stroke-width:3px
    classDef operator fill:#fff3e0,stroke:#e65100,stroke-width:3px
    classDef monitoring fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef router fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef managed fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class OperatorPod,DSCCtrl,DSCICtrl,SecretGen,CertGen,MetricsSvc operator
    class Prometheus,Alertmanager monitoring
    class PromRoute,AMRoute router
    class AppsNS managed
    class GitHub,Quay,RHIO externalservice
