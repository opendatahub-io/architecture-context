graph TB
    subgraph "ODH Model Controller Deployment"
        Manager[Manager Deployment<br/>3 replicas HA<br/>Leader Election]

        subgraph "Controllers"
            OSISVCRec[OpenshiftInferenceService<br/>Reconciler]
            MMRec[ModelMesh<br/>Reconciler]
            KServerlessRec[KServe Serverless<br/>Reconciler]
            KRawRec[KServe Raw<br/>Reconciler]
            StorageRec[StorageSecret<br/>Reconciler]
            CARec[CustomCA<br/>Reconciler]
            MonRec[Monitoring<br/>Reconciler]
            MRRec[ModelRegistry<br/>Reconciler]
        end

        Webhook[Knative Service<br/>Validating Webhook<br/>9443/TCP HTTPS]

        Manager --> OSISVCRec
        Manager --> MMRec
        Manager --> KServerlessRec
        Manager --> KRawRec
        Manager --> StorageRec
        Manager --> CARec
        Manager --> MonRec
        Manager --> MRRec
        Manager --> Webhook
    end

    subgraph "Watched Resources"
        ISVC[InferenceService CR<br/>serving.kserve.io/v1beta1]
        KnativeSvc[Knative Service CR<br/>serving.knative.dev/v1]
        DSC[DataScienceCluster CR]
        DSCI[DSCInitialization CR]
        Secrets[Data Connection Secrets<br/>opendatahub.io/dashboard=true]
        CABundle[odh-trusted-ca-bundle<br/>ConfigMap]
        ServingRT[ServingRuntime CR]
    end

    subgraph "Created Resources"
        Routes[OpenShift Routes]
        VirtualServices[Istio VirtualServices]
        Gateways[Istio Gateways]
        PeerAuth[PeerAuthentication CR<br/>STRICT mTLS]
        AuthConfigs[Authorino AuthConfigs]
        ServiceMesh[ServiceMeshMember CR]
        NetworkPolicies[NetworkPolicies]
        ServiceMonitors[ServiceMonitors]
        PodMonitors[PodMonitors]
        RoleBindings[Monitoring RoleBindings]
        StorageConfig[storage-config Secret]
        Dashboards[Grafana Dashboard ConfigMaps]
    end

    subgraph "External Dependencies"
        KServe[KServe Controller]
        Knative[Knative Serving]
        Istio[Istio Service Mesh]
        Authorino[Authorino]
        Prometheus[Prometheus Operator]
        ModelRegistry[Model Registry]
    end

    %% Watches
    ISVC -.->|watched by| OSISVCRec
    KnativeSvc -.->|validated by| Webhook
    DSC -.->|read by| OSISVCRec
    DSCI -.->|read by| OSISVCRec
    Secrets -.->|watched by| StorageRec
    CABundle -.->|watched by| CARec
    ServingRT -.->|watched by| MonRec

    %% Creates
    OSISVCRec -->|mode: ModelMesh| MMRec
    OSISVCRec -->|mode: Serverless| KServerlessRec
    OSISVCRec -->|mode: Raw| KRawRec

    MMRec -->|creates| Routes

    KServerlessRec -->|creates| Routes
    KServerlessRec -->|creates| VirtualServices
    KServerlessRec -->|creates| Gateways
    KServerlessRec -->|creates| PeerAuth
    KServerlessRec -->|creates| AuthConfigs
    KServerlessRec -->|creates| ServiceMesh
    KServerlessRec -->|creates| NetworkPolicies
    KServerlessRec -->|creates| ServiceMonitors
    KServerlessRec -->|creates| PodMonitors
    KServerlessRec -->|creates| Dashboards

    KRawRec -->|creates| Routes

    StorageRec -->|aggregates| StorageConfig

    MonRec -->|creates| RoleBindings

    MRRec -->|queries| ModelRegistry

    %% External Dependencies
    KServerlessRec -.->|requires| Knative
    KServerlessRec -.->|requires| Istio
    KServerlessRec -.->|optional| Authorino
    KServerlessRec -.->|optional| Prometheus

    ISVC -.->|managed by| KServe

