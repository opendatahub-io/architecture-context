graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI System]
        Client[Client Application]
    end

    subgraph K8sControlPlane["KUBERNETES API SERVER"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Bearer Token, Client Certs"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE (modelmesh-serving)"]
        direction TB

        Controller["ModelMesh Controller<br/>SA: modelmesh-controller<br/>8081/TCP HTTP (health)<br/>8443/TCP HTTPS (metrics)"]

        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>Auth: K8s API Server CA<br/>Secret: modelmesh-webhook-server-cert"]

        etcd["etcd Service<br/>2379/TCP HTTP<br/>⚠️  No Encryption"]

        RBACProxy["kube-rbac-proxy<br/>Bearer Token Auth<br/>TokenReview + SubjectAccessReview"]

        Controller --> RBACProxy
    end

    subgraph UserNamespace["USER NAMESPACE (Runtime Pods)"]
        direction TB

        Service["Kubernetes Service<br/>{predictor-name}<br/>ClusterIP"]

        subgraph RuntimePod["ModelMesh Runtime Pod<br/>SA: {predictor-name}-sa"]
            direction LR

            ModelMesh["modelmesh<br/>8033/TCP gRPC<br/>2112/TCP HTTP metrics"]
            RESTProxy["rest-proxy<br/>8008/TCP HTTP<br/>KServe V2 Translation"]
            RuntimeAdapter["runtime-adapter<br/>8085/TCP gRPC<br/>Model Load/Unload"]
            StorageHelper["storage-helper<br/>8086/TCP gRPC<br/>S3 Puller"]
            ModelServer["model-server<br/>Triton/MLServer/OVMS<br/>varies gRPC/HTTP"]

            RESTProxy -->|8033/TCP<br/>gRPC| ModelMesh
            ModelMesh -->|8085/TCP<br/>gRPC| RuntimeAdapter
            RuntimeAdapter -->|8086/TCP<br/>gRPC| StorageHelper
            RuntimeAdapter -->|varies<br/>gRPC/HTTP| ModelServer
        end

        Service -->|route| ModelMesh
        Service -->|route| RESTProxy
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS1.2+ (AWS)<br/>9000/TCP HTTP (MinIO)<br/>Auth: AWS IAM or Access Key<br/>Secret: storage-config"]

        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secret"]

        Prometheus["Prometheus<br/>Metrics Collection"]

        CertManager["cert-manager<br/>TLS Certificate Provisioning"]
    end

    %% External to K8s API
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI

    %% K8s API to Operator
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>Client Cert| Webhook
    K8sAPI <-->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| Controller

    %% Controller to Dependencies
    Controller -->|HTTP/2379<br/>⚠️  No Encryption| etcd
    Controller -->|gRPC/8033| ModelMesh

    %% Webhook to cert-manager
    Webhook -.->|TLS certs| CertManager

    %% Client to Inference
    Client -->|gRPC/8033<br/>⚠️  No Built-in Auth| Service
    Client -->|HTTP/8008<br/>⚠️  No Built-in Auth| Service

    %% Storage Helper to S3
    StorageHelper -->|HTTPS/443 or HTTP/9000<br/>Access Key/IAM| S3

    %% Registry pulls
    RuntimePod -.->|HTTPS/443<br/>Pull Secret| Registry

    %% Metrics
    Prometheus -->|HTTPS/8443<br/>Bearer Token| RBACProxy
    Prometheus -->|HTTP/2112| ModelMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Client external
    class K8sAPI k8sapi
    class Controller,Webhook,RBACProxy operator
    class etcd warning
    class Service,ModelMesh,RESTProxy,RuntimeAdapter,StorageHelper,ModelServer runtime
    class S3,Registry,Prometheus,CertManager externalservice
