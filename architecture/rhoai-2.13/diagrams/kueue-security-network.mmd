graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[User / Data Scientist]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token / mTLS"]
    end

    subgraph OpendatahubNS["NAMESPACE: opendatahub"]
        direction TB

        subgraph KueueWebhook["Kueue Webhook Server"]
            WebhookPod["Pod: kueue-controller-manager<br/>SA: kueue-controller-manager<br/>Container: odh-kueue-controller"]
            WebhookSvc["Service: kueue-webhook-service<br/>ClusterIP<br/>443/TCP → 9443/TCP"]
            WebhookCert["Secret: kueue-webhook-server-cert<br/>kubernetes.io/tls<br/>Provisioned by: cert-manager"]
        end

        subgraph KueueManager["Kueue Manager Controller"]
            ManagerDeployment["Deployment: kueue-controller-manager<br/>SA: kueue-controller-manager<br/>Resources: CPU 500m, Mem 512Mi"]
        end

        subgraph KueueVisibility["Kueue Visibility API Server"]
            VisibilityPod["Visibility Server<br/>SA: kueue-controller-manager"]
            VisibilitySvc["Service: kueue-visibility-server<br/>ClusterIP<br/>443/TCP → 8082/TCP"]
            VisibilityCert["Secret: kueue-visibility-server-cert<br/>kubernetes.io/tls<br/>Internal Cert Manager"]
        end

        subgraph KueueMetrics["Kueue Metrics Service"]
            MetricsSvc["Service: kueue-metrics-service<br/>ClusterIP<br/>8080/TCP<br/>HTTP (no encryption)"]
        end
    end

    subgraph MonitoringNS["NAMESPACE: Monitoring"]
        Prometheus["Prometheus<br/>Scrapes: 8080/TCP HTTP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        RemoteClusters["Remote Cluster API Servers<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: KubeConfig Credentials<br/>Secret: multikueue-cluster-credentials"]
        ClusterAutoscaler["Cluster Autoscaler API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: K8s RBAC (ServiceAccount)"]
    end

    subgraph JobFrameworks["JOB FRAMEWORKS (Watched by Kueue)"]
        BatchJob["Kubernetes Batch Job<br/>batch/v1"]
        KubeflowJobs["Kubeflow Training Jobs<br/>TFJob, PyTorchJob, MPIJob<br/>kubeflow.org"]
        RayJobs["Ray Jobs/Clusters<br/>ray.io"]
        JobSet["JobSet<br/>jobset.x-k8s.io"]
        AppWrapper["AppWrapper<br/>workload.codeflare.dev"]
    end

    %% User to API Server
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| APIServer

    %% API Server to Webhook
    APIServer -->|"HTTPS/9443<br/>TLS 1.2+<br/>mTLS (API Server cert)"| WebhookSvc
    WebhookSvc --> WebhookPod
    WebhookPod -.->|uses| WebhookCert

    %% Manager to API Server (watch/manage)
    ManagerDeployment -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch/Manage CRDs"| APIServer

    %% API Server to Visibility API (API Aggregation)
    APIServer -->|"HTTPS/8082<br/>TLS (internal cert)<br/>API Aggregation<br/>K8s RBAC"| VisibilitySvc
    VisibilitySvc --> VisibilityPod
    VisibilityPod -.->|uses| VisibilityCert

    %% Prometheus to Metrics
    Prometheus -->|"HTTP/8080<br/>No Auth<br/>/metrics scrape"| MetricsSvc

    %% Manager to External Services
    ManagerDeployment -->|"HTTPS/6443<br/>TLS 1.2+<br/>KubeConfig Auth<br/>MultiKueue"| RemoteClusters
    ManagerDeployment -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>ProvisioningRequests"| ClusterAutoscaler

    %% Job Frameworks to Webhook (mutations/validations)
    User -.->|creates| BatchJob
    User -.->|creates| KubeflowJobs
    User -.->|creates| RayJobs
    User -.->|creates| JobSet

    BatchJob -.->|mutated/validated by| WebhookSvc
    KubeflowJobs -.->|mutated/validated by| WebhookSvc
    RayJobs -.->|mutated/validated by| WebhookSvc
    JobSet -.->|mutated/validated by| WebhookSvc
    AppWrapper -.->|watched by| ManagerDeployment

    %% Manager watches Job Frameworks
    ManagerDeployment -.->|watches via API Server| BatchJob
    ManagerDeployment -.->|watches via API Server| KubeflowJobs
    ManagerDeployment -.->|watches via API Server| RayJobs
    ManagerDeployment -.->|watches via API Server| JobSet
    ManagerDeployment -.->|watches via API Server| AppWrapper

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kueuecomponent fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef jobframework fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class APIServer controlplane
    class WebhookPod,WebhookSvc,WebhookCert,ManagerDeployment,VisibilityPod,VisibilitySvc,VisibilityCert,MetricsSvc kueuecomponent
    class Prometheus monitoring
    class RemoteClusters,ClusterAutoscaler externalservice
    class BatchJob,KubeflowJobs,RayJobs,JobSet,AppWrapper jobframework
