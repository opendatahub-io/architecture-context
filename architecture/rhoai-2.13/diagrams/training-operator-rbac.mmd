graph TD
    subgraph "Service Accounts"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR[training-operator<br/>ClusterRole]
        EditRole[training-edit<br/>ClusterRole<br/>User access]
        ViewRole[training-view<br/>ClusterRole<br/>User access]
    end

    subgraph "Core Resources"
        ConfigMaps[configmaps]
        Events[events]
        Pods[pods]
        PodsExec[pods/exec]
        ServiceAccounts[serviceaccounts]
        Services[services]
    end

    subgraph "Autoscaling Resources"
        HPA[horizontalpodautoscalers<br/>autoscaling]
    end

    subgraph "Training Job CRDs"
        MPIJobs[mpijobs, mpijobs/status, mpijobs/finalizers<br/>kubeflow.org]
        MXJobs[mxjobs, mxjobs/status, mxjobs/finalizers<br/>kubeflow.org]
        PaddleJobs[paddlejobs, paddlejobs/status, paddlejobs/finalizers<br/>kubeflow.org]
        PyTorchJobs[pytorchjobs, pytorchjobs/status, pytorchjobs/finalizers<br/>kubeflow.org]
        TFJobs[tfjobs, tfjobs/status, tfjobs/finalizers<br/>kubeflow.org]
        XGBoostJobs[xgboostjobs, xgboostjobs/status, xgboostjobs/finalizers<br/>kubeflow.org]
    end

    subgraph "RBAC Resources"
        Roles[roles, rolebindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPG[podgroups<br/>scheduling.volcano.sh]
        SchedPluginPG[podgroups<br/>scheduling.x-k8s.io]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Core permissions
    CR -->|create, list, update, watch| ConfigMaps
    CR -->|create, delete, get, list, patch, update, watch| Events
    CR -->|create, delete, get, list, patch, update, watch| Pods
    CR -->|create| PodsExec
    CR -->|create, get, list, watch| ServiceAccounts
    CR -->|create, delete, get, list, watch| Services

    %% Autoscaling permissions
    CR -->|create, delete, get, list, patch, update, watch| HPA

    %% Training Job permissions (all verbs)
    CR -->|* all verbs| MPIJobs
    CR -->|* all verbs| MXJobs
    CR -->|* all verbs| PaddleJobs
    CR -->|* all verbs| PyTorchJobs
    CR -->|* all verbs| TFJobs
    CR -->|* all verbs| XGBoostJobs

    %% RBAC permissions
    CR -->|create, list, update, watch| Roles

    %% Gang scheduling permissions
    CR -->|create, delete, get, list, patch, update, watch| VolcanoPG
    CR -->|create, delete, get, list, patch, update, watch| SchedPluginPG

    %% User roles
    EditRole -->|create, delete, get, list, patch, update, watch| MPIJobs
    EditRole -->|create, delete, get, list, patch, update, watch| TFJobs
    EditRole -->|create, delete, get, list, patch, update, watch| PyTorchJobs
    EditRole -->|create, delete, get, list, patch, update, watch| MXJobs
    EditRole -->|create, delete, get, list, patch, update, watch| XGBoostJobs
    EditRole -->|create, delete, get, list, patch, update, watch| PaddleJobs
    EditRole -.->|get status only| MPIJobs
    EditRole -.->|get status only| TFJobs

    ViewRole -->|get, list, watch| MPIJobs
    ViewRole -->|get, list, watch| TFJobs
    ViewRole -->|get, list, watch| PyTorchJobs
    ViewRole -->|get, list, watch| MXJobs
    ViewRole -->|get, list, watch| XGBoostJobs
    ViewRole -->|get, list, watch| PaddleJobs
    ViewRole -.->|get status only| MPIJobs
    ViewRole -.->|get status only| TFJobs

    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB fill:#7ed321,stroke:#333
    style EditRole fill:#f5a623,stroke:#333
    style ViewRole fill:#f5a623,stroke:#333
    style MPIJobs fill:#dae8fc,stroke:#333
    style MXJobs fill:#dae8fc,stroke:#333
    style PaddleJobs fill:#dae8fc,stroke:#333
    style PyTorchJobs fill:#dae8fc,stroke:#333
    style TFJobs fill:#dae8fc,stroke:#333
    style XGBoostJobs fill:#dae8fc,stroke:#333
    style ConfigMaps fill:#e1d5e7,stroke:#333
    style Events fill:#e1d5e7,stroke:#333
    style Pods fill:#e1d5e7,stroke:#333
    style Services fill:#e1d5e7,stroke:#333
