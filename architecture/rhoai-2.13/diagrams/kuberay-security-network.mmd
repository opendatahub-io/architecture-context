graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressRoute["Kubernetes Ingress /<br/>OpenShift Route<br/>443/TCP → 8265/8000<br/>TLS 1.2+ Edge/Passthrough<br/>Optional Bearer Token"]
    end

    subgraph UserNamespace["RAY CLUSTER (User Namespace)"]
        direction TB

        subgraph Services["Services"]
            HeadSvc["Ray Head Service<br/>ClusterIP/LoadBalancer<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
            ServeSvc["Ray Serve Service<br/>ClusterIP<br/>8000/TCP HTTP<br/>Optional TLS"]
            MetricsSvc["Metrics Service<br/>ClusterIP<br/>8080/TCP HTTP"]
        end

        subgraph Pods["Ray Cluster Pods"]
            HeadPod["Ray Head Pod<br/>SA: {raycluster}-head<br/>GCS + Dashboard + Scheduler<br/>runAsNonRoot=true<br/>allowPrivilegeEscalation=false"]
            Worker1["Ray Worker Pod 1<br/>SA: {raycluster}-worker<br/>Task Execution<br/>runAsNonRoot=true"]
            Worker2["Ray Worker Pod 2<br/>SA: {raycluster}-worker<br/>Task Execution<br/>runAsNonRoot=true"]
        end

        subgraph Autoscaler["Autoscaler (Head Pod Sidecar)"]
            AutoscalerSidecar["Ray Autoscaler<br/>localhost:8265 HTTP<br/>No Auth"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Replicas: 1<br/>FIPS Mode<br/>runAsNonRoot=true"]
        WebhookSvc["Webhook Service<br/>ClusterIP<br/>443/TCP → 9443/TCP"]
        WebhookServer["Validating Webhook<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Client Certificates"]

        Operator -.->|embedded| WebhookServer
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer/SA Tokens"]
    end

    subgraph Monitoring["MONITORING (Trusted)"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>No Auth<br/>Network Policy Protected"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        CertManager["cert-manager<br/>TLS Certificate Mgmt<br/>K8s CRD API<br/>Auto-Rotate: Yes"]
        Redis["External Redis (Optional)<br/>6379/TCP TCP<br/>Optional TLS<br/>Password Auth"]
        S3["S3 / Object Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Keys"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Optional Bearer| IngressRoute

    %% Ingress to Services
    IngressRoute -->|HTTP or HTTPS<br/>8265/TCP<br/>Dashboard Access| HeadSvc
    IngressRoute -->|HTTP or HTTPS<br/>8000/TCP<br/>Inference Requests| ServeSvc

    %% Services to Pods
    HeadSvc -->|Routes to| HeadPod
    ServeSvc -->|Routes to| HeadPod
    MetricsSvc -->|Routes to| HeadPod

    %% Worker to Head communication
    Worker1 -->|TCP/6379<br/>GCS Protocol<br/>Optional TLS<br/>Optional Password| HeadPod
    Worker2 -->|TCP/6379<br/>GCS Protocol<br/>Optional TLS<br/>Optional Password| HeadPod

    %% Autoscaler flows
    AutoscalerSidecar -->|HTTP/8265<br/>localhost<br/>No Auth| HeadPod
    AutoscalerSidecar -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Scale Workers| K8sAPI

    %% Operator flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRs, Manage Resources| K8sAPI
    Operator -->|Creates/Manages| HeadPod
    Operator -->|Creates/Manages| Worker1
    Operator -->|Creates/Manages| Worker2
    Operator -->|Creates/Manages| HeadSvc
    Operator -->|Creates/Manages| ServeSvc

    %% Webhook flows
    K8sAPI -->|POST /validate<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Client Certificates| WebhookSvc
    WebhookSvc -->|Routes to| WebhookServer
    WebhookServer -.->|Uses cert from| CertManager

    %% Prometheus flows
    Prometheus -->|HTTP/8080<br/>Scrape Metrics| Operator
    Prometheus -->|HTTP/8080<br/>Scrape Metrics| MetricsSvc

    %% External dependencies
    HeadPod -.->|TCP/6379<br/>Optional TLS<br/>Password| Redis
    HeadPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Worker1 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Worker2 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef usernamespace fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class IngressRoute ingress
    class HeadSvc,ServeSvc,MetricsSvc,HeadPod,Worker1,Worker2,AutoscalerSidecar usernamespace
    class Operator,WebhookSvc,WebhookServer operatorns
    class K8sAPI controlplane
    class Prometheus monitoring
    class CertManager,Redis,S3,Registry externalservice
