graph TD
    subgraph "Service Account"
        SA["notebook-controller-service-account<br/>Namespace: operator-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB[notebook-controller-role-binding<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRole Permissions"
        CR[notebook-controller-role<br/>Type: ClusterRole]
    end

    subgraph "API Resources - Apps"
        StatefulSets[apps/statefulsets<br/>Verbs: *]
    end

    subgraph "API Resources - Core"
        Events[core/events<br/>Verbs: get, list, watch,<br/>create, patch]
        Pods[core/pods<br/>Verbs: get, list, watch, delete]
        Services[core/services<br/>Verbs: *]
    end

    subgraph "API Resources - Kubeflow"
        Notebooks[kubeflow.org/notebooks<br/>Verbs: *]
        NotebooksStatus[kubeflow.org/notebooks/status<br/>Verbs: *]
        NotebooksFinalizers[kubeflow.org/notebooks/finalizers<br/>Verbs: *]
    end

    subgraph "API Resources - Istio"
        VirtualServices[networking.istio.io/virtualservices<br/>Verbs: *]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions
    CR -->|full control| StatefulSets
    CR -->|read, create, patch| Events
    CR -->|read, delete| Pods
    CR -->|full control| Services
    CR -->|full control| Notebooks
    CR -->|full control| NotebooksStatus
    CR -->|full control| NotebooksFinalizers
    CR -->|full control| VirtualServices

    %% Notes
    subgraph Legend
        LegendFull[* = all verbs<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
    end

    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style StatefulSets fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Events fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Pods fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Services fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Notebooks fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style NotebooksStatus fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style NotebooksFinalizers fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style VirtualServices fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style LegendFull fill:#e8e8e8,stroke:#333,stroke-width:1px
