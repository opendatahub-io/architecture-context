graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>HTTPS TLS 1.2+<br/>Re-encrypt mode"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        subgraph Pod["Pod: odh-dashboard<br/>Namespace: redhat-ods-applications<br/>ServiceAccount: odh-dashboard"]
            direction TB
            OAuthProxy["Container: oauth-proxy<br/>8443/TCP HTTPS<br/>TLS Cert: dashboard-proxy-tls<br/>Cookie: dashboard-oauth-config<br/>Client: dashboard-oauth-client"]
            Backend["Container: odh-dashboard<br/>8080/TCP HTTP (localhost only)<br/>Node.js 18+ / Fastify<br/>CPU: 500m-1000m / Mem: 1Gi-2Gi"]
        end

        Service["Service: odh-dashboard<br/>Type: ClusterIP<br/>8443/TCP<br/>TLS (Service Serving Cert)"]

        subgraph ExternalServices["External Services"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
            OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS1.2+"]
            Prometheus["Prometheus Service<br/>9091/TCP HTTP"]
            ImageRegistry["Image Registry<br/>5000/TCP HTTPS TLS1.2+"]
        end
    end

    %% User flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (cookie)"| Route
    Route -->|"HTTPS/8443<br/>TLS (service cert)"| Service
    Service -->|"HTTPS/8443<br/>mTLS"| OAuthProxy

    %% OAuth proxy flows
    OAuthProxy -->|"HTTP/8080<br/>localhost<br/>Bearer Token (header)"| Backend
    OAuthProxy <-->|"HTTPS/443<br/>OAuth Client Secret<br/>Token validation"| OAuthServer

    %% Backend flows
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>User Bearer Token<br/>(impersonation)"| K8sAPI
    Backend -->|"HTTP/9091<br/>ServiceAccount Token<br/>PromQL queries"| Prometheus
    Backend -->|"HTTPS/5000<br/>TLS 1.2+<br/>ServiceAccount Token<br/>ImageStream ops"| ImageRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class Pod,ClusterInternal trusted
    class OAuthProxy,Backend container
    class Service service
    class K8sAPI,OAuthServer,Prometheus,ImageRegistry externalservice
