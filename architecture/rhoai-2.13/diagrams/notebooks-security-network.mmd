graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Mode<br/>Route: notebook-{name}"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Same Pod - Localhost Trust)"]
        direction TB

        subgraph Sidecar["OAuth Proxy Sidecar"]
            OAuth["oauth-proxy<br/>8443/TCP → 8888/TCP<br/>OAuth2 Token Validation<br/>SA: notebook-{name}"]
        end

        subgraph Container["Workbench Container"]
            Jupyter["Jupyter/CodeServer/RStudio<br/>8888/TCP HTTP<br/>No Auth (trusts sidecar)<br/>User: UID 1001 (non-root)<br/>Endpoints: /, /api/kernels"]
        end
    end

    subgraph Egress["EGRESS (External Services)"]
        direction TB

        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS TLS1.2+<br/>No Auth<br/>pip install"]

        CRAN["CRAN<br/>cran.rstudio.com<br/>443/TCP HTTPS TLS1.2+<br/>No Auth<br/>R packages"]

        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM credentials<br/>boto3 SDK"]

        Git["Git Repositories<br/>443/TCP HTTPS or 22/TCP SSH<br/>TLS1.2+/SSH<br/>Tokens/SSH Keys"]
    end

    subgraph InternalCluster["INTERNAL CLUSTER (Trusted)"]
        direction TB

        KFP["Kubeflow Pipelines API<br/>8888/TCP HTTP<br/>K8s SA Token<br/>Elyra pipeline submit"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>K8s SA Token<br/>oc client"]

        Registry["OpenShift Registry<br/>5000/TCP HTTPS TLS1.2+<br/>Pull Secrets<br/>Image pull"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Cookie| Router
    Router -->|HTTPS/8443<br/>OAuth2 Token| OAuth
    OAuth -->|HTTP/8888<br/>Localhost<br/>Trusted| Jupyter

    Jupyter -->|HTTPS/443<br/>pip install| PyPI
    Jupyter -->|HTTPS/443<br/>install.packages| CRAN
    Jupyter -->|HTTPS/443<br/>AWS IAM| S3
    Jupyter -->|HTTPS/443 or SSH/22<br/>Git credentials| Git

    Jupyter -->|HTTP/8888<br/>K8s SA Token| KFP
    Jupyter -->|HTTPS/6443<br/>K8s SA Token| K8sAPI
    Jupyter -.->|HTTPS/5000<br/>Pull Secret| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#d32f2f,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Router ingress
    class OAuth,Jupyter workbench
    class PyPI,CRAN,S3,Git egress
    class KFP,K8sAPI,Registry internal
