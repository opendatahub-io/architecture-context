graph TD
    subgraph "Service Accounts"
        SA1[odh-model-controller<br/>Namespace: system]
        SA2[prometheus-custom<br/>Namespace: openshift-monitoring]
    end

    subgraph "Cluster-Level Bindings"
        CRB1[odh-model-controller-role-binding<br/>ClusterRoleBinding]
        CRB2[prometheus-ns-access<br/>RoleBinding per namespace]
    end

    subgraph "Leader Election (Namespace-Scoped)"
        RB1[odh-model-controller-leader-election-binding<br/>RoleBinding in system namespace]
        R1[odh-model-controller-leader-election-role<br/>Role]
    end

    subgraph "Cluster Roles"
        CR1[odh-model-controller-role<br/>ClusterRole]
        CR2[prometheus-ns-access<br/>ClusterRole]
    end

    subgraph "API Resources - KServe & Serving"
        API1[serving.kserve.io<br/>InferenceService<br/>ServingRuntime]
        API2[serving.knative.dev<br/>Service]
    end

    subgraph "API Resources - Istio"
        API3[networking.istio.io<br/>VirtualService<br/>Gateway]
        API4[security.istio.io<br/>PeerAuthentication<br/>AuthorizationPolicy]
        API5[telemetry.istio.io<br/>Telemetry]
    end

    subgraph "API Resources - OpenShift"
        API6[route.openshift.io<br/>Route]
    end

    subgraph "API Resources - Core"
        API7[Core APIs<br/>Service, Secret<br/>ConfigMap, ServiceAccount<br/>Namespace, Pod, Endpoint]
    end

    subgraph "API Resources - Networking"
        API8[networking.k8s.io<br/>NetworkPolicy<br/>Ingress]
    end

    subgraph "API Resources - Monitoring"
        API9[monitoring.coreos.com<br/>ServiceMonitor<br/>PodMonitor]
    end

    subgraph "API Resources - Auth"
        API10[authorino.kuadrant.io<br/>AuthConfig]
    end

    subgraph "API Resources - Service Mesh"
        API11[maistra.io<br/>ServiceMeshMember<br/>ServiceMeshMemberRoll<br/>ServiceMeshControlPlane]
    end

    subgraph "API Resources - RBAC"
        API12[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>RoleBinding]
    end

    subgraph "API Resources - ODH"
        API13[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        API14[dscinitialization.opendatahub.io<br/>DSCInitialization]
    end

    subgraph "Leader Election Resources"
        API15[Core APIs<br/>ConfigMap, Event]
        API16[coordination.k8s.io<br/>Lease]
    end

    subgraph "Monitoring Resources"
        API17[Core APIs<br/>Service, Endpoint, Pod]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1
    SA2 -->|bound via| CRB2

    %% Cluster Role Bindings
    CRB1 -->|grants| CR1
    RB1 -->|grants| R1
    CRB2 -->|grants| CR2

