    CR1 -->|get,list,watch,create,update,patch,delete| API10
    CR1 -->|get,list,watch,create,update,patch,delete,use| API11
    CR1 -->|get,list,watch,create,update,patch,delete| API12
    CR1 -->|get,list,watch| API13
    CR1 -->|get,list,watch| API14

    %% Leader Election Permissions
    R1 -->|get,list,watch,create,update,patch,delete| API15
