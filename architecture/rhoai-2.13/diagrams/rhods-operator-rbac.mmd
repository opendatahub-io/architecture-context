graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-operator]
    end

    subgraph "ClusterRole Binding"
        CRB[controller-manager-rolebinding<br/>Scope: Cluster-wide]
    end

    subgraph "ClusterRole Permissions"
        CR[controller-manager-role]
    end

    subgraph "Core Resources"
        Core1["secrets, configmaps, serviceaccounts<br/>namespaces, services, pvcs, pods, events<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Apps Resources"
        Apps["deployments, statefulsets, replicasets<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "RBAC Resources"
        RBAC["roles, rolebindings<br/>clusterroles, clusterrolebindings<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "OpenShift Resources"
        Route["routes (route.openshift.io)<br/>Verbs: create, delete, get, list, patch, update, watch"]
        OAuth["oauthclients (oauth.openshift.io)<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Console["consolelinks, odhquickstarts (console.openshift.io)<br/>Verbs: create, delete, get, list, patch"]
        Config["clusterversions, authentications, ingresses (config.openshift.io)<br/>Verbs: get, list, watch"]
    end

    subgraph "Networking Resources"
        Network["networkpolicies, ingresses (networking.k8s.io)<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Monitoring Resources"
        Monitoring["servicemonitors, prometheusrules, podmonitors<br/>(monitoring.coreos.com)<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Operator Lifecycle"
        OLM["subscriptions, clusterserviceversions<br/>(operators.coreos.com)<br/>Verbs: get, list, watch, delete"]
    end

    subgraph "Model Serving Resources"
        KServe["inferenceservices, servingruntimes<br/>clusterservingruntimes (serving.kserve.io)<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Knative["services (serving.knative.dev)<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Authorino["authconfigs (authorino.kuadrant.io)<br/>Verbs: * (all)"]
    end

    subgraph "Pipeline Resources"
        Tekton["* (all resources in tekton.dev)<br/>Verbs: * (all)"]
    end

    subgraph "Workload Resources"
        Batch["jobs, cronjobs (batch)<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Autoscaling["horizontalpodautoscalers (autoscaling)<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "Custom Resources (ODH)"
        ODHCR["datascienceclusters (datasciencecluster.opendatahub.io)<br/>dscinitializations (dscinitialization.opendatahub.io)<br/>featuretrackers (features.opendatahub.io)<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "CRD Resources"
        CRD["customresourcedefinitions (apiextensions.k8s.io)<br/>Verbs: create, delete, get, list, patch, watch"]
    end

