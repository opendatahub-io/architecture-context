graph TB
    subgraph "TrustyAI Service Operator"
        Controller[TrustyAI Operator Controller<br/>Go Controller-Runtime]
        MetricsEndpoint[Metrics Endpoint<br/>8080/TCP]
        HealthEndpoint[Health/Ready Endpoints<br/>8081/TCP]

        Controller -->|exposes| MetricsEndpoint
        Controller -->|exposes| HealthEndpoint
    end

    subgraph "Managed TrustyAI Service Resources"
        direction TB
        TrustyAIService[TrustyAI Service<br/>Quarkus Application<br/>8080/TCP HTTP]
        OAuthProxy[OAuth Proxy<br/>Sidecar Container<br/>8443/TCP HTTPS]
        ServiceMonitor[ServiceMonitor<br/>Prometheus CRD]
        Storage[PVC Storage<br/>1Gi Default]
        Route[OpenShift Route<br/>443/TCP HTTPS]

        OAuthProxy -->|proxies to| TrustyAIService
        ServiceMonitor -->|scrapes| TrustyAIService
        TrustyAIService -->|persists data| Storage
    end

    subgraph "Custom Resources"
        TrustyAICR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    User[User/Admin] -->|creates| TrustyAICR
    TrustyAICR -->|watched by| Controller

    Controller -->|creates/manages| TrustyAIService
    Controller -->|creates/manages| OAuthProxy
    Controller -->|creates/manages| ServiceMonitor
    Controller -->|creates/manages| Storage
    Controller -->|creates/manages| Route

    subgraph "External Dependencies"
        KServe[KServe InferenceServices]
        ModelMesh[Model Mesh]
        Prometheus[Prometheus]
        K8sAPI[Kubernetes API Server]
        Database[(Database Backend<br/>PostgreSQL/MySQL<br/>Optional)]
    end

    Controller -->|patches| KServe
    Controller -->|configures| ModelMesh
    Controller -->|manages resources via| K8sAPI
    Prometheus -->|scrapes metrics from| ServiceMonitor
    TrustyAIService -.->|optional storage| Database

    ExternalUser[External User] -->|HTTPS 443/TCP<br/>OAuth| Route
    Route -->|re-encrypt TLS| OAuthProxy

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style TrustyAICR fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#999,stroke:#333
    style ModelMesh fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Database fill:#e8e8e8,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333
