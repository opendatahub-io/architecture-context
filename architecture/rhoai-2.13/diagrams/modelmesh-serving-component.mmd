    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterServingRuntimeCR fill:#f5a623,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style RuntimeAdapter fill:#7ed321,stroke:#333
    style RESTProxy fill:#7ed321,stroke:#333
    style StorageHelper fill:#7ed321,stroke:#333
    style ModelServer fill:#7ed321,stroke:#333
    style etcd fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
