graph TB
    subgraph "RHODS Operator"
        DSCController[DataScienceCluster Controller<br/>Manages component lifecycle]
        DSCIController[DSCInitialization Controller<br/>Platform initialization]
        SecretGen[SecretGenerator Controller<br/>OAuth client generation]
        CertGen[CertConfigmapGenerator Controller<br/>Trusted CA bundle management]

        DSCController -->|uses| ManifestFetcher[Manifest Fetcher<br/>Git repos + Kustomize]
        DSCIController -->|configures| ServiceMeshConfig[Service Mesh Config]
        DSCIController -->|deploys| MonitoringStack[Monitoring Stack<br/>Prometheus/Alertmanager]
        SecretGen -->|creates| OAuthClients[OAuth Clients]
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FeatureTracker[FeatureTracker CR<br/>features.opendatahub.io/v1]
    end

    subgraph "Managed Components"
        Dashboard[ODH Dashboard]
        Notebooks[Workbenches/Notebooks]
        KServe[KServe]
        ModelMesh[ModelMesh Serving]
        DSP[Data Science Pipelines]
        CodeFlare[CodeFlare]
        Ray[KubeRay]
        Kueue[Kueue]
        Training[Training Operator]
        TrustyAI[TrustyAI]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ServiceMesh[OpenShift Service Mesh<br/>Conditional]
        Serverless[OpenShift Serverless<br/>Conditional]
        Pipelines[OpenShift Pipelines<br/>Conditional]
        GitHub[GitHub Manifest Repos<br/>443/TCP HTTPS]
        QuayIO[quay.io<br/>443/TCP HTTPS]
        RHIO[registry.redhat.io<br/>443/TCP HTTPS]
    end

    User[User/GitOps] -->|creates| DSC
    User -->|creates| DSCI

    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController

    DSCController -->|creates/manages| Dashboard
    DSCController -->|creates/manages| Notebooks
    DSCController -->|creates/manages| KServe
    DSCController -->|creates/manages| ModelMesh
    DSCController -->|creates/manages| DSP
    DSCController -->|creates/manages| CodeFlare
    DSCController -->|creates/manages| Ray
    DSCController -->|creates/manages| Kueue
    DSCController -->|creates/manages| Training
    DSCController -->|creates/manages| TrustyAI

    DSCController -->|API calls| K8sAPI
    DSCIController -->|API calls| K8sAPI
    SecretGen -->|API calls| K8sAPI
    CertGen -->|API calls| K8sAPI

    ManifestFetcher -->|fetches| GitHub
    DSCController -->|pulls images| QuayIO
    DSCController -->|pulls images| RHIO

    KServe -.->|requires| ServiceMesh
    KServe -.->|requires| Serverless
    DSP -.->|requires| Pipelines

