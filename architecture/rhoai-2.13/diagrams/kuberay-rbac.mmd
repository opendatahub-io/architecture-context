graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph RoleBindings["Role Bindings"]
        RB[leader-election-rolebinding<br/>Namespace: opendatahub]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph Roles["Roles"]
        R[leader-election-role<br/>Namespace: opendatahub]
    end

    subgraph CoreAPI["API: '' (core)"]
        direction TB
        Pods["pods, pods/status<br/>create, delete, deletecollection,<br/>get, list, patch, update, watch"]
        Services["services, services/status<br/>create, delete, get, list,<br/>patch, update, watch"]
        ServiceAccounts["serviceaccounts<br/>create, delete, get, list, watch"]
        Events["events<br/>create, delete, get, list,<br/>patch, update, watch"]
        Endpoints["endpoints<br/>get, list"]
    end

    subgraph BatchAPI["API: batch"]
        Jobs["jobs<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph RayAPI["API: ray.io"]
        direction TB
        RayClusters["rayclusters, rayclusters/status,<br/>rayclusters/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayJobs["rayjobs, rayjobs/status,<br/>rayjobs/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayServices["rayservices, rayservices/status,<br/>rayservices/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph NetworkingAPI["API: networking.k8s.io"]
        Ingresses["ingresses, ingressclasses<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph ExtensionsAPI["API: extensions"]
        IngressesExt["ingresses<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph RouteAPI["API: route.openshift.io"]
        Routes["routes<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph RBACAPI["API: rbac.authorization.k8s.io"]
        RolesRBAC["roles, rolebindings<br/>create, delete, get, list,<br/>update, watch"]
    end

    subgraph CoordinationAPI["API: coordination.k8s.io"]
        Leases["leases<br/>create, get, list, update"]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Role Bindings to Roles
    CRB -->|grants| CR
    RB -->|grants| R

    %% ClusterRole Permissions
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Events
    CR -->|permissions| Endpoints
    CR -->|permissions| Jobs
    CR -->|permissions| RayClusters
    CR -->|permissions| RayJobs
    CR -->|permissions| RayServices
    CR -->|permissions| Ingresses
    CR -->|permissions| IngressesExt
    CR -->|permissions| Routes
    CR -->|permissions| RolesRBAC
    CR -->|permissions| Leases

    %% Role Permissions
    R -->|permissions| Leases

