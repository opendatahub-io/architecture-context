    style K8sAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Istio fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Prometheus fill:#999,stroke:#333,stroke-width:2px,color:#fff
