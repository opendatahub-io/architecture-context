graph TB
    subgraph External["EXTERNAL - Untrusted"]
        ExternalUser[External User]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>443/TCP → 443/TCP<br/>TLS 1.3 edge<br/>Re-encrypt to backend"]
        TLSService["{name}-tls Service<br/>ClusterIP<br/>443/TCP → 8443/TCP"]
    end

    subgraph Application["APPLICATION LAYER - Authenticated"]
        direction TB

        subgraph OAuthLayer["OAuth Authentication Layer"]
            OAuthProxy["OAuth Proxy Sidecar<br/>ose-oauth-proxy<br/>8443/TCP HTTPS TLS1.2+<br/>SA: {name}-proxy<br/>Secret: {name}-tls"]
            OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>Bearer Token Validation"]
        end

        subgraph ServiceLayer["TrustyAI Service Layer"]
            TrustyAIService["TrustyAI Service<br/>quay.io/trustyai/trustyai-service<br/>8080/TCP HTTP internal<br/>4443/TCP HTTPS internal TLS<br/>Secret: {name}-internal"]
        end

        subgraph Storage["Storage Backend"]
            PVC["PersistentVolumeClaim<br/>1Gi Default<br/>CSV Format"]
            Database["Database - Optional<br/>PostgreSQL/MySQL<br/>3306/5432 JDBC TLS1.2+<br/>Secrets: {name}-db-credentials, {name}-db-tls"]
        end
    end

    subgraph Monitoring["INTERNAL MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor CRD"]
        MetricsService["{name} Service<br/>ClusterIP<br/>80/TCP → 8080/TCP<br/>HTTP internal only"]
    end

    subgraph Operator["OPERATOR LAYER - Control Plane"]
        OperatorController["TrustyAI Operator<br/>controller-manager<br/>SA: controller-manager<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>SA Bearer Token Auth"]
    end

    subgraph ModelServing["MODEL SERVING INTEGRATION"]
        KServe["KServe InferenceServices<br/>443/TCP HTTPS TLS1.2+<br/>Service Certificate - mTLS"]
        ModelMesh["Model Mesh Services<br/>443/TCP HTTPS TLS1.2+<br/>Service Certificate"]
    end

    %% External Access Flow
    ExternalUser -->|HTTPS/443<br/>TLS 1.3<br/>No Auth| Router
    Router -->|HTTPS/443<br/>TLS 1.2+ re-encrypt| TLSService
    TLSService -->|HTTPS/8443<br/>TLS 1.2+| OAuthProxy

    %% OAuth Validation
    OAuthProxy <-->|HTTPS/443<br/>OAuth 2.0<br/>Token Validation| OAuthServer

    %% Authenticated Access
    OAuthProxy -->|HTTP/8080<br/>Localhost<br/>No Encryption<br/>Trusted| TrustyAIService

    %% Storage
    TrustyAIService -->|Volume Mount<br/>CSV Data| PVC
    TrustyAIService -.->|JDBC/3306 or 5432<br/>TLS 1.2+ optional<br/>DB Credentials| Database

    %% Monitoring
    Prometheus -->|HTTP/80<br/>No Auth<br/>ClusterIP Internal| MetricsService
    MetricsService -->|HTTP/8080<br/>Internal| TrustyAIService

    %% Operator Control
    OperatorController <-->|HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token| K8sAPI
    OperatorController -->|Creates/Manages| TrustyAIService
    OperatorController -->|Creates/Manages| OAuthProxy
    OperatorController -->|Creates/Manages| PVC
    OperatorController -->|Creates ServiceMonitor| Prometheus

    %% Model Serving Integration
    OperatorController -->|Patches via K8s API<br/>Inject MM_PAYLOAD_PROCESSORS| KServe
    OperatorController -->|Configures via K8s API| ModelMesh
    KServe -->|HTTPS/443<br/>TLS 1.2+<br/>Service Cert| TrustyAIService
    ModelMesh -->|HTTPS/443<br/>TLS 1.2+<br/>Service Cert| TrustyAIService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef modelserving fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class ExternalUser external
    class Router,TLSService ingress
    class OAuthProxy,OAuthServer,TrustyAIService,PVC,Database application
    class Prometheus,MetricsService monitoring
    class OperatorController,K8sAPI operator
    class KServe,ModelMesh modelserving
