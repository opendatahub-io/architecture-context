graph LR
    CodeFlare[CodeFlare Operator]

    %% External Dependencies (Required)
    CodeFlare -->|"manages security<br/>watches CRDs"| KubeRay[KubeRay Operator v1.1.1<br/>REQUIRED]

    %% External Dependencies (Optional)
    CodeFlare -.->|"workload scheduling<br/>quota mgmt"| Kueue[Kueue v0.7.0+<br/>OPTIONAL]
    CodeFlare -.->|"alt cert mgmt"| CertManager[cert-manager<br/>OPTIONAL]
    CodeFlare -.->|"Routes, config"| OpenShiftAPI[OpenShift API v4.x<br/>OPTIONAL - OpenShift only]

    %% Internal ODH Dependencies
    CodeFlare -->|"reads DSCInit<br/>app namespace"| ODHOperator[opendatahub-operator]
    CodeFlare -->|"injects sidecar<br/>dashboard auth"| OAuthProxy[oauth-proxy]

    %% Platform Dependencies
    CodeFlare -->|"reconciliation<br/>CRD watching"| K8sAPI[Kubernetes API Server]

    %% Integration Points
    Prometheus[Prometheus] -->|"scrapes metrics<br/>8080/TCP HTTP"| CodeFlare
    Dashboard[ODH Dashboard] -.->|"UI management"| CodeFlare
    Pipelines[Data Science Pipelines] -.->|"auto-deploy clusters"| CodeFlare

    %% Managed Resources
    CodeFlare -->|creates/manages| RayCluster[RayCluster Resources<br/>with mTLS + OAuth]
    CodeFlare -->|creates/manages| AppWrapper[AppWrapper Resources<br/>gang scheduling]
    CodeFlare -->|creates| NetworkPolicies[Network Policies<br/>pod isolation]
    CodeFlare -->|creates| Secrets[Secrets<br/>CA, TLS, OAuth config]
    CodeFlare -->|creates| Routes[Routes/Ingresses<br/>external access]

    %% Custom Resource Definitions
    KubeRay -->|defines| RayClusterCRD[RayCluster CRD<br/>ray.io/v1]
    CodeFlare -->|defines| AppWrapperCRD[AppWrapper CRD<br/>workload.codeflare.dev/v1beta2]
    Kueue -.->|defines| WorkloadCRD[Workload CRD<br/>kueue.x-k8s.io/v1beta1]

