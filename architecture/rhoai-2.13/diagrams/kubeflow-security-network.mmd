graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+ Termination<br/>RequestAuthentication (JWT)"]
        VirtualService["VirtualService<br/>Path: /notebook/ns/name/*<br/>Created when USE_ISTIO=true"]
    end

    subgraph ServiceMesh["SERVICE MESH (Internal - Optional mTLS)"]
        direction TB

        subgraph UserNamespace["Namespace: user-namespace"]
            NotebookService["Notebook Service<br/>ClusterIP<br/>Port: 80/TCP → 8888/TCP<br/>Name: notebook-name"]

            subgraph NotebookPod["Notebook Pod (StatefulSet)"]
                JupyterContainer["Jupyter Container<br/>Port: 8888/TCP HTTP<br/>Image: notebook-image"]
                OAuthSidecar["OAuth Proxy Sidecar<br/>(Optional - OpenShift)"]
            end
        end
    end

    subgraph ControllerPlane["CONTROLLER PLANE"]
        direction TB

        subgraph OperatorNamespace["Namespace: operator-namespace"]
            Controller["Notebook Controller<br/>SA: notebook-controller-service-account"]

            subgraph ControllerEndpoints["Controller Endpoints"]
                Metrics["Metrics<br/>:8080/TCP HTTP<br/>/metrics<br/>Auth: None"]
                Health["Health Probes<br/>:8081/TCP HTTP<br/>/healthz, /readyz"]
                Webhook["Webhook Server<br/>:9443/TCP HTTPS<br/>Status: Disabled"]
            end

            Culler["Culling Reconciler<br/>(if ENABLE_CULLING=true)<br/>Period: 1 min<br/>Timeout: 24h"]
        end
    end

    subgraph K8sPlane["KUBERNETES PLATFORM"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Image Pull Secrets"]
        Prometheus["Prometheus<br/>Scrapes :8080/TCP HTTP"]
    end

    %% User flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth/JWT| Gateway
    Gateway -->|HTTP/80<br/>mTLS STRICT<br/>Service Identity| VirtualService
    VirtualService -->|HTTP/80<br/>mTLS optional| NotebookService
    NotebookService -->|HTTP/8888| JupyterContainer

    %% Controller flows
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>CRUD Operations| K8sAPI
    K8sAPI -.->|Watch Events<br/>Notebook CRs| Controller
    Controller -.->|Creates when<br/>USE_ISTIO=true| VirtualService

    %% Culling flows
    Culler -->|HTTP/80<br/>GET /api/kernels<br/>GET /api/terminals| NotebookService
    Culler -->|Update annotations<br/>Scale to 0| K8sAPI

    %% Dependencies
    NotebookPod -->|Pull images<br/>HTTPS/443<br/>TLS 1.2+| Registry
    Prometheus -->|Scrape metrics<br/>HTTP/8080| Metrics
    Controller -->|Emits metrics| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externaldeps fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway,VirtualService ingress
    class NotebookService,NotebookPod,JupyterContainer,OAuthSidecar servicemesh
    class Controller,Culler,Metrics,Health,Webhook controller
    class K8sAPI k8s
    class Registry,Prometheus externaldeps
