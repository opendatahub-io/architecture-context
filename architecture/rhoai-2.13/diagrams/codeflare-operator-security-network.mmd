graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router /<br/>Ingress Controller<br/>443/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph Operator["CodeFlare Operator Manager<br/>SA: controller-manager<br/>User: 65532 (non-root)<br/>FIPS: Enabled"]
            Metrics["Metrics Server<br/>8080/TCP HTTP<br/>Auth: Bearer Token"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>Auth: None"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>Auth: mTLS (API server)"]
        end
    end

    subgraph UserNS["USER NAMESPACE ({namespace})"]
        direction TB

        subgraph HeadPod["RayCluster Head Pod<br/>SA: {raycluster}-sa"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS TLS1.2+<br/>Auth: OAuth flow"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>localhost only"]
            GCS["GCS Server<br/>10001/TCP gRPC<br/>mTLS + Client Cert"]
        end

        subgraph WorkerPods["RayCluster Worker Pods<br/>SA: {raycluster}-sa<br/>Certs: {raycluster}-tls"]
            Worker["Ray Worker<br/>mTLS Client Cert"]
        end
    end

    subgraph K8sAPI["KUBERNETES API"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        KubeRay["KubeRay Operator<br/>CRD Watch"]
        Kueue["Kueue Scheduler<br/>CRD Management"]
        OAuthProvider["OpenShift OAuth<br/>443/TCP HTTPS TLS1.2+"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% Data Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| Router
    Router -->|HTTPS/8443<br/>TLS Passthrough| OAuthProxy
    OAuthProxy -->|OAuth Redirect| OAuthProvider
    OAuthProxy -->|HTTP/8265<br/>localhost<br/>No encryption| Dashboard

    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| APIServer
    APIServer -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS| Webhook

    Worker -->|gRPC/10001<br/>mTLS<br/>Client Cert| GCS

    Operator -.->|CRD Watch<br/>via K8s API| KubeRay
    Operator -.->|CRD Mgmt<br/>via K8s API| Kueue

    Prometheus -->|HTTP/8080<br/>Bearer Token| Metrics

    %% Network Policies
    NP1["NetworkPolicy: {raycluster}-head<br/>Allow: 8443/TCP from any NS<br/>Allow: 10001/TCP from same NS<br/>Allow: workers in same NS"]
    NP2["NetworkPolicy: {raycluster}-workers<br/>Allow: traffic from head<br/>Allow: traffic from other workers"]

    HeadPod -.- NP1
    WorkerPods -.- NP2

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef usernamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef networkpolicy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,stroke-dasharray: 5 5

    class User external
    class Router ingress
    class Operator,Metrics,Health,Webhook operator
    class HeadPod,OAuthProxy,Dashboard,GCS,WorkerPods,Worker usernamespace
    class APIServer k8s
    class KubeRay,Kueue,OAuthProvider,Prometheus externalservice
    class NP1,NP2 networkpolicy
