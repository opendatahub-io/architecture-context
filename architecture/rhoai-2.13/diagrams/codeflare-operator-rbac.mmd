graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>ServiceAccount]
    end

    subgraph "Cluster-wide RBAC"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        CR1[manager-role<br/>ClusterRole]
    end

    subgraph "Namespace-scoped RBAC"
        RB1[leader-election-rolebinding<br/>RoleBinding]
        R1[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Ray & CodeFlare"
        Ray1[ray.io<br/>RayCluster, RayJob]
        AW1[workload.codeflare.dev<br/>AppWrapper]
        Kueue1[kueue.x-k8s.io<br/>Workload, ResourceFlavor,<br/>WorkloadPriorityClass]
    end

    subgraph "API Resources - Core & Apps"
        Core1[core<br/>Pods, Services, Secrets,<br/>ServiceAccounts, Events, Nodes]
        Apps1[apps<br/>Deployments, StatefulSets]
        Batch1[batch<br/>Jobs]
    end

    subgraph "API Resources - Networking"
        Net1[networking.k8s.io<br/>Ingresses, NetworkPolicies]
        Route1[route.openshift.io<br/>Routes]
    end

    subgraph "API Resources - RBAC & Admission"
        RBAC1[rbac.authorization.k8s.io<br/>ClusterRoleBindings]
        Admission1[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration,<br/>ValidatingWebhookConfiguration]
    end

    subgraph "API Resources - Platform & ODH"
        CRD1[apiextensions.k8s.io<br/>CustomResourceDefinitions]
        Config1[config.openshift.io<br/>Ingresses]
        DSC1[dscinitialization.opendatahub.io<br/>DSCInitializations]
    end

    subgraph "API Resources - Auth & Scheduling"
        Auth1[authentication.k8s.io<br/>TokenReviews]
        Auth2[authorization.k8s.io<br/>SubjectAccessReviews]
        Sched1[scheduling.k8s.io<br/>PriorityClasses]
        Sched2[scheduling.sigs.k8s.io<br/>PodGroups]
        Sched3[scheduling.x-k8s.io<br/>PodGroups]
    end

    subgraph "API Resources - ML Training"
        ML1[kubeflow.org<br/>PyTorchJobs]
    end

    subgraph "Namespace Resources"
        NS1[core<br/>ConfigMaps, Events]
        Coord1[coordination.k8s.io<br/>Leases]
    end

