graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge<br/>Route: [isvc]-[ns].[domain]"]
    end

    subgraph ServiceMeshIngress["SERVICE MESH INGRESS"]
        Gateway["Istio Gateway<br/>kserve-local-gateway<br/>443/TCP HTTPS<br/>TLS Mode: SIMPLE"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>PeerAuth: STRICT"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            Predictor["Predictor Pod<br/>SA: isvc-name-sa<br/>Istio Sidecar: Envoy<br/>PeerAuth: STRICT<br/>Secrets: storage-config"]
            VirtualService["VirtualService<br/>Routing rules"]
            PeerAuth["PeerAuthentication<br/>mTLS: STRICT"]
        end

        subgraph NS_System["Namespace: system-namespace"]
            AuthConfig["AuthConfig<br/>Authorino<br/>(if auth enabled)"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph NS_ControllerNS["Namespace: system-namespace"]
            Controller["ODH Model Controller<br/>3 replicas HA<br/>Leader Election<br/>SA: odh-model-controller"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTPS<br/>Service CA"]
        end

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>openshift-monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Auth"]
        ModelRegistry["Model Registry<br/>gRPC mTLS<br/>(optional)"]
    end

    %% Data Plane Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Router -->|HTTPS/443<br/>mTLS STRICT<br/>Service Identity| Gateway
    Gateway -->|HTTP/8080<br/>mTLS STRICT<br/>VirtualService route| Activator
    Activator -->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity| Predictor
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Access Key| S3

    %% Control Plane Flows
    Controller -->|Watch/Update<br/>HTTPS/6443<br/>SA Token| K8sAPI
    K8sAPI -->|Webhook<br/>HTTPS/9443<br/>Client Cert| Webhook
    Prometheus -->|Scrape<br/>HTTPS/8080<br/>Bearer Token| MetricsSvc
    Prometheus -->|Scrape<br/>varies<br/>Bearer Token| Predictor
    Controller -->|gRPC<br/>mTLS<br/>Client Cert| ModelRegistry

    %% Created Resources
    Controller -.->|creates| VirtualService
    Controller -.->|creates| PeerAuth
    Controller -.->|creates| AuthConfig
    Controller -.->|creates| Router

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class Gateway,Activator,Predictor,VirtualService,PeerAuth servicemesh
    class Controller,Webhook,MetricsSvc,K8sAPI,Prometheus controlplane
    class S3,ModelRegistry externalservice

    %% Annotations
    style NS_Knative fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style NS_User fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style NS_System fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style NS_ControllerNS fill:#e3f2fd,stroke:#2196f3,stroke-width:1px
