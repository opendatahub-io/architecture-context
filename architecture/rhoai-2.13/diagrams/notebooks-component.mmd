graph TB
    subgraph "Workbench Images (Notebooks Component)"
        subgraph "Jupyter Images"
            JupyterMin[Jupyter Minimal<br/>JupyterLab 3.6.7<br/>Python 3.9/3.11]
            JupyterDS[Jupyter DataScience<br/>pandas, numpy, scikit-learn<br/>boto3, Elyra]
            JupyterPT[Jupyter PyTorch<br/>PyTorch + CUDA/ROCm<br/>GPU Support]
            JupyterTF[Jupyter TensorFlow<br/>TensorFlow + CUDA/ROCm<br/>GPU Support]
            JupyterTA[Jupyter TrustyAI<br/>AI Explainability<br/>Fairness Analysis]
            JupyterHabana[Jupyter Habana<br/>Intel Gaudi SDK<br/>Deprecated]
        end

        subgraph "Alternative IDEs"
            CodeServer[CodeServer<br/>VS Code 4.22.0<br/>NGINX + supervisord]
            RStudio[RStudio Server<br/>R 4.3.3<br/>NGINX + supervisord]
        end

        subgraph "Runtime Images"
            RuntimeMin[Runtime Minimal<br/>Serving Only]
            RuntimeDS[Runtime DataScience<br/>scikit-learn]
            RuntimePT[Runtime PyTorch<br/>CPU Serving]
            RuntimeTF[Runtime TensorFlow<br/>CPU Serving]
        end

        subgraph "Base Layers"
            BaseUBI9[Base UBI9<br/>Python 3.9/3.11<br/>oc client]
            CUDA[CUDA Support<br/>NVIDIA GPU]
            ROCm[ROCm Support<br/>AMD GPU]
            Intel[Intel oneAPI<br/>Intel GPU]
        end
    end

    subgraph "ODH/RHOAI Platform"
        NotebookController[notebook-controller<br/>Pod Launcher]
        OAuthProxy[oauth-proxy<br/>Authentication Sidecar]
        Dashboard[ODH Dashboard<br/>UI Integration]
        ImageStreams[OpenShift ImageStreams<br/>quay.io/modh]
    end

    subgraph "External Dependencies"
        PyPI[PyPI<br/>Python Packages<br/>443/TCP HTTPS]
        CRAN[CRAN<br/>R Packages<br/>443/TCP HTTPS]
        S3[S3 Storage<br/>Datasets/Models<br/>443/TCP HTTPS]
        Git[Git Repositories<br/>Source Code<br/>443/TCP HTTPS]
        KFP[Kubeflow Pipelines<br/>Pipeline API<br/>8888/TCP HTTP]
        K8sAPI[Kubernetes API<br/>Cluster Mgmt<br/>6443/TCP HTTPS]
    end

    subgraph "Model Serving"
        ModelMesh[Model Mesh<br/>Uses Runtime Images]
    end

    %% Base layer relationships
    BaseUBI9 --> JupyterMin
    BaseUBI9 --> CodeServer
    BaseUBI9 --> RStudio
    BaseUBI9 --> RuntimeMin

    JupyterMin --> JupyterDS
    JupyterDS --> JupyterTA

    CUDA --> JupyterPT
    CUDA --> JupyterTF
    ROCm --> JupyterPT
    ROCm --> JupyterTF
    Intel --> JupyterHabana

    %% Platform integration
    ImageStreams -->|pulls images| NotebookController
    NotebookController -->|creates pods| JupyterDS
    NotebookController -->|creates pods| JupyterPT
    NotebookController -->|creates pods| CodeServer
    NotebookController -->|creates pods| RStudio
    OAuthProxy -.->|sidecar| JupyterDS
    Dashboard -->|lists images| ImageStreams

    %% External dependencies
    JupyterDS -->|pip install| PyPI
    JupyterPT -->|pip install| PyPI
    JupyterDS -->|boto3| S3
    JupyterDS -->|git clone| Git
    JupyterDS -->|Elyra| KFP
    JupyterDS -->|oc client| K8sAPI
    RStudio -->|install.packages| CRAN

    %% Runtime usage
    RuntimeMin --> ModelMesh
    RuntimeDS --> ModelMesh
    RuntimePT --> ModelMesh
    RuntimeTF --> ModelMesh

