graph TD
    subgraph "Service Accounts"
        SA1[modelmesh-controller<br/>Namespace: modelmesh-serving]
        SA2[modelmesh-serving-sa<br/>Namespace: modelmesh-serving]
    end

    subgraph "ClusterRole Bindings"
        CRB1[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB2[auth-proxy-role-binding<br/>RoleBinding]
    end

    subgraph "Roles"
        CR1[modelmesh-controller-role<br/>ClusterRole]
        CR2[leader-election-role<br/>Role]
        CR3[auth-proxy-client-clusterrole<br/>ClusterRole]
        CR4[restricted-scc-role<br/>Role]
    end

    subgraph "API Resources - serving.kserve.io"
        R1[InferenceService<br/>serving.kserve.io/v1beta1]
        R2[Predictor<br/>serving.kserve.io/v1alpha1]
        R3[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        R4[ClusterServingRuntime<br/>serving.kserve.io/v1alpha1]
        R5[*/status<br/>Status subresources]
        R6[*/finalizers<br/>Finalizer subresources]
    end

    subgraph "API Resources - Core/Apps"
        R7[ConfigMaps, Secrets<br/>core/v1]
        R8[Services, Namespaces<br/>core/v1]
        R9[Endpoints, PVCs<br/>core/v1]
        R10[Deployments<br/>apps/v1]
        R11[Events<br/>core/v1]
    end

    subgraph "API Resources - Autoscaling/Monitoring"
        R12[HorizontalPodAutoscaler<br/>autoscaling/v2]
        R13[ServiceMonitor<br/>monitoring.coreos.com/v1]
    end

    subgraph "API Resources - Coordination/Auth"
        R14[Leases<br/>coordination.k8s.io/v1]
        R15[TokenReviews<br/>authentication.k8s.io/v1]
        R16[SubjectAccessReviews<br/>authorization.k8s.io/v1]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA1 -->|bound via| LeaderElectionBinding[leader-election-rolebinding]
    SA2 -->|bound via| SSCBinding[restricted-scc-role-binding]

    %% Role Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR3
    LeaderElectionBinding -->|grants| CR2
    SSCBinding -->|grants| CR4

    %% modelmesh-controller-role Permissions
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R3
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R4
    CR1 -->|get, patch, update| R5
    CR1 -->|get, patch, update| R6
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R7
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R8
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R9
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R10
    CR1 -->|create, delete, get, list,<br/>update, watch| R12
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| R13

    %% leader-election-role Permissions
    CR2 -->|get, list, watch,<br/>create, update, patch| R7
    CR2 -->|get, list, watch,<br/>create, update, patch| R14
    CR2 -->|create, patch| R11

    %% auth-proxy-client-clusterrole Permissions
    CR3 -->|create| R15
    CR3 -->|create| R16

