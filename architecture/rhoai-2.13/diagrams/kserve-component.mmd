graph TB
    subgraph "KServe Control Plane - Namespace: kserve"
        Controller[kserve-controller-manager<br/>Kubernetes Operator<br/>Go]
        Webhook[Webhook Server<br/>Admission Controller<br/>9443/TCP HTTPS]
        Controller -->|validates via| Webhook
    end

    subgraph "User Namespace - Data Plane"
        subgraph "InferenceService Pod"
            StorageInit[storage-initializer<br/>Init Container<br/>Downloads models]
            Agent[kserve-agent<br/>Sidecar Container<br/>9081/TCP]
            ModelServer[Model Server<br/>8080/TCP HTTP<br/>TensorFlow/PyTorch/etc]
            StorageInit -.->|model artifacts| ModelServer
            Agent -->|proxy requests| ModelServer
        end

        subgraph "InferenceGraph"
            Router[kserve-router<br/>Router Service<br/>8080/TCP]
        end
    end

    subgraph "Custom Resources"
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        InferenceGraphCR[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
        TrainedModelCR[TrainedModel CR<br/>serving.kserve.io/v1alpha1]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        ClusterServingRuntimeCR[ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Created Resources"
        KnativeService[Knative Service<br/>serving.knative.dev]
        Deployment[Deployment<br/>apps/v1]
        Service[Service<br/>core/v1]
        VirtualService[VirtualService<br/>networking.istio.io]
    end

    subgraph "External Dependencies"
        Knative[Knative Serving 0.39+<br/>Serverless autoscaling]
        Istio[Istio 1.19+<br/>Service mesh & routing]
        CertManager[cert-manager<br/>TLS certificates]
        S3[S3/GCS Storage<br/>Model artifacts]
    end

    subgraph "Internal ODH Dependencies"
        ModelController[odh-model-controller<br/>Creates InferenceServices]
        Dashboard[odh-dashboard<br/>UI management]
        ServiceMesh[Service Mesh OSSM<br/>mTLS & policies]
        ModelRegistry[Model Registry<br/>Model metadata]
    end

    %% User interactions
    User[User/Data Scientist] -->|kubectl apply| InferenceServiceCR
    User -->|kubectl apply| InferenceGraphCR

    %% CRD watching
    InferenceServiceCR -->|watched by| Controller
    InferenceGraphCR -->|watched by| Controller
    TrainedModelCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    ClusterServingRuntimeCR -->|watched by| Controller

    %% Webhook validation
    InferenceServiceCR -.->|validates/mutates| Webhook
    TrainedModelCR -.->|validates| Webhook
    InferenceGraphCR -.->|validates| Webhook

    %% Controller creates resources
    Controller -->|creates| KnativeService
    Controller -->|creates| Deployment
    Controller -->|creates| Service
    Controller -->|creates| VirtualService

    %% Resource deployments
    KnativeService -.->|deploys| Agent
    Deployment -.->|deploys| Router

    %% External dependencies
    Controller -->|uses| Knative
    Controller -->|uses| Istio
    Controller -->|uses| CertManager
    StorageInit -->|downloads from| S3

    %% Internal integrations
    ModelController -->|creates| InferenceServiceCR
    Dashboard -->|manages| InferenceServiceCR
    Agent -->|protected by| ServiceMesh
    ModelServer -->|references| ModelRegistry

    %% Request flow
    Client[External Client] -->|HTTPS 443| VirtualService
    VirtualService -->|routes to| Agent
    Router -->|orchestrates| Agent

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Agent fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Router fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ModelServer fill:#50c878,stroke:#333,stroke-width:2px
    style StorageInit fill:#50c878,stroke:#333,stroke-width:2px

    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceGraphCR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainedModelCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px

    style Knative fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
    style S3 fill:#999,stroke:#333,stroke-width:2px

    style ModelController fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
