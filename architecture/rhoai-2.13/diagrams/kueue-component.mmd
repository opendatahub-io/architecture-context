graph TB
    subgraph "Kueue Component"
        Manager[Manager Controller<br/>Deployment]
        Webhook[Webhook Server<br/>9443/TCP HTTPS]
        Visibility[Visibility API Server<br/>8082/TCP HTTPS]
        QueueMgr[Queue Manager<br/>In-Memory Cache]
        Scheduler[Scheduler Engine]
        Integrations[Job Framework<br/>Integrations]

        Manager -->|manages| QueueMgr
        Manager -->|schedules via| Scheduler
        Manager -->|validates/mutates| Webhook
        Manager -->|serves| Visibility
        Manager -->|plugins| Integrations
    end

    subgraph "Kueue CRDs"
        ClusterQueue[ClusterQueue<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue<br/>kueue.x-k8s.io/v1beta1]
        Workload[Workload<br/>kueue.x-k8s.io/v1beta1]
        ResourceFlavor[ResourceFlavor<br/>kueue.x-k8s.io/v1beta1]
        AdmissionCheck[AdmissionCheck<br/>kueue.x-k8s.io/v1beta1]
        WorkloadPriorityClass[WorkloadPriorityClass<br/>kueue.x-k8s.io/v1beta1]
    end

    subgraph "Job Frameworks"
        BatchJob[Kubernetes Batch Job<br/>batch/v1]
        TFJob[TensorFlow Job<br/>kubeflow.org]
        PyTorchJob[PyTorch Job<br/>kubeflow.org]
        MPIJob[MPI Job<br/>kubeflow.org]
        RayJob[Ray Job<br/>ray.io]
        RayCluster[Ray Cluster<br/>ray.io]
        JobSet[JobSet<br/>jobset.x-k8s.io]
        AppWrapper[AppWrapper<br/>workload.codeflare.dev]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Certificate Provisioning]
        Prometheus[Prometheus<br/>8080/TCP HTTP]
        ClusterAutoscaler[Cluster Autoscaler<br/>443/TCP HTTPS]
        RemoteClusters[Remote Clusters<br/>MultiKueue]
    end

    %% User interactions
    User[User/Data Scientist] -->|creates| BatchJob
    User -->|creates| TFJob
    User -->|creates| PyTorchJob
    User -->|creates| RayJob

    %% Job framework to Kueue
    BatchJob -->|watched/mutated by| Webhook
    TFJob -->|watched/mutated by| Webhook
    PyTorchJob -->|watched/mutated by| Webhook
    MPIJob -->|watched/mutated by| Webhook
    RayJob -->|watched/mutated by| Webhook
    RayCluster -->|watched/mutated by| Webhook
    JobSet -->|watched/mutated by| Webhook
    AppWrapper -->|watched by| Manager

    %% Workload management
    Manager -->|creates/manages| Workload
    Manager -->|watches| ClusterQueue
    Manager -->|watches| LocalQueue
    Manager -->|uses| ResourceFlavor
    Manager -->|evaluates| AdmissionCheck
    Manager -->|applies| WorkloadPriorityClass

    %% Scheduler decisions
    Scheduler -->|admits workloads to| BatchJob
    Scheduler -->|unsuspends| TFJob
    Scheduler -->|unsuspends| PyTorchJob
    Scheduler -->|unsuspends| RayJob

    %% External interactions
    Manager -->|API calls| K8sAPI
    Webhook -->|cert from| CertManager
    Manager -->|metrics to| Prometheus
    Manager -->|provisioning requests| ClusterAutoscaler
    Manager -->|distributes workloads| RemoteClusters

    %% User queries
    User -->|queries pending workloads| Visibility
    Visibility -->|reads from| QueueMgr

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Visibility fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style QueueMgr fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Scheduler fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style ClusterQueue fill:#f5a623,stroke:#333,stroke-width:2px
    style LocalQueue fill:#f5a623,stroke:#333,stroke-width:2px
    style Workload fill:#f5a623,stroke:#333,stroke-width:2px
    style ResourceFlavor fill:#f5a623,stroke:#333,stroke-width:2px
    style AdmissionCheck fill:#f5a623,stroke:#333,stroke-width:2px

    style BatchJob fill:#7ed321,stroke:#333,stroke-width:2px
    style TFJob fill:#7ed321,stroke:#333,stroke-width:2px
    style PyTorchJob fill:#7ed321,stroke:#333,stroke-width:2px
    style RayJob fill:#7ed321,stroke:#333,stroke-width:2px

    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
    style CertManager fill:#999,stroke:#333,stroke-width:2px
