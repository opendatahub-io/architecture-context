graph TD
    subgraph "Workbench RBAC (Created by notebook-controller)"
        SA["ServiceAccount:<br/>notebook-NAME<br/>Namespace: USER-NAMESPACE"]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB["RoleBinding:<br/>notebook-NAME-view<br/>Namespace: USER-NAMESPACE"]
    end

    subgraph "Roles (Namespace-scoped)"
        ViewRole[Role: view<br/>Built-in K8s role<br/>Read-only access]
    end

    subgraph "API Resources - Read Access"
        direction TB

        ConfigMaps[core/ConfigMaps<br/>Read configs]
        Secrets[core/Secrets<br/>Read credentials]
        Pods[core/Pods<br/>List pods]
        Services[core/Services<br/>List services]
        PVCs[core/PersistentVolumeClaims<br/>List storage]
    end

    subgraph "External API Access"
        direction TB

        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS<br/>Read namespace resources<br/>via SA token]

        KFPAPI[Kubeflow Pipelines API<br/>8888/TCP HTTP<br/>Submit pipeline runs<br/>via SA token]
    end

    subgraph "No Cluster Permissions"
        NoCR[❌ No ClusterRole<br/>❌ No ClusterRoleBinding<br/>❌ No cluster-level access<br/>❌ No cross-namespace access]
    end

    subgraph "Security Context"
        direction TB

        PodSecurity["Pod Security:<br/>User: UID 1001 non-root<br/>FSGroup: 0 root group<br/>runAsNonRoot: true<br/>allowPrivilegeEscalation: false"]

        SCC["OpenShift SCC:<br/>restricted default<br/>No privileged mode<br/>No host access<br/>No capabilities"]
    end

    %% RBAC Flow
    SA -->|bound via| RB
    RB -->|grants| ViewRole
    ViewRole -->|get, list, watch| ConfigMaps
    ViewRole -->|get, list, watch| Secrets
    ViewRole -->|get, list, watch| Pods
    ViewRole -->|get, list, watch| Services
    ViewRole -->|get, list, watch| PVCs

    %% API Access
    SA -->|auto-mounted token<br/>authenticates to| K8sAPI
    SA -->|auto-mounted token<br/>authenticates to| KFPAPI

    %% Security Context
    SA -.->|enforces| PodSecurity
    SA -.->|enforces| SCC

    %% No cluster access
    SA -.->|restricted to namespace| NoCR

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RB fill:#f5a623,stroke:#333,stroke-width:2px
    style ViewRole fill:#7ed321,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#dae8fc,stroke:#333
    style Secrets fill:#dae8fc,stroke:#333
    style Pods fill:#dae8fc,stroke:#333
    style Services fill:#dae8fc,stroke:#333
    style PVCs fill:#dae8fc,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style KFPAPI fill:#7ed321,stroke:#333
    style NoCR fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style PodSecurity fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style SCC fill:#d5e8d4,stroke:#82b366,stroke-width:2px
