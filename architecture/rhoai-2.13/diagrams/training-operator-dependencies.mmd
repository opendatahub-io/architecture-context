graph LR
    TrainingOp[Training Operator]

    %% External Dependencies
    TrainingOp -->|orchestration| K8s[Kubernetes 1.25+]
    TrainingOp -.->|optional metrics| Prom[Prometheus]
    TrainingOp -.->|optional gang scheduling| Volcano[Volcano Scheduler]
    TrainingOp -.->|optional gang scheduling| SchedPlugins[Scheduler Plugins]

    %% Kubernetes Resources
    TrainingOp -->|watches/creates| Pods[Pods]
    TrainingOp -->|creates| Services[Services]
    TrainingOp -->|creates| ConfigMaps[ConfigMaps]
    TrainingOp -->|creates| HPA[HorizontalPodAutoscaler]
    TrainingOp -->|creates| PodGroups[PodGroups]

    %% CRDs Managed
    subgraph CRDs["Custom Resource Definitions"]
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob<br/>kubeflow.org/v1]
        MXJob[MXJob<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob<br/>kubeflow.org/v1]
    end

    TrainingOp -->|reconciles| PyTorchJob
    TrainingOp -->|reconciles| TFJob
    TrainingOp -->|reconciles| MPIJob
    TrainingOp -->|reconciles| XGBoostJob
    TrainingOp -->|reconciles| MXJob
    TrainingOp -->|reconciles| PaddleJob

    %% Python SDK
    SDK[Python SDK<br/>kubeflow-training 1.7.0] -->|creates/manages| PyTorchJob
    SDK -->|creates/manages| TFJob
    SDK -->|creates/manages| MPIJob

    %% External Services
    TrainingJobs[Training Job Pods] -->|downloads| Storage[Object Storage<br/>S3/etc]
    TrainingJobs -->|saves| Storage
    TrainingJobs -->|pulled from| Registry[Container Registries]

    %% Monitoring
    Prom -->|scrapes| TrainingOp

    %% Init Containers
    TrainingOp -->|uses| KubectlInit[kubectl-delivery<br/>Init Container]
    TrainingOp -->|uses| PyTorchInit[PyTorch Init Container]

    style TrainingOp fill:#4a90e2,stroke:#333,stroke-width:4px
    style K8s fill:#999,stroke:#333,stroke-width:2px
    style Prom fill:#7ed321,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style SchedPlugins fill:#e8e8e8,stroke:#333
    style SDK fill:#7ed321,stroke:#333
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style MXJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style Storage fill:#f5a623,stroke:#333
    style Registry fill:#f5a623,stroke:#333
    style TrainingJobs fill:#dae8fc,stroke:#333
