graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "Cluster Roles"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "Roles"
        R[leader-election-role<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph "Core API Resources"
        Pods[pods, pods/status<br/>verbs: create, delete,<br/>deletecollection, get,<br/>list, patch, update, watch]
        Services[services, services/status<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        ServiceAccounts[serviceaccounts<br/>verbs: create, delete,<br/>get, list, watch]
        Events[events<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        Endpoints[endpoints<br/>verbs: get, list]
    end

    subgraph "Batch API Resources"
        Jobs[jobs<br/>apiGroup: batch<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    subgraph "Ray API Resources (ray.io)"
        RayClusters[rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        RayJobs[rayjobs<br/>rayjobs/status<br/>rayjobs/finalizers<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        RayServices[rayservices<br/>rayservices/status<br/>rayservices/finalizers<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    subgraph "Networking API Resources"
        Ingresses[ingresses<br/>apiGroups: networking.k8s.io,<br/>extensions<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        IngressClasses[ingressclasses<br/>apiGroup: networking.k8s.io<br/>verbs: get, list, watch]
    end

    subgraph "OpenShift Route API"
        Routes[routes<br/>apiGroup: route.openshift.io<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    subgraph "RBAC API Resources"
        Roles[roles<br/>rolebindings<br/>apiGroup: rbac.authorization.k8s.io<br/>verbs: create, delete, get,<br/>list, update, watch]
    end

    subgraph "Coordination API Resources"
        Leases[leases<br/>apiGroup: coordination.k8s.io<br/>verbs: create, get,<br/>list, update]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Bindings to Roles
    CRB -->|grants| CR
    RB -->|grants| R

    %% ClusterRole Permissions
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Events
    CR -->|permissions| Endpoints
    CR -->|permissions| Jobs
    CR -->|permissions| RayClusters
    CR -->|permissions| RayJobs
    CR -->|permissions| RayServices
    CR -->|permissions| Ingresses
    CR -->|permissions| IngressClasses
    CR -->|permissions| Routes
    CR -->|permissions| Roles
    CR -->|permissions| Leases

    %% Role Permissions (Leader Election)
    R -->|permissions| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#7ed321,stroke:#333,stroke-width:2px
    style RB fill:#7ed321,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style R fill:#f5a623,stroke:#333,stroke-width:2px

    style Pods fill:#d5e8d4,stroke:#82b366
    style Services fill:#d5e8d4,stroke:#82b366
    style ServiceAccounts fill:#d5e8d4,stroke:#82b366
    style Events fill:#d5e8d4,stroke:#82b366
    style Endpoints fill:#d5e8d4,stroke:#82b366

    style Jobs fill:#fff2cc,stroke:#d6b656

    style RayClusters fill:#e1d5e7,stroke:#9673a6
    style RayJobs fill:#e1d5e7,stroke:#9673a6
    style RayServices fill:#e1d5e7,stroke:#9673a6

    style Ingresses fill:#dae8fc,stroke:#6c8ebf
    style IngressClasses fill:#dae8fc,stroke:#6c8ebf

    style Routes fill:#ffe6cc,stroke:#d79b00

    style Roles fill:#f8cecc,stroke:#b85450

    style Leases fill:#fff4e6,stroke:#ff9800
