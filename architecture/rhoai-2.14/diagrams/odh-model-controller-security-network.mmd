graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientists/Apps]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ Edge Termination<br/>Route CRD"]
    end

    subgraph ServiceMeshIngress["SERVICE MESH INGRESS"]
        Gateway["Istio Gateway<br/>networking.istio.io<br/>TLS SIMPLE/PASSTHROUGH"]
        Authorino["Authorino<br/>5001/TCP HTTP<br/>JWT Validation<br/>AuthConfig CRD"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Inference["Namespace: {user-namespace}<br/>ServiceMeshMember enrolled"]
            InferencePod["Inference Service Pod<br/>SA: {isvc-name}-sa<br/>Ports: 8080,8081,8033,8085<br/>mTLS Sidecar (STRICT)<br/>Secrets: storage-config,<br/>kserve-custom-ca-bundle"]
        end

        subgraph NS_Controller["Namespace: redhat-ods-applications"]
            Controller["odh-model-controller<br/>SA: odh-model-controller<br/>Replicas: 1 (leader election)"]
            WebhookSvc["Webhook Service<br/>443→9443/TCP HTTPS<br/>TLS 1.2+<br/>Cert: Service CA"]
            MetricsSvc["Metrics Service<br/>8443→8080/TCP HTTP<br/>Auth: Bearer Token"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>SA: prometheus-k8s<br/>ServiceMonitor/PodMonitor"]
        end
    end

    subgraph ControlPlane["CLUSTER CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Signature v4"]
        ModelRegistry["Model Registry (Optional)<br/>8080/TCP HTTP<br/>No Auth (internal)"]
    end

    %% Flow connections
    Client -->|HTTPS/443<br/>TLS 1.2+ Edge<br/>Bearer Token| Router
    Router -->|HTTP/8080<br/>Internal| Gateway
    Gateway -->|HTTP/5001<br/>Local Sidecar<br/>Auth Validation| Authorino
    Gateway -->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity| InferencePod
    InferencePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Signature v4| S3

    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Controller -.->|creates| WebhookSvc
    Controller -.->|exposes| MetricsSvc
    Controller -.->|exposes| HealthProbes

    K8sAPI -->|Webhook Call<br/>HTTPS/9443<br/>TLS 1.2+| WebhookSvc

    Prometheus -->|HTTP/8080<br/>Bearer Token| MetricsSvc
    Prometheus -->|HTTP/8080<br/>mTLS| InferencePod

    Controller -.->|optional| ModelRegistry

    %% CRD Management (dotted lines for "manages")
    Controller -.->|creates Route| Router
    Controller -.->|creates Gateway| Gateway
    Controller -.->|creates VirtualService| Gateway
    Controller -.->|creates AuthConfig| Authorino
    Controller -.->|creates PeerAuth| InferencePod
    Controller -.->|creates ServiceMonitor| Prometheus
    Controller -.->|creates NetworkPolicy| NS_Inference

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef servicemeshingress fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:3px

    class Client external
    class Router ingress
    class Gateway,Authorino servicemeshingress
    class InferencePod,Controller,WebhookSvc,MetricsSvc,HealthProbes,Prometheus servicemesh
    class K8sAPI controlplane
    class S3,ModelRegistry externalservice

    %% Trust zone borders with notes
    style External fill:#f9f9f9,stroke:#999,stroke-width:4px,stroke-dasharray: 5 5
    style Ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:4px,stroke-dasharray: 5 5
    style ServiceMeshIngress fill:#fff2cc,stroke:#d6b656,stroke-width:4px,stroke-dasharray: 5 5
    style ServiceMesh fill:#d5e8d4,stroke:#82b366,stroke-width:4px
    style ControlPlane fill:#dae8fc,stroke:#6c8ebf,stroke-width:4px,stroke-dasharray: 5 5
    style ExternalServices fill:#fff2cc,stroke:#d6b656,stroke-width:4px,stroke-dasharray: 5 5
