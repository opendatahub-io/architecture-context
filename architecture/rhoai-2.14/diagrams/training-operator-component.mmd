graph TB
    subgraph "Kubeflow Training Operator"
        Manager[Training Operator Manager<br/>Go Binary]

        subgraph "Controllers"
            PyTorchCtrl[PyTorch Controller]
            TFCtrl[TensorFlow Controller]
            MPICtrl[MPI Controller]
            MXNetCtrl[MXNet Controller]
            XGBoostCtrl[XGBoost Controller]
            PaddleCtrl[PaddlePaddle Controller]
        end

        MetricsServer[Metrics Server<br/>:8080/TCP HTTP]
        HealthServer[Health Probe Server<br/>:8081/TCP HTTP]

        Manager --> PyTorchCtrl
        Manager --> TFCtrl
        Manager --> MPICtrl
        Manager --> MXNetCtrl
        Manager --> XGBoostCtrl
        Manager --> PaddleCtrl
        Manager --> MetricsServer
        Manager --> HealthServer
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        MXJob[MXJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Training Worker Pods]
        Services[Headless Services]
        ConfigMaps[Job ConfigMaps]
        PodGroups[PodGroups<br/>Gang Scheduling]
        HPA[HorizontalPodAutoscalers<br/>Elastic Training]
    end

    User[User/Dashboard] -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| MPIJob

    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    MPIJob -->|watched by| MPICtrl
    MXJob -->|watched by| MXNetCtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    PaddleJob -->|watched by| PaddleCtrl

    PyTorchCtrl -->|creates| Pods
    PyTorchCtrl -->|creates| Services
    PyTorchCtrl -->|creates| ConfigMaps
    PyTorchCtrl -->|creates| PodGroups
    PyTorchCtrl -->|creates| HPA

    TFCtrl -->|creates| Pods
    MPICtrl -->|creates| Pods

    Prometheus[Prometheus] -->|scrapes| MetricsServer
    K8sHealthCheck[Kubernetes] -->|probes| HealthServer

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        Volcano[Volcano Scheduler<br/>Optional]
        SchedulerPlugins[scheduler-plugins<br/>Optional]
    end

    Manager -->|watches/manages| K8sAPI
    PodGroups -->|used by| Volcano
    PodGroups -->|used by| SchedulerPlugins

    style Manager fill:#4a90e2
    style PyTorchCtrl fill:#4a90e2
    style TFCtrl fill:#4a90e2
    style MPICtrl fill:#4a90e2
    style MXNetCtrl fill:#4a90e2
    style XGBoostCtrl fill:#4a90e2
    style PaddleCtrl fill:#4a90e2
    style PyTorchJob fill:#f5a623
    style TFJob fill:#f5a623
    style MPIJob fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style Volcano fill:#e8e8e8
    style SchedulerPlugins fill:#e8e8e8
    style Prometheus fill:#7ed321
