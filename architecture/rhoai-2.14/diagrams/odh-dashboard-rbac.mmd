graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: odh-dashboard]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding<br/>Namespace: kube-system]
        CRB3[odh-dashboard-cluster-monitoring<br/>ClusterRoleBinding<br/>Namespace: openshift-monitoring]
    end

    subgraph "RoleBinding"
        RB[odh-dashboard<br/>RoleBinding<br/>Namespace: odh-dashboard]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]
        AuthDelegator[system:auth-delegator<br/>ClusterRole]
        MonitoringView[cluster-monitoring-view<br/>ClusterRole]
    end

    subgraph "Namespace-scoped Role"
        NSRole[odh-dashboard<br/>Role<br/>Namespace: odh-dashboard]
    end

    subgraph "Core API Resources (Cluster-wide)"
        Nodes[nodes<br/>get, list]
        ConfigMaps[configmaps, secrets, pvcs<br/>create, delete, get, list, patch, update, watch]
        Namespaces[namespaces<br/>create, delete, get, list, patch, update, watch]
        Pods[pods, serviceaccounts, services<br/>get, list, watch]
        Events[events<br/>get, list, watch]
    end

    subgraph "OpenShift Resources (Cluster-wide)"
        Routes[routes<br/>route.openshift.io<br/>get, list, watch]
        ClusterVersion[clusterversions<br/>config.openshift.io<br/>get, watch, list]
        ConsoleLinks[consolelinks<br/>console.openshift.io<br/>get, list, watch]
        Users[users, groups<br/>user.openshift.io<br/>get, list, watch]
    end

    subgraph "RBAC Resources (Cluster-wide)"
        RBACResources[rolebindings, clusterrolebindings, roles<br/>rbac.authorization.k8s.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "ODH Custom Resources (Cluster-wide)"
        Notebooks[notebooks<br/>kubeflow.org<br/>create, delete, get, list, patch, update, watch]
        DSC[datascienceclusters<br/>datasciencecluster.opendatahub.io<br/>get, list, watch]
        DSCI[dscinitializations<br/>dscinitialization.opendatahub.io<br/>get, list, watch]
        InferenceServices[inferenceservices<br/>serving.kserve.io<br/>get, list, watch]
        ModelRegistries[modelregistries<br/>modelregistry.opendatahub.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Namespace-scoped Resources (odh-dashboard namespace)"
        AccelProfiles[acceleratorprofiles<br/>dashboard.opendatahub.io<br/>create, delete, get, list, patch, update]
        OdhDashboardConfigs[odhdashboardconfigs<br/>opendatahub.io<br/>create, delete, get, list, patch, update, watch]
        OdhApps[odhapplications, odhdocuments<br/>dashboard.opendatahub.io<br/>get, list]
        Templates[templates<br/>template.openshift.io<br/>all verbs]
        ServingRuntimes[servingruntimes<br/>serving.kserve.io<br/>all verbs]
        Builds[builds, buildconfigs<br/>build.openshift.io<br/>create, delete, get, list, patch, watch]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB

    CRB1 -->|grants| CR
    CRB2 -->|grants| AuthDelegator
    CRB3 -->|grants| MonitoringView
    RB -->|grants cluster role| CR
    RB -->|grants namespace role| NSRole

    %% ClusterRole permissions
    CR -->|get, list| Nodes
    CR -->|CRUD + watch| ConfigMaps
    CR -->|CRUD + watch| Namespaces
    CR -->|read| Pods
    CR -->|read| Events
    CR -->|read| Routes
    CR -->|read| ClusterVersion
    CR -->|read| ConsoleLinks
    CR -->|read| Users
    CR -->|full CRUD| RBACResources
    CR -->|full CRUD| Notebooks
    CR -->|read| DSC
    CR -->|read| DSCI
    CR -->|read| InferenceServices
    CR -->|full CRUD| ModelRegistries

    %% Namespace Role permissions
    NSRole -->|CRUD| AccelProfiles
    NSRole -->|CRUD + watch| OdhDashboardConfigs
    NSRole -->|read| OdhApps
    NSRole -->|all verbs| Templates
    NSRole -->|all verbs| ServingRuntimes
    NSRole -->|CRUD + watch| Builds

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style NSRole fill:#f5a623,stroke:#333,stroke-width:2px
    style AuthDelegator fill:#f5a623,stroke:#333,stroke-width:1px
    style MonitoringView fill:#f5a623,stroke:#333,stroke-width:1px

    style Nodes fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style ClusterVersion fill:#7ed321,stroke:#333
    style ConsoleLinks fill:#7ed321,stroke:#333
    style Users fill:#7ed321,stroke:#333
    style RBACResources fill:#7ed321,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style DSC fill:#7ed321,stroke:#333
    style DSCI fill:#7ed321,stroke:#333
    style InferenceServices fill:#7ed321,stroke:#333
    style ModelRegistries fill:#7ed321,stroke:#333
    style AccelProfiles fill:#7ed321,stroke:#333
    style OdhDashboardConfigs fill:#7ed321,stroke:#333
    style OdhApps fill:#7ed321,stroke:#333
    style Templates fill:#7ed321,stroke:#333
    style ServingRuntimes fill:#7ed321,stroke:#333
    style Builds fill:#7ed321,stroke:#333
