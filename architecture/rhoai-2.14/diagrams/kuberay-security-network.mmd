graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>User/Application]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route / K8s Ingress<br/>443/TCP → 8265/8000/TCP<br/>TLS 1.2+ → HTTP<br/>Optional"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Internal)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            direction TB
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>runAsNonRoot, seccomp: runtime/default"]
            APIServer["KubeRay API Server (Optional)<br/>HTTP: 8888/TCP<br/>gRPC: 8887/TCP<br/>Auth: None (default)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            HeadPod["Ray Head Pod<br/>SA: {cluster}-head-sa<br/>GCS: 6379/TCP (Ray Protocol)<br/>Dashboard: 8265/TCP HTTP<br/>Client: 10001/TCP (Ray Protocol)<br/>Serve: 8000/TCP HTTP<br/>runAsUser: 1000, Drop ALL caps"]
            WorkerPods["Ray Worker Pods<br/>0 to maxReplicas (autoscaling)<br/>Connect to GCS: 6379/TCP<br/>runAsUser: 1000, Drop ALL caps"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth<br/>RBAC Enforced"]

        Prometheus["Prometheus (Optional)<br/>Scrapes: HTTP"]
    end

    subgraph Egress["EGRESS (Outbound)"]
        direction TB
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret Auth"]
        Redis["External Redis (Optional)<br/>6379/TCP<br/>Redis/TLS<br/>Password Auth<br/>GCS Fault Tolerance"]
        S3["S3/Cloud Storage (Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Cloud IAM Auth"]
        Git["Git Repositories (Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Custom Auth| Route
    Route -->|HTTP/8265, 8000<br/>No Encryption<br/>No Auth| HeadPod

    %% Kubernetes API flows
    Client -->|HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig| K8sAPI
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    APIServer -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Internal Ray cluster flows
    Operator -->|Creates & Manages| HeadPod
    Operator -->|Creates & Manages| WorkerPods
    WorkerPods -->|Ray Protocol/6379<br/>No Encryption<br/>No Auth| HeadPod

    %% Monitoring flows
    Prometheus -->|HTTP/8080<br/>No Auth| Operator
    Prometheus -->|HTTP/8265<br/>No Auth| HeadPod

    %% Egress flows
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry
    HeadPod -.->|Redis/6379<br/>Optional TLS<br/>Password| Redis
    HeadPod -.->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| S3
    HeadPod -.->|HTTPS/443<br/>TLS 1.2+| Git

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class Operator,APIServer,HeadPod,WorkerPods,K8sAPI,Prometheus internal
    class Registry,Redis,S3,Git egress
