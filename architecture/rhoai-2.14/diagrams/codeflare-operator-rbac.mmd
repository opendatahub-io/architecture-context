graph TD
    subgraph "Service Accounts"
        SA_Operator["codeflare-operator-controller-manager<br/>Namespace: operator-namespace"]
        SA_OAuth["raycluster-oauth-proxy<br/>Namespace: user-namespace<br/>Per RayCluster"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["codeflare-operator-manager-rolebinding<br/>Cluster-wide"]
        CRB_OAuth["raycluster-oauth-crb<br/>Cluster-wide<br/>Per RayCluster"]
    end

    subgraph "ClusterRole: codeflare-operator-manager-role"
        direction TB
        CR_Manager["codeflare-operator-manager-role"]

        subgraph "Core Resources"
            CorePerms["API Group: core<br/>──────────────────<br/>• pods, services, secrets<br/>• serviceaccounts, events<br/>Verbs: get, list, watch,<br/>create, update, patch, delete<br/><br/>• nodes<br/>Verbs: get, list, watch"]
        end

        subgraph "App Resources"
            AppPerms["API Group: apps<br/>──────────────────<br/>• deployments<br/>• statefulsets<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Batch Resources"
            BatchPerms["API Group: batch<br/>──────────────────<br/>• jobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Ray Resources"
            RayPerms["API Group: ray.io<br/>──────────────────<br/>• rayclusters<br/>• rayclusters/status<br/>• rayclusters/finalizers<br/>• rayjobs<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "CodeFlare Resources"
            CFPerms["API Group: workload.codeflare.dev<br/>──────────────────<br/>• appwrappers<br/>• appwrappers/status<br/>• appwrappers/finalizers<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Kueue Resources"
            KueuePerms["API Group: kueue.x-k8s.io<br/>──────────────────<br/>• workloads, workloads/status<br/>• workloads/finalizers<br/>Verbs: get, list, watch,<br/>create, update, patch, delete<br/><br/>• clusterqueues, resourceflavors<br/>• workloadpriorityclasses<br/>Verbs: get, list, watch,<br/>update, patch"]
        end

        subgraph "Network Resources"
            NetPerms["API Group: networking.k8s.io<br/>──────────────────<br/>• ingresses<br/>• networkpolicies<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "RBAC Resources"
            RBACPerms["API Group: rbac.authorization.k8s.io<br/>──────────────────<br/>• clusterrolebindings<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Route Resources"
            RoutePerms["API Group: route.openshift.io<br/>──────────────────<br/>• routes<br/>• routes/custom-host<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph "Webhook Resources"
            WebhookPerms["API Group: admissionregistration<br/>──────────────────<br/>• mutatingwebhookconfigurations<br/>• validatingwebhookconfigurations<br/>Verbs: get, list, watch, update"]
        end

        subgraph "Other Resources"
            OtherPerms["Multiple API Groups<br/>──────────────────<br/>• customresourcedefinitions get, list, watch<br/>• config.openshift.io/ingresses get<br/>• dscinitializations get, list, watch<br/>• pytorchjobs full CRUD<br/>• priorityclasses get, list, watch<br/>• podgroups full CRUD<br/>• tokenreviews, subjectaccessreviews create"]
        end

        CR_Manager --> CorePerms
        CR_Manager --> AppPerms
        CR_Manager --> BatchPerms
        CR_Manager --> RayPerms
        CR_Manager --> CFPerms
        CR_Manager --> KueuePerms
        CR_Manager --> NetPerms
        CR_Manager --> RBACPerms
        CR_Manager --> RoutePerms
        CR_Manager --> WebhookPerms
        CR_Manager --> OtherPerms
    end

    subgraph "ClusterRole: system:auth-delegator Built-in"
        CR_AuthDelegator["system:auth-delegator<br/>──────────────────<br/>Allows OAuth proxy to delegate<br/>authentication to OpenShift OAuth"]
    end

    subgraph "API Resources Accessed"
        direction LR

        API_RayCluster["RayCluster<br/>ray.io/v1"]
        API_AppWrapper["AppWrapper<br/>workload.codeflare.dev/v1beta2"]
        API_Workload["Workload<br/>kueue.x-k8s.io/v1beta1"]
        API_NetworkPolicy["NetworkPolicy<br/>networking.k8s.io/v1"]
        API_Route["Route<br/>route.openshift.io/v1"]
        API_Secret["Secret<br/>core/v1"]
        API_ServiceAccount["ServiceAccount<br/>core/v1"]
        API_Pod["Pod<br/>core/v1"]
        API_Service["Service<br/>core/v1"]
    end

    %% Service Account bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_OAuth -->|bound via| CRB_OAuth

    %% ClusterRoleBindings to ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_OAuth -->|grants| CR_AuthDelegator

    %% ClusterRole to API Resources
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_RayCluster
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_AppWrapper
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Workload
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_NetworkPolicy
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Route
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Secret
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_ServiceAccount
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Pod
    CR_Manager -->|get, list, watch,<br/>create, update,<br/>patch, delete| API_Service

    %% OAuth delegation
    CR_AuthDelegator -.->|delegates<br/>authentication to| OAuthServer["OpenShift OAuth Server"]

