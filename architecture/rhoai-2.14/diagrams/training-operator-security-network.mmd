graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[User / ODH Dashboard]
    end

    subgraph ControlPlane["KUBERNETES API SERVER (Control Plane)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>RBAC Auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["Training Operator Manager<br/>SA: kubeflow-training-operator<br/>Non-root (UID 65532)<br/>FIPS Mode Enabled<br/>Istio: Disabled"]

        subgraph Monitoring["Internal Services"]
            MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth (ClusterIP)"]
            HealthEndpoint["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        Operator --> MetricsEndpoint
        Operator --> HealthEndpoint
    end

    subgraph TrainingNS["TRAINING JOB NAMESPACE ({user-namespace})"]
        direction TB

        subgraph TrainingPods["Training Pods"]
            Master["PyTorch Master Pod<br/>SA: {job-name}-sa<br/>Image: {user-training-image}<br/>Port: 23456/TCP"]
            Worker1["PyTorch Worker Pod 1<br/>SA: {job-name}-sa<br/>Port: 23456/TCP"]
            Worker2["PyTorch Worker Pod 2<br/>SA: {job-name}-sa<br/>Port: 23456/TCP"]
        end

        HeadlessService["Headless Service<br/>ClusterIP: None<br/>DNS-based pod discovery"]

        HeadlessService -.->|selects| TrainingPods
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secrets"]
        Volcano["Volcano Scheduler<br/>(Optional)<br/>443/TCP HTTPS<br/>Gang Scheduling"]
    end

    subgraph MonitoringExternal["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor"]
        Kubelet["Kubernetes Kubelet<br/>Health Checks"]
    end

    %% User to API
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User Token"| K8sAPI

    %% API to Operator (Watch)
    K8sAPI -->|"Watch API<br/>HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"| Operator

    %% Operator to API (Manage Resources)
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create Pods/Services/ConfigMaps"| K8sAPI

    %% Operator creates Training Pods
    Operator -.->|creates| Master
    Operator -.->|creates| Worker1
    Operator -.->|creates| Worker2
    Operator -.->|creates| HeadlessService

    %% Training Pod Communication (Plaintext)
    Master <-->|"TCP/23456<br/>Plaintext<br/>torch.distributed"| Worker1
    Master <-->|"TCP/23456<br/>Plaintext<br/>torch.distributed"| Worker2
    Worker1 <-->|"TCP/23456<br/>Plaintext<br/>All-Reduce"| Worker2

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>GET /metrics<br/>No Auth"| MetricsEndpoint
    Kubelet -->|"HTTP/8081<br/>GET /healthz, /readyz<br/>No Auth"| HealthEndpoint

    %% External Services
    Master -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets"| Registry
    Worker1 -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets"| Registry
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets"| Registry

    Operator -.->|"creates PodGroups"| K8sAPI
    Volcano -->|"reads PodGroups<br/>HTTPS/443<br/>ServiceAccount Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef training fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,MetricsEndpoint,HealthEndpoint operator
    class Master,Worker1,Worker2,HeadlessService training
    class Registry,Volcano externalservice
    class Prometheus,Kubelet monitoring
