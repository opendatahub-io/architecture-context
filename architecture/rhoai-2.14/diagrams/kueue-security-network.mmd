graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[User/Data Scientist]
        PromOp[Prometheus Operator]
    end

    subgraph K8sAPI["KUBERNETES API SERVER (Trust Anchor)"]
        API["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>RBAC Enforcement"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (kueue-system)"]
        direction TB

        subgraph Controller["kueue-controller-manager"]
            ControllerPod["Controller Pod<br/>SA: controller-manager<br/>RBAC: manager-role"]
        end

        subgraph Webhook["webhook-server"]
            WebhookPod["Webhook Server<br/>SA: controller-manager<br/>Service: webhook-service<br/>443/TCP → 9443/TCP<br/>TLS 1.2+"]
        end

        subgraph Visibility["visibility-server"]
            VisibilityPod["Visibility API Server<br/>SA: visibility-server<br/>Service: visibility-server<br/>443/TCP → 8082/TCP<br/>TLS 1.2+"]
        end

        Services["Services:<br/>• controller-manager-metrics: 8443/TCP HTTPS<br/>• metrics-service: 8080/TCP HTTP<br/>• webhook-service: 443→9443/TCP HTTPS<br/>• visibility-server: 443→8082/TCP HTTPS"]
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACES (User Namespaces)"]
        LocalQueue["LocalQueue CR<br/>Maps to ClusterQueue"]
        Jobs["Jobs/PyTorchJobs/AppWrappers<br/>Initially suspended<br/>Admitted by Kueue"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Autoscaler["Cluster Autoscaler<br/>Watches ProvisioningRequest<br/>6443/TCP HTTPS TLS1.2+"]
        CertMgr["cert-manager (optional)<br/>Provisions TLS certs<br/>Auto-rotation"]
    end

    %% User flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| API
    PromOp -->|HTTP/8080<br/>Plaintext| ControllerPod

    %% API Server to Kueue components
    API -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s mTLS| WebhookPod
    API -->|HTTPS/8082<br/>TLS 1.2+<br/>K8s mTLS| VisibilityPod

    %% Controller to API Server
    ControllerPod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| API

    %% Webhook and Visibility to API
    WebhookPod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| API
    VisibilityPod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| API

    %% User namespace interactions
    User -->|Submit jobs| API
    API -->|Webhook mutation| WebhookPod
    ControllerPod -->|Manage| LocalQueue
    ControllerPod -->|Admit/Suspend| Jobs

    %% External services
    ControllerPod -->|Create ProvisioningRequest<br/>HTTPS/6443 TLS1.2+| API
    Autoscaler -->|Watch ProvisioningRequest<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount Token| API
    CertMgr -->|Provision certs| WebhookPod
    CertMgr -->|Provision certs| VisibilityPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workloadns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,PromOp external
    class API k8sapi
    class ControllerPod,WebhookPod,VisibilityPod,Services kueuens
    class LocalQueue,Jobs workloadns
    class Autoscaler,CertMgr externalservice
