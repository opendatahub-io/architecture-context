graph LR
    TrainingOp[Kubeflow Training Operator]

    %% External Dependencies (Required)
    TrainingOp -->|"runtime platform<br/>watches CRDs, manages pods"| K8s[Kubernetes 1.25+]
    TrainingOp -->|"controller framework<br/>v0.17.2"| ControllerRuntime[controller-runtime]

    %% External Dependencies (Optional)
    TrainingOp -.->|"gang scheduling<br/>(optional)"| Volcano[Volcano Scheduler v1.8.0]
    TrainingOp -.->|"gang scheduling<br/>alternative"| SchedulerPlugins[scheduler-plugins v0.26.7]
    TrainingOp -.->|"metrics collection<br/>(optional)"| PrometheusOp[Prometheus Operator]

    %% Internal ODH Dependencies
    TrainingOp -->|"integrates with"| Dashboard[ODH Dashboard]
    TrainingOp -->|"metrics collection"| Monitoring[ODH Monitoring]

    %% Integration Points
    Dashboard -->|"creates training jobs"| TrainingOp
    Monitoring -->|"scrapes metrics"| TrainingOp

    %% External Services
    TrainingOp -->|"API calls<br/>HTTPS 443/TCP"| K8sAPI[Kubernetes API Server]
    TrainingOp -->|"image pull<br/>HTTPS 443/TCP"| Registry[Container Registry]

    %% Created Resources
    TrainingOp -.->|creates| Pods[Training Worker Pods]
    TrainingOp -.->|creates| Services[Headless Services]
    TrainingOp -.->|creates| ConfigMaps[Job ConfigMaps]
    TrainingOp -.->|creates| PodGroups[PodGroups<br/>Gang Scheduling]
    TrainingOp -.->|creates| HPA[HorizontalPodAutoscalers<br/>Elastic Training]

