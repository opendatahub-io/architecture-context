graph TD
    subgraph Operator_RBAC["Operator Service Accounts & Roles"]
        SA_Controller["ServiceAccount:<br/>controller-manager<br/>Namespace: opendatahub/redhat-ods-applications"]

        CRB_Manager["ClusterRoleBinding:<br/>role-binding"]
        CRB_Argo["ClusterRoleBinding:<br/>argo-role-binding"]

        CR_Manager["ClusterRole:<br/>manager-role"]
        CR_Argo["ClusterRole:<br/>manager-argo-role"]
    end

    subgraph DSPA_RBAC["DSPA Instance Service Accounts & Roles (per namespace)"]
        SA_API["ServiceAccount:<br/>ds-pipeline-NAME"]
        SA_Runner["ServiceAccount:<br/>pipeline-runner-NAME"]
        SA_PA["ServiceAccount:<br/>ds-pipeline-persistenceagent-NAME"]
        SA_SWF["ServiceAccount:<br/>ds-pipeline-scheduledworkflow-NAME"]

        RB_API["RoleBinding:<br/>ds-pipeline-NAME"]
        RB_Runner["RoleBinding:<br/>pipeline-runner-NAME"]
        RB_PA["RoleBinding:<br/>ds-pipeline-persistenceagent-NAME"]
        RB_SWF["RoleBinding:<br/>ds-pipeline-scheduledworkflow-NAME"]

        R_API["Role:<br/>ds-pipeline-NAME"]
        R_Runner["Role:<br/>pipeline-runner-NAME"]
        R_PA["Role:<br/>ds-pipeline-persistenceagent-NAME"]
        R_SWF["Role:<br/>ds-pipeline-scheduledworkflow-NAME"]
    end

    subgraph Manager_Permissions["ClusterRole: manager-role Permissions"]
        PERM_DSPA[datasciencepipelinesapplications.opendatahub.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_Deployments[apps: deployments, replicasets<br/>Verbs: * all]
        PERM_Core[Core: configmaps, secrets, services, serviceaccounts, pvcs<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_Pods[Core: pods, pods/exec, pods/log<br/>Verbs: * all]
        PERM_Argo[argoproj.io: workflows<br/>Verbs: * all]
        PERM_Tekton[tekton.dev: *<br/>Verbs: * all]
        PERM_Routes[route.openshift.io: routes<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_NP[networking.k8s.io: networkpolicies<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_RBAC[rbac.authorization.k8s.io: roles, rolebindings<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_Monitor[monitoring.coreos.com: servicemonitors<br/>Verbs: create, delete, get, list, patch, update, watch]
        PERM_KF[kubeflow.org: *<br/>Verbs: * all]
        PERM_Ray[ray.io: rayclusters, rayjobs, rayservices<br/>Verbs: create, delete, get, list, patch]
        PERM_AppWrapper[workload.codeflare.dev: appwrappers<br/>Verbs: create, delete, deletecollection, get, list, patch, update, watch]
    end

    subgraph Argo_Permissions["ClusterRole: manager-argo-role Permissions"]
        ARGO_WF[argoproj.io: workflows, workflowtasksets, cronworkflows<br/>Verbs: get, list, watch, update, patch, delete, create]
        ARGO_Pods[Core: pods, pods/exec<br/>Verbs: create, get, list, watch, update, patch, delete]
        ARGO_PVC[Core: persistentvolumeclaims, persistentvolumeclaims/finalizers<br/>Verbs: create, update, delete, get]
        ARGO_Lease[coordination.k8s.io: leases<br/>Verbs: create, get, update]
    end

    subgraph API_Permissions["Role: ds-pipeline-{name} Permissions"]
        API_PERM[Namespace-scoped permissions for:<br/>- Workflow management<br/>- Service operations<br/>- ConfigMap/Secret access]
    end

    subgraph Runner_Permissions["Role: pipeline-runner-{name} Permissions"]
        RUNNER_PERM[Namespace-scoped permissions for:<br/>- Pod creation/management<br/>- Secret list/get for parameters<br/>- PVC access<br/>- Workflow execution]
    end

    subgraph PA_Permissions["Role: ds-pipeline-persistenceagent-{name} Permissions"]
        PA_PERM[Namespace-scoped permissions for:<br/>- Workflow watch<br/>- API server updates]
    end

    subgraph SWF_Permissions["Role: ds-pipeline-scheduledworkflow-{name} Permissions"]
        SWF_PERM[Namespace-scoped permissions for:<br/>- Workflow creation on schedule<br/>- CronWorkflow management]
    end

    %% Operator RBAC Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Argo
    CRB_Manager -->|grants| CR_Manager
    CRB_Argo -->|grants| CR_Argo

    CR_Manager -.->|permissions| PERM_DSPA
    CR_Manager -.->|permissions| PERM_Deployments
    CR_Manager -.->|permissions| PERM_Core
    CR_Manager -.->|permissions| PERM_Pods
    CR_Manager -.->|permissions| PERM_Argo
    CR_Manager -.->|permissions| PERM_Tekton
    CR_Manager -.->|permissions| PERM_Routes
    CR_Manager -.->|permissions| PERM_NP
    CR_Manager -.->|permissions| PERM_RBAC
    CR_Manager -.->|permissions| PERM_Monitor
    CR_Manager -.->|permissions| PERM_KF
    CR_Manager -.->|permissions| PERM_Ray
    CR_Manager -.->|permissions| PERM_AppWrapper

    CR_Argo -.->|permissions| ARGO_WF
    CR_Argo -.->|permissions| ARGO_Pods
    CR_Argo -.->|permissions| ARGO_PVC
    CR_Argo -.->|permissions| ARGO_Lease

    %% DSPA Instance RBAC Bindings
    SA_API -->|bound via| RB_API
    SA_Runner -->|bound via| RB_Runner
    SA_PA -->|bound via| RB_PA
    SA_SWF -->|bound via| RB_SWF

    RB_API -->|grants| R_API
    RB_Runner -->|grants| R_Runner
    RB_PA -->|grants| R_PA
    RB_SWF -->|grants| R_SWF

    R_API -.->|permissions| API_PERM
    R_Runner -.->|permissions| RUNNER_PERM
    R_PA -.->|permissions| PA_PERM
    R_SWF -.->|permissions| SWF_PERM

