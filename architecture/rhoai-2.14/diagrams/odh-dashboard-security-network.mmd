graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>Route: odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph Pod["ODH Dashboard Pod (Namespace: odh-dashboard)"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            OAuthProxy["oauth-proxy container<br/>Port: 8443/TCP HTTPS<br/>TLS cert: dashboard-proxy-tls<br/>OAuth: dashboard-oauth-client-generated<br/>Cookie: dashboard-oauth-config-generated<br/>Skip Auth: ^/metrics"]
        end

        subgraph AppLayer["Application Layer"]
            Backend["odh-dashboard container<br/>Port: 8080/TCP HTTP<br/>Fastify + React SPA<br/>SA: odh-dashboard<br/>Image: ubi8/nodejs-18"]
        end

        OAuthProxy -->|"HTTP/8080<br/>pod-local<br/>Bearer token header"| Backend
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>RBAC: ClusterRole/odh-dashboard"]

        subgraph CRDs["Custom Resources"]
            OdhApp[OdhApplication]
            OdhConfig[OdhDashboardConfig]
            Notebook[Notebook]
            InferenceService[InferenceService]
            ModelRegistry[ModelRegistry]
        end
    end

    subgraph ExternalAuth["AUTHENTICATION"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS1.2+<br/>Client Secret Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Prometheus["Thanos Querier<br/>9092/TCP HTTP<br/>SA token auth"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS TLS1.2+<br/>SA token auth"]
    end

    %% User flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth cookie"| Router
    Router -->|"HTTPS/8443<br/>TLS 1.2+ service cert"| OAuthProxy

    %% OAuth flow
    OAuthProxy <-->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth validation"| OSAuth

    %% Backend to K8s API
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% K8s API manages CRDs
    K8sAPI -->|manages| OdhApp
    K8sAPI -->|manages| OdhConfig
    K8sAPI -->|manages| Notebook
    K8sAPI -->|manages| InferenceService
    K8sAPI -->|manages| ModelRegistry

    %% Backend to external services
    Backend -->|"HTTP/9092<br/>SA token<br/>metrics queries"| Prometheus
    Backend -->|"HTTPS/5000<br/>TLS 1.2+<br/>SA token<br/>image metadata"| ImageRegistry

    %% Prometheus scraping
    Prometheus -.->|"HTTPS/443<br/>GET /metrics<br/>no auth (skip-auth-regex)"| Router
    Router -.->|"HTTPS/8443"| OAuthProxy
    OAuthProxy -.->|"HTTP/8080<br/>no auth"| Backend

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef app fill:#cce5ff,stroke:#4a90e2,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crd fill:#f5a623,stroke:#333,stroke-width:1px

    class Client external
    class Router ingress
    class OAuthProxy auth
    class Backend app
    class K8sAPI controlplane
    class OSAuth auth
    class Prometheus,ImageRegistry externalservice
    class OdhApp,OdhConfig,Notebook,InferenceService,ModelRegistry crd
