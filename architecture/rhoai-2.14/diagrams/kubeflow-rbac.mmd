graph TD
    subgraph "Service Accounts"
        SA_Manager["ServiceAccount: manager<br/>Namespace: odh-notebook-controller"]
        SA_Notebook["ServiceAccount: {notebook-name}<br/>Namespace: {user-namespace}<br/>Annotation: oauth-redirectreference"]
    end

    subgraph "Cluster-Scoped Bindings"
        CRB_Manager["ClusterRoleBinding:<br/>manager-rolebinding"]
        CRB_Admin["ClusterRole: notebooks-admin<br/>(Aggregates notebooks-edit)"]
        CRB_Edit["ClusterRole: notebooks-edit"]
        CRB_View["ClusterRole: notebooks-view"]
    end

    subgraph "Namespace-Scoped Bindings"
        RB_Leader["RoleBinding:<br/>leader-election-rolebinding<br/>Namespace: odh-notebook-controller"]
    end

    subgraph "Cluster Roles"
        CR_Manager["ClusterRole: manager-role<br/>(Controller permissions)"]
        R_Leader["Role: leader-election-role<br/>Namespace: odh-notebook-controller"]
    end

    subgraph "API Resources - Notebooks"
        direction TB
        Notebook_CR["kubeflow.org/v1<br/>Notebook CR"]
        Notebook_Status["kubeflow.org/v1<br/>Notebook/status"]
        Notebook_Finalizers["kubeflow.org/v1<br/>Notebook/finalizers"]
    end

    subgraph "API Resources - OpenShift"
        direction TB
        Routes["route.openshift.io/v1<br/>Routes"]
        Proxies["config.openshift.io/v1<br/>Proxies"]
    end

    subgraph "API Resources - Core"
        direction TB
        Services["core/v1<br/>Services"]
        ServiceAccounts["core/v1<br/>ServiceAccounts"]
        Secrets["core/v1<br/>Secrets"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
        Events["core/v1<br/>Events"]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies["networking.k8s.io/v1<br/>NetworkPolicies"]
    end

    subgraph "API Resources - Coordination"
        Leases["coordination.k8s.io/v1<br/>Leases"]
    end

    %% Service Account to Bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_Manager -->|"bound via"| RB_Leader

    %% Bindings to Roles
    CRB_Manager -->|"grants"| CR_Manager
    RB_Leader -->|"grants"| R_Leader

    %% Manager Role Permissions (Controller)
    CR_Manager -->|"get, list, watch, patch"| Notebook_CR
    CR_Manager -->|"get"| Notebook_Status
    CR_Manager -->|"update"| Notebook_Finalizers
    CR_Manager -->|"get, list, watch, create, update, patch"| Routes
    CR_Manager -->|"get, list, watch"| Proxies
    CR_Manager -->|"get, list, watch, create, update, patch"| Services
    CR_Manager -->|"get, list, watch, create, update, patch"| ServiceAccounts
    CR_Manager -->|"get, list, watch, create, update, patch"| Secrets
    CR_Manager -->|"get, list, watch, create, update, patch"| ConfigMaps
    CR_Manager -->|"get, list, watch, create, update, patch"| NetworkPolicies

    %% Leader Election Role Permissions
    R_Leader -->|"get, list, watch, create, update, patch, delete"| ConfigMaps
    R_Leader -->|"get, list, watch, create, update, patch, delete"| Leases
    R_Leader -->|"create, patch"| Events

    %% User-facing Roles (aggregated to admin/edit/view)
    CRB_Edit -->|"get, list, watch, create, delete, deletecollection, patch, update"| Notebook_CR
    CRB_Edit -->|"get, list, watch, create, delete, deletecollection, patch, update"| Notebook_Status

    CRB_View -->|"get, list, watch"| Notebook_CR
    CRB_View -->|"get, list, watch"| Notebook_Status

    CRB_Admin -->|"aggregates"| CRB_Edit

    %% Notebook ServiceAccount (OAuth)
    SA_Notebook -.->|"used by OAuth Proxy<br/>for SAR checks"| K8sAPI["Kubernetes API Server<br/>SubjectAccessReview"]

    %% Styling
    classDef serviceAccount fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clusterRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef binding fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef resource fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef api fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class SA_Manager,SA_Notebook serviceAccount
    class CR_Manager,CRB_Admin,CRB_Edit,CRB_View clusterRole
    class R_Leader role
    class CRB_Manager,RB_Leader binding
    class Notebook_CR,Notebook_Status,Notebook_Finalizers,Routes,Proxies,Services,ServiceAccounts,Secrets,ConfigMaps,NetworkPolicies,Leases,Events resource
    class K8sAPI api
