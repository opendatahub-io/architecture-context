graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>Controller Namespace]
        SA_Serving[modelmesh-serving-sa<br/>User Namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB_LeaderElection[modelmesh-leader-election-rolebinding<br/>RoleBinding - Controller NS]
        CRB_SCC[modelmesh-serving-sa-restricted-scc<br/>RoleBinding - Runtime NS]
    end

    subgraph "ClusterRole Permissions"
        CR_Controller[modelmesh-controller-role<br/>ClusterRole]
        CR_LeaderElection[modelmesh-leader-election-role<br/>Role]
        CR_SCC[modelmesh-restricted-scc-role<br/>Role]
    end

    subgraph "API Resources - Core"
        ConfigMaps["core/ConfigMaps<br/>create, delete, get, list,<br/>patch, update, watch"]
        Secrets["core/Secrets<br/>create, delete, get, list,<br/>patch, update, watch"]
        Services["core/Services<br/>Services/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        Namespaces["core/Namespaces<br/>Namespaces/finalizers<br/>get, list, patch, update, watch"]
        Endpoints["core/Endpoints<br/>get, list, watch"]
        PVCs["core/PersistentVolumeClaims<br/>get, list, watch"]
    end

    subgraph "API Resources - Apps"
        Deployments["apps/Deployments<br/>Deployments/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - serving.kserve.io"
        Predictors["serving.kserve.io/Predictors<br/>Predictors/status<br/>Predictors/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        ServingRuntimes["serving.kserve.io/ServingRuntimes<br/>ServingRuntimes/status<br/>ServingRuntimes/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        ClusterServingRuntimes["serving.kserve.io/ClusterServingRuntimes<br/>ClusterServingRuntimes/status<br/>ClusterServingRuntimes/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
        InferenceServices["serving.kserve.io/InferenceServices<br/>InferenceServices/status<br/>InferenceServices/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors["monitoring.coreos.com/ServiceMonitors<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Autoscaling"
        HPAs["autoscaling/HorizontalPodAutoscalers<br/>HorizontalPodAutoscalers/status<br/>create, delete, get, list,<br/>watch, update"]
    end

    subgraph "Leader Election Resources"
        LeaderConfigMaps["core/ConfigMaps<br/>get, list, watch,<br/>create, update, patch, delete"]
        Leases["coordination.k8s.io/Leases<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Serving -->|bound via| CRB_SCC

    %% Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_SCC -->|grants| CR_SCC

    %% Controller Role Permissions - Core
    CR_Controller -->|permissions| ConfigMaps
    CR_Controller -->|permissions| Secrets
    CR_Controller -->|permissions| Services
    CR_Controller -->|permissions| Namespaces
    CR_Controller -->|permissions| Endpoints
    CR_Controller -->|permissions| PVCs

    %% Controller Role Permissions - Apps
    CR_Controller -->|permissions| Deployments

    %% Controller Role Permissions - serving.kserve.io
    CR_Controller -->|permissions| Predictors
    CR_Controller -->|permissions| ServingRuntimes
    CR_Controller -->|permissions| ClusterServingRuntimes
    CR_Controller -->|permissions| InferenceServices

    %% Controller Role Permissions - Monitoring
    CR_Controller -->|permissions| ServiceMonitors

    %% Controller Role Permissions - Autoscaling
    CR_Controller -->|permissions| HPAs

    %% Leader Election Role Permissions
    CR_LeaderElection -->|permissions| LeaderConfigMaps
    CR_LeaderElection -->|permissions| Leases

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f39c12,stroke:#333,stroke-width:2px
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#7ed321,stroke:#333,stroke-width:2px
    classDef leaderresource fill:#3498db,stroke:#333,stroke-width:2px

    class SA_Controller,SA_Serving serviceaccount
    class CRB_Controller,CRB_LeaderElection,CRB_SCC binding
    class CR_Controller,CR_LeaderElection,CR_SCC role
    class ConfigMaps,Secrets,Services,Namespaces,Endpoints,PVCs,Deployments,Predictors,ServingRuntimes,ClusterServingRuntimes,InferenceServices,ServiceMonitors,HPAs resource
    class LeaderConfigMaps,Leases leaderresource
