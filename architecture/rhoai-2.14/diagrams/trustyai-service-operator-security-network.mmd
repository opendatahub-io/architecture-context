graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External User/Client]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Re-encrypt Termination"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        OAuth["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>SA: instance-name-sa"]
    end

    subgraph AppLayer["APPLICATION LAYER - Trusted"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            TrustyAI["TrustyAI Service Pod<br/>SA: instance-name-sa<br/>Image: quay.io/trustyai/trustyai-service"]

            subgraph Services["Internal Services"]
                InternalSvc["Service: instance-name<br/>80/TCP to 8080 HTTP<br/>443/TCP to 4443 HTTPS mTLS"]
                TLSSvc["Service: instance-name-tls<br/>443/TCP to 8443 HTTPS OAuth"]
            end

            PVC["PersistentVolumeClaim<br/>instance-name<br/>ReadWriteOnce"]
        end

        OAuth -.->|sidecar| TrustyAI
        TrustyAI -->|exposed by| InternalSvc
        OAuth -->|exposed by| TLSSvc
        TrustyAI -->|mounts| PVC
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>80/TCP HTTP<br/>Bearer Token Auth<br/>/q/metrics"]
        OpMetrics["Operator Metrics Service<br/>8443/TCP HTTPS<br/>TLS + Bearer Token"]
    end

    subgraph Integration["INTEGRATION POINTS"]
        direction TB

        subgraph NS_Operator["Namespace: operator-namespace"]
            Operator["TrustyAI Operator Controller<br/>SA: controller-manager"]
        end

        ModelMesh["ModelMesh Pods<br/>Env: MM_PAYLOAD_PROCESSORS"]
        KServe["KServe InferenceServices"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database["External Database<br/>Varies/TCP JDBC<br/>TLS 1.2+ optional<br/>Username/Password Auth"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    %% External User Flow
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Unauthenticated| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+ Re-encrypted<br/>OAuth Cookie/Bearer| OAuth
    OAuth -->|HTTP/8080<br/>Plaintext localhost<br/>Trusted Sidecar| TrustyAI

    %% Monitoring Flows
    Prometheus -->|HTTP/80<br/>Bearer Token<br/>GET /q/metrics| InternalSvc
    Prometheus -->|HTTPS/8443<br/>Bearer Token| OpMetrics

    %% Operator Flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Operator -->|Watches/Patches| KServe
    Operator -->|Patches Env Vars| ModelMesh

    %% Integration Flows
    ModelMesh -->|HTTP/80<br/>Inference Payloads<br/>No Auth| InternalSvc

    %% Database Flow
    TrustyAI -->|JDBC/Varies<br/>TLS 1.2+ optional<br/>Username/Password| Database

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff4e6,stroke:#f59e0b,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class OAuth auth
    class TrustyAI,InternalSvc,TLSSvc,PVC app
    class Prometheus,OpMetrics monitoring
    class Operator,ModelMesh,KServe integration
    class Database,K8sAPI externalservice
