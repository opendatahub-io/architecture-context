graph TD
    subgraph "Service Accounts"
        SA_Controller[odh-model-controller<br/>Namespace: redhat-ods-applications]
        SA_Prometheus[prometheus-k8s<br/>Namespace: openshift-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[odh-model-controller-role-binding]
        RB_LeaderElection[odh-model-controller-leader-election-role-binding<br/>RoleBinding]
        RB_Prometheus[kserve-prometheus-k8s-rolebinding<br/>RoleBinding per namespace]
    end

    subgraph "ClusterRoles"
        CR_Controller[odh-model-controller-role]
        CR_Prometheus[kserve-prometheus-k8s]
        R_LeaderElection[odh-model-controller-leader-election-role<br/>Role]
    end

    subgraph "API Resources - KServe"
        InferenceService[InferenceService<br/>serving.kserve.io]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io]
    end

    subgraph "API Resources - Istio/Service Mesh"
        Gateways[Gateways<br/>networking.istio.io]
        VirtualServices[VirtualServices<br/>networking.istio.io]
        PeerAuths[PeerAuthentications<br/>security.istio.io]
        AuthzPolicies[AuthorizationPolicies<br/>security.istio.io]
        Telemetries[Telemetries<br/>telemetry.istio.io]
        ServiceMeshMembers[ServiceMeshMembers<br/>maistra.io]
    end

    subgraph "API Resources - OpenShift"
        Routes[Routes<br/>route.openshift.io]
        NetworkPolicies[NetworkPolicies<br/>networking.k8s.io]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com]
        PodMonitors[PodMonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - Auth"
        AuthConfigs[AuthConfigs<br/>authorino.kuadrant.io]
    end

    subgraph "API Resources - Core"
        Services[Services<br/>core]
        Secrets[Secrets<br/>core]
        ConfigMaps[ConfigMaps<br/>core]
        ServiceAccounts[ServiceAccounts<br/>core]
        Namespaces[Namespaces<br/>core]
        Pods[Pods<br/>core]
        Endpoints[Endpoints<br/>core]
    end

    subgraph "API Resources - RBAC"
        ClusterRoleBindings[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - ODH"
        DataScienceClusters[DataScienceClusters<br/>datasciencecluster.opendatahub.io]
        DSCInitializations[DSCInitializations<br/>dscinitialization.opendatahub.io]
    end

    subgraph "API Resources - Leader Election"
        LeaderConfigMaps[ConfigMaps<br/>core - leader election]
        Leases[Leases<br/>coordination.k8s.io]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Controller

    SA_Controller -->|bound via| RB_LeaderElection
    RB_LeaderElection -->|grants| R_LeaderElection

    SA_Prometheus -->|bound via| RB_Prometheus
    RB_Prometheus -->|grants| CR_Prometheus

    %% Controller permissions - KServe
    CR_Controller -->|get, list, watch, update| InferenceService
    CR_Controller -->|get, list, watch, update| ServingRuntime

    %% Controller permissions - Istio
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| Gateways
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| VirtualServices
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| PeerAuths
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| AuthzPolicies
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| Telemetries
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| ServiceMeshMembers

    %% Controller permissions - OpenShift
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| Routes
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| NetworkPolicies

    %% Controller permissions - Monitoring
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| ServiceMonitors
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| PodMonitors

    %% Controller permissions - Auth
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| AuthConfigs

    %% Controller permissions - Core
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| Services
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| Secrets
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| ConfigMaps
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| ServiceAccounts
    CR_Controller -->|get, list, watch,<br/>create, update, patch| Namespaces
    CR_Controller -->|get, list, watch,<br/>create, update, patch| Pods
    CR_Controller -->|get, list, watch,<br/>create, update, patch| Endpoints

    %% Controller permissions - RBAC
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| ClusterRoleBindings
    CR_Controller -->|get, list, watch,<br/>create, update, patch, delete| RoleBindings

    %% Controller permissions - ODH
    CR_Controller -->|get, list, watch| DataScienceClusters
    CR_Controller -->|get, list, watch| DSCInitializations

    %% Leader election permissions
    R_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| LeaderConfigMaps
    R_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| Leases

    %% Prometheus permissions
    CR_Prometheus -->|get, list, watch| Services
    CR_Prometheus -->|get, list, watch| Endpoints
    CR_Prometheus -->|get, list, watch| Pods

