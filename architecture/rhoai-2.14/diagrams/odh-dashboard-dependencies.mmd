graph LR
    Dashboard[ODH Dashboard]

    %% External Dependencies
    Dashboard -->|"runtime & build"| NodeJS[Node.js 18+]
    Dashboard -->|"authentication"| OSAuth[OpenShift OAuth]
    Dashboard -->|"resource mgmt<br/>RBAC"| K8sAPI[Kubernetes API 1.24+]
    Dashboard -.->|"optional<br/>metrics"| Prometheus[Prometheus/Thanos]
    Dashboard -.->|"optional<br/>custom images"| ImageRegistry[OpenShift Image Registry]
    Dashboard -.->|"optional<br/>image builds"| Builds[OpenShift Builds]

    %% Internal ODH Dependencies
    Dashboard -->|"CRD watch<br/>kubeflow.org/v1"| NotebookController[Notebook Controller]
    Dashboard -->|"CRD watch<br/>serving.kserve.io"| KServe[KServe]
    Dashboard -->|"CRD watch<br/>modelregistry.opendatahub.io"| ModelRegistry[Model Registry]
    Dashboard -->|"CRD watch<br/>datasciencecluster.opendatahub.io"| DSCluster[Data Science Cluster Operator]
    Dashboard -->|"API/K8s proxy"| Pipelines[Data Science Pipelines]
    Dashboard -->|"CRD watches<br/>config"| ODHOperator[ODH Operator]

    %% Integration Points (reverse dependencies - components that use Dashboard)
    UserPortal[User Portal/UI] -->|"web interface"| Dashboard
    DSWorkbench[Data Scientists] -->|"notebook mgmt"| Dashboard
    MLOps[MLOps Teams] -->|"model serving UI"| Dashboard
    Admins[Administrators] -->|"component config"| Dashboard

    %% Styling
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:4px

    %% External dependencies (required)
    style NodeJS fill:#999,stroke:#333
    style OSAuth fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333

    %% External dependencies (optional)
    style Prometheus fill:#ccc,stroke:#666,stroke-dasharray: 5 5
    style ImageRegistry fill:#ccc,stroke:#666,stroke-dasharray: 5 5
    style Builds fill:#ccc,stroke:#666,stroke-dasharray: 5 5

    %% Internal ODH components
    style NotebookController fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style DSCluster fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333

    %% Users/consumers
    style UserPortal fill:#f5a623,stroke:#333
    style DSWorkbench fill:#f5a623,stroke:#333
    style MLOps fill:#f5a623,stroke:#333
