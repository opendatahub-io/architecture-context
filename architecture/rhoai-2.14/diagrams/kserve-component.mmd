graph TB
    subgraph "KServe Platform"
        subgraph "Control Plane"
            Controller[kserve-controller-manager<br/>Go Operator<br/>Port: 8080/TCP metrics]
            Webhook[kserve-webhook-server<br/>Go Webhook<br/>Port: 9443/TCP HTTPS mTLS]
            Controller -->|validates/mutates via| Webhook
        end

        subgraph "Data Plane Components"
            Agent[kserve-agent<br/>Sidecar<br/>Port: 9081/TCP]
            Router[kserve-router<br/>InferenceGraph orchestrator<br/>Port: 8080/TCP]
            StorageInit[storage-initializer<br/>InitContainer<br/>Python]
        end

        subgraph "Model Serving Runtimes"
            SkLearn[sklearn-server<br/>V1/V2 protocol]
            XGBoost[xgboost-server<br/>V1/V2 protocol]
            TensorFlow[tensorflow-server<br/>TensorFlow Serving]
            PyTorch[pytorch-server<br/>TorchServe]
            Triton[triton-server<br/>NVIDIA Triton]
            HuggingFace[huggingface-server<br/>Transformers]
        end

        subgraph "Optional Components"
            Alibi[alibi-explainer<br/>Explainability sidecar]
            ART[art-explainer<br/>Adversarial analysis]
        end
    end

    subgraph "Custom Resources"
        InferenceService[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntime[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        InferenceGraph[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
        TrainedModel[TrainedModel CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "External Dependencies"
        Knative[Knative Serving<br/>Autoscaling & scale-to-zero]
        Istio[Istio<br/>Traffic management & mTLS]
        CertMgr[cert-manager<br/>TLS certificates]
        K8s[Kubernetes API<br/>1.26+]
    end

    subgraph "Storage Backends"
        S3[S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM]
        GCS[GCS Storage<br/>443/TCP HTTPS<br/>Service Account]
        Azure[Azure Blob<br/>443/TCP HTTPS<br/>Storage Keys]
    end

    %% User interactions
    User[Data Scientist] -->|creates| InferenceService
    User -->|creates| InferenceGraph
    User -->|creates| TrainedModel

    %% Controller watches CRs
    InferenceService -->|watched by| Controller
    ServingRuntime -->|watched by| Controller
    InferenceGraph -->|watched by| Controller
    TrainedModel -->|watched by| Controller

    %% Controller creates resources
    Controller -->|creates| KnativeService[Knative Service]
    Controller -->|creates| VirtualService[Istio VirtualService]
    Controller -->|creates| K8sDeployment[Kubernetes Deployment]

    %% Webhook validation
    InferenceService -->|validated by| Webhook

    %% Component relationships
    Webhook -->|injects| StorageInit
    Webhook -->|injects| Agent
    StorageInit -->|downloads models from| S3
    StorageInit -->|downloads models from| GCS
    StorageInit -->|downloads models from| Azure
    Agent -->|manages| SkLearn
    Agent -->|manages| XGBoost
    Router -->|orchestrates| InferenceService

    %% External integrations
    Controller -->|depends on| Knative
    Controller -->|depends on| Istio
    Controller -->|depends on| K8s
    Webhook -->|cert provisioned by| CertMgr

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:3px
    style InferenceService fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntime fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceGraph fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainedModel fill:#f5a623,stroke:#333,stroke-width:2px
    style Knative fill:#e8e8e8,stroke:#666,stroke-width:2px
    style Istio fill:#e8e8e8,stroke:#666,stroke-width:2px
    style CertMgr fill:#e8e8e8,stroke:#666,stroke-width:2px
    style K8s fill:#e8e8e8,stroke:#666,stroke-width:2px
    style S3 fill:#7ed321,stroke:#333,stroke-width:2px
    style GCS fill:#7ed321,stroke:#333,stroke-width:2px
    style Azure fill:#7ed321,stroke:#333,stroke-width:2px
