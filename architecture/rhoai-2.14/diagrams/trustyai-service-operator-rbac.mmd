graph TD
    subgraph "Service Accounts"
        SA1[controller-manager<br/>operator namespace]
        SA2["{instance-name}-sa<br/>{user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        RB1[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "Roles"
        CR1[manager-role<br/>ClusterRole]
        CR2[leader-election-role<br/>ClusterRole]
    end

    subgraph "Core Resources"
        Core1[configmaps]
        Core2[events]
        Core3[pods]
        Core4[secrets]
        Core5[serviceaccounts]
        Core6[services]
        Core7[persistentvolumeclaims]
        Core8[persistentvolumes]
    end

    subgraph "Apps Resources"
        Apps1[deployments]
        Apps2[deployments/finalizers]
        Apps3[deployments/status]
    end

    subgraph "Coordination Resources"
        Coord1[leases<br/>coordination.k8s.io]
    end

    subgraph "Monitoring Resources"
        Mon1[servicemonitors<br/>monitoring.coreos.com]
    end

    subgraph "RBAC Resources"
        RBAC1[clusterrolebindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "Route Resources"
        Route1[routes<br/>route.openshift.io]
    end

    subgraph "KServe Resources"
        KS1[inferenceservices<br/>serving.kserve.io]
        KS2[inferenceservices/finalizers]
        KS3[servingruntimes]
        KS4[servingruntimes/status]
    end

    subgraph "TrustyAI Resources"
        TA1[trustyaiservices<br/>trustyai.opendatahub.io]
        TA2[trustyaiservices/finalizers]
        TA3[trustyaiservices/status]
    end

    %% Service Account to Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    RB1 -->|grants| CR2

    %% manager-role permissions
    CR1 -->|create,delete,get,list,patch,update,watch| Core1
    CR1 -->|create,patch,update| Core2
    CR1 -->|create,delete,get,list,patch,update,watch| Core3
    CR1 -->|create,delete,get,list,patch,update,watch| Core4
    CR1 -->|create,delete,get,list,update,watch| Core5
    CR1 -->|create,delete,get,list,patch,update,watch| Core6
    CR1 -->|create,delete,get,list,patch,update,watch| Core7
    CR1 -->|get,list,watch| Core8
    CR1 -->|create,delete,get,list,patch,update,watch| Apps1
    CR1 -->|update| Apps2
    CR1 -->|get,patch,update| Apps3
    CR1 -->|create,get,update| Coord1
    CR1 -->|create,list,watch| Mon1
    CR1 -->|create,delete,get,list,update,watch| RBAC1
    CR1 -->|create,delete,get,list,patch,update,watch| Route1
    CR1 -->|get,list,patch,update,watch| KS1
    CR1 -->|delete,get,list,patch,update,watch| KS2
    CR1 -->|create,delete,get,list,patch,update,watch| KS3
    CR1 -->|get,patch,update| KS4
    CR1 -->|create,delete,get,list,patch,update,watch| TA1
    CR1 -->|update| TA2
    CR1 -->|get,patch,update| TA3

    %% leader-election-role permissions
    CR2 -->|get,list,watch,create,update,patch| Coord1
    CR2 -->|get,list,watch,create,update,patch| Core1
    CR2 -->|create,patch| Core2

    %% TrustyAI Service SA (limited, managed by operator)
    SA2 -.->|identity for| TrustyAIPod[TrustyAI Service Pod]

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA2 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#bd10e0,stroke:#333,stroke-width:2px
    style RB1 fill:#bd10e0,stroke:#333,stroke-width:2px
    style TA1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style TA2 fill:#50e3c2,stroke:#333,stroke-width:2px
    style TA3 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KS1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KS2 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KS3 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KS4 fill:#50e3c2,stroke:#333,stroke-width:2px
