graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-operator]
    end

    subgraph "ClusterRoleBinding"
        CRB[controller-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[controller-manager-role<br/>ClusterRole]
    end

    subgraph "ODH/RHOAI CRDs"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
        FT[features.opendatahub.io<br/>FeatureTracker]
    end

    subgraph "Core Resources"
        NS[core<br/>namespaces]
        CM[core<br/>configmaps]
        Secrets[core<br/>secrets]
        SVC[core<br/>services]
        SA_RES[core<br/>serviceaccounts]
    end

    subgraph "Apps Resources"
        Deploy[apps<br/>deployments]
        RS[apps<br/>replicasets]
        STS[apps<br/>statefulsets]
    end

    subgraph "RBAC Resources"
        Roles[rbac.authorization.k8s.io<br/>roles, rolebindings]
        ClusterRoles[rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings]
    end

    subgraph "Networking"
        Routes[route.openshift.io<br/>routes]
        NetPol[networking.k8s.io<br/>networkpolicies]
    end

    subgraph "API Extensions"
        CRDs[apiextensions.k8s.io<br/>customresourcedefinitions]
        Webhooks[admissionregistration.k8s.io<br/>webhooks]
    end

    subgraph "Component CRDs"
        KServeIS[serving.kserve.io<br/>inferenceservices, servingruntimes]
        DSPA[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
        AuthConfig[authorino.kuadrant.io<br/>authconfigs]
    end

    subgraph "OpenShift Console"
        ConsoleLinks[console.openshift.io<br/>consolelinks, odhquickstarts]
    end

    subgraph "Monitoring"
        ServiceMon[monitoring.coreos.com<br/>servicemonitors, prometheusrules]
    end

    subgraph "Batch Jobs"
        Jobs[batch<br/>jobs, cronjobs]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - ODH CRDs
    CR -->|create, delete, get, list,<br/>patch, update, watch| DSC
    CR -->|create, delete, get, list,<br/>patch, update, watch| DSCI
    CR -->|create, delete, get, list,<br/>patch, update, watch| FT

    %% Permissions - Core
    CR -->|create, delete, get, list,<br/>patch, update, watch| NS
    CR -->|create, delete, get, list,<br/>patch, update, watch| CM
    CR -->|create, delete, get, list,<br/>patch, update, watch| Secrets
    CR -->|create, delete, get, list,<br/>patch, update, watch| SVC
    CR -->|create, delete, get, list,<br/>patch, update, watch| SA_RES

    %% Permissions - Apps
    CR -->|create, delete, get, list,<br/>patch, update, watch| Deploy
    CR -->|create, delete, get, list,<br/>patch, update, watch| RS
    CR -->|create, delete, get, list,<br/>patch, update, watch| STS

    %% Permissions - RBAC
    CR -->|create, delete, get, list,<br/>patch, update, watch| Roles
    CR -->|create, delete, get, list,<br/>patch, update, watch| ClusterRoles

    %% Permissions - Networking
    CR -->|create, delete, get, list,<br/>patch, update, watch| Routes
    CR -->|create, delete, get, list,<br/>patch, update, watch| NetPol

    %% Permissions - API Extensions
    CR -->|create, delete, get, list,<br/>patch, watch| CRDs
    CR -->|create, delete, get, list,<br/>patch, update, watch| Webhooks

    %% Permissions - Component CRDs
    CR -->|create, delete, get, list,<br/>patch, update, watch| KServeIS
    CR -->|create, delete, get, list,<br/>patch, update, watch| DSPA
    CR -->|create, delete, get, list,<br/>patch, update, watch| AuthConfig

    %% Permissions - Console
    CR -->|create, delete, get, list, patch| ConsoleLinks

    %% Permissions - Monitoring
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceMon

    %% Permissions - Batch
    CR -->|create, delete, get, list,<br/>patch, update, watch| Jobs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style DSC fill:#7ed321,stroke:#333,stroke-width:2px
    style DSCI fill:#7ed321,stroke:#333,stroke-width:2px
    style FT fill:#7ed321,stroke:#333,stroke-width:2px

