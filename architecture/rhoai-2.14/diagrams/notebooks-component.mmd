graph TB
    subgraph "Notebooks Component (Container Images)"
        direction TB

        subgraph "Jupyter Workbenches"
            JupyterMin[Jupyter Minimal<br/>Python 3.9/3.11]
            JupyterDS[Jupyter Data Science<br/>Pandas, NumPy, scikit-learn]
            JupyterPT[Jupyter PyTorch<br/>Deep Learning]
            JupyterTF[Jupyter TensorFlow<br/>Deep Learning]
            JupyterTA[Jupyter TrustyAI<br/>Explainable AI]
        end

        subgraph "Hardware Accelerator Images"
            JupyterIntel[Intel GPU Jupyter<br/>Intel oneAPI]
            JupyterROCm[ROCm Jupyter<br/>AMD GPU]
            JupyterHabana[Habana Jupyter<br/>Gaudi Accelerator]
        end

        subgraph "Alternative Workbenches"
            CodeServer[code-server<br/>VS Code in Browser]
            RStudio[RStudio Server<br/>R Development]
        end

        subgraph "Runtime Images"
            RuntimeMin[Runtime Minimal<br/>Pipeline Execution]
            RuntimeDS[Runtime Data Science<br/>Pipeline Execution]
            RuntimePT[Runtime PyTorch<br/>GPU Pipeline Execution]
        end

        subgraph "Base Images"
            Base[Base Images<br/>UBI9/C9S Python 3.9/3.11]
        end
    end

    subgraph "OpenShift Platform"
        ImageStream[ImageStream<br/>Image Distribution]
        ODHController[ODH Notebook Controller<br/>Workbench Lifecycle]
        ODHDashboard[ODH Dashboard<br/>UI Selection]
    end

    subgraph "External Services"
        Registry[Container Registry<br/>quay.io]
        ObjectStorage[Object Storage<br/>S3/Minio]
        PyPI[PyPI/Conda<br/>Package Repos]
    end

    subgraph "Pipeline Execution"
        KFP[Kubeflow Pipelines<br/>Elyra]
    end

    User[Data Scientist] -->|selects workbench| ODHDashboard
    ODHDashboard -->|references| ImageStream
    ImageStream -->|pulls from| Registry
    Registry -->|hosts| JupyterDS
    Registry -->|hosts| CodeServer
    Registry -->|hosts| RuntimeDS

    User -->|launches| ODHController
    ODHController -->|creates pods using| JupyterDS
    ODHController -->|creates pods using| JupyterPT
    ODHController -->|creates pods using| CodeServer

    Base -->|foundation for| JupyterMin
    JupyterMin -->|extends to| JupyterDS
    JupyterMin -->|extends to| JupyterPT
    JupyterMin -->|extends to| JupyterTF
    JupyterMin -->|extends to| JupyterTA

    Base -->|with GPU drivers| JupyterIntel
    Base -->|with GPU drivers| JupyterROCm
    Base -->|with GPU drivers| JupyterHabana

    Base -->|foundation for| RuntimeMin
    RuntimeMin -->|extends to| RuntimeDS
    RuntimeMin -->|extends to| RuntimePT

    KFP -->|executes| RuntimeDS
    KFP -->|executes| RuntimePT
    RuntimeDS -->|stores artifacts| ObjectStorage
    RuntimePT -->|stores artifacts| ObjectStorage

    JupyterDS -->|installs packages| PyPI
    RuntimeDS -->|downloads dependencies| ObjectStorage

    style JupyterDS fill:#4a90e2,stroke:#333,stroke-width:2px
    style CodeServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style RStudio fill:#4a90e2,stroke:#333,stroke-width:2px
    style RuntimeDS fill:#7ed321,stroke:#333,stroke-width:2px
    style Base fill:#f5a623,stroke:#333,stroke-width:2px
    style ODHController fill:#bd10e0,stroke:#333,stroke-width:2px
    style ODHDashboard fill:#bd10e0,stroke:#333,stroke-width:2px
    style ImageStream fill:#50e3c2,stroke:#333,stroke-width:2px
    style ObjectStorage fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Registry fill:#e8e8e8,stroke:#333,stroke-width:2px
    style KFP fill:#bd10e0,stroke:#333,stroke-width:2px
