graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Go Operator]
        Webhook[webhook-server<br/>Admission Webhook]
        Visibility[visibility-server<br/>API Server]
        Importer[importer<br/>Utility]
        CLI[kueuectl<br/>CLI Tool]
    end

    subgraph "Custom Resources"
        CQ[ClusterQueue<br/>kueue.x-k8s.io/v1beta1]
        LQ[LocalQueue<br/>kueue.x-k8s.io/v1beta1]
        WL[Workload<br/>kueue.x-k8s.io/v1beta1]
        RF[ResourceFlavor<br/>kueue.x-k8s.io/v1beta1]
        WPC[WorkloadPriorityClass<br/>kueue.x-k8s.io/v1beta1]
        AC[AdmissionCheck<br/>kueue.x-k8s.io/v1beta1]
    end

    subgraph "Job Frameworks"
        BatchJob[Batch Job<br/>batch/v1]
        MPIJob[MPIJob<br/>kubeflow.org]
        PyTorchJob[PyTorchJob<br/>kubeflow.org]
        TFJob[TFJob<br/>kubeflow.org]
        RayJob[RayJob<br/>ray.io]
        RayCluster[RayCluster<br/>ray.io]
        JobSet[JobSet<br/>jobset.x-k8s.io]
        AppWrapper[AppWrapper<br/>workload.codeflare.dev]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        CertMgr[cert-manager<br/>optional]
        Prometheus[Prometheus<br/>optional]
        ClusterAutoscaler[Cluster Autoscaler]
    end

    %% User interactions
    User[User/Admin] -->|creates| CQ
    User -->|creates| LQ
    User -->|submits| BatchJob
    User -->|submits| MPIJob
    User -->|submits| PyTorchJob
    User -->|submits| AppWrapper

    %% Controller watches CRDs
    Controller -->|watches/manages| CQ
    Controller -->|watches/manages| LQ
    Controller -->|watches/manages| WL
    Controller -->|watches/manages| RF
    Controller -->|watches/manages| WPC
    Controller -->|watches/manages| AC

    %% Controller integrates with job frameworks
    Controller -->|watches/mutates| BatchJob
    Controller -->|watches/mutates| MPIJob
    Controller -->|watches/mutates| PyTorchJob
    Controller -->|watches/mutates| TFJob
    Controller -->|watches/mutates| RayJob
    Controller -->|watches/mutates| RayCluster
    Controller -->|watches/mutates| JobSet
    Controller -->|watches| AppWrapper

    %% Webhook integration
    Webhook -->|validates/mutates| BatchJob
    Webhook -->|validates/mutates| MPIJob
    Webhook -->|validates/mutates| CQ
    Webhook -->|validates/mutates| LQ

    %% Visibility server
    Visibility -->|queries| CQ
    Visibility -->|queries| LQ
    Visibility -->|queries| WL
    User -->|queries via| Visibility

    %% External dependencies
    Controller -->|API calls| K8sAPI
    Webhook -->|API calls| K8sAPI
    Visibility -->|API calls| K8sAPI
    CertMgr -->|provides certs| Webhook
    CertMgr -->|provides certs| Visibility
    Prometheus -->|scrapes metrics| Controller
    Controller -->|creates| ProvisioningRequest[ProvisioningRequest<br/>autoscaling.x-k8s.io]
    ClusterAutoscaler -->|watches| ProvisioningRequest

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style Visibility fill:#4a90e2,stroke:#333,stroke-width:2px
    style Importer fill:#4a90e2,stroke:#333,stroke-width:1px
    style CLI fill:#4a90e2,stroke:#333,stroke-width:1px
    style CQ fill:#f5a623,stroke:#333,stroke-width:2px
    style LQ fill:#f5a623,stroke:#333,stroke-width:2px
    style WL fill:#f5a623,stroke:#333,stroke-width:2px
    style RF fill:#f5a623,stroke:#333,stroke-width:2px
    style BatchJob fill:#7ed321,stroke:#333,stroke-width:2px
    style MPIJob fill:#7ed321,stroke:#333,stroke-width:2px
    style PyTorchJob fill:#7ed321,stroke:#333,stroke-width:2px
    style AppWrapper fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style CertMgr fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Prometheus fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333,stroke-width:2px
