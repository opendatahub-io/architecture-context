graph TB
    subgraph "Service Accounts"
        SA1[controller-manager<br/>kueue-system]
        SA2[visibility-server<br/>kueue-system]
    end

    subgraph "ClusterRole Bindings"
        CRB1[leader-election-role-binding]
        CRB2[auth-proxy-role-binding]
        RB1[visibility-server-auth-reader]
    end

    subgraph "ClusterRoles - Operator"
        CR_Manager[manager-role]
    end

    subgraph "ClusterRoles - Users"
        CR_BatchAdmin[batch-admin-role]
        CR_BatchUser[batch-user-role]
        CR_CQEditor[clusterqueue-editor-role]
        CR_CQViewer[clusterqueue-viewer-role]
        CR_LQEditor[localqueue-editor-role]
        CR_LQViewer[localqueue-viewer-role]
        CR_WLEditor[workload-editor-role]
        CR_WLViewer[workload-viewer-role]
        CR_RFEditor[resourceflavor-editor-role]
        CR_RFViewer[resourceflavor-viewer-role]
    end

    subgraph "Core API Resources"
        Core_Events[events]
        Core_Pods[pods]
        Core_Namespaces[namespaces]
        Core_Secrets[secrets]
        Core_LimitRanges[limitranges]
        Core_ResourceQuotas[resourcequotas]
    end

    subgraph "Batch API Resources"
        Batch_Jobs[batch/jobs]
    end

    subgraph "Kueue API Resources"
        Kueue_CQ[kueue.x-k8s.io<br/>ClusterQueue]
        Kueue_LQ[kueue.x-k8s.io<br/>LocalQueue]
        Kueue_WL[kueue.x-k8s.io<br/>Workload]
        Kueue_RF[kueue.x-k8s.io<br/>ResourceFlavor]
        Kueue_WPC[kueue.x-k8s.io<br/>WorkloadPriorityClass]
        Kueue_AC[kueue.x-k8s.io<br/>AdmissionCheck]
        Kueue_PRC[kueue.x-k8s.io<br/>ProvisioningRequestConfig]
        Kueue_MKC[kueue.x-k8s.io<br/>MultiKueueCluster]
        Kueue_MKCFG[kueue.x-k8s.io<br/>MultiKueueConfig]
    end

    subgraph "Kubeflow API Resources"
        KF_MPI[kubeflow.org<br/>MPIJob]
        KF_PyTorch[kubeflow.org<br/>PyTorchJob]
        KF_TF[kubeflow.org<br/>TFJob]
        KF_XGBoost[kubeflow.org<br/>XGBoostJob]
        KF_MX[kubeflow.org<br/>MXJob]
        KF_Paddle[kubeflow.org<br/>PaddleJob]
    end

    subgraph "Ray API Resources"
        Ray_Job[ray.io<br/>RayJob]
        Ray_Cluster[ray.io<br/>RayCluster]
    end

    subgraph "Other API Resources"
        JobSet_JS[jobset.x-k8s.io<br/>JobSet]
        CF_AW[workload.codeflare.dev<br/>AppWrapper]
        AS_PR[autoscaling.x-k8s.io<br/>ProvisioningRequest]
        Admission_MWC[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration]
        Admission_VWC[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| RB1

    %% Role Bindings to Roles
    CRB1 -->|grants| CR_Manager
    CRB2 -->|grants| CR_Manager

    %% Manager Role Permissions - Core
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Events
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Pods
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Namespaces
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Secrets
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_LimitRanges

    %% Manager Role Permissions - Batch
    CR_Manager -->|get,list,patch,update,watch| Batch_Jobs

    %% Manager Role Permissions - Kueue
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_CQ
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_LQ
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_WL
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_RF
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_WPC
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_AC
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_PRC
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_MKC
    CR_Manager -->|create,delete,get,list,patch,update,watch| Kueue_MKCFG

    %% Manager Role Permissions - Kubeflow
    CR_Manager -->|get,list,patch,update,watch| KF_MPI
    CR_Manager -->|get,list,patch,update,watch| KF_PyTorch
    CR_Manager -->|get,list,patch,update,watch| KF_TF
    CR_Manager -->|get,list,patch,update,watch| KF_XGBoost
    CR_Manager -->|get,list,patch,update,watch| KF_MX
    CR_Manager -->|get,list,patch,update,watch| KF_Paddle

    %% Manager Role Permissions - Ray
    CR_Manager -->|get,list,patch,update,watch| Ray_Job
    CR_Manager -->|get,list,patch,update,watch| Ray_Cluster

    %% Manager Role Permissions - Other
    CR_Manager -->|get,list,patch,update,watch| JobSet_JS
    CR_Manager -->|get,list,watch| CF_AW
    CR_Manager -->|create,delete,get,list,patch,update,watch| AS_PR
    CR_Manager -->|get,list,update,watch| Admission_MWC
    CR_Manager -->|get,list,update,watch| Admission_VWC

    %% Batch Admin Role Permissions
    CR_BatchAdmin -->|get,list,watch| Core_Events
    CR_BatchAdmin -->|get,list,watch| Core_LimitRanges
    CR_BatchAdmin -->|get,list,watch| Core_Pods
    CR_BatchAdmin -->|get,list,watch| Core_ResourceQuotas
    CR_BatchAdmin -->|create,delete,get,list,patch,update,watch| Kueue_LQ

    %% Batch User Role Permissions
    CR_BatchUser -->|get,list,watch| Core_Events
    CR_BatchUser -->|get,list,watch| Core_LimitRanges
    CR_BatchUser -->|get,list,watch| Core_Pods
    CR_BatchUser -->|get,list,watch| Core_ResourceQuotas
    CR_BatchUser -->|get,list,watch| Kueue_LQ

    %% ClusterQueue Editor/Viewer
    CR_CQEditor -->|create,delete,get,list,patch,update,watch| Kueue_CQ
    CR_CQViewer -->|get,list,watch| Kueue_CQ

    %% LocalQueue Editor/Viewer
    CR_LQEditor -->|create,delete,get,list,patch,update,watch| Kueue_LQ
    CR_LQViewer -->|get,list,watch| Kueue_LQ

    %% Workload Editor/Viewer
    CR_WLEditor -->|create,delete,get,list,patch,update,watch| Kueue_WL
    CR_WLViewer -->|get,list,watch| Kueue_WL

    %% ResourceFlavor Editor/Viewer
    CR_RFEditor -->|create,delete,get,list,patch,update,watch| Kueue_RF
    CR_RFViewer -->|get,list,watch| Kueue_RF

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_BatchAdmin fill:#f5a623,stroke:#333,stroke-width:1px
    style CR_BatchUser fill:#f5a623,stroke:#333,stroke-width:1px
    style Kueue_CQ fill:#7ed321,stroke:#333,stroke-width:2px
    style Kueue_LQ fill:#7ed321,stroke:#333,stroke-width:2px
    style Kueue_WL fill:#7ed321,stroke:#333,stroke-width:2px
    style Batch_Jobs fill:#7ed321,stroke:#333,stroke-width:2px
    style KF_MPI fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style KF_PyTorch fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Ray_Job fill:#d5e8d4,stroke:#82b366,stroke-width:1px
