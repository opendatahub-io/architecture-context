graph TD
    subgraph "Service Accounts"
        SA[kubeflow-training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kubeflow-training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole: kubeflow-training-operator"
        CR[kubeflow-training-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Pods[pods<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        PodsExec[pods/exec<br/>verbs: create]
        Services[services<br/>verbs: create, delete,<br/>get, list, watch]
        ConfigMaps[configmaps<br/>verbs: create, list,<br/>update, watch]
        Events[events<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        ServiceAccounts[serviceaccounts<br/>verbs: create, get,<br/>list, watch]
    end

    subgraph "kubeflow.org API Resources"
        PyTorchJobs[pytorchjobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        TFJobs[tfjobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        MPIJobs[mpijobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        MXJobs[mxjobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        XGBoostJobs[xgboostjobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        PaddleJobs[paddlejobs<br/>verbs: create, delete, get,<br/>list, patch, update, watch]

        PyTorchStatus[pytorchjobs/status<br/>verbs: get, patch, update]
        TFStatus[tfjobs/status<br/>verbs: get, patch, update]
        MPIStatus[mpijobs/status<br/>verbs: get, patch, update]
        MXStatus[mxjobs/status<br/>verbs: get, patch, update]
        XGBoostStatus[xgboostjobs/status<br/>verbs: get, patch, update]
        PaddleStatus[paddlejobs/status<br/>verbs: get, patch, update]

        PyTorchFinalizers[pytorchjobs/finalizers<br/>verbs: update]
        TFFinalizers[tfjobs/finalizers<br/>verbs: update]
        MPIFinalizers[mpijobs/finalizers<br/>verbs: update]
        MXFinalizers[mxjobs/finalizers<br/>verbs: update]
        XGBoostFinalizers[xgboostjobs/finalizers<br/>verbs: update]
        PaddleFinalizers[paddlejobs/finalizers<br/>verbs: update]
    end

    subgraph "RBAC API Resources"
        Roles[roles<br/>verbs: create, list,<br/>update, watch]
        RoleBindings[rolebindings<br/>verbs: create, list,<br/>update, watch]
    end

    subgraph "Autoscaling API Resources"
        HPA[horizontalpodautoscalers<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    subgraph "Gang Scheduling Resources (Optional)"
        VolcanoPodGroups[podgroups<br/>scheduling.volcano.sh<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
        SchedulerPluginsPodGroups[podgroups<br/>scheduling.x-k8s.io<br/>verbs: create, delete, get,<br/>list, patch, update, watch]
    end

    subgraph "User Roles (Aggregated)"
        EditRole[kubeflow-training-edit<br/>Aggregates to edit/admin]
        ViewRole[kubeflow-training-view<br/>Aggregates to view]
    end

    subgraph "User Permissions"
        EditPerms[Training Job CRs:<br/>create, delete, get, list,<br/>patch, update, watch<br/><br/>Status: get]
        ViewPerms[Training Job CRs:<br/>get, list, watch<br/><br/>Status: get]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% ClusterRole Permissions - Core
    CR -->|full CRUD| Pods
    CR -->|exec| PodsExec
    CR -->|full CRUD| Services
    CR -->|create, list, update, watch| ConfigMaps
    CR -->|full CRUD| Events
    CR -->|create, get, list, watch| ServiceAccounts

    %% ClusterRole Permissions - Training Jobs
    CR -->|full CRUD| PyTorchJobs
    CR -->|full CRUD| TFJobs
    CR -->|full CRUD| MPIJobs
    CR -->|full CRUD| MXJobs
    CR -->|full CRUD| XGBoostJobs
    CR -->|full CRUD| PaddleJobs

    CR -->|update status| PyTorchStatus
    CR -->|update status| TFStatus
    CR -->|update status| MPIStatus
    CR -->|update status| MXStatus
    CR -->|update status| XGBoostStatus
    CR -->|update status| PaddleStatus

    CR -->|update| PyTorchFinalizers
    CR -->|update| TFFinalizers
    CR -->|update| MPIFinalizers
    CR -->|update| MXFinalizers
    CR -->|update| XGBoostFinalizers
    CR -->|update| PaddleFinalizers

    %% ClusterRole Permissions - Other
    CR -->|create, list, update, watch| Roles
    CR -->|create, list, update, watch| RoleBindings
    CR -->|full CRUD| HPA
    CR -.->|optional| VolcanoPodGroups
    CR -.->|optional| SchedulerPluginsPodGroups

    %% User Role Aggregation
    EditRole -->|grants| EditPerms
    ViewRole -->|grants| ViewPerms

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style CRB fill:#7ed321,color:#fff
    style PyTorchJobs fill:#ee4c2c,color:#fff
    style TFJobs fill:#ff6f00,color:#fff
    style MPIJobs fill:#0066cc,color:#fff
    style MXJobs fill:#0099e5,color:#fff
    style XGBoostJobs fill:#00a65a,color:#fff
    style PaddleJobs fill:#0052d9,color:#fff
    style EditRole fill:#9b59b6,color:#fff
    style ViewRole fill:#3498db,color:#fff
