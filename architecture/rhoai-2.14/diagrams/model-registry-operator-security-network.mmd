graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Gateway["Istio Ingress Gateway<br/>443/TCP → 8080/9090<br/>TLS 1.2+ HTTPS/gRPC<br/>Hosts: {name}-rest/grpc.{domain}"]

        subgraph AuthFlow["Authorization Flow"]
            AuthzPolicy["AuthorizationPolicy<br/>{registry-name}-authorino<br/>Action: CUSTOM"]
            Authorino["Authorino Service<br/>50051/TCP gRPC mTLS"]
            K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>TokenReview + SubjectAccessReview"]
        end

        Gateway --> AuthzPolicy
        AuthzPolicy --> Authorino
        Authorino --> K8sAPI
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS Configurable)"]
        direction TB

        VirtualService["VirtualService<br/>{registry-name}<br/>Routes REST + gRPC traffic"]
        DestinationRule["DestinationRule<br/>{registry-name}<br/>mTLS: ISTIO_MUTUAL"]
        Service["Service: {registry-name}<br/>ClusterIP<br/>8080/TCP (REST)<br/>9090/TCP (gRPC)"]

        subgraph Pod["Model Registry Pod"]
            direction LR
            RESTContainer["REST Container<br/>8080/TCP HTTP<br/>quay.io/opendatahub/<br/>model-registry"]
            gRPCContainer["gRPC Container<br/>9090/TCP gRPC<br/>quay.io/opendatahub/<br/>mlmd-grpc-server"]

            RESTContainer -->|localhost:9090<br/>gRPC<br/>No encryption| gRPCContainer
        end

        VirtualService --> Service
        Service --> RESTContainer
        Service --> gRPCContainer
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database[(Database<br/>PostgreSQL: 5432/TCP<br/>MySQL: 3306/TCP<br/>TLS 1.2+ configurable<br/>Username/Password)]
    end

    subgraph OperatorControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>NS: model-registry-operator-system<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS"]
    end

    subgraph AlternativeIngress["ALTERNATIVE: OpenShift Route"]
        Route["OpenShift Router<br/>443/TCP HTTPS<br/>Edge/Passthrough TLS<br/>No Auth"]
    end

    %% Main flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Gateway
    Gateway -->|HTTP/8080 or gRPC/9090<br/>mTLS if ISTIO_MUTUAL<br/>Validated token| VirtualService
    gRPCContainer -->|PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS configurable<br/>User/Pass| Database

    %% Alternative route flow
    Client -.->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Route
    Route -.->|HTTP/8080<br/>No encryption<br/>No auth| Service

    %% Operator flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Operator -.->|Creates/Manages| Service
    Operator -.->|Creates/Manages| Pod
    Operator -.->|Creates if Istio| Gateway
    Operator -.->|Creates if Istio| VirtualService
    Operator -.->|Creates if Istio| DestinationRule
    Operator -.->|Creates if Istio| AuthzPolicy

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef alternative fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway,AuthzPolicy,Authorino ingress
    class VirtualService,DestinationRule,Service,RESTContainer,gRPCContainer servicemesh
    class Database externalservice
    class Operator,K8sAPI operator
    class Route alternative
