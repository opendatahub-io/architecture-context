graph TD
    subgraph "Notebooks Component"
        Note1["ℹ️ No RBAC Resources Defined<br/>This component provides container images only<br/>RBAC is managed by ODH Notebook Controller"]
    end

    subgraph "RBAC Managed by ODH Notebook Controller"
        direction TB

        subgraph "Per-Workbench Resources (Created by Controller)"
            SA["ServiceAccount<br/>(workbench-name)-sa<br/>Namespace: (user-namespace)"]
            RB["RoleBinding<br/>(workbench-name)-pvc-access<br/>Namespace: (user-namespace)"]
            Role["Role<br/>pvc-access<br/>Resources: persistentvolumeclaims<br/>Verbs: get, list"]
        end

        subgraph "OAuth Proxy RBAC"
            OAuthSA["ServiceAccount<br/>oauth-proxy<br/>Namespace: (user-namespace)"]
            OAuthRB["RoleBinding<br/>oauth-proxy-user-validation<br/>Grants: Validate user identity"]
        end

        subgraph "Controller RBAC (Platform Level)"
            ControllerSA["ServiceAccount<br/>odh-notebook-controller-sa<br/>Namespace: opendatahub"]
            ControllerCRB["ClusterRoleBinding<br/>odh-notebook-controller"]
            ControllerCR["ClusterRole<br/>odh-notebook-controller<br/>Resources: pods, services,<br/>routes, statefulsets<br/>Verbs: create, delete,<br/>get, list, watch, update"]
        end
    end

    subgraph "Access Control Flow"
        User[User] -->|"Authenticated via OpenShift"| OpenShiftRBAC[OpenShift RBAC]
        OpenShiftRBAC -->|"Can create notebooks?"| NamespaceAccess{Namespace<br/>Access Check}
        NamespaceAccess -->|"Yes: User has edit/admin<br/>in namespace"| AllowCreate[Allow Notebook Creation]
        NamespaceAccess -->|"No: User lacks permissions"| DenyCreate[Deny Access]

        AllowCreate --> ControllerSA
        ControllerSA -->|"Creates workbench pod<br/>with ServiceAccount"| SA

        SA -->|"Bound via"| RB
        RB -->|"Grants"| Role
        Role -->|"Access to"| PVC["PersistentVolumeClaim<br/>(workbench-name)"]

        OAuthSA -->|"Validates user"| OAuthRB
        OAuthRB -->|"Ensures user owns<br/>notebook instance"| Policy["Policy: User owns<br/>/notebook/ns/user/"]
    end

    subgraph "Secrets Management (Injected by Controller)"
        SA -->|"Mounts"| StorageSecret["Secret: storage-credentials<br/>Type: Opaque<br/>Data: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY"]
        SA -->|"Mounts"| OAuthSecret["Secret: oauth-token<br/>Type: Opaque<br/>Data: OAuth token for APIs"]
        SA -->|"Mounts"| GitSecret["Secret: git-credentials<br/>Type: kubernetes.io/basic-auth<br/>Data: username, password"]
    end

    subgraph "Resources Accessed by Workbench"
        SA -->|"get, list"| PVC
        SA -->|"read"| StorageSecret
        SA -->|"read"| OAuthSecret
        SA -->|"read"| GitSecret
        SA -->|"create, delete"| TempPods["Ephemeral Pods<br/>(if user launches jobs)"]
    end

    %% Styling
    style Note1 fill:#fff9e6,stroke:#f5a623,stroke-width:2px

    style SA fill:#4a90e2,stroke:#333
    style RB fill:#7ed321,stroke:#333
    style Role fill:#f5a623,stroke:#333

    style OAuthSA fill:#4a90e2,stroke:#333
    style OAuthRB fill:#7ed321,stroke:#333

    style ControllerSA fill:#4a90e2,stroke:#333
    style ControllerCRB fill:#7ed321,stroke:#333
    style ControllerCR fill:#f5a623,stroke:#333

    style AllowCreate fill:#d5e8d4,stroke:#82b366
    style DenyCreate fill:#f8cecc,stroke:#b85450

    style PVC fill:#dae8fc,stroke:#6c8ebf
    style StorageSecret fill:#e1d5e7,stroke:#9673a6
    style OAuthSecret fill:#e1d5e7,stroke:#9673a6
    style GitSecret fill:#e1d5e7,stroke:#9673a6
    style TempPods fill:#dae8fc,stroke:#6c8ebf
