graph TB
    subgraph "CodeFlare Operator"
        Manager[Operator Manager<br/>Deployment]
        RayController[RayCluster Controller<br/>Reconciler]
        AppController[AppWrapper Controller<br/>Reconciler]
        RayWebhook[RayCluster Webhook<br/>MutatingWebhook]
        AppWebhook[AppWrapper Webhook<br/>MutatingWebhook]
        CertRotator[Certificate Rotator<br/>Controller]
        Metrics[Metrics Exporter<br/>:8080/TCP]

        Manager --> RayController
        Manager --> AppController
        Manager --> RayWebhook
        Manager --> AppWebhook
        Manager --> CertRotator
        Manager --> Metrics
    end

    subgraph "Managed CRDs"
        AppWrapper[AppWrapper CR<br/>workload.codeflare.dev/v1beta2]
    end

    subgraph "Watched External CRDs"
        RayCluster[RayCluster CR<br/>ray.io/v1]
        RayJob[RayJob CR<br/>ray.io/v1]
        KueueWorkload[Workload CR<br/>kueue.x-k8s.io/v1beta1]
        DSCInit[DSCInitialization<br/>dscinitialization.opendatahub.io/v1]
    end

    subgraph "Created Resources (per RayCluster)"
        OAuthProxy[OAuth Proxy Sidecar]
        mTLSCerts[mTLS Certificates]
        NetworkPolicies[NetworkPolicy Resources]
        Routes[Route/Ingress]
        OAuthResources[OAuth ServiceAccount/RoleBinding]
    end

    subgraph "External Dependencies"
        KubeRay[KubeRay Operator<br/>v1.1.0]
        Kueue[Kueue<br/>v0.8.1<br/>Optional]
        CertController[cert-controller<br/>Webhook Certs]
        OSRouter[OpenShift Router<br/>Optional]
    end

    subgraph "Internal ODH Integration"
        Dashboard[ODH Dashboard]
        OSAuth[OpenShift OAuth]
        OSMonitoring[OpenShift Monitoring]
    end

    %% User interactions
    User[User] -->|creates| AppWrapper
    User -->|creates via UI| Dashboard
    Dashboard -->|creates| RayCluster

    %% Controller watches
    RayCluster -->|watched by| RayController
    RayJob -->|watched by| AppController
    AppWrapper -->|managed by| AppController
    KueueWorkload -->|created by| AppController
    DSCInit -->|read by| RayController

    %% Webhook mutations
    RayWebhook -->|mutates/validates| RayCluster
    AppWebhook -->|mutates/validates| AppWrapper

    %% Resource creation
    RayController -->|creates| OAuthProxy
    RayController -->|creates| mTLSCerts
    RayController -->|creates| NetworkPolicies
    RayController -->|creates| Routes
    RayController -->|creates| OAuthResources

    %% External dependencies
    RayController -->|extends| KubeRay
    AppController -->|integrates| Kueue
    CertRotator -->|uses| CertController
    Routes -->|exposed via| OSRouter
    OAuthProxy -->|authenticates via| OSAuth
    Metrics -->|scraped by| OSMonitoring

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:4px
    style RayController fill:#4a90e2,stroke:#333
    style AppController fill:#4a90e2,stroke:#333
    style RayWebhook fill:#4a90e2,stroke:#333
    style AppWebhook fill:#4a90e2,stroke:#333
    style AppWrapper fill:#f5a623,stroke:#333
    style RayCluster fill:#f5a623,stroke:#333
    style KubeRay fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style OSAuth fill:#7ed321,stroke:#333
    style OSMonitoring fill:#7ed321,stroke:#333
