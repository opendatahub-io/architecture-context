graph LR
    ODHNotebookController["ODH Notebook Controller<br/>(OpenshiftNotebookReconciler)"]

    %% External Dependencies - Required
    ODHNotebookController -->|"watches CRs<br/>v1.27.0+"| KubeflowController["Kubeflow Notebook Controller<br/>(Creates StatefulSets)"]
    ODHNotebookController -->|"creates/updates<br/>route.openshift.io/v1"| RouteAPI["OpenShift Route API"]
    ODHNotebookController -->|"sidecar injection<br/>sha256:4bef31eb993feb6"| OAuthProxyImage["OpenShift OAuth Proxy Image<br/>(ose-oauth-proxy)"]
    ODHNotebookController -->|"cert provisioning<br/>via annotation"| ServiceCA["OpenShift Service CA Operator<br/>(OpenShift 4.x)"]

    %% External Dependencies - OAuth Flow
    OAuthProxyImage -->|"user authentication<br/>OAuth 2.0"| OAuthServer["OpenShift OAuth Server<br/>(OpenShift 4.x)"]
    OAuthProxyImage -->|"authorization<br/>SubjectAccessReview"| K8sAPI["Kubernetes API Server"]

    %% Controller Dependencies
    ODHNotebookController -->|"CRUD operations<br/>HTTPS/443 SA Token"| K8sAPI
    ODHNotebookController -->|"webhook registration<br/>MutatingWebhookConfiguration"| K8sAPI

    %% Internal ODH Dependencies
    Dashboard["ODH Dashboard"] -->|"creates CRs<br/>UI management"| ODHNotebookController
    Dashboard -->|"links to Routes<br/>HTTPS/443"| RouteAPI

    Pipelines["Data Science Pipelines"] -.->|"optional integration<br/>auto-deploy notebooks"| ODHNotebookController

    ODHNotebookController -.->|"optional integration<br/>opendatahub.io/service-mesh"| ServiceMesh["Service Mesh (Istio)<br/>(mutually exclusive with OAuth)"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080"| ODHNotebookController

    %% Workload Dependencies
    ODHNotebookController -->|"creates/manages"| NotebookPod["Notebook Pod<br/>(StatefulSet)"]
    NotebookPod -->|"storage access<br/>(optional)"| PVC["PersistentVolumeClaims"]

    %% Certificate Management
    ServiceCA -->|"auto-rotates<br/>TLS certs"| TLSSecrets["TLS Secrets<br/>(webhook-cert, {notebook}-tls)"]
    ODHNotebookController -->|"creates"| OAuthSecrets["OAuth Secrets<br/>({notebook}-oauth-config)"]

    %% Network Policy
    ODHNotebookController -->|"creates<br/>networking.k8s.io"| NetworkPolicies["NetworkPolicies<br/>(ctrl-np, oauth-np)"]
    NetworkPolicies -->|"allows traffic to"| NotebookPod

    %% RBAC
    ODHNotebookController -->|"uses"| ServiceAccount["ServiceAccount: manager<br/>(ClusterRole: manager-role)"]
    NotebookPod -->|"uses"| NotebookSA["ServiceAccount: {notebook-name}<br/>(OAuth redirect annotation)"]

    %% Styling
    style ODHNotebookController fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies (Required)
    style KubeflowController fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style RouteAPI fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style OAuthProxyImage fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style ServiceCA fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style OAuthServer fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Pipelines fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px,color:#000,stroke-dasharray: 5 5

    %% Monitoring
    style Prometheus fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    %% Resources Created
    style NotebookPod fill:#50c878,stroke:#333,stroke-width:2px,color:#fff
    style PVC fill:#e8e8e8,stroke:#333,stroke-width:1px,color:#000
    style TLSSecrets fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#000
    style OAuthSecrets fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#000
    style NetworkPolicies fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000
    style ServiceAccount fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    style NotebookSA fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
