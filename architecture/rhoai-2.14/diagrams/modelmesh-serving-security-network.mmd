graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / OpenShift Route<br/>443/TCP → 8033/8008/TCP<br/>TLS 1.3<br/>Bearer Token/mTLS"]
    end

    subgraph ServiceMesh["SERVICE MESH / CLUSTER NETWORK (Plaintext)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            subgraph RestPath["REST Inference Path"]
                RestProxy["REST Proxy<br/>SA: modelmesh-serving-sa<br/>8008/TCP HTTP"]
            end

            subgraph GrpcPath["gRPC Inference Path"]
                ModelMeshSvc["ModelMesh Service<br/>8033/TCP gRPC"]
            end

            subgraph RuntimePod["Runtime Pod Components"]
                direction TB
                ModelMesh["ModelMesh Container<br/>8033/8080/TCP gRPC"]
                Adapter["Runtime Adapter<br/>8085/TCP gRPC"]
                Runtime["Model Server<br/>MLServer/Triton/OVMS<br/>8001/8002/TCP gRPC/HTTP"]
            end
        end
    end

    subgraph ControllerPlane["CONTROLLER PLANE"]
        direction TB

        subgraph NS_Controller["Namespace: {controller-namespace}"]
            Controller["ModelMesh Controller<br/>SA: modelmesh-controller"]
        end

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        PrometheusMetrics["Prometheus<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Webhook["ValidatingWebhook<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API mTLS"]
    end

    subgraph Coordination["COORDINATION LAYER"]
        etcd["etcd Cluster<br/>2379/TCP HTTP<br/>Basic Auth/mTLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage / MinIO<br/>443/9000 HTTPS/HTTP<br/>TLS 1.2+ or None<br/>AWS IAM/Access Keys"]
    end

    %% Flows - External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Gateway

    %% Flows - Ingress to Services
    Gateway -->|REST Path<br/>HTTP/8008| RestProxy
    Gateway -->|gRPC Path<br/>gRPC/8033| ModelMeshSvc

    %% Flows - REST Path
    RestProxy -->|Translate to gRPC<br/>gRPC/8033| ModelMesh

    %% Flows - gRPC Path
    ModelMeshSvc -->|Forward| ModelMesh

    %% Flows - Within Runtime Pod
    ModelMesh -->|Route inference<br/>gRPC/8085| Adapter
    Adapter -->|Inference request<br/>gRPC/8001| Runtime

    %% Flows - Runtime to External
    Runtime -->|Download models<br/>HTTPS/443 or HTTP/9000<br/>AWS IAM| S3

    %% Flows - Controller Plane
    Controller -->|Watch CRs<br/>HTTPS/6443<br/>TLS 1.2+| K8sAPI
    Controller -->|Expose metrics<br/>HTTPS/8443<br/>TLS 1.2+| PrometheusMetrics
    Controller -->|Validate CRs<br/>HTTPS/9443<br/>TLS 1.2+| Webhook
    Controller -->|Metadata<br/>HTTP/2379<br/>Basic Auth| etcd

    %% Flows - Coordination
    ModelMesh -->|Coordination<br/>HTTP/2379<br/>Basic Auth| etcd

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef coordination fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class RestProxy,ModelMeshSvc,ModelMesh,Adapter,Runtime servicemesh
    class Controller,K8sAPI,PrometheusMetrics,Webhook controller
    class etcd coordination
    class S3 externalservice
