graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        DataScientist["Data Scientist<br/>kubectl"]
        Client["External Client<br/>Inference Requests"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.3<br/>Client cert/token auth"]
        IstioGateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>HTTPS TLS 1.3<br/>Bearer Token (optional)"]
    end

    subgraph ControlPlane["CONTROL PLANE (kserve namespace)"]
        direction TB

        Webhook["kserve-webhook-server<br/>9443/TCP HTTPS TLS 1.2+<br/>mTLS<br/>SA: kserve-controller-manager<br/>Secret: kserve-webhook-server-cert"]

        Controller["kserve-controller-manager<br/>Watch API + 6443/TCP<br/>SA: kserve-controller-manager<br/>ClusterRole: kserve-manager-role"]

        CRs["Custom Resources<br/>InferenceService<br/>ServingRuntime<br/>InferenceGraph<br/>TrainedModel"]
    end

    subgraph DataPlane["DATA PLANE (Service Mesh - User Namespaces)"]
        direction TB

        subgraph KnativeNS["knative-serving namespace"]
            Activator["Knative Activator<br/>8012/TCP HTTP<br/>mTLS (optional)<br/>SA: activator"]
        end

        subgraph UserNS["user-namespace"]
            direction TB

            subgraph ServerlessPod["InferenceService Pod (Serverless)"]
                QueueProxy["queue-proxy<br/>(Knative sidecar)"]
                StorageInit["storage-initializer<br/>(InitContainer)<br/>AWS IAM/GCP SA/Azure Keys"]
                Agent["kserve-agent<br/>9081/TCP control<br/>8012/TCP proxy"]
                ModelServer["model-server<br/>8080/TCP HTTP<br/>8081/TCP gRPC"]
            end

            Router["kserve-router<br/>8080/TCP HTTP<br/>InferenceGraph orchestrator<br/>SA: {ig-name}-sa"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM (IRSA) or Access Keys<br/>Secret: storage-config"]

        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account (Workload Identity)<br/>or JSON key"]

        Azure["Azure Blob<br/>{account}.blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Storage Keys or SAS token"]

        CloudEvents["CloudEvents Broker<br/>80/TCP HTTP<br/>mTLS (optional)"]
    end

    subgraph CertMgmt["CERTIFICATE MANAGEMENT"]
        CertManager["cert-manager<br/>Provisions webhook certs<br/>90-day rotation"]
    end

    %% External to Ingress
    DataScientist -->|"HTTPS/6443<br/>TLS 1.3<br/>kubeconfig"| K8sAPI
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer (optional)"| IstioGateway

    %% Ingress to Control Plane
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>mTLS"| Webhook
    K8sAPI -->|"Watch API<br/>SA token"| Controller
    Controller -->|"HTTPS/6443<br/>TLS 1.3<br/>SA token"| K8sAPI
    Webhook -.->|"validates/mutates"| CRs
    Controller -->|"watches"| CRs

    %% Ingress to Data Plane
    IstioGateway -->|"HTTP/8012<br/>mTLS (optional)"| Activator
    IstioGateway -->|"HTTP/80<br/>mTLS (optional)"| Router

    %% Data Plane flows
    Activator -->|"HTTP/8012<br/>mTLS (optional)"| Agent
    Agent -->|"HTTP/8080<br/>localhost"| ModelServer
    Router -->|"HTTP/80<br/>Header propagation<br/>mTLS (optional)"| ModelServer

    %% Control to Data
    Controller -->|"HTTP/9081<br/>Load model cmd"| Agent

    %% Data Plane to External Services
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA/Keys"| S3
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA/Keys"| GCS
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Keys"| Azure
    Agent -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA"| S3
    Agent -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA"| GCS
    Agent -->|"HTTP/80<br/>CloudEvents"| CloudEvents

    %% Certificate Management
    CertManager -->|"provisions"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef controlplane fill:#cce5ff,stroke:#0066cc,stroke-width:2px,color:#000
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef certmgmt fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000

    class DataScientist,Client external
    class K8sAPI,IstioGateway ingress
    class Webhook,Controller,CRs controlplane
    class Activator,QueueProxy,StorageInit,Agent,ModelServer,Router dataplane
    class S3,GCS,Azure,CloudEvents externalservice
    class CertManager certmgmt
