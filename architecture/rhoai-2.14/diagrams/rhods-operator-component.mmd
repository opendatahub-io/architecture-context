graph TB
    subgraph "rhods-operator Pod"
        Manager[Operator Manager<br/>Port: 8081 health/ready<br/>Port: 8080 metrics]
        AuthProxy[Auth Proxy<br/>kube-rbac-proxy<br/>Port: 8443]
        Webhook[Webhook Server<br/>Port: 9443 HTTPS]

        subgraph "Controllers"
            DSCController[DataScienceCluster<br/>Controller]
            DSCIController[DSCInitialization<br/>Controller]
            SecretGen[SecretGenerator<br/>Controller]
            CertGen[CertConfigmapGenerator<br/>Controller]
        end

        Manager --> DSCController
        Manager --> DSCIController
        Manager --> SecretGen
        Manager --> CertGen
        Manager --> Webhook
        AuthProxy -->|proxies| Manager
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FeatureTracker[FeatureTracker CR<br/>features.opendatahub.io/v1]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        GitHub[github.com<br/>443/TCP HTTPS<br/>Manifest source]
        QuayIO[quay.io<br/>443/TCP HTTPS<br/>Container images]
        ServiceMesh[Service Mesh Operator]
        Serverless[Serverless Operator]
        Authorino[Authorino Operator]
    end

    subgraph "Deployed Components"
        Dashboard[ODH Dashboard]
        KServe[KServe]
        ModelMesh[ModelMesh Serving]
        DSP[Data Science Pipelines]
        CodeFlare[CodeFlare Operator]
        KubeRay[KubeRay Operator]
        Training[Training Operator]
        Kueue[Kueue]
        ModelRegistry[Model Registry]
        TrustyAI[TrustyAI Service]
    end

    User[Admin/System] -->|creates/updates| DSC
    User -->|creates| DSCI

    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController

    Webhook -->|validates/mutates| DSC
    Webhook -->|validates| DSCI

    DSCController -->|reconciles via| K8sAPI
    DSCIController -->|reconciles via| K8sAPI
    SecretGen -->|creates secrets via| K8sAPI
    CertGen -->|creates configmaps via| K8sAPI

    DSCController -->|downloads manifests| GitHub
    DSCController -->|deploys| Dashboard
    DSCController -->|deploys| KServe
    DSCController -->|deploys| ModelMesh
    DSCController -->|deploys| DSP
    DSCController -->|deploys| CodeFlare
    DSCController -->|deploys| KubeRay
    DSCController -->|deploys| Training
    DSCController -->|deploys| Kueue
    DSCController -->|deploys| ModelRegistry
    DSCController -->|deploys| TrustyAI

    DSCController -->|depends on| ServiceMesh
    DSCController -->|depends on| Serverless
    DSCController -->|depends on| Authorino

    DSCController -->|creates| FeatureTracker
    Manager -->|pulls from| QuayIO

    Prometheus[Prometheus] -->|scrapes metrics| AuthProxy

    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCIController fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSC fill:#f5a623,stroke:#333,stroke-width:2px
    style DSCI fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style GitHub fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:1px
    style KServe fill:#7ed321,stroke:#333,stroke-width:1px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:1px
    style DSP fill:#7ed321,stroke:#333,stroke-width:1px
