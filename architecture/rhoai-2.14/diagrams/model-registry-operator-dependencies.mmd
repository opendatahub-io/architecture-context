    style Istio fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Authorino fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style CertManager fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style OSM fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Prometheus fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style OpenShift fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style OperatorImage fill:#f5a623,stroke:#333
