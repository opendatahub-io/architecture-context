graph LR
    ModelRegistryOperator[Model Registry Operator<br/>v-2160 rhoai-2.14]

    %% External Dependencies (Required)
    Database[(Database<br/>PostgreSQL 9.6+ OR<br/>MySQL 5.7+)]
    K8sAPI[Kubernetes API<br/>Core APIs]

    %% External Dependencies (Optional)
    Istio[Istio 1.20+<br/>Service Mesh]
    Authorino[Authorino 0.17+<br/>External AuthZ]
    CertManager[cert-manager<br/>Certificate Management]
    OSM[OpenShift Service Mesh 2.x]

    %% Internal ODH/RHOAI Dependencies
    ODHOperator[ODH Operator<br/>Config Provider]
    Prometheus[Prometheus<br/>Metrics Collection]

    %% OpenShift Specific
    OpenShift[OpenShift<br/>Routes, Groups, Ingress]

    %% Container Images
    OperatorImage[quay.io/opendatahub/<br/>model-registry-operator:latest]
    RESTImage[quay.io/opendatahub/<br/>model-registry:latest]
    gRPCImage[quay.io/opendatahub/<br/>mlmd-grpc-server:latest]

    %% Required dependencies
    ModelRegistryOperator -->|requires one of| Database
    ModelRegistryOperator -->|manages resources| K8sAPI
    ModelRegistryOperator -->|uses image| OperatorImage
    ModelRegistryOperator -->|deploys| RESTImage
    ModelRegistryOperator -->|deploys| gRPCImage

    %% Optional dependencies
    ModelRegistryOperator -.->|traffic mgmt, mTLS| Istio
    ModelRegistryOperator -.->|API authentication| Authorino
    ModelRegistryOperator -.->|TLS certificates| CertManager
    ModelRegistryOperator -.->|OpenShift variant| OSM
    ModelRegistryOperator -.->|exposes metrics to| Prometheus
    ModelRegistryOperator -.->|Route creation| OpenShift

    %% Internal integrations
    ModelRegistryOperator -.->|auth config| ODHOperator

    %% Istio dependencies
    Istio -.->|delegates authz| Authorino
    Istio -.->|certificate requests| CertManager

    %% Relationships between dependencies
    OSM -->|includes| Istio
    OpenShift -->|provides| OSM

    %% Styling
    style ModelRegistryOperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Database fill:#e74c3c,stroke:#333,stroke-width:3px,color:#fff
