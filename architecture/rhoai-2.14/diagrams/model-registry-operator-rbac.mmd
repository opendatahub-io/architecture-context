graph TD
    subgraph "Operator Service Account"
        SA[controller-manager<br/>NS: model-registry-operator-system]
    end

    subgraph "Operator ClusterRole Bindings"
        ManagerBinding[manager-role-binding]
        LeaderBinding[leader-election-role-binding]
    end

    subgraph "Operator ClusterRoles"
        ManagerRole[manager-role<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>ClusterRole]
    end

    subgraph "User-Facing Roles"
        EditorRole[modelregistry-editor-role<br/>ClusterRole]
        ViewerRole[modelregistry-viewer-role<br/>ClusterRole]
    end

    subgraph "Per-Instance Resources"
        InstanceRole["registry-user-NAME<br/>Role per instance"]
        InstanceBinding["registry-user-NAME<br/>RoleBinding per instance"]
        InstanceGroup["NAME-users<br/>Group OpenShift only"]
    end

    subgraph "API Resources - Core"
        ModelRegistryCR[modelregistry.opendatahub.io<br/>ModelRegistry]
        Deployments[apps<br/>Deployments]
        Services[core<br/>Services]
        ServiceAccounts[core<br/>ServiceAccounts]
        Pods[core<br/>Pods]
        Events[core<br/>Events]
        Roles[rbac.authorization.k8s.io<br/>Roles]
        RoleBindings[rbac.authorization.k8s.io<br/>RoleBindings]
    end

    subgraph "API Resources - Istio"
        Gateways[networking.istio.io<br/>Gateways]
        VirtualServices[networking.istio.io<br/>VirtualServices]
        DestinationRules[networking.istio.io<br/>DestinationRules]
        AuthzPolicies[security.istio.io<br/>AuthorizationPolicies]
    end

    subgraph "API Resources - Authorino"
        AuthConfigs[authorino.kuadrant.io<br/>AuthConfigs]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io<br/>Routes]
        RoutesCustomHost[route.openshift.io<br/>Routes/custom-host]
        Groups[user.openshift.io<br/>Groups]
        Ingresses[config.openshift.io<br/>Ingresses]
    end

    subgraph "API Resources - Leader Election"
        ConfigMaps[core<br/>ConfigMaps]
        Leases[coordination.k8s.io<br/>Leases]
    end

    subgraph "Per-Instance Service Resource"
        ServiceResource["core<br/>Service/REGISTRY-NAME"]
    end

    %% Service Account to Bindings
    SA -->|bound via| ManagerBinding
    SA -->|bound via| LeaderBinding

    %% Bindings to Roles
    ManagerBinding -->|grants| ManagerRole
    LeaderBinding -->|grants| LeaderRole

    %% Manager Role Permissions (all verbs: create, delete, get, list, patch, update, watch)
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| ModelRegistryCR
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Deployments
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Services
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts
    ManagerRole -->|get, list, watch| Pods
    ManagerRole -->|create, patch| Events
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Roles
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| RoleBindings
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Gateways
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| VirtualServices
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| DestinationRules
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| AuthzPolicies
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| AuthConfigs
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Routes
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| RoutesCustomHost
    ManagerRole -->|create, delete, get, list,<br/>patch, update, watch| Groups
    ManagerRole -->|get, list, watch| Ingresses

    %% Leader Election Role Permissions
    LeaderRole -->|get, list, watch, create,<br/>update, patch, delete| ConfigMaps
    LeaderRole -->|get, list, watch, create,<br/>update, patch, delete| Leases

    %% User-facing roles
    EditorRole -->|create, delete, get, list,<br/>patch, update, watch| ModelRegistryCR
    ViewerRole -->|get, list, watch| ModelRegistryCR

    %% Per-instance RBAC
    InstanceBinding -->|grants| InstanceRole
    InstanceRole -->|get| ServiceResource
    InstanceGroup -.->|bound via| InstanceBinding

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style EditorRole fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style ViewerRole fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style InstanceRole fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style ModelRegistryCR fill:#e8e8e8,stroke:#333
    style Deployments fill:#e8e8e8,stroke:#333
    style Services fill:#e8e8e8,stroke:#333
    style ServiceResource fill:#e8e8e8,stroke:#333
    style Gateways fill:#d5e8d4,stroke:#82b366
    style VirtualServices fill:#d5e8d4,stroke:#82b366
    style DestinationRules fill:#d5e8d4,stroke:#82b366
    style AuthzPolicies fill:#d5e8d4,stroke:#82b366
    style AuthConfigs fill:#d5e8d4,stroke:#82b366
    style Routes fill:#ffe6cc,stroke:#d79b00
    style Groups fill:#ffe6cc,stroke:#d79b00
    style InstanceGroup fill:#ffe6cc,stroke:#d79b00

    %% Legend
    subgraph RBACLegend["RBAC Legend"]
        LegendSA[Service Account]
        LegendClusterRole[ClusterRole]
        LegendRole[Role per-instance]
        LegendUserRole[User-facing Role]
        LegendCoreAPI[Core API Resource]
        LegendIstioAPI[Istio API Resource]
        LegendOSAPI[OpenShift API Resource]
    end

    style LegendSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style LegendClusterRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style LegendRole fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style LegendUserRole fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style LegendCoreAPI fill:#e8e8e8,stroke:#333
    style LegendIstioAPI fill:#d5e8d4,stroke:#82b366
    style LegendOSAPI fill:#ffe6cc,stroke:#d79b00
