graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Admin]
        GitHub["github.com<br/>Component Manifests"]
        Quay["quay.io<br/>Container Images"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB

        subgraph OperatorPod["rhods-operator Pod<br/>SA: controller-manager"]
            direction LR
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ (service-ca)"]
            Manager["Operator Manager<br/>8081/TCP (health)<br/>8080/TCP (metrics)"]
            AuthProxy["kube-rbac-proxy<br/>8443/TCP HTTPS"]

            AuthProxy -->|HTTP/8080<br/>internal pod| Manager
        end

        WebhookSvc["webhook-service<br/>443→9443/TCP"]
        MetricsSvc["controller-manager-metrics-service<br/>8443/TCP"]

        WebhookSvc -->|routes to| Webhook
        MetricsSvc -->|routes to| AuthProxy
    end

    subgraph MonitoringNamespace["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>SA: prometheus"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph DeployedComponents["DEPLOYED COMPONENTS"]
        Dashboard["ODH Dashboard"]
        KServe["KServe"]
        ModelMesh["ModelMesh"]
        DSP["Data Science Pipelines"]
        Other["Other Components..."]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.3<br/>kubeconfig auth| K8sAPI

    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS API Server<br/>Webhook validation| WebhookSvc

    Manager -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token<br/>Reconciliation| K8sAPI

    Manager -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>Download manifests| GitHub

    Manager -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>Pull images| Quay

    Manager -->|HTTPS/5000<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Internal images| ImageRegistry

    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token<br/>Scrape metrics| MetricsSvc

    Manager -->|via K8s API<br/>Deploy & manage| Dashboard
    Manager -->|via K8s API<br/>Deploy & manage| KServe
    Manager -->|via K8s API<br/>Deploy & manage| ModelMesh
    Manager -->|via K8s API<br/>Deploy & manage| DSP
    Manager -->|via K8s API<br/>Deploy & manage| Other

    %% NetworkPolicy annotations
    K8sAPI -.->|Kubelet health probes<br/>8081/TCP| Manager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef components fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class User,GitHub,Quay external
    class K8sAPI controlplane
    class Webhook,Manager,AuthProxy,WebhookSvc,MetricsSvc operator
    class Prometheus monitoring
    class ImageRegistry externalservice
    class Dashboard,KServe,ModelMesh,DSP,Other components
