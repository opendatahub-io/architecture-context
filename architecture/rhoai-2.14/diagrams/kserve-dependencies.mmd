graph LR
    KServe[KServe Platform<br/>Model Serving]

    %% External Dependencies (Required/Conditional)
    KServe -->|"serverless mode<br/>autoscaling"| Knative[Knative Serving 1.x<br/>Conditional]
    KServe -->|"traffic mgmt<br/>VirtualServices<br/>mTLS"| Istio[Istio 1.x<br/>Conditional]
    KServe -->|"core platform<br/>CRDs, operators"| K8s[Kubernetes 1.26+<br/>Required]
    KServe -->|"webhook certs<br/>TLS provisioning"| CertManager[cert-manager 1.x<br/>Conditional]
    KServe -.->|"metrics scraping<br/>HTTP/8080"| Prometheus[Prometheus 2.x<br/>Optional]

    %% Internal ODH Dependencies
    KServe -.->|"model metadata<br/>versioning"| ModelRegistry[Model Registry<br/>Internal ODH<br/>Optional]
    KServe -.->|"service mesh<br/>inherited"| ServiceMesh[Service Mesh Istio<br/>Internal ODH<br/>Conditional]

    %% Integration Points (ODH Components)
    Dashboard[ODH Dashboard<br/>Internal ODH] -.->|"UI management<br/>InferenceService CRUD"| KServe
    Pipelines[Data Science Pipelines<br/>Internal ODH] -.->|"auto deploy<br/>pipeline outputs"| KServe
    Authorino[Authorino<br/>Internal ODH] -.->|"external authz<br/>inference endpoints"| KServe

    %% External Services (Cloud Storage)
    KServe -->|"model download<br/>HTTPS/443<br/>AWS IAM/Keys"| S3[S3 Storage<br/>External Service]
    KServe -->|"model download<br/>HTTPS/443<br/>GCP SA"| GCS[GCS Storage<br/>External Service]
    KServe -->|"model download<br/>HTTPS/443<br/>Storage Keys"| Azure[Azure Blob<br/>External Service]
    KServe -.->|"model download<br/>8020/TCP<br/>Kerberos"| HDFS[HDFS<br/>External Service<br/>Optional]

    %% External Services (Other)
    KServe -.->|"request logging<br/>CloudEvents<br/>HTTP/80"| CloudEventsBroker[CloudEvents Broker<br/>External Service<br/>Optional]

    %% API Server interaction
    K8s -->|"webhook callbacks<br/>HTTPS/9443 mTLS"| KServe
    K8s -->|"watch events<br/>SA token"| KServe

    %% Styling
