graph TB
    subgraph "Model Registry Operator"
        Controller[Operator Controller<br/>Port: 8081 Health, 8443 Metrics]
    end

    subgraph "Model Registry Instance"
        direction LR
        RESTContainer[REST Container<br/>Port: 8080/TCP HTTP]
        gRPCContainer[gRPC Container<br/>Port: 9090/TCP gRPC]
        RESTContainer -->|localhost:9090| gRPCContainer
    end

    subgraph "Kubernetes Resources"
        ModelRegistryCR[ModelRegistry CR<br/>v1alpha1]
        Deployment[Deployment]
        Service[Service<br/>ClusterIP 8080, 9090]
        ServiceAccount[ServiceAccount]
    end

    subgraph "Istio Resources (Optional)"
        Gateway[Istio Gateway<br/>REST + gRPC]
        VirtualService[VirtualService]
        DestinationRule[DestinationRule<br/>mTLS: ISTIO_MUTUAL]
        AuthzPolicy[AuthorizationPolicy<br/>CUSTOM: Authorino]
    end

    subgraph "Security Resources (Optional)"
        AuthConfig[AuthConfig CR<br/>Authorino]
        Role["Role: registry-user-NAME"]
        RoleBinding[RoleBinding]
        UserGroup["Group: NAME-users<br/>OpenShift Only"]
    end

    subgraph "External Dependencies"
        Database[(PostgreSQL/MySQL<br/>Port: 5432/3306)]
        Authorino[Authorino Service<br/>Port: 50051 gRPC]
        K8sAPI[Kubernetes API<br/>Port: 6443]
    end

    User[User/Client] -->|creates| ModelRegistryCR
    ModelRegistryCR -->|watched by| Controller
    Controller -->|creates/manages| Deployment
    Controller -->|creates/manages| Service
    Controller -->|creates/manages| ServiceAccount
    Controller -->|creates if istio enabled| Gateway
    Controller -->|creates if istio enabled| VirtualService
    Controller -->|creates if istio enabled| DestinationRule
    Controller -->|creates if istio enabled| AuthzPolicy
    Controller -->|creates if auth enabled| AuthConfig
    Controller -->|creates| Role
    Controller -->|creates| RoleBinding
    Controller -->|creates if OpenShift| UserGroup
    Controller -->|API calls| K8sAPI

    Deployment -->|contains| RESTContainer
    Deployment -->|contains| gRPCContainer
    Service -->|routes to| RESTContainer
    Service -->|routes to| gRPCContainer
    Gateway -->|routes via| VirtualService
    VirtualService -->|targets| Service
    AuthzPolicy -->|delegates to| Authorino
    gRPCContainer -->|connects to| Database

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style RESTContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style gRPCContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistryCR fill:#f5a623,stroke:#333,stroke-width:2px
    style Gateway fill:#bd10e0,stroke:#333,stroke-width:2px
    style AuthConfig fill:#bd10e0,stroke:#333,stroke-width:2px
    style Database fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Authorino fill:#e8e8e8,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
