graph TB
    subgraph "Platform Orchestration"
        RhodsOp[rhods-operator<br/>v1.6.0-826<br/>Platform Orchestrator]
    end

    subgraph "Core Services - redhat-ods-applications"
        Dashboard[odh-dashboard<br/>v1.21.0-18<br/>Unified Platform UI]
        NotebookCtrl[notebook-controller<br/>v1.27.0-663<br/>Kubeflow Base]
        OdhNotebookCtrl[odh-notebook-controller<br/>v1.27.0-663<br/>OpenShift Extensions]
        ModelCtrl[odh-model-controller<br/>v1.27.0-483<br/>Service Mesh Integration]
    end

    subgraph "Model Serving"
        KServe[kserve<br/>1fdf877e7<br/>Serverless/Raw Deployment]
        ModelMesh[modelmesh-serving<br/>v1.27.0-261<br/>Multi-Model Serving]
        ModelRegistry[model-registry-operator<br/>v-2160<br/>Model Versioning]
    end

    subgraph "ML Workflows"
        DSPO[data-science-pipelines-operator<br/>6b7b774<br/>Argo-based Pipelines]
    end

    subgraph "Distributed Computing"
        CodeFlare[codeflare-operator<br/>v1.9.0<br/>Ray Orchestration]
        KubeRay[kuberay<br/>d490ea60<br/>Ray Clusters]
        TrainingOp[training-operator<br/>4b4e3bb4<br/>Distributed Training]
        Kueue[kueue<br/>v0.8.1<br/>Job Queueing]
    end

    subgraph "Monitoring & Governance"
        TrustyAI[trustyai-service-operator<br/>1.17.0<br/>Fairness & Bias Detection]
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh]
        Knative[Knative Serving]
        OAuth[OpenShift OAuth]
        Prometheus[Prometheus Monitoring]
        K8sAPI[Kubernetes API Server]
    end

    subgraph "User Workloads - {user-namespace}"
        Notebooks[Jupyter/code-server/RStudio<br/>Workbenches]
        InferenceServices[InferenceService Pods<br/>Model Serving]
        DSPInstances[DSPA Instances<br/>Pipeline Infrastructure]
        TrainingJobs[Training Job Pods<br/>PyTorch/TensorFlow/MPI]
        RayClusters[Ray Clusters<br/>Distributed Computing]
    end

    %% Platform Orchestration
    RhodsOp -->|manages| Dashboard
    RhodsOp -->|manages| NotebookCtrl
    RhodsOp -->|manages| OdhNotebookCtrl
    RhodsOp -->|manages| DSPO
    RhodsOp -->|manages| KServe
    RhodsOp -->|manages| ModelMesh
    RhodsOp -->|manages| ModelRegistry
    RhodsOp -->|manages| ModelCtrl
    RhodsOp -->|manages| CodeFlare
    RhodsOp -->|manages| KubeRay
    RhodsOp -->|manages| TrainingOp
    RhodsOp -->|manages| Kueue
    RhodsOp -->|manages| TrustyAI

    %% Dashboard Integration
    Dashboard -->|creates| Notebooks
    Dashboard -->|manages| InferenceServices
    Dashboard -->|manages| DSPInstances
    Dashboard -->|integrates| ModelRegistry

    %% Notebook Management
    NotebookCtrl -->|creates StatefulSets| Notebooks
    OdhNotebookCtrl -->|creates Routes/NetworkPolicies| Notebooks

    %% Model Serving
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    KServe -->|integrates| ModelCtrl
    KServe -->|creates| InferenceServices
    ModelMesh -->|integrates| ModelCtrl
    ModelMesh -->|creates| InferenceServices
    ModelCtrl -->|creates Routes/Gateways| InferenceServices

    %% ML Workflows
    DSPO -->|creates| DSPInstances
    DSPO -->|integrates| KServe

    %% Distributed Computing
    CodeFlare -->|manages| KubeRay
    CodeFlare -->|integrates| Kueue
    KubeRay -->|creates| RayClusters
    TrainingOp -->|creates| TrainingJobs
    TrainingOp -->|integrates| Kueue
    Kueue -->|schedules| TrainingJobs
    Kueue -->|schedules| RayClusters

    %% Monitoring
    TrustyAI -->|monitors| InferenceServices
    TrustyAI -->|monitors| ModelMesh

    %% External Dependencies
    Dashboard -->|authenticates via| OAuth
    Notebooks -->|authenticates via| OAuth
    RayClusters -->|authenticates via| OAuth
    All[All Components] -.->|metrics to| Prometheus
    All -.->|API calls| K8sAPI

