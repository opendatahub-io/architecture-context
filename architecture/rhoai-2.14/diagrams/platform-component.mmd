    style ModelMesh fill:#2ecc71,stroke:#333,stroke-width:2px
    style DSPO fill:#9b59b6,stroke:#333,stroke-width:2px
    style CodeFlare fill:#f39c12,stroke:#333,stroke-width:2px
    style KubeRay fill:#f39c12,stroke:#333,stroke-width:2px
    style TrainingOp fill:#f39c12,stroke:#333,stroke-width:2px
    style Kueue fill:#f39c12,stroke:#333,stroke-width:2px
    style TrustyAI fill:#1abc9c,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333
    style Knative fill:#999,stroke:#333
    style OAuth fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
