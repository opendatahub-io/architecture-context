    style ServiceAccounts fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
    style HPAs fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
    style Ingresses fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
