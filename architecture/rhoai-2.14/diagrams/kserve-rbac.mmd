graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "Cluster Role Bindings"
        CRB1[kserve-manager-rolebinding]
        CRB2[kserve-leader-election-rolebinding]
        CRB3[kserve-proxy-rolebinding]
    end

    subgraph "Cluster Roles"
        CR1[kserve-manager-role]
        CR2[kserve-leader-election-role]
        CR3[kserve-proxy-role]
    end

    subgraph "KServe CRDs - serving.kserve.io"
        InferenceService[InferenceService<br/>+ finalizers, status]
        ServingRuntime[ServingRuntime<br/>ClusterServingRuntime<br/>+ finalizers]
        InferenceGraph[InferenceGraph<br/>+ finalizers, status]
        TrainedModel[TrainedModel<br/>+ status]
        ClusterStorage[ClusterStorageContainer]
    end

    subgraph "Knative CRDs - serving.knative.dev"
        KnativeService[Service<br/>+ finalizers, status]
    end

    subgraph "Istio CRDs - networking.istio.io"
        VirtualService[VirtualService<br/>+ finalizers, status]
    end

    subgraph "Kubernetes Core Resources"
        Deployments[Deployments<br/>apps]
        Services[Services<br/>core]
        Secrets[Secrets<br/>core]
        ConfigMaps[ConfigMaps<br/>core]
        Events[Events<br/>core]
        Namespaces[Namespaces<br/>core - read only]
        Pods[Pods<br/>core - read only]
        ServiceAccounts[ServiceAccounts<br/>core - read only]
        HPAs[HorizontalPodAutoscalers<br/>autoscaling]
        Ingresses[Ingresses<br/>networking.k8s.io]
        MutatingWebhooks[MutatingWebhookConfigurations<br/>admissionregistration.k8s.io]
        ValidatingWebhooks[ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io]
    end

    subgraph "Leader Election Resources"
        ConfigMapsLE[ConfigMaps<br/>core - leader election]
        Leases[Leases<br/>coordination.k8s.io]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% Role bindings to roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% kserve-manager-role permissions
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| InferenceService
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| ServingRuntime
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| InferenceGraph
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| TrainedModel
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| ClusterStorage

    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| KnativeService
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| VirtualService

    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Deployments
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Services
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Secrets
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| ConfigMaps
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Events
    CR1 -->|"get, list, watch"| Namespaces
    CR1 -->|"get, list, watch"| Pods
    CR1 -->|"get, list, watch"| ServiceAccounts
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| HPAs
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| Ingresses
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| MutatingWebhooks
    CR1 -->|"create, delete, get<br/>list, patch, update, watch"| ValidatingWebhooks

    %% kserve-leader-election-role permissions
    CR2 -->|"get, update, create"| ConfigMapsLE
    CR2 -->|"get, update, create"| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB3 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style InferenceService fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ServingRuntime fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
