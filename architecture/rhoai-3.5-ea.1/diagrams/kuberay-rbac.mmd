graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>(operator namespace)"]
        HeadSA["{cluster}-head-svc SA<br/>(cluster namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB1["kuberay-operator<br/>(ClusterRoleBinding)"]
        CRB2["kuberay-operator-gateway-api<br/>(ClusterRoleBinding)"]
        CRB3["kuberay-operator-configmap<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB1["kuberay-operator-leader-election<br/>(operator namespace)"]
        RB2["{cluster}-autoscaler<br/>(cluster namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR1["kuberay-operator"]
        CR2["kuberay-operator-gateway-api"]
        CR3["kuberay-operator-configmap"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R1["kuberay-operator-leader-election"]
        R2["{cluster}-autoscaler"]
    end

    %% SA → Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    HeadSA -->|bound via| RB2

    %% Bindings → Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    RB1 -->|grants| R1
    RB2 -->|grants| R2

    %% ClusterRole: kuberay-operator resources
    subgraph CR1Resources["kuberay-operator Resources"]
        direction LR
        CoreRes["core: pods, services,<br/>configmaps, events,<br/>secrets, serviceaccounts,<br/>endpoints"]
        AppsRes["apps: deployments"]
        BatchRes["batch: jobs"]
        RayRes["ray.io: rayclusters,<br/>rayjobs, rayservices<br/>+ /finalizers, /status"]
        CertRes["cert-manager.io:<br/>certificates, issuers<br/>+ /status"]
        GWRes["gateway.networking.k8s.io:<br/>gateways, httproutes,<br/>referencegrants"]
        NetRes["networking.k8s.io:<br/>ingresses, ingressclasses,<br/>networkpolicies"]
        RouteRes["route.openshift.io:<br/>routes"]
        OSConfigRes["config.openshift.io:<br/>authentications, oauths<br/>+ /status"]
        OSOpRes["operator.openshift.io:<br/>kubeapiservers + /status"]
        RBACRes["rbac.authorization.k8s.io:<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
        AuthRes["authentication.k8s.io:<br/>tokenreviews<br/>authorization.k8s.io:<br/>subjectaccessreviews"]
        CoordRes["coordination.k8s.io:<br/>leases"]
        ExtRes["extensions:<br/>ingresses"]
    end

    CR1 -->|"CRUD + watch"| CoreRes
    CR1 -->|"get, list, patch,<br/>update, watch"| AppsRes
    CR1 -->|"CRUD + watch"| BatchRes
    CR1 -->|"CRUD + watch"| RayRes
    CR1 -->|"CRUD + watch"| CertRes
    CR1 -->|"get, list, watch +<br/>CRUD (routes/policies)"| GWRes
    CR1 -->|"CRUD + watch"| NetRes
    CR1 -->|"CRUD + watch"| RouteRes
    CR1 -->|"get, list, watch"| OSConfigRes
    CR1 -->|"get, list, watch"| OSOpRes
    CR1 -->|"get, list, watch +<br/>CRUD roles/bindings"| RBACRes
    CR1 -->|"create"| AuthRes
    CR1 -->|"create, get,<br/>list, update"| CoordRes
    CR1 -->|"CRUD + watch"| ExtRes

    %% ClusterRole: gateway-api resources
    subgraph CR2Resources["gateway-api Resources"]
        GW2Res["gateways: get, list, watch<br/>httproutes: CRUD + watch<br/>referencegrants: CRUD + watch"]
    end
    CR2 -->|"gateway.networking.k8s.io"| GW2Res

    %% ClusterRole: configmap resources
    subgraph CR3Resources["configmap Resources"]
        CM3Res["configmaps:<br/>CRUD + watch"]
    end
    CR3 -->|"core"| CM3Res

    %% Role: leader-election resources
    subgraph R1Resources["leader-election Resources"]
        LE1Res["configmaps, events: CRUD<br/>leases: create, get,<br/>list, update"]
    end
    R1 -->|"core, coordination.k8s.io"| LE1Res

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style HeadSA fill:#4a90e2,stroke:#333,color:#fff
    style CR1 fill:#f5a623,stroke:#333
    style CR2 fill:#f5a623,stroke:#333
    style CR3 fill:#f5a623,stroke:#333
    style R1 fill:#e8a317,stroke:#333
    style R2 fill:#e8a317,stroke:#333
    style CRB1 fill:#b8d4e3,stroke:#333
    style CRB2 fill:#b8d4e3,stroke:#333
    style CRB3 fill:#b8d4e3,stroke:#333
    style RB1 fill:#a8c4d3,stroke:#333
    style RB2 fill:#a8c4d3,stroke:#333
    style RayRes fill:#7ed321,stroke:#333
    style CertRes fill:#7ed321,stroke:#333
    style GWRes fill:#7ed321,stroke:#333
    style AuthRes fill:#ff6b6b,stroke:#333,color:#fff
