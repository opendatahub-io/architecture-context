graph TB
    subgraph TrainingOperator["Training Operator (KFTO)"]
        direction TB

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller"]
            TFCtrl["TFJob Controller"]
            MPICtrl["MPIJob Controller"]
            XGBoostCtrl["XGBoostJob Controller"]
            PaddleCtrl["PaddleJob Controller"]
            JAXCtrl["JAXJob Controller"]
        end

        subgraph Common["Common Controller Base"]
            JobController["Job Controller<br/>(pkg/controller.v1/common)"]
            PodReconciler["Pod Reconciler"]
            ServiceReconciler["Service Reconciler"]
            StatusTracker["Status Tracker"]
            GangScheduler["Gang Scheduling<br/>(PodGroup Control)"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP TLS)"]
            PyTorchWH["PyTorchJob Validator"]
            TFWH["TFJob Validator"]
            XGBoostWH["XGBoostJob Validator"]
            PaddleWH["PaddleJob Validator"]
            JAXWH["JAXJob Validator"]
        end

        CertMgr["Certificate Manager<br/>(cert-controller)"]
        Metrics["Metrics Server<br/>(8080/TCP)"]
        HealthProbes["Health Probes<br/>(8081/TCP)"]
    end

    %% Controller Interface pattern
    PyTorchCtrl -->|implements| JobController
    TFCtrl -->|implements| JobController
    MPICtrl -.->|"own lifecycle<br/>(architectural outlier)"| JobController
    XGBoostCtrl -->|implements| JobController
    PaddleCtrl -->|implements| JobController
    JAXCtrl -->|implements| JobController

    JobController --> PodReconciler
    JobController --> ServiceReconciler
    JobController --> StatusTracker
    JobController --> GangScheduler

    CertMgr -->|"manages TLS certs"| Webhooks

    %% CRDs
    User["User / Data Scientist"] -->|creates| PyTorchJobCR["PyTorchJob CR"]
    User -->|creates| TFJobCR["TFJob CR"]
    User -->|creates| MPIJobCR["MPIJob CR"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR"]
    User -->|creates| PaddleJobCR["PaddleJob CR"]
    User -->|creates| JAXJobCR["JAXJob CR"]

    PyTorchJobCR -->|"validated by"| PyTorchWH
    TFJobCR -->|"validated by"| TFWH
    XGBoostJobCR -->|"validated by"| XGBoostWH
    PaddleJobCR -->|"validated by"| PaddleWH
    JAXJobCR -->|"validated by"| JAXWH

    PyTorchJobCR -->|"watched by"| PyTorchCtrl
    TFJobCR -->|"watched by"| TFCtrl
    MPIJobCR -->|"watched by"| MPICtrl
    XGBoostJobCR -->|"watched by"| XGBoostCtrl
    PaddleJobCR -->|"watched by"| PaddleCtrl
    JAXJobCR -->|"watched by"| JAXCtrl

    %% Created resources
    PodReconciler -->|creates| WorkerPods["Worker/Master Pods"]
    ServiceReconciler -->|creates| HeadlessSvc["Headless Services<br/>(inter-pod DNS)"]
    GangScheduler -->|creates| PodGroup["PodGroup CR<br/>(Volcano / scheduler-plugins)"]

    %% PyTorch-specific
    PyTorchCtrl -->|creates| HPA["HPA<br/>(elastic scaling)"]
    PyTorchCtrl -->|creates| NetPol["NetworkPolicy<br/>(pod isolation)"]

    %% MPI-specific
    MPICtrl -->|creates| ConfigMap["ConfigMap<br/>(hostfile, kubexec.sh)"]
    MPICtrl -->|creates| LauncherPod["Launcher Pod<br/>(+ kubectl init container)"]
    MPICtrl -->|creates| MPISA["ServiceAccount + Role<br/>(pods/exec)"]

    %% External
    JobController -->|"REST API"| K8sAPI["Kubernetes API Server"]
    Metrics -->|"scraped by"| Prometheus["Prometheus / OpenShift Monitoring"]

    %% Styles
    style TrainingOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8d4,stroke:#82b366
    style Common fill:#dae8fc,stroke:#6c8ebf
    style Webhooks fill:#fff2cc,stroke:#d6b656
    style PyTorchCtrl fill:#4a90e2,color:#fff
    style TFCtrl fill:#4a90e2,color:#fff
    style MPICtrl fill:#e06666,color:#fff
    style XGBoostCtrl fill:#4a90e2,color:#fff
    style PaddleCtrl fill:#4a90e2,color:#fff
    style JAXCtrl fill:#4a90e2,color:#fff
    style CertMgr fill:#b4a7d6,stroke:#674ea7
    style Metrics fill:#b4a7d6,stroke:#674ea7
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
    style PyTorchJobCR fill:#f5a623
    style TFJobCR fill:#f5a623
    style MPIJobCR fill:#f5a623
    style XGBoostJobCR fill:#f5a623
    style PaddleJobCR fill:#f5a623
    style JAXJobCR fill:#f5a623
    style HPA fill:#7ed321
    style NetPol fill:#7ed321
    style PodGroup fill:#7ed321
