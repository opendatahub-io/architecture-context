graph LR
    GD["Guardrails Detectors<br/>(3 detector services)"]

    %% Internal RHOAI Dependencies
    GD -->|"called by<br/>REST/HTTP"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployed via<br/>InferenceService CRs"| KServe["KServe"]
    GD -->|"sidecar mTLS<br/>inject: true"| Istio["Istio Service Mesh"]

    %% External Service Dependencies
    GD -->|"model weights<br/>HTTP/9000"| S3["S3/MinIO Storage"]
    GD -->|"LLM evaluation<br/>HTTP/8080"| VLLM["vLLM Inference Server"]

    %% Core Language/Framework Dependencies
    GD -->|"HTTP framework"| FastAPI["FastAPI 0.121.2"]
    GD -->|"ASGI server"| Uvicorn["uvicorn 0.30.5"]
    GD -->|"runtime"| Python["Python 3.x (UBI9)"]

    %% HuggingFace-specific Dependencies
    GD -->|"ML inference<br/>(hf only)"| PyTorch["PyTorch 2.6.0+"]
    GD -->|"model loading<br/>(hf only)"| Transformers["transformers 4.57.1"]
    GD -->|"tokenization<br/>(hf only)"| Sentencepiece["sentencepiece 0.2.1"]
    GD -->|"tokenization<br/>(hf only)"| Tiktoken["tiktoken 0.12.0"]

    %% Judge-specific Dependencies
    GD -->|"LLM judge<br/>(judge only)"| VLLMJudge["vllm-judge 0.1.8"]

    %% Built-in-specific Dependencies
    GD -->|"schema validation<br/>(built-in only)"| JSONSchema["jsonschema 4.24.0"]
    GD -->|"XML validation<br/>(built-in only)"| XMLSchema["xmlschema 4.1.0"]

    %% Monitoring Dependencies
    GD -->|"metrics"| PromClient["prometheus_client"]
    GD -->|"auto-instrument"| PromFastAPI["prometheus-fastapi-<br/>instrumentator"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"scrapes /metrics"| GD
    Dashboard["OpenShift AI Dashboard"] -.->|"dashboard labels"| GD

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% External Infrastructure
    style Istio fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style VLLM fill:#f5a623,stroke:#333
    style Prometheus fill:#999,stroke:#333,color:#fff

    %% Core Dependencies
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style Python fill:#e8e8e8,stroke:#333

    %% ML Dependencies
    style PyTorch fill:#e74c3c,stroke:#333,color:#fff
    style Transformers fill:#e74c3c,stroke:#333,color:#fff
    style Sentencepiece fill:#e8e8e8,stroke:#333
    style Tiktoken fill:#e8e8e8,stroke:#333

    %% Judge Dependencies
    style VLLMJudge fill:#e74c3c,stroke:#333,color:#fff

    %% Built-in Dependencies
    style JSONSchema fill:#e8e8e8,stroke:#333
    style XMLSchema fill:#e8e8e8,stroke:#333

    %% Monitoring Dependencies
    style PromClient fill:#e8e8e8,stroke:#333
    style PromFastAPI fill:#e8e8e8,stroke:#333
