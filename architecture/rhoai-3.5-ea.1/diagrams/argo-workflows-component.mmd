graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        direction TB
        Controller["workflow-controller<br/>Go Service<br/>Ports: 9090 (metrics), 6060 (health)"]
        ArgoExec["argoexec<br/>Sidecar/Init Container<br/>Emissary Executor"]
        Controller -->|"injects into<br/>workflow pods"| ArgoExec
    end

    subgraph CRDs["Custom Resource Definitions (argoproj.io/v1alpha1)"]
        WorkflowCR["Workflow"]
        CronWorkflowCR["CronWorkflow"]
        WorkflowTemplateCR["WorkflowTemplate"]
        ClusterWFTemplate["ClusterWorkflowTemplate"]
        WorkflowTaskSetCR["WorkflowTaskSet"]
        WorkflowTaskResultCR["WorkflowTaskResult"]
        ArtifactGCTask["WorkflowArtifactGCTask"]
        EventBinding["WorkflowEventBinding"]
    end

    User["User / DSP API"] -->|"creates"| WorkflowCR
    User -->|"creates"| CronWorkflowCR
    WorkflowCR -->|"watched by"| Controller
    CronWorkflowCR -->|"watched by"| Controller
    WorkflowTemplateCR -->|"referenced by"| Controller
    ClusterWFTemplate -->|"referenced by"| Controller

    Controller -->|"creates pods for<br/>workflow steps"| WorkflowPod["Workflow Pod"]
    ArgoExec -->|"reports results via"| WorkflowTaskResultCR
    Controller -->|"reads"| WorkflowTaskResultCR
    Controller -->|"manages"| WorkflowTaskSetCR
    Controller -->|"creates"| ArtifactGCTask

    Controller -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    ArgoExec -->|"443/TCP HTTPS"| K8sAPI
    ArgoExec -->|"443/TCP HTTPS"| S3["S3 / Minio<br/>Artifact Storage"]
    Controller -->|"5432/TCP (optional)"| PostgreSQL["PostgreSQL<br/>Workflow Archival"]

    DSPO["Data Science Pipelines<br/>Operator"] -->|"deploys &<br/>configures"| Controller

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ArgoExec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,stroke-width:1px
    style CronWorkflowCR fill:#f5a623,stroke:#333,stroke-width:1px
    style WorkflowTemplateCR fill:#f5a623,stroke:#333,stroke-width:1px
    style ClusterWFTemplate fill:#f5a623,stroke:#333,stroke-width:1px
    style WorkflowTaskSetCR fill:#f5a623,stroke:#333,stroke-width:1px
    style WorkflowTaskResultCR fill:#f5a623,stroke:#333,stroke-width:1px
    style ArtifactGCTask fill:#f5a623,stroke:#333,stroke-width:1px
    style EventBinding fill:#f5a623,stroke:#333,stroke-width:1px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:1px
    style S3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style PostgreSQL fill:#e8e8e8,stroke:#333,stroke-width:1px
    style DSPO fill:#7ed321,stroke:#333,stroke-width:1px
    style User fill:#f9f9f9,stroke:#333,stroke-width:1px
    style WorkflowPod fill:#d5e8d4,stroke:#333,stroke-width:1px
