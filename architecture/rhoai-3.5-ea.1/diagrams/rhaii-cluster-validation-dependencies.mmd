graph LR
    Validator["RHAII Cluster Validation<br/>rhaii-validator"]

    %% External Dependencies (Required)
    Validator -->|"Job CRUD, RBAC,<br/>node discovery"| K8sAPI["Kubernetes API<br/>v1.28+"]
    Validator -->|"nvidia-smi<br/>driver ≥ 535.0"| NVIDIADriver["NVIDIA GPU Driver"]
    Validator -->|"rocm-smi<br/>driver ≥ 535.0"| AMDDriver["AMD ROCm Driver"]
    Validator -->|"device injection<br/>libcuda.so.1"| NVIDIAToolkit["NVIDIA Container<br/>Toolkit"]
    Validator -->|"ibv_devices, ibstat<br/>sysfs discovery"| RDMASubsystem["InfiniBand / RDMA<br/>Subsystem"]
    Validator -->|"TCP bandwidth<br/>5201/TCP"| Iperf3["iperf3"]
    Validator -->|"RDMA bandwidth<br/>CUDA GPUDirect"| Perftest["perftest<br/>(ib_write_bw)<br/>v25.10.0"]

    %% Internal Platform Dependencies (Validated)
    Validator -.->|"CRD existence check"| GatewayAPI["Gateway API CRDs<br/>gateways, httproutes"]
    Validator -.->|"CRD existence check"| InferencePool["InferencePool CRD<br/>inference.networking"]
    Validator -.->|"CRD existence check"| LWS_CRD["LeaderWorkerSet CRD"]
    Validator -.->|"CRD existence check"| CertManagerCRD["cert-manager CRD"]
    Validator -.->|"operator health check"| CertManagerOp["cert-manager Operator<br/>NS: cert-manager"]
    Validator -.->|"operator health check"| IstioOp["Istio Service Mesh<br/>NS: istio-system"]
    Validator -.->|"operator health check"| LWSOperator["LWS Operator<br/>NS: openshift-lws-operator"]

    %% Host-Level Dependencies
    Validator -->|"hostPath /<br/>sysfs, PCI"| HostFS["Host Filesystem<br/>/sys/class/infiniband<br/>/dev/infiniband"]
    Validator -->|"hostPID=true<br/>topology checks"| HostPID["Host PID Namespace"]
    Validator -->|"node labels<br/>nvidia.com/gpu.present"| GPUDevicePlugin["GPU Device Plugin<br/>(NVIDIA / AMD)"]
    Validator -->|"rdma/* resources"| RDMADevicePlugin["RDMA Device Plugin"]
    Validator -->|"SCC: privileged<br/>(OCP only)"| OpenShiftSCC["OpenShift SCC"]

    style Validator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External - gray
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style NVIDIADriver fill:#999,stroke:#333,color:#fff
    style AMDDriver fill:#999,stroke:#333,color:#fff
    style NVIDIAToolkit fill:#999,stroke:#333,color:#fff
    style RDMASubsystem fill:#999,stroke:#333,color:#fff
    style Iperf3 fill:#999,stroke:#333,color:#fff
    style Perftest fill:#999,stroke:#333,color:#fff
    style HostFS fill:#999,stroke:#333,color:#fff
    style HostPID fill:#999,stroke:#333,color:#fff
    style GPUDevicePlugin fill:#999,stroke:#333,color:#fff
    style RDMADevicePlugin fill:#999,stroke:#333,color:#fff
    style OpenShiftSCC fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI - green
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style LWS_CRD fill:#7ed321,stroke:#333,color:#fff
    style CertManagerCRD fill:#7ed321,stroke:#333,color:#fff
