graph TB
    subgraph Container["kube-auth-proxy Container Image<br/>(rhoai/odh-kube-auth-proxy-rhel9)"]
        direction TB
        Entrypoint["entrypoint<br/>(Go Binary)<br/>Mode Selector"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>(Go Service)<br/>Port: 4180/TCP"]
            SessionMgmt["Session Management<br/>(Cookie / Redis)"]
            AuthChain["Authentication Chain<br/>1. K8s TokenReview<br/>2. OpenShift OAuth (sha256~)<br/>3. JWT Bearer<br/>4. Basic Auth (htpasswd)<br/>5. Stored Sessions"]
            AuthProxy --> SessionMgmt
            AuthProxy --> AuthChain
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            RBACProxy["kube-rbac-proxy<br/>(Go Service)<br/>Port: 8443/TCP HTTPS"]
            AuthzChain["Authorization Chain<br/>1. Hardcoded Prometheus SA<br/>2. Static Authorizer<br/>3. SubjectAccessReview"]
            RBACProxy --> AuthzChain
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac<br/>(default)"| RBACProxy
    end

    %% External Clients
    Browser["Client Browser"] -->|"HTTP/HTTPS<br/>4180/TCP"| AuthProxy
    ServicePod["Service / Pod"] -->|"HTTPS<br/>8443/TCP<br/>Bearer/Client Cert"| RBACProxy

    %% OAuth2 Endpoints
    subgraph OAuth2Endpoints["OAuth2 Endpoints (Auth Mode)"]
        SignIn["/oauth2/sign_in"]
        Start["/oauth2/start"]
        Callback["/oauth2/callback"]
        AuthCheck["/oauth2/auth<br/>(ext_authz)"]
        UserInfo["/oauth2/userinfo"]
        SignOut["/oauth2/sign_out"]
    end
    AuthProxy --- OAuth2Endpoints

    %% Upstream
    Upstream["Upstream RHOAI<br/>Component Service"]
    AuthProxy -->|"Forward<br/>(post-auth)<br/>Headers injected"| Upstream
    RBACProxy -->|"Forward<br/>(post-authz)"| Upstream

    %% External Dependencies
    OIDC["OIDC Provider<br/>443/TCP HTTPS"]
    OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS"]
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Redis["Redis (optional)<br/>6379/TCP"]

    AuthProxy -->|"OIDC Discovery<br/>Token Exchange"| OIDC
    AuthProxy -->|"OAuth Discovery<br/>Token Exchange"| OAuthServer
    AuthProxy -->|"TokenReview"| K8sAPI
    AuthProxy -.->|"Sessions"| Redis
    RBACProxy -->|"TokenReview +<br/>SubjectAccessReview"| K8sAPI

    %% Monitoring
    Prometheus["OpenShift Monitoring<br/>(Prometheus)"] -.->|"Metrics scraping"| RBACProxy

    %% Styling
    style Container fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style AuthMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RBACMode fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Entrypoint fill:#4a90e2,color:#fff,stroke:#333
    style AuthProxy fill:#4a90e2,color:#fff,stroke:#333
    style RBACProxy fill:#4a90e2,color:#fff,stroke:#333
    style AuthChain fill:#f0f0f0,stroke:#999
    style AuthzChain fill:#f0f0f0,stroke:#999
    style SessionMgmt fill:#f0f0f0,stroke:#999
    style OAuth2Endpoints fill:#f5f5f5,stroke:#ccc
    style Upstream fill:#7ed321,stroke:#333
    style OIDC fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
