graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>Bearer Token"]
        NVIDIAAuth["NVIDIA Auth<br/>authn.nvidia.com<br/>443/TCP HTTPS<br/>Basic Auth"]
        NVCR["NVIDIA Registry<br/>nvcr.io<br/>443/TCP HTTPS<br/>Docker Auth"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Dynamic)"]
        Route["{isvc-name} Route<br/>443/TCP → runtime-specific<br/>TLS Edge/Re-encrypt<br/>Per-route auth config"]
    end

    subgraph ClusterInternal["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            direction TB

            subgraph ControllerPod["odh-model-controller Pod"]
                Controller["odh-model-controller<br/>SA: odh-model-controller<br/>Image: odh-model-controller-container"]
                ControllerHealth["Health: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP<br/>Webhook: 9443/TCP HTTPS"]
            end

            subgraph APIPod["model-serving-api Pod"]
                APIServer["model-serving-api<br/>SA: model-serving-api<br/>Image: odh-model-serving-api-container"]
                APIHealth["API: 8443/TCP HTTPS<br/>Metrics: 8080/TCP HTTPS"]
            end

            WebhookSvc["webhook-service<br/>ClusterIP 443→9443<br/>HTTPS (webhook cert)"]
            MetricsSvc["metrics-service<br/>ClusterIP 8443<br/>HTTPS TLS 1.2+"]
            APISvc["model-serving-api<br/>ClusterIP 443→8443<br/>HTTPS TLS 1.2+<br/>FIPS ciphers (ECDHE+AES-GCM)<br/>Curves: P-256, P-384"]
            APIMetricsSvc["api-metrics<br/>ClusterIP 8080<br/>HTTPS TLS 1.2+"]
        end

        subgraph NS_User["Namespace: {user-namespace} (dynamic)"]
            ISVCMetrics["{isvc-name}-metrics<br/>ClusterIP (runtime-specific)<br/>HTTP No Auth"]
        end
    end

    subgraph InternalConsumers["INTERNAL CONSUMERS"]
        Dashboard["RHOAI Dashboard"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus Operator"]
        ModelRegistry["Model Registry<br/>varies/TCP<br/>HTTP/HTTPS<br/>Bearer Token"]
    end

    %% External client to route
    Client -->|"HTTPS/443<br/>TLS Edge/Re-encrypt<br/>Per-route auth"| Route
    Route -->|"HTTP/HTTPS<br/>internal routing"| NS_User

    %% Dashboard to API
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+ FIPS<br/>Bearer Token (JWT)"| APISvc

    %% Controller egress
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NGC
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Basic Auth"| NVIDIAAuth
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker $oauthtoken"| NVCR
    Controller -->|"HTTP(S)/varies<br/>Optional TLS<br/>Bearer Token"| ModelRegistry

    %% API server egress
    APIServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token + User Token (SSAR)"| K8sAPI

    %% K8s API to webhooks
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (webhook cert)<br/>K8s client cert"| WebhookSvc

    %% Prometheus scraping
    Prometheus -->|"HTTP/8080<br/>SA authn/authz"| ControllerHealth
    Prometheus -->|"HTTPS/8080<br/>TLS 1.2+"| APIMetricsSvc
    Prometheus -->|"HTTP<br/>No Auth"| ISVCMetrics

    %% Internal service wiring
    WebhookSvc -.->|internal| Controller
    MetricsSvc -.->|internal| Controller
    APISvc -.->|internal| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef consumer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef nvidia fill:#76b900,stroke:#333,color:#fff

    class Client external
    class Route ingress
    class Controller,APIServer,WebhookSvc,MetricsSvc,APISvc,APIMetricsSvc,ISVCMetrics clusterinternal
    class Dashboard,K8sAPI,Prometheus,ModelRegistry consumer
    class NGC,NVIDIAAuth,NVCR nvidia
