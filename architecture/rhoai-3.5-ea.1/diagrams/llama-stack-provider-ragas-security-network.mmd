graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Client"]
    end

    subgraph Application["APPLICATION (Llama Stack Server)"]
        direction TB
        LLS["Llama Stack Server<br/>ClusterIP 8321/TCP<br/>HTTP, No TLS<br/>Auth: None"]

        subgraph InlineMode["Inline Provider (in-process)"]
            InlineEval["RagasEvaluatorInline<br/>In-process Python<br/>No separate network identity"]
        end

        subgraph RemoteMode["Remote Provider (orchestrator)"]
            RemoteEval["RagasEvaluatorRemote<br/>In-process Python<br/>Submits KFP pipelines"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        KFP["Kubeflow Pipelines API<br/>(Data Science Pipelines)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (OAuth)"]

        subgraph KFPPods["KFP Pipeline Pods"]
            KFPStep1["Step 1: retrieve_data<br/>Image: odh-trustyai-ragas-<br/>lls-provider-dsp-rhel9"]
            KFPStep2["Step 2: run_ragas_eval<br/>Secrets injected via KFP:<br/>S3 creds, inference config"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token / kubeconfig"]

        InferenceBackend["Ollama / vLLM<br/>11434/TCP HTTP<br/>Encryption: Configurable<br/>Auth: Bearer Token or None"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM (AccessKey/SecretKey)"]
    end

    %% External to Application
    Client -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LLS

    %% Internal application flows
    LLS -->|"in-process<br/>Python call"| InlineEval
    LLS -->|"in-process<br/>Python call"| RemoteEval

    %% Inline mode flows
    InlineEval -->|"in-process API<br/>LLM + Embeddings"| LLS

    %% Remote mode flows
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth)"| KFP
    RemoteEval -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% KFP pipeline pod flows
    KFP -->|"schedules"| KFPStep1
    KFPStep1 -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LLS
    KFPStep1 -->|"dataset"| KFPStep2
    KFPStep2 -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LLS
    KFPStep2 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Inference backend
    LLS -->|"HTTP/11434<br/>Configurable TLS<br/>Bearer Token or None"| InferenceBackend

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef provider fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kfppod fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class LLS application
    class InlineEval,RemoteEval provider
    class KFP,K8sAPI,InferenceBackend cluster
    class KFPStep1,KFPStep2 kfppod
    class S3 externalservice
