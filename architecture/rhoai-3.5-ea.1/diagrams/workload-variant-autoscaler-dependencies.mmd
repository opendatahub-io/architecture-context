graph LR
    WVA["Workload Variant<br/>Autoscaler"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>9090-9091/TCP HTTPS<br/>REQUIRED"| Prometheus["Prometheus /<br/>Thanos Querier"]

    %% External Dependencies (Optional)
    WVA -.->|"reads custom metrics<br/>OPTIONAL"| KEDA["KEDA v2.18.0+"]
    WVA -.->|"reads custom metrics<br/>OPTIONAL"| HPA["HPA v2"]
    WVA -.->|"GPU node labels<br/>OPTIONAL"| GFD["GPU Feature<br/>Discovery (GFD)"]
    WVA -.->|"multi-worker targets<br/>OPTIONAL (CRD detected)"| LWS["LeaderWorkerSet<br/>(LWS) v1"]
    WVA -.->|"bridges metrics<br/>OPTIONAL"| PromAdapter["Prometheus<br/>Adapter"]

    %% Internal Platform Dependencies
    WVA -->|"CRD Watch<br/>InferencePool"| InferencePool["Gateway API<br/>Inference Extension"]
    WVA -->|"indirect via<br/>Prometheus metrics"| vLLM["vLLM / Model<br/>Servers"]

    %% Kubernetes API Dependencies
    WVA -->|"watch, patch, scale<br/>443/TCP HTTPS"| Deployments["Deployments<br/>(apps/v1)"]
    WVA -->|"watch, patch<br/>443/TCP HTTPS"| Nodes["Nodes<br/>(core/v1)"]
    WVA -->|"watch, get, update<br/>443/TCP HTTPS"| ConfigMaps["ConfigMaps<br/>(core/v1)"]

    %% Integration - Consumers of WVA metrics
    PromAdapter -->|"custom metrics API"| HPA
    Prometheus -->|"ScaledObject query"| KEDA

    %% Scaling chain
    HPA -->|"scale subresource"| Deployments
    KEDA -->|"scale subresource"| Deployments

    %% vLLM → Prometheus
    vLLM -->|"emit metrics"| Prometheus

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style HPA fill:#999,stroke:#333,color:#fff
    style GFD fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style PromAdapter fill:#999,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#f5a623,stroke:#333
    style Nodes fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
