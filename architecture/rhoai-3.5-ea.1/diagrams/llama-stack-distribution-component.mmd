graph TB
    subgraph OGX["OGX Distribution (odh-ogx-core)"]
        direction TB
        Server["OGX Server<br/>Port 8321/TCP<br/>Python / FastAPI / uvicorn"]

        subgraph APIs["REST API Endpoints"]
            Health["/v1/health"]
            Models["/v1/models"]
            Chat["/v1/chat/completions"]
            Embeddings["/v1/embeddings"]
            Inference["/inference/*"]
            Responses["/responses/*"]
            Batches["/batches/*"]
            VectorIO["/vector_io/*"]
            Files["/files/*"]
            ToolRuntime["/tool_runtime/*"]
        end

        subgraph Providers["Provider Framework"]
            InferenceProviders["Inference Providers<br/>(vLLM, Bedrock, watsonx,<br/>Azure, Vertex AI, OpenAI)"]
            EmbeddingProviders["Embedding Providers<br/>(vLLM, sentence-transformers)"]
            VectorProviders["Vector Providers<br/>(Milvus, FAISS, pgvector, Qdrant)"]
            StorageProviders["Storage Providers<br/>(Local FS, S3)"]
            ToolProviders["Tool Providers<br/>(Brave, Tavily, MCP)"]
        end

        AuthMiddleware["OAuth2 JWT Auth Middleware<br/>(conditional via AUTH_ISSUER)"]

        Server --> AuthMiddleware
        AuthMiddleware --> APIs
        Chat --> InferenceProviders
        Embeddings --> EmbeddingProviders
        VectorIO --> VectorProviders
        Files --> StorageProviders
        ToolRuntime --> ToolProviders
        Responses --> InferenceProviders
        Batches --> InferenceProviders
    end

    Client["Client"] -->|"HTTPS/443<br/>Bearer JWT"| Gateway["RHOAI Gateway<br/>(Envoy)"]
    Gateway -->|"HTTPS/8443"| KRBP["kube-rbac-proxy<br/>sidecar"]
    KRBP -->|"HTTP/8321<br/>localhost"| Server

    InferenceProviders -->|"HTTP(S)"| vLLM["vLLM Inference Server"]
    EmbeddingProviders -->|"HTTP(S)"| vLLMEmbed["vLLM Embedding Server"]
    InferenceProviders -->|"HTTPS/443"| CloudLLMs["Cloud LLM APIs<br/>(Bedrock, watsonx,<br/>Azure, Vertex AI, OpenAI)"]
    VectorProviders -->|"TCP/gRPC"| VectorDBs["Vector Databases<br/>(Milvus, pgvector, Qdrant)"]
    StorageProviders -->|"HTTPS/443"| S3["S3 / S3-compatible"]
    ToolProviders -->|"HTTPS/443"| SearchAPIs["Search APIs<br/>(Brave, Tavily)"]

    Server -->|"TCP/5432"| PostgreSQL["PostgreSQL<br/>(KV store, SQL store,<br/>agent state, logs)"]

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style AuthMiddleware fill:#e8744f,stroke:#333,color:#fff
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KRBP fill:#ffe6cc,stroke:#d79b00
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333
    style vLLMEmbed fill:#7ed321,stroke:#333
    style CloudLLMs fill:#999,stroke:#333,color:#fff
    style VectorDBs fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style SearchAPIs fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
