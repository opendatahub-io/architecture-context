graph TD
    subgraph SA_NBC["Service Accounts"]
        SA1["notebook-controller-<br/>service-account<br/>(opendatahub ns)"]
        SA2["odh-notebook-controller-<br/>manager<br/>(opendatahub ns)"]
        SA3["{notebook-name}<br/>(user namespace)<br/>[per notebook]"]
    end

    subgraph CRB_NBC["ClusterRole Bindings"]
        CRB1["notebook-controller-<br/>role-binding"]
        CRB2["notebook-controller-<br/>proxy-rolebinding"]
        CRB3["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB4["{notebook-name}-rbac-<br/>{namespace}-auth-delegator<br/>[per notebook]"]
    end

    subgraph CR_NBC["ClusterRoles"]
        CR1["notebook-controller-role"]
        CR2["notebook-controller-proxy-role"]
        CR3["odh-notebook-controller-<br/>manager-role"]
        CR4["system:auth-delegator"]
    end

    %% SA → CRB → CR links
    SA1 -->|"bound via"| CRB1
    SA1 -->|"bound via"| CRB2
    CRB1 -->|"grants"| CR1
    CRB2 -->|"grants"| CR2

    SA2 -->|"bound via"| CRB3
    CRB3 -->|"grants"| CR3

    SA3 -->|"bound via"| CRB4
    CRB4 -->|"grants"| CR4

    subgraph Resources_CR1["notebook-controller-role Resources"]
        R1_events["core/events<br/>create, get, list,<br/>patch, watch"]
        R1_pods["core/pods<br/>delete, get, list, watch"]
        R1_services["core/services<br/>* (all verbs)"]
        R1_sts["apps/statefulsets<br/>* (all verbs)"]
        R1_nb["kubeflow.org/notebooks<br/>notebooks/finalizers<br/>notebooks/status<br/>* (all verbs)"]
        R1_vs["networking.istio.io<br/>/virtualservices<br/>* (all verbs)"]
    end

    CR1 -->|"permits"| R1_events
    CR1 -->|"permits"| R1_pods
    CR1 -->|"permits"| R1_services
    CR1 -->|"permits"| R1_sts
    CR1 -->|"permits"| R1_nb
    CR1 -->|"permits"| R1_vs

    subgraph Resources_CR2["notebook-controller-proxy-role Resources"]
        R2_tr["authentication.k8s.io<br/>/tokenreviews<br/>create"]
        R2_sar["authorization.k8s.io<br/>/subjectaccessreviews<br/>create"]
    end

    CR2 -->|"permits"| R2_tr
    CR2 -->|"permits"| R2_sar

    subgraph Resources_CR3["odh-notebook-controller-manager-role Resources"]
        R3_core["core: configmaps, secrets,<br/>serviceaccounts, services, events<br/>get, list, watch, create,<br/>update, patch"]
        R3_auth["authentication.k8s.io<br/>/tokenreviews (create)<br/>authorization.k8s.io<br/>/subjectaccessreviews (create)"]
        R3_proxy["config.openshift.io/proxies<br/>get, list, watch"]
        R3_dspa["datasciencepipelines<br/>applications.opendatahub.io<br/>dspa, dspa/api<br/>get, list, watch, create,<br/>update, patch, delete"]
        R3_gw["gateway.networking.k8s.io<br/>gateways (get, list, watch)<br/>httproutes (full CRUD)<br/>referencegrants (full CRUD)"]
        R3_is["image.openshift.io<br/>/imagestreams<br/>list, get, watch"]
        R3_nb["kubeflow.org/notebooks<br/>notebooks/finalizers<br/>notebooks/status<br/>get, list, watch, patch, update"]
        R3_np["networking.k8s.io<br/>/networkpolicies<br/>get, list, watch,<br/>create, update, patch"]
        R3_oauth["oauth.openshift.io<br/>/oauthclients<br/>get, list, watch,<br/>update, patch, delete"]
        R3_rbac["rbac.authorization.k8s.io<br/>clusterrolebindings (full CRUD)<br/>clusterroles (get)<br/>rolebindings (full CRUD)<br/>roles (get, list, watch,<br/>create, update, patch)"]
        R3_route["route.openshift.io/routes<br/>get, list, watch"]
    end

    CR3 -->|"permits"| R3_core
    CR3 -->|"permits"| R3_auth
    CR3 -->|"permits"| R3_proxy
    CR3 -->|"permits"| R3_dspa
    CR3 -->|"permits"| R3_gw
    CR3 -->|"permits"| R3_is
    CR3 -->|"permits"| R3_nb
    CR3 -->|"permits"| R3_np
    CR3 -->|"permits"| R3_oauth
    CR3 -->|"permits"| R3_rbac
    CR3 -->|"permits"| R3_route

    subgraph PerNotebookRB["Per-Notebook RoleBindings (user namespace)"]
        RB_pipeline["elyra-pipelines-{notebook-name}<br/>→ ds-pipeline-user-access-dspa<br/>(if DSPA enabled)"]
        RB_mlflow["{notebook-name}-mlflow<br/>→ mlflow-operator-mlflow-integration<br/>(if MLflow enabled)"]
    end

    SA3 -->|"bound via"| RB_pipeline
    SA3 -->|"bound via"| RB_mlflow

    subgraph AggRoles["Aggregation ClusterRoles"]
        AGG_admin["kubeflow-notebooks-admin<br/>notebooks-admin<br/>→ aggregated to admin"]
        AGG_edit["kubeflow-notebooks-edit<br/>notebooks-edit<br/>get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"]
        AGG_view["kubeflow-notebooks-view<br/>notebooks-view<br/>get, list, watch"]
    end

    %% Styling
    style SA1 fill:#4a90e2,color:#fff
    style SA2 fill:#4a90e2,color:#fff
    style SA3 fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623,color:#fff
    style CR2 fill:#f5a623,color:#fff
    style CR3 fill:#f5a623,color:#fff
    style CR4 fill:#f5a623,color:#fff
    style CRB1 fill:#e8e8e8
    style CRB2 fill:#e8e8e8
    style CRB3 fill:#e8e8e8
    style CRB4 fill:#e8e8e8
    style AGG_admin fill:#7ed321,color:#fff
    style AGG_edit fill:#7ed321,color:#fff
    style AGG_view fill:#7ed321,color:#fff
