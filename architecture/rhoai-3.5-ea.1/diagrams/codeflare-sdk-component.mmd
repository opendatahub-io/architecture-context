graph TB
    subgraph SDK["CodeFlare SDK (Python Client Library)"]
        direction TB
        subgraph CoreModules["Core Modules"]
            Cluster["Cluster<br/>ClusterConfiguration<br/>(ray/cluster/)"]
            RayJobModule["RayJob<br/>ManagedClusterConfig<br/>(ray/rayjobs/)"]
            Auth["kube-authkit Integration<br/>(common/kubernetes_cluster/auth.py)"]
        end

        subgraph Utilities["Utilities"]
            TLSGen["TLS Certificate Generator<br/>(common/utils/generate_cert.py)<br/>RSA-3072, SHA-256"]
            BuildRC["RayCluster Builder<br/>(ray/cluster/build_ray_cluster.py)"]
            KueueUtil["Kueue Utilities<br/>(common/kueue/kueue.py)"]
            Widgets["Jupyter Notebook Widgets<br/>(common/widgets/widgets.py)"]
        end

        subgraph Vendored["Vendored Libraries"]
            KubeRayClient["KubeRay Python Client<br/>(vendored/python_client/)<br/>RayClusterApi, RayjobApi"]
        end

        Cluster -->|builds CR| BuildRC
        Cluster -->|manages TLS| TLSGen
        Cluster -->|checks queues| KueueUtil
        Cluster -->|displays status| Widgets
        RayJobModule -->|builds cluster spec| BuildRC
        RayJobModule -->|validates queues| KueueUtil
        Cluster -->|uses| KubeRayClient
        RayJobModule -->|uses| KubeRayClient
        Cluster -->|authenticates via| Auth
        RayJobModule -->|authenticates via| Auth
    end

    User["Data Scientist / ML Engineer<br/>(Jupyter Notebook or Script)"]
    User -->|creates| Cluster
    User -->|submits| RayJobModule

    subgraph K8sResources["Kubernetes Resources Created"]
        RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
        RayJobCR["RayJob CR<br/>(ray.io/v1)"]
        FileSecret["File Secret<br/>({rayjob}-files)"]
    end

    BuildRC -->|generates| RayClusterCR
    RayJobModule -->|generates| RayJobCR
    RayJobModule -->|packages files into| FileSecret

    subgraph Platform["Platform Dependencies"]
        KubeRayOp["KubeRay Operator"]
        KueueCtrl["Kueue Controller"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    end

    RayClusterCR -->|reconciled by| KubeRayOp
    RayJobCR -->|reconciled by| KubeRayOp
    KubeRayClient -->|CRUD via| K8sAPI
    Auth -->|authenticates to| K8sAPI
    KueueUtil -->|reads queues from| K8sAPI

    subgraph RayCluster["Ray Cluster (Created Pods)"]
        HeadPod["Ray Head Pod<br/>Ports: 6379, 8265, 10001"]
        WorkerPods["Ray Worker Pods"]
    end

    KubeRayOp -->|creates| HeadPod
    KubeRayOp -->|creates| WorkerPods
    TLSGen -->|mTLS certs for| HeadPod

    style SDK fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CoreModules fill:#bbdefb,stroke:#1565c0
    style Utilities fill:#bbdefb,stroke:#1565c0
    style Vendored fill:#bbdefb,stroke:#1565c0
    style K8sResources fill:#fff3e0,stroke:#e65100
