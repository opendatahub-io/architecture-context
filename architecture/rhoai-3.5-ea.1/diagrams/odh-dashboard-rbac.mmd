graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Main["odh-dashboard<br/>(main dashboard + kube-rbac-proxy)"]
        SA_Modules["odh-dashboard-modules<br/>(BFF sidecar containers)"]
    end

    subgraph MainBindings["ClusterRole Bindings (odh-dashboard)"]
        CRB_Main["odh-dashboard<br/>ClusterRoleBinding"]
        CRB_Auth["odh-dashboard-auth-delegator<br/>ClusterRoleBinding"]
        CRB_Monitor["odh-dashboard-monitoring<br/>ClusterRoleBinding"]
    end

    subgraph ModuleBindings["ClusterRole Bindings (odh-dashboard-modules)"]
        CRB_Modules["odh-dashboard-modules<br/>ClusterRoleBinding"]
    end

    subgraph MainRole["ClusterRole: odh-dashboard"]
        direction LR
        subgraph CoreK8s["Core Kubernetes"]
            Nodes["nodes<br/>get, list"]
            ConfigMaps["configmaps, PVCs, secrets<br/>create, delete, get, list,<br/>patch, update, watch"]
            Pods["pods, SAs, services<br/>get, list, watch"]
            Namespaces["namespaces<br/>patch"]
            Events["events<br/>get, list, watch"]
            Endpoints["endpoints<br/>get"]
        end

        subgraph RBACPerms["RBAC Management"]
            RoleBindings["rolebindings, CRBs, roles<br/>list, get, create, patch, delete"]
            TokenReviews["tokenreviews<br/>create"]
            SAR["subjectaccessreviews<br/>create"]
        end

        subgraph OpenShift["OpenShift APIs"]
            Storage["storageclasses<br/>update, patch"]
            Machines["machineautoscalers, machinesets<br/>get, list"]
            ClusterVer["clusterversions, ingresses<br/>get, watch, list"]
            OLM_Perms["CSVs, subscriptions<br/>get, list, watch"]
            ImageStreams["imagestreams/layers<br/>get"]
            Routes["routes<br/>get, list, watch"]
            ConsoleLinks["consolelinks<br/>get, list, watch"]
            Users["users, groups<br/>get, list, watch"]
        end

        subgraph RHOAI["RHOAI CRDs"]
            Notebooks["kubeflow.org/notebooks<br/>get, list, watch, create,<br/>update, patch, delete"]
            DSC["datascienceclusters<br/>list, watch, get"]
            DSCI["dscinitializations<br/>list, watch, get"]
            InferSvc["inferenceservices<br/>get, list, watch"]
            ModelRegs["modelregistries<br/>get, list, watch, create,<br/>update, patch, delete"]
            Auths["services.platform/auths<br/>get"]
            OGXServers["ogx.io/ogxservers<br/>get, list, watch"]
            Guardrails["guardrailsorchestrators,<br/>evalhubs<br/>get, list, watch"]
            FeatureStores["feast.dev/featurestores<br/>get, list, watch"]
            MLflows["mlflow/mlflows<br/>get, list, watch"]
        end
    end

    subgraph SystemRoles["System ClusterRoles"]
        AuthDelegator["system:auth-delegator"]
        MonitorView["cluster-monitoring-view"]
    end

    subgraph ModulesRole["ClusterRole: odh-dashboard-modules (limited)"]
        Mod_MLflow["mlflow/mlflows<br/>get, list, watch"]
        Mod_Ingress["config.openshift.io/ingresses<br/>get, list, watch"]
        Mod_SAR["subjectaccessreviews<br/>create"]
    end

    %% Main SA bindings
    SA_Main -->|"bound via"| CRB_Main
    SA_Main -->|"bound via"| CRB_Auth
    SA_Main -->|"bound via"| CRB_Monitor

    CRB_Main -->|"grants"| MainRole
    CRB_Auth -->|"grants"| AuthDelegator
    CRB_Monitor -->|"grants"| MonitorView

    %% Modules SA bindings
    SA_Modules -->|"bound via"| CRB_Modules
    CRB_Modules -->|"grants"| ModulesRole

    %% Styling
    style SA_Main fill:#4a90e2,stroke:#333,color:#fff
    style SA_Modules fill:#27ae60,stroke:#333,color:#fff
    style CRB_Main fill:#f5a623,stroke:#333,color:#fff
    style CRB_Auth fill:#f5a623,stroke:#333,color:#fff
    style CRB_Monitor fill:#f5a623,stroke:#333,color:#fff
    style CRB_Modules fill:#f5a623,stroke:#333,color:#fff
    style AuthDelegator fill:#95a5a6,stroke:#333,color:#fff
    style MonitorView fill:#95a5a6,stroke:#333,color:#fff

    style Notebooks fill:#7ed321,stroke:#333,color:#fff
    style ModelRegs fill:#7ed321,stroke:#333,color:#fff
    style InferSvc fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333,color:#fff
    style Guardrails fill:#7ed321,stroke:#333,color:#fff
    style FeatureStores fill:#7ed321,stroke:#333,color:#fff
    style MLflows fill:#7ed321,stroke:#333,color:#fff
    style OGXServers fill:#7ed321,stroke:#333,color:#fff
    style Auths fill:#7ed321,stroke:#333,color:#fff

    style RoleBindings fill:#e74c3c,stroke:#333,color:#fff
    style TokenReviews fill:#e74c3c,stroke:#333,color:#fff
    style SAR fill:#e74c3c,stroke:#333,color:#fff

    style Mod_MLflow fill:#27ae60,stroke:#333,color:#fff
    style Mod_Ingress fill:#27ae60,stroke:#333,color:#fff
    style Mod_SAR fill:#27ae60,stroke:#333,color:#fff
