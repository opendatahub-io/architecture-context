graph TB
    subgraph OGX["OGX Distribution (odh-ogx-core)"]
        direction TB
        Entrypoint["entrypoint.sh<br/>Launches OGX server"]
        Server["OGX Server<br/>FastAPI + Uvicorn<br/>Port 8321/TCP"]
        BuildTool["build.py<br/>Code Generator"]
        Config["config.yaml<br/>Runtime Config"]
        BuildYAML["build.yaml<br/>Declarative Manifest"]

        BuildYAML -->|generates via| BuildTool
        BuildTool -->|produces| Config
        Entrypoint -->|starts| Server
        Server -->|loads| Config
    end

    subgraph APIs["OpenAI-Compatible API (8321/TCP)"]
        Health["/v1/health<br/>GET - No Auth"]
        Models["/v1/models<br/>GET"]
        Chat["/v1/chat/completions<br/>POST"]
        Embeddings["/v1/embeddings<br/>POST"]
        Responses["/v1/responses<br/>POST"]
        Batches["/v1/batches<br/>POST"]
        Files["/v1/files<br/>POST"]
        VectorStores["/v1/vector_stores<br/>POST"]
    end

    subgraph InferenceProviders["Inference Providers"]
        vLLM["vLLM<br/>(Primary)"]
        Bedrock["AWS Bedrock"]
        VertexAI["Google Vertex AI"]
        AzureOAI["Azure OpenAI"]
        Watsonx["IBM watsonx"]
        OpenAI["OpenAI API"]
    end

    subgraph VectorDBs["Vector Databases"]
        Milvus["Milvus"]
        PGVector["pgvector"]
        Qdrant["Qdrant"]
        FAISS["FAISS (inline)"]
    end

    subgraph Storage["Storage & Tools"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>KV + SQL + Logs"]
        S3["S3 Storage"]
        BraveSearch["Brave Search"]
        TavilySearch["Tavily Search"]
        MCP["MCP Servers"]
    end

    Client[Client] -->|HTTP 8321/TCP<br/>OAuth2 Token optional| Server
    Server --> APIs

    Server -->|HTTP/HTTPS<br/>Bearer Token| vLLM
    Server -->|HTTPS/443<br/>Bearer Token| Bedrock
    Server -->|HTTPS/443<br/>ADC| VertexAI
    Server -->|HTTPS/443<br/>API Key| AzureOAI
    Server -->|HTTPS/443<br/>API Key| Watsonx
    Server -->|HTTPS/443<br/>API Key| OpenAI

    Server -->|TCP<br/>Token| Milvus
    Server -->|PostgreSQL/5432<br/>Password| PGVector
    Server -->|HTTP+gRPC<br/>6333+6334| Qdrant
    Server -.->|inline| FAISS

    Server -->|PostgreSQL/5432<br/>Password| PostgreSQL
    Server -->|HTTPS/443<br/>IAM| S3
    Server -->|HTTPS/443<br/>API Key| BraveSearch
    Server -->|HTTPS/443<br/>API Key| TavilySearch
    Server -->|configurable| MCP

    subgraph CIOnly["CI Only (not shipped)"]
        VLLMCpu["vllm-cpu<br/>Pre-downloaded models"]
    end

