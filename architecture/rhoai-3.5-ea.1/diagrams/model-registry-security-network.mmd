graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / User"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ termination<br/>oauth2-proxy AuthN<br/>Injects kubeflow-userid header"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            Proxy["Model Registry Proxy<br/>SA: model-registry<br/>:8080/TCP HTTP<br/>FIPS: strictfipsruntime<br/>AuthZ: Istio Policy"]
            Catalog["Model Catalog<br/>:8080/TCP HTTP<br/>Leader Election (pglock)<br/>AuthZ: Istio Policy"]
            Controller["MR Controller<br/>SA: controller-manager<br/>:8081/TCP (health)<br/>⚠ InsecureSkipVerify: true"]
            UI["Model Registry UI<br/>SA: model-registry-ui<br/>:8080/TCP HTTP"]
            AsyncJob["Async Upload Job<br/>Python 3.12<br/>One-shot K8s Job"]
        end

        subgraph NS_KServe["KServe Predictor Pods"]
            CSI["MR CSI Init Container<br/>KServe Provider<br/>model-registry:// resolver"]
        end
    end

    subgraph DataStores["INTERNAL DATA STORES"]
        MySQL["MySQL 8.3+<br/>3306/TCP<br/>Optional TLS 1.2+<br/>Username/Password"]
        PostgreSQL["PostgreSQL 16+<br/>5432/TCP<br/>Optional TLS 1.2+<br/>Username/Password"]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Object Stores<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS<br/>Docker Auth"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Sigstore["Sigstore<br/>(Fulcio + Rekor + TUF)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>oauth2-proxy OIDC"| IstioGW

    %% Ingress → Services
    IstioGW -->|"HTTP/8080<br/>Istio mTLS<br/>kubeflow-userid header"| Proxy
    IstioGW -->|"HTTP/8080<br/>Istio mTLS"| Catalog

    %% Internal service-to-service
    Controller -->|"HTTP/8080<br/>Istio mTLS<br/>Bearer Token (SA)<br/>⚠ InsecureSkipVerify"| Proxy
    CSI -->|"HTTP/8080<br/>No encryption<br/>No auth"| Proxy
    UI -->|"HTTP/8080<br/>Istio mTLS"| Proxy
    AsyncJob -->|"HTTP/8080<br/>No auth"| Proxy

    %% Data store connections
    Proxy -->|"TCP/3306<br/>Optional TLS 1.2+<br/>Username/Password"| MySQL
    Proxy -->|"TCP/5432<br/>Optional TLS 1.2+<br/>Username/Password"| PostgreSQL
    Catalog -->|"TCP/5432<br/>Optional TLS 1.2+<br/>Username/Password"| PostgreSQL

    %% K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    UI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReviews"| K8sAPI

    %% External services
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS<br/>Docker Auth"| OCI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| HF
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC"| Sigstore
    Catalog -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| HF
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Provider creds"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class IstioGW ingress
    class Proxy,Catalog,UI,AsyncJob servicemesh
    class Controller warning
    class CSI servicemesh
    class MySQL,PostgreSQL datastore
    class K8sAPI k8s
    class S3,OCI,HF,Sigstore externalservice
