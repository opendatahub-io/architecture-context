graph LR
    ODHCLI["odh-cli<br/>(rhai-cli / kubectl-odh)"]

    %% External Dependencies (Required)
    ODHCLI -->|"all cluster ops<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>v1.28+"]
    ODHCLI -->|"ClusterVersion, ImageStreams,<br/>Routes"| OSCAPI["OpenShift API Server<br/>v4.19+"]
    ODHCLI -->|"Subscription/CSV<br/>queries"| OLM["OLM<br/>v0.39+"]
    ODHCLI -->|"read-only CR client<br/>(library)"| CtrlRuntime["controller-runtime<br/>v0.23"]
    ODHCLI -->|"cluster health checks<br/>(library import)"| ClusterHealth["opendatahub-operator<br/>clusterhealth v0.1.1"]

    %% External Dependencies (Libraries)
    ODHCLI -->|"CLI framework"| Cobra["cobra v1.10"]
    ODHCLI -->|"version parsing"| Semver["semver v4.0.0"]
    ODHCLI -->|"JQ evaluation"| GoJQ["gojq v0.12"]
    ODHCLI -->|"table rendering"| TableWriter["tablewriter v1.1"]

    %% External Services
    ODHCLI -->|"fetch dep manifest<br/>443/TCP HTTPS<br/>(deps --refresh)"| GitHub["odh-gitops<br/>(GitHub)"]

    %% Internal ODH Platform Dependencies (CRD Reads)
    ODHCLI -->|"version detect,<br/>component state"| DSC["DataScienceCluster CR<br/>opendatahub.io/v2"]
    ODHCLI -->|"platform init,<br/>ServiceMesh config"| DSCI["DSCInitialization CR<br/>opendatahub.io/v2"]
    ODHCLI -->|"health, readiness"| ComponentCRs["Component CRs<br/>platform.opendatahub.io/v1alpha1"]
    ODHCLI -->|"backup, image compat,<br/>connection integrity"| Notebooks["Notebook CRs<br/>kubeflow.org/v1"]
    ODHCLI -->|"backup, deployment<br/>mode validation"| ISVC["InferenceService CRs<br/>serving.kserve.io/v1beta1"]
    ODHCLI -->|"deprecated runtime<br/>detection"| ServingRT["ServingRuntime CRs<br/>serving.kserve.io/v1alpha1"]
    ODHCLI -->|"CodeFlare workload<br/>detection"| Ray["RayCluster/RayJob<br/>ray.io/v1"]
    ODHCLI -->|"TrainingOperator<br/>deprecation"| PyTorch["PyTorchJob<br/>kubeflow.org/v1"]
    ODHCLI -->|"InstructLab removal,<br/>version migration"| DSPA["DSPA CRs<br/>opendatahub.io/v1"]
    ODHCLI -->|"config validation,<br/>OTel migration"| Guardrails["GuardrailsOrchestrator<br/>trustyai.opendatahub.io"]
    ODHCLI -->|"upgrade impact"| LlamaStack["LlamaStackDistribution<br/>llamastack.io"]
    ODHCLI -->|"management state,<br/>data integrity"| Kueue["Kueue CRs<br/>kueue.x-k8s.io/v1beta1"]
    ODHCLI -->|"llm-d readiness"| Kuadrant["Kuadrant/Authorino<br/>kuadrant.io"]
    ODHCLI -->|"migration, integrity"| HWProfile["HardwareProfile /<br/>AcceleratorProfile"]
    ODHCLI -->|"image compat"| ImageStream["ImageStream/Tag<br/>image.openshift.io/v1"]
    ODHCLI -->|"SM v3 catalog"| PkgManifest["PackageManifest<br/>packages.operators.coreos.com"]
    ODHCLI -->|"AppWrapper cleanup"| AppWrapper["AppWrapper<br/>workload.codeflare.dev"]
    ODHCLI -->|"dep install status"| CertMgr["cert-manager Operator"]
    ODHCLI -->|"SM v2/v3 upgrade"| ServiceMesh["Service Mesh Operator"]

    %% Bundled Components
    ODHCLI -.->|"bundled in container"| YQ["yq (FIPS)"]
    ODHCLI -.->|"bundled in container"| UpgradeHelpers["rhoai-upgrade-helpers<br/>Python/Shell"]

