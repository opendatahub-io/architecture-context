graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)<br/>Port: 8090/TCP"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>/{route_name}/v1/chat/completions"]
        StreamHandler["Streaming Handler<br/>(SSE Processing)"]
        NonStreamHandler["Non-Streaming Handler<br/>(JSON Response)"]
        TLSBuilder["TLS Client Builder<br/>(openssl / native-tls)"]
        DetectorInjector["Detector Config Injector<br/>(Policy Injection)"]

        ConfigLoader -->|"loads YAML config"| Gateway
        Gateway -->|"routes POST requests"| RouteHandler
        RouteHandler -->|"enriches with detectors"| DetectorInjector
        DetectorInjector -->|"stream=true"| StreamHandler
        DetectorInjector -->|"stream=false"| NonStreamHandler
        TLSBuilder -->|"mTLS client identity"| Gateway
    end

    Client["Client Application"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP<br/>Authorization header"| Gateway

    subgraph "TLS Secrets (Volume Mounts)"
        TLSCert["/etc/tls/private/tls.crt"]
        TLSKey["/etc/tls/private/tls.key"]
        CACert["/etc/tls/ca/service-ca.crt"]
    end

    TLSCert --> TLSBuilder
    TLSKey --> TLSBuilder
    CACert --> TLSBuilder

    StreamHandler -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator
    NonStreamHandler -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator

    Orchestrator["FMS Guardrails<br/>Orchestrator<br/>8085/TCP"]
    Orchestrator -->|"invokes"| Detectors["Detector Services<br/>(e.g., regex-language)"]
    Orchestrator -->|"inference"| vLLM["vLLM Model Server"]

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style StreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style NonStreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style TLSBuilder fill:#4a90e2,stroke:#333,color:#fff
    style DetectorInjector fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Orchestrator fill:#7ed321,stroke:#333,stroke-width:2px
    style Detectors fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style TLSCert fill:#f5a623,stroke:#333
    style TLSKey fill:#f5a623,stroke:#333
    style CACert fill:#f5a623,stroke:#333
