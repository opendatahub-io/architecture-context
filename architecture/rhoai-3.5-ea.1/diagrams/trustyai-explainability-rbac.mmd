graph TD
    subgraph Operator["trustyai-service-operator (manages all RBAC)"]
        direction TB
        OperatorNote["RBAC is NOT managed by this service directly.<br/>All roles, bindings, and service accounts are<br/>created and managed by the trustyai-service-operator."]
    end

    subgraph InfraAuth["Infrastructure-Level Authentication"]
        direction TB
        KubeRBAC["kube-rbac-proxy Sidecar<br/>(injected by operator)"]
        NetPolicy["Kubernetes NetworkPolicy<br/>(cluster-internal access)"]
        ClusterIP["ClusterIP Service<br/>(no external exposure)"]
    end

    subgraph ServiceEndpoints["TrustyAI Service Endpoints (No App-Level Auth)"]
        direction TB
        ConsumerEP["/consumer/kserve/v2<br/>POST - Inference ingestion<br/>Auth: None (cluster-internal)"]
        MetricsEP["/metrics/group/fairness/*<br/>/metrics/drift/*<br/>POST/GET/DELETE<br/>Auth: None"]
        DataEP["/data/upload, /data/download<br/>POST<br/>Auth: None"]
        InfoEP["/info, /info/tags, /info/names<br/>GET/POST/DELETE<br/>Auth: None"]
        HealthEP["/q/health/*, /q/metrics<br/>GET<br/>Auth: None"]
        ExplainerEP["/explainers/*<br/>POST (disabled in RHOAI)<br/>Auth: None"]
    end

    subgraph Secrets["Secrets (Provisioned by Operator / User)"]
        direction TB
        TLSCert["TLS Certificates<br/>Type: kubernetes.io/tls<br/>Provisioned by: operator / cert-manager<br/>Path: /etc/tls/internal/<br/>Purpose: HTTPS on port 4443"]
        DBCreds["Database Credentials<br/>Type: Opaque<br/>Provisioned by: operator<br/>Keys: QUARKUS_DATASOURCE_USERNAME<br/>       QUARKUS_DATASOURCE_PASSWORD<br/>Auto-Rotate: No"]
        MinioCreds["MinIO Credentials<br/>Type: Opaque<br/>Provisioned by: user<br/>Keys: access-key, secret-key<br/>Auto-Rotate: No"]
    end

    %% Flows
    Operator -->|"creates & manages"| InfraAuth
    Operator -->|"provisions"| Secrets

    KubeRBAC -->|"authenticates requests to"| ServiceEndpoints
    NetPolicy -->|"restricts access to"| ServiceEndpoints
    ClusterIP -->|"limits exposure of"| ServiceEndpoints

    TLSCert -.->|"mounted at<br/>/etc/tls/internal/"| ServiceEndpoints
    DBCreds -.->|"env vars"| ServiceEndpoints
    MinioCreds -.->|"env vars"| ServiceEndpoints

    %% Styling
    style Operator fill:#e0e7ff,stroke:#6366f1,stroke-width:2px
    style InfraAuth fill:#dcfce7,stroke:#22c55e,stroke-width:2px
    style ServiceEndpoints fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style Secrets fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    style OperatorNote fill:#f0f0f0,stroke:#999
    style KubeRBAC fill:#bbf7d0,stroke:#16a34a
    style NetPolicy fill:#bbf7d0,stroke:#16a34a
    style ClusterIP fill:#bbf7d0,stroke:#16a34a
    style TLSCert fill:#fde68a,stroke:#d97706
    style DBCreds fill:#fde68a,stroke:#d97706
    style MinioCreds fill:#fde68a,stroke:#d97706
    style ConsumerEP fill:#bfdbfe,stroke:#2563eb
    style MetricsEP fill:#bfdbfe,stroke:#2563eb
    style DataEP fill:#bfdbfe,stroke:#2563eb
    style InfoEP fill:#bfdbfe,stroke:#2563eb
    style HealthEP fill:#bfdbfe,stroke:#2563eb
    style ExplainerEP fill:#fecaca,stroke:#ef4444
