graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Agent["AI Agent<br/>(Claude Desktop/Code)"]
    end

    subgraph Ingress["INGRESS (Edge)"]
        Route["OpenShift Route<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination"]
    end

    subgraph Application["APPLICATION (Cluster Internal)"]
        direction TB

        subgraph MCPPod["rhoai-mcp Pod"]
            MCP["RHOAI MCP Server<br/>SA: rhoai-mcp/rhoai-mcp<br/>ClusterIP: 8000/TCP HTTP"]
            Safety["Safety Controls:<br/>• read_only_mode<br/>• dangerous_ops gate<br/>• credential masking"]
        end

        subgraph InCluster["In-Cluster Services"]
            direction LR
            ModelReg["Model Registry<br/>8080/TCP HTTP<br/>(direct)"]
            ModelRegProxy["Model Registry<br/>8443/TCP HTTPS<br/>(kube-rbac-proxy)"]
            ModelCatalog["Model Catalog<br/>8080/TCP HTTP"]
            NeuralNav["Neural Navigator<br/>8000/TCP HTTP"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF)"]
        S3["S3 Object Store<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Helm["Helm Registries<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External to Ingress
    Agent -->|"stdio (local pipe)<br/>No network"| MCP
    Agent -->|"HTTPS/443<br/>TLS Edge<br/>No MCP Auth"| Route

    %% Ingress to Application
    Route -->|"HTTP/8000<br/>No encryption<br/>Cluster internal"| MCP

    %% Application to K8s API
    MCP -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (SA/kubeconfig)"| K8sAPI

    %% Application to in-cluster services
    MCP -->|"HTTP/8080<br/>No auth (in-cluster)"| ModelReg
    MCP -->|"HTTPS/8443<br/>Bearer Token (OAuth)"| ModelRegProxy
    MCP -->|"HTTP/8080<br/>No auth"| ModelCatalog
    MCP -->|"HTTP/8000<br/>No auth"| NeuralNav

    %% Application to external services
    MCP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    MCP -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    MCP -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| Git
    MCP -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| Helm

    %% Styling
    classDef external fill:#fef2f2,stroke:#ef4444,stroke-width:2px
    classDef ingress fill:#fff7ed,stroke:#f97316,stroke-width:2px
    classDef application fill:#f0fdf4,stroke:#22c55e,stroke-width:2px
    classDef controlplane fill:#eff6ff,stroke:#3b82f6,stroke-width:2px
    classDef externalservice fill:#fefce8,stroke:#ca8a04,stroke-width:2px
    classDef safety fill:#fef3c7,stroke:#d97706,stroke-width:1px

    class Agent external
    class Route ingress
    class MCP application
    class Safety safety
    class ModelReg,ModelRegProxy,ModelCatalog,NeuralNav application
    class K8sAPI controlplane
    class HF,S3,Git,Helm externalservice
