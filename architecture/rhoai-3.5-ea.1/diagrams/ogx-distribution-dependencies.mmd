graph LR
    OGX["OGX Distribution<br/>(odh-ogx-core)"]

    %% Core Runtime Dependencies
    OGX -->|"core framework"| OGXPkg["OGX 1.0.2+rhaiv.0"]
    OGX -->|"API definitions"| OGXApi["ogx-api 1.0.2+rhaiv.0"]
    OGX -->|"client library"| OGXClient["ogx-client 1.0.2"]
    OGX -->|"runtime"| Python["Python 3.12"]
    OGX -->|"web framework"| FastAPI["FastAPI"]
    OGX -->|"ASGI server"| Uvicorn["Uvicorn"]

    %% Primary Inference Backend
    OGX -->|"inference + embedding"| vLLM["vLLM<br/>(primary backend)"]

    %% Remote Inference Providers
    OGX -->|"remote inference"| Bedrock["AWS Bedrock<br/>(boto3 1.35.88)"]
    OGX -->|"remote inference"| VertexAI["Google Vertex AI<br/>(google-genai >=1.69.0)"]
    OGX -->|"remote inference"| AzureOAI["Azure OpenAI"]
    OGX -->|"remote inference"| Watsonx["IBM watsonx"]
    OGX -->|"remote inference"| OpenAI["OpenAI API"]

    %% Database
    OGX -->|"persistent storage<br/>(asyncpg + psycopg2)"| PostgreSQL["PostgreSQL"]

    %% Vector Databases
    OGX -->|"vector DB (pymilvus 2.6.9)"| Milvus["Milvus"]
    OGX -->|"vector DB"| PGVector["pgvector"]
    OGX -->|"vector DB"| Qdrant["Qdrant"]
    OGX -.->|"inline vector (faiss-cpu)"| FAISS["FAISS"]
    OGX -.->|"inline vector (milvus-lite 2.5.1)"| MilvusLite["milvus-lite"]

    %% ML/AI Libraries
    OGX -->|"ML framework"| PyTorch["PyTorch (CPU)"]
    OGX -.->|"inline embedding"| SentTransformers["sentence-transformers"]
    OGX -->|"tokenizer (0.12.0)"| Tiktoken["tiktoken"]
    OGX -->|"transformers"| HFTransformers["transformers"]

    %% Tool Services
    OGX -->|"web search"| BraveSearch["Brave Search API"]
    OGX -->|"web search"| TavilySearch["Tavily Search API"]
    OGX -->|"tool protocol (>=1.23.0)"| MCP["MCP Servers"]

    %% Storage
    OGX -->|"file storage"| S3["S3 Storage"]

    %% Observability
    OGX -->|"telemetry"| OTEL["opentelemetry-distro"]

    %% Build-Time Dependencies
    OGX -.->|"build-time only"| UV["uv (package installer)"]
    OGX -.->|"build-time only"| RHOAIBase["RHOAI Base Image<br/>(quay.io/aipcc/base-images/cpu:3.5.0-ea.1)"]
    OGX -.->|"build-time only"| RHOAIPyPI["RHOAI PyPI Index<br/>(packages.redhat.com)"]
    OGX -.->|"build-time only"| HFHub["HuggingFace Hub"]

    %% CI/CD
    OGX -.->|"CI/CD"| Konflux["konflux-central<br/>(Tekton pipelines)"]

