graph LR
    BatchGW["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% Required External Dependencies
    BatchGW -->|"metadata, queue,<br/>events, cache<br/>6379/TCP"| Redis["Redis / Valkey 6+<br/>(if db_client.type=redis)"]
    BatchGW -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 14+<br/>(if db_client.type=postgresql)"]
    BatchGW -->|"file storage<br/>443/TCP HTTPS"| S3["S3-Compatible Storage<br/>(AWS S3, MinIO)<br/>(if file_client.type=s3)"]
    BatchGW -->|"inference dispatch<br/>HTTP/HTTPS"| InferenceGW["LLM Inference Gateway<br/>(vLLM, llm-d)<br/>OpenAI-compatible"]

    %% Optional External Dependencies
    BatchGW -.->|"TLS certs<br/>auto-provisioning"| CertManager["cert-manager v1"]
    BatchGW -.->|"metrics scraping<br/>8081/9090/TCP"| Prometheus["Prometheus Operator<br/>(ServiceMonitor, PodMonitor,<br/>PrometheusRule)"]
    BatchGW -.->|"trace export<br/>4317/TCP gRPC"| OTel["OpenTelemetry Collector<br/>(OTLP)"]
    BatchGW -.->|"dashboard loading<br/>ConfigMap label"| Grafana["Grafana 8+<br/>(sidecar auto-load)"]

    %% Internal Platform Dependencies
    LLMDGW["llm-d-inference-gateway"] -->|"Gateway API<br/>HTTPRoute parent"| BatchGW

    %% Integration Points (consumers of batch-gateway)
    BatchGW -.->|"priority band<br/>HTTP header"| GIE["GIE InferenceObjective<br/>(x-gateway-inference-objective)"]

    %% Styling
    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required dependencies (solid borders)
    style Redis fill:#dc382c,stroke:#333,stroke-width:2px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,stroke-width:2px,color:#fff
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    %% Optional dependencies (dashed borders)
    style CertManager fill:#999,stroke:#333,stroke-width:1px,color:#fff
    style Prometheus fill:#999,stroke:#333,stroke-width:1px,color:#fff
    style OTel fill:#999,stroke:#333,stroke-width:1px,color:#fff
    style Grafana fill:#999,stroke:#333,stroke-width:1px,color:#fff

    %% Internal platform
    style LLMDGW fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style GIE fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
