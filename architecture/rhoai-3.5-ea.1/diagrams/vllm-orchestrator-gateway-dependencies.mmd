graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)"]

    %% Internal Platform Dependencies (Direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (Indirect via Orchestrator)
    Gateway -.->|"indirect<br/>(via orchestrator)"| Detectors["Detector Services<br/>(e.g., regex-language)"]
    Gateway -.->|"indirect<br/>(via orchestrator)"| vLLM["vLLM Model Server"]

    %% Platform Infrastructure
    Gateway -->|"TLS certs<br/>/etc/tls/private/"| CertManager["cert-manager /<br/>service-serving-cert-signer"]
    Gateway -->|"CA cert<br/>/etc/tls/ca/"| ServiceCA["OpenShift service-ca"]

    %% Integration Points (Inbound)
    PlatformIngress["Platform Ingress<br/>(HTTPRoute / Route)"] -->|"routes traffic<br/>8090/TCP HTTP"| Gateway

    %% Key Rust Dependencies (Runtime)
    subgraph RustDeps["Key Rust Dependencies"]
        direction TB
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        OpenSSL["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        NativeTLS["native-tls 0.2.12<br/>(TLS backend)"]
    end

    Gateway -->|"built with"| Axum
    Gateway -->|"built with"| Reqwest
    Gateway -->|"built with"| Tokio
    Gateway -->|"built with"| OpenSSL
    Gateway -->|"built with"| NativeTLS

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,stroke-width:2px
    style Detectors fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style PlatformIngress fill:#f5a623,stroke:#333
    style Axum fill:#e8e8e8,stroke:#333
    style Reqwest fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style OpenSSL fill:#e8e8e8,stroke:#333
    style NativeTLS fill:#e8e8e8,stroke:#333
