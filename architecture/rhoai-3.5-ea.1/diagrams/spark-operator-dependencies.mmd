graph LR
    SparkOp["Spark Operator<br/>(v2.3.0)"]

    %% Required External Dependencies
    SparkOp -->|"orchestrates driver/<br/>executor pods"| Spark["Apache Spark 3.0.0+"]
    SparkOp -->|"Python Spark support<br/>(bundled in image)"| PySpark["PySpark 4.0.1"]
    SparkOp -->|"JVM runtime<br/>(bundled in image)"| Java17["Java 17 (OpenJDK)"]
    SparkOp -->|"PID 1 init process"| Tini["tini"]

    %% Optional External Dependencies
    SparkOp -.->|"gang scheduling<br/>(PodGroup CRD)"| Volcano["Volcano 1.10.x"]
    SparkOp -.->|"gang scheduling<br/>(annotation-based)"| Yunikorn["Yunikorn"]
    SparkOp -.->|"gang scheduling<br/>(PodGroup CRD)"| SchedPlugins["scheduler-plugins 0.32.x"]
    SparkOp -.->|"external TLS certs<br/>(alternative to self-signed)"| CertManager["cert-manager"]

    %% Kubernetes Platform
    SparkOp -->|"CRUD: pods, services,<br/>ingresses, configmaps,<br/>secrets, CRDs"| K8sAPI["Kubernetes API<br/>Server"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| SparkOp

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080, 8090"| SparkOp
    NetworkPolicy["NetworkPolicy<br/>(RHOAI/ODH overlays)"] -.->|"restricts ingress<br/>ports 7078, 7079, 4040"| SparkOp

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required dependencies (solid border)
    style Spark fill:#e8e8e8,stroke:#333
    style PySpark fill:#e8e8e8,stroke:#333
    style Java17 fill:#e8e8e8,stroke:#333
    style Tini fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333

    %% Optional dependencies (lighter)
    style Volcano fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
    style Yunikorn fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
    style SchedPlugins fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
    style CertManager fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5

    %% Internal platform (green)
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff

    %% Integration points (orange/purple)
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style NetworkPolicy fill:#fff2cc,stroke:#d6b656
