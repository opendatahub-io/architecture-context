graph TB
    subgraph Operator["TrustyAI Service Operator (Go, controller-runtime)"]
        direction TB
        Manager["Operator Manager<br/>8080/TCP metrics<br/>8081/TCP health"]

        subgraph Controllers["Enabled Controllers (--enable-services)"]
            TASCtrl["TAS Controller<br/>TrustyAIService"]
            LMESCtrl["LMES Controller<br/>LMEvalJob"]
            EvalHubCtrl["EvalHub Controller<br/>EvalHub"]
            GORCHCtrl["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMOCtrl["NeMo Controller<br/>NemoGuardrails"]
        end

        subgraph Optional["Optional Controller"]
            JobMgr["JobManager Controller<br/>(Kueue integration)"]
        end

        Manager --> TASCtrl
        Manager --> LMESCtrl
        Manager --> EvalHubCtrl
        Manager --> GORCHCtrl
        Manager --> NEMOCtrl
        Manager -.-> JobMgr
    end

    subgraph Driver["ta-lmes-driver (Go CLI)"]
        DriverBin["Driver Binary<br/>18080/TCP internal<br/>init container + sidecar"]
    end

    %% CRDs
    TAS_CR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMES_CR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    EH_CR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GORCH_CR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NEMO_CR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD → Controller mapping
    TAS_CR -->|watched by| TASCtrl
    LMES_CR -->|watched by| LMESCtrl
    EH_CR -->|watched by| EvalHubCtrl
    GORCH_CR -->|watched by| GORCHCtrl
    NEMO_CR -->|watched by| NEMOCtrl

    %% Created resources
    TASCtrl -->|creates| TAS_Deploy["TAS Deployment<br/>+ kube-rbac-proxy sidecar"]
    TASCtrl -->|creates| TAS_Svc["TAS Service<br/>443/TCP, 80/TCP"]
    TASCtrl -->|creates| TAS_Route["TAS Route<br/>reencrypt TLS"]
    TASCtrl -->|creates| TAS_SM["ServiceMonitor"]

    LMESCtrl -->|creates| LMES_Pod["LMEvalJob Pod<br/>+ driver init container"]
    LMES_Pod --> DriverBin

    EvalHubCtrl -->|creates| EH_Deploy["EvalHub Deployment"]
    EvalHubCtrl -->|creates| EH_Svc["EvalHub Service<br/>8443/TCP"]
    EvalHubCtrl -->|creates| EH_Route["EvalHub Route<br/>reencrypt TLS"]
    EvalHubCtrl -->|creates| EH_RBAC["Tenant RBAC<br/>(per-namespace)"]

    GORCHCtrl -->|creates| GORCH_Deploy["Orchestrator Deployment<br/>+ kube-rbac-proxy sidecar"]
    GORCHCtrl -->|creates| GORCH_Svc["Orchestrator Service<br/>8432, 9443, 8490, 8480/TCP"]
    GORCHCtrl -->|creates| GORCH_Routes["Orchestrator Routes<br/>reencrypt TLS"]

    NEMOCtrl -->|creates| NEMO_Deploy["NeMo Deployment<br/>+ kube-rbac-proxy (conditional)"]
    NEMOCtrl -->|creates| NEMO_Svc["NeMo Service<br/>8443/TCP"]
    NEMOCtrl -->|creates| NEMO_Route["NeMo Route<br/>edge/reencrypt TLS"]

    %% External integrations
    TASCtrl -->|patches| KServeIS["KServe InferenceService"]
    TASCtrl -->|patches env| ModelMesh["ModelMesh Deployments"]
    GORCHCtrl -->|auto-discovers| KServeIS

    JobMgr -->|wraps as| KueueWL["Kueue Workload"]

    %% ConfigMap
    ConfigMap["trustyai-service-operator-config<br/>ConfigMap (image refs)"] -->|read by| Manager

    %% Platform operator
    RhodsOp["rhods-operator"] -->|deploys via kustomize| Operator

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style TASCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style LMESCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style EvalHubCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style GORCHCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style NEMOCtrl fill:#5b9bd5,stroke:#333,color:#fff
    style JobMgr fill:#7fafd4,stroke:#333,color:#fff
    style DriverBin fill:#4a90e2,stroke:#333,color:#fff
    style TAS_CR fill:#f5a623,stroke:#333
    style LMES_CR fill:#f5a623,stroke:#333
    style EH_CR fill:#f5a623,stroke:#333
    style GORCH_CR fill:#f5a623,stroke:#333
    style NEMO_CR fill:#f5a623,stroke:#333
    style KServeIS fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style KueueWL fill:#7ed321,stroke:#333
    style ConfigMap fill:#e8e8e8,stroke:#333
    style RhodsOp fill:#e8e8e8,stroke:#333
