graph TB
    subgraph MCPServer["RHOAI MCP Server"]
        direction TB

        subgraph Core["Core Infrastructure"]
            Server["FastMCP Server<br/>(server.py)"]
            Config["Config Manager<br/>(pydantic-settings)"]
            PluginMgr["Plugin Manager<br/>(pluggy hooks)"]
            K8sClient["K8sClient<br/>(dynamic client)"]
            PortFwd["Port-Forward Manager<br/>(asyncio/oc)"]
            Cache["CRD Cache"]
            ResponseFmt["Response Formatter<br/>(3 verbosity levels)"]
        end

        subgraph Domains["Domain Plugins (9)"]
            direction LR
            Projects["Projects"]
            Notebooks["Notebooks"]
            Inference["Inference"]
            Pipelines["Pipelines"]
            Connections["Connections"]
            Storage["Storage"]
            Training["Training"]
            ModelReg["Model Registry"]
            Quickstarts["Quickstarts"]
        end

        subgraph Composites["Composite Plugins (4)"]
            direction LR
            Cluster["Cluster<br/>(exploration)"]
            TrainingComp["Training<br/>(orchestration)"]
            Meta["Meta<br/>(tool discovery)"]
            NeuralNav["NeuralNav<br/>(recommendations)"]
        end

        Server -->|registers| PluginMgr
        PluginMgr -->|loads| Domains
        PluginMgr -->|loads| Composites
        Domains -->|uses| K8sClient
        Composites -->|orchestrates| Domains
        K8sClient -->|caches| Cache
        ModelReg -->|uses| PortFwd
        Server -->|formats| ResponseFmt
        Server -->|reads| Config
    end

    %% External Actors
    Agent["AI Agent<br/>(Claude Desktop/Code)"]
    Agent -->|MCP Protocol<br/>stdio/SSE/HTTP| Server

    %% Transport Endpoints
    subgraph Transport["MCP Transport"]
        STDIO["stdio<br/>(local)"]
        SSE["SSE<br/>GET /sse<br/>8000/TCP"]
        StreamHTTP["Streamable HTTP<br/>POST /messages<br/>8000/TCP"]
        Health["GET /health<br/>8000/TCP"]
    end

    Server --- Transport

    %% CRDs (consumed)
    subgraph CRDs["RHOAI CRDs (consumed)"]
        direction LR
        NotebookCR["Notebook CR<br/>kubeflow.org/v1"]
        InfSvcCR["InferenceService CR<br/>serving.kserve.io/v1beta1"]
        ServingRtCR["ServingRuntime CR<br/>serving.kserve.io/v1alpha1"]
        DSPACR["DSPA CR<br/>opendatahub.io/v1alpha1"]
        TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1"]
        DSCCR["DataScienceCluster CR<br/>opendatahub.io/v1"]
    end

    K8sClient -->|CRUD| CRDs

    %% External Services
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    ModelRegSvc["Model Registry Service<br/>8080/TCP HTTP"]
    NeuralNavBE["Neural Navigator Backend<br/>8000/TCP HTTP"]

    K8sClient -->|HTTPS/6443<br/>Bearer Token| K8sAPI
    ModelReg -->|HTTP/8080| ModelRegSvc
    NeuralNav -->|HTTP/8000| NeuralNavBE

    %% Styles
    style MCPServer fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style Domains fill:#dcfce7,stroke:#22c55e,stroke-width:1px
    style Composites fill:#fef3c7,stroke:#f59e0b,stroke-width:1px
    style Transport fill:#f3e8ff,stroke:#a855f7,stroke-width:1px
    style CRDs fill:#fff7ed,stroke:#f97316,stroke-width:1px

    style Agent fill:#fef2f2,stroke:#ef4444,stroke-width:2px
    style K8sAPI fill:#f1f5f9,stroke:#64748b,stroke-width:2px
    style ModelRegSvc fill:#f1f5f9,stroke:#64748b,stroke-width:2px
    style NeuralNavBE fill:#f1f5f9,stroke:#64748b,stroke-width:2px

    style Server fill:#4a90e2,color:#fff
    style PluginMgr fill:#4a90e2,color:#fff
    style K8sClient fill:#4a90e2,color:#fff
