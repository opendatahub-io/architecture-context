graph TB
    subgraph "vLLM CPU Component"
        direction TB
        subgraph "HTTP Entrypoint"
            APIServer["OpenAI API Server<br/>FastAPI/Uvicorn<br/>Port 8000/TCP"]
            AuthMiddleware["Auth Middleware<br/>Bearer Token (optional)"]
            SSLRefresher["SSL Cert Refresher<br/>Hot-reload TLS certs"]
        end

        subgraph "gRPC Entrypoint"
            GRPCServer["gRPC Server<br/>grpc.aio<br/>Port 50051/TCP"]
        end

        subgraph "Core Engine"
            AsyncLLM["AsyncLLM Engine (V1)<br/>Model loading, scheduling,<br/>continuous batching"]
            CPUKernels["CPU Kernels<br/>C/C++ Extensions<br/>Attention, Cache, Activation"]
        end

        subgraph "Observability"
            Prometheus["Prometheus Instrumentator<br/>Metrics at /metrics"]
            OTel["OpenTelemetry Tracing<br/>OTLP Exporter (optional)"]
        end
    end

    Client[External Client] -->|"POST /v1/chat/completions<br/>HTTP 8000/TCP"| AuthMiddleware
    AuthMiddleware --> APIServer
    APIServer --> AsyncLLM
    SSLRefresher -.->|"watches cert files"| APIServer

    GRPCClient[gRPC Client] -->|"gRPC 50051/TCP<br/>plaintext"| GRPCServer
    GRPCServer --> AsyncLLM

    AsyncLLM -->|"C FFI"| CPUKernels
    APIServer --> Prometheus
    APIServer --> OTel

    subgraph "KServe Platform"
        KServeIngress["KServe Ingress<br/>443/TCP HTTPS"]
    end

    KServeIngress -->|"routes traffic<br/>TLS termination"| APIServer

    subgraph "External Services"
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
        UsageStats["RHOAI Usage Stats<br/>console.redhat.com"]
        ModelStorage["Model Storage<br/>PVC / S3"]
    end

    AsyncLLM -->|"model download<br/>HTTPS 443"| HFHub
    AsyncLLM -->|"model weights<br/>File I/O"| ModelStorage
    APIServer -.->|"telemetry<br/>HTTPS 443"| UsageStats

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncLLM fill:#4a90e2,stroke:#333,color:#fff
    style CPUKernels fill:#4a90e2,stroke:#333,color:#fff
    style AuthMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style SSLRefresher fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#4a90e2,stroke:#333,color:#fff
    style OTel fill:#4a90e2,stroke:#333,color:#fff
    style KServeIngress fill:#7ed321,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style UsageStats fill:#f5a623,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style GRPCClient fill:#e8e8e8,stroke:#333
