graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Protocols["Protocol Adapters"]
            REST["REST Server<br/>FastAPI/Uvicorn<br/>8080/TCP"]
            GRPC["gRPC Server<br/>grpc.aio<br/>8081/TCP"]
            Kafka["Kafka Consumer/Producer<br/>aiokafka<br/>9092/TCP"]
            Metrics["Metrics Server<br/>Prometheus<br/>8082/TCP"]
        end

        subgraph Core["Core Engine"]
            DataPlane["DataPlane Handler<br/>Unified request dispatch"]
            Registry["Model Registry<br/>Runtime discovery & lifecycle"]
            Repository["Model Repository<br/>Filesystem watcher"]
            Batching["Adaptive Batching<br/>max_batch_size / max_batch_time"]
            Cache["Response Cache<br/>Deduplication"]
            CloudEvents["CloudEvents Middleware<br/>Event metadata injection"]
        end

        subgraph Workers["Parallel Inference"]
            Dispatcher["Dispatcher<br/>Round-robin routing"]
            Worker1["Worker Process 1<br/>multiprocessing.spawn"]
            Worker2["Worker Process N<br/>multiprocessing.spawn"]
        end

        subgraph Runtimes["Runtime Plugins (RHOAI)"]
            SKLearn["mlserver-sklearn<br/>joblib/pickle"]
            XGBoost["mlserver-xgboost"]
            LightGBM["mlserver-lightgbm"]
            ONNX["mlserver-onnx<br/>onnxruntime CPU/CUDA"]
        end

        subgraph RuntimesExtra["Runtime Plugins (Not in RHOAI)"]
            MLflow["mlserver-mlflow"]
            HuggingFace["mlserver-huggingface"]
            AlibiDetect["mlserver-alibi-detect"]
            AlibiExplain["mlserver-alibi-explain"]
            CatBoost["mlserver-catboost"]
        end
    end

    %% Protocol to Core flows
    REST -->|V2 Dataplane API| DataPlane
    GRPC -->|V2 Dataplane API| DataPlane
    Kafka -->|Async inference| DataPlane

    %% Core internal flows
    DataPlane -->|dispatch| Registry
    DataPlane -->|batch requests| Batching
    DataPlane -->|check cache| Cache
    DataPlane -->|inject metadata| CloudEvents
    Repository -->|discover models| Registry

    %% Registry to runtimes
    Registry -->|load/invoke| SKLearn
    Registry -->|load/invoke| XGBoost
    Registry -->|load/invoke| LightGBM
    Registry -->|load/invoke| ONNX

    %% Parallel inference
    DataPlane -.->|parallel mode| Dispatcher
    Dispatcher -->|IPC Queue| Worker1
    Dispatcher -->|IPC Queue| Worker2

    %% External integrations
    Client[External Client] -->|HTTPS/443| KServeGW["KServe Gateway<br/>TLS Termination"]
    KServeGW -->|HTTP/8080| REST
    KServeGW -->|gRPC/8081| GRPC
    ModelStorage["Model Storage<br/>/mnt/models<br/>PVC or S3"] -->|volume mount| Repository
    Prometheus["Prometheus"] -->|scrape /metrics| Metrics
    OTELCollector["OpenTelemetry Collector<br/>4317/TCP"] -.->|trace export| DataPlane
    TrustedAllowlist["Trusted Runtime Allowlist<br/>/etc/mlserver/trusted-runtimes.json"] -->|validates| Registry

    %% Styling
    style REST fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
