graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["data-science-gateway<br/>(Envoy)<br/>443/TCP → 8443/TCP<br/>HTTPRoute path rewrite:<br/>/mlflow/api/* → /api/*<br/>/mlflow/v1/* → /v1/*"]
    end

    subgraph AppLayer["APPLICATION LAYER (Operator-managed)"]
        direction TB

        subgraph NS_Target["Namespace: {target-namespace}"]
            MLflow["MLflow Server<br/>SA: mlflow-sa<br/>8443/TCP HTTPS<br/>uvicorn + service-ca TLS<br/>AuthN: kubernetes-auth<br/>(SelfSubjectAccessReview)<br/>AuthZ: RBAC via<br/>mlflow.kubeflow.org"]
            CAWatcher["ca-bundle-watcher<br/>(sidecar)<br/>30s poll interval"]
            NetPol["NetworkPolicy<br/>Ingress: 8443 any NS<br/>Egress: restricted"]
        end
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE"]
        subgraph NS_RHOAI["Namespace: redhat-ods-applications"]
            Operator["mlflow-operator<br/>SA: controller-manager<br/>8081/TCP health (HTTP)<br/>8443/TCP metrics (HTTPS)<br/>HTTP/2 disabled<br/>FIPS: strictfipsruntime"]
        end
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        ServiceCA["OpenShift service-ca<br/>Auto-provisions mlflow-tls<br/>Auto-rotated"]
        Console["OpenShift Console<br/>ConsoleLink CR"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap<br/>SSL_CERT_FILE<br/>REQUESTS_CA_BUNDLE<br/>AWS_CA_BUNDLE<br/>PGSSLROOTCERT"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>8443/TCP HTTPS<br/>service-ca verified<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PGSSLMODE=verify-full<br/>Connection string creds"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS configurable<br/>Connection string creds"]
        S3["S3-compatible Storage<br/>(MinIO/SeaweedFS/AWS)<br/>443/9000/8333-8334/TCP<br/>HTTPS (via CA bundle)<br/>AWS IAM credentials"]
    end

    %% External → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token"| Gateway

    %% Gateway → MLflow
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca cert)<br/>Token passthrough"| MLflow

    %% MLflow → K8s API (AuthZ)
    MLflow -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>(SelfSubjectAccessReview)"| K8sAPI

    %% MLflow → Backend Stores
    MLflow -->|"PostgreSQL/5432<br/>TLS verify-full<br/>Conn string creds"| PostgreSQL
    MLflow -->|"MySQL/3306<br/>TLS configurable<br/>Conn string creds"| MySQL
    MLflow -->|"HTTPS/443,9000,8333<br/>TLS (CA bundle)<br/>AWS IAM creds"| S3

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch + SSA patch"| K8sAPI

    %% Platform integrations
    ServiceCA -.->|"provisions"| MLflow
    CABundle -.->|"mounted into"| MLflow
    CABundle -.->|"watched by"| CAWatcher
    Operator -.->|"creates"| Console
    Prometheus -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token"| MLflow
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class MLflow,CAWatcher,NetPol app
    class Operator operator
    class K8sAPI,ServiceCA,Console,CABundle platform
    class Prometheus monitoring
    class PostgreSQL,MySQL,S3 extsvc
