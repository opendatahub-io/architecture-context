graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Ctrl["spark-operator-controller<br/>(ServiceAccount)"]
        SA_WH["spark-operator-webhook<br/>(ServiceAccount)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Ctrl["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_WH["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_LE["spark-operator-leader-election<br/>(RoleBinding, operator namespace)"]
    end

    subgraph ControllerClusterRole["ClusterRole: spark-operator-controller"]
        direction LR
        CR_Ctrl_Core["core<br/>pods: create,delete,get,list,update,watch<br/>configmaps: create,get,list,patch,update,watch<br/>services: create,delete,get,list,patch,update,watch<br/>persistentvolumeclaims: list,watch<br/>events: create,patch,update"]
        CR_Ctrl_ApiExt["apiextensions.k8s.io<br/>customresourcedefinitions: get"]
        CR_Ctrl_Net["extensions, networking.k8s.io<br/>ingresses: create,delete,get,update"]
        CR_Ctrl_Spark["sparkoperator.k8s.io<br/>sparkapplications: create,delete,get,list,watch<br/>sparkapplications/finalizers: update<br/>sparkapplications/status: update<br/>scheduledsparkapplications: get,list,watch<br/>scheduledsparkapplications/finalizers: update,patch<br/>scheduledsparkapplications/status: update<br/>sparkconnects: get,list,watch<br/>sparkconnects/status: update"]
    end

    subgraph WebhookClusterRole["ClusterRole: spark-operator-webhook"]
        direction LR
        CR_WH_Admission["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations: list,watch<br/>validatingwebhookconfigurations: list,watch<br/>mutatingwebhookconfigurations (named): get,update<br/>validatingwebhookconfigurations (named): get,update"]
        CR_WH_Spark["sparkoperator.k8s.io<br/>sparkapplications: get,list,watch<br/>scheduledsparkapplications: get,list,watch"]
        CR_WH_Core["core<br/>pods: list,watch"]
    end

    subgraph UserRoles["User-Facing ClusterRoles"]
        direction LR
        CR_Editor["sparkapplication-editor<br/>sparkoperator.k8s.io/sparkapplications:<br/>create,delete,get,list,patch,update,watch<br/>sparkapplications/status: get"]
        CR_Viewer["sparkapplication-viewer<br/>sparkoperator.k8s.io/sparkapplications:<br/>get,list,watch<br/>sparkapplications/status: get"]
        CR_SchedEditor["scheduledsparkapplication-editor<br/>sparkoperator.k8s.io/scheduledsparkapplications:<br/>create,delete,get,list,patch,update,watch<br/>scheduledsparkapplications/status: get"]
        CR_SchedViewer["scheduledsparkapplication-viewer<br/>sparkoperator.k8s.io/scheduledsparkapplications:<br/>get,list,watch<br/>scheduledsparkapplications/status: get"]
    end

    subgraph LeaderElectionRole["Role: spark-operator-leader-election"]
        LE_Resources["coordination.k8s.io<br/>leases: get,create,update<br/>core/configmaps: get,list,watch,create,update,patch,delete<br/>core/events: create,patch"]
    end

    %% Bindings
    SA_Ctrl -->|"bound via"| CRB_Ctrl
    SA_WH -->|"bound via"| CRB_WH
    SA_Ctrl -->|"bound via"| RB_LE

    CRB_Ctrl -->|"grants"| CR_Ctrl_Core
    CRB_Ctrl -->|"grants"| CR_Ctrl_ApiExt
    CRB_Ctrl -->|"grants"| CR_Ctrl_Net
    CRB_Ctrl -->|"grants"| CR_Ctrl_Spark

    CRB_WH -->|"grants"| CR_WH_Admission
    CRB_WH -->|"grants"| CR_WH_Spark
    CRB_WH -->|"grants"| CR_WH_Core

    RB_LE -->|"grants"| LE_Resources

    %% Styling
    style SA_Ctrl fill:#4a90e2,color:#fff
    style SA_WH fill:#4a90e2,color:#fff
    style CRB_Ctrl fill:#f5a623,color:#fff
    style CRB_WH fill:#f5a623,color:#fff
    style RB_LE fill:#f5a623,color:#fff
    style CR_Ctrl_Core fill:#7ed321,color:#fff
    style CR_Ctrl_ApiExt fill:#7ed321,color:#fff
    style CR_Ctrl_Net fill:#7ed321,color:#fff
    style CR_Ctrl_Spark fill:#7ed321,color:#fff
    style CR_WH_Admission fill:#7ed321,color:#fff
    style CR_WH_Spark fill:#7ed321,color:#fff
    style CR_WH_Core fill:#7ed321,color:#fff
    style CR_Editor fill:#b8e986,color:#333
    style CR_Viewer fill:#b8e986,color:#333
    style CR_SchedEditor fill:#b8e986,color:#333
    style CR_SchedViewer fill:#b8e986,color:#333
    style LE_Resources fill:#7ed321,color:#fff
