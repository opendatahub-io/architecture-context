graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{release-name}-epp<br/>Namespace: deployment NS"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["(EPP chart-managed)<br/>RoleBinding"]
        RB_Metrics["metrics-reader<br/>RoleBinding"]
    end

    subgraph Roles["Roles (EPP chart-managed)"]
        Role_EPP["EPP Role"]
        Role_Metrics["metrics-reader Role"]
    end

    subgraph CoreAPI["API Group: core ('')"]
        Pods["pods"]
    end

    subgraph InferenceAPI["API Group: inference.networking.x-k8s.io"]
        InferencePools["inferencepools"]
        InferenceObjectives["inferenceobjectives"]
    end

    subgraph Verbs_RO["Permissions"]
        VerbsReadOnly["get, list, watch"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB_EPP
    SA_EPP -->|"bound via"| RB_Metrics
    RB_EPP -->|"grants"| Role_EPP
    RB_Metrics -->|"grants"| Role_Metrics

    %% Role → Resources
    Role_EPP -->|"get, list, watch"| Pods
    Role_EPP -->|"get, list, watch"| InferencePools
    Role_EPP -->|"get, list, watch"| InferenceObjectives

    subgraph Secrets["Secrets"]
        HFToken["llm-d-hf-token<br/>Type: Opaque<br/>Purpose: HuggingFace API token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        MetricsToken["controller-manager-token<br/>Type: Opaque<br/>Purpose: EPP metrics access (WVA)<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph AuthEndpoints["Authentication & Authorization"]
        ChatEndpoint["/v1/chat/completions<br/>Auth: None (default)<br/>Open access within cluster"]
        CompletionsEndpoint["/v1/completions<br/>Auth: None (default)<br/>Open access within cluster"]
        MetricsEndpoint["/metrics<br/>Auth: None (default)<br/>Open for Prometheus"]
        GatewayEndpoint["Gateway Ingress<br/>Auth: Configurable<br/>Provider-dependent"]
    end

    %% Secret usage
    HFToken -.->|"mounted in"| ModelServerPod["Model Server Pods"]
    MetricsToken -.->|"used by"| WVA["WVA Autoscaler"]

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RB_EPP fill:#ffe6cc,stroke:#d79b00
    style RB_Metrics fill:#ffe6cc,stroke:#d79b00
    style Role_EPP fill:#f5a623,stroke:#333,stroke-width:2px
    style Role_Metrics fill:#f5a623,stroke:#333,stroke-width:2px
    style Pods fill:#7ed321,stroke:#333
    style InferencePools fill:#7ed321,stroke:#333
    style InferenceObjectives fill:#7ed321,stroke:#333
    style HFToken fill:#f8cecc,stroke:#b85450
    style MetricsToken fill:#f8cecc,stroke:#b85450
    style ChatEndpoint fill:#d5e8d4,stroke:#82b366
    style CompletionsEndpoint fill:#d5e8d4,stroke:#82b366
    style MetricsEndpoint fill:#d5e8d4,stroke:#82b366
    style GatewayEndpoint fill:#ffe6cc,stroke:#d79b00
    style ModelServerPod fill:#dae8fc,stroke:#6c8ebf
    style WVA fill:#dae8fc,stroke:#6c8ebf
