graph TB
    subgraph ClientHost["CLIENT HOST (Trusted - Admin Workstation)"]
        Admin["Cluster Admin / CI Pipeline"]
        CLI["rhai-cli Process<br/>Go Binary (FIPS: strictfipsruntime)<br/>Container: rhoai-upgrade-helpers-rhel9<br/>QPS=50, Burst=100"]
        Kubeconfig["kubeconfig<br/>(~/.kube/config)"]

        Admin -->|"CLI invocation"| CLI
        Kubeconfig -.->|"credentials"| CLI
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (RBAC Enforced)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>AuthN: Bearer/Cert/OIDC<br/>AuthZ: RBAC"]

        subgraph CoreAPIs["Core & Apps APIs"]
            Core["namespaces, pods, pods/log,<br/>configmaps, secrets, pvcs,<br/>services, events, nodes<br/>Verbs: get, list, watch"]
            Apps["deployments, statefulsets,<br/>replicasets, daemonsets<br/>Verbs: get, list"]
        end

        subgraph ODHCRDs["ODH/RHOAI CRDs (Read-Only)"]
            Platform["DSC, DSCI, Component CRs<br/>opendatahub.io/v2"]
            MLWorkloads["Notebooks, InferenceServices,<br/>ServingRuntimes, RayClusters,<br/>PyTorchJobs, DSPAs,<br/>GuardrailsOrchestrators,<br/>LlamaStackDistributions"]
            Infra["HardwareProfiles,<br/>AcceleratorProfiles,<br/>ClusterQueues, LocalQueues,<br/>AppWrappers"]
        end

        subgraph OLMAPIs["OLM APIs"]
            OLM["Subscriptions, CSVs,<br/>InstallPlans, PackageManifests<br/>Verbs: get, list<br/>(+ create for deps install)"]
        end

        subgraph OSCAPIs["OpenShift APIs"]
            OSC["ClusterVersions, ImageStreams,<br/>ImageStreamTags, CRDs<br/>Verbs: get, list"]
        end

        K8sAPI --> CoreAPIs
        K8sAPI --> ODHCRDs
        K8sAPI --> OLMAPIs
        K8sAPI --> OSCAPIs
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        GitHub["raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)<br/>Purpose: odh-gitops manifest"]
    end

    subgraph LocalFS["LOCAL FILESYSTEM"]
        BackupDir["Backup Output Dir<br/>YAML manifests (0644)<br/>Write only via backup cmd"]
    end

    %% Network Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+ (FIPS)<br/>Bearer Token /<br/>Client Certificate /<br/>OIDC"| K8sAPI

    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>(deps --refresh only,<br/>optional)"| GitHub

    CLI -->|"File I/O<br/>(backup cmd only)"| BackupDir

    %% Security annotations
    subgraph SecurityNotes["SECURITY CONTROLS"]
        direction LR
        FIPS["FIPS: CGO_ENABLED=1<br/>strictfipsruntime<br/>OpenSSL via ose-cli-rhel9"]
        CatalogAL["Catalog Allowlist:<br/>redhat-operators<br/>community-operators<br/>certified-operators<br/>redhat-marketplace"]
        NSReject["Namespace Rejection:<br/>kube-*, openshift-*<br/>(deps install only)"]
        ReadOnly["Read-Only Client:<br/>client.Reader interface<br/>(lint checks enforced)"]
    end

    %% Styling
    classDef client fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef filesystem fill:#f3e8ff,stroke:#9333ea,stroke-width:2px
    classDef security fill:#fef3c7,stroke:#f59e0b,stroke-width:1px,stroke-dasharray:5

    class Admin,CLI,Kubeconfig client
    class K8sAPI,Core,Apps,Platform,MLWorkloads,Infra,OLM,OSC cluster
    class GitHub external
    class BackupDir filesystem
    class FIPS,CatalogAL,NSReject,ReadOnly security
