graph TB
    subgraph Client["CLIENT ENVIRONMENT (Workbench / Notebook)"]
        SDK["CodeFlare SDK<br/>(Python Client Library)<br/>Auth: kube-authkit<br/>Crypto: RSA-3072, SHA-256"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer/OIDC/OAuth<br/>AuthZ: RBAC"]
    end

    subgraph Operators["OPERATOR NAMESPACE"]
        KubeRay["KubeRay Operator<br/>SA: controller-manager<br/>Watches: ray.io/v1"]
        Kueue["Kueue Controller<br/>Manages: LocalQueue,<br/>Workload, PriorityClass"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        HeadSvc["{cluster}-head-svc<br/>Type: ClusterIP<br/>Ports: 6379, 8265, 10001"]

        subgraph HeadPod["Ray Head Pod"]
            GCS["Ray GCS<br/>6379/TCP gRPC<br/>mTLS<br/>Client cert"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>TLS via proxy<br/>Bearer Token"]
            RayClient["Ray Client<br/>10001/TCP gRPC<br/>mTLS<br/>Client cert"]
        end

        Workers["Ray Worker Pods<br/>(internal Ray protocol)"]

        subgraph Secrets["Kubernetes Secrets"]
            CASec["{cluster}-ca-secret-{uid}<br/>Type: Opaque<br/>CA cert+key for mTLS"]
            FileSec["{rayjob}-files<br/>Type: Opaque<br/>Local files for RayJob<br/>ownerRef → RayJob"]
        end
    end

    subgraph Ingress["INGRESS LAYER"]
        direction TB
        GatewayAPI["RHOAI Gateway (v3.0+)<br/>HTTPRoute<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE<br/>Auth: kube-rbac-proxy<br/>Path: /ray/{ns}/{cluster}"]
        OSRoute["OpenShift Route (pre-v3.0)<br/>443/TCP HTTPS<br/>TLS edge termination<br/>Auth: OAuth proxy"]
    end

    subgraph External["EXTERNAL ACCESS"]
        Browser["User Browser<br/>Auth: Bearer Token"]
    end

    %% SDK to K8s API
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer/OIDC/OAuth<br/>CRUD: RayClusters, RayJobs,<br/>Secrets, Routes, HTTPRoutes"| K8sAPI

    %% SDK direct to Ray Head (mTLS)
    SDK -->|"gRPC/10001<br/>mTLS<br/>Client cert<br/>(ray.init)"| RayClient
    SDK -->|"gRPC/6379<br/>mTLS<br/>Client cert<br/>(GCS)"| GCS

    %% K8s API to operators
    K8sAPI -.->|"Watch events"| KubeRay
    K8sAPI -.->|"Watch events"| Kueue

    %% Operators to resources
    KubeRay -->|"Creates pods,<br/>services, secrets"| HeadPod
    KubeRay -->|"Creates"| Workers
    KubeRay -->|"Creates"| CASec

    %% Service routing
    HeadSvc -.->|"Routes to"| HeadPod

    %% Ingress to Dashboard
    GatewayAPI -->|"HTTP/8265<br/>Proxied"| Dashboard
    OSRoute -->|"HTTP/8265<br/>Proxied"| Dashboard

    %% External to Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| GatewayAPI
    Browser -.->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| OSRoute

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef controlplane fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef operator fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef userns fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef ingress fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef external fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef secret fill:#fff9c4,stroke:#f57f17,stroke-width:1px

    class SDK client
    class K8sAPI controlplane
    class KubeRay,Kueue operator
    class HeadSvc,GCS,Dashboard,RayClient,Workers userns
    class GatewayAPI,OSRoute ingress
    class Browser external
    class CASec,FileSec secret
