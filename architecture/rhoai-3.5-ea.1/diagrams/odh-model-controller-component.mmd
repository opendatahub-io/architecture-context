graph TB
    subgraph ODH["odh-model-controller Component"]
        direction TB

        subgraph ServingControllers["Serving Controllers"]
            ISVCController["InferenceService<br/>Controller"]
            IGController["InferenceGraph<br/>Controller"]
            SRController["ServingRuntime<br/>Controller"]
        end

        subgraph SubReconcilers["Sub-Resource Reconcilers"]
            RouteReconciler["Route Reconciler"]
            MetricsSvcReconciler["Metrics Service<br/>Reconciler"]
            SMReconciler["ServiceMonitor<br/>Reconciler"]
            DashboardReconciler["Dashboard ConfigMap<br/>Reconciler"]
            KEDAReconciler["KEDA Reconciler"]
            CRBReconciler["ClusterRoleBinding<br/>Reconciler"]
            SAReconciler["ServiceAccount<br/>Reconciler"]
            MRReconciler["Model Registry<br/>Reconciler"]
        end

        subgraph LLMControllers["LLM Controllers"]
            LLMISVCController["LLMInferenceService<br/>Controller"]
            GWController["Gateway<br/>Controller"]
            AuthPolicyReconciler["AuthPolicy<br/>Reconciler"]
        end

        subgraph NIMSubsystem["NIM Subsystem"]
            NIMController["NIM Account<br/>Controller"]
            ValidationHandler["Validation Handler"]
            ConfigMapHandler["ConfigMap Handler"]
            TemplateHandler["Template Handler"]
            PullSecretHandler["PullSecret Handler"]
        end

        subgraph CoreControllers["Core Controllers"]
            CMController["ConfigMap Controller<br/>(CA Bundle)"]
            SecretController["Secret Controller<br/>(storage-config)"]
            PodController["Pod Controller<br/>(Ray TLS)"]
        end

        subgraph Webhooks["Admission Webhooks"]
            ISVCWebhook["InferenceService<br/>Webhook"]
            IGWebhook["InferenceGraph<br/>Webhook"]
            NIMWebhook["NIM Account<br/>Webhook"]
            PodWebhook["Pod Webhook<br/>(Ray TLS Inject)"]
        end

        subgraph APIServer["model-serving-api"]
            GatewayAPI["GET /api/v1/gateways<br/>8443/TCP HTTPS"]
            AuthMiddleware["Auth Middleware<br/>(Bearer Token + SSAR)"]
            GatewayDiscovery["Gateway Discovery<br/>(label-filtered)"]
        end

        ISVCController -->|delegates| RouteReconciler
        ISVCController -->|delegates| MetricsSvcReconciler
        ISVCController -->|delegates| SMReconciler
        ISVCController -->|delegates| DashboardReconciler
        ISVCController -->|delegates| KEDAReconciler
        ISVCController -->|delegates| CRBReconciler
        ISVCController -->|delegates| SAReconciler
        ISVCController -->|delegates| MRReconciler

        LLMISVCController -->|delegates| AuthPolicyReconciler

        NIMController -->|chain| ValidationHandler
        ValidationHandler -->|chain| ConfigMapHandler
        ConfigMapHandler -->|chain| TemplateHandler
        TemplateHandler -->|chain| PullSecretHandler

        GatewayAPI -->|uses| AuthMiddleware
        AuthMiddleware -->|calls| GatewayDiscovery
    end

    %% External CRDs watched
    ISVC["InferenceService CR"]
    LLMISVC["LLMInferenceService CR"]
    NIMAccount["NIM Account CR"]
    IG["InferenceGraph CR"]
    SR["ServingRuntime CR"]

    ISVC -->|watched by| ISVCController
    LLMISVC -->|watched by| LLMISVCController
    NIMAccount -->|watched by| NIMController
    IG -->|watched by| IGController
    SR -->|watched by| SRController

    %% Resources created
    RouteReconciler -->|creates| Route["OpenShift Route"]
    MetricsSvcReconciler -->|creates| MetricsSvc["Metrics Service"]
    SMReconciler -->|creates| ServiceMonitor["ServiceMonitor"]
    KEDAReconciler -->|creates| TriggerAuth["KEDA TriggerAuth"]
    CRBReconciler -->|creates| CRB["ClusterRoleBinding"]
    AuthPolicyReconciler -->|creates| AuthPolicy["Kuadrant AuthPolicy"]
    GWController -->|creates| EnvoyFilter["Istio EnvoyFilter"]
    GWController -->|creates| GWAuthPolicy["Gateway AuthPolicy"]
    LLMISVCController -->|creates| HTTPRouteAP["HTTPRoute AuthPolicy"]
    TemplateHandler -->|creates| Template["OpenShift Template"]
    PullSecretHandler -->|creates| PullSecret["Docker Pull Secret"]
    CMController -->|creates| CABundle["odh-kserve-custom-ca-bundle"]
    SecretController -->|creates| StorageConfig["storage-config Secret"]
    PodController -->|creates| RayTLS["Ray TLS Certs"]

    %% External dependencies
    ISVCController -->|depends on| KServe["KServe"]
    GWController -->|depends on| GatewayAPIRes["Gateway API"]
    AuthPolicyReconciler -->|depends on| Kuadrant["Kuadrant / Authorino"]
    NIMController -->|calls| NGC["NVIDIA NGC API"]
    GatewayDiscovery -->|queries| K8sAPI["Kubernetes API"]

    %% Dashboard consumer
    Dashboard["RHOAI Dashboard"] -->|calls| GatewayAPI

    %% Styling
    style ODH fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style ServingControllers fill:#d5e8d4,stroke:#82b366
    style SubReconcilers fill:#dae8fc,stroke:#6c8ebf
    style LLMControllers fill:#e1d5e7,stroke:#9673a6
    style NIMSubsystem fill:#fff2cc,stroke:#d6b656
    style CoreControllers fill:#f8cecc,stroke:#b85450
    style Webhooks fill:#ffe6cc,stroke:#d79b00
    style APIServer fill:#d5e8d4,stroke:#82b366

    style ISVC fill:#f5a623,stroke:#333
    style LLMISVC fill:#f5a623,stroke:#333
    style NIMAccount fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333

    style Route fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style Template fill:#7ed321,stroke:#333
    style PullSecret fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333
    style StorageConfig fill:#7ed321,stroke:#333
    style RayTLS fill:#7ed321,stroke:#333

    style KServe fill:#e8e8e8,stroke:#333
    style GatewayAPIRes fill:#e8e8e8,stroke:#333
    style Kuadrant fill:#e8e8e8,stroke:#333
    style NGC fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Dashboard fill:#4a90e2,color:#fff,stroke:#333
