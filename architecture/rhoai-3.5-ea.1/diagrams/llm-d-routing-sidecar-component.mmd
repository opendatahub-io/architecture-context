graph TB
    subgraph SidecarPod["Decoder Pod (StatefulSet)"]
        direction TB

        subgraph Sidecar["llm-d-routing-sidecar (Port 8000/TCP)"]
            direction TB
            ProxyServer["Proxy Server<br/>HTTPS Listener<br/>TLS 1.2+"]
            ChatHandler["Chat Completions Handler<br/>/v1/chat/completions"]
            CompHandler["Completions Handler<br/>/v1/completions"]
            HealthHandler["Health Check<br/>/health"]
            CatchAll["Catch-All Passthrough<br/>/*"]
            ConnectorNIXLv2["NIXL v2 Connector<br/>(default)"]
            ConnectorNIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            ConnectorLMCache["LMCache Connector<br/>(deprecated)"]
            LRUCache["LRU Proxy Cache<br/>hashicorp/golang-lru"]

            ProxyServer --> ChatHandler
            ProxyServer --> CompHandler
            ProxyServer --> HealthHandler
            ProxyServer --> CatchAll
            ChatHandler --> ConnectorNIXLv2
            ChatHandler -.-> ConnectorNIXLv1
            ChatHandler -.-> ConnectorLMCache
            CompHandler --> ConnectorNIXLv2
            ConnectorNIXLv2 --> LRUCache
        end

        subgraph SSRFProtection["SSRF Protection (Optional)"]
            AllowlistValidator["AllowlistValidator<br/>Kubernetes Dynamic Client"]
            PodInformer["Pod Informer<br/>30s Resync"]
            AllowlistValidator --> PodInformer
        end

        vLLMDecoder["vLLM Decoder<br/>Port 8001/TCP"]
    end

    %% External actors
    Client["Client / Gateway API Router"]
    RemotePrefiller["Remote Prefiller Pods<br/>(vLLM Instances)"]
    K8sAPI["Kubernetes API Server<br/>443/TCP"]
    InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io"]
    Scheduler["llm-d-inference-scheduler<br/>(sets x-prefiller-host-port)"]

    %% Flows
    Client -->|"HTTPS/8000<br/>POST /v1/chat/completions"| ProxyServer
    Scheduler -.->|"sets header"| Client
    ChatHandler -->|"validates host"| AllowlistValidator
    ConnectorNIXLv2 -->|"HTTP(S)/dynamic<br/>Prefill Request"| RemotePrefiller
    RemotePrefiller -->|"kv_transfer_params"| ConnectorNIXLv2
    CatchAll -->|"HTTP(S)/8001"| vLLMDecoder
    ConnectorNIXLv2 -->|"HTTP(S)/8001<br/>Decode Request"| vLLMDecoder
    AllowlistValidator -->|"Watch"| K8sAPI
    K8sAPI -->|"InferencePool events"| AllowlistValidator
    InferencePoolCR -.->|"watched by"| AllowlistValidator

    %% Styles
    style ProxyServer fill:#4a90e2,color:#fff
    style ChatHandler fill:#4a90e2,color:#fff
    style CompHandler fill:#4a90e2,color:#fff
    style HealthHandler fill:#4a90e2,color:#fff
    style CatchAll fill:#4a90e2,color:#fff
    style ConnectorNIXLv2 fill:#50c878,color:#fff
    style ConnectorNIXLv1 fill:#999,color:#fff
    style ConnectorLMCache fill:#999,color:#fff
    style LRUCache fill:#50c878,color:#fff
    style AllowlistValidator fill:#f5a623,color:#fff
    style PodInformer fill:#f5a623,color:#fff
    style vLLMDecoder fill:#9b59b6,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style RemotePrefiller fill:#9b59b6,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePoolCR fill:#f5a623,color:#fff
    style Scheduler fill:#e8e8e8,stroke:#333
