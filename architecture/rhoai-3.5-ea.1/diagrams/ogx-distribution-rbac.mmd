graph TD
    subgraph "OGX Distribution - Access Control Model"
        direction TB

        subgraph "Note"
            NoK8sRBAC["No Kubernetes RBAC Defined<br/>(Container image, not an operator)<br/>No direct K8s API interaction"]
        end

        subgraph "Application-Level Auth (OAuth2/OIDC)"
            direction TB
            AuthConfig["AUTH_ISSUER env var<br/>(enables/disables auth)"]
            JWKS["JWKS Endpoint<br/>(AUTH_JWKS_URI)<br/>Key rotation: AUTH_JWKS_RECHECK_PERIOD (3600s)"]
            AuthConfig -->|"configures"| JWKS
        end

        subgraph "API Endpoints"
            direction TB
            HealthEP["/v1/health<br/>GET<br/>Auth: None (Open)"]
            AllAPIs["/v1/* (all other endpoints)<br/>GET, POST, PUT, DELETE<br/>Auth: OAuth2 Bearer Token (JWT)"]
        end

        subgraph "Access Policies"
            direction TB
            Policy1["Unowned Resources<br/>→ Publicly readable"]
            Policy2["Authenticated Users<br/>→ Can create resources"]
            Policy3["Resource Owners<br/>→ Can read/update/delete own resources"]
        end

        subgraph "Secrets (16 Environment Variables)"
            direction TB
            InferenceCreds["Inference Provider Credentials<br/>VLLM_API_TOKEN, VLLM_EMBEDDING_API_TOKEN<br/>AWS_BEARER_TOKEN_BEDROCK (12h TTL)<br/>WATSONX_API_KEY, AZURE_API_KEY, OPENAI_API_KEY"]
            DBCreds["Database Credentials<br/>POSTGRES_PASSWORD<br/>PGVECTOR_PASSWORD<br/>MILVUS_TOKEN, QDRANT_API_KEY"]
            CloudCreds["Cloud Service Credentials<br/>AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY<br/>BRAVE_SEARCH_API_KEY, TAVILY_SEARCH_API_KEY"]
            AuthCreds["Auth Configuration<br/>AUTH_ISSUER, AUTH_JWKS_URI"]
        end
    end

    AuthConfig -->|"when set"| AllAPIs
    AuthConfig -->|"not applied to"| HealthEP
    AllAPIs -->|"enforces"| Policy1
    AllAPIs -->|"enforces"| Policy2
    AllAPIs -->|"enforces"| Policy3

    style NoK8sRBAC fill:#fff3cd,stroke:#856404,stroke-width:2px
    style AuthConfig fill:#4a90e2,stroke:#333,color:#fff
    style JWKS fill:#4a90e2,stroke:#333,color:#fff
    style HealthEP fill:#d5e8d4,stroke:#82b366
    style AllAPIs fill:#dae8fc,stroke:#6c8ebf
    style Policy1 fill:#e8e8e8,stroke:#666
    style Policy2 fill:#e8e8e8,stroke:#666
    style Policy3 fill:#e8e8e8,stroke:#666
    style InferenceCreds fill:#f8cecc,stroke:#b85450
    style DBCreds fill:#f8cecc,stroke:#b85450
    style CloudCreds fill:#f8cecc,stroke:#b85450
    style AuthCreds fill:#f8cecc,stroke:#b85450
