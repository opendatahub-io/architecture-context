graph LR
    ODH["odh-model-controller<br/>Operator"]

    %% Required External Dependencies
    ODH -->|"CRDs, serving infra<br/>(required)"| KServe["KServe<br/>v0.15.1 (ODH fork v0.17.0-rc1)"]
    ODH -->|"controller framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.19.7"]

    %% Optional External Dependencies
    ODH -->|"auth policies<br/>(optional)"| Kuadrant["Kuadrant AuthPolicy<br/>v1"]
    ODH -->|"authz backend<br/>(optional)"| Authorino["Authorino<br/>v0.22.0"]
    ODH -->|"TLS filter<br/>(optional)"| Istio["Istio EnvoyFilter<br/>v1alpha3"]
    ODH -->|"HTTPRoute, Gateway<br/>(optional)"| GatewayAPI["Gateway API<br/>v1.2.1"]
    ODH -->|"custom metric autoscaling<br/>(optional)"| KEDA["KEDA<br/>v2.17.3"]
    ODH -->|"ServiceMonitor CRDs<br/>(optional)"| PrometheusOp["Prometheus Operator"]
    ODH -->|"model versioning<br/>(optional)"| ModelRegistry["Model Registry<br/>v0.2.19"]

    %% External Services
    ODH -->|"NIM catalog, key validation<br/>HTTPS/443 Bearer Token"| NGC["NVIDIA NGC API"]
    ODH -->|"NIM image verification<br/>HTTPS/443 Docker Auth"| NVCR["nvcr.io Registry"]
    ODH -->|"CRD CRUD, watches<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator"] -->|"deploys via kustomize"| ODH
    ODH -->|"read DSC spec"| DSC["DataScienceCluster CRD"]
    ODH -->|"read init state"| DSCI["DSCInitialization CRD"]
    ODH -->|"create Routes"| OpenShiftRoute["OpenShift Route API"]
    ODH -->|"create NIM templates"| OpenShiftTemplate["OpenShift Template API"]
    ODH -->|"auth audiences"| OpenShiftAuth["OpenShift Authentication"]
    ODH -->|"CA certificates"| ServiceCA["OpenShift Service CA"]
    ODH -->|"CA bundle source"| TrustedCA["odh-trusted-ca-bundle"]

    %% Integration Points (consumers)
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>HTTPS/443"| ODH

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required dependencies
    style KServe fill:#e74c3c,stroke:#333,color:#fff
    style ControllerRuntime fill:#e74c3c,stroke:#333,color:#fff

    %% Optional external dependencies
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PrometheusOp fill:#999,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style NGC fill:#76b900,stroke:#333,color:#fff
    style NVCR fill:#76b900,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333

    %% Internal platform
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftRoute fill:#e74c3c,stroke:#333,color:#fff
    style OpenShiftTemplate fill:#e74c3c,stroke:#333,color:#fff
    style OpenShiftAuth fill:#e74c3c,stroke:#333,color:#fff
    style ServiceCA fill:#e74c3c,stroke:#333,color:#fff
    style TrustedCA fill:#f5a623,stroke:#333

