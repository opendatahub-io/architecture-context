graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["Gateway Controller<br/>(Envoy / Istio / agentgateway)<br/>80/TCP or 443/TCP"]
    end

    subgraph LLMDStack["llm-d Inference Stack"]
        subgraph Router["llm-d Router / EPP"]
            EPP["llm-d-inference-scheduler<br/>(Endpoint Picker Plugin)<br/>80/TCP HTTP, 9090/TCP metrics"]
            ExtProc["ext-proc gRPC<br/>interface"]
            EPP --- ExtProc
        end

        subgraph InferencePool["InferencePool (K8s CRD)"]
            direction TB
            subgraph CUDAServers["CUDA Model Servers"]
                CUDA1["llm-d-cuda Pod<br/>vLLM 8000/TCP<br/>NVSHMEM + UCX + NIXL"]
                CUDA2["llm-d-cuda Pod<br/>vLLM 8000/TCP"]
                CUDA3["llm-d-cuda Pod<br/>vLLM 8000/TCP"]
            end

            subgraph AltAccelerators["Alternative Accelerator Images"]
                ROCm["llm-d-rocm<br/>AMD ROCm + RIXL"]
                HPU["llm-d-hpu<br/>Intel Gaudi + vllm-gaudi"]
                CPU["llm-d-cpu<br/>CPU-only + NIXL"]
            end
        end

        subgraph KVTransfer["KV Cache Transfer Plane"]
            NIXL["NIXL / UCX<br/>RDMA/TCP"]
            NVSHMEM["NVSHMEM<br/>RDMA/IB"]
            ZMQ["KV Events<br/>ZMQ 5556/TCP"]
        end
    end

    subgraph K8sCRDs["Kubernetes CRDs (upstream)"]
        GatewayCR["Gateway CR<br/>gateway.networking.k8s.io/v1"]
        HTTPRoute["HTTPRoute CR<br/>gateway.networking.k8s.io/v1"]
        InfPoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        InfObjCR["InferenceObjective CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    end

    subgraph Observability["Observability"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC"]
    end

    subgraph ExternalServices["External Services"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    end

    %% Request Flow
    Client -->|HTTP/HTTPS| Gateway
    Gateway -->|ext-proc gRPC| ExtProc
    ExtProc -->|routing decision| Gateway
    Gateway -->|HTTP 8000/TCP| CUDA1
    Gateway -->|HTTP 8000/TCP| CUDA2
    Gateway -->|HTTP 8000/TCP| CUDA3

    %% EPP monitoring
    EPP -->|metrics scrape 8000/TCP| CUDA1
    EPP -->|metrics scrape 8000/TCP| CUDA2

    %% KV Transfer
    CUDA1 <-->|RDMA/TCP| NIXL
    CUDA2 <-->|RDMA/TCP| NIXL
    CUDA1 <-->|RDMA/IB| NVSHMEM
    CUDA1 -->|KV events| ZMQ
    ZMQ -->|event subscription| EPP

    %% CRD relationships
    GatewayCR -->|configures| Gateway
    HTTPRoute -->|routes to| InfPoolCR
    InfPoolCR -->|selects pods| InferencePool

    %% Observability
    CUDA1 -->|/metrics| Prometheus
    EPP -->|9090/TCP| Prometheus
    CUDA1 -->|traces 4317/TCP| OTEL
    EPP -->|traces 4317/TCP| OTEL

    %% External
    CUDA1 -->|model download 443/TCP| HFHub

    %% Styling
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ExtProc fill:#4a90e2,stroke:#333,stroke-width:1px,color:#fff
    style CUDA1 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CUDA2 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CUDA3 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ROCm fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style HPU fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style CPU fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style NIXL fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style NVSHMEM fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style ZMQ fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style HFHub fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Prometheus fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style OTEL fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style GatewayCR fill:#f5a623,stroke:#333,stroke-width:1px
    style HTTPRoute fill:#f5a623,stroke:#333,stroke-width:1px
    style InfPoolCR fill:#f5a623,stroke:#333,stroke-width:1px
    style InfObjCR fill:#f5a623,stroke:#333,stroke-width:1px
