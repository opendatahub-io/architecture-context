    style BatchRes fill:#7ed321,stroke:#333,color:#fff
    style ScaleRes fill:#7ed321,stroke:#333,color:#fff
    style PolicyRes fill:#7ed321,stroke:#333,color:#fff
    style RouteRes fill:#7ed321,stroke:#333,color:#fff
    style MonitorRes fill:#7ed321,stroke:#333,color:#fff
    style KubeflowRes fill:#7ed321,stroke:#333,color:#fff
    style APIExtRes fill:#7ed321,stroke:#333,color:#fff
    style TokenReviewRes fill:#7ed321,stroke:#333,color:#fff
