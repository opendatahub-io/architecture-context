graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Feast["feast-{name}<br/>(user namespace)"]
        SA_Subjects["Permission Policy Subjects<br/>(from Feast permissions)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_TokenReview["feast-{name}-cluster-binding"]
        CRB_Discover["feast-{ns}--{name}-discover"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Viewer["feast-{ns}--{name}-viewer<br/>(user namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Viewer["featurestore-viewer-role"]
        CR_Editor["featurestore-editor-role"]
        CR_TokenReview["feast-token-review-cluster-role"]
        CR_Discover["feast-discover-namespaces"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role"]
        R_NSViewer["feast-{ns}--{name}-viewer"]
    end

    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB
        FeastRes["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        CoreRes["core ('')<br/>configmaps, services,<br/>persistentvolumeclaims,<br/>serviceaccounts<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        CoreRead["core ('')<br/>namespaces, pods, secrets<br/><i>get,list,watch</i><br/>pods/exec: create"]
        AppsRes["apps<br/>deployments<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        RBACRes["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles,<br/>clusterrolebindings,<br/>subjectaccessreviews<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        AuthRes["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        BatchRes["batch<br/>cronjobs<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        ScaleRes["autoscaling<br/>horizontalpodautoscalers<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        PolicyRes["policy<br/>poddisruptionbudgets<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        RouteRes["route.openshift.io<br/>routes<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        MonitorRes["monitoring.coreos.com<br/>servicemonitors<br/><i>create,delete,get,list,<br/>patch,watch</i>"]
        KubeflowRes["kubeflow.org<br/>notebooks<br/><i>get,list,watch</i>"]
        APIExtRes["apiextensions.k8s.io<br/>customresourcedefinitions<br/><i>get,list</i>"]
    end

    subgraph TokenReviewPermissions["feast-token-review-cluster-role Permissions"]
        TokenReviewRes["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        SARRes["rbac.authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    subgraph ViewerPermissions["featurestore-viewer-role Permissions"]
        ViewerRes["feast.dev<br/>featurestores<br/>featurestores/status<br/><i>get,list,watch</i>"]
    end

    subgraph DiscoverPermissions["feast-discover-namespaces Permissions"]
        DiscoverRes["rbac.authorization.k8s.io<br/>rolebindings<br/><i>list</i>"]
    end

    %% Service Account → Binding → Role → Resources
    SA_CM -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager --- ManagerPermissions

    SA_CM -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    SA_Feast -->|bound via| CRB_TokenReview
    CRB_TokenReview -->|grants| CR_TokenReview
    CR_TokenReview --- TokenReviewPermissions

    SA_Subjects -->|bound via| CRB_Discover
    CRB_Discover -->|grants| CR_Discover
    CR_Discover --- DiscoverPermissions

    SA_Subjects -->|bound via| RB_Viewer
    RB_Viewer -->|grants| R_NSViewer

    CR_Viewer --- ViewerPermissions
    CR_Editor ---|"superset of viewer +<br/>create,delete,patch,update"| ViewerRes

