graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["odh-model-controller<br/>(Namespace: opendatahub)"]
        SA_API["model-serving-api<br/>(Namespace: opendatahub)"]
        SA_Dynamic["Dynamic SAs<br/>(per InferenceService)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["odh-model-controller-rolebinding<br/>(Cluster-scoped)"]
        CRB_API["model-serving-api<br/>(Cluster-scoped)"]
        CRB_Dynamic["{ns}-{sa}-opendatahub-<br/>model-serving-access<br/>(Dynamic, Cluster-scoped)"]
        CRB_Leader["odh-model-controller-leader-election<br/>(Namespace-scoped)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Controller["odh-model-controller-role"]
        CR_API["model-serving-api"]
        CR_Leader["odh-model-controller-<br/>leader-election-role"]
        CR_Serving["opendatahub-<br/>model-serving-access"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_Leader
    SA_API -->|bound via| CRB_API
    SA_Dynamic -->|bound via| CRB_Dynamic

    CRB_Controller -->|grants| CR_Controller
    CRB_API -->|grants| CR_API
    CRB_Leader -->|grants| CR_Leader
    CRB_Dynamic -->|grants| CR_Serving

    %% Controller Role Resources
    subgraph ControllerResources["odh-model-controller-role Resources"]
        direction LR

        subgraph CoreAPI["Core API ('')"]
            ConfigMaps["configmaps<br/>CRUD + watch"]
            Secrets["secrets<br/>CRUD + watch"]
            ServiceAccounts_R["serviceaccounts<br/>CRUD + watch"]
            Services_R["services<br/>CRUD + watch"]
            Endpoints["endpoints<br/>create, get, list,<br/>patch, update, watch"]
            Namespaces["namespaces<br/>create, get, list,<br/>patch, update, watch"]
            Pods["pods<br/>create, get, list,<br/>patch, update, watch"]
            Events["events<br/>create, patch"]
        end

        subgraph OpenShiftAPI["OpenShift APIs"]
            Auth_R["config.openshift.io<br/>authentications<br/>get, list, watch"]
            Routes_R["route.openshift.io<br/>routes, routes/custom-host<br/>CRUD + watch"]
            Templates_R["template.openshift.io<br/>templates<br/>CRUD + watch"]
        end

        subgraph PlatformAPI["Platform APIs"]
            DSC_R["datasciencecluster.odh.io<br/>datascienceclusters<br/>get, list, watch"]
            DSCI_R["dscinitialization.odh.io<br/>dscinitializations<br/>get, list, watch"]
            NIM_R["nim.opendatahub.io<br/>accounts, finalizers, status<br/>get, list, patch,<br/>update, watch"]
        end

        subgraph ServingAPI["Serving APIs"]
            ISVC_R["serving.kserve.io<br/>inferenceservices + finalizers<br/>CRUD + watch"]
            IG_R["serving.kserve.io<br/>inferencegraphs<br/>get, list, watch"]
            LLMISVC_R["serving.kserve.io<br/>llminferenceservices<br/>+ finalizers, status<br/>get, list, patch, post,<br/>update, watch"]
            SR_R["serving.kserve.io<br/>servingruntimes + finalizers<br/>create, get, list,<br/>update, watch"]
            LLMISVCConfig_R["serving.kserve.io<br/>llminferenceserviceconfigs<br/>get, list, watch"]
        end

        subgraph NetworkAPI["Network APIs"]
            GW_R["gateway.networking.k8s.io<br/>gateways + finalizers<br/>get, list, patch,<br/>update, watch"]
            HTTPRoute_R["gateway.networking.k8s.io<br/>httproutes<br/>get, list, watch"]
            EnvoyFilter_R["networking.istio.io<br/>envoyfilters<br/>CRUD + watch"]
            NetPol_R["networking.k8s.io<br/>networkpolicies<br/>CRUD + watch"]
        end

        subgraph SecurityAPI["Security & Auth APIs"]
            AuthPolicy_R["kuadrant.io<br/>authpolicies + status<br/>CRUD + watch"]
            Kuadrant_R["kuadrant.io<br/>kuadrants<br/>get, list, watch"]
            Authorino_R["operator.authorino.kuadrant.io<br/>authorinos<br/>get, list, watch"]
            RBAC_R["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/>CRUD + watch"]
        end

        subgraph MonitoringAPI["Monitoring APIs"]
            SM_R["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/>CRUD + watch"]
            Metrics_R["metrics.k8s.io<br/>nodes, pods<br/>get, list, watch"]
            KEDA_R["keda.sh<br/>triggerauthentications<br/>CRUD + watch"]
        end
    end

    CR_Controller -->|grants access to| ControllerResources

    %% API Role Resources
    subgraph APIResources["model-serving-api Resources"]
        GW_API_R["gateway.networking.k8s.io<br/>gateways<br/>list"]
        NS_API_R["core<br/>namespaces<br/>get"]
    end

    CR_API -->|grants access to| APIResources

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_API fill:#4a90e2,color:#fff
    style SA_Dynamic fill:#4a90e2,color:#fff

    style CRB_Controller fill:#f5a623
    style CRB_API fill:#f5a623
    style CRB_Dynamic fill:#f5a623
    style CRB_Leader fill:#f5a623

    style CR_Controller fill:#e74c3c,color:#fff
    style CR_API fill:#e74c3c,color:#fff
    style CR_Leader fill:#e74c3c,color:#fff
    style CR_Serving fill:#e74c3c,color:#fff
