graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph APILayer["API Layer"]
            GRPCModule["GRPCServerModule<br/>gRPC/HTTP2"]
            DrogonHTTP["DrogonHttpServer<br/>HTTP/REST"]
        end

        subgraph Frontends["API Frontends"]
            TFSFrontend["TFS v1 Frontend<br/>/v1/models/..."]
            KFSFrontend["KServe v2 Frontend<br/>/v2/models/..."]
            OpenAIFrontend["OpenAI v3 Frontend<br/>/v3/chat/completions<br/>/v3/embeddings<br/>/v3/images/generations<br/>/v3/audio/*"]
        end

        subgraph ServingEngine["Serving Engine"]
            ServableManager["ServableManagerModule<br/>Model Lifecycle"]
            ModelInstance["ModelInstance<br/>Classical ML Models"]
            MediaPipeExec["MediaPipe Graph Executor<br/>Multi-Model Pipelines"]
            GenAiServable["GenAiServable<br/>LLM Continuous Batching<br/>Streaming (SSE)"]
        end

        subgraph Runtime["Runtime Libraries"]
            OVRuntime["OpenVINO Runtime 2026.1<br/>Core Inference Engine"]
            OVGenAI["OpenVINO GenAI 2026.1<br/>LLM/Image/Audio Pipelines"]
            OVTokenizers["OpenVINO Tokenizers 2026.1"]
        end

        subgraph Support["Support Modules"]
            MetricModule["MetricModule<br/>Prometheus /metrics"]
            PythonInterp["PythonInterpreterModule<br/>Custom Python Nodes"]
            HfPullModule["HfPullModelModule<br/>HuggingFace Downloads"]
        end

        LibOVMS["libovms_shared.so<br/>C API Embedding Library"]
    end

    %% API Layer connections
    GRPCModule --> TFSFrontend
    GRPCModule --> KFSFrontend
    DrogonHTTP --> TFSFrontend
    DrogonHTTP --> KFSFrontend
    DrogonHTTP --> OpenAIFrontend

    %% Frontend to engine connections
    TFSFrontend --> ModelInstance
    KFSFrontend --> ModelInstance
    KFSFrontend --> MediaPipeExec
    OpenAIFrontend --> MediaPipeExec
    MediaPipeExec --> GenAiServable

    %% Engine to runtime
    ModelInstance --> OVRuntime
    GenAiServable --> OVGenAI
    GenAiServable --> OVTokenizers
    OVGenAI --> OVRuntime
    ServableManager --> ModelInstance
    ServableManager --> MediaPipeExec

    %% External integrations
    Client["External Client"] --> GRPCModule
    Client --> DrogonHTTP

    KServe["KServe<br/>InferenceService"] -.->|deploys as<br/>serving runtime| OVMS
    KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS"] -->|auth proxy| DrogonHTTP
    Istio["Istio Sidecar<br/>mTLS"] -.->|transparent<br/>encryption| OVMS

    HfPullModule -->|HTTPS/443| HFHub["HuggingFace Hub"]
    ServableManager -->|HTTPS/443| S3["S3 Storage"]
    ServableManager -->|HTTPS/443| Azure["Azure Blob Storage"]
    ServableManager -->|HTTPS/443| GCS["Google Cloud Storage"]
    ServableManager -->|local| LocalFS["Local Filesystem"]

    Prometheus["Prometheus"] -->|scrapes /metrics| MetricModule

    %% Styling
    style OVMS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style GRPCModule fill:#4a90e2,stroke:#333,color:#fff
    style DrogonHTTP fill:#4a90e2,stroke:#333,color:#fff
    style TFSFrontend fill:#7986cb,stroke:#333,color:#fff
    style KFSFrontend fill:#7986cb,stroke:#333,color:#fff
    style OpenAIFrontend fill:#7986cb,stroke:#333,color:#fff
    style ServableManager fill:#4db6ac,stroke:#333,color:#fff
    style ModelInstance fill:#4db6ac,stroke:#333,color:#fff
    style MediaPipeExec fill:#4db6ac,stroke:#333,color:#fff
    style GenAiServable fill:#4db6ac,stroke:#333,color:#fff
    style OVRuntime fill:#ff8a65,stroke:#333,color:#fff
    style OVGenAI fill:#ff8a65,stroke:#333,color:#fff
    style OVTokenizers fill:#ff8a65,stroke:#333,color:#fff
    style MetricModule fill:#a1887f,stroke:#333,color:#fff
    style PythonInterp fill:#a1887f,stroke:#333,color:#fff
    style HfPullModule fill:#a1887f,stroke:#333,color:#fff
    style LibOVMS fill:#90a4ae,stroke:#333,color:#fff
    style Client fill:#f5f5f5,stroke:#999
    style KServe fill:#7ed321,stroke:#333
    style KubeRBACProxy fill:#7ed321,stroke:#333
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e65100,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style LocalFS fill:#f5a623,stroke:#333
