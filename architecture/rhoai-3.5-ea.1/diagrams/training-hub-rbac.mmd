graph TD
    subgraph Note["training-hub RBAC"]
        direction TB
        Info["training-hub is a Python SDK / Library<br/>No Kubernetes RBAC roles or bindings<br/><br/>Authentication is handled at runtime<br/>via environment variables or function arguments"]
    end

    subgraph RuntimeCredentials["Runtime Credentials (User-Provided)"]
        direction TB
        HFToken["HF_TOKEN<br/>HuggingFace Hub access<br/>Scope: Model + dataset downloads<br/>Optional"]
        WandBKey["WANDB_API_KEY<br/>Weights & Biases API<br/>Scope: Experiment tracking<br/>Optional"]
        MLflowCreds["MLflow Credentials<br/>Configurable per deployment<br/>Scope: Experiment tracking<br/>Optional"]
    end

    subgraph AccessPatterns["Access Patterns"]
        direction TB
        HFAccess["HuggingFace Hub<br/>Read: Models, tokenizers, datasets, configs<br/>Write: None<br/>Protocol: HTTPS/443"]
        WandBAccess["Weights & Biases<br/>Read: None<br/>Write: Metrics, logs, artifacts<br/>Protocol: HTTPS/443"]
        MLflowAccess["MLflow Server<br/>Read: None<br/>Write: Metrics, params, artifacts<br/>Protocol: HTTP(S)"]
        FSAccess["Local Filesystem<br/>Read: Training data, cached models<br/>Write: Checkpoints, metrics, logs<br/>Protocol: Filesystem I/O"]
        GPUAccess["GPU Resources<br/>Read: N/A<br/>Write: CUDA compute, VRAM<br/>Protocol: CUDA / NCCL"]
    end

    HFToken -->|"authenticates"| HFAccess
    WandBKey -->|"authenticates"| WandBAccess
    MLflowCreds -->|"authenticates"| MLflowAccess

    %% Styling
    classDef info fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cred fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef access fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Info info
    class HFToken,WandBKey,MLflowCreds cred
    class HFAccess,WandBAccess,MLflowAccess,FSAccess,GPUAccess access
