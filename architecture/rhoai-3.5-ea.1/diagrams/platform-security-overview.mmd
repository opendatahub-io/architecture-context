graph TD
    subgraph AuthMechanisms["Authentication Mechanisms"]
        KRBPAuth["kube-rbac-proxy<br/>TokenReview + SubjectAccessReview<br/>FIPS TLS Cipher Suites<br/>Port 8443"]
        IntOAuth["IntegratedOAuth<br/>OpenShift OAuth<br/>OAuthClient CR + EnvoyFilter"]
        OIDCAuth["OIDC<br/>External Provider<br/>GatewayConfig CR"]
        mTLSAuth["mTLS<br/>Client Certificates<br/>Istio PeerAuth + Ray TLS"]
        BearerFwd["Bearer Token Forwarding<br/>User token from Gateway<br/>K8s API impersonation"]
        APIKeyAuth["API Key Management<br/>Authorino ext-authz<br/>Per-provider credential injection"]
        SARbac["ServiceAccount RBAC<br/>Bound SA tokens<br/>Projected volumes"]
    end

    subgraph ServiceAccounts["Key ServiceAccounts (redhat-ods-applications)"]
        SA_rhods["rhods-operator<br/>NS: redhat-ods-operator"]
        SA_kserve["kserve-controller-manager<br/>NS: redhat-ods-applications"]
        SA_llmisvc["llmisvc-controller-manager<br/>NS: redhat-ods-applications"]
        SA_odmctrl["odh-model-controller<br/>NS: redhat-ods-applications"]
        SA_dashboard["odh-dashboard<br/>NS: redhat-ods-applications"]
        SA_dsp["data-science-pipelines-operator<br/>NS: redhat-ods-applications"]
        SA_trainer["training-operator<br/>NS: redhat-ods-applications"]
        SA_modelreg["model-registry-operator<br/>NS: redhat-ods-applications"]
        SA_trustyai["trustyai-service-operator<br/>NS: redhat-ods-applications"]
    end

    subgraph ClusterRoles["ClusterRoles (Most Privileged)"]
        CR_rhods["rhods-operator-role<br/>DSC, DSCI lifecycle<br/>All 16 component CRDs<br/>OLM resources, Gateway API"]
        CR_kserve["kserve-manager-role<br/>serving.kserve.io/*<br/>core/services, apps/deployments<br/>networking.istio.io/*<br/>autoscaling.keda.sh/*"]
        CR_odmctrl["odh-model-controller-role<br/>InferenceService status<br/>NetworkPolicy, ServiceMonitor<br/>Gateway discovery API"]
        CR_dashboard["odh-dashboard-role<br/>opendatahub.io/*<br/>monitoring.coreos.com/*<br/>Bearer token forwarding"]
        CR_dsp["dsp-operator-role<br/>datasciencepipelines<br/>.opendatahub.io/*"]
        CR_trainer["training-operator-role<br/>kubeflow.org/*<br/>(PyTorchJob, MPIJob,<br/>TFJob, XGBoostJob)"]
    end

    subgraph KRBPSidecars["kube-rbac-proxy Deployments"]
        KRBP_dash["kube-rbac-proxy<br/>→ odh-dashboard :8443"]
        KRBP_modelreg["kube-rbac-proxy<br/>→ Model Registry Operator :8443"]
        KRBP_trustyai["kube-rbac-proxy<br/>→ TrustyAI Operator :8443"]
        KRBP_ogx["kube-rbac-proxy<br/>→ OGX Operator :8443"]
        KRBP_evalhub["kube-rbac-proxy<br/>→ EvalHub :8443"]
        KRBP_feast["kube-rbac-proxy<br/>→ Feast Operator :8443"]
        KRBP_nemo["kube-rbac-proxy<br/>→ NeMo Guardrails :8443"]
        KRBP_notebooks["kube-rbac-proxy<br/>→ Notebooks (injected) :8443"]
    end

    subgraph TLSConfig["TLS Configuration"]
        TLS_webhooks["Admission Webhooks<br/>9443/TCP Server TLS<br/>cert-manager or service-ca<br/>12+ webhook configs"]
        TLS_metrics["Metrics Endpoints<br/>8443/TCP Server TLS<br/>kube-rbac-proxy terminated<br/>50 endpoints"]
        TLS_gateway["Gateway Ingress<br/>443/TCP Server TLS<br/>Gateway API listeners<br/>TLS 1.2+"]
        TLS_mesh["Service Mesh Internal<br/>mTLS PERMISSIVE/STRICT<br/>Istio PeerAuthentication<br/>DestinationRule TLS"]
        TLS_ray["Ray Cluster Internal<br/>Client-to-cluster mTLS<br/>Generated certificates"]
    end

    subgraph ContainerSecurity["Container Security Patterns"]
        CS_nonroot1["Non-root USER 1001<br/>82 Dockerfiles<br/>OpenShift restricted SCC"]
        CS_nonroot2["Non-root USER 65532:65532<br/>66 Dockerfiles<br/>distroless convention (Go)"]
        CS_ubi9["UBI 9 Base Images<br/>87 production Dockerfiles<br/>RHEL 9 security patches"]
        CS_fips["FIPS 140-2 Go Builds<br/>strictfipsruntime<br/>CGO_ENABLED=1"]
        CS_caps["Capability Dropping<br/>drop: ALL<br/>seccomp: RuntimeDefault"]
        CS_multistage["Multi-Stage Builds<br/>372 Dockerfiles<br/>Minimal production images"]
    end

    subgraph FIPSCiphers["FIPS-Compliant TLS Cipher Suites"]
        Cipher1["TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"]
        Cipher2["TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"]
        Cipher3["TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"]
        Cipher4["TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384"]
        Cipher5["+ 2 additional FIPS ciphers"]
    end

    subgraph FIPSGaps["Known FIPS Gaps"]
        Gap1["KServe localmodel<br/>CGO_ENABLED=0<br/>No FIPS crypto"]
        Gap2["KServe PodMonitor<br/>InsecureSkipVerify<br/>in TLS config"]
        Gap3["odh-dashboard BFFs<br/>INSECURE_SKIP_VERIFY<br/>flags in Go code"]
    end

    subgraph GatewayAuth["Gateway API Authentication Stack"]
        GW_envoyfilter["EnvoyFilter CRs<br/>on data-science-gateway"]
        GW_kubeauthproxy["kube-auth-proxy<br/>HPA 2+ replicas"]
        GW_authorino["Authorino<br/>API key + rate limiting<br/>(MaaS only)"]
    end

    subgraph NetworkIsolation["Network Isolation"]
        NP1["NetworkPolicy per component<br/>Namespace-scoped isolation"]
        NP2["Namespace separation<br/>Operator, Platform, Monitoring,<br/>User namespaces"]
        NP3["Cross-namespace managed<br/>ownerReference-less resources<br/>Label selectors + finalizers"]
    end

    %% RBAC Bindings
    SA_rhods -->|bound to| CR_rhods
    SA_kserve -->|bound to| CR_kserve
    SA_odmctrl -->|bound to| CR_odmctrl
    SA_dashboard -->|bound to| CR_dashboard
    SA_dsp -->|bound to| CR_dsp
    SA_trainer -->|bound to| CR_trainer

    %% Auth mechanism usage
    KRBPAuth -->|enforces| KRBP_dash
    KRBPAuth -->|enforces| KRBP_modelreg
    KRBPAuth -->|enforces| KRBP_trustyai
    KRBPAuth -->|enforces| KRBP_ogx
    KRBPAuth -->|enforces| KRBP_evalhub
    KRBPAuth -->|enforces| KRBP_feast
    KRBPAuth -->|enforces| KRBP_nemo
    KRBPAuth -->|enforces| KRBP_notebooks

    IntOAuth -->|configured via| GW_envoyfilter
    OIDCAuth -->|configured via| GW_envoyfilter
    GW_envoyfilter -->|routes to| GW_kubeauthproxy
    APIKeyAuth -->|configured via| GW_authorino

    BearerFwd -->|used by| SA_dashboard
    mTLSAuth -->|used by| TLS_mesh
    mTLSAuth -->|used by| TLS_ray
    SARbac -->|used by| SA_kserve
    SARbac -->|used by| SA_rhods
    SARbac -->|used by| SA_dsp

    %% TLS relationships
    TLS_metrics -->|via| KRBPAuth
    TLS_gateway -->|via| GW_envoyfilter

    %% FIPS cipher suite usage
    KRBPAuth -->|uses| FIPSCiphers
    CS_fips -->|validates via| FIPSCiphers

