graph TB
    subgraph External["External Clients"]
        Prometheus["Prometheus<br/>(openshift-monitoring)"]
        Dashboard["ODH Dashboard"]
        OtherClient["Other K8s Clients"]
    end

    subgraph Pod["Component Pod (e.g., Model Controller, Dashboard)"]
        direction TB

        subgraph Sidecar["kube-rbac-proxy Sidecar"]
            direction TB
            PathFilter["Path Filter<br/>(WithAllowPaths)"]
            AuthNFilter["Authentication Filter<br/>(WithAuthentication)"]
            AuthZFilter["Authorization Filter<br/>(WithAuthorization)"]
            AuthHeaders["Auth Header Injection<br/>(WithAuthHeaders)"]
            HardcodedAuth["Hardcoded Metrics Authorizer<br/>(prometheus-k8s SA)"]
            CertReloader["TLS CertReloader<br/>(polling, 1min interval)"]
            SanitizingFilter["Token Sanitizing Filter<br/>(klog redaction)"]

            PathFilter -->|"passes"| AuthNFilter
            AuthNFilter -->|"authenticated"| AuthZFilter
            AuthZFilter -->|"authorized"| AuthHeaders
        end

        UpstreamApp["Upstream Application<br/>(metrics, API, etc.)<br/>127.0.0.1:8081"]
    end

    subgraph K8sControlPlane["Kubernetes Control Plane"]
        APIServer["Kubernetes API Server"]
        TokenReview["TokenReview API<br/>(authentication/v1)"]
        SAR["SubjectAccessReview API<br/>(authorization/v1)"]
    end

    subgraph ExternalIdentity["External Identity (optional)"]
        OIDC["OIDC Identity Provider"]
    end

    subgraph PlatformOps["Platform Operations"]
        Operator["rhods-operator"]
        CertManager["cert-manager"]
    end

    %% Client flows
    Prometheus -->|"HTTPS/8443<br/>Bearer Token"| PathFilter
    Dashboard -->|"HTTPS/8443<br/>Bearer Token"| PathFilter
    OtherClient -->|"HTTPS/8443<br/>Bearer/mTLS/OIDC"| PathFilter

    %% Auth flows
    AuthNFilter -->|"TokenReview<br/>HTTPS/443"| TokenReview
    AuthNFilter -.->|"OIDC JWKS<br/>HTTPS/443"| OIDC
    AuthZFilter -->|"SubjectAccessReview<br/>HTTPS/443"| SAR
    HardcodedAuth -.->|"bypasses SAR for<br/>prometheus-k8s SA"| AuthZFilter

    %% Forwarding
    AuthHeaders -->|"HTTP/8081<br/>localhost<br/>+ x-remote-user headers"| UpstreamApp

    %% TLS management
    CertManager -.->|"provisions TLS certs"| CertReloader
    Operator -.->|"deploys sidecar"| Sidecar

    %% API Server grouping
    APIServer --- TokenReview
    APIServer --- SAR

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PathFilter fill:#5ba3f5,stroke:#333,color:#fff
    style AuthNFilter fill:#5ba3f5,stroke:#333,color:#fff
    style AuthZFilter fill:#5ba3f5,stroke:#333,color:#fff
    style AuthHeaders fill:#5ba3f5,stroke:#333,color:#fff
    style HardcodedAuth fill:#e8a838,stroke:#333,color:#fff
    style CertReloader fill:#5ba3f5,stroke:#333,color:#fff
    style SanitizingFilter fill:#5ba3f5,stroke:#333,color:#fff
    style UpstreamApp fill:#7ed321,stroke:#333,color:#fff
    style APIServer fill:#f5a623,stroke:#333,color:#fff
    style TokenReview fill:#f5a623,stroke:#333,color:#fff
    style SAR fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style Dashboard fill:#e8e8e8,stroke:#333
    style OtherClient fill:#e8e8e8,stroke:#333
    style Operator fill:#b8b8b8,stroke:#333
    style CertManager fill:#b8b8b8,stroke:#333
    style OIDC fill:#d4a8e8,stroke:#333
