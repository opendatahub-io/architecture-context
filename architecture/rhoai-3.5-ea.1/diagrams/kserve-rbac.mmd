graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_ISVC["kserve-controller-manager<br/>(Namespace: kserve)"]
        SA_LLMISVC["llmisvc-controller-manager<br/>(Namespace: kserve)"]
        SA_EPP["{name}-epp-sa<br/>(Namespace: {user-ns})"]
        SA_Metrics["kserve-metrics-reader-sa<br/>(Namespace: {user-ns})"]
        SA_MN["{name}-kserve-mn<br/>(Namespace: {user-ns})"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_ISVC["kserve-controller-manager<br/>-rolebinding"]
        CRB_LLMISVC["llmisvc-controller-manager<br/>-clusterrolebinding"]
        CRB_EPP_Auth["{name}-epp-auth-rb<br/>(system:auth-delegator)"]
        CRB_Metrics["kserve-metrics-reader<br/>-role-binding-{ns}"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_EPP["{name}-epp-rb<br/>(Namespace: {user-ns})"]
        RB_SCC["{name}-kserve-mn-scc<br/>(OCP SCC binding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_ISVC["kserve-controller-manager"]
        CR_LLMISVC["llmisvc-controller-manager"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Metrics["kserve-metrics-reader-cluster-role"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_EPP["{name}-epp-role"]
        R_SCC["openshift-ai-llminferenceservice-scc<br/>(SecurityContextConstraints)"]
    end

    subgraph ISVC_Resources["kserve-controller-manager Resources"]
        direction LR
        ISVC_R1["serving.kserve.io<br/>inferenceservices<br/>servingruntimes<br/>clusterservingruntimes<br/>clusterstoragecontainers<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        ISVC_R2["apps<br/>deployments<br/><i>full CRUD</i>"]
        ISVC_R3["serving.knative.dev<br/>services<br/><i>full CRUD</i>"]
        ISVC_R4["networking.istio.io<br/>virtualservices<br/><i>full CRUD</i>"]
        ISVC_R5["gateway.networking.k8s.io<br/>httproutes<br/><i>full CRUD</i>"]
        ISVC_R6["autoscaling<br/>horizontalpodautoscalers<br/><i>full CRUD</i>"]
        ISVC_R7["core (v1)<br/>services, configmaps,<br/>secrets, namespaces,<br/>events, pods, sa<br/><i>full CRUD</i>"]
        ISVC_R8["route.openshift.io<br/>routes<br/><i>get,list,watch</i>"]
        ISVC_R9["admissionregistration<br/>webhook configs<br/><i>full CRUD</i>"]
        ISVC_R10["keda.sh<br/>scaledobjects<br/><i>full CRUD</i>"]
    end

    subgraph LLMISVC_Resources["llmisvc-controller-manager Resources"]
        direction LR
        LLM_R1["serving.kserve.io<br/>llminferenceservices<br/>llminferenceserviceconfigs<br/><i>full CRUD</i>"]
        LLM_R2["gateway.networking.k8s.io<br/>httproutes, gateways,<br/>gatewayclasses<br/><i>full CRUD</i>"]
        LLM_R3["inference.networking.x-k8s.io<br/>inferencepools,<br/>inferencemodels,<br/>inferenceobjectives<br/><i>full CRUD</i>"]
        LLM_R4["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/><i>full CRUD</i>"]
        LLM_R5["llmd.ai<br/>variantautoscalings<br/><i>full CRUD</i>"]
        LLM_R6["monitoring.coreos.com<br/>podmonitors,<br/>servicemonitors<br/><i>full CRUD</i>"]
        LLM_R7["networking.istio.io<br/>destinationrules<br/><i>get,list,watch,<br/>create,update,delete</i>"]
        LLM_R8["security.openshift.io<br/>SCC: openshift-ai-<br/>llminferenceservice-scc<br/><i>use</i>"]
        LLM_R9["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings<br/><i>full CRUD</i>"]
    end

    %% SA -> CRB -> CR -> Resources
    SA_ISVC -->|bound via| CRB_ISVC
    CRB_ISVC -->|grants| CR_ISVC
    CR_ISVC -->|permissions| ISVC_R1
    CR_ISVC -->|permissions| ISVC_R2
    CR_ISVC -->|permissions| ISVC_R3
    CR_ISVC -->|permissions| ISVC_R4
    CR_ISVC -->|permissions| ISVC_R5
    CR_ISVC -->|permissions| ISVC_R6
    CR_ISVC -->|permissions| ISVC_R7
    CR_ISVC -->|permissions| ISVC_R8
    CR_ISVC -->|permissions| ISVC_R9
    CR_ISVC -->|permissions| ISVC_R10

    SA_LLMISVC -->|bound via| CRB_LLMISVC
    CRB_LLMISVC -->|grants| CR_LLMISVC
    CR_LLMISVC -->|permissions| LLM_R1
    CR_LLMISVC -->|permissions| LLM_R2
    CR_LLMISVC -->|permissions| LLM_R3
    CR_LLMISVC -->|permissions| LLM_R4
    CR_LLMISVC -->|permissions| LLM_R5
    CR_LLMISVC -->|permissions| LLM_R6
    CR_LLMISVC -->|permissions| LLM_R7
    CR_LLMISVC -->|permissions| LLM_R8
    CR_LLMISVC -->|permissions| LLM_R9

    SA_EPP -->|bound via| RB_EPP
    RB_EPP -->|grants| R_EPP

    SA_EPP -->|bound via| CRB_EPP_Auth
    CRB_EPP_Auth -->|grants| CR_AuthDelegator

    SA_Metrics -->|bound via| CRB_Metrics
    CRB_Metrics -->|grants| CR_Metrics

    SA_MN -->|bound via (OCP)| RB_SCC
    RB_SCC -->|grants| R_SCC

