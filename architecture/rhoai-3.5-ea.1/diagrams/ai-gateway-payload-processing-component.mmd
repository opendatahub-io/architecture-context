graph TB
    subgraph "AI Gateway Payload Processing"
        direction TB

        subgraph PluginService["BBR Plugin Service (ext-proc)<br/>9004/TCP gRPC | 9005/TCP health"]
            direction LR
            ModelResolver["model-provider-resolver<br/>Plugin"]
            APITranslation["api-translation<br/>Plugin"]
            APIKeyInjection["apikey-injection<br/>Plugin"]
            NemoReqGuard["nemo-request-guard<br/>Plugin"]
            NemoRespGuard["nemo-response-guard<br/>Plugin"]

            ModelResolver -->|CycleState| APITranslation
            APITranslation -->|CycleState| APIKeyInjection
            APIKeyInjection -->|CycleState| NemoReqGuard
            NemoReqGuard -->|CycleState| NemoRespGuard
        end

        subgraph Controllers["Kubernetes Controllers"]
            direction LR
            ExternalModelCtrl["ExternalModel<br/>Controller"]
            ExternalProviderCtrl["ExternalProvider<br/>Controller"]
        end
    end

    %% CRDs
    ExternalModelCR["ExternalModel CR<br/>(inference.opendatahub.io/v1alpha1)"]
    ExternalProviderCR["ExternalProvider CR<br/>(inference.opendatahub.io/v1alpha1)"]
    MaaSExternalModel["ExternalModel CR<br/>(maas.opendatahub.io/v1alpha1)"]
    BBRSecrets["Kubernetes Secrets<br/>(bbr-managed labeled)"]

    %% Managed Resources
    HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    ExtNameSvc["ExternalName Service"]
    ServiceEntry["Istio ServiceEntry"]
    DestRule["Istio DestinationRule"]

    %% External systems
    Gateway["Gateway (Envoy)<br/>maas-default-gateway"]
    K8sAPI["Kubernetes API Server"]
    NeMo["NeMo Guardrails<br/>Service"]

    subgraph ExternalProviders["External LLM Providers"]
        OpenAI["OpenAI API"]
        Anthropic["Anthropic API"]
        Azure["Azure OpenAI"]
        Bedrock["AWS Bedrock"]
        VertexAI["Google Vertex AI"]
    end

    %% Flows
    Gateway -->|ext-proc filter<br/>gRPC/9004| PluginService
    ModelResolver -->|watches| MaaSExternalModel
    APIKeyInjection -->|reads| BBRSecrets
    NemoReqGuard -->|HTTP POST| NeMo
    NemoRespGuard -->|HTTP POST| NeMo

    ExternalModelCR -->|watched by| ExternalModelCtrl
    ExternalProviderCR -->|watched by| ExternalProviderCtrl

    ExternalModelCtrl -->|creates| HTTPRoute
    ExternalProviderCtrl -->|creates| ExtNameSvc
    ExternalProviderCtrl -->|creates| ServiceEntry
    ExternalProviderCtrl -->|creates| DestRule

    ExternalModelCtrl -->|API calls| K8sAPI
    ExternalProviderCtrl -->|API calls| K8sAPI

    Gateway -->|routes via| HTTPRoute
    HTTPRoute -->|targets| ExtNameSvc
    ExtNameSvc -->|resolved by| ServiceEntry
    DestRule -->|TLS origination| ExternalProviders

    %% Styling
    style PluginService fill:#4a90e2,stroke:#333,color:#fff
    style Controllers fill:#4a90e2,stroke:#333,color:#fff
    style ModelResolver fill:#5ba3f5,stroke:#333,color:#fff
    style APITranslation fill:#5ba3f5,stroke:#333,color:#fff
    style APIKeyInjection fill:#5ba3f5,stroke:#333,color:#fff
    style NemoReqGuard fill:#5ba3f5,stroke:#333,color:#fff
    style NemoRespGuard fill:#5ba3f5,stroke:#333,color:#fff
    style ExternalModelCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style ExternalProviderCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style ExternalModelCR fill:#f5a623,stroke:#333
    style ExternalProviderCR fill:#f5a623,stroke:#333
    style MaaSExternalModel fill:#f5a623,stroke:#333
    style BBRSecrets fill:#f5a623,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style ExtNameSvc fill:#7ed321,stroke:#333
    style ServiceEntry fill:#7ed321,stroke:#333
    style DestRule fill:#7ed321,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style NeMo fill:#e8e8e8,stroke:#333
    style OpenAI fill:#f9f9f9,stroke:#999
    style Anthropic fill:#f9f9f9,stroke:#999
    style Azure fill:#f9f9f9,stroke:#999
    style Bedrock fill:#f9f9f9,stroke:#999
    style VertexAI fill:#f9f9f9,stroke:#999
