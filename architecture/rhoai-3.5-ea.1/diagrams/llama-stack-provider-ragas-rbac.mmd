graph TD
    subgraph "llama-stack-provider-ragas RBAC"
        direction TB

        Note["No RBAC resources (ClusterRoles, RoleBindings)<br/>defined directly by this component"]
    end

    subgraph "Implicit RBAC Requirements"
        direction TB

        subgraph "KFP Pipeline Pods (runtime)"
            KFPPod["KFP Pipeline Pod<br/>(odh-trustyai-ragas-lls-provider-dsp-rhel9)"]
        end

        subgraph "Required Access (via KFP Secret Injection)"
            ConfigMapRead["ConfigMap Read Access<br/>trustyai-service-operator-config<br/>Namespace: redhat-ods-applications<br/>or opendatahub"]
            SecretRead["Secret Read Access<br/>(injected by KFP mechanism)"]
        end

        subgraph "Secrets Referenced"
            S3Creds["S3 Credentials (Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_DEFAULT_REGION<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
            KFPToken["kubeflow-pipelines-token (Opaque)<br/>KUBEFLOW_PIPELINES_TOKEN<br/>Provisioned: Manual or kubeconfig<br/>Auto-Rotate: No"]
            InferenceSecret["llama-stack-inference-model-secret (Opaque)<br/>INFERENCE_MODEL, VLLM_URL<br/>VLLM_TLS_VERIFY, VLLM_API_TOKEN<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
            AWSCreds["aws-credentials (Opaque)<br/>AWS credentials for S3 access<br/>from Llama Stack pod (demo)<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        end

        subgraph "Authentication Flows"
            KFPAuth["KFP API Authentication<br/>Method: Bearer Token (OpenShift OAuth)<br/>Enforcement: KFP server<br/>Token Source: kubeconfig or env var"]
            S3Auth["S3 Authentication<br/>Method: AWS IAM (AccessKey/SecretKey)<br/>Enforcement: S3 service<br/>Injected via K8s Secret"]
            LLSAuth["Llama Stack Auth<br/>Method: None (local API)<br/>Enforcement: Llama Stack server<br/>In-process or HTTP"]
        end
    end

    KFPPod -->|"needs"| ConfigMapRead
    KFPPod -->|"needs"| SecretRead
    SecretRead -->|"reads"| S3Creds
    SecretRead -->|"reads"| InferenceSecret

    KFPToken -->|"used by"| KFPAuth
    S3Creds -->|"used by"| S3Auth

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KFPPod fill:#4a90e2,color:#fff
    style ConfigMapRead fill:#f5a623,color:#fff
    style SecretRead fill:#f5a623,color:#fff
    style S3Creds fill:#e74c3c,color:#fff
    style KFPToken fill:#e74c3c,color:#fff
    style InferenceSecret fill:#e74c3c,color:#fff
    style AWSCreds fill:#e74c3c,color:#fff
    style KFPAuth fill:#9b59b6,color:#fff
    style S3Auth fill:#9b59b6,color:#fff
    style LLSAuth fill:#9b59b6,color:#fff
