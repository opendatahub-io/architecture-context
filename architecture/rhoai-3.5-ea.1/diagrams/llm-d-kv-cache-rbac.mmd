graph TD
    subgraph "Service Accounts"
        SA_Operator["operator-controller-manager<br/>ServiceAccount<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Exec["${PROJECT_NAME}-exec-rbac-rolebinding<br/>ClusterRoleBinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "ClusterRoles"
        CR_Exec["${PROJECT_NAME}-exec-rbac-role<br/>ClusterRole"]
    end

    subgraph "API Resources"
        PodsExec["Core API Group<br/>pods/exec"]
    end

    subgraph "Effective Permissions"
        direction LR
        Perm1["✓ Create pods/exec<br/>(Execute commands in pods)"]
    end

    SA_Operator -->|"bound via"| CRB_Exec
    CRB_Exec -->|"grants"| CR_Exec
    CR_Exec -->|"create"| PodsExec
    PodsExec -.->|"enables"| Perm1

    subgraph "Authentication & Authorization Matrix"
        direction TB
        AuthMatrix["
        UDS Tokenizer gRPC ─── No auth (pod-local UDS)
        UDS Tokenizer /healthz ─── No auth (health probe)
        ZMQ Subscriber ─── No auth (network isolation)
        Redis/Valkey ─── Address-based (optional TLS)
        Kubernetes API ─── SA Token + mTLS
        "]
    end

    subgraph "Security Context (PVC Evictor - Helm)"
        direction TB
        SecCtx["
        runAsNonRoot: true
        allowPrivilegeEscalation: false
        readOnlyRootFilesystem: true
        capabilities: drop ALL
        seccompProfile: RuntimeDefault
        "]
    end

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Exec fill:#9b59b6,stroke:#333,color:#fff
    style CR_Exec fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Perm1 fill:#e8e8e8,stroke:#333
    style AuthMatrix fill:#fff2cc,stroke:#d6b656
    style SecCtx fill:#d5e8d4,stroke:#82b366
