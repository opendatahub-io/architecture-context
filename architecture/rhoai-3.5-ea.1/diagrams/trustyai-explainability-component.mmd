graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus REST)"]
            ConsumerEP["Consumer Endpoint<br/>/consumer/kserve/v2"]
            CloudEventEP["CloudEvent Consumer<br/>(Knative Funq)"]
            MetricsEP["Metrics Endpoints<br/>/metrics/group/fairness/*<br/>/metrics/drift/*<br/>/metrics/identity"]
            ExplainerEP["Explainer Endpoints<br/>/explainers/local/*<br/>/explainers/global/*<br/>(disabled in RHOAI)"]
            DataEP["Data Endpoints<br/>/data/upload<br/>/data/download"]
            InfoEP["Info Endpoints<br/>/info, /info/tags<br/>/info/names"]
            HealthEP["Health & Metrics<br/>/q/health/*, /q/metrics"]
            GzipFilter["GzipRequestFilter<br/>(upload decompression)"]
        end

        subgraph Reconciliation["Payload Reconciliation"]
            MMReconciler["ModelMesh<br/>InferencePayload<br/>Reconciler"]
            KSReconciler["KServe<br/>InferencePayload<br/>Reconciler"]
        end

        subgraph StorageLayer["Storage Backends (Strategy Pattern)"]
            PVCStorage["PVC Storage<br/>(/inputs mount)<br/>Flat-file CSV"]
            MinIOStorage["MinIO Storage<br/>S3-compatible<br/>Object store"]
            HibernateStorage["Hibernate Storage<br/>MariaDB/MySQL<br/>JDBC"]
        end

        subgraph PrometheusInt["Prometheus Integration"]
            Scheduler["PrometheusScheduler<br/>(cron, default 5s)"]
            Publisher["PrometheusPublisher<br/>trustyai_ prefix gauges"]
        end

        subgraph CoreLib["explainability-core (Library)"]
            Fairness["Fairness Metrics<br/>SPD, DIR"]
            Drift["Drift Metrics<br/>KS, FourierMMD<br/>Meanshift, Jensen-Shannon"]
            XAI["XAI Algorithms<br/>LIME, SHAP<br/>Counterfactual, PDP<br/>TSSaliency"]
        end

        subgraph ConnectorsLib["explainability-connectors (Library)"]
            KServeGRPC["KServe v2 gRPC<br/>Prediction Provider"]
            KServeHTTP["KServe v1/v2 HTTP<br/>Prediction Provider"]
        end

        subgraph ArrowLib["explainability-arrow (Library)"]
            ArrowConv["Arrow Converters<br/>Java-Python exchange"]
        end
    end

    %% Internal flows
    ConsumerEP -->|"payloads"| MMReconciler
    CloudEventEP -->|"events"| KSReconciler
    MMReconciler -->|"matched records"| PVCStorage
    MMReconciler -->|"matched records"| MinIOStorage
    MMReconciler -->|"matched records"| HibernateStorage
    KSReconciler -->|"matched records"| PVCStorage
    KSReconciler -->|"matched records"| MinIOStorage
    KSReconciler -->|"matched records"| HibernateStorage

    MetricsEP --> Fairness
    MetricsEP --> Drift
    ExplainerEP --> XAI
    XAI --> KServeGRPC
    XAI --> KServeHTTP

    Scheduler -->|"reads data"| PVCStorage
    Scheduler -->|"reads data"| MinIOStorage
    Scheduler -->|"reads data"| HibernateStorage
    Scheduler --> Fairness
    Scheduler --> Drift
    Scheduler -->|"publishes"| Publisher

    DataEP -->|"upload/download"| PVCStorage
    DataEP -->|"upload/download"| MinIOStorage
    DataEP -->|"upload/download"| HibernateStorage
    GzipFilter -.->|"decompresses"| DataEP

    %% External interactions
    ModelMesh["ModelMesh<br/>Payload Logger"] -->|"POST 8080/TCP"| ConsumerEP
    KServeLogger["KServe<br/>Inference Logger"] -->|"CloudEvents 8080/TCP"| CloudEventEP
    Prometheus["Prometheus Server"] -->|"scrape /q/metrics<br/>8080/TCP"| HealthEP

    KServeGRPC -->|"gRPC (plaintext)"| ModelServer["KServe/ModelMesh<br/>Model Servers"]
    KServeHTTP -->|"HTTP v1/v2"| ModelServer

    HibernateStorage -->|"JDBC 3306/TCP"| MariaDB["MariaDB/MySQL"]
    MinIOStorage -->|"HTTP/HTTPS"| MinIO["MinIO / S3"]

    Operator["trustyai-service-operator"] -.->|"manages lifecycle"| TrustyAI

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ServiceLayer fill:#dbeafe,stroke:#3b82f6
    style CoreLib fill:#dcfce7,stroke:#22c55e
    style ConnectorsLib fill:#fef3c7,stroke:#f59e0b
    style ArrowLib fill:#f3e8ff,stroke:#a855f7
    style StorageLayer fill:#fff7ed,stroke:#f97316
    style Reconciliation fill:#fce7f3,stroke:#ec4899
    style PrometheusInt fill:#f0fdf4,stroke:#16a34a
    style Operator fill:#e0e7ff,stroke:#6366f1
    style ModelMesh fill:#f9fafb,stroke:#6b7280
    style KServeLogger fill:#f9fafb,stroke:#6b7280
    style Prometheus fill:#f9fafb,stroke:#6b7280
    style ModelServer fill:#f9fafb,stroke:#6b7280
    style MariaDB fill:#fef2f2,stroke:#ef4444
    style MinIO fill:#fef2f2,stroke:#ef4444
