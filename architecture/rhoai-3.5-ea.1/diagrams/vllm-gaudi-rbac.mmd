graph TD
    subgraph "vllm-gaudi RBAC Model"
        direction TB

        Note["ℹ️ vllm-gaudi is a container image workload,<br/>not an operator. It defines NO RBAC<br/>roles, bindings, or service accounts.<br/><br/>RBAC is managed externally by the<br/>components that deploy it."]
    end

    subgraph "Platform-Managed RBAC (External)"
        direction TB

        subgraph "KServe / ServingRuntime Controller"
            KServeSA["Service Account<br/>(defined by ServingRuntime CR)"]
            KServeRole["RBAC Roles<br/>(defined by KServe operator)"]
        end

        subgraph "kube-rbac-proxy Sidecar"
            ProxySA["Sidecar injected by<br/>platform operator"]
            RBAC["Kubernetes RBAC<br/>SubjectAccessReview"]
        end
    end

    subgraph "Authentication Flow"
        Client["External Client"] -->|"1. HTTPS/8443<br/>Bearer Token"| Proxy["kube-rbac-proxy"]
        Proxy -->|"2. SubjectAccessReview"| K8sAPI["Kubernetes API Server"]
        K8sAPI -->|"3. RBAC evaluation"| RBAC2["ClusterRole/Role<br/>Bindings"]
        RBAC2 -->|"4. Allow/Deny"| K8sAPI
        K8sAPI -->|"5. Auth result"| Proxy
        Proxy -->|"6. Forward if allowed<br/>HTTP/8000 (localhost)"| vLLM["vLLM API Server<br/>(no in-process auth)"]
    end

    subgraph "Endpoint Auth Matrix"
        direction TB
        AuthMatrix["Endpoint              │ Auth Required<br/>──────────────────┼──────────────<br/>/v1/completions      │ Yes (RBAC via proxy)<br/>/v1/chat/completions │ Yes (RBAC via proxy)<br/>/v1/embeddings       │ Yes (RBAC via proxy)<br/>/v1/models           │ Yes (RBAC via proxy)<br/>/health              │ No<br/>/version             │ No"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999
    style Proxy fill:#e6ccff,stroke:#8a2be2
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style vLLM fill:#d5e8d4,stroke:#82b366
    style AuthMatrix fill:#f5f5f5,stroke:#ccc
    style RBAC2 fill:#ffe6cc,stroke:#d79b00
    style KServeSA fill:#e8e8e8,stroke:#999
    style KServeRole fill:#e8e8e8,stroke:#999
    style ProxySA fill:#e8e8e8,stroke:#999
    style RBAC fill:#e8e8e8,stroke:#999
