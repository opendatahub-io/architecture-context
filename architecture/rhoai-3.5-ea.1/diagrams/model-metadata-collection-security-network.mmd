graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Pipeline)"]
        direction TB

        subgraph Tools["Build Tools (not shipped)"]
            Extractor["model-extractor CLI<br/>Go 1.24<br/>CGO_ENABLED=0"]
            Reporter["metadata-report CLI<br/>Go 1.24<br/>File I/O only"]
        end

        subgraph Outputs["Generated Artifacts"]
            ModelsCatalog["models-catalog.yaml"]
            MCPCatalogRH["redhat-mcp-servers-catalog.yaml"]
            MCPCatalogPartner["partner-mcp-servers-catalog.yaml"]
            MCPCatalogCommunity["community-mcp-servers-catalog.yaml"]
        end

        Extractor -->|generates| ModelsCatalog
        Extractor -->|generates| MCPCatalogRH
        Extractor -->|generates| MCPCatalogPartner
        Extractor -->|generates| MCPCatalogCommunity
        Reporter -->|analyzes| ModelsCatalog
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time Egress Only)"]
        RHRegistry["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
        AccessRegistry["registry.access.redhat.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public"]
        HuggingFace["huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        Quay["quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
    end

    subgraph ContainerBuild["CONTAINER BUILD (Konflux)"]
        Dockerfile["Dockerfile.konflux<br/>Base: UBI9-minimal<br/>COPY YAML → /app/data/<br/>USER: 1001 (non-root)<br/>CMD: sleep infinity"]
    end

    subgraph Runtime["RUNTIME (Kubernetes - Zero Network)"]
        DataContainer["Data Container<br/>odh-model-metadata-collection<br/>No ports, no services<br/>No ingress, no egress<br/>Volume: /app/data/"]
        Dashboard["RHOAI Dashboard<br/>(Consumer)"]
    end

    %% Build-time egress flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Auth"| RHRegistry
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Public"| AccessRegistry
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Auth"| Quay

    %% Build pipeline
    ModelsCatalog -->|"COPY (build)"| Dockerfile
    MCPCatalogRH -->|"COPY (build)"| Dockerfile
    Dockerfile -->|"produces"| DataContainer

    %% Runtime consumption
    Dashboard -->|"Volume Mount<br/>Filesystem<br/>No Network"| DataContainer

    %% Styling
    classDef buildtool fill:#4a90e2,stroke:#333,color:#fff
    classDef artifact fill:#b8e986,stroke:#333
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef consumer fill:#f5a623,stroke:#333,color:#fff

    class Extractor,Reporter buildtool
    class ModelsCatalog,MCPCatalogRH,MCPCatalogPartner,MCPCatalogCommunity artifact
    class RHRegistry,AccessRegistry,HuggingFace,Quay external
    class Dockerfile build
    class DataContainer runtime
    class Dashboard consumer
