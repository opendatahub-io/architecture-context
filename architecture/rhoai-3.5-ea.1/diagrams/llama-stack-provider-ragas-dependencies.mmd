graph LR
    Provider["llama-stack-provider-ragas<br/>(Python Library)"]

    %% External Dependencies (Required)
    Provider -->|"core eval framework<br/>v0.3.0"| Ragas["ragas 0.3.0"]
    Provider -->|"server framework<br/>>0.2.23"| LlamaStack["llama-stack >0.2.23"]
    Provider -->|"BaseRagasLLM/Embeddings<br/>(transitive via ragas)"| LangChain["langchain-core"]
    Provider -->|"DataFrame ops"| Pandas["pandas <2.3.0"]
    Provider -->|"config models"| Pydantic["pydantic"]
    Provider -->|"HTTP client"| Requests["requests >=2.32.5"]
    Provider -->|"columnar format"| PyArrow["pyarrow >=21.0.0"]
    Provider -->|"HF datasets"| Datasets["datasets >=2.16.0"]
    Provider -->|"async support"| Greenlet["greenlet 3.2.4"]
    Provider -->|"pretty output"| Rich["rich"]
    Provider -->|"TLS/crypto<br/>(transitive)"| Cryptography["cryptography 46.0.2"]

    %% External Dependencies (Optional - remote extra)
    Provider -.->|"pipeline SDK<br/>>=2.5.0 (remote)"| KFP["kfp >=2.5.0"]
    Provider -.->|"K8s extensions<br/>>=2.0.0 (remote)"| KFPKubernetes["kfp-kubernetes >=2.0.0"]
    Provider -.->|"K8s API client<br/>>=30.0.0 (remote)"| Kubernetes["kubernetes >=30.0.0"]
    Provider -.->|"S3 filesystem<br/>>=2024.12.0 (remote)"| S3FS["s3fs >=2024.12.0"]
    Provider -.->|"LS HTTP client<br/>(remote)"| LlamaStackClient["llama-stack-client"]

    %% Internal Platform Dependencies
    Provider ==>|"hosts as eval<br/>provider plugin"| LlamaStackServer["Llama Stack Server"]
    Provider ==>|"submit pipelines<br/>REST API"| DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    Provider ==>|"ConfigMap read<br/>base image"| TrustyAI["TrustyAI Service<br/>Operator"]
    Provider ==>|"store/retrieve<br/>results"| S3["S3-compatible<br/>Object Storage"]
    Provider ==>|"inference backend"| OllamaVLLM["Ollama / vLLM"]

    %% Integration Points (inbound)
    LlamaStackServer -->|"registers provider"| Provider

    %% Styling - Core component
    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Styling - Required external deps
    style Ragas fill:#e8e8e8,stroke:#333
    style LlamaStack fill:#e8e8e8,stroke:#333
    style LangChain fill:#e8e8e8,stroke:#333
    style Pandas fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333
    style Requests fill:#e8e8e8,stroke:#333
    style PyArrow fill:#e8e8e8,stroke:#333
    style Datasets fill:#e8e8e8,stroke:#333
    style Greenlet fill:#e8e8e8,stroke:#333
    style Rich fill:#e8e8e8,stroke:#333
    style Cryptography fill:#e8e8e8,stroke:#333

    %% Styling - Optional external deps (remote extra)
    style KFP fill:#d5d5d5,stroke:#999,stroke-dasharray:5 5
    style KFPKubernetes fill:#d5d5d5,stroke:#999,stroke-dasharray:5 5
    style Kubernetes fill:#d5d5d5,stroke:#999,stroke-dasharray:5 5
    style S3FS fill:#d5d5d5,stroke:#999,stroke-dasharray:5 5
    style LlamaStackClient fill:#d5d5d5,stroke:#999,stroke-dasharray:5 5

    %% Styling - Internal platform deps
    style LlamaStackServer fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OllamaVLLM fill:#f5a623,stroke:#333,color:#fff
