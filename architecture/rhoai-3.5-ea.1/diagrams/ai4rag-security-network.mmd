graph TB
    subgraph HostProcess["LIBRARY HOST PROCESS<br/>(e.g., Kubeflow Pipeline Component Container)"]
        direction TB

        subgraph AI4RAG["ai4rag Library (in-process Python)"]
            direction TB

            Experiment["AI4RAGExperiment<br/><i>Orchestrator</i>"]
            MPS["ModelsPreSelector<br/><i>Pre-Selection Phase</i>"]
            GAM["GAMOptimizer<br/><i>HPO Engine</i>"]

            subgraph InProcess["IN-PROCESS (No Network)"]
                Chunker["LangChainChunker<br/><i>Text Splitting</i>"]
                ChromaDB["ChromaDB<br/><i>In-Memory Vector DB</i>"]
                Unitxt["UnitxtEvaluator<br/><i>Metrics Computation</i>"]
                EventHandler["EventHandler<br/><i>Local / KFP</i>"]
            end

            subgraph OGXClients["OGX CLIENT LAYER (ogx-client SDK → httpx)"]
                OgxFM["OGXFoundationModel"]
                OgxEmbed["OGXEmbeddingModel"]
                OgxVS["OGXVectorStore"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB

        subgraph OGXServer["OGX Server<br/><i>Base URL: configurable</i>"]
            ChatAPI["Chat Completions API<br/>Port: configurable<br/>HTTPS / TLS 1.2+<br/>Auth: API Key (Bearer)"]
            EmbedAPI["Embeddings API<br/>Port: configurable<br/>HTTPS / TLS 1.2+<br/>Auth: API Key (Bearer)"]
            VecStoresAPI["Vector Stores API<br/>Port: configurable<br/>HTTPS / TLS 1.2+<br/>Auth: API Key (Bearer)"]
            VecIOAPI["Vector IO API<br/>Port: configurable<br/>HTTPS / TLS 1.2+<br/>Auth: API Key (Bearer)"]
        end

        subgraph BackendDB["Backend Vector DB (behind OGX)"]
            Milvus["Milvus / Qdrant<br/><i>Not accessed directly</i>"]
        end
    end

    %% Internal flows (no network)
    Experiment --> MPS
    Experiment --> GAM
    MPS --> Chunker
    MPS --> ChromaDB
    MPS --> Unitxt
    GAM --> Chunker
    GAM --> Unitxt
    Experiment --> EventHandler

    %% Egress flows (network boundary crossing)
    OgxFM -->|"HTTPS<br/>TLS 1.2+<br/>API Key (Bearer)"| ChatAPI
    OgxEmbed -->|"HTTPS<br/>TLS 1.2+<br/>API Key (Bearer)"| EmbedAPI
    OgxVS -->|"HTTPS<br/>TLS 1.2+<br/>API Key (Bearer)"| VecStoresAPI
    OgxVS -->|"HTTPS<br/>TLS 1.2+<br/>API Key (Bearer)"| VecIOAPI

    MPS --> OgxFM
    MPS --> OgxEmbed
    GAM --> OgxFM
    GAM --> OgxEmbed
    GAM --> OgxVS

    VecStoresAPI -.->|"internal"| Milvus
    VecIOAPI -.->|"internal"| Milvus

    %% Styling
    classDef hostprocess fill:#f0f8ff,stroke:#4a90e2,stroke-width:3px
    classDef library fill:#e8f4fd,stroke:#3b82f6,stroke-width:2px
    classDef inprocess fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ogxclient fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef backend fill:#f9f9f9,stroke:#999,stroke-width:1px

    class Experiment,MPS,GAM library
    class Chunker,ChromaDB,Unitxt,EventHandler inprocess
    class OgxFM,OgxEmbed,OgxVS ogxclient
    class ChatAPI,EmbedAPI,VecStoresAPI,VecIOAPI external
    class Milvus backend
