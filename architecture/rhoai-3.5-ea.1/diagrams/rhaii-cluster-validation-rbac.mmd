graph TD
    subgraph "Service Accounts"
        SA["ServiceAccount<br/>rhaii-validator<br/>Namespace: rhaii-validation"]
    end

    subgraph "ClusterRole Bindings"
        CRB["ClusterRoleBinding<br/>rhaii-validator<br/>(cluster-scoped)"]
        CRB_SCC["ClusterRoleBinding<br/>rhaii-validator-scc<br/>(cluster-scoped, OCP only)"]
    end

    subgraph "ClusterRoles"
        CR["ClusterRole<br/>rhaii-validator"]
        CR_SCC["ClusterRole<br/>system:openshift:scc:privileged"]
    end

    subgraph "API Resources — Core (\"\")"
        Nodes["core<br/>nodes"]
        Pods["core<br/>pods"]
        PodsLog["core<br/>pods/log"]
    end

    subgraph "API Resources — batch"
        Jobs["batch<br/>jobs"]
    end

    subgraph "API Resources — apiextensions.k8s.io"
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph "Security Context Constraints (OCP)"
        SCC["SCC: privileged<br/>privileged=true<br/>hostPID=true<br/>hostPath mounts"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via (OCP)"| CRB_SCC
    CRB -->|"grants"| CR
    CRB_SCC -->|"grants"| CR_SCC

    %% Permissions
    CR -->|"get, list"| Nodes
    CR -->|"get, list, patch"| Pods
    CR -->|"get"| PodsLog
    CR -->|"create, get, list, delete"| Jobs
    CR -->|"get, list"| CRDs

    %% SCC
    CR_SCC -->|"grants access"| SCC

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#b8d4f0,stroke:#333
    style CRB_SCC fill:#f8cecc,stroke:#b85450
    style CR fill:#f5a623,stroke:#333,color:#fff
    style CR_SCC fill:#f8cecc,stroke:#b85450,color:#333
    style Nodes fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsLog fill:#7ed321,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333,color:#fff
    style CRDs fill:#7ed321,stroke:#333,color:#fff
    style SCC fill:#f8cecc,stroke:#b85450,color:#333
