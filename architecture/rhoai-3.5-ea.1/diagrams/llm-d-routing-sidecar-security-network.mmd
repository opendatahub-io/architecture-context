graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Gateway API Router"]
    end

    subgraph Ingress["INGRESS (OpenShift Route - Edge TLS)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
        Service["ClusterIP Service<br/>8080/TCP → 8000/TCP"]
        Route --> Service
    end

    subgraph Application["APPLICATION (Decoder Pod - StatefulSet)"]
        direction TB

        subgraph SidecarContainer["llm-d-routing-sidecar"]
            Proxy["HTTPS Proxy Server<br/>8000/TCP<br/>TLS 1.2+ FIPS Ciphers<br/>Self-signed or -cert-path"]
            SSRFCheck{"SSRF<br/>Allowlist<br/>Check"}
            Proxy --> SSRFCheck
        end

        subgraph SSRFModule["SSRF Protection (Optional)"]
            Validator["AllowlistValidator<br/>Dynamic Client Watch<br/>30s Resync"]
        end

        Decoder["vLLM Decoder (local)<br/>8001/TCP<br/>HTTP or HTTPS<br/>Optional TLS 1.2+"]
    end

    subgraph RemoteInference["REMOTE INFERENCE PODS"]
        Prefiller["vLLM Prefiller Pods<br/>dynamic port (from header)<br/>HTTP or HTTPS<br/>Optional TLS 1.2+"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>ServiceAccount Token Auth"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    end

    subgraph UpstreamDep["UPSTREAM DEPENDENCY"]
        Scheduler["llm-d-inference-scheduler<br/>(sets x-prefiller-host-port header)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Edge"| Route
    Service -->|"HTTPS/8000<br/>TLS 1.2+"| Proxy

    %% Application flows
    SSRFCheck -->|"HTTP(S)/8001<br/>Optional TLS 1.2+<br/>Decode request"| Decoder
    SSRFCheck -->|"HTTP(S)/dynamic<br/>Optional TLS 1.2+<br/>Prefill request<br/>SSRF validated"| Prefiller

    %% Control plane flows
    Validator -->|"HTTPS/443<br/>TLS<br/>SA Bearer Token<br/>Watch InferencePool + Pods"| K8sAPI
    SSRFCheck -.->|"validates against"| Validator

    %% Upstream
    Scheduler -.->|"sets header<br/>(no direct connection)"| Client

    %% Styles
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remote fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef upstream fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Proxy,SSRFCheck,Validator,Decoder application
    class Prefiller remote
    class K8sAPI,InferencePool controlplane
    class Scheduler upstream
