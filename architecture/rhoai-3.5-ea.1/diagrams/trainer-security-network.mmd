graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / Client Certs"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE (opendatahub)"]
        direction TB
        subgraph ControllerPod["kubeflow-trainer-controller-manager"]
            direction TB
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>No Encryption<br/>No Auth"]
            MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS (secure serving)<br/>No Auth"]
            WebhookEndpoint["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-managed certs)<br/>Auth: K8s API server certs"]
            ProgressionClient["Progression Tracker<br/>(RHAI Extension)"]
        end
    end

    subgraph UserNS["USER NAMESPACES (per TrainJob)"]
        direction TB
        subgraph TrainingWorkload["Training Workload"]
            TrainingPods["Training Pods<br/>(created by JobSet)"]
            MetricsPort["Metrics Endpoint<br/>28080/TCP HTTP<br/>PLAINTEXT<br/>NetworkPolicy: controller only"]
            MPIWorkers["MPI Worker Pods<br/>22/TCP SSH<br/>SSH key auth"]
        end
        NetPol["NetworkPolicy<br/>(RHAI-created, per TrainJob)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus / OpenShift Monitoring<br/>PodMonitor"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / Client Cert"| K8sAPI

    %% Control Plane → Controller (webhooks)
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-managed)<br/>API server client cert<br/>failurePolicy: Fail"| WebhookEndpoint

    %% Controller → Control Plane (CRUD operations)
    ControllerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Bearer Token<br/>CRUD: TrainJob, JobSet, PodGroup,<br/>NetworkPolicy, ConfigMap, Secret"| K8sAPI

    %% Controller → Training Pods (progression)
    ProgressionClient -->|"HTTP/28080<br/>PLAINTEXT<br/>No Auth<br/>NetworkPolicy enforced"| MetricsPort

    %% Monitoring → Controller
    Prometheus -->|"HTTPS/8443<br/>TLS (insecureSkipVerify)<br/>PodMonitor scrape"| MetricsEndpoint

    %% MPI internal
    TrainingPods -.->|"SSH/22<br/>SSH key auth<br/>Key from Secret"| MPIWorkers

    %% NetworkPolicy enforcement
    NetPol -.->|"restricts ingress"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class HealthProbe,MetricsEndpoint,WebhookEndpoint,ProgressionClient controller
    class TrainingPods,MetricsPort,MPIWorkers userns
    class Prometheus monitoring
    class NetPol security
