graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE"]
        direction TB

        subgraph MainServer["Main API Server"]
            API["FMS Guardrails Orchestrator<br/>Port 8033/TCP<br/>HTTP/HTTPS<br/>TLS 1.2+ (rustls+ring)<br/>Optional mTLS (WebPkiClientVerifier)"]
        end

        subgraph HealthServer["Health Server"]
            Health["Health Endpoints<br/>Port 8034/TCP<br/>HTTP (plaintext)<br/>No auth<br/>/health, /info"]
        end
    end

    subgraph GenerationZone["GENERATION BACKENDS (Internal)"]
        direction TB
        TGIS["TGIS Server<br/>gRPC 8033/TCP<br/>Optional TLS/mTLS<br/>(tonic+rustls)<br/>fmaas.GenerationService"]
        CaikitNLP["caikit-NLP Server<br/>gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>(tonic+rustls)<br/>NlpService"]
        OpenAISrv["OpenAI-compatible (vLLM)<br/>HTTP 8080/TCP<br/>Optional TLS<br/>(reqwest+rustls)<br/>Bearer token auth"]
    end

    subgraph SafetyZone["SAFETY SERVICES (Internal)"]
        direction TB
        Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>HTTP 8080/TCP<br/>Optional TLS/mTLS<br/>(hyper+rustls)<br/>Bearer token auth"]
        Chunkers["Chunker Services<br/>(caikit)<br/>gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>(tonic+rustls)<br/>ChunkersService"]
    end

    subgraph ObservabilityZone["OBSERVABILITY (External)"]
        OTEL["OTLP Collector<br/>gRPC 4317/TCP or HTTP 4318/TCP<br/>Configurable encryption<br/>W3C Trace Context"]
    end

    %% Client to Orchestrator
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ (rustls+ring)<br/>Optional mTLS client certs"| API

    %% Orchestrator to Generation
    API -->|"gRPC 8033/TCP<br/>Optional TLS/mTLS<br/>mTLS client certs"| TGIS
    API -->|"gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>mTLS client certs"| CaikitNLP
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Bearer token (api_token)"| OpenAISrv

    %% Orchestrator to Safety
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS/mTLS<br/>Bearer token (passthrough/api_token)"| Detectors
    API -->|"gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>mTLS client certs"| Chunkers

    %% Orchestrator to Observability
    API -->|"OTLP gRPC/HTTP<br/>4317 or 4318/TCP<br/>Traces + Metrics"| OTEL

    %% Health probes
    Health -.->|"gRPC Health.Check"| TGIS
    Health -.->|"gRPC Health.Check"| CaikitNLP
    Health -.->|"GET /health"| OpenAISrv
    Health -.->|"GET /health"| Detectors
    Health -.->|"gRPC Health.Check"| Chunkers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#4a90e2,stroke:#2e75b6,stroke-width:2px,color:#fff
    classDef health fill:#5dade2,stroke:#2e86c1,stroke-width:1px,color:#fff
    classDef generation fill:#999,stroke:#666,stroke-width:2px,color:#fff
    classDef safety fill:#f5a623,stroke:#d68910,stroke-width:2px
    classDef observability fill:#7ed321,stroke:#5daf11,stroke-width:2px

    class Client external
    class API orchestrator
    class Health health
    class TGIS,CaikitNLP,OpenAISrv generation
    class Detectors,Chunkers safety
    class OTEL observability
