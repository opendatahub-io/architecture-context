graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS"]
        IngressCtrl["Ingress Controller<br/>{instance}-ingress<br/>80/443 TCP<br/>Encryption: depends on config"]
    end

    subgraph Cluster["CLUSTER INTERNAL (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["OGX K8s Operator<br/>SA: controller-manager<br/>Probes: 8081/TCP"]
            WebhookSvc["webhook-service<br/>443→9443/TCP HTTPS<br/>TLS: service-serving-cert<br/>Auth: K8s API client cert"]
            MetricsSvc["metrics-service<br/>8443/TCP HTTPS<br/>Auth: Bearer token<br/>(kube-rbac-proxy)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid"]
            InstanceSvc["{instance}-service<br/>ClusterIP<br/>8321/TCP HTTP<br/>Configurable TLS"]
            PVC["PVC<br/>Model/data storage"]
            NetPol["NetworkPolicy<br/>Allow: same-ns + operator-ns<br/>+ router-ns (optional)"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount token"]
        CertSigner["OpenShift<br/>service-serving-cert-signer<br/>Auto TLS cert generation"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (User-Configured)"]
        vLLM["vLLM<br/>User-defined port<br/>HTTP/HTTPS<br/>Auth: API token"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: IAM credentials"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: GCP credentials"]
        VectorDBs["Vector DBs<br/>(PGVector, Milvus, Qdrant)<br/>User-defined ports<br/>Auth: Password/Token/Key"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS access key"]
    end

    %% External access flow
    Client -->|"HTTP/HTTPS<br/>80 or 443/TCP"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>cluster internal"| InstanceSvc
    InstanceSvc --> OGXPod

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/443<br/>Admission Review"| WebhookSvc
    Operator -->|"HTTP/8321<br/>health, version,<br/>provider queries"| OGXPod
    CertSigner -.->|"auto-generates cert"| WebhookSvc

    %% OGX Server egress to providers
    OGXPod -->|"HTTPS/443<br/>API key"| OpenAI
    OGXPod -->|"HTTPS/443<br/>API key"| Azure
    OGXPod -->|"HTTPS/443<br/>IAM creds"| Bedrock
    OGXPod -->|"HTTPS/443<br/>GCP creds"| VertexAI
    OGXPod -->|"HTTP/HTTPS<br/>API token"| vLLM
    OGXPod -->|"Various protocols<br/>Auth varies"| VectorDBs
    OGXPod -->|"HTTPS/443<br/>AWS key"| S3

    %% Metrics
    MetricsSvc -.->|"Prometheus scrape<br/>HTTPS/8443"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class Operator,WebhookSvc,MetricsSvc,OGXPod,InstanceSvc,PVC,NetPol cluster
    class K8sAPI,CertSigner controlplane
    class vLLM,OpenAI,Azure,Bedrock,VertexAI,VectorDBs,S3 externalservice
