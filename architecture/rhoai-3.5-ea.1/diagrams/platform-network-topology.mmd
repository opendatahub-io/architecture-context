graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>Data Scientists, Applications"]
    end

    subgraph Ingress["INGRESS — Gateway API (DMZ)"]
        direction TB
        DashGW["ODH Dashboard Gateway<br/>443/TCP HTTPS<br/>IntegratedOAuth or OIDC<br/>data-science-gateway"]
        KServeGW["KServe Inference Gateway<br/>443/TCP HTTPS<br/>Bearer Token or API Key<br/>Gateway API HTTPRoute"]
        MaaSGW["MaaS API Gateway<br/>443/TCP HTTPS<br/>Authorino API Key Auth<br/>Rate Limited"]
    end

    subgraph OperatorNS["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator<br/>OLM Managed"]
    end

    subgraph PlatformNS["Namespace: redhat-ods-applications"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            KubeAuthProxy["kube-auth-proxy<br/>HPA 2+ replicas<br/>EnvoyFilter Integration"]
        end

        subgraph Controllers["Platform Controllers"]
            KServeCM["KServe controller-manager<br/>SA: kserve-controller-manager"]
            LLMISVC["KServe llmisvc-controller-manager<br/>SA: llmisvc-controller-manager"]
            ODHModelCtrl["odh-model-controller<br/>SA: odh-model-controller"]
            DSPOp["DSP Operator<br/>SA: data-science-pipelines-operator"]
            ModelRegOp["Model Registry Operator<br/>kube-rbac-proxy :8443"]
            TrustyAIOp["TrustyAI Service Operator<br/>kube-rbac-proxy :8443"]
            FeastOp["Feast Operator<br/>SA: feast-operator"]
            KubeRayOp["KubeRay Operator<br/>SA: kuberay-operator"]
            SparkOp["Spark Operator<br/>SA: spark-operator"]
            TrainerOp["Kubeflow Trainer<br/>SA: training-operator"]
            TrainingOpV1["Training Operator v1<br/>SA: training-operator"]
            MLflowOp["MLflow Operator<br/>SA: mlflow-operator"]
            OGXOp["OGX K8s Operator<br/>kube-rbac-proxy :8443"]
            WVAOp["WVA Controller<br/>SA: wva-controller"]
        end

        subgraph DashboardPod["Dashboard Pod (9 containers)"]
            ODHDash["odh-dashboard<br/>kube-rbac-proxy :8443<br/>7 BFF Plugins"]
        end
    end

    subgraph MonitoringNS["Namespace: redhat-ods-monitoring"]
        Prometheus["Prometheus<br/>Scrapes 50 endpoints"]
        AlertManager["AlertManager"]
    end

    subgraph IstioNS["Namespace: istio-system / redhat-ods-istio"]
        IstioCP["Istio Control Plane<br/>Gateway API Provider"]
        EnvoyProxy["Envoy Proxies<br/>ext-proc Filters"]
    end

    subgraph UserNS["User Data Science Namespaces (per-project)"]
        direction TB
        NotebookPod["Notebooks (StatefulSets)<br/>kube-rbac-proxy sidecar"]
        InfSvc["InferenceServices<br/>vLLM, OVMS, MLServer pods"]
        LLMInfSvc["LLMInferenceServices<br/>llm-d stack + EPP + WVA"]
        DSPA["DSPA Instance<br/>API Server + Argo Controller"]
        TrainingJobs["Training Jobs<br/>PyTorchJob, TrainJob, MPIJob"]
        MLflowInst["MLflow Instance<br/>Experiment Tracking"]
        ModelRegInst["Model Registry Instance<br/>Metadata + Catalog"]
        TrustyAISvc["TrustyAI Service<br/>PVC-backed state"]
        EvalHubInst["EvalHub Instance<br/>Evaluation Jobs"]
        FeastSvc["Feast Feature Server<br/>HPA + PDB"]
        RayClusters["Ray Clusters<br/>mTLS internal"]
    end

    subgraph KnativeNS["Namespace: knative-serving (optional)"]
        KnativeSrv["Knative Serving<br/>Serverless Runtime"]
    end

    subgraph EgressZone["EGRESS (External Services)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>AWS IAM or Static Creds"]
        ContainerReg["Container Registry<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS, Pull Secrets"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>SA Tokens"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>API Token"]
        OCIReg["OCI Artifact Registry<br/>443/TCP HTTPS<br/>Eval Results Storage"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443<br/>OAuth redirect| DashGW
    Clients -->|HTTPS/443<br/>Bearer or API Key| KServeGW
    Clients -->|HTTPS/443<br/>Authorino API Key| MaaSGW

    %% Ingress to Platform
    DashGW -->|EnvoyFilter auth<br/>IntegratedOAuth| KubeAuthProxy
    KubeAuthProxy -->|authenticated req| ODHDash
    KServeGW -->|HTTPRoute| InfSvc
    KServeGW -->|HTTPRoute| LLMInfSvc
    MaaSGW -->|Authorino ext-authz| InfSvc

    %% Operator to Platform
    RhodsOp -->|reconciles DSC/DSCI| KServeCM
    RhodsOp -->|reconciles DSC/DSCI| ODHModelCtrl
    RhodsOp -->|reconciles DSC/DSCI| DSPOp
    RhodsOp -->|reconciles DSC/DSCI| ODHDash
    RhodsOp -->|reconciles DSC/DSCI| ModelRegOp
    RhodsOp -->|reconciles DSC/DSCI| TrustyAIOp
    RhodsOp -->|reconciles DSC/DSCI| FeastOp
    RhodsOp -->|gateway config| IstioCP

    %% Controllers to User Namespaces
    KServeCM -->|creates Deployments<br/>Services, HTTPRoutes| InfSvc
    LLMISVC -->|creates LeaderWorkerSets<br/>InferencePools| LLMInfSvc
    DSPOp -->|creates DSPA resources| DSPA
    ODHModelCtrl -->|NetworkPolicy<br/>ServiceMonitor| InfSvc
    ModelRegOp -->|creates Registry| ModelRegInst
    TrustyAIOp -->|creates TrustyAI svc| TrustyAISvc
    TrustyAIOp -->|creates eval Jobs| EvalHubInst
    FeastOp -->|creates FeatureServer| FeastSvc
    KubeRayOp -->|creates RayClusters| RayClusters
    TrainerOp -->|creates JobSets| TrainingJobs
    TrainingOpV1 -->|creates PyTorchJobs| TrainingJobs
    MLflowOp -->|creates MLflow svc| MLflowInst
    WVAOp -->|HPA/KEDA scaling| LLMInfSvc

    %% Service Mesh
    IstioCP -->|sidecar injection<br/>mTLS enforcement| InfSvc
    IstioCP -->|sidecar injection<br/>mTLS enforcement| LLMInfSvc
    EnvoyProxy -->|ext-proc routing| LLMInfSvc

    %% Monitoring
    Prometheus -->|scrapes :8443<br/>kube-rbac-proxy| ODHDash
    Prometheus -->|scrapes metrics| KServeCM
    Prometheus -->|scrapes metrics| InfSvc
    Prometheus -->|scrapes metrics| DSPA
    Prometheus -->|scrapes metrics| TrainingJobs

    %% Cross-namespace data flows
    ODHDash -->|K8s API proxy| ModelRegInst
    ODHDash -->|K8s API proxy| InfSvc
    ODHDash -->|K8s API proxy| NotebookPod
    DSPA -->|artifact I/O| S3
    InfSvc -->|model download| S3
    InfSvc -->|model download| HFHub
    LLMInfSvc -->|model download| S3
    EvalHubInst -->|eval results| OCIReg
    EvalHubInst -->|experiment tracking| MLflowInst
    ModelRegInst -->|artifact refs| S3
    NotebookPod -->|training data| S3

    %% Egress from controllers
    KServeCM -->|SA token| K8sAPI
    RhodsOp -->|SA token| K8sAPI
    ODHDash -->|SA token| K8sAPI
    InfSvc -->|image pull| ContainerReg
    LLMInfSvc -->|image pull| ContainerReg
    NotebookPod -->|image pull| ContainerReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef mesh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef user fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f5f5f5,stroke:#666,stroke-width:2px

    class Clients external
    class DashGW,KServeGW,MaaSGW ingress
    class RhodsOp operator
    class KubeAuthProxy,KServeCM,LLMISVC,ODHModelCtrl,DSPOp,ModelRegOp,TrustyAIOp,FeastOp,KubeRayOp,SparkOp,TrainerOp,TrainingOpV1,MLflowOp,OGXOp,WVAOp,ODHDash platform
    class Prometheus,AlertManager monitoring
    class IstioCP,EnvoyProxy mesh
    class NotebookPod,InfSvc,LLMInfSvc,DSPA,TrainingJobs,MLflowInst,ModelRegInst,TrustyAISvc,EvalHubInst,FeastSvc,RayClusters user
    class KnativeSrv mesh
    class S3,ContainerReg,K8sAPI,HFHub,OCIReg egress
