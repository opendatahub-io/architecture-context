graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform Component"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS)"]
        Gateway["RHOAI Platform Ingress<br/>HTTPRoute / Route<br/>TLS 1.2+ Termination<br/>kube-rbac-proxy / Gateway API"]
    end

    subgraph Application["APPLICATION (NeMo Guardrails)"]
        direction TB

        subgraph ServerPod["Pod: NeMo Guardrails Server"]
            Server["FastAPI/Uvicorn Server<br/>UBI 9 / Python 3.12<br/>Listen: 0.0.0.0:8000 HTTP<br/>No server-level auth"]

            subgraph InProcess["In-Process NLP Models (no egress)"]
                SpaCy["SpaCy en_core_web_lg"]
                SentTrans["Sentence Transformers"]
                FastEmbedRT["FastEmbed / ONNX Runtime"]
            end
        end
    end

    subgraph LLMProviders["EGRESS - LLM Providers"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        NIM["NVIDIA NIM<br/>443/TCP or custom<br/>HTTPS/HTTP<br/>Bearer Token"]
        AzureOAI["Azure OpenAI<br/>*.openai.azure.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (api-key header)"]
        AnthropicAPI["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (x-api-key)"]
        CohereAPI["Cohere API<br/>api.cohere.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        vLLMSvc["vLLM / TRT-LLM<br/>Custom port<br/>HTTP/HTTPS<br/>Bearer Token (optional)"]
    end

    subgraph InfraServices["EGRESS - Infrastructure"]
        OTELCol["OpenTelemetry Collector<br/>Custom port<br/>HTTP/gRPC<br/>Configurable encryption"]
        RedisStore["Redis<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Username/Password"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / API Key"| Gateway

    %% Ingress to Application
    Gateway -->|"HTTP/8000<br/>Plaintext (TLS terminated)<br/>Auth header forwarded"| Server

    %% Application to LLM Providers
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>OPENAI_API_KEY"| OpenAI
    Server -->|"HTTPS or HTTP<br/>TLS 1.2+<br/>API Key"| NIM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>AZURE_OPENAI_API_KEY"| AzureOAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>ANTHROPIC_API_KEY"| AnthropicAPI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>COHERE_API_KEY"| CohereAPI
    Server -->|"HTTP/HTTPS<br/>Configurable<br/>Bearer Token"| vLLMSvc

    %% Application to Infrastructure
    Server -.->|"HTTP/gRPC<br/>Configurable<br/>OTEL_EXPORTER_OTLP_ENDPOINT"| OTELCol
    Server -.->|"Redis/6379<br/>Optional TLS<br/>Username/Password"| RedisStore

    %% In-process (no network)
    Server --- SpaCy
    Server --- SentTrans
    Server --- FastEmbedRT

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infra fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef inprocess fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class Client external
    class Gateway ingress
    class Server application
    class OpenAI,NIM,AzureOAI,AnthropicAPI,CohereAPI,vLLMSvc llmprovider
    class OTELCol,RedisStore infra
    class SpaCy,SentTrans,FastEmbedRT inprocess
