graph TB
    subgraph External["EXTERNAL CALLERS (Trusted - within cluster)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Calls all detector services"]
    end

    subgraph ServiceMesh["ISTIO SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph IstioProxy["Istio Sidecar Proxy"]
            Sidecar["TLS Mode: ISTIO_MUTUAL<br/>sidecar.istio.io/inject: true"]
        end

        subgraph Detectors["Detector Services (KServe InferenceServices)"]
            direction LR

            subgraph NS_BuiltIn["Built-in Detector"]
                BuiltIn["odh-built-in-detector<br/>Port: 8080/TCP<br/>Image: odh-built-in-detector-rhel9<br/>Auth: KServe (enable-auth: true)"]
            end

            subgraph NS_HF["HuggingFace Detector"]
                HF["odh-guardrails-detector-hf-runtime<br/>Port: 8000/TCP<br/>Image: odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>Auth: KServe (enable-auth: true)"]
            end

            subgraph NS_Judge["LLM Judge Detector"]
                Judge["guardrails-detector-llm-judge<br/>Port: 8000/TCP<br/>Image: guardrails-detector-llm-judge<br/>Auth: KServe (enable-auth: true)"]
            end
        end

        subgraph InternalServices["INTERNAL SERVICES"]
            VLLM["vLLM Inference Server<br/>Port: 8080/TCP<br/>OpenAI API compatible<br/>Istio mTLS"]
        end
    end

    subgraph Storage["STORAGE (Internal)"]
        S3["S3/MinIO Object Storage<br/>Port: 9000/TCP<br/>HTTP (in-cluster)<br/>AWS IAM credentials"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>HTTP, unauthenticated<br/>Prefix: trustyai_guardrails_*"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>Istio mTLS<br/>KServe Auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS<br/>KServe Auth"| HF
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS<br/>KServe Auth"| Judge

    Judge -->|"HTTP/8080<br/>Istio mTLS<br/>No Auth"| VLLM

    HF -->|"HTTP/9000<br/>No Encryption<br/>AWS IAM credentials"| S3

    Prometheus -.->|"HTTP/8080<br/>No Auth"| BuiltIn
    Prometheus -.->|"HTTP/8000<br/>No Auth"| HF
    Prometheus -.->|"HTTP/8000<br/>No Auth"| Judge

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef detector fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef istio fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Orchestrator external
    class BuiltIn,HF,Judge detector
    class S3 storage
    class Prometheus monitoring
    class Sidecar istio
    class VLLM servicemesh
