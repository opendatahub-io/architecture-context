graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Optional)"]
        Ingress["HTTPRoute / OpenShift Route<br/>(managed externally)<br/>TLS termination + auth expected here"]
    end

    subgraph GatewayService["GATEWAY SERVICE (Internal - ClusterIP)"]
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>Rust / axum 0.7.9<br/>Port: 8090/TCP<br/>Protocol: HTTP (plaintext)<br/>Auth: None (pass-through only)"]

        subgraph TLSSecrets["TLS Secrets (Volume Mounts)"]
            Cert["/etc/tls/private/tls.crt<br/>kubernetes.io/tls"]
            Key["/etc/tls/private/tls.key<br/>kubernetes.io/tls"]
            CA["/etc/tls/ca/service-ca.crt<br/>Opaque"]
        end

        Cert -.->|"client identity"| Gateway
        Key -.->|"client identity"| Gateway
        CA -.->|"CA validation"| Gateway
    end

    subgraph BackendServices["BACKEND SERVICES (Internal)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>Port: 8085/TCP (configurable)<br/>Endpoint: /api/v2/chat/completions-detection<br/>Protocol: HTTP or HTTPS<br/>Auth: Receives forwarded Authorization header"]

        Detectors["Detector Services<br/>(e.g., regex-language)<br/>Port: Varies<br/>Managed by orchestrator"]

        vLLM["vLLM Model Server<br/>Port: Varies<br/>Managed by orchestrator"]
    end

    %% Traffic Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header<br/>(not validated by gateway)"| Ingress
    Ingress -->|"HTTP/8090<br/>Plaintext"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>(PKCS#12 via openssl + native-tls)<br/>Authorization header forwarded<br/>x-forwarded-* headers forwarded"| Orchestrator
    Orchestrator -->|"Detection requests<br/>Port varies"| Detectors
    Orchestrator -->|"Inference requests<br/>Port varies"| vLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secrets fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class Ingress ingress
    class Gateway gateway
    class Orchestrator,Detectors,vLLM backend
    class Cert,Key,CA secrets
