graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP API Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB
        Controller["workflow-controller<br/>SA: argo<br/>ClusterRole: argo-cluster-role<br/>Image: odh-dsp-argo-workflowcontroller<br/>FIPS: strictfipsruntime"]
        Metrics["Metrics: 9090/TCP<br/>HTTPS, TLS 1.2+ (self-signed)<br/>No Auth"]
        Health["Health: 6060/TCP<br/>HTTP, No Encryption<br/>No Auth"]
        Controller --- Metrics
        Controller --- Health
    end

    subgraph WorkflowPods["WORKFLOW PODS (User Namespace)"]
        direction TB
        subgraph Pod["Workflow Pod"]
            ArgoExec["argoexec sidecar<br/>FIPS: dual binary<br/>No listening ports"]
            UserContainer["User Container<br/>(workflow step)"]
            ArgoExec -->|"Process-local<br/>Emissary pattern"| UserContainer
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Minio<br/>443/TCP or 9000/TCP<br/>HTTPS/HTTP<br/>AWS AccessKey/SecretKey"]
        PostgreSQL["PostgreSQL (optional)<br/>5432/TCP<br/>SSL/TLS configurable<br/>DB credentials"]
        MySQL["MySQL (optional)<br/>3306/TCP<br/>TLS optional<br/>DB credentials"]
        GCS["GCS (optional)<br/>443/TCP HTTPS<br/>SA JSON key"]
        Azure["Azure Blob (optional)<br/>443/TCP HTTPS<br/>Azure AD Identity"]
        Registries["Container Registries<br/>443/TCP HTTPS (OCI)<br/>Image pull secrets"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"Watch events<br/>TLS 1.2+<br/>SA Token"| Controller
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD CRUD, Pod mgmt,<br/>Leader Election"| K8sAPI
    Controller -->|"Creates pods,<br/>injects argoexec"| Pod
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>WorkflowTaskResult CRs"| K8sAPI
    ArgoExec -->|"HTTPS/443 or HTTP/9000<br/>TLS 1.2+ or plaintext<br/>AWS creds<br/>Artifact I/O"| S3
    Controller -->|"TCP/5432<br/>SSL/TLS<br/>DB creds<br/>Workflow archival"| PostgreSQL
    Controller -->|"TCP/3306<br/>TLS optional<br/>DB creds"| MySQL
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA JSON key"| GCS
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure AD"| Azure
    Controller -->|"HTTPS/443<br/>OCI protocol<br/>Pull secrets"| Registries

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workflowpod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,Metrics,Health controller
    class ArgoExec,UserContainer workflowpod
    class S3,PostgreSQL,MySQL,GCS,Azure,Registries externalservice
