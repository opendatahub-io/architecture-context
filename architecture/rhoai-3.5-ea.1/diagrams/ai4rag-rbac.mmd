graph TD
    subgraph Legend["RBAC Context for ai4rag"]
        direction TB
        Note["ai4rag is a Python library, not a Kubernetes workload.<br/>It defines NO ClusterRoles, Roles, or RoleBindings.<br/><br/>RBAC requirements are inherited from the <b>consuming component</b><br/>(e.g., Kubeflow Pipeline step's ServiceAccount)."]
    end

    subgraph ConsumerRBAC["Consumer RBAC (Illustrative)"]
        direction TB

        subgraph SA["Service Account"]
            KFPStepSA["KFP Pipeline Step SA<br/><i>(defined by consuming component)</i>"]
        end

        subgraph Permissions["Permissions Needed by Consumer"]
            direction TB
            SecretAccess["core / Secrets<br/>get (OGX API Key)"]
            ConfigMapAccess["core / ConfigMaps<br/>get (OGX Base URL config)"]
            PodExec["core / Pods<br/>create, get (pipeline step execution)"]
        end

        subgraph ExternalAuth["External Authentication"]
            direction TB
            OGXAuth["OGX Server<br/>API Key (Bearer Token)<br/><i>Passed via OgxClient constructor</i>"]
        end
    end

    KFPStepSA -->|"needs access to"| SecretAccess
    KFPStepSA -->|"needs access to"| ConfigMapAccess
    KFPStepSA -->|"runs as"| PodExec
    KFPStepSA -->|"provides credentials to"| OGXAuth

    subgraph CryptoProfile["Cryptographic Profile"]
        direction TB
        SHA256["hashlib.sha256<br/><i>Document deduplication</i><br/>FIPS-approved"]
        TLS["TLS 1.2+ (via httpx)<br/><i>Platform OpenSSL</i><br/>FIPS depends on container image"]
    end

    OGXAuth -->|"uses"| TLS

    %% Styling
    style Legend fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Note fill:#fff3cd,stroke:none
    style ConsumerRBAC fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style SA fill:#dbeafe,stroke:#3b82f6
    style Permissions fill:#dcfce7,stroke:#22c55e
    style ExternalAuth fill:#fef3c7,stroke:#f59e0b
    style CryptoProfile fill:#f3e8ff,stroke:#a855f7
    style KFPStepSA fill:#4a90e2,color:#fff
    style OGXAuth fill:#f5a623,color:#fff
    style SHA256 fill:#d5e8d4,stroke:#82b366
    style TLS fill:#d5e8d4,stroke:#82b366
