graph LR
    MLflowOp["MLflow Operator"]

    %% External Dependencies (required)
    MLflowOp -->|"controller framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"chart rendering<br/>(required)"| Helm["helm/v3<br/>v3.19.2"]

    %% External Dependencies (optional)
    MLflowOp -.->|"HTTPRoute creation<br/>(optional)"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -.->|"ConsoleLink CRD<br/>(optional)"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260209"]
    MLflowOp -.->|"ServiceMonitor CRD<br/>(optional)"| PrometheusOp["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"traffic routing<br/>(HTTPRoute parent)"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    MLflowOp -->|"TLS cert provisioning<br/>(service annotation)"| ServiceCA["OpenShift service-ca<br/>operator"]
    MLflowOp -->|"console integration<br/>(ConsoleLink CR)"| Console["OpenShift Console"]
    MLflowOp -->|"metrics scraping<br/>(ServiceMonitor CR)"| Prometheus["Prometheus /<br/>monitoring stack"]
    MLflowOp -->|"CA certificates<br/>(volume mount)"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Deployed MLflow Server dependencies
    MLflowServer["MLflow Server<br/>(deployed workload)"]
    MLflowOp -->|"deploys & manages<br/>(Helm-rendered)"| MLflowServer

    %% MLflow Server external connections
    MLflowServer -->|"metadata store<br/>5432/TCP TLS"| PostgreSQL["PostgreSQL"]
    MLflowServer -->|"metadata store<br/>3306/TCP TLS"| MySQL["MySQL"]
    MLflowServer -->|"artifact store<br/>443/9000/8333/TCP"| S3["S3-compatible<br/>Storage"]
    MLflowServer -->|"authZ checks<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Integration Points (other components using MLflow)
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org)"] -.->|"artifact config<br/>overrides"| MLflowOp
    ArtifactSecret["mlflow-artifact-<br/>connection Secret"] -.->|"S3 credentials<br/>(per-namespace)"| MLflowServer

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MLflowServer fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
