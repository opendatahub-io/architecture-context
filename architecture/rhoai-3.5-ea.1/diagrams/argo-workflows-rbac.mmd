graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(not deployed in RHOAI)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>(ClusterRoleBinding)"]
        CRB_Server["argo-server-binding<br/>(ClusterRoleBinding)<br/>⚠️ Not in RHOAI"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/>⚠️ Not in RHOAI"]
        CR_View["argo-aggregate-to-view<br/>(aggregates to view)"]
        CR_Edit["argo-aggregate-to-edit<br/>(aggregates to edit)"]
        CR_Admin["argo-aggregate-to-admin<br/>(aggregates to admin)"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        Pods["pods, pods/exec"]
        ConfigMaps["configmaps"]
        PVCs["persistentvolumeclaims<br/>+ finalizers"]
        ServiceAccounts2["serviceaccounts"]
        Events["events"]
        Secrets["secrets<br/>(limited: agent-ca-certs)"]
    end

    subgraph ArgoResources["Argo Resources (argoproj.io)"]
        Workflows["workflows<br/>+ finalizers"]
        CronWorkflows["cronworkflows<br/>+ finalizers"]
        WorkflowTemplates["workflowtemplates<br/>+ finalizers"]
        ClusterWFTemplates["clusterworkflowtemplates<br/>+ finalizers"]
        WorkflowTaskSets["workflowtasksets<br/>+ finalizers"]
        WorkflowTaskResults["workflowtaskresults"]
        ArtifactGCTasks["workflowartifactgctasks"]
        EventBindings["workfloweventbindings"]
    end

    subgraph PolicyResources["Policy Resources (policy)"]
        PDBs["poddisruptionbudgets"]
    end

    %% Bindings
    SA_Argo -->|"bound via"| CRB_Argo
    SA_Server -->|"bound via"| CRB_Server
    CRB_Argo -->|"grants"| CR_Argo
    CRB_Server -->|"grants"| CR_Server

    %% argo-cluster-role permissions
    CR_Argo -->|"create, get, list,<br/>watch, update,<br/>patch, delete"| Pods
    CR_Argo -->|"get, watch, list"| ConfigMaps
    CR_Argo -->|"create, update,<br/>delete, get"| PVCs
    CR_Argo -->|"get, list"| ServiceAccounts2
    CR_Argo -->|"create, patch"| Events
    CR_Argo -->|"get (named)"| Secrets
    CR_Argo -->|"get, list, watch,<br/>update, patch,<br/>delete, create"| Workflows
    CR_Argo -->|"get, list, watch,<br/>update, patch,<br/>delete, create"| WorkflowTaskSets
    CR_Argo -->|"get, list, watch,<br/>update, patch,<br/>delete, create"| ArtifactGCTasks
    CR_Argo -->|"get, list, watch"| WorkflowTemplates
    CR_Argo -->|"get, list, watch"| ClusterWFTemplates
    CR_Argo -->|"list, watch,<br/>deletecollection"| WorkflowTaskResults
    CR_Argo -->|"get, list, watch,<br/>update, patch,<br/>delete"| CronWorkflows
    CR_Argo -->|"create, get, delete"| PDBs

    %% Aggregate roles
    CR_View -->|"get, list, watch"| Workflows
    CR_View -->|"get, list, watch"| EventBindings
    CR_Edit -->|"full CRUD"| Workflows
    CR_Edit -->|"full CRUD"| EventBindings
    CR_Admin -->|"full CRUD<br/>+ workflowtasksets"| Workflows

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#999,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333
    style CR_Server fill:#999,stroke:#333,color:#fff
    style CR_View fill:#d5e8d4,stroke:#82b366
    style CR_Edit fill:#d5e8d4,stroke:#82b366
    style CR_Admin fill:#d5e8d4,stroke:#82b366
    style CRB_Argo fill:#ffe6cc,stroke:#d79b00
    style CRB_Server fill:#999,stroke:#333,color:#fff
    style Workflows fill:#7ed321,stroke:#333
    style CronWorkflows fill:#7ed321,stroke:#333
    style WorkflowTemplates fill:#7ed321,stroke:#333
    style ClusterWFTemplates fill:#7ed321,stroke:#333
    style WorkflowTaskSets fill:#7ed321,stroke:#333
    style WorkflowTaskResults fill:#7ed321,stroke:#333
    style ArtifactGCTasks fill:#7ed321,stroke:#333
    style EventBindings fill:#7ed321,stroke:#333
