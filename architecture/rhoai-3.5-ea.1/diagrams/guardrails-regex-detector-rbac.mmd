graph TD
    subgraph "guardrails-regex-detector RBAC"
        direction TB
        NoRBAC["No RBAC Resources Defined"]
        NoSA["No ServiceAccount Specified"]
        NoK8sAPI["No Kubernetes API Interactions"]
    end

    subgraph "Security Boundary (Infrastructure-Dependent)"
        direction TB
        NetPolicy["Network Policies<br/>(restrict access to port 8080)"]
        ServiceMesh["Service Mesh<br/>(mTLS sidecar injection)"]
        RBACProxy["kube-rbac-proxy<br/>(authentication sidecar)"]
    end

    subgraph "Application-Level Auth"
        direction TB
        NoAuth["No Authentication Enforced"]
        NoAuthZ["No Authorization Enforced"]
        PlainHTTP["Plain HTTP (No TLS)"]
    end

    NoRBAC -.->|"security delegated to"| NetPolicy
    NoRBAC -.->|"security delegated to"| ServiceMesh
    NoRBAC -.->|"security delegated to"| RBACProxy

    style NoRBAC fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NoSA fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NoK8sAPI fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NetPolicy fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ServiceMesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RBACProxy fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NoAuth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style NoAuthZ fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style PlainHTTP fill:#f8cecc,stroke:#b85450,stroke-width:2px
