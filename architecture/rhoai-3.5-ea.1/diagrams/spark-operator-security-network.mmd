graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / CI Pipeline"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)<br/>NetworkPolicy: ingress restricted"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
            SparkSubmitProc["spark-submit<br/>(local process exec)<br/>Contains: PySpark 4.0.1, Java 17"]
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>9443/TCP HTTPS (self-signed RSA 2048)<br/>HTTP/2 disabled (CVE mitigation)<br/>Cert auto-rotate <180d remaining"]
        end

        WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443<br/>TLS (self-signed)"]
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)<br/>NetworkPolicy: ports 7078, 7079, 4040"]
        direction TB

        DriverPod["Spark Driver Pod<br/>4040/TCP HTTP (Web UI)<br/>8090/TCP HTTP (JMX metrics)<br/>No encryption, No auth"]
        ExecutorPods["Spark Executor Pods<br/>7078/TCP TCP (driver RPC)<br/>7079/TCP TCP (block mgr)<br/>8090/TCP HTTP (JMX metrics)<br/>No encryption, No auth"]

        ConnectServer["SparkConnect Server (optional)<br/>15002/TCP gRPC (Spark Connect)<br/>7078/TCP TCP, 7079/TCP TCP<br/>4040/TCP HTTP<br/>No encryption, No auth"]
    end

    subgraph OptionalIngress["OPTIONAL INGRESS"]
        Ingress["Spark UI Ingress<br/>80/443 HTTP/HTTPS<br/>TLS: Configurable"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scrape<br/>8080/TCP, 8090/TCP HTTP"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>k8s API server cert"| WebhookSvc
    WebhookSvc --> Webhook
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Controller --> SparkSubmitProc
    SparkSubmitProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Webhook -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    K8sAPI -->|"Creates/Manages"| DriverPod
    K8sAPI -->|"Creates/Manages"| ExecutorPods
    K8sAPI -->|"Creates/Manages"| ConnectServer

    DriverPod -->|"TCP/7078, 7079<br/>No encryption<br/>No auth"| ExecutorPods
    ConnectServer -->|"TCP/7078, 7079<br/>No encryption"| ExecutorPods

    DriverPod -.-> Ingress
    User -->|"gRPC/15002<br/>No encryption<br/>No auth"| ConnectServer

    Prometheus -->|"HTTP/8080<br/>No auth"| Controller
    Prometheus -->|"HTTP/8080<br/>No auth"| Webhook
    Prometheus -->|"HTTP/8090<br/>No auth"| DriverPod
    Prometheus -->|"HTTP/8090<br/>No auth"| ExecutorPods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,SparkSubmitProc,Webhook,WebhookSvc operator
    class DriverPod,ExecutorPods,ConnectServer workload
    class Ingress ingress
    class Prometheus monitoring
