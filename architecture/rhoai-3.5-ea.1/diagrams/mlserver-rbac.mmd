graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        Note["MLServer does NOT define Kubernetes RBAC resources.<br/>It runs as a workload inside KServe-managed pods<br/>with KServe-defined service accounts."]

        subgraph KServeManaged["KServe-Managed RBAC (External to MLServer)"]
            KServeSA["KServe Service Account<br/>(defined by KServe operator)"]
            KServeRB["KServe Role Bindings<br/>(managed by KServe)"]
            KServeSA -->|"bound via"| KServeRB
        end

        subgraph ApplicationSecurity["Application-Level Security (MLServer)"]
            direction TB

            subgraph RuntimeSecurity["Trusted Runtime Allowlist"]
                AllowlistFile["/etc/mlserver/trusted-runtimes.json<br/>Permissions: 0444 (read-only)<br/>Baked into container image"]
                ProdMode["PRODUCTION Mode<br/>Blocks unauthorized runtimes<br/>Blocks custom Python envs<br/>Blocks wildcard CORS"]
                DevMode["DEVELOPMENT Mode<br/>Allows all runtimes<br/>(not for production use)"]
            end

            subgraph ValidationLayers["Defense-in-Depth Validation"]
                PydanticValidator["Layer 1: Pydantic Validator<br/>Validates implementation import path<br/>against allowlist during settings parse"]
                PropertyGetter["Layer 2: Property Getter<br/>Re-validates at runtime access time<br/>against allowlist"]
            end

            AllowlistFile -->|"checked by"| PydanticValidator
            AllowlistFile -->|"checked by"| PropertyGetter
            ProdMode -->|"enforces"| PydanticValidator
            ProdMode -->|"enforces"| PropertyGetter
        end

        subgraph AuthDelegation["Authentication Delegation"]
            V2Endpoints["All V2 Endpoints<br/>/v2/*, /v2/models/*/infer<br/>No application-level auth"]
            InfraAuth["Infrastructure Auth<br/>kube-rbac-proxy / Istio sidecar<br/>(managed externally)"]
            RuntimeEndpoint["/v2/runtimes Endpoint<br/>Exposes security mode<br/>and active allowlist<br/>for operator auditing"]
        end

        V2Endpoints -->|"auth delegated to"| InfraAuth
    end

    subgraph SecretsManagement["Secrets Management"]
        NoSecrets["MLServer manages NO secrets directly"]
        KServeSecrets["Model storage credentials<br/>injected by KServe"]
        TLSCerts["TLS certificates<br/>managed by KServe/Istio"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style AllowlistFile fill:#f8cecc,stroke:#b85450
    style ProdMode fill:#d4edda,stroke:#155724
    style DevMode fill:#f8d7da,stroke:#721c24
    style PydanticValidator fill:#cce5ff,stroke:#004085
    style PropertyGetter fill:#cce5ff,stroke:#004085
    style V2Endpoints fill:#e8e8e8,stroke:#333
    style InfraAuth fill:#d5e8d4,stroke:#82b366
    style RuntimeEndpoint fill:#dae8fc,stroke:#6c8ebf
    style NoSecrets fill:#e8e8e8,stroke:#333
    style KServeSecrets fill:#e8e8e8,stroke:#333
    style TLSCerts fill:#e8e8e8,stroke:#333
    style KServeSA fill:#e8e8e8,stroke:#333
    style KServeRB fill:#e8e8e8,stroke:#333
