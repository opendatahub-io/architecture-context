graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        SA_Auth["system:authenticated<br/>(Group)"]
        SA_Placeholder["placeholder<br/>(ServiceAccount)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace: ${NAMESPACE})"]
        RB_Exec["${PROJECT_NAME}-exec-rolebinding"]
        RB_SSRF["ssrf-allowlist-rolebinding"]
    end

    subgraph Roles["Roles"]
        Role_Exec["${PROJECT_NAME}-exec-role"]
        Role_SSRF["ssrf-allowlist-role"]
    end

    subgraph APIResources_Exec["API Resources (Exec)"]
        PodsExec["core (v1)<br/>pods/exec"]
    end

    subgraph APIResources_SSRF["API Resources (SSRF Protection)"]
        Pods["core (v1)<br/>pods"]
        InferencePools["inference.networking.x-k8s.io<br/>inferencepools"]
    end

    %% Exec role chain
    SA_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| Role_Exec
    Role_Exec -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| Role_SSRF
    Role_SSRF -->|"get, watch, list"| Pods
    Role_SSRF -->|"get, watch, list"| InferencePools

    %% Purpose annotations
    PodsExec -.- ExecNote["Purpose: Debugging<br/>exec into pods"]
    Pods -.- PodsNote["Purpose: Build IP/hostname<br/>allowlist from pod IPs"]
    InferencePools -.- PoolNote["Purpose: Extract pod selectors<br/>for SSRF protection"]

    %% Styles
    style SA_Auth fill:#4a90e2,color:#fff
    style SA_Placeholder fill:#4a90e2,color:#fff
    style RB_Exec fill:#9b59b6,color:#fff
    style RB_SSRF fill:#9b59b6,color:#fff
    style Role_Exec fill:#f5a623,color:#fff
    style Role_SSRF fill:#f5a623,color:#fff
    style PodsExec fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style InferencePools fill:#7ed321,color:#fff
    style ExecNote fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
    style PodsNote fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
    style PoolNote fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
