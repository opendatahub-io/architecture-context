graph TB
    subgraph "LM Evaluation Harness (Batch Job Pod)"
        direction TB
        Adapter["LMEval Adapter<br/>(main.py)<br/>EvalHub FrameworkAdapter"]
        LMEval["lm_eval Library<br/>(EleutherAI v0.4.8 fork)<br/>Core Evaluation Engine"]
        Tasks["Task Definitions<br/>(6,586 YAML files)<br/>157 categories"]
        Metrics["Metric Modules<br/>(54 metric types)<br/>Offline-capable"]
        OCIPublisher["OCI Artifact Publisher<br/>(scripts/oci.py)<br/>skopeo + olot"]
        Unitxt["Unitxt Framework<br/>Extensible task/metric<br/>definitions"]

        Adapter -->|"calls simple_evaluate()"| LMEval
        LMEval -->|"loads tasks"| Tasks
        LMEval -->|"computes metrics"| Metrics
        LMEval -->|"unitxt task type"| Unitxt
        Adapter -->|"publishes artifacts"| OCIPublisher
    end

    Operator["TrustyAI LMEval Operator"] -->|"creates Pod<br/>mounts /meta/job.json"| Adapter
    JobSpec["/meta/job.json<br/>(ConfigMap mount)"] -->|"read by"| Adapter

    Adapter -->|"POST status/results<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    LMEval -->|"POST /v1/completions<br/>HTTP(S)"| ModelEndpoint["Model Inference<br/>Endpoint<br/>(vLLM / TGI / OpenAI)"]
    OCIPublisher -->|"push artifacts<br/>HTTPS/443"| OCIRegistry["OCI Registry<br/>(Quay)"]
    LMEval -->|"download tokenizers<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    Adapter -->|"log metrics"| MLflow["MLflow Tracking<br/>Server"]

    subgraph "Offline Mode (Air-Gapped)"
        TestData["/test_data mount<br/>Tokenizers + Datasets"]
        OfflineMetrics["metrics/ directory<br/>Local metric files"]
    end

    TestData -.->|"auto-detected<br/>HF_HUB_OFFLINE=1"| Adapter
    OfflineMetrics -.->|"patched evaluate.load()"| LMEval

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style LMEval fill:#4a90e2,stroke:#333,color:#fff
    style Tasks fill:#7ed321,stroke:#333,color:#fff
    style Metrics fill:#7ed321,stroke:#333,color:#fff
    style OCIPublisher fill:#4a90e2,stroke:#333,color:#fff
    style Unitxt fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#f5a623,stroke:#333,color:#fff
    style JobSpec fill:#f5a623,stroke:#333
    style EvalHub fill:#e8e8e8,stroke:#333
    style ModelEndpoint fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style TestData fill:#d5e8d4,stroke:#82b366
    style OfflineMetrics fill:#d5e8d4,stroke:#82b366
