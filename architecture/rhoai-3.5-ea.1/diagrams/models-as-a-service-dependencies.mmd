graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy +<br/>TokenRateLimitPolicy<br/>+ Authorino callbacks"| Kuadrant["Kuadrant / RHCL<br/>1.4.2+ / 1.3+"]
    MaaS -->|"Watch LLMInferenceService<br/>model readiness"| KServe["KServe<br/>v0.15+"]
    MaaS -->|"API key hash<br/>storage + queries<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"ServiceEntry,<br/>DestinationRule,<br/>EnvoyFilter"| Istio["Istio<br/>(Service Mesh)"]
    MaaS -->|"Gateway +<br/>HTTPRoute<br/>per model"| GatewayAPI["Gateway API<br/>(OpenShift)<br/>v1"]
    MaaS -->|"CRD ops, RBAC,<br/>leader election<br/>6443/TCP"| OpenShift["OpenShift<br/>4.19.9+"]

    %% Internal Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"DSC component<br/>enablement"| MaaS
    MaaS -.->|"HTTP callbacks<br/>8080/TCP"| Authorino["Kuadrant<br/>Authorino"]
    MaaS -.->|"rate limit<br/>enforcement"| Limitador["Kuadrant<br/>Limitador"]
    MaaS -.->|"maas-default-gateway<br/>openshift-ingress"| OCP_Ingress["OpenShift Ingress<br/>(Gateway)"]
    MaaS -.->|"dashboards +<br/>datasources"| Perses["Perses<br/>(optional, COO)"]

    %% Integration Points (consumers of MaaS)
    Prometheus["Prometheus<br/>(monitoring)"] -->|"scrape metrics<br/>9090, 8080, 9005,<br/>15090/TCP"| MaaS

    %% External Services
    MaaS -->|"inference via<br/>ServiceEntry<br/>443/TCP HTTPS"| ExternalLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]

    %% Sub-component relationships
    subgraph MaaS_Internal["MaaS Internal Components"]
        direction TB
        Controller["maas-controller<br/>(Go Operator)"]
        API["maas-api<br/>(Go/Gin HTTP)"]
        Payload["payload-processing<br/>(Envoy ext_proc)"]
        Controller -->|"kustomize deploy"| API
        Controller -->|"kustomize deploy"| Payload
    end

    MaaS --- MaaS_Internal

    %% Styling
    classDef primary fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    classDef external fill:#999,stroke:#333,stroke-width:1px,color:#fff
    classDef internal fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef extservice fill:#f5a623,stroke:#333,stroke-width:1px,color:#fff
    classDef monitoring fill:#50e3c2,stroke:#333,stroke-width:1px,color:#333
    classDef subcomponent fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px,color:#333

    class MaaS primary
    class Kuadrant,KServe,PostgreSQL,Istio,GatewayAPI,OpenShift external
    class RHODSOp,Authorino,Limitador,OCP_Ingress,Perses internal
    class ExternalLLM extservice
    class Prometheus monitoring
    class Controller,API,Payload subcomponent
