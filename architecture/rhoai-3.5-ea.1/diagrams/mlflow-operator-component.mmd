graph TB
    subgraph Operator["MLflow Operator (Go)"]
        Controller["MLflow Controller<br/>controller-runtime"]
        HelmRenderer["Helm Chart Renderer<br/>helm/v3"]
        RoutingMgr["Routing Manager<br/>HTTPRoute + ConsoleLink"]
        CABundleMgr["CA Bundle Manager<br/>ConfigMap watcher"]
        Controller -->|renders| HelmRenderer
        Controller -->|manages| RoutingMgr
        Controller -->|watches| CABundleMgr
    end

    subgraph DeployedStack["Deployed MLflow Stack (Helm-rendered)"]
        MLflowServer["MLflow Server<br/>Python/Uvicorn<br/>8443/TCP HTTPS"]
        CAWatcher["CA Bundle Watcher<br/>Sidecar"]
        MLflowSA["ServiceAccount<br/>mlflow-sa"]
        MLflowTLS["mlflow-tls Secret<br/>TLS cert"]
        NetPolicy["NetworkPolicy<br/>Restrictive egress"]
        PVC["PersistentVolumeClaim<br/>(optional)"]
        SvcMonitor["ServiceMonitor<br/>Prometheus scraping"]
        MLflowServer --- CAWatcher
        MLflowServer --- MLflowSA
        MLflowServer --- MLflowTLS
        MLflowServer --- NetPolicy
        MLflowServer --- PVC
        MLflowServer --- SvcMonitor
    end

    %% CRDs
    User[Data Scientist / Admin] -->|creates| MLflowCR["MLflow CR<br/>mlflow.opendatahub.io/v1<br/>(Cluster-scoped)"]
    User -->|creates| MLflowConfigCR["MLflowConfig CR<br/>mlflow.kubeflow.org/v1<br/>(Namespaced)"]
    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller
    HelmRenderer -->|SSA patch| DeployedStack

    %% External dependencies
    Controller -->|watch/patch| K8sAPI["Kubernetes API<br/>6443/TCP"]
    RoutingMgr -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    RoutingMgr -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    HTTPRoute -->|parent ref| Gateway["data-science-gateway<br/>(Envoy)"]

    %% Service-CA integration
    ServiceCA["OpenShift service-ca"] -->|provisions| MLflowTLS

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes via| SvcMonitor

    %% Backend connections
    MLflowServer -->|metadata store| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflowServer -->|artifact store| S3["S3-compatible Storage<br/>443/9000/8333/TCP"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style RoutingMgr fill:#4a90e2,color:#fff
    style CABundleMgr fill:#4a90e2,color:#fff
    style MLflowServer fill:#7ed321,color:#fff
    style CAWatcher fill:#7ed321,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style HTTPRoute fill:#f5a623,color:#fff
    style ConsoleLink fill:#f5a623,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
