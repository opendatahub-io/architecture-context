graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB1["model-registry-manager<br/>-rolebinding"]
        CRB2["model-registry-ui<br/>-services-reader-binding"]
        CRB3["model-registry-retrieve<br/>-clusterrolebindings-binding"]
        CRB4["model-registry-create<br/>-sars-binding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR1["model-registry-manager-role"]
        CR2["model-registry-ui-services-reader"]
        CR3["model-registry-retrieve-clusterrolebindings"]
        CR4["model-registry-create-sars"]
    end

    subgraph APIResources_Controller["API Resources (Controller)"]
        CoreServices["core<br/>services<br/>get, list, watch"]
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>get, list, patch,<br/>update, watch"]
        ISFinalizers["serving.kserve.io<br/>inferenceservices/finalizers<br/>create, delete, get,<br/>list, patch, update, watch"]
    end

    subgraph APIResources_UI["API Resources (UI)"]
        UIServices["core<br/>services<br/>get, list, watch"]
        UIClusterRB["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get, list, watch"]
        UISAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    %% Controller SA bindings
    SA_Controller -->|"bound via"| CRB1
    CRB1 -->|"grants"| CR1
    CR1 -->|"get, list, watch"| CoreServices
    CR1 -->|"get, list, patch,<br/>update, watch"| InferenceServices
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| ISFinalizers

    %% UI SA bindings
    SA_UI -->|"bound via"| CRB2
    SA_UI -->|"bound via"| CRB3
    SA_UI -->|"bound via"| CRB4
    CRB2 -->|"grants"| CR2
    CRB3 -->|"grants"| CR3
    CRB4 -->|"grants"| CR4
    CR2 -->|"get, list, watch"| UIServices
    CR3 -->|"get, list, watch"| UIClusterRB
    CR4 -->|"create"| UISAR

    subgraph IstioAuthZ["Istio Authorization"]
        AuthPolicy["AuthorizationPolicy:<br/>model-registry"]
        Rule1["Allow: ingress gateway<br/>(oauth2-proxy authenticated)"]
        Rule2["Allow: internal with JWT<br/>but NO kubeflow-userid header<br/>(prevents spoofing)"]
        AuthPolicy --> Rule1
        AuthPolicy --> Rule2
    end

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff
    style CR1 fill:#f5a623,stroke:#333,color:#fff
    style CR2 fill:#f5a623,stroke:#333,color:#fff
    style CR3 fill:#f5a623,stroke:#333,color:#fff
    style CR4 fill:#f5a623,stroke:#333,color:#fff
    style CRB1 fill:#85BBF0,stroke:#333
    style CRB2 fill:#85BBF0,stroke:#333
    style CRB3 fill:#85BBF0,stroke:#333
    style CRB4 fill:#85BBF0,stroke:#333
    style CoreServices fill:#7ed321,stroke:#333,color:#fff
    style InferenceServices fill:#7ed321,stroke:#333,color:#fff
    style ISFinalizers fill:#7ed321,stroke:#333,color:#fff
    style UIServices fill:#7ed321,stroke:#333,color:#fff
    style UIClusterRB fill:#7ed321,stroke:#333,color:#fff
    style UISAR fill:#7ed321,stroke:#333,color:#fff
    style AuthPolicy fill:#e8a0bf,stroke:#333
    style Rule1 fill:#f0d0e0,stroke:#333
    style Rule2 fill:#f0d0e0,stroke:#333
