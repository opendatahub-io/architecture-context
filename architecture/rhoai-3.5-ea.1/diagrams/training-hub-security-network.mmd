graph TB
    subgraph LocalEnv["LOCAL EXECUTION ENVIRONMENT<br/>(GPU Machine / Notebook Pod)"]
        direction TB

        UserScript["User Script / Notebook"]

        subgraph SDK["training-hub SDK"]
            direction TB
            Registry["AlgorithmRegistry"]
            ParamLayer["Parameter Translation"]

            subgraph BackendZone["Backends"]
                ILab["instructlab-training<br/>In-process API"]
                MiniT["mini-trainer<br/>In-process API"]
                Unsloth["Unsloth<br/>In-process API"]
                ART["ART<br/>Subprocess (GPU isolation)"]
                Verl["verl<br/>CLI / torchrun"]
            end

            MemEst["Memory Estimator"]
        end

        GPU["Local GPU(s)<br/>CUDA / NCCL"]
        Filesystem["Local Filesystem<br/>Checkpoints + Metrics"]
    end

    subgraph Distributed["DISTRIBUTED TRAINING<br/>(Intra-cluster, when multi-node)"]
        NCCL["torchrun / NCCL Workers<br/>Dynamic/TCP<br/>NO Encryption<br/>NO Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF Token (optional)"]
        WandB["Weights & Biases API<br/>api.wandb.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API Key (optional)"]
        MLflow["MLflow Tracking Server<br/>Configurable port<br/>HTTP/HTTPS<br/>Auth: Configurable (optional)"]
    end

    %% Internal flows
    UserScript -->|"Function call<br/>In-process"| SDK
    SDK -->|"CUDA"| GPU
    SDK -->|"Filesystem I/O"| Filesystem

    %% Distributed training
    Verl -->|"Dynamic/TCP<br/>NCCL<br/>NO encryption"| NCCL

    %% Egress flows
    SDK -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HF
    SDK -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WandB
    SDK -->|"HTTP(S)<br/>Configurable<br/>Configurable auth"| MLflow

    %% Styling
    classDef local fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sdk fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef distributed fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class UserScript local
    class Registry,ParamLayer,MemEst sdk
    class ILab,MiniT,Unsloth,ART,Verl backend
    class NCCL distributed
    class HF,WandB,MLflow external
    class GPU,Filesystem hardware
