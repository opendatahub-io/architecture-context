graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager"]
        SA_TAS_Proxy["{tas-instance}-proxy"]
        SA_EvalHub["{evalhub-instance}"]
        SA_GORCH["{gorch-instance}"]
        SA_Nemo["{nemoguardrails-instance}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_AuthDel["manager-auth-delegator"]
        CRB_TASProxy["{tas}-proxy-rolebinding"]
        CRB_EHAuth["{evalhub}-auth-reviewer"]
        CRB_GORCHAuth["{gorch}-auth-delegator"]
        CRB_NemoAuth["{nemo}-auth-delegator"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_TAS["tas-manager-role"]
        CR_LMES["lmes-manager-role"]
        CR_EH["evalhub-manager-role"]
        CR_GORCH["gorch-manager-role"]
        CR_NEMO["nemo-guardrails-manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    %% SA → Binding → Role connections
    SA_CM -->|bound via| CRB_AuthDel
    CRB_AuthDel -->|grants| CR_AuthDel

    SA_CM -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    SA_TAS_Proxy -->|bound via| CRB_TASProxy
    CRB_TASProxy -->|grants| CR_Proxy

    SA_EvalHub -->|bound via| CRB_EHAuth
    CRB_EHAuth -->|grants| CR_AuthDel

    SA_GORCH -->|bound via| CRB_GORCHAuth
    CRB_GORCHAuth -->|grants| CR_AuthDel

    SA_Nemo -->|bound via| CRB_NemoAuth
    CRB_NemoAuth -->|grants| CR_AuthDel

    %% TAS Manager Role Resources
    subgraph TAS_Resources["TAS Manager Resources"]
        TAS_R1["trustyai.opendatahub.io<br/>trustyaiservices (+status/finalizers)<br/>full CRUD"]
        TAS_R2["apps<br/>deployments (+status/finalizers)<br/>full CRUD"]
        TAS_R3["core<br/>services, pods, configmaps,<br/>pvcs, secrets, SAs, events<br/>full CRUD"]
        TAS_R4["serving.kserve.io<br/>inferenceservices (+finalizers)<br/>list, watch, get, update, patch, delete"]
        TAS_R5["route.openshift.io<br/>routes — full CRUD"]
        TAS_R6["monitoring.coreos.com<br/>servicemonitors<br/>list, watch, create"]
        TAS_R7["networking.istio.io<br/>destinationrules, virtualservices<br/>full CRUD"]
    end

    CR_TAS -->|manages| TAS_R1
    CR_TAS -->|manages| TAS_R2
    CR_TAS -->|manages| TAS_R3
    CR_TAS -->|manages| TAS_R4
    CR_TAS -->|manages| TAS_R5
    CR_TAS -->|manages| TAS_R6
    CR_TAS -->|manages| TAS_R7

    %% LMES Manager Role Resources
    subgraph LMES_Resources["LMES Manager Resources"]
        LMES_R1["trustyai.opendatahub.io<br/>lmevaljobs (+status/finalizers)<br/>full CRUD"]
        LMES_R2["core<br/>pods, pods/exec<br/>get, list, watch, create, delete"]
        LMES_R3["core<br/>configmaps, secrets<br/>get, watch, list"]
        LMES_R4["core<br/>pvs, pvcs<br/>full CRUD"]
    end

    CR_LMES -->|manages| LMES_R1
    CR_LMES -->|manages| LMES_R2
    CR_LMES -->|manages| LMES_R3
    CR_LMES -->|manages| LMES_R4

    %% EvalHub Manager Role Resources
    subgraph EH_Resources["EvalHub Manager Resources"]
        EH_R1["trustyai.opendatahub.io<br/>evalhubs (+status/finalizers/proxy)<br/>full CRUD"]
        EH_R2["apps<br/>deployments (+status)<br/>full CRUD"]
        EH_R3["core<br/>services, configmaps, SAs,<br/>namespaces, pods, events<br/>full CRUD"]
        EH_R4["rbac.authorization.k8s.io<br/>clusterrolebindings, roles,<br/>rolebindings — full CRUD"]
        EH_R5["kueue.x-k8s.io<br/>workloads<br/>get, list, watch, patch"]
        EH_R6["batch<br/>jobs<br/>get, list, watch, patch, delete"]
    end

    CR_EH -->|manages| EH_R1
    CR_EH -->|manages| EH_R2
    CR_EH -->|manages| EH_R3
    CR_EH -->|manages| EH_R4
    CR_EH -->|manages| EH_R5
    CR_EH -->|manages| EH_R6

    %% GORCH Manager Role Resources
    subgraph GORCH_Resources["GORCH Manager Resources"]
        GORCH_R1["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>(+status/finalizers) full CRUD"]
        GORCH_R2["serving.kserve.io<br/>servingruntimes, inferenceservices<br/>get, list, watch"]
        GORCH_R3["apps<br/>deployments (+status/finalizers)<br/>full CRUD"]
        GORCH_R4["core<br/>services, pods, configmaps,<br/>events, secrets, SAs<br/>full CRUD"]
    end

    CR_GORCH -->|manages| GORCH_R1
    CR_GORCH -->|manages| GORCH_R2
    CR_GORCH -->|manages| GORCH_R3
    CR_GORCH -->|manages| GORCH_R4

    %% NeMo Manager Role Resources
    subgraph NEMO_Resources["NeMo Manager Resources"]
        NEMO_R1["trustyai.opendatahub.io<br/>nemoguardrails (+status/finalizers)<br/>full CRUD"]
        NEMO_R2["apps<br/>deployments (+status/finalizers)<br/>full CRUD"]
        NEMO_R3["core<br/>configmaps, services,<br/>secrets, SAs — full CRUD"]
        NEMO_R4["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>full CRUD"]
    end

    CR_NEMO -->|manages| NEMO_R1
    CR_NEMO -->|manages| NEMO_R2
    CR_NEMO -->|manages| NEMO_R3
    CR_NEMO -->|manages| NEMO_R4

    %% Proxy Role Resources
    subgraph Proxy_Resources["Proxy Role Resources"]
        Proxy_R1["authentication.k8s.io<br/>tokenreviews — create"]
        Proxy_R2["authorization.k8s.io<br/>subjectaccessreviews — create"]
    end

    CR_Proxy -->|manages| Proxy_R1
    CR_Proxy -->|manages| Proxy_R2

    %% Leader Election Role Resources
    subgraph Leader_Resources["Leader Election Resources"]
        Leader_R1["core, coordination.k8s.io<br/>configmaps, leases, events<br/>full CRUD"]
    end

    R_Leader -->|manages| Leader_R1

