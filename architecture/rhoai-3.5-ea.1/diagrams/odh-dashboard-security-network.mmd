graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)"]
    end

    subgraph AuthZone["AUTHENTICATION ZONE"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS 1.2+ (service-ca)<br/>OIDC validation<br/>K8s RBAC (list projects)"]
    end

    subgraph DashPod["DASHBOARD POD (In-Pod Trust)"]
        direction TB

        subgraph MainContainer["SA: odh-dashboard (broad perms)"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP<br/>secureRoute / secureAdminRoute"]
        end

        subgraph BFFContainers["SA: odh-dashboard-modules (limited perms)"]
            direction LR
            MR["model-registry-ui<br/>8043/TCP HTTPS"]
            GenAI["gen-ai-ui<br/>8143/TCP HTTPS"]
            MaaS["maas-ui<br/>8243/TCP HTTPS"]
            MLflow["mlflow-ui<br/>8343/TCP HTTPS"]
            EvalHub["eval-hub-ui<br/>8543/TCP HTTPS"]
            AutoML["automl-ui<br/>8643/TCP HTTPS"]
            AutoRAG["autorag-ui<br/>8743/TCP HTTPS"]
        end
    end

    subgraph PlatformEncrypted["PLATFORM SERVICES (Encrypted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        DSPipeline["DS Pipeline API<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        ModelRegSvc["Model Registry Service<br/>HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        TrustyAISvc["TrustyAI Service<br/>HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        MLflowSvc["MLflow Tracking<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        FeastSvc["Feast Registry<br/>HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph PlatformPlaintext["PLATFORM SERVICES (⚠️ Unencrypted)"]
        Perses["Perses<br/>8080/TCP HTTP<br/>⚠️ No Encryption<br/>Bearer Token"]
        LlamaStack["Llama Stack<br/>8321/TCP HTTP<br/>⚠️ No Encryption<br/>Bearer Token"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Outbound)"]
        ExternalModels["External Model Endpoints<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Segment["Segment Analytics<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    %% Flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+ (service-ca)<br/>Token forwarded"| KRBAC
    KRBAC -->|"HTTP/8080<br/>No encryption (localhost)<br/>X-Auth-Request headers"| Backend

    Backend -->|"HTTPS 8043-8743<br/>TLS 1.2+ (shared cert)<br/>x-forwarded-access-token"| MR
    Backend -->|"HTTPS<br/>x-forwarded-access-token"| GenAI
    Backend -->|"HTTPS<br/>x-forwarded-access-token"| MaaS
    Backend -->|"HTTPS<br/>x-forwarded-access-token"| MLflow

    Backend -->|"HTTPS/6443<br/>Bearer Token (user)"| K8sAPI
    Backend -->|"HTTPS/9092<br/>Bearer Token"| Thanos
    Backend -->|"HTTPS/8443<br/>Bearer Token"| DSPipeline
    Backend -->|"HTTPS<br/>Bearer Token"| ModelRegSvc
    Backend -->|"HTTPS<br/>Bearer Token"| TrustyAISvc
    Backend -->|"HTTP/8080<br/>⚠️ Plaintext"| Perses
    Backend -->|"HTTP/8321<br/>⚠️ Plaintext"| LlamaStack

    GenAI -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    MaaS -->|"HTTPS/443<br/>Bearer Token"| ExternalModels

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalsvc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Browser external
    class Gateway ingress
    class KRBAC auth
    class Backend,MR,GenAI,MaaS,MLflow,EvalHub,AutoML,AutoRAG trusted
    class K8sAPI,Thanos,DSPipeline,ModelRegSvc,TrustyAISvc,MLflowSvc,FeastSvc platform
    class Perses,LlamaStack warning
    class ExternalModels,Segment externalsvc
