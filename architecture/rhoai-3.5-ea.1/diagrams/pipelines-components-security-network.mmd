graph TB
    subgraph PipelineRuntime["KFP PIPELINE RUNTIME (Ephemeral Task Containers)"]
        direction TB

        subgraph InitContainer["Init Container"]
            InitPipelines["odh-pipelines-components<br/>quay.io/rhoai/odh-pipelines-components<br/>Path traversal validation: is_relative_to()"]
        end

        subgraph TaskPods["KFP Task Pods"]
            direction LR
            AutoMLPod["odh-automl Tasks<br/>SA: KFP pipeline SA<br/>Image: quay.io/rhoai/odh-automl"]
            AutoRAGPod["odh-autorag Tasks<br/>SA: KFP pipeline SA<br/>Image: quay.io/rhoai/odh-autorag"]
            KFPPod["KFP Component Tasks<br/>SA: KFP pipeline SA<br/>Image: kfp-component-base"]
        end
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        KFPServer["KFP API Server<br/>Shared Volume Mount"]
        TrainingHub["Kubeflow Training Hub<br/>ClusterTrainingRuntime"]
        ModelReg["Model Registry<br/>8080/TCP HTTP<br/>⚠ PLAINTEXT / No Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (TLS 1.2+)"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>AWS IAM Credentials"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>Bearer Token (HF_TOKEN)"]
        OGX["OGX API<br/>443/TCP HTTPS<br/>Bearer Token (OGX_CLIENT_API_KEY)<br/>⚠ SSL verify=False fallback"]
        LiteLLM["LiteLLM / LLM Provider<br/>443/TCP HTTPS<br/>API Key (LLM_API_KEY)"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>Docker config.json"]
        Milvus["Milvus Vector Store<br/>Configurable Port<br/>HTTP/gRPC"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+ (in-cluster CA)<br/>Bearer Token"]
    end

    subgraph SharedStorage["LOCAL STORAGE (Shared Volumes)"]
        PVC["Pipeline Workspace PVC<br/>50Gi RWX (fine-tuning)<br/>12Gi RWO (AutoML)"]
        ManagedVol["Managed Pipelines Volume<br/>/config/managed-pipelines/"]
    end

    %% Init container flow
    InitPipelines -->|"Filesystem copy<br/>(path validated)"| ManagedVol
    ManagedVol -->|"Pipeline discovery"| KFPServer

    %% Task pod egress - S3
    AutoMLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Task pod egress - HuggingFace
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Task pod egress - OGX
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer OGX_CLIENT_API_KEY<br/>⚠ verify=False fallback"| OGX

    %% Task pod egress - K8s API
    KFPPod -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer KUBERNETES_AUTH_TOKEN"| K8sAPI
    K8sAPI -->|"Manages"| TrainingHub

    %% Task pod egress - Model Registry
    KFPPod -->|"HTTP/8080<br/>⚠ PLAINTEXT<br/>⚠ No Auth"| ModelReg

    %% Task pod egress - Milvus
    AutoRAGPod -->|"HTTP or gRPC<br/>Configurable"| Milvus

    %% Task pod egress - LiteLLM
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LiteLLM

    %% Task pod egress - OCI
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker config.json"| OCIReg

    %% PVC access
    AutoMLPod ---|"Filesystem"| PVC
    AutoRAGPod ---|"Filesystem"| PVC
    KFPPod ---|"Filesystem"| PVC

    %% Styling
    classDef runtime fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef internal fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef k8s fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef storage fill:#eceff1,stroke:#546e7a,stroke-width:2px
    classDef warning fill:#ffebee,stroke:#c62828,stroke-width:2px

    class InitPipelines,AutoMLPod,AutoRAGPod,KFPPod runtime
    class KFPServer,TrainingHub internal
    class ModelReg warning
    class S3,HFHub,OGX,LiteLLM,OCIReg,Milvus external
    class K8sAPI k8s
    class PVC,ManagedVol storage
