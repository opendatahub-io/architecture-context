graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist / ML Engineer<br/>Browser + MLflow SDK + OTel SDK"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["RHOAI Platform Gateway<br/>HTTPRoute (rhods-operator managed)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph Sidecar["SIDECAR (Auth Enforcement)"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP → 5000/TCP<br/>TokenReview validation"]
    end

    subgraph Application["APPLICATION (MLflow Server)"]
        direction TB

        subgraph SecurityStack["Security Middleware"]
            CORS["CORSBlockingMiddleware<br/>Block cross-origin mutations"]
            HostValid["HostValidationMiddleware<br/>DNS rebinding protection"]
            SecHeaders["Security Headers"]
        end

        subgraph AuthPlugin["kubernetes-auth Plugin"]
            K8sAuth["SA Token Auth Provider<br/>60s TTL cache<br/>Permission: READ/EDIT/MANAGE"]
            WorkspaceCtx["Workspace ContextVar<br/>Per-request isolation"]
        end

        subgraph Server["MLflow Server"]
            Uvicorn["Uvicorn ASGI<br/>Port 5000/TCP HTTP<br/>Non-root UID 1001"]
            EnvelopeEnc["Envelope Encryption<br/>AES-256-GCM<br/>PBKDF2-HMAC-SHA256<br/>(600k iterations)"]
        end

        subgraph HealthEndpoints["Auth-Exempt"]
            Health["/health, /version<br/>No auth required"]
        end
    end

    subgraph Backend["BACKEND SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>TLS configurable<br/>Auth: Username/Password"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Artifact Storage)"]
        S3["S3-compatible Store<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / STS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: GCP Service Account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Azure AD"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/5000<br/>Plaintext (localhost)<br/>Pre-validated"| Uvicorn

    Uvicorn -->|"PostgreSQL/5432<br/>TLS configurable<br/>Username/Password"| PostgreSQL
    Uvicorn -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    Uvicorn -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Uvicorn -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    Uvicorn -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure AD"| Azure

    KubeRBACProxy -.->|"TokenReview<br/>HTTPS/443"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class Gateway ingress
    class KubeRBACProxy sidecar
    class Uvicorn,EnvelopeEnc,Health application
    class CORS,HostValid,SecHeaders security
    class K8sAuth,WorkspaceCtx auth
    class PostgreSQL,K8sAPI backend
    class S3,GCS,Azure externalservice
