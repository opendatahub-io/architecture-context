graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% External Python Dependencies
    subgraph ExtDeps["External Dependencies (Python)"]
        Ray["ray 2.54.1<br/>(core, data, default)"]
        K8sClient["kubernetes >= 27.2.0"]
        KubeAuthkit["kube-authkit >= 0.4.0"]
        OSClient["openshift-client 1.0.18"]
        Cryptography["cryptography 46.0.7"]
        Pydantic["pydantic >= 2.10.6"]
        Rich["rich >= 12.5, < 15.0"]
        IPyWidgets["ipywidgets 8.1.2"]
        Executing["executing 2.2.1"]
    end

    SDK -->|"distributed compute"| Ray
    SDK -->|"K8s API access"| K8sClient
    SDK -->|"OIDC/OAuth/token auth"| KubeAuthkit
    SDK -->|"OpenShift utilities"| OSClient
    SDK -->|"TLS cert generation<br/>RSA-3072, SHA-256"| Cryptography
    SDK -->|"config validation"| Pydantic
    SDK -->|"terminal formatting"| Rich
    SDK -->|"notebook widgets"| IPyWidgets
    SDK -->|"AST context (Ray dep)"| Executing

    %% Internal Platform Dependencies
    subgraph IntDeps["Internal Platform Dependencies"]
        KubeRayOp["KubeRay Operator<br/>(ray.io/v1)"]
        KueueCtrl["Kueue Controller<br/>(kueue.x-k8s.io/v1beta1)"]
        RHOAIGw["RHOAI Gateway<br/>(gateway.networking.k8s.io/v1)"]
        OSRouter["OpenShift Router<br/>(route.openshift.io/v1)"]
        CABundle["ODH Trusted CA Bundle<br/>(ConfigMap)"]
        CASecret["Ray Head CA Secret<br/>({cluster}-ca-secret-*)"]
    end

    SDK -->|"CRD: RayCluster, RayJob"| KubeRayOp
    SDK -->|"CRD: LocalQueue, Workload,<br/>WorkloadPriorityClass"| KueueCtrl
    SDK -->|"CRD: HTTPRoute, Gateway<br/>(dashboard URL, v3.0+)"| RHOAIGw
    SDK -.->|"CRD: Route<br/>(dashboard URL, fallback)"| OSRouter
    SDK -.->|"mounted into Ray pods"| CABundle
    SDK -->|"reads for mTLS cert gen"| CASecret

    %% Integration Points (consumers of SDK-created resources)
    subgraph Consumers["Integrates With (Bidirectional)"]
        RayHead["Ray Head Pod<br/>Ports: 6379, 8265, 10001"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    end

    SDK -->|"gRPC mTLS<br/>10001/TCP"| RayHead
    SDK -->|"HTTPS CRUD<br/>6443/TCP"| K8sAPI
    KubeRayOp -->|"creates/manages"| RayHead

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style Ray fill:#e8e8e8,stroke:#333
    style K8sClient fill:#e8e8e8,stroke:#333
    style KubeAuthkit fill:#e8e8e8,stroke:#333
    style OSClient fill:#e8e8e8,stroke:#333
    style Cryptography fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333
    style Rich fill:#e8e8e8,stroke:#333
    style IPyWidgets fill:#e8e8e8,stroke:#333
    style Executing fill:#e8e8e8,stroke:#333

    style KubeRayOp fill:#7ed321,stroke:#333
    style KueueCtrl fill:#7ed321,stroke:#333
    style RHOAIGw fill:#7ed321,stroke:#333
    style OSRouter fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333
    style CASecret fill:#7ed321,stroke:#333

    style RayHead fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
