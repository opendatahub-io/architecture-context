graph TB
    subgraph "models-perf-benchmark-data"
        subgraph "Data Container (Shipped)"
            DataImage["odh-model-performance-data<br/>UBI9-minimal Init Container"]
            BenchmarkData["/app/benchmarks<br/>Benchmark Data Files"]
            DataImage -->|contains| BenchmarkData
        end

        subgraph "Offline Tooling (Not Shipped)"
            KafkaProcessor["kafka-processor<br/>Python 3.12 CLI"]
            EntityClassifier["Entity Classifier<br/>Type routing by topic/fields"]
            Transforms["Post-Processing Transforms"]
            OverallAccuracy["OverallAccuracyTransform<br/>Mean evaluation score"]
            HardwareConfig["HardwareConfigurationTransform<br/>Hardware type + count"]

            KafkaProcessor -->|classifies| EntityClassifier
            KafkaProcessor -->|applies| Transforms
            Transforms --> OverallAccuracy
            Transforms --> HardwareConfig
        end
    end

    %% Build-time flow
    KafkaProcessor -->|"produces data/"| DataFiles["data/<br/>provider/model hierarchy"]
    DataFiles -->|"COPY into image"| DataImage

    %% Runtime flow
    DataImage -->|"init container<br/>copies to shared volume"| SharedVolume["Shared Volume<br/>/app/benchmarks"]
    SharedVolume -->|"filesystem read"| ModelCatalog["model-catalog<br/>(Model Registry)"]

    %% External data source
    KafkaBroker["Internal Kafka Cluster<br/>CDC Topics"] -->|"9092/TCP or 9096/TCP<br/>SASL_SSL / SCRAM-SHA-512"| KafkaProcessor

    %% Operator management
    ModelRegistryOp["model-registry-operator"] -->|"manages Deployment<br/>sets init container image"| ModelCatalogDeploy["model-catalog Deployment<br/>ns: odh-model-registries"]
    DataImage -.->|"referenced by"| ModelCatalogDeploy

    %% Styling
    style DataImage fill:#4a90e2,stroke:#333,color:#fff
    style KafkaProcessor fill:#4a90e2,stroke:#333,color:#fff
    style EntityClassifier fill:#7ed321,stroke:#333
    style OverallAccuracy fill:#7ed321,stroke:#333
    style HardwareConfig fill:#7ed321,stroke:#333
    style Transforms fill:#7ed321,stroke:#333
    style BenchmarkData fill:#f5a623,stroke:#333
    style DataFiles fill:#f5a623,stroke:#333
    style SharedVolume fill:#f5a623,stroke:#333
    style KafkaBroker fill:#999,stroke:#333,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333
    style ModelRegistryOp fill:#7ed321,stroke:#333
    style ModelCatalogDeploy fill:#7ed321,stroke:#333
