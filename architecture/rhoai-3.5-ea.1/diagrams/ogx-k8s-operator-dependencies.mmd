graph LR
    OGX["OGX K8s Operator"]

    %% External Dependencies (required frameworks/libraries)
    OGX -->|"controller framework<br/>v0.22.4"| ControllerRuntime["controller-runtime"]
    OGX -->|"manifest rendering<br/>v0.21.0"| Kustomize["kustomize/api"]
    OGX -->|"image ref parsing<br/>v0.20.7"| GoContainerReg["go-containerregistry"]
    OGX -->|"metrics<br/>v1.22.0"| Prometheus["prometheus/client_golang"]
    OGX -.->|"webhook TLS<br/>(vanilla K8s only)"| CertManager["cert-manager"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| OGX
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -.->|"CA cert injection<br/>for managed pods"| OGX

    %% Infrastructure Dependencies
    OGX -->|"CR reconciliation<br/>resource CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    OGX -->|"webhook TLS cert<br/>(OpenShift)"| CertSigner["service-serving-<br/>cert-signer"]

    %% Managed Resources (operator creates these)
    OGX -->|"creates/manages"| OGXServer["OGX Server Pods<br/>(Deployment)"]

    %% OGX Server external integrations (user-configured)
    OGXServer -->|"inference<br/>HTTP/HTTPS"| vLLM["vLLM"]
    OGXServer -->|"inference<br/>HTTPS/443"| OpenAI["OpenAI API"]
    OGXServer -->|"inference<br/>HTTPS/443"| Azure["Azure OpenAI"]
    OGXServer -->|"inference<br/>HTTPS/443"| Bedrock["AWS Bedrock"]
    OGXServer -->|"inference<br/>HTTPS/443"| VertexAI["Google Vertex AI"]
    OGXServer -->|"inference<br/>HTTPS"| Watsonx["IBM watsonx"]
    OGXServer -->|"vector_io<br/>TCP"| PGVector["PGVector"]
    OGXServer -->|"vector_io<br/>HTTP/gRPC"| Milvus["Milvus"]
    OGXServer -->|"vector_io<br/>HTTP/gRPC"| Qdrant["Qdrant"]
    OGXServer -->|"files<br/>HTTPS/443"| S3["S3 Storage"]

    %% Metrics integration
    PromScrape["Prometheus /<br/>ServiceMonitor"] -->|"metrics scrape<br/>HTTPS/8443"| OGX

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OGXServer fill:#d5e8d4,stroke:#82b366,stroke-width:2px

