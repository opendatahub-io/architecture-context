graph TB
    subgraph "model-metadata-collection"
        direction TB

        subgraph "Build-Time Tools"
            Extractor["model-extractor<br/>(Go CLI)"]
            Report["metadata-report<br/>(Go CLI)"]
        end

        subgraph "Shippable Artifact"
            DataContainer["Data Container<br/>(UBI9-minimal)<br/>sleep infinity"]
            CatalogData["/app/data/*.yaml<br/>Model & MCP Catalogs"]
            BenchmarkData["/app/benchmarks/<br/>Sample Benchmark Data"]
            DataContainer --- CatalogData
            DataContainer --- BenchmarkData
        end
    end

    subgraph "Input Files"
        ModelsIndex["models-index.yaml"]
        MCPIndex["mcp-servers-index.yaml"]
        VLLMConfigs["vllm-config/*.yaml"]
        SupplementalCatalog["supplemental-catalog.yaml"]
        MCPInputs["input/mcp_servers/*.yaml<br/>(Red Hat, Partner, Community)"]
    end

    subgraph "External Registries"
        RedHatRegistry["registry.redhat.io<br/>443/TCP HTTPS"]
        AccessRegistry["registry.access.redhat.com<br/>443/TCP HTTPS"]
        QuayRegistry["quay.io<br/>443/TCP HTTPS"]
    end

    subgraph "Enrichment Sources"
        HuggingFaceAPI["HuggingFace API<br/>443/TCP HTTPS"]
        HuggingFaceCollections["HuggingFace Collections<br/>443/TCP HTTPS"]
    end

    subgraph "Consumers"
        Dashboard["RHOAI Dashboard<br/>(Volume Mount)"]
    end

    %% Build-time flows
    ModelsIndex -->|input| Extractor
    MCPIndex -->|input| Extractor
    VLLMConfigs -->|input| Extractor
    SupplementalCatalog -->|input| Extractor
    MCPInputs -->|input| Extractor

    Extractor -->|fetch manifests & layers| RedHatRegistry
    Extractor -->|fetch MCP images| AccessRegistry
    Extractor -->|fetch architectures| QuayRegistry
    Extractor -->|enrich metadata| HuggingFaceAPI
    Extractor -->|discover collections| HuggingFaceCollections

    Extractor -->|generates| CatalogData
    CatalogData -->|analyzed by| Report

    %% Runtime flow
    Dashboard -->|reads /app/data/| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Report fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style CatalogData fill:#b8e986,stroke:#333
    style BenchmarkData fill:#b8e986,stroke:#333
    style Dashboard fill:#f5a623,stroke:#333,color:#fff
    style RedHatRegistry fill:#e8e8e8,stroke:#333
    style AccessRegistry fill:#e8e8e8,stroke:#333
    style QuayRegistry fill:#e8e8e8,stroke:#333
    style HuggingFaceAPI fill:#e8e8e8,stroke:#333
    style HuggingFaceCollections fill:#e8e8e8,stroke:#333
