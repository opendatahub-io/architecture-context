graph TB
    subgraph InternalCallers["INTERNAL CALLERS (Platform Services)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Guardrails Pipeline Controller"]
    end

    subgraph ServiceZone["SERVICE ZONE (No TLS, No Auth)"]
        direction TB
        Detector["guardrails-regex-detector<br/>Rust/axum HTTP Service<br/>Port: 8080/TCP<br/>Protocol: HTTP (plaintext)<br/>Auth: None<br/>User: root ⚠"]

        subgraph Endpoints["Exposed Endpoints"]
            Health["GET /health"]
            Detection["POST /api/v1/text/contents"]
        end

        Detector --- Health
        Detector --- Detection
    end

    subgraph SecurityNotes["SECURITY NOTES"]
        direction TB
        Note1["⚠ No TLS at application level"]
        Note2["⚠ No authentication enforced"]
        Note3["⚠ Container runs as root"]
        Note4["✓ Rust regex crate: linear-time<br/>matching (no ReDoS risk)"]
        Note5["✓ Zero egress (no outbound calls)"]
        Note6["✓ Fully stateless (no data persistence)"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>Plaintext<br/>No Auth<br/>POST /api/v1/text/contents"| Detector

    %% No egress from detector

    %% Styling
    classDef internalCaller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef endpoint fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Orchestrator internalCaller
    class Detector service
    class Health,Detection endpoint
    class Note1,Note2,Note3,Note4,Note5,Note6 warning
