graph LR
    MRO["Model Registry Operator<br/>(controller-runtime)"]

    %% External Dependencies (Required)
    MRO -->|"controller framework"| CR["controller-runtime<br/>v0.23.3"]
    MRO -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.35.4"]
    MRO -->|"resource diff/patch"| ObjMatcher["k8s-objectmatcher<br/>v1.8.0"]

    %% External Dependencies (Conditional)
    MRO -.->|"Route, User, Config APIs<br/>(OpenShift only)"| OSApi["openshift/api<br/>v0.0.0-20260320"]
    MRO -.->|"scheme registration<br/>(conditional)"| IstioClient["istio.io/client-go<br/>v1.29.2"]
    MRO -.->|"metadata storage<br/>(optional auto-provision)"| PostgreSQL["PostgreSQL 16"]

    %% Internal Platform Dependencies
    MRO -->|"catalog owner ref"| PlatformMR["components.platform<br/>.opendatahub.io<br/>ModelRegistry"]
    MRO -->|"admin groups<br/>for catalog RBAC"| AuthCR["services.platform<br/>.opendatahub.io<br/>Auth"]
    MRO -->|"cluster ingress domain<br/>for Route hostnames"| IngressConfig["config.openshift.io<br/>Ingress"]

    %% Container Image Dependencies
    MRO -->|"REST server image"| RESTImage["model-registry<br/>(rest-container)"]
    MRO -->|"auth sidecar image"| KRBPImage["kube-rbac-proxy<br/>(sidecar)"]
    MRO -->|"catalog data<br/>init container"| CatalogData["odh-model-metadata<br/>-collection"]

    %% Integration Points (Consumed by others)
    Dashboard["ODH Dashboard"] -->|"UI management"| MRO
    Pipelines["Data Science Pipelines"] -.->|"model deployment"| MRO

    %% Runtime Dependencies
    MRO -->|"CRUD on managed resources<br/>watches, webhooks, SAR"| K8sAPIServer["Kubernetes API Server"]
    MRO -->|"CRD version migration"| MigrationAPI["migration.k8s.io<br/>StorageVersionMigration"]
    MRO -->|"CRD introspection"| ApiExtensions["apiextensions.k8s.io<br/>CRD"]

    %% External Database Options
    RESTImage -->|"metadata storage"| ExtPostgres["External PostgreSQL<br/>5432/TCP"]
    RESTImage -->|"metadata storage<br/>(alternative)"| ExtMySQL["External MySQL<br/>3306/TCP"]

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style CR fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style ObjMatcher fill:#999,stroke:#333

    %% Conditional external deps
    style OSApi fill:#bbb,stroke:#333,stroke-dasharray:5
    style IstioClient fill:#bbb,stroke:#333,stroke-dasharray:5
    style PostgreSQL fill:#bbb,stroke:#333,stroke-dasharray:5

    %% Internal ODH deps
    style PlatformMR fill:#7ed321,stroke:#333
    style AuthCR fill:#7ed321,stroke:#333
    style IngressConfig fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333,stroke-dasharray:5

    %% Image deps
    style RESTImage fill:#dae8fc,stroke:#6c8ebf
    style KRBPImage fill:#dae8fc,stroke:#6c8ebf
    style CatalogData fill:#dae8fc,stroke:#6c8ebf

    %% Runtime/API deps
    style K8sAPIServer fill:#e8e8e8,stroke:#333
    style MigrationAPI fill:#e8e8e8,stroke:#333
    style ApiExtensions fill:#e8e8e8,stroke:#333

    %% External services
    style ExtPostgres fill:#f5a623,stroke:#333
    style ExtMySQL fill:#f5a623,stroke:#333
