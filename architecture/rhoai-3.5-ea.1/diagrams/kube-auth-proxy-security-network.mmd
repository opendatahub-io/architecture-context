graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Browser /<br/>External Client"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (Pod-level)"]
        direction TB

        subgraph Entrypoint["Container: rhoai/odh-kube-auth-proxy-rhel9<br/>FIPS: strictfipsruntime + CGO_ENABLED=1"]
            direction LR

            subgraph AuthModeBox["Auth Mode"]
                AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP/HTTPS<br/>TLS 1.2-1.3<br/>AES-CFB/GCM sessions<br/>HMAC-SHA256 signing"]
            end

            subgraph RBACModeBox["RBAC Mode (default)"]
                RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2-1.3<br/>Auto-generated certs"]
            end
        end

        subgraph UpstreamBox["Same Pod"]
            Upstream["Upstream Application<br/>Configurable port<br/>HTTP/HTTPS/H2C<br/>No auth (post-auth)"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES (Trusted - Internal)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]

        UserAPI["OpenShift User API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]

        Prometheus["OpenShift Monitoring<br/>(Prometheus)<br/>SA: prometheus-k8s<br/>Hardcoded allowlist"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        direction TB

        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client ID/Secret"]

        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password Auth"]
    end

    %% Client flows
    Client -->|"HTTP/HTTPS 4180/TCP<br/>TLS 1.2+ (configurable)<br/>OIDC/OAuth/JWT/K8s Token"| AuthProxy
    Client -->|"HTTPS 8443/TCP<br/>TLS 1.2+<br/>Bearer/Client Cert"| RBACProxy

    %% Proxy to upstream
    AuthProxy -->|"HTTP/HTTPS<br/>Post-auth<br/>X-Forwarded-* headers"| Upstream
    RBACProxy -->|"HTTP/HTTPS/H2C<br/>Post-authz"| Upstream

    %% Auth mode egress
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client ID/Secret"| OIDC
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| UserAPI
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview"| K8sAPI
    AuthProxy -.->|"TCP/TLS 6379<br/>Password<br/>Sessions + Locks"| Redis

    %% RBAC mode egress
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR"| K8sAPI

    %% Monitoring
    Prometheus -.->|"Metrics scraping<br/>Hardcoded SA allowlist"| RBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    classDef authmode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef rbacmode fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef upstream fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class AuthProxy authmode
    class RBACProxy rbacmode
    class K8sAPI,OAuthServer,UserAPI,Prometheus cluster
    class OIDC,Redis extsvc
    class Upstream upstream
