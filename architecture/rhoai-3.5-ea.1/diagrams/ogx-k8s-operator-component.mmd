graph TB
    subgraph OGXOperator["OGX K8s Operator"]
        direction TB
        Controller["OGX Controller<br/>(controller-runtime)<br/>Reconciles OGXServer CRs"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS<br/>Validates OGXServer create/update"]
        AdoptionReconciler["Legacy Adoption Reconciler<br/>Migrates LlamaStackDistribution<br/>to OGXServer"]
        KustomizeEngine["Kustomize Render Engine<br/>In-process manifest rendering<br/>with transformer plugins"]
        NetworkPolicyPlugin["NetworkPolicy Transformer<br/>Default ingress rules +<br/>user overrides"]

        Controller --> KustomizeEngine
        Controller --> AdoptionReconciler
        Controller -->|registers| Webhook
        KustomizeEngine --> NetworkPolicyPlugin
    end

    %% CRDs
    User[Data Scientist / Admin] -->|creates| OGXServerCR["OGXServer CR<br/>(ogx.io/v1beta1)"]
    OGXServerCR -->|watched by| Controller
    LegacyCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)<br/>deprecated"] -.->|adopted by| AdoptionReconciler

    %% Managed Resources
    Controller -->|creates/manages| ManagedDeployment["Deployment<br/>(OGX Server pods)"]
    Controller -->|creates/manages| ManagedService["Service<br/>{instance}-service<br/>8321/TCP"]
    Controller -->|creates/manages| ManagedPVC["PersistentVolumeClaim"]
    Controller -->|creates/manages| ManagedNetPol["NetworkPolicy"]
    Controller -->|creates/manages| ManagedIngress["Ingress<br/>(optional)"]
    Controller -->|creates/manages| ManagedHPA["HorizontalPodAutoscaler"]
    Controller -->|creates/manages| ManagedPDB["PodDisruptionBudget"]
    Controller -->|creates/manages| ManagedSA["ServiceAccount +<br/>RoleBinding"]

    %% Health checks
    Controller -->|/v1/health<br/>/v1/version<br/>/v1/providers| ManagedDeployment

    %% Platform Integration
    PlatformOperator["rhods-operator /<br/>opendatahub-operator"] -->|deploys via kustomize| OGXOperator
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -.->|watched| Controller

    %% Webhook validation flow
    OGXServerCR -->|admission review| Webhook

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style AdoptionReconciler fill:#4a90e2,color:#fff
    style KustomizeEngine fill:#4a90e2,color:#fff
    style NetworkPolicyPlugin fill:#4a90e2,color:#fff
    style OGXServerCR fill:#f5a623,color:#fff
    style LegacyCR fill:#d0d0d0,color:#333
    style ManagedDeployment fill:#7ed321,color:#fff
    style ManagedService fill:#7ed321,color:#fff
    style ManagedPVC fill:#7ed321,color:#fff
    style ManagedNetPol fill:#7ed321,color:#fff
    style ManagedIngress fill:#7ed321,color:#fff
    style ManagedHPA fill:#7ed321,color:#fff
    style ManagedPDB fill:#7ed321,color:#fff
    style ManagedSA fill:#7ed321,color:#fff
    style PlatformOperator fill:#e8e8e8,color:#333
    style CABundle fill:#e8e8e8,color:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
