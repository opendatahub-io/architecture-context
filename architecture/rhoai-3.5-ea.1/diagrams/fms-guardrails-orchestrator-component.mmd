graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        direction TB
        subgraph MainAPI["Main API Server (Port 8033)"]
            direction LR
            V1Routes["v1 API Routes<br/>/api/v1/task/*"]
            V2DetRoutes["v2 Detection Routes<br/>/api/v2/text/detection/*"]
            V2GenRoutes["v2 Generation Routes<br/>/api/v2/text/generation-detection<br/>/api/v2/chat/completions-detection<br/>/api/v2/text/completions-detection"]
        end

        subgraph OrchEngine["Orchestration Engine"]
            direction LR
            Handlers["Handler Dispatch<br/>(Handle&lt;Task&gt; trait)"]
            Batcher["DetectionBatcherManager<br/>(actor pattern, mpsc channels)"]
            CompBatcher["CompletionBatcher /<br/>MaxProcessedIndexBatcher"]
        end

        subgraph HealthSrv["Health Server (Port 8034)"]
            HealthEP["/health endpoint"]
            InfoEP["/info endpoint"]
        end

        TLSLayer["TLS Layer<br/>rustls + ring<br/>Optional TLS/mTLS"]
    end

    Client[External Client] -->|"HTTP/HTTPS<br/>8033/TCP"| TLSLayer
    TLSLayer --> MainAPI
    MainAPI --> OrchEngine
    Handlers --> Batcher
    Batcher --> CompBatcher

    Probe[Health Probes] -->|"HTTP 8034/TCP"| HealthSrv

    subgraph GenBackends["Generation Backends"]
        TGIS["TGIS Server<br/>gRPC 8033/TCP"]
        CaikitNLP["caikit-NLP Server<br/>gRPC 8085/TCP"]
        OpenAISrv["OpenAI-compatible Server<br/>HTTP 8080/TCP"]
    end

    subgraph SafetyServices["Safety Services"]
        Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>HTTP 8080/TCP"]
        Chunkers["Chunker Services<br/>(caikit)<br/>gRPC 8085/TCP"]
    end

    subgraph Observability["Observability"]
        OTELCollector["OTLP Collector<br/>gRPC 4317/TCP<br/>HTTP 4318/TCP"]
    end

    OrchEngine -->|"gRPC<br/>Optional TLS/mTLS"| TGIS
    OrchEngine -->|"gRPC<br/>Optional TLS/mTLS"| CaikitNLP
    OrchEngine -->|"HTTP/HTTPS<br/>Optional Bearer"| OpenAISrv
    OrchEngine -->|"HTTP/HTTPS<br/>Optional TLS/mTLS"| Detectors
    OrchEngine -->|"gRPC<br/>Optional TLS/mTLS"| Chunkers
    Orchestrator -->|"OTLP traces/metrics"| OTELCollector
    HealthSrv -->|"gRPC Health.Check"| GenBackends
    HealthSrv -->|"GET /health"| SafetyServices

    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MainAPI fill:#5b9bd5,stroke:#333,color:#fff
    style OrchEngine fill:#5b9bd5,stroke:#333,color:#fff
    style HealthSrv fill:#5b9bd5,stroke:#333,color:#fff
    style TLSLayer fill:#2e75b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Probe fill:#f9f9f9,stroke:#999,stroke-width:2px
    style TGIS fill:#999,stroke:#333,color:#fff
    style CaikitNLP fill:#999,stroke:#333,color:#fff
    style OpenAISrv fill:#999,stroke:#333,color:#fff
    style Detectors fill:#f5a623,stroke:#333
    style Chunkers fill:#f5a623,stroke:#333
    style OTELCollector fill:#7ed321,stroke:#333
