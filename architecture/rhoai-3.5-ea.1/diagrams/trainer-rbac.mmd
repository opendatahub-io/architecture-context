graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>(namespace: opendatahub)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-wide)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        subgraph TrainerAPIs["trainer.kubeflow.org"]
            TrainJobs["trainjobs<br/>get, list, watch, update, patch"]
            TrainJobStatus["trainjobs/status<br/>trainjobs/finalizers<br/>get, update, patch"]
            TrainingRuntimes["trainingruntimes<br/>get, list, watch, update, patch"]
            RuntimeFinalizers["trainingruntimes/finalizers<br/>clustertrainingruntimes/finalizers<br/>get, update, patch"]
            ClusterRuntimes["clustertrainingruntimes<br/>get, list, watch, update, patch"]
        end

        subgraph JobSetAPIs["jobset.x-k8s.io"]
            JobSets["jobsets<br/>create, get, list, watch, update, patch"]
        end

        subgraph SchedulingAPIs["scheduling.volcano.sh<br/>scheduling.x-k8s.io"]
            PodGroups["podgroups<br/>create, get, list, watch, update, patch"]
        end

        subgraph CoreAPIs["core ('')"]
            ConfigMapsSecrets["configmaps, secrets<br/>create, get, list, watch, update, patch"]
            Events["events<br/>create, watch, update, patch"]
            LimitRanges["limitranges<br/>get, list, watch"]
            Pods["pods (RHAI)<br/>get, list"]
        end

        subgraph NetworkAPIs["networking.k8s.io"]
            NetworkPolicies["networkpolicies (RHAI)<br/>get, list, watch, create, update, patch"]
        end

        subgraph AdminAPIs["admissionregistration.k8s.io"]
            Webhooks["validatingwebhookconfigurations<br/>get, list, watch, update"]
        end

        subgraph CoordAPIs["coordination.k8s.io"]
            Leases["leases<br/>create, get, list, update"]
        end

        subgraph NodeAPIs["node.k8s.io"]
            RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        end
    end

    subgraph AggregateRoles["Aggregate ClusterRoles (User-Facing)"]
        direction LR
        EditRole["training-edit<br/>trainjobs: full CRUD<br/>runtimes: read-only"]
        AdminRole["training-admin<br/>all trainer resources: full CRUD"]
        ViewRole["training-view<br/>all trainer resources: read-only"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| ControllerRole

    SA -.->|"used by controller pod"| ControllerPod["Controller Pod<br/>kubeflow-trainer-controller-manager"]

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#5b9bd5,color:#fff
    style TrainJobs fill:#7ed321,color:#fff
    style TrainJobStatus fill:#7ed321,color:#fff
    style TrainingRuntimes fill:#7ed321,color:#fff
    style RuntimeFinalizers fill:#7ed321,color:#fff
    style ClusterRuntimes fill:#7ed321,color:#fff
    style JobSets fill:#f5a623,color:#fff
    style PodGroups fill:#f5a623,color:#fff
    style ConfigMapsSecrets fill:#dae8fc
    style Events fill:#dae8fc
    style LimitRanges fill:#dae8fc
    style Pods fill:#ed7d31,color:#fff
    style NetworkPolicies fill:#ed7d31,color:#fff
    style Webhooks fill:#e1d5e7
    style Leases fill:#e1d5e7
    style RuntimeClasses fill:#e1d5e7
    style EditRole fill:#fff2cc,stroke:#d6b656
    style AdminRole fill:#fff2cc,stroke:#d6b656
    style ViewRole fill:#fff2cc,stroke:#d6b656
    style ControllerPod fill:#4a90e2,color:#fff
