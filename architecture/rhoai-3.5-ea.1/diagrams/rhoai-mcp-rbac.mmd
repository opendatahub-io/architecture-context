graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["rhoai-mcp<br/>Namespace: rhoai-mcp"]
    end

    subgraph Bindings["ClusterRoleBinding"]
        CRB["rhoai-mcp<br/>(cluster-wide)"]
    end

    subgraph ClusterRole["ClusterRole: rhoai-mcp"]
        CR["rhoai-mcp"]
    end

    subgraph CoreResources["Core API Resources (read-only)"]
        Namespaces["core/v1<br/>Namespaces"]
        Pods["core/v1<br/>Pods"]
        PodsLog["core/v1<br/>Pods/log"]
        Services["core/v1<br/>Services"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
        Secrets["core/v1<br/>Secrets"]
        PVCs["core/v1<br/>PersistentVolumeClaims"]
        Events["core/v1<br/>Events"]
    end

    subgraph KubeflowResources["Kubeflow Resources (full CRUD)"]
        Notebooks["kubeflow.org<br/>Notebooks"]
        Profiles["kubeflow.org<br/>Profiles"]
    end

    subgraph TektonResources["Tekton Resources (full CRUD)"]
        PipelineRuns["tekton.dev<br/>PipelineRuns"]
        TaskRuns["tekton.dev<br/>TaskRuns"]
        Pipelines["tekton.dev<br/>Pipelines"]
        Tasks["tekton.dev<br/>Tasks"]
    end

    subgraph ServingResources["Serving Resources (full CRUD)"]
        InferenceServices["serving.kserve.io<br/>InferenceServices"]
        ServingRuntimes["serving.kserve.io<br/>ServingRuntimes"]
        OVMS["serving.openvino.ai<br/>OVMS"]
    end

    subgraph ODHResources["ODH Resources (read-only)"]
        DSC["opendatahub.io<br/>DataScienceClusters"]
        DSPA["opendatahub.io<br/>DSPApplications"]
    end

    subgraph StorageResources["Storage Resources (full CRUD)"]
        OBC["objectbucket.io<br/>ObjectBucketClaims"]
    end

    subgraph OpenShiftResources["OpenShift Resources (read-only)"]
        Routes["route.openshift.io<br/>Routes"]
        Projects["project.openshift.io<br/>Projects"]
    end

    %% Binding chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Read-only permissions
    CR -->|"get, list, watch"| Namespaces
    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| PodsLog
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, watch"| ConfigMaps
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| PVCs
    CR -->|"get, list, watch"| Events

    %% Full CRUD permissions
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Notebooks
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Profiles
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| PipelineRuns
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| TaskRuns
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Pipelines
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Tasks
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| InferenceServices
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| ServingRuntimes
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| OVMS
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| OBC

    %% Read-only ODH
    CR -->|"get, list, watch"| DSC
    CR -->|"get, list, watch"| DSPA

    %% Read-only OpenShift
    CR -->|"get, list, watch"| Routes
    CR -->|"get, list, watch"| Projects

    %% Styles
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#6366f1,color:#fff
    style CR fill:#f59e0b,color:#fff

    style Namespaces fill:#e5e7eb
    style Pods fill:#e5e7eb
    style PodsLog fill:#e5e7eb
    style Services fill:#e5e7eb
    style ConfigMaps fill:#e5e7eb
    style Secrets fill:#e5e7eb
    style PVCs fill:#e5e7eb
    style Events fill:#e5e7eb

    style Notebooks fill:#7ed321,color:#fff
    style Profiles fill:#7ed321,color:#fff
    style PipelineRuns fill:#7ed321,color:#fff
    style TaskRuns fill:#7ed321,color:#fff
    style Pipelines fill:#7ed321,color:#fff
    style Tasks fill:#7ed321,color:#fff
    style InferenceServices fill:#7ed321,color:#fff
    style ServingRuntimes fill:#7ed321,color:#fff
    style OVMS fill:#7ed321,color:#fff
    style OBC fill:#7ed321,color:#fff

    style DSC fill:#fbbf24
    style DSPA fill:#fbbf24

    style Routes fill:#fb923c
    style Projects fill:#fb923c
