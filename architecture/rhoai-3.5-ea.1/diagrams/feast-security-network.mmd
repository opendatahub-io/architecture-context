graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>ML Application"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        RouteOnline["feast-{name}-online Route<br/>443/TCP HTTPS<br/>TLS Edge/Passthrough"]
        RouteRegistry["feast-{name}-registry Route<br/>443/TCP HTTPS<br/>TLS Edge/Passthrough"]
        RouteUI["feast-{name}-ui Route<br/>443/TCP HTTPS<br/>TLS Edge/Passthrough"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["feast-operator<br/>SA: controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP HTTPS"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OnlineSvc["feast-{name}-online<br/>ClusterIP 80|443→6566/TCP<br/>TLS (service serving certs)<br/>Auth: Bearer Token (JWT)"]
            OfflineSvc["feast-{name}-offline<br/>ClusterIP 80|443→6566/TCP<br/>Auth: Bearer Token (JWT)"]
            RegistrySvc["feast-{name}-registry<br/>ClusterIP 80|443→6566/TCP<br/>Auth: Bearer Token (JWT)"]
            UISvc["feast-{name}-ui<br/>ClusterIP 80|443→8888/TCP<br/>Auth: None"]
            MetricsSvc["Prometheus Metrics<br/>8000/TCP HTTP<br/>Auth: None"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        OpenShiftAPI["OpenShift API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        OIDC["OIDC Provider<br/>(Keycloak / Azure AD)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalStores["EXTERNAL DATA STORES"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Password Auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/Password"]
        DynamoDB["DynamoDB (AWS)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        S3["S3 (AWS)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["GCS (GCP)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth/Password"]
        BigQuery["BigQuery (GCP)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token (JWT)"| RouteOnline
    Client -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| RouteRegistry
    Client -->|"HTTPS/443<br/>TLS edge"| RouteUI

    %% Ingress to Services
    RouteOnline -->|"HTTP(S)/80|443<br/>TLS (service certs)"| OnlineSvc
    RouteRegistry -->|"HTTP(S)/80|443<br/>TLS (service certs)"| RegistrySvc
    RouteUI -->|"HTTP(S)/80|443"| UISvc

    %% Operator to Services
    Operator -->|"HTTP(S)/80|443<br/>TLS InsecureSkipVerify<br/>Intra-comm JWT (HMAC-SHA256)"| RegistrySvc

    %% Operator to Platform
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OpenShiftAPI

    %% Feature Server to Auth
    OnlineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS validation"| OIDC
    OnlineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>TokenReview"| K8sAPI

    %% Feature Server to Stores
    OnlineSvc -->|"Redis/6379<br/>TLS optional<br/>Password"| Redis
    OnlineSvc -->|"PG/5432<br/>TLS optional<br/>User/Pass"| PostgreSQL
    OnlineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| DynamoDB
    OfflineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Snowflake
    OfflineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| BigQuery
    RegistrySvc -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RegistrySvc -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datastore fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RouteOnline,RouteRegistry,RouteUI ingress
    class Operator,OnlineSvc,OfflineSvc,RegistrySvc,UISvc,MetricsSvc cluster
    class K8sAPI,OpenShiftAPI,OIDC platform
    class Redis,PostgreSQL,DynamoDB,S3,GCS,Snowflake,BigQuery datastore
