graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AuthProxy["AUTH PROXY (Trust Boundary)"]
        KubeProxy["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.2+<br/>K8s RBAC (SubjectAccessReview)"]
    end

    subgraph Pod["APPLICATION POD (UID: 2000, non-root)"]
        direction TB

        subgraph AppContainer["Container: odh-vllm-gaudi-rhel9"]
            vLLM["vLLM API Server<br/>8000/TCP HTTP (no TLS)<br/>Endpoints: /v1/completions,<br/>/v1/chat/completions,<br/>/v1/embeddings, /v1/models,<br/>/health, /version"]
            Plugin["vllm-gaudi Plugin<br/>HPU Platform | Attention Backends<br/>Quantization (FP8/GPTQ/AWQ/INC)"]
            SynapseAI["Habana Synapse AI 1.23.0<br/>+ PyTorch 2.9.0"]
        end
    end

    subgraph Distributed["DISTRIBUTED INFERENCE (Inter-Pod/Card)"]
        direction TB
        Ray["Ray Runtime<br/>No encryption<br/>Ray cluster auth"]
        HCCL["HCCL Fabric<br/>No encryption<br/>Collective ops<br/>(all-reduce, all-gather)"]
        NIXL["NIXL Transfer (optional)<br/>No encryption<br/>KV cache prefill↔decode"]
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF Token"]
        ModelStore["Model Storage<br/>S3 / PVC<br/>443/TCP HTTPS (S3)<br/>Auth: IAM / None"]
    end

    subgraph BuildTimeOnly["BUILD-TIME ONLY"]
        Habana["vault.habana.ai<br/>443/TCP HTTPS<br/>RPMs & PyTorch"]
        PyPI["pypi.org<br/>443/TCP HTTPS<br/>Python packages"]
    end

    subgraph Hardware["HARDWARE"]
        Gaudi["Intel Gaudi 2/3<br/>HPU Accelerator"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (RBAC)"| KubeProxy
    KubeProxy -->|"HTTP/8000<br/>localhost (no TLS)<br/>Pre-authenticated"| vLLM
    vLLM --> Plugin
    Plugin --> SynapseAI
    SynapseAI -->|"In-process<br/>Device calls"| Gaudi

    vLLM -->|"Multi-worker init"| Ray
    Ray -->|"HCCL backend"| HCCL
    vLLM -.->|"Disaggregated<br/>serving"| NIXL

    vLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub
    vLLM -->|"HTTPS/443 or<br/>filesystem<br/>IAM / None"| ModelStore

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authproxy fill:#e6ccff,stroke:#8a2be2,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef distributed fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef buildtime fill:#f0f0f0,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5
    classDef hardware fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class KubeProxy authproxy
    class vLLM,Plugin,SynapseAI app
    class Ray,HCCL,NIXL distributed
    class HFHub,ModelStore egress
    class Habana,PyPI buildtime
    class Gaudi hardware
