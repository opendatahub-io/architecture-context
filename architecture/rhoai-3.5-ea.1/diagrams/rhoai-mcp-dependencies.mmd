graph LR
    RHOAIMCP["RHOAI MCP Server<br/>(Python / FastMCP)"]

    %% External Runtime Dependencies
    subgraph ExtDeps["External Dependencies"]
        FastMCP["mcp / FastMCP<br/>>=1.0.0"]
        K8sClient["kubernetes-python<br/>>=28.1.0"]
        Pydantic["pydantic<br/>>=2.0.0"]
        PydanticSettings["pydantic-settings<br/>>=2.0.0"]
        HTTPX["httpx<br/>>=0.27.0"]
        Pluggy["pluggy<br/>>=1.4.0"]
        UV["uv<br/>(package manager)"]
    end

    %% Optional CLI Dependencies
    subgraph CLIDeps["CLI Dependencies (optional)"]
        HelmCLI["Helm CLI<br/>v3.18.0"]
        OC["oc CLI<br/>stable-4.18"]
        GitCLI["git"]
    end

    %% Internal RHOAI Dependencies (via K8s API)
    subgraph InternalDeps["Internal RHOAI Dependencies"]
        KServeCtrl["KServe Controller<br/>(InferenceService, ServingRuntime)"]
        NotebookCtrl["Kubeflow Notebook Controller<br/>(Notebook CR)"]
        TrainingOp["Kubeflow Training Operator<br/>(TrainJob, ClusterTrainingRuntime)"]
        DSPOp["DS Pipelines Operator<br/>(DSPA CR)"]
        DSC["DataScienceCluster CR<br/>(component status)"]
        DSCI["DSCInitialization CR<br/>(init state)"]
        AccProf["AcceleratorProfile CR<br/>(GPU profiles)"]
    end

    %% Internal RHOAI Services (via REST API)
    subgraph InternalSvcs["Internal RHOAI Services"]
        ModelRegSvc["Model Registry<br/>HTTP/8080 or HTTPS/8443"]
        ModelCatSvc["Model Catalog<br/>HTTP/8080"]
        NeuralNavSvc["Neural Navigator<br/>HTTP/8000"]
    end

    %% External Services (via HTTPS)
    subgraph ExternalSvcs["External Services"]
        K8sAPI["Kubernetes API Server<br/>HTTPS/6443"]
        HuggingFace["HuggingFace Hub<br/>HTTPS/443"]
        S3["S3 Object Store<br/>HTTPS/443"]
        GitRepos["Git Repositories<br/>HTTPS/443"]
        HelmRegs["Helm Registries<br/>HTTPS/443"]
    end

    %% Integration Points (consume MCP server resources)
    subgraph Consumers["Consumers"]
        Dashboard["RHOAI Dashboard<br/>(label/annotation convention)"]
    end

    %% Library dependencies
    RHOAIMCP -->|"MCP protocol"| FastMCP
    RHOAIMCP -->|"K8s API client"| K8sClient
    RHOAIMCP -->|"data validation"| Pydantic
    RHOAIMCP -->|"env config"| PydanticSettings
    RHOAIMCP -->|"async HTTP"| HTTPX
    RHOAIMCP -->|"plugin hooks"| Pluggy
    RHOAIMCP -->|"runtime"| UV

    %% CLI dependencies
    RHOAIMCP -.->|"quickstart deploy"| HelmCLI
    RHOAIMCP -.->|"port-forward, deploy"| OC
    RHOAIMCP -.->|"repo cloning"| GitCLI

    %% K8s API interactions
    RHOAIMCP -->|"CRD CRUD"| K8sAPI
    K8sAPI -->|"reconciles"| KServeCtrl
    K8sAPI -->|"reconciles"| NotebookCtrl
    K8sAPI -->|"reconciles"| TrainingOp
    K8sAPI -->|"reconciles"| DSPOp

    RHOAIMCP -->|"reads status"| DSC
    RHOAIMCP -->|"reads state"| DSCI
    RHOAIMCP -->|"reads profiles"| AccProf

    %% Service interactions
    RHOAIMCP -->|"REST API"| ModelRegSvc
    RHOAIMCP -->|"REST API"| ModelCatSvc
    RHOAIMCP -->|"REST API"| NeuralNavSvc

    %% External service interactions
    RHOAIMCP -->|"model downloads"| HuggingFace
    RHOAIMCP -->|"artifact storage"| S3
    RHOAIMCP -->|"quickstart repos"| GitRepos
    RHOAIMCP -->|"helm charts"| HelmRegs

    %% Convention-based integration
    Dashboard -.->|"reads labels/annotations"| RHOAIMCP

