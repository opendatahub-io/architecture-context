graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>Namespace: opendatahub"]
        SA_API["maas-api<br/>Namespace: opendatahub"]
        SA_Payload["payload-processing<br/>Namespace: openshift-ingress"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Controller["maas-controller-role-binding<br/>(cluster-wide)"]
        CRB_Config["maas-controller-cluster-<br/>config-role-binding<br/>(cluster-wide)"]
        CRB_Leader["maas-controller-leader-<br/>election-role-binding<br/>(opendatahub ns)"]
        CRB_API["maas-api<br/>(cluster-wide)"]
        CRB_API_Supp["maas-api-supplemental<br/>(cluster-wide)"]
        CRB_Payload["payload-processing-reader<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["maas-controller-role"]
        CR_Config["maas-controller-cluster-<br/>config-role"]
        CR_Leader["maas-controller-leader-<br/>election-role"]
        CR_API["maas-api"]
        CR_API_Supp["maas-api-supplemental"]
        CR_Payload["payload-processing-reader"]
        CR_Owner["maas-owner-role<br/>(aggregate: admin, edit)"]
        CR_Viewer["maas-viewer-role<br/>(aggregate: view, admin, edit)"]
    end

    subgraph MaaSResources["MaaS CRD Resources (maas.opendatahub.io)"]
        Configs["configs<br/>+ /status, /finalizers"]
        ExternalModels["externalmodels"]
        AuthPolicies["maasauthpolicies"]
        ModelRefs["maasmodelrefs"]
        Subscriptions["maassubscriptions"]
        Tenants["tenants<br/>+ /status, /finalizers"]
    end

    subgraph GatewayResources["Gateway API Resources"]
        Gateways["gateways<br/>+ /finalizers"]
        HTTPRoutes["httproutes<br/>+ /finalizers"]
    end

    subgraph KuadrantResources["Kuadrant Resources"]
        KAuthPolicies["authpolicies"]
        TokenRLP["tokenratelimitpolicies"]
        RLP["ratelimitpolicies"]
    end

    subgraph IstioResources["Istio Resources"]
        DestRules["destinationrules"]
        EnvoyFilters["envoyfilters"]
        ServiceEntries["serviceentries"]
    end

    subgraph K8sResources["Kubernetes Core Resources"]
        CoreResources["configmaps, secrets,<br/>services, namespaces,<br/>serviceaccounts, pods,<br/>endpoints, events"]
        Deployments["deployments<br/>+ /finalizers"]
        CronJobs["cronjobs"]
        NetworkPolicies["networkpolicies"]
        PodMonitors["podmonitors"]
        RBAC_Resources["clusterroles,<br/>clusterrolebindings"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["tokenreviews"]
        SAR["subjectaccessreviews"]
    end

    %% maas-controller bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Controller -->|"bound via"| CRB_Config
    SA_Controller -->|"bound via"| CRB_Leader
    CRB_Controller -->|"grants"| CR_Controller
    CRB_Config -->|"grants"| CR_Config
    CRB_Leader -->|"grants"| CR_Leader

    %% maas-controller permissions
    CR_Controller -->|"full CRUD"| MaaSResources
    CR_Controller -->|"get,list,watch,<br/>create,patch,delete"| GatewayResources
    CR_Controller -->|"full CRUD"| KuadrantResources
    CR_Controller -->|"full CRUD"| IstioResources
    CR_Controller -->|"varies"| K8sResources
    CR_Controller -->|"create"| AuthResources
    CR_Controller -->|"get,list,watch"| LLMISvc["serving.kserve.io<br/>llminferenceservices"]
    CR_Config -->|"full CRUD"| Configs

    %% maas-api bindings
    SA_API -->|"bound via"| CRB_API
    SA_API -->|"bound via"| CRB_API_Supp
    CRB_API -->|"grants"| CR_API
    CRB_API_Supp -->|"grants"| CR_API_Supp

    %% maas-api permissions
    CR_API -->|"get,list,watch"| ModelRefs
    CR_API -->|"get,list,watch"| Subscriptions
    CR_API -->|"get,list,watch"| HTTPRoutes
    CR_API -->|"get,list,watch,<br/>create,delete"| CoreResources
    CR_API -->|"create"| AuthResources

    %% payload-processing bindings
    SA_Payload -->|"bound via"| CRB_Payload
    CRB_Payload -->|"grants"| CR_Payload

    %% payload-processing permissions
    CR_Payload -->|"get,list,watch"| CoreResources
    CR_Payload -->|"get,list,watch"| ExternalModels

    %% Aggregate roles (for end users)
    CR_Owner -->|"full CRUD"| ModelRefs
    CR_Owner -->|"full CRUD"| ExternalModels
    CR_Viewer -->|"get,list,watch"| ModelRefs
    CR_Viewer -->|"get,list,watch"| ExternalModels

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef crb fill:#50e3c2,stroke:#333,stroke-width:1px,color:#333
    classDef cr fill:#f5a623,stroke:#333,stroke-width:1px,color:#fff
    classDef resource fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef authres fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    classDef aggregate fill:#f8e71c,stroke:#333,stroke-width:1px,color:#333

    class SA_Controller,SA_API,SA_Payload sa
    class CRB_Controller,CRB_Config,CRB_Leader,CRB_API,CRB_API_Supp,CRB_Payload crb
    class CR_Controller,CR_Config,CR_Leader,CR_API,CR_API_Supp,CR_Payload cr
    class CR_Owner,CR_Viewer aggregate
    class Configs,ExternalModels,AuthPolicies,ModelRefs,Subscriptions,Tenants resource
    class Gateways,HTTPRoutes,KAuthPolicies,TokenRLP,RLP resource
    class DestRules,EnvoyFilters,ServiceEntries resource
    class CoreResources,Deployments,CronJobs,NetworkPolicies,PodMonitors,RBAC_Resources resource
    class TokenReviews,SAR,LLMISvc authres
