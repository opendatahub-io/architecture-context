graph LR
    MPBD["models-perf-benchmark-data<br/>(Data Container + Kafka Processor)"]

    %% Internal RHOAI Dependencies
    MPBD -->|"init container in pod"| ModelCatalog["model-catalog<br/>(Model Registry)"]
    MPBD -.->|"image ref managed by"| ModelRegOp["model-registry-operator"]

    %% External Dependencies (kafka-processor only)
    MPBD -->|"CDC consumer<br/>9092/9096 TCP<br/>SASL_SSL"| KafkaCluster["Internal Kafka Cluster"]

    %% Python Library Dependencies (kafka-processor)
    subgraph "Python Dependencies (kafka-processor only)"
        ConfluentKafka["confluent-kafka<br/>>=2.11.1"]
        LZ4["lz4<br/>>=4.4.4"]
        PythonDotenv["python-dotenv<br/>>=1.1.1"]
        LibRdKafka["librdkafka<br/>(system package)"]
    end

    MPBD -->|"Kafka client"| ConfluentKafka
    MPBD -->|"decompression"| LZ4
    MPBD -->|"env loading"| PythonDotenv
    ConfluentKafka -->|"wraps"| LibRdKafka

    %% Build/Deploy Dependencies
    MPBD -->|"image pull<br/>5000/TCP HTTPS"| OCPRegistry["OpenShift Image Registry"]
    MPBD -->|"base image"| UBI9["UBI9-minimal<br/>(Base Image)"]

    %% Integration Points (consumers of this component)
    ModelCatalog -->|"reads benchmark data<br/>from shared volume"| MPBD

    %% Styling
    style MPBD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333
    style ModelRegOp fill:#7ed321,stroke:#333
    style KafkaCluster fill:#999,stroke:#333,color:#fff
    style ConfluentKafka fill:#e8e8e8,stroke:#333
    style LZ4 fill:#e8e8e8,stroke:#333
    style PythonDotenv fill:#e8e8e8,stroke:#333
    style LibRdKafka fill:#e8e8e8,stroke:#333
    style OCPRegistry fill:#f5a623,stroke:#333
    style UBI9 fill:#f5a623,stroke:#333
