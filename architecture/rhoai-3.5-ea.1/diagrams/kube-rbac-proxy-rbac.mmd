graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["Component ServiceAccount<br/>(inherits from parent Pod)"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
    end

    subgraph RBACBindings["ClusterRole Bindings"]
        CRB["ClusterRoleBinding<br/>(provisioned by rhods-operator)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["kube-rbac-proxy ClusterRole<br/>(minimum required)"]
    end

    subgraph APIResources["API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph HardcodedBypass["Hardcoded Authorization (No RBAC)"]
        MetricsAuth["Hardcoded Metrics Authorizer<br/>pkg/hardcodedauthorizer/metrics.go"]
        MetricsEndpoint["/metrics endpoint<br/>(GET only)"]
    end

    subgraph AuthzConfig["Authorization Configuration"]
        Format1["Format1: Top-level resourceAttributes<br/>+ query/header rewrites"]
        Format2["Format2: Path-scoped endpoint rules<br/>per-method resource mappings"]
    end

    subgraph ProtectedResources["Protected Resources (configurable per-component)"]
        ConfiguredResource["Configured API Group<br/>Configured Resource<br/>Configured Verbs<br/>(from --authorization-config)"]
    end

    %% RBAC flow for proxy's own permissions
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Hardcoded bypass
    PromSA -->|"auto-allowed<br/>(no SAR check)"| MetricsAuth
    MetricsAuth -->|"GET"| MetricsEndpoint

    %% Authorization config flow
    SA -.->|"uses config"| Format1
    SA -.->|"uses config"| Format2
    Format1 -->|"maps requests to"| ConfiguredResource
    Format2 -->|"maps requests to"| ConfiguredResource
    ConfiguredResource -->|"checked via"| SAR

    %% Provisioning
    Operator["rhods-operator"] -.->|"provisions<br/>RBAC rules"| CRB

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style PromSA fill:#e8a838,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style CRB fill:#f5c86e,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style MetricsAuth fill:#e8a838,stroke:#333,color:#fff
    style MetricsEndpoint fill:#7ed321,stroke:#333,color:#fff
    style Format1 fill:#d4a8e8,stroke:#333
    style Format2 fill:#d4a8e8,stroke:#333
    style ConfiguredResource fill:#b8d4e8,stroke:#333
    style Operator fill:#999,stroke:#333,color:#fff
