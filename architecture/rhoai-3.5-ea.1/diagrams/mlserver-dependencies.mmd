graph LR
    MLServer["MLServer<br/>v1.7.1+rhaiv.8<br/>Python Inference Server"]

    %% Internal RHOAI Dependencies
    MLServer -->|"deployed as container in<br/>InferenceService pods"| KServe["KServe<br/>Inference Platform"]
    MLServer -->|"model artifacts from<br/>/mnt/models"| ModelStorage["Model Storage<br/>PVC / S3"]

    %% Core Framework Dependencies
    MLServer -->|"REST API framework"| FastAPI["FastAPI<br/>>=0.88.0,<0.116.0"]
    MLServer -->|"ASGI HTTP server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC server"| gRPC["grpcio<br/>>=1.67.1"]
    MLServer -->|"protobuf serialization"| Protobuf["protobuf<br/>>=5.27.2,<7.0.0"]
    MLServer -->|"settings & validation"| Pydantic["pydantic<br/>^2.7.1"]

    %% ML Runtime Dependencies (RHOAI shipped)
    MLServer -->|"sklearn runtime"| ScikitLearn["scikit-learn"]
    MLServer -->|"xgboost runtime"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm runtime"| LightGBM["LightGBM"]
    MLServer -->|"onnx runtime"| ONNX["onnxruntime"]

    %% Observability Dependencies
    MLServer -->|"trace export"| OTEL["opentelemetry-sdk<br/>^1.22.0"]
    MLServer -->|"REST metrics"| StarletteExporter["starlette-exporter"]
    MLServer -->|"gRPC metrics"| GRPCPrometheus["py-grpc-prometheus"]

    %% Infrastructure Dependencies
    MLServer -->|"async Kafka"| Kafka["aiokafka"]
    MLServer -->|"event loop"| Uvloop["uvloop"]
    MLServer -->|"multiprocessing"| Gevent["gevent"]
    MLServer -->|"fast JSON"| Orjson["orjson"]

    %% Integration Points (other components → MLServer)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8082/TCP"| MLServer
    OTELCollector["OpenTelemetry Collector"] -.->|"receives traces<br/>4317/TCP gRPC"| OTEL
    KafkaBrokers["Kafka Brokers"] -.->|"async inference<br/>9092/TCP"| Kafka

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333,color:#fff

    %% Core frameworks
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style gRPC fill:#e8e8e8,stroke:#333
    style Protobuf fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333

    %% ML Runtimes
    style ScikitLearn fill:#f5a623,stroke:#333,color:#fff
    style XGBoost fill:#f5a623,stroke:#333,color:#fff
    style LightGBM fill:#f5a623,stroke:#333,color:#fff
    style ONNX fill:#f5a623,stroke:#333,color:#fff

    %% Observability
