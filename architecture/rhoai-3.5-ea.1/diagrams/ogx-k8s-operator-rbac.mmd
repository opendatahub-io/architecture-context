graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Instance["{instance}-rb<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Viewer["ogxserver-viewer-role"]
        CR_Editor["ogxserver-editor-role"]
        CR_Leader["leader-election-role<br/>(Role, not ClusterRole)"]
        CR_SCC["system:openshift:scc:anyuid<br/>(ClusterRole)"]
    end

    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB
        subgraph OGX_API["ogx.io"]
            OGXServers["ogxservers<br/>get, list, watch,<br/>create, update, patch, delete"]
            OGXStatus["ogxservers/status<br/>get, update, patch"]
            OGXFinalizers["ogxservers/finalizers<br/>update"]
        end

        subgraph Core_API["core ('')"]
            Services["services, serviceaccounts<br/>get, list, watch,<br/>create, update, patch, delete"]
            Pods["pods<br/>list"]
            ConfigMaps["configmaps,<br/>persistentvolumeclaims<br/>get, list, watch,<br/>create, update, patch"]
        end

        subgraph Apps_API["apps"]
            Deployments["deployments<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Networking_API["networking.k8s.io"]
            Ingresses["ingresses, networkpolicies<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Autoscaling_API["autoscaling"]
            HPAs["horizontalpodautoscalers<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Policy_API["policy"]
            PDBs["poddisruptionbudgets<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RBAC_API["rbac.authorization.k8s.io"]
            CRBs["clusterrolebindings<br/>get, list, delete"]
            CRs["clusterroles<br/>get, list, watch"]
            RBs["rolebindings<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph Security_API["security.openshift.io"]
            SCCs["securitycontextconstraints<br/>use"]
        end
    end

    subgraph ViewerPermissions["ogxserver-viewer-role Permissions"]
        ViewerOGX["ogx.io: ogxservers,<br/>ogxservers/status<br/>get, list, watch"]
    end

    subgraph EditorPermissions["ogxserver-editor-role Permissions"]
        EditorOGX["ogx.io: ogxservers,<br/>ogxservers/status<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| RB_Leader
    SA_Instance -->|"bound via"| RB_Instance

    CRB_Manager -->|"grants"| CR_Manager
    RB_Leader -->|"grants"| CR_Leader
    RB_Instance -->|"grants"| CR_SCC

    %% Permissions
    CR_Manager -->|"permissions"| ManagerPermissions
    CR_Viewer -->|"permissions"| ViewerPermissions
    CR_Editor -->|"permissions"| EditorPermissions

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_Viewer fill:#f5a623,color:#fff
    style CR_Editor fill:#f5a623,color:#fff
    style CR_Leader fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
    style CRB_Manager fill:#e8e8e8,color:#333
    style RB_Leader fill:#e8e8e8,color:#333
    style RB_Instance fill:#e8e8e8,color:#333

    style OGXServers fill:#7ed321,color:#fff
    style OGXStatus fill:#7ed321,color:#fff
    style OGXFinalizers fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style Ingresses fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style PDBs fill:#7ed321,color:#fff
    style CRBs fill:#7ed321,color:#fff
    style CRs fill:#7ed321,color:#fff
    style RBs fill:#7ed321,color:#fff
    style SCCs fill:#7ed321,color:#fff
    style ViewerOGX fill:#7ed321,color:#fff
    style EditorOGX fill:#7ed321,color:#fff
