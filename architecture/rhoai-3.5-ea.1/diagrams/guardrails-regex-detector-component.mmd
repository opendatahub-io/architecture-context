graph TB
    subgraph "guardrails-regex-detector Service"
        direction TB
        AxumServer["axum HTTP Server<br/>Port 8080/TCP"]

        subgraph "Endpoints"
            HealthEndpoint["GET /health<br/>Health Check"]
            DetectionEndpoint["POST /api/v1/text/contents<br/>PII & Regex Detection"]
        end

        subgraph "Detection Engine"
            BuiltIn["Built-in PII Detectors"]
            CustomRegex["Custom Regex Compiler"]
        end

        subgraph "Built-in Detectors"
            EmailDetector["email_address_detector<br/>Email Pattern"]
            SSNDetector["ssn_detector<br/>SSN Pattern"]
            CreditCardDetector["credit_card_detector<br/>Credit Card Pattern"]
        end

        AxumServer --> HealthEndpoint
        AxumServer --> DetectionEndpoint
        DetectionEndpoint --> BuiltIn
        DetectionEndpoint --> CustomRegex
        BuiltIn --> EmailDetector
        BuiltIn --> SSNDetector
        BuiltIn --> CreditCardDetector
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| AxumServer
    AxumServer -->|"JSON Response<br/>Match Results"| Orchestrator

    K8sProbe["Kubernetes<br/>Liveness/Readiness"] -.->|"GET /health<br/>HTTP 8080/TCP"| AxumServer

    style AxumServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style DetectionEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style EmailDetector fill:#7ed321,stroke:#333
    style SSNDetector fill:#7ed321,stroke:#333
    style CreditCardDetector fill:#7ed321,stroke:#333
    style BuiltIn fill:#f5a623,stroke:#333
    style CustomRegex fill:#f5a623,stroke:#333
    style Orchestrator fill:#9b59b6,stroke:#333,color:#fff
    style K8sProbe fill:#e8e8e8,stroke:#999
