graph TB
    subgraph MLMDComponent["ML Metadata (MLMD) gRPC Server"]
        direction TB
        ServerBinary["metadata_store_server<br/>(C++ gRPC Binary)<br/>Port: 8080/TCP"]
        ServiceImpl["MetadataStoreServiceImpl<br/>(gRPC Service Layer)<br/>Thread-safe request handling"]
        MetadataStore["MetadataStore Core<br/>(C++ Library)<br/>Schema, transactions, queries"]

        subgraph DBBackends["Database Backends"]
            SQLite["SQLite Adapter<br/>(embedded/in-memory)"]
            MySQL["MySQL/MariaDB Adapter<br/>(libmysqlclient)"]
            PostgreSQL["PostgreSQL Adapter<br/>(libpq)"]
        end

        subgraph ProtoLayer["Protocol Definitions"]
            ServiceProto["MetadataStoreService.proto<br/>(gRPC contract)"]
            StoreProto["metadata_store.proto<br/>(data model types)"]
            SourceProto["metadata_source.proto<br/>(query configs)"]
        end

        ServerBinary --> ServiceImpl
        ServiceImpl --> MetadataStore
        MetadataStore --> SQLite
        MetadataStore --> MySQL
        MetadataStore --> PostgreSQL
        ServiceProto -.->|defines API| ServiceImpl
        StoreProto -.->|defines types| MetadataStore
        SourceProto -.->|defines queries| MetadataStore
    end

    subgraph PythonLib["ml-metadata Python Library"]
        PyClient["Python Client<br/>(pybind11 bindings)"]
        PyGRPC["gRPC Client Mode<br/>(grpcio)"]
        PyDirect["Direct DB Mode<br/>(C++ bindings)"]
        PyClient --> PyGRPC
        PyClient --> PyDirect
    end

    %% External Consumers
    KFP["Kubeflow Pipelines SDK"] -->|gRPC/8080| ServerBinary
    DSP["Data Science Pipelines"] -->|gRPC/8080| ServerBinary
    PipelineUI["Pipeline UI Components"] -->|gRPC/8080| ServerBinary
    TFX["TFX Components"] -->|gRPC/8080| ServerBinary
    PyGRPC -->|gRPC/8080| ServerBinary

    %% Database Connections
    MySQL -->|3306/TCP<br/>MySQL protocol| MySQLDB[(MySQL/MariaDB<br/>Database)]
    PostgreSQL -->|5432/TCP<br/>PostgreSQL protocol| PostgreSQLDB[(PostgreSQL<br/>Database)]
    PyDirect -->|Direct connection| MySQLDB
    PyDirect -->|Direct connection| PostgreSQLDB

    %% DSP Operator
    DSPOperator["DSP Operator"] -.->|deploys & configures| ServerBinary

    %% Styling
    style ServerBinary fill:#4a90e2,stroke:#333,color:#fff
    style ServiceImpl fill:#4a90e2,stroke:#333,color:#fff
    style MetadataStore fill:#4a90e2,stroke:#333,color:#fff
    style SQLite fill:#6baed6,stroke:#333
    style MySQL fill:#6baed6,stroke:#333
    style PostgreSQL fill:#6baed6,stroke:#333
    style PyClient fill:#9b59b6,stroke:#333,color:#fff
    style PyGRPC fill:#9b59b6,stroke:#333,color:#fff
    style PyDirect fill:#9b59b6,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style PipelineUI fill:#7ed321,stroke:#333
    style TFX fill:#7ed321,stroke:#333
    style DSPOperator fill:#f5a623,stroke:#333
    style MySQLDB fill:#e8e8e8,stroke:#333
    style PostgreSQLDB fill:#e8e8e8,stroke:#333
    style ServiceProto fill:#bdc3c7,stroke:#333
    style StoreProto fill:#bdc3c7,stroke:#333
    style SourceProto fill:#bdc3c7,stroke:#333
