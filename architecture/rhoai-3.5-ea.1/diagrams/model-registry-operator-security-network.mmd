graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Admin"]
        Client["API Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph Cluster["CLUSTER INTERNAL (NetworkPolicy Enforced)"]
        direction TB

        subgraph OperatorPod["Operator Manager Pod"]
            Operator["model-registry-operator<br/>SA: controller-manager<br/>FIPS: strictfipsruntime"]
            OpMetrics["Metrics: 8443/TCP HTTPS<br/>Bearer Token auth"]
            OpHealth["Health: 8081/TCP HTTP"]
            OpWebhook["Webhooks: 9443/TCP HTTPS<br/>API server mTLS"]
        end

        subgraph RegistryPod["Per-Registry Pod"]
            KRBP_Reg["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>SubjectAccessReview"]
            RESTContainer["rest-container<br/>8080/TCP HTTP<br/>localhost only"]
        end

        subgraph CatalogPod["Model Catalog Pod (Singleton)"]
            KRBP_Cat["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>SubjectAccessReview"]
            CatalogContainer["catalog container<br/>8080/TCP HTTP<br/>localhost only"]
        end

        subgraph Database["Database Layer"]
            RegPG["Registry PostgreSQL<br/>5432/TCP<br/>Password (Secret)"]
            CatPG["model-catalog-postgres<br/>5432/TCP<br/>Password (Secret)"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        ExtPG["External PostgreSQL<br/>5432/TCP<br/>SSL configurable<br/>Username/password"]
        ExtMySQL["External MySQL<br/>3306/TCP<br/>SSL configurable<br/>Username/password"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User credentials"| K8sAPI
    Client -->|"HTTPS/443<br/>TLS (edge)<br/>Bearer token"| Router

    %% Ingress to services
    Router -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer token"| KRBP_Reg
    Router -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer token"| KRBP_Cat

    %% kube-rbac-proxy auth flow
    KRBP_Reg -->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI
    KRBP_Cat -->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI

    %% Internal proxy
    KRBP_Reg -->|"HTTP/8080<br/>localhost<br/>No auth"| RESTContainer
    KRBP_Cat -->|"HTTP/8080<br/>localhost<br/>No auth"| CatalogContainer

    %% Database connections
    RESTContainer -->|"PostgreSQL/5432<br/>SSL configurable<br/>Username/password"| RegPG
    CatalogContainer -->|"PostgreSQL/5432<br/>Username/password"| CatPG
    RESTContainer -.->|"PostgreSQL/5432<br/>SSL configurable"| ExtPG
    RESTContainer -.->|"MySQL/3306<br/>SSL configurable"| ExtMySQL

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>mTLS<br/>Webhook calls"| OpWebhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef proxy fill:#b8d4e3,stroke:#6c8ebf,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef k8s fill:#e8e8e8,stroke:#666,stroke-width:2px

    class User,Client external
    class Router ingress
    class Operator,OpMetrics,OpHealth,OpWebhook operator
    class KRBP_Reg,KRBP_Cat proxy
    class RESTContainer,CatalogContainer container
    class RegPG,CatPG database
    class ExtPG,ExtMySQL extsvc
    class K8sAPI k8s
