graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"CRD CRUD, pod mgmt<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>1.24+"]
    ArgoWF -->|"artifact I/O<br/>443/TCP or 9000/TCP"| S3["S3 / Minio<br/>(required for DSP)"]

    %% External Dependencies (Optional)
    ArgoWF -.->|"workflow archival<br/>5432/TCP SSL"| PostgreSQL["PostgreSQL<br/>9.6+ (optional)"]
    ArgoWF -.->|"workflow archival<br/>3306/TCP"| MySQL["MySQL<br/>5.7+ (optional)"]
    ArgoWF -.->|"artifact storage<br/>443/TCP HTTPS"| GCS["Google Cloud Storage<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>443/TCP HTTPS"| Azure["Azure Blob Storage<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>8020/TCP RPC"| HDFS["HDFS<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>443/TCP HTTPS"| AliOSS["Alibaba OSS<br/>(optional)"]
    ArgoWF -->|"resolve entrypoints<br/>443/TCP HTTPS OCI"| Registries["Container Registries"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys &<br/>configures"| ArgoWF

    %% Integration Points (inbound)
    ArgoEvents["Argo Events"] -.->|"WorkflowEventBinding<br/>triggers"| ArgoWF

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style Azure fill:#999,stroke:#333,color:#fff
    style HDFS fill:#999,stroke:#333,color:#fff
    style AliOSS fill:#999,stroke:#333,color:#fff
    style Registries fill:#f5a623,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style ArgoEvents fill:#7ed321,stroke:#333
