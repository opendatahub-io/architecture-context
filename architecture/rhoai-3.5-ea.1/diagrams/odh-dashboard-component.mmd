graph TB
    subgraph External["External Access"]
        Browser[Browser / Client]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["data-science-gateway<br/>HTTPRoute<br/>443/TCP HTTPS"]
    end

    subgraph DashboardPod["ODH Dashboard Pod (2 replicas)"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OIDC + K8s RBAC"]
        end

        subgraph CoreShell["Core Shell Application"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP"]
            Frontend["React Frontend<br/>PatternFly 6<br/>Module Federation Host"]
            Backend -->|serves| Frontend
        end

        subgraph BFFSidecars["BFF Sidecar Modules (Module Federation)"]
            direction LR
            MR["model-registry-ui<br/>Go BFF + React<br/>8043/TCP"]
            GenAI["gen-ai-ui<br/>Go BFF + React<br/>8143/TCP"]
            MaaS["maas-ui<br/>Go BFF + React<br/>8243/TCP"]
            MLflow["mlflow-ui<br/>Go BFF + React<br/>8343/TCP"]
            EvalHub["eval-hub-ui<br/>Go BFF + React<br/>8543/TCP"]
            AutoML["automl-ui<br/>Go BFF + React<br/>8643/TCP"]
            AutoRAG["autorag-ui<br/>Go BFF + React<br/>8743/TCP"]
        end

        KubeRBAC -->|"X-Auth-Request-User<br/>headers injected"| Backend
        Backend -->|"HTTPS proxy<br/>x-forwarded-access-token"| MR
        Backend -->|"HTTPS proxy"| GenAI
        Backend -->|"HTTPS proxy"| MaaS
        Backend -->|"HTTPS proxy"| MLflow
        Backend -->|"HTTPS proxy"| EvalHub
        Backend -->|"HTTPS proxy"| AutoML
        Backend -->|"HTTPS proxy"| AutoRAG
        GenAI -.->|"inter-BFF call<br/>HTTPS/8243"| MaaS
    end

    subgraph CRDs["Watched CRDs"]
        direction LR
        ISVC["InferenceService"]
        NB["Notebook"]
        ModelReg["ModelRegistry"]
        DSC["DataScienceCluster"]
        OdhConfig["OdhDashboardConfig"]
        FS["FeatureStore"]
        MLF["MLflow"]
        OGX["OGXServer"]
    end

    subgraph PlatformServices["Platform Services"]
        direction LR
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        Thanos["Thanos Querier<br/>9092/TCP"]
        DSPipeline["DS Pipeline API<br/>8443/TCP"]
        ModelRegSvc["Model Registry<br/>Service"]
        TrustyAI["TrustyAI<br/>Service"]
        LlamaStack["Llama Stack<br/>8321/TCP"]
    end

    Browser -->|"HTTPS/443"| Gateway
    Gateway -->|"HTTPS/8443"| KubeRBAC

    Backend -->|"K8s API calls"| K8sAPI
    Backend -->|"metrics proxy"| Thanos
    Backend -->|"pipeline proxy"| DSPipeline
    Backend -->|"registry proxy"| ModelRegSvc
    Backend -->|"fairness proxy"| TrustyAI
    Backend -->|"LLM proxy"| LlamaStack
    Backend -->|"CRD watch"| CRDs

    style KubeRBAC fill:#e74c3c,stroke:#333,color:#fff
    style Backend fill:#4a90e2,stroke:#333,color:#fff
    style Frontend fill:#4a90e2,stroke:#333,color:#fff
