graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Gateway (Envoy)<br/>maas-default-gateway<br/>443/TCP → ext-proc<br/>TLS 1.2+ terminated<br/>Gateway-level auth"]
    end

    subgraph MeshInternal["SERVICE MESH (Internal)"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            direction TB

            subgraph BBRService["BBR ext-proc Service"]
                direction LR
                MPR["model-provider-resolver"]
                AT["api-translation"]
                AKI["apikey-injection"]
                NRQ["nemo-request-guard"]
                NRS["nemo-response-guard"]
            end

            subgraph ControllersGroup["Controllers"]
                direction LR
                EMCtrl["ExternalModel<br/>Controller"]
                EPCtrl["ExternalProvider<br/>Controller"]
            end

            Secrets["Kubernetes Secrets<br/>(bbr-managed labeled)<br/>Opaque: api-key"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>ServiceAccount token"]

        NeMo["NeMo Guardrails<br/>configurable port<br/>HTTP (no app-level TLS)<br/>No auth"]
    end

    subgraph ManagedResources["MANAGED RESOURCES (created by controllers)"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
        ExtNameSvc["Service<br/>(ExternalName)"]
        SvcEntry["Istio ServiceEntry"]
        DestRule["Istio DestinationRule<br/>TLS mode: SIMPLE"]
    end

    subgraph ExternalServices["EXTERNAL LLM PROVIDERS"]
        OpenAI["api.openai.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Authorization: Bearer"]
        Anthropic["api.anthropic.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>x-api-key header"]
        Azure["{resource}.openai.azure.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>api-key header"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Authorization: Bearer"]
        VertexAI["Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Authorization: Bearer"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Gateway auth"| Gateway
    Gateway -->|"gRPC/9004<br/>plaintext<br/>mesh-internal"| BBRService
    AKI -->|"reads cached"| Secrets
    NRQ -->|"HTTP POST<br/>configurable port<br/>No TLS / No auth"| NeMo
    NRS -->|"HTTP POST<br/>configurable port<br/>No TLS / No auth"| NeMo
    BBRService -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    EMCtrl -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    EPCtrl -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    EMCtrl -->|creates| HTTPRoute
    EPCtrl -->|creates| ExtNameSvc
    EPCtrl -->|creates| SvcEntry
    EPCtrl -->|creates| DestRule

    Gateway -->|"routes via HTTPRoute →<br/>ExternalName Service →<br/>ServiceEntry"| DestRule
    DestRule -->|"HTTPS/443<br/>TLS 1.2+ SIMPLE origination<br/>Provider API key"| OpenAI
    DestRule -->|"HTTPS/443<br/>TLS 1.2+ SIMPLE origination<br/>Provider API key"| Anthropic
    DestRule -->|"HTTPS/443<br/>TLS 1.2+ SIMPLE origination<br/>Provider API key"| Azure
    DestRule -->|"HTTPS/443<br/>TLS 1.2+ SIMPLE origination<br/>Provider API key"| Bedrock
    DestRule -->|"HTTPS/443<br/>TLS 1.2+ SIMPLE origination<br/>Provider API key"| VertexAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef meshinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef managed fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class BBRService,MPR,AT,AKI,NRQ,NRS,EMCtrl,EPCtrl,Secrets,K8sAPI meshinternal
    class HTTPRoute,ExtNameSvc,SvcEntry,DestRule managed
    class OpenAI,Anthropic,Azure,Bedrock,VertexAI externalservice
    class NeMo warning
