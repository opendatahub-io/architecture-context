graph TD
    subgraph RuntimeIdentity["Runtime Identity (KFP-Managed)"]
        KFPSA["KFP Pipeline<br/>Service Account<br/>(injected by KFP at runtime)"]
    end

    subgraph SecretInjection["Secret Injection via kfp.kubernetes.use_secret_as_env()"]
        direction TB

        S3Secret["s3-secret<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_DEFAULT_REGION"]
        HFSecret["hf-token<br/>(Opaque)<br/>HF_TOKEN"]
        K8sSecret["kubernetes-credentials<br/>(Opaque)<br/>KUBERNETES_SERVER_URL<br/>KUBERNETES_AUTH_TOKEN"]
        OCISecret["oci-pull-secret-model-download<br/>(Opaque)<br/>Docker config.json"]
        OGXSecret["ogx-secret<br/>(Opaque)<br/>OGX_CLIENT_BASE_URL<br/>OGX_CLIENT_API_KEY"]
        LLMSecret["llm-credentials<br/>(Opaque)<br/>api_key → LLM_API_KEY"]
    end

    subgraph AuthEndpoints["Authenticated Endpoints"]
        S3Endpoint["AWS S3<br/>GET, PUT, LIST<br/>AWS IAM Credentials"]
        HFEndpoint["HuggingFace Hub<br/>GET<br/>Bearer Token"]
        OGXEndpoint["OGX API<br/>POST<br/>Bearer Token"]
        K8sEndpoint["Kubernetes API<br/>POST, GET, WATCH<br/>Bearer Token"]
        ModelRegEndpoint["Model Registry<br/>POST, GET<br/>⚠ No Auth (insecure HTTP)"]
    end

    subgraph SecurityNotes["Security Notes"]
        Note1["⚠ No RBAC manifests in repository"]
        Note2["⚠ No auto-rotation on any secrets"]
        Note3["⚠ Model Registry: HTTP insecure, no auth"]
        Note4["⚠ K8s auth via env var tokens,<br/>not in-cluster SA mount"]
    end

    %% Service account to secrets
    KFPSA -->|"mounts"| S3Secret
    KFPSA -->|"mounts"| HFSecret
    KFPSA -->|"mounts"| K8sSecret
    KFPSA -->|"mounts"| OCISecret
    KFPSA -->|"mounts"| OGXSecret
    KFPSA -->|"mounts"| LLMSecret

    %% Secrets to endpoints
    S3Secret -->|"authenticates"| S3Endpoint
    HFSecret -->|"authenticates"| HFEndpoint
    OGXSecret -->|"authenticates"| OGXEndpoint
    K8sSecret -->|"authenticates"| K8sEndpoint
    KFPSA -.->|"no auth required"| ModelRegEndpoint

    %% Styling
    style KFPSA fill:#4a90e2,stroke:#333,color:#fff
    style S3Secret fill:#f5a623,stroke:#333
    style HFSecret fill:#f5a623,stroke:#333
    style K8sSecret fill:#f5a623,stroke:#333
    style OCISecret fill:#f5a623,stroke:#333
    style OGXSecret fill:#f5a623,stroke:#333
    style LLMSecret fill:#f5a623,stroke:#333
    style S3Endpoint fill:#7ed321,stroke:#333
    style HFEndpoint fill:#7ed321,stroke:#333
    style OGXEndpoint fill:#7ed321,stroke:#333
    style K8sEndpoint fill:#7ed321,stroke:#333
    style ModelRegEndpoint fill:#ff6b6b,stroke:#333,color:#fff
    style Note1 fill:#fff3e0,stroke:#e65100
    style Note2 fill:#fff3e0,stroke:#e65100
    style Note3 fill:#ffebee,stroke:#c62828
    style Note4 fill:#fff3e0,stroke:#e65100
