graph TB
    subgraph PipelinesComponents["Pipelines Components"]
        direction TB

        subgraph InitContainer["Init Container"]
            GenManaged["generate_managed_pipelines<br/>(Build-time Script)"]
            InitManaged["init_managed_pipelines<br/>(Entrypoint)"]
            GenManaged -->|compiles pipeline.py → pipeline.yaml| InitManaged
        end

        subgraph ComponentLibrary["KFP Component Library"]
            direction LR

            subgraph DataProc["Data Processing"]
                DatasetDownload["dataset_download"]
                SDG["sdg<br/>(Synthetic Data Gen)"]
                DocsDiscovery["documents_discovery"]
                TextExtraction["text_extraction<br/>(Docling)"]
                DocsIndexing["documents_indexing"]
                YodaProcessor["yoda_data_processor"]
                AutoMLDataLoader["automl_data_loader"]
            end

            subgraph Training["Training"]
                LoRA["LoRA Fine-Tuning<br/>(Unsloth backend)"]
                OSFT["OSFT Fine-Tuning<br/>(mini-trainer backend)"]
                SFT["SFT Fine-Tuning<br/>(instructlab-training)"]
                AutoGluonTrain["AutoGluon Training<br/>(Tabular + Time-Series)"]
                RAGOptimize["RAG Templates<br/>Optimization"]
                SearchSpace["Search Space<br/>Preparation"]
            end

            subgraph Evaluation["Evaluation"]
                LMEval["lm_eval<br/>(Benchmark)"]
                Leaderboard["Leaderboard<br/>Evaluation"]
            end

            subgraph Deploy["Deployment"]
                ModelRegComp["Model Registry<br/>Registration"]
                ResponsesAPI["Build Responses<br/>API Requests"]
            end
        end

        subgraph RuntimeImages["Runtime Container Images"]
            AutoMLImage["odh-automl<br/>quay.io/rhoai/odh-automl<br/>(AutoGluon 1.5.0)"]
            AutoRAGImage["odh-autorag<br/>quay.io/rhoai/odh-autorag<br/>(Docling + ai4rag + OGX)"]
        end
    end

    %% Init container relationship to KFP
    InitManaged -->|copies YAMLs to<br/>/config/managed-pipelines/| KFPServer["KFP API Server"]

    %% Runtime image usage
    AutoMLImage -.->|base_image for| AutoGluonTrain
    AutoMLImage -.->|base_image for| AutoMLDataLoader
    AutoMLImage -.->|base_image for| Leaderboard
    AutoRAGImage -.->|base_image for| DocsDiscovery
    AutoRAGImage -.->|base_image for| TextExtraction
    AutoRAGImage -.->|base_image for| DocsIndexing
    AutoRAGImage -.->|base_image for| RAGOptimize
    AutoRAGImage -.->|base_image for| SearchSpace
    AutoRAGImage -.->|base_image for| ResponsesAPI

    %% External dependencies
    LoRA -->|TrainerClient| TrainingHub["Kubeflow Training Hub"]
    OSFT -->|TrainerClient| TrainingHub
    SFT -->|TrainerClient| TrainingHub
    ModelRegComp -->|REST API| ModelRegistry["Kubeflow Model Registry<br/>8080/TCP HTTP"]
    RAGOptimize -->|HTTPS| OGX["OGX API<br/>443/TCP"]
    DocsIndexing -->|HTTP/gRPC| Milvus["Milvus Vector Store"]
    DatasetDownload -->|HTTPS| HFHub["HuggingFace Hub"]
    DatasetDownload -->|HTTPS| S3["AWS S3"]
    SDG -->|HTTPS| LiteLLM["LiteLLM / LLM Provider"]

    %% Styling
    style PipelinesComponents fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style InitContainer fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style ComponentLibrary fill:#f5f5f5,stroke:#999,stroke-width:1px
    style RuntimeImages fill:#e8f5e9,stroke:#82b366,stroke-width:2px
    style DataProc fill:#e3f2fd,stroke:#64b5f6,stroke-width:1px
    style Training fill:#fce4ec,stroke:#ef5350,stroke-width:1px
    style Evaluation fill:#fff8e1,stroke:#ffd54f,stroke-width:1px
    style Deploy fill:#e8f5e9,stroke:#66bb6a,stroke-width:1px

    style GenManaged fill:#f5a623,color:#fff
    style InitManaged fill:#f5a623,color:#fff
    style KFPServer fill:#4a90e2,color:#fff
    style TrainingHub fill:#999,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style OGX fill:#999,stroke:#333
    style Milvus fill:#999,stroke:#333
    style HFHub fill:#999,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style LiteLLM fill:#999,stroke:#333
    style AutoMLImage fill:#66bb6a,color:#fff
    style AutoRAGImage fill:#66bb6a,color:#fff
