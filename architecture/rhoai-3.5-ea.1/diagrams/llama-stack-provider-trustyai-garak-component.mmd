graph TB
    subgraph "Llama Stack Provider: TrustyAI Garak"
        direction TB

        subgraph "Core Provider"
            Provider[trustyai-garak-lls-provider<br/>Python Llama Stack Provider]
            BaseEval[GarakEvalBase<br/>Common Eval Interface]
            Compat[Compatibility Layer<br/>llama_stack ↔ llama_stack_api]
            Provider --> BaseEval
            Provider --> Compat
        end

        subgraph "Execution Adapters"
            InlineAdapter[Inline Eval Adapter<br/>Subprocess + Semaphore]
            RemoteAdapter[Remote Eval Adapter<br/>KFP Pipeline Submission]
            EvalHubAdapter[eval-hub Adapter<br/>FrameworkAdapter + Sidecar]
            BaseEval --> InlineAdapter
            BaseEval --> RemoteAdapter
            BaseEval --> EvalHubAdapter
        end

        subgraph "Scanning Engines"
            ShieldOrch[Shield Scan Orchestrator<br/>SimpleShieldOrchestrator]
            SDGEngine[SDG Engine<br/>sdg-hub Flow Runner]
            IntentsEngine[Intents/CAS Engine<br/>Policy Taxonomy → CAS Topology]
            GarakRunner[Garak Runner<br/>Subprocess Manager]
        end

        subgraph "Pipeline & Results"
            KFPComponents[KFP Pipeline Components<br/>6-step DAG]
            ResultParser[Result Parser<br/>TBSA Scoring + ART Reports]
        end

        InlineAdapter --> GarakRunner
        RemoteAdapter --> KFPComponents
        EvalHubAdapter --> GarakRunner
        EvalHubAdapter --> KFPComponents
        BaseEval --> ShieldOrch
        BaseEval --> SDGEngine
        SDGEngine --> IntentsEngine
        GarakRunner --> ResultParser
        KFPComponents --> ResultParser
    end

    %% External interactions
    Client[Client / User] -->|POST /v1/eval/run| LlamaStackServer
    LlamaStackServer[Llama Stack Server<br/>8321/TCP HTTP] -->|Provider Interface| Provider

    %% Upstream dependencies
    GarakRunner -->|HTTPS/443<br/>Bearer Token| vLLM[vLLM Inference<br/>Target Model]
    ShieldOrch -->|HTTP/8321| SafetyAPI[Llama Stack Safety API<br/>Input/Output Shields]
    SDGEngine -->|HTTP/8321| InferenceAPI[Llama Stack Inference API<br/>LLM for Prompt Generation]
    RemoteAdapter -->|HTTPS/443<br/>SA Token| KFPAPI[KFP API<br/>Data Science Pipelines]
    EvalHubAdapter -->|gRPC| EvalHubSidecar[eval-hub Sidecar<br/>OCI + MLflow]
    EvalHubAdapter -->|HTTPS/443<br/>AWS IAM| S3[S3 / MinIO]
    ResultParser -->|HTTP/8321| FilesAPI[Llama Stack Files API<br/>Artifact Storage]

    %% Styling
    style Provider fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style BaseEval fill:#4a90e2,stroke:#333,color:#fff
    style InlineAdapter fill:#5ba3d9,stroke:#333,color:#fff
    style RemoteAdapter fill:#5ba3d9,stroke:#333,color:#fff
    style EvalHubAdapter fill:#5ba3d9,stroke:#333,color:#fff
    style ShieldOrch fill:#9b59b6,stroke:#333,color:#fff
    style SDGEngine fill:#9b59b6,stroke:#333,color:#fff
    style IntentsEngine fill:#9b59b6,stroke:#333,color:#fff
    style GarakRunner fill:#e67e22,stroke:#333,color:#fff
    style KFPComponents fill:#e67e22,stroke:#333,color:#fff
    style ResultParser fill:#e67e22,stroke:#333,color:#fff
    style Compat fill:#7f8c8d,stroke:#333,color:#fff

    style LlamaStackServer fill:#2ecc71,stroke:#333,color:#fff
    style vLLM fill:#e8e8e8,stroke:#999
