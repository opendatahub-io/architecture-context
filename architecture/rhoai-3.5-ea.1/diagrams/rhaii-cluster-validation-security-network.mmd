graph TB
    subgraph External["USER WORKSTATION (External)"]
        User["User / kubectl rhaii-validate"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC: ClusterRole rhaii-validator"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK — Namespace: rhaii-validation"]
        direction TB

        subgraph GPUChecks["Per-Node GPU/RDMA Checks"]
            GPUJob["GPU Check Job Pod<br/>SA: rhaii-validator<br/>Image: odh-rhaii-cluster-validator<br/>privileged=true, hostPID=true<br/>hostPath: / → /host"]
        end

        subgraph TCPTests["TCP Bandwidth & Latency Tests"]
            IperfSrv["iperf3 Server Pod<br/>5201/TCP"]
            IperfCli["iperf3 Client Pod"]
            LatSrv["TCP Latency Server Pod<br/>12865/TCP echo"]
            LatCli["TCP Latency Client Pod"]
        end

        subgraph RDMATests["RDMA Bandwidth & Connectivity Tests"]
            IBSrv["ib_write_bw Server Pod<br/>18515/TCP RDMA"]
            IBCli["ib_write_bw Client Pod"]
            PingSrv["ibv_rc_pingpong Server<br/>variable/TCP RDMA"]
            PingCli["ibv_rc_pingpong Client"]
        end
    end

    subgraph HostAccess["HOST NODE ACCESS (Privileged)"]
        GPU["GPU Hardware<br/>nvidia-smi / rocm-smi<br/>libcuda.so.1 device mount"]
        RDMA["InfiniBand / RoCE Fabric<br/>/dev/infiniband<br/>/sys/class/infiniband"]
        HostFS["Host Filesystem<br/>hostPath / → /host<br/>sysfs, PCI topology"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (kubeconfig)"| K8sAPI

    %% Control Plane → Job Pods
    K8sAPI -->|"Job scheduling<br/>HTTPS/6443<br/>Bearer Token (SA)"| GPUJob
    K8sAPI -->|"Job scheduling"| IperfSrv
    K8sAPI -->|"Job scheduling"| IperfCli
    K8sAPI -->|"Job scheduling"| IBSrv
    K8sAPI -->|"Job scheduling"| IBCli

    %% Pod-to-Pod (unencrypted)
    IperfCli -->|"TCP/5201<br/>No encryption<br/>No auth"| IperfSrv
    LatCli -->|"TCP/12865<br/>No encryption<br/>No auth"| LatSrv
    IBCli -->|"RDMA verbs/18515<br/>No encryption<br/>No auth"| IBSrv
    PingCli -->|"RDMA verbs/variable<br/>No encryption<br/>No auth"| PingSrv

    %% Host Access
    GPUJob -->|"Local exec<br/>Device mount<br/>No network"| GPU
    GPUJob -->|"sysfs read<br/>hostPath mount"| RDMA
    GPUJob -->|"hostPath /<br/>hostPID=true"| HostFS
    IBSrv -->|"Direct HW access<br/>RDMA verbs"| RDMA
    IBCli -->|"Direct HW access<br/>RDMA verbs"| RDMA

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hostaccess fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class GPUJob,IperfSrv,IperfCli,LatSrv,LatCli cluster
    class IBSrv,IBCli,PingSrv,PingCli danger
    class GPU,RDMA,HostFS hostaccess
