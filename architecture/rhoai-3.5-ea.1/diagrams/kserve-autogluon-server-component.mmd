graph TB
    subgraph KServeAutogluon["KServe AutoGluon Server"]
        direction TB

        subgraph ServerCore["Server Core (autogluonserver)"]
            Main["__main__.py<br/>Entry Point"]
            PredictorFactory["PredictorFactory<br/>Auto-detect model type"]
            PredictorDetect["predictor_detect<br/>TimeSeriesPredictor.load() → TabularPredictor.load()"]
            RuntimePaths["runtime_paths<br/>Writable dir selection"]
        end

        subgraph Models["Model Implementations"]
            TabularModel["AutoGluonTabularModel<br/>v1 + v2 inference<br/>Classification / Regression / Quantile"]
            TimeSeriesModel["AutoGluonTimeSeriesModel<br/>v1 inference only<br/>Time Series Forecasting"]
            DetectedModel["AutoGluonDetectedModel<br/>Delegates to Tabular or TimeSeries"]
        end

        subgraph KServeSDK["KServe SDK (python/kserve)"]
            FastAPIServer["FastAPI REST Server<br/>8080/TCP"]
            GRPCServer["gRPC Server<br/>8081/TCP"]
            ModelRepo["Model Repository"]
            Metrics["Prometheus Metrics<br/>/metrics"]
            HealthChecks["Health Checks<br/>/v2/health/live, /ready"]
        end

        subgraph Storage["KServe Storage (python/storage)"]
            StorageModule["kserve-storage<br/>S3 / GCS / Azure / HuggingFace"]
        end
    end

    %% Internal flows
    Main -->|initializes| PredictorFactory
    PredictorFactory -->|calls| PredictorDetect
    PredictorDetect -->|creates| DetectedModel
    DetectedModel -->|delegates to| TabularModel
    DetectedModel -->|delegates to| TimeSeriesModel
    Main -->|configures| RuntimePaths
    Main -->|starts| FastAPIServer
    Main -->|starts| GRPCServer

    TabularModel -->|registers with| ModelRepo
    TimeSeriesModel -->|registers with| ModelRepo
    FastAPIServer -->|routes to| ModelRepo
    GRPCServer -->|routes to| ModelRepo

    %% External interactions
    Client[External Client] -->|HTTPS/443| Gateway["Platform Gateway<br/>Istio / Gateway API"]
    Gateway -->|HTTP/8080| QueueProxy["Queue Proxy<br/>(sidecar)"]
    QueueProxy -->|HTTP/8080| FastAPIServer

    GRPCClient[gRPC Client] -->|gRPC/8081| GRPCServer

    StorageInit["Storage Initializer<br/>(init container)"] -->|writes to| MountModels["/mnt/models"]
    MountModels -->|read by| PredictorDetect

    StorageInit -->|uses| StorageModule
    StorageModule -->|downloads from| RemoteStorage["Remote Storage<br/>S3 / GCS / Azure / HF"]

    Prometheus["Prometheus"] -->|scrapes /metrics| Metrics

    KServeCtrl["KServe Controller"] -->|reads| CSR["ClusterServingRuntime CR<br/>kserve-autogluonserver"]
    KServeCtrl -->|creates pods with| KServeAutogluon

    %% Styling
    style KServeAutogluon fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ServerCore fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Models fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style KServeSDK fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style Storage fill:#f8cecc,stroke:#b85450,stroke-width:1px

    style Client fill:#f9f9f9,stroke:#999
    style GRPCClient fill:#f9f9f9,stroke:#999
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style QueueProxy fill:#ffe6cc,stroke:#d79b00
    style StorageInit fill:#e1d5e7,stroke:#9673a6
    style RemoteStorage fill:#f5f5f5,stroke:#666
    style Prometheus fill:#f5f5f5,stroke:#666
    style KServeCtrl fill:#e1d5e7,stroke:#9673a6
    style CSR fill:#f5a623,stroke:#333
    style MountModels fill:#f5f5f5,stroke:#666
