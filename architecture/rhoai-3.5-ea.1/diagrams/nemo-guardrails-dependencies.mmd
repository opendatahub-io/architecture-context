graph LR
    NemoGR["NeMo Guardrails<br/>Server v0.21.0"]

    %% Core Framework Dependencies
    subgraph CoreFramework["Core Framework"]
        FastAPI["FastAPI >=0.103.0"]
        Uvicorn["Uvicorn >=0.23"]
        Pydantic["Pydantic >=1.10"]
        httpx["httpx >=0.24.1"]
    end

    NemoGR -->|HTTP server| FastAPI
    NemoGR -->|ASGI server| Uvicorn
    NemoGR -->|data validation| Pydantic
    NemoGR -->|async HTTP client| httpx

    %% LLM Framework Dependencies
    subgraph LLMFramework["LLM Abstraction"]
        LangChain["LangChain >=0.2.14"]
        LangChainCore["LangChain-Core >=0.2.14"]
        LangChainCommunity["LangChain-Community >=0.2.5"]
        OpenAISDK["OpenAI SDK >=1.0.0"]
    end

    NemoGR -->|LLM orchestration| LangChain
    NemoGR -->|core abstractions| LangChainCore
    NemoGR -->|community integrations| LangChainCommunity
    NemoGR -->|API client + types| OpenAISDK

    %% NLP / ML Dependencies
    subgraph NLPModels["NLP / ML (Pre-baked in Image)"]
        SpaCy["SpaCy >=3.4.4<br/>+ en_core_web_lg 3.8.0"]
        SentTrans["Sentence Transformers >=2.2.0"]
        FastEmbed["FastEmbed >=0.2.2"]
        ONNXRuntime["ONNX Runtime >=1.17.0"]
        PyTorch["PyTorch >=2.0.0"]
        NLTK["NLTK >=3.8"]
        Annoy["Annoy >=1.17.3"]
        Lark["Lark >=1.1.7"]
    end

    NemoGR -->|entity recognition| SpaCy
    NemoGR -->|embeddings| SentTrans
    NemoGR -->|lightweight embeddings| FastEmbed
    NemoGR -->|neural inference| ONNXRuntime
    NemoGR -->|model inference| PyTorch
    NemoGR -->|tokenization| NLTK
    NemoGR -->|ANN index| Annoy
    NemoGR -->|Colang parser| Lark

    %% Optional Dependencies
    subgraph OptionalDeps["Optional Dependencies"]
        Presidio["Presidio Analyzer/Anonymizer >=2.2<br/>(sensitive data detection)"]
        YARA["YARA-Python ^4.5.1<br/>(jailbreak detection)"]
        OTelAPI["OpenTelemetry API >=1.27.0<br/>(tracing)"]
        OTelSDK["OpenTelemetry SDK >=1.38.0<br/>(auto-instrumentation)"]
        LCOpenAI["LangChain-OpenAI >=0.1.0"]
        LCNvidia["LangChain-NVIDIA >=0.2.0"]
        aioredis["aioredis<br/>(Redis client)"]
        fastlangdetect["fast-langdetect >=1.0.0<br/>(multilingual)"]
    end

    NemoGR -.->|PII detection| Presidio
    NemoGR -.->|pattern matching| YARA
    NemoGR -.->|tracing| OTelAPI
    NemoGR -.->|full OTEL| OTelSDK
    NemoGR -.->|OpenAI provider| LCOpenAI
    NemoGR -.->|NVIDIA provider| LCNvidia
    NemoGR -.->|Redis state| aioredis
    NemoGR -.->|language detection| fastlangdetect

    %% Internal Platform Dependencies
    subgraph InternalPlatform["Internal RHOAI Platform"]
        LLMService["LLM Inference Service<br/>(NIM / vLLM / TGI)"]
        PlatformGW["RHOAI Platform Gateway<br/>(HTTPRoute / Ingress)"]
    end

    NemoGR -->|upstream LLM calls| LLMService
    PlatformGW -->|routes traffic| NemoGR

    %% External Runtime Services
    subgraph ExternalServices["External Runtime Services"]
        OpenAIAPI["OpenAI API<br/>HTTPS/443"]
        NIMAPI["NVIDIA NIM<br/>HTTPS/443"]
        AzureAPI["Azure OpenAI<br/>HTTPS/443"]
        AnthropicExt["Anthropic API<br/>HTTPS/443"]
        CohereExt["Cohere API<br/>HTTPS/443"]
        Redis["Redis<br/>6379/TCP"]
        OTELCol["OTEL Collector"]
    end

    NemoGR -->|LLM inference| OpenAIAPI
    NemoGR -->|LLM inference| NIMAPI
    NemoGR -->|LLM inference| AzureAPI
    NemoGR -->|LLM inference| AnthropicExt
    NemoGR -->|LLM inference| CohereExt
    NemoGR -.->|state persistence| Redis
    NemoGR -.->|trace export| OTELCol

