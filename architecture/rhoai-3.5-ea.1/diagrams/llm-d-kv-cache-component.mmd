graph TB
    subgraph InferenceScheduler["llm-d-inference-scheduler (Consumer)"]
        Scheduler[Inference Scheduler<br/>Go Binary]
    end

    subgraph LLMDKVCache["llm-d-kv-cache Component"]
        direction TB

        subgraph IndexerLib["KV-Cache Indexer (pkg/kvcache/)"]
            Indexer[Indexer<br/>GetPodScores API]
            KVBlockScorer[KVBlock Scorer<br/>Cache hit ratio scoring]
            TokenProcessor[Token Processor<br/>FNV-64a block key computation]
            Indexer --> KVBlockScorer
            KVBlockScorer --> TokenProcessor
        end

        subgraph EventsLib["KV-Events Processor (pkg/kvevents/)"]
            EventPool[Event Pool<br/>Sharded worker pool<br/>FNV-1a pod-ID routing]
            ZMQSub[ZMQ Subscriber<br/>PUB/SUB receiver]
            SubManager[Subscriber Manager<br/>Dynamic pod discovery]
            EngineAdapters[Engine Adapters<br/>vLLM / SGLang]
            ZMQSub --> EngineAdapters
            EngineAdapters --> EventPool
            SubManager --> ZMQSub
        end

        subgraph TokenLib["Tokenization (pkg/tokenization/)"]
            TokenPool[Tokenization Pool<br/>Worker pool with fallback]
            CompositeTokenizer[Composite Tokenizer<br/>Fallback chain]
            TokenPool --> CompositeTokenizer
        end

        subgraph StorageBackends["Index Storage Backends"]
            InMemory[InMemoryIndex<br/>hashicorp/golang-lru]
            CostAware[CostAwareMemoryIndex<br/>dgraph-io/ristretto]
            RedisIdx[RedisIndex<br/>Pipelined + Lua cleanup]
        end

        subgraph Observability["Observability Layer"]
            InstrumentedIdx[Instrumented Index<br/>Prometheus metrics]
            TracedIdx[Traced Index<br/>OpenTelemetry spans]
            TracedScorer[Traced Scorer<br/>OpenTelemetry spans]
        end

        Indexer --> TokenPool
        KVBlockScorer --> InstrumentedIdx
        InstrumentedIdx --> TracedIdx
        TracedIdx --> InMemory
        TracedIdx --> CostAware
        TracedIdx --> RedisIdx
        EventPool --> InstrumentedIdx
    end

    subgraph Sidecars["Sidecar Services"]
        UDSTokenizer[UDS Tokenizer Service<br/>Python gRPC<br/>UDS: /tmp/tokenizer/tokenizer-uds.socket<br/>Health: 8082/TCP]
        PVCEvictor[PVC Evictor<br/>Python utility<br/>Multi-process disk mgmt]
    end

    subgraph ExternalEngines["Inference Engines"]
        vLLM[vLLM Pods<br/>ZMQ PUB]
        SGLang[SGLang Pods<br/>ZMQ PUB]
    end

    subgraph FSBackend["KV Connector Plugin"]
        LlmdFS[llmd_fs_backend<br/>vLLM Plugin wheel<br/>Shared storage offloading]
    end

    %% Primary consumer
    Scheduler -->|Go library import| Indexer

    %% ZMQ event ingestion
    vLLM -->|ZMQ PUB/SUB<br/>KVEvents| ZMQSub
    SGLang -->|ZMQ PUB/SUB<br/>KVEvents| ZMQSub

    %% Tokenizer connection
    CompositeTokenizer -->|gRPC via UDS| UDSTokenizer

    %% Redis backend
    RedisIdx -->|6379/TCP<br/>Redis protocol| Redis[(Redis/Valkey)]

    %% UDS Tokenizer external deps
    UDSTokenizer -->|HTTPS/443<br/>HF Token| HFHub[Hugging Face Hub]

    %% FS backend relationship
    LlmdFS -->|Shared PVC| SharedStorage[(NFS/PVC<br/>Shared Storage)]
    PVCEvictor -->|File I/O| SharedStorage

    %% K8s API for pod discovery
    SubManager -->|HTTPS/443<br/>mTLS| K8sAPI[Kubernetes API]

