graph TB
    subgraph "vllm-gaudi Container Image (odh-vllm-gaudi-rhel9)"
        direction TB

        subgraph "vLLM OpenAI API Server"
            APIServer["vLLM API Server<br/>python3 -m vllm.entrypoints.openai.api_server<br/>Port 8000/TCP"]
        end

        subgraph "vllm-gaudi Plugin"
            direction TB
            Platform["HpuPlatform<br/>Platform registration"]
            AttentionBackends["Attention Backends<br/>PagedAttn | UnifiedAttn | MLA"]
            Quantization["Quantization<br/>FP8 | INC | GPTQ | AWQ | ModelOpt"]
            ModelOverrides["Model Overrides<br/>11 architectures<br/>(DeepseekV2, Qwen3, Gemma3, etc.)"]
            OpsLayer["HPU Operations<br/>LayerNorm | MoE | RoPE | Conv<br/>LoRA | Mamba2 SSM"]
            SpecDecode["Speculative Decoding<br/>EAGLE | EAGLE Unified"]
            Scheduler["HPU Async Scheduler"]
        end

        subgraph "Worker & Distributed"
            HpuWorker["HPU Worker<br/>hpu_worker.py"]
            ModelRunner["HPU Model Runner<br/>hpu_model_runner.py"]
            HpuComm["HPU Communicator<br/>HCCL backend"]
            NIXLConn["NIXL Connector<br/>Disaggregated KV transfer"]
            KVOffload["KV Offload<br/>CPU-HPU offloading"]
        end

        subgraph "Runtime Dependencies"
            SynapseAI["Habana Synapse AI 1.23.0<br/>Graph compiler & runtime"]
            PyTorchHPU["PyTorch 2.9.0<br/>+ habana-torch-plugin"]
        end
    end

    %% External inputs
    Client[Client] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>POST /v1/embeddings"| KubeProxy
    KubeProxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS"] -->|"HTTP 8000/TCP<br/>(localhost)"| APIServer

    %% Internal flow
    APIServer -->|loads plugin| Platform
    Platform -->|selects| AttentionBackends
    Platform -->|configures| Quantization
    Platform -->|registers| ModelOverrides
    Platform -->|registers| OpsLayer
    APIServer -->|dispatches| HpuWorker
    HpuWorker -->|runs| ModelRunner
    ModelRunner -->|uses| AttentionBackends
    ModelRunner -->|uses| OpsLayer
    ModelRunner -->|uses| Quantization
    HpuWorker -->|multi-card| HpuComm
    HpuWorker -->|disaggregated| NIXLConn

    %% Hardware
    HpuWorker -->|"device calls"| SynapseAI
    ModelRunner -->|"HPU graphs"| PyTorchHPU
    SynapseAI -->|"kernel execution"| GaudiHW["Intel Gaudi 2/3<br/>HPU Hardware"]

    %% External dependencies
    APIServer -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    APIServer -->|"model load"| ModelStorage["Model Storage<br/>PVC / S3"]

    %% KServe integration
    KServe["KServe ServingRuntime"] -->|"pulls image"| APIServer

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style Platform fill:#7ed321,stroke:#333
    style AttentionBackends fill:#7ed321,stroke:#333
    style Quantization fill:#7ed321,stroke:#333
    style ModelOverrides fill:#7ed321,stroke:#333
    style OpsLayer fill:#7ed321,stroke:#333
    style SpecDecode fill:#7ed321,stroke:#333
    style Scheduler fill:#7ed321,stroke:#333
    style HpuWorker fill:#50c8e8,stroke:#333
    style ModelRunner fill:#50c8e8,stroke:#333
    style HpuComm fill:#50c8e8,stroke:#333
    style NIXLConn fill:#50c8e8,stroke:#333
    style KVOffload fill:#50c8e8,stroke:#333
    style SynapseAI fill:#f5a623,stroke:#333
    style PyTorchHPU fill:#f5a623,stroke:#333
    style GaudiHW fill:#e8e8e8,stroke:#333
    style KubeProxy fill:#d0a0d0,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style KServe fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
