graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers (opendatahub namespace)"]
        direction TB

        subgraph NBC["notebook-controller"]
            NBCMain["Controller Manager<br/>Go / controller-runtime"]
            NBCCulling["Culling Reconciler<br/>Polls Jupyter API"]
            NBCMain -->|"reconcile loop"| NBCCulling
        end

        subgraph ODHC["odh-notebook-controller"]
            ODHMain["Controller Manager<br/>Go / controller-runtime"]
            MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>443/TCP HTTPS"]
            ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>443/TCP HTTPS"]
            ODHMain -->|"registers"| MutatingWH
            ODHMain -->|"registers"| ValidatingWH
        end
    end

    %% CRDs
    NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>(Namespaced)"]

    %% User interaction
    User["User / Dashboard"] -->|"creates/updates"| NotebookCR

    %% API Server flow
    APIServer["Kubernetes API Server<br/>6443/TCP HTTPS"]
    NotebookCR -->|"persisted in"| APIServer
    APIServer -->|"admission webhook call"| MutatingWH
    APIServer -->|"admission webhook call"| ValidatingWH
    APIServer -->|"watch events"| NBCMain
    APIServer -->|"watch events"| ODHMain

    %% Resources created by notebook-controller
    subgraph CreatedResources["Resources Created (per Notebook)"]
        StatefulSet["StatefulSet<br/>(replicas: 1)"]
        NBService["Service<br/>80/TCP → 8888"]
        VirtualService["VirtualService<br/>(if Istio enabled)"]
    end

    NBCMain -->|"creates/manages"| StatefulSet
    NBCMain -->|"creates/manages"| NBService
    NBCMain -->|"creates (optional)"| VirtualService

    %% Resources created by odh-notebook-controller
    subgraph ODHResources["RHOAI Resources Created (per Notebook)"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
        NetworkPolicy["NetworkPolicy"]
        RBACProxy["kube-rbac-proxy<br/>Sidecar (8443/TCP)"]
        RefGrant["ReferenceGrant"]
        TrustBundle["workbench-trusted-ca-bundle<br/>ConfigMap"]
    end

    ODHMain -->|"creates"| HTTPRoute
    ODHMain -->|"creates"| NetworkPolicy
    ODHMain -->|"creates"| RefGrant
    ODHMain -->|"manages"| TrustBundle
    MutatingWH -->|"injects sidecar"| RBACProxy

    %% Culling flow
    NotebookPod["Notebook Pod<br/>(JupyterLab)<br/>8888/TCP"]
    StatefulSet -->|"manages"| NotebookPod
    NBCCulling -->|"polls /api/kernels<br/>/api/terminals<br/>8888/TCP HTTP"| NotebookPod

    %% Gateway
    Gateway["data-science-gateway<br/>(openshift-ingress)"]
    HTTPRoute -->|"attached to"| Gateway
    Gateway -->|"routes traffic to"| RBACProxy
    RBACProxy -->|"proxies to<br/>8888/TCP HTTP"| NotebookPod

    %% Styling
    style NBC fill:#4a90e2,stroke:#333,color:#fff
    style ODHC fill:#4a90e2,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style CreatedResources fill:#d5e8d4,stroke:#82b366
    style ODHResources fill:#dae8fc,stroke:#6c8ebf
    style Gateway fill:#e8e8e8,stroke:#333
    style NotebookPod fill:#7ed321,stroke:#333,color:#fff
    style APIServer fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#999
