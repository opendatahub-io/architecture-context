graph LR
    VllmGaudi["vllm-gaudi Plugin<br/>(HPU inference runtime)"]

    %% Core External Dependencies (Required)
    VllmGaudi -->|"plugin host<br/>v0.16.0"| vLLM["vLLM Core<br/>v0.16.0"]
    VllmGaudi -->|"driver stack<br/>graph compiler"| SynapseAI["Habana Synapse AI<br/>1.23.0"]
    VllmGaudi -->|"HPU device<br/>support"| PyTorch["PyTorch<br/>2.9.0 + habana-torch-plugin"]
    VllmGaudi -->|"target hardware"| Gaudi["Intel Gaudi 2/3<br/>HPU Hardware"]

    %% Runtime Dependencies
    VllmGaudi -->|"distributed<br/>inference"| Ray["Ray<br/>>=2.48.0"]
    VllmGaudi -->|"model loading<br/>tokenization"| Transformers["transformers<br/>>=4.56.0, <5"]
    VllmGaudi -->|"array ops"| NumPy["NumPy<br/>>=1.26.0"]
    VllmGaudi -->|"JIT compilation"| Numba["numba<br/>>=0.58.0"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>ServingRuntime"] -->|"pulls container image"| VllmGaudi
    KubeProxy["kube-rbac-proxy<br/>(sidecar)"] -->|"auth proxy<br/>8443→8000"| VllmGaudi

    %% External Services
    VllmGaudi -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    VllmGaudi -->|"model storage<br/>HTTPS/443 or PVC"| ModelStorage["Model Storage<br/>(S3 / PVC)"]

    %% Distributed Communication
    VllmGaudi -->|"collective ops<br/>(all-reduce)"| HCCL["HCCL Fabric"]
    VllmGaudi -.->|"KV cache<br/>transfer"| NIXL["NIXL<br/>(disaggregated serving)"]

