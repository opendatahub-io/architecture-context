graph LR
    RhodsOp["rhods-operator<br/>(RHOAI Platform Operator)"]

    %% ── Infrastructure Dependencies ──
    subgraph Infrastructure["Infrastructure Dependencies"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        ControllerRT["controller-runtime<br/>v0.23.3"]
        GatewayAPI["Gateway API CRDs<br/>v1.3.0"]
        OCP_API["OpenShift API<br/>(Route, OAuth, Infra)"]
        OLM_API["OLM API<br/>v0.42.0"]
        ManifestKit["k8s-manifest-kit<br/>v0.2.1"]
        HelmRenderer["renderer-helm<br/>v0.3.1"]
        PromOperator["prometheus-operator<br/>v0.68.0"]
    end

    %% ── Platform Services ──
    subgraph PlatformServices["Platform Services (Deployed by Operator)"]
        Istio["Istio / Sail Operator<br/>(Envoy data plane)"]
        CertMgr["cert-manager<br/>(XKS: Helm install)"]
        COO["Cluster Observability<br/>Operator"]
        LWS["LeaderWorkerSet<br/>(XKS: Helm install)"]
    end

    %% ── Managed Components (16) ──
    subgraph Components["Managed AI/ML Components (16)"]
        Dashboard["Dashboard"]
        KServe["KServe"]
        DSP["Data Science Pipelines"]
        ModelReg["Model Registry"]
        KubeRay["KubeRay"]
        Kueue["Kueue"]
        TrainingOp["Training Operator"]
        Trainer["Trainer (v2)"]
        TrustyAI["TrustyAI"]
        Feast["Feast Operator"]
        Spark["Spark Operator"]
        OGX["OGX"]
        MLflow["MLflow Operator"]
        MaaS["MaaS Controller"]
        ModelCtrl["Model Controller"]
        Workbenches["Workbenches"]
    end

    %% ── External Services ──
    subgraph ExternalSvc["External Services"]
        OAuth["OpenShift OAuth<br/>443/TCP HTTPS"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS"]
        Segment["Segment.IO<br/>443/TCP HTTPS"]
    end

    %% ── Operator → Infrastructure ──
    RhodsOp -->|"controller framework"| ControllerRT
    RhodsOp -->|"ingress management"| GatewayAPI
    RhodsOp -->|"Routes, OAuth, Infra"| OCP_API
    RhodsOp -->|"Subscription, CSV"| OLM_API
    RhodsOp -->|"kustomize rendering"| ManifestKit
    RhodsOp -->|"Helm rendering (XKS)"| HelmRenderer
    RhodsOp -->|"monitoring CRDs"| PromOperator
    RhodsOp -->|"all resource CRUD"| K8sAPI

    %% ── Operator → Platform Services ──
    RhodsOp -->|"gateway data plane<br/>EnvoyFilter + DestinationRule"| Istio
    RhodsOp -->|"TLS certs (XKS Helm)"| CertMgr
    RhodsOp -->|"MonitoringStack<br/>ThanosQuerier CRs"| COO
    RhodsOp -->|"LWS operator (XKS Helm)"| LWS

    %% ── Operator → Components (Kustomize deploy) ──
    RhodsOp -->|"kustomize deploy"| Dashboard
    RhodsOp -->|"kustomize deploy"| KServe
    RhodsOp -->|"kustomize deploy"| DSP
    RhodsOp -->|"kustomize deploy"| ModelReg
    RhodsOp -->|"kustomize deploy"| KubeRay
    RhodsOp -->|"kustomize deploy"| Kueue
    RhodsOp -->|"kustomize deploy"| TrainingOp
    RhodsOp -->|"kustomize deploy"| Trainer
    RhodsOp -->|"kustomize deploy"| TrustyAI
    RhodsOp -->|"kustomize deploy"| Feast
    RhodsOp -->|"kustomize deploy"| Spark
    RhodsOp -->|"kustomize deploy"| OGX
    RhodsOp -->|"kustomize deploy"| MLflow
    RhodsOp -->|"kustomize deploy"| MaaS
    RhodsOp -->|"kustomize deploy"| ModelCtrl
    RhodsOp -->|"kustomize deploy"| Workbenches

    %% ── Operator → External Services ──
    RhodsOp -->|"OAuth2 (gateway auth)"| OAuth
    RhodsOp -.->|"OIDC (when configured)"| OIDC
    RhodsOp -.->|"telemetry (Self-Managed)"| Segment

