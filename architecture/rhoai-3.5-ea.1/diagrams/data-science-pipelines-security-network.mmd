graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist<br/>Dashboard"]
    end

    subgraph APILayer["API LAYER (Core Services)"]
        direction TB
        APIServer["ml-pipeline API Server<br/>SA: ml-pipeline<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP Webhook<br/>FIPS: strictfipsruntime<br/>Auth: Bearer Token / HTTP Header → SAR"]
        Frontend["ml-pipeline-ui Frontend<br/>SA: ml-pipeline-ui-sa<br/>3000/TCP HTTP<br/>Auth: upstream proxy"]
        VisServer["Visualization Server<br/>8888/TCP HTTP<br/>Auth: None"]
    end

    subgraph Controllers["CONTROLLER LAYER"]
        direction TB
        PA["Persistence Agent<br/>SA: ml-pipeline-persistenceagent-sa<br/>No ports exposed<br/>FIPS: strictfipsruntime"]
        SWC["Scheduled Workflow Controller<br/>SA: ml-pipeline-scheduledworkflow-sa<br/>9090/TCP Prometheus<br/>FIPS: strictfipsruntime"]
    end

    subgraph Execution["EXECUTION LAYER (Ephemeral Argo Task Pods)"]
        direction TB
        Driver["Driver<br/>SA: pipeline-runner-sa<br/>No ports (CLI)<br/>FIPS: strictfipsruntime"]
        Launcher["Launcher<br/>SA: pipeline-runner-sa<br/>No ports (CLI sidecar)<br/>FIPS: dual binary"]
    end

    subgraph DataLayer["DATA LAYER (Stateful)"]
        direction TB
        MySQL["MySQL/PostgreSQL<br/>3306/5432 TCP<br/>Encryption: None (in-cluster)<br/>Auth: username/password"]
        S3["SeaweedFS/MinIO<br/>8333/9000 TCP HTTP (S3)<br/>Encryption: None (in-cluster)<br/>Auth: access key/secret key"]
        MLMD["metadata-grpc-service<br/>8080/TCP gRPC<br/>Encryption: Optional TLS<br/>Auth: None"]
        Envoy["metadata-envoy-service<br/>9090/TCP HTTP<br/>Encryption: None"]
    end

    subgraph Webhooks["WEBHOOK SERVICES"]
        CacheServer["cache-server<br/>MutatingWebhook<br/>443/TCP HTTPS TLS<br/>Auth: K8s API cert"]
    end

    subgraph K8sInfra["KUBERNETES INFRASTRUCTURE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>TokenReview / SubjectAccessReview"]
        ArgoCtrl["Argo Workflows Controller<br/>Executes Workflow CRs"]
    end

    subgraph CloudStorage["EXTERNAL SERVICES (Optional)"]
        AWS["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA credentials"]
    end

    %% External → API Layer
    User -->|"HTTP/8888<br/>Optional TLS<br/>Bearer Token / HTTP Header"| APIServer
    User -->|"HTTP/3000<br/>via auth proxy"| Frontend

    %% API Server → Data Layer
    APIServer -->|"MySQL/PG / 3306-5432<br/>None (in-cluster)<br/>username/password"| MySQL
    APIServer -->|"HTTP(S3)/8333<br/>None (in-cluster)<br/>access key/secret"| S3
    APIServer -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD

    %% API Server → K8s
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA token<br/>Workflow CRUD + SAR + TokenReview"| K8sAPI
    APIServer -->|"HTTPS/8443<br/>mTLS<br/>PipelineVersion webhook"| K8sAPI

    %% Frontend → Metadata
    Frontend -->|"HTTP/9090<br/>None"| Envoy
    Envoy -->|"gRPC→HTTP proxy"| MLMD

    %% Controllers → API & K8s
    PA -->|"HTTP/8888<br/>Optional TLS<br/>Projected SA Token (1h)"| APIServer
    PA -->|"HTTPS/443 Watch<br/>TLS<br/>SA token"| K8sAPI
    SWC -->|"gRPC/8887<br/>Optional TLS<br/>Projected SA Token (1h)"| APIServer
    SWC -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Execution → Services
    Driver -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Driver -->|"gRPC/8887<br/>Optional TLS<br/>cache lookup"| APIServer
    Driver -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    Launcher -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Launcher -->|"gRPC/8887<br/>Optional TLS<br/>cache register"| APIServer
    Launcher -->|"HTTP(S3)/8333<br/>Secret mount<br/>artifact up/download"| S3

    %% Optional cloud storage
    Launcher -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA creds"| AWS
    Launcher -.->|"HTTPS/443<br/>TLS 1.2+<br/>SA creds"| GCS

    %% Argo
    K8sAPI -->|"Workflow CR"| ArgoCtrl
    ArgoCtrl -->|"creates task pods"| Driver

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef api fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef controller fill:#e8d5f5,stroke:#8b5cf6,stroke-width:2px
    classDef execution fill:#d1fae5,stroke:#10b981,stroke-width:2px
    classDef data fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef webhook fill:#fee2e2,stroke:#ef4444,stroke-width:2px
    classDef k8s fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    classDef cloud fill:#fff7ed,stroke:#ea580c,stroke-width:2px

    class User external
    class APIServer,Frontend,VisServer api
    class PA,SWC controller
    class Driver,Launcher execution
    class MySQL,S3,MLMD,Envoy data
    class CacheServer webhook
    class K8sAPI,ArgoCtrl k8s
    class AWS,GCS cloud
