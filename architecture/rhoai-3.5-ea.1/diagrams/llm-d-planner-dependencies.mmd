graph LR
    Planner["llm-d Planner<br/>FastAPI + Streamlit"]

    %% Infrastructure Dependencies (co-deployed)
    Planner -->|"DB queries<br/>PostgreSQL/5432"| PostgreSQL["PostgreSQL 16<br/>(co-deployed)"]
    Planner -->|"LLM inference<br/>HTTP/11434"| Ollama["Ollama<br/>(co-deployed)"]

    %% External Service Dependencies
    Planner -->|"model metadata<br/>HTTPS/443"| HuggingFace["HuggingFace Hub API"]
    Planner -->|"deploy + GPU discovery<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]

    %% Internal RHOAI Dependencies (optional)
    Planner -.->|"benchmark sync<br/>HTTPS/8443"| ModelCatalog["RHOAI Model Catalog<br/>(optional)"]

    %% Build-time Dependencies
    Planner -->|"roofline estimation<br/>Python library"| LLMOptimizer["BentoML llm-optimizer<br/>(build-time)"]

    %% Generated CRD Targets
    Planner -->|"generates CRDs"| KServe["KServe<br/>InferenceService v1beta1"]
    Planner -->|"generates HPA"| HPA["HPA<br/>autoscaling/v2"]
    Planner -->|"generates"| ServiceMonitor["ServiceMonitor<br/>Prometheus"]
    Planner -->|"generates"| GrafanaDash["Grafana Dashboard<br/>ConfigMap"]

    %% Runtime Dependencies
    KServe -->|"serves with"| vLLM["vLLM Runtime"]
    Planner -.->|"dev simulator<br/>HTTP/8080"| Simulator["vLLM Simulator<br/>(dev only)"]

    %% Platform Integration (reads)
    Planner -->|"GPU node labels<br/>read-only"| NVIDIAOperator["NVIDIA GPU Operator"]

    %% Key Library Dependencies
    Planner -->|"API framework"| FastAPI["FastAPI >=0.136.1"]
    Planner -->|"UI framework"| Streamlit["Streamlit 1.57.0"]
    Planner -->|"model config"| Transformers["transformers >=5.7.0"]
    Planner -->|"template engine"| Jinja2["Jinja2 3.1.6"]

    %% Styling
    style Planner fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#7c3aed,stroke:#333,color:#fff
    style HuggingFace fill:#ff9d00,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style ModelCatalog fill:#ee0000,stroke:#333,color:#fff
    style KServe fill:#ee0000,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333
    style Simulator fill:#999,stroke:#333,stroke-dasharray:5
    style NVIDIAOperator fill:#76b900,stroke:#333,color:#fff
    style LLMOptimizer fill:#f5a623,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333
    style GrafanaDash fill:#7ed321,stroke:#333
    style FastAPI fill:#e8e8e8,stroke:#333
    style Streamlit fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style Jinja2 fill:#e8e8e8,stroke:#333
