graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator)"]
        SA_MLflow["mlflow-sa<br/>(deployed workload)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(cluster-scoped)"]
        CRB_MLflow["mlflow-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Manager["manager-rolebinding<br/>(target namespace)"]
        RB_Leader["leader-election-rolebinding<br/>(target namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Metrics["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
        CR_MLflow["mlflow<br/>(deployed workload)"]
    end

    subgraph NamespacedRoles["Namespace-scoped Roles"]
        R_Manager["manager-role<br/>(Role)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph AggregateRoles["Aggregate Roles (extend built-in)"]
        AR_View["mlflow-view<br/>(→ view role)"]
        AR_Edit["mlflow-edit<br/>(→ edit/admin roles)"]
        AR_Integration["mlflow-integration"]
    end

    subgraph ManagerClusterResources["manager-role ClusterRole Resources"]
        Res_MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
        Res_NS["core<br/>namespaces<br/>▸ get,list,watch"]
        Res_Secrets_Named["core<br/>secrets (mlflow-artifact-connection)<br/>▸ get,list,watch"]
        Res_ConsoleLinks["console.openshift.io<br/>consolelinks<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
        Res_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
        Res_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>▸ get,list,watch"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph ManagerNSResources["manager-role Role Resources"]
        Res_Core["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>▸ full CRUD"]
        Res_Apps["apps<br/>deployments<br/>▸ full CRUD"]
        Res_NetPol["networking.k8s.io<br/>networkpolicies<br/>▸ full CRUD"]
        Res_SvcMon["monitoring.coreos.com<br/>servicemonitors<br/>▸ full CRUD"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        Res_LeaderCM["core<br/>configmaps, events<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
        Res_Leases["coordination.k8s.io<br/>leases<br/>▸ get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph MetricsResources["metrics-auth-role Resources"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>▸ create"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>▸ create"]
    end

    %% Operator SA bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Metrics
    SA_CM -->|bound via| RB_Manager
    SA_CM -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    RB_Manager -->|grants| R_Manager
    RB_Leader -->|grants| R_Leader

    %% MLflow SA bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow

    %% ClusterRole → Resources
    CR_Manager --> Res_MLflows
    CR_Manager --> Res_NS
    CR_Manager --> Res_Secrets_Named
    CR_Manager --> Res_ConsoleLinks
    CR_Manager --> Res_HTTPRoutes
    CR_Manager --> Res_MLflowConfigs
    CR_Manager --> Res_RBAC

    %% Namespace Role → Resources
    R_Manager --> Res_Core
    R_Manager --> Res_Apps
    R_Manager --> Res_NetPol
    R_Manager --> Res_SvcMon

    %% Leader election → Resources
    R_Leader --> Res_LeaderCM
    R_Leader --> Res_Leases

    %% Metrics → Resources
    CR_Metrics --> Res_TokenReview
    CR_Metrics --> Res_SAR

