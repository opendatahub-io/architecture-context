    style R_Leader fill:#f5a623,color:#fff
    style AR_View fill:#d4a623,color:#fff
    style AR_Edit fill:#d4a623,color:#fff
    style AR_Integration fill:#d4a623,color:#fff
    style Res_MLflows fill:#7ed321,color:#fff
    style Res_NS fill:#7ed321,color:#fff
    style Res_Secrets_Named fill:#7ed321,color:#fff
    style Res_ConsoleLinks fill:#7ed321,color:#fff
