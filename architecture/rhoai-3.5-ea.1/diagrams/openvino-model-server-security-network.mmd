graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist"]
    end

    subgraph PlatformAuth["PLATFORM AUTH BOUNDARY"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP → REST port/TCP<br/>TLS Termination<br/>K8s RBAC Token Review"]
    end

    subgraph MeshLayer["SERVICE MESH (Optional)"]
        IstioSidecar["Istio Sidecar Proxy<br/>Transparent mTLS<br/>SPIFFE Identity"]
    end

    subgraph OVMSContainer["OVMS CONTAINER (No built-in TLS)"]
        direction TB

        subgraph RESTServer["REST Server (Drogon)"]
            REST["DrogonHttpServer<br/>configurable/TCP HTTP<br/>Bearer Token (optional via --api_key_file)"]
            Metrics["/metrics endpoint<br/>No auth, Prometheus"]
            Health["/v2/health/* endpoints<br/>No auth"]
        end

        subgraph GRPCServer["gRPC Server"]
            GRPC["GRPCServerModule<br/>configurable/TCP gRPC/HTTP2<br/>InsecureServerCredentials<br/>NO authentication"]
        end

        Engine["Inference Engine<br/>OpenVINO Runtime + GenAI"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS<br/>AWS IAM Credentials"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS<br/>Connection String"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS<br/>Application Credentials"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS TLS<br/>HF Token (libgit2 + curl)"]
        LocalFS["Local/Mounted Filesystem<br/>PVC / emptyDir"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS<br/>Bearer/OAuth"| KubeRBAC
    KubeRBAC -->|"HTTP/configurable<br/>Plaintext (pod-internal)<br/>Auth validated"| REST
    IstioSidecar -.->|"mTLS (when enabled)<br/>SPIFFE Identity"| OVMSContainer
    Client -->|"gRPC (if direct)<br/>InsecureCredentials<br/>No Auth"| GRPC

    %% Internal flows
    REST --> Engine
    GRPC --> Engine

    %% Egress flows
    Engine -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    Engine -->|"HTTPS/443<br/>TLS<br/>Conn String"| Azure
    Engine -->|"HTTPS/443<br/>TLS<br/>Google Creds"| GCS
    Engine -->|"HTTPS/443<br/>TLS<br/>HF Token"| HFHub
    Engine -->|"Local I/O"| LocalFS

    %% Monitoring
    Prometheus -->|"HTTP/configurable<br/>No Auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authboundary fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef mesh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef noauth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class KubeRBAC authboundary
    class IstioSidecar mesh
    class REST,Health container
    class GRPC noauth
    class Metrics container
    class Engine container
    class S3,Azure,GCS,HFHub,LocalFS externalservice
    class Prometheus monitoring
