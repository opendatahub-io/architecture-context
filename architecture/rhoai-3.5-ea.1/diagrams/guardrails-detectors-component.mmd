graph TB
    subgraph "Guardrails Detectors"
        subgraph CommonLib["Common Library"]
            BaseAPI["DetectorBaseAPI<br/>(FastAPI Base Class)"]
            Schemas["Pydantic Schemas<br/>(ContentAnalysisRequest/Response)"]
            Metrics["Prometheus Instrumentation<br/>(trustyai_guardrails_*)"]
            Logging["Logging Configuration"]
        end

        subgraph BuiltIn["Built-in Detector<br/>Port: 8080/TCP"]
            BuiltInApp["FastAPI App"]
            Registry["BaseDetectorRegistry"]
            RegexDet["Regex Detectors<br/>(email, CC, SSN, phone, IP)"]
            FileTypeDet["File Type Detectors<br/>(JSON, YAML, XML + schema)"]
            CustomDet["Custom Detectors<br/>(User Python code, AST-validated)"]
            BuiltInApp --> Registry
            Registry --> RegexDet
            Registry --> FileTypeDet
            Registry --> CustomDet
        end

        subgraph HFDetector["HuggingFace Runtime Detector<br/>Port: 8000/TCP"]
            HFApp["FastAPI App"]
            SeqClass["AutoModelForSequenceClassification"]
            TokClass["AutoModelForTokenClassification"]
            GraniteLM["GraniteForCausalLM"]
            HFApp --> SeqClass
            HFApp --> TokClass
            HFApp --> GraniteLM
        end

        subgraph JudgeDetector["LLM Judge Detector<br/>Port: 8000/TCP"]
            JudgeApp["FastAPI App"]
            VLLMJudge["vllm_judge Library<br/>(safety, toxicity, helpfulness, etc.)"]
            JudgeApp --> VLLMJudge
        end

        BuiltInApp -.->|extends| BaseAPI
        HFApp -.->|extends| BaseAPI
        JudgeApp -.->|extends| BaseAPI
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| JudgeApp

    S3["S3/MinIO<br/>Model Storage"] -.->|model weights<br/>9000/TCP| HFDetector
    VLLMServer["vLLM Inference Server"] -.->|OpenAI API<br/>8080/TCP| VLLMJudge

    KServe["KServe<br/>InferenceService"] -->|deploys| HFDetector
    KServe -->|deploys| JudgeDetector
    Istio["Istio Service Mesh"] -->|sidecar mTLS| BuiltIn
    Istio -->|sidecar mTLS| HFDetector
    Istio -->|sidecar mTLS| JudgeDetector

    Prometheus["Prometheus"] -.->|scrapes /metrics| BuiltInApp
    Prometheus -.->|scrapes /metrics| HFApp
    Prometheus -.->|scrapes /metrics| JudgeApp

    style BaseAPI fill:#4a90e2,stroke:#333,color:#fff
    style Schemas fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style Logging fill:#4a90e2,stroke:#333,color:#fff
    style BuiltInApp fill:#7ed321,stroke:#333,color:#fff
    style HFApp fill:#7ed321,stroke:#333,color:#fff
    style JudgeApp fill:#7ed321,stroke:#333,color:#fff
    style Registry fill:#9b59b6,stroke:#333,color:#fff
    style RegexDet fill:#9b59b6,stroke:#333,color:#fff
    style FileTypeDet fill:#9b59b6,stroke:#333,color:#fff
    style CustomDet fill:#9b59b6,stroke:#333,color:#fff
    style SeqClass fill:#e67e22,stroke:#333,color:#fff
    style TokClass fill:#e67e22,stroke:#333,color:#fff
    style GraniteLM fill:#e67e22,stroke:#333,color:#fff
    style VLLMJudge fill:#e74c3c,stroke:#333,color:#fff
    style Orchestrator fill:#f5a623,stroke:#333
    style S3 fill:#999,stroke:#333,color:#fff
    style VLLMServer fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
