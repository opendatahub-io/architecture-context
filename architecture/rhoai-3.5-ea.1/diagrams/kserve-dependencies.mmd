graph LR
    KServe["KServe<br/>(Multi-Controller Operator)"]

    %% External Dependencies (Required)
    KServe -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.20.4"]

    %% External Dependencies (Optional)
    KServe -->|"serverless mode"| Knative["Knative Serving<br/>v1"]
    KServe -->|"VirtualService routing<br/>mTLS, DestinationRules"| Istio["Istio / Service Mesh<br/>v1beta1"]
    KServe -->|"HTTPRoute ingress<br/>(RHOAI 3.x primary)"| GatewayAPI["Gateway API<br/>v1"]
    KServe -->|"event-driven autoscaling"| KEDA["KEDA<br/>v1alpha1"]
    KServe -->|"webhook TLS certs<br/>(non-OCP)"| CertManager["cert-manager<br/>v1"]
    KServe -->|"PodMonitor/ServiceMonitor"| PromOperator["Prometheus Operator<br/>v1"]
    KServe -->|"multi-node LLM workloads"| LWS["LeaderWorkerSet<br/>v1"]
    KServe -->|"LLM autoscaling"| WVA["WVA Controller<br/>llmd.ai v1alpha1"]
    KServe -->|"scheduler-based LB"| InfExtAPI["Inference Extension API<br/>v1/v1alpha2"]
    KServe -->|"auth precondition<br/>(OCP only)"| Kuadrant["Kuadrant<br/>v1"]

    %% Internal RHOAI Dependencies
    RhodsOp["rhods-operator"] -->|"deploys via<br/>Kustomize manifests"| KServe
    OdhOp["opendatahub-operator"] -->|"deploys via<br/>Kustomize manifests"| KServe
    KServe -.->|"reads CA certs<br/>(OCP)"| ServiceCA["OpenShift service-ca"]
    KServe -.->|"reads URL status<br/>(OCP)"| OCPRoutes["OpenShift Routes"]
    KServe -.->|"central config"| ISVCConfig["inferenceservice-config<br/>ConfigMap"]

    %% External Cloud Services
    KServe -->|"model download<br/>HTTPS/443 IAM"| S3["Amazon S3"]
    KServe -->|"model download<br/>HTTPS/443 ADC"| GCS["Google Cloud Storage"]
    KServe -->|"model download<br/>HTTPS/443 SP/SAS"| Azure["Azure Blob Storage"]
    KServe -->|"model download<br/>HTTPS/443 Token"| HF["HuggingFace Hub"]
    KServe -->|"model download<br/>HTTP 50070 Kerberos"| HDFS["HDFS"]
    KServe -->|"autoscaling metrics<br/>HTTPS Bearer"| Prom["Prometheus"]

    %% Peer Components (Integration Points)
    KServe -->|"creates Knative<br/>Services"| KnativeSvc["Knative Services"]
    KServe -->|"creates VirtualServices<br/>DestinationRules"| IstioRes["Istio Resources"]
    KServe -->|"creates HTTPRoutes<br/>Gateways"| GWRes["Gateway API Resources"]
    KServe -->|"creates InferencePools"| IPools["InferencePools"]
    KServe -->|"creates VariantAutoscalings"| VWARes["WVA Resources"]
    KServe -->|"creates ScaledObjects"| KEDARes["KEDA Resources"]
    KServe -->|"creates LeaderWorkerSets"| LWSRes["LWS Resources"]
    KServe -->|"creates PodMonitors<br/>ServiceMonitors"| MonRes["Monitoring Resources"]

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required dependency
    style CtrlRuntime fill:#2c3e50,stroke:#333,color:#fff

    %% External optional dependencies
    style Knative fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style PromOperator fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style WVA fill:#999,stroke:#333,color:#fff
    style InfExtAPI fill:#999,stroke:#333,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style OdhOp fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style OCPRoutes fill:#7ed321,stroke:#333,color:#fff
    style ISVCConfig fill:#7ed321,stroke:#333,color:#fff

    %% Cloud services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style HF fill:#f5a623,stroke:#333,color:#fff
    style HDFS fill:#f5a623,stroke:#333,color:#fff
    style Prom fill:#bd10e0,stroke:#333,color:#fff

    %% Created resources
    style KnativeSvc fill:#ddd,stroke:#666,color:#333
    style IstioRes fill:#ddd,stroke:#666,color:#333
    style GWRes fill:#ddd,stroke:#666,color:#333
    style IPools fill:#ddd,stroke:#666,color:#333
    style VWARes fill:#ddd,stroke:#666,color:#333
    style KEDARes fill:#ddd,stroke:#666,color:#333
    style LWSRes fill:#ddd,stroke:#666,color:#333
    style MonRes fill:#ddd,stroke:#666,color:#333
