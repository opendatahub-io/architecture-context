graph TB
    subgraph External["EXTERNAL (Internal Network)"]
        Kafka["Internal Kafka Cluster<br/>CDC Topics<br/>9092/TCP (dev) · 9096/TCP (prod)<br/>SASL_SSL · SCRAM-SHA-512"]
    end

    subgraph OfflineEnv["OFFLINE ENVIRONMENT (Not Deployed to Cluster)"]
        direction TB
        KafkaProcessor["kafka-processor<br/>Python 3.12 CLI<br/>No network listeners<br/>confluent-kafka + librdkafka"]
        LocalFS["Local Filesystem<br/>data/ directory<br/>provider/model hierarchy<br/>JSON · NDJSON"]
    end

    subgraph Cluster["CLUSTER (Namespace: odh-model-registries)"]
        direction TB

        subgraph Pod["model-catalog Pod"]
            direction TB

            subgraph InitPhase["Init Phase"]
                InitContainer["Init Container<br/>odh-model-performance-data<br/>Image: odh-model-performance-data-rhel9<br/>Base: UBI9-minimal<br/>No listeners · No processes"]
            end

            SharedVolume["Shared Volume<br/>/app/benchmarks<br/>Benchmark Data Files"]

            subgraph MainPhase["Main Phase"]
                ModelCatalog["model-catalog<br/>Main Container<br/>Reads benchmark data"]
            end
        end

        Operator["model-registry-operator<br/>Manages Deployment spec"]
    end

    subgraph BuildSystem["BUILD SYSTEM (Konflux)"]
        ContainerBuild["Container Image Build<br/>Dockerfile.konflux<br/>COPY data/ → /app/benchmarks"]
        ImageRegistry["Image Registry<br/>odh-model-performance-data-rhel9"]
    end

    %% Offline data flow
    Kafka -->|"Kafka/9092 or 9096<br/>TLS (SASL_SSL)<br/>SCRAM-SHA-512<br/>Optional mTLS"| KafkaProcessor
    KafkaProcessor -->|"Filesystem<br/>No network"| LocalFS

    %% Build flow
    LocalFS -->|"COPY"| ContainerBuild
    ContainerBuild -->|"Push"| ImageRegistry

    %% Runtime flow
    ImageRegistry -.->|"Image pull"| InitContainer
    InitContainer -->|"Volume mount<br/>No network"| SharedVolume
    SharedVolume -->|"Volume mount<br/>No network"| ModelCatalog

    %% Operator management
    Operator -.->|"Manages init container<br/>image reference"| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef offline fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef build fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef data fill:#f5a623,stroke:#333,stroke-width:1px
    classDef confidential fill:#ff6b6b,stroke:#c0392b,stroke-width:2px

    class Kafka external
    class KafkaProcessor offline
    class LocalFS data
    class InitContainer,ModelCatalog,Operator cluster
    class ContainerBuild,ImageRegistry build
    class SharedVolume data
