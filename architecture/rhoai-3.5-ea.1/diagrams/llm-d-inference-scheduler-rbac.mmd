graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>ServiceAccount<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["${EPP_NAME}-binding<br/>RoleBinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role["${EPP_NAME}<br/>Role<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph GIE_Resources["GIE Resources (inference.networking.x-k8s.io)"]
        InferencePools_legacy["InferencePools<br/>(x-k8s.io)"]
        InferenceObjectives["InferenceObjectives"]
        InferenceModelRewrites["InferenceModelRewrites"]
    end

    subgraph GIE_GA_Resources["GIE Resources (inference.networking.k8s.io)"]
        InferencePools_ga["InferencePools<br/>(k8s.io GA)"]
    end

    subgraph Core_Resources["Core API Resources"]
        Pods["Pods"]
    end

    subgraph Auth_Resources["Authentication & Authorization APIs"]
        TokenReviews["TokenReviews<br/>(authentication.k8s.io)"]
        SubjectAccessReviews["SubjectAccessReviews<br/>(authorization.k8s.io)"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB
    RB -->|"grants"| Role

    %% GIE x-k8s.io permissions
    Role -->|"get, watch, list"| InferencePools_legacy
    Role -->|"get, watch, list"| InferenceObjectives
    Role -->|"get, watch, list"| InferenceModelRewrites

    %% GIE k8s.io GA permissions
    Role -->|"get, watch, list"| InferencePools_ga

    %% Core permissions
    Role -->|"get, watch, list"| Pods

    %% Auth permissions
    Role -->|"create"| TokenReviews
    Role -->|"create"| SubjectAccessReviews

    %% Styling
    style SA_EPP fill:#4a90e2,color:#fff
    style RB fill:#9b59b6,color:#fff
    style Role fill:#f5a623,color:#fff
    style InferencePools_legacy fill:#7ed321,color:#fff
    style InferenceObjectives fill:#7ed321,color:#fff
    style InferenceModelRewrites fill:#7ed321,color:#fff
    style InferencePools_ga fill:#7ed321,color:#fff
    style Pods fill:#3498db,color:#fff
    style TokenReviews fill:#e74c3c,color:#fff
    style SubjectAccessReviews fill:#e74c3c,color:#fff
