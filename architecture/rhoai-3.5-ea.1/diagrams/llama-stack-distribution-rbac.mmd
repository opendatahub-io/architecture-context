graph TD
    subgraph Note["Note: No Kubernetes RBAC"]
        direction TB
        Info["This is a container image, not an operator.<br/>No ClusterRoles, Roles, or RoleBindings defined.<br/>Authorization is handled at two layers:"]
    end

    subgraph PlatformAuth["Platform-Level Authorization"]
        direction TB
        GatewayAuth["RHOAI Gateway (Envoy)<br/>JWT validation at ingress"]
        KRBPAuth["kube-rbac-proxy sidecar<br/>Kubernetes RBAC-based authorization<br/>Service account token verification"]
        GatewayAuth --> KRBPAuth
    end

    subgraph AppAuth["Application-Level Authorization (OGX Auth Middleware)"]
        direction TB
        AuthConfig["Configuration:<br/>AUTH_ISSUER (OAuth2 issuer URL)<br/>AUTH_AUDIENCE (default: ogx)<br/>AUTH_JWKS_URI (JWKS endpoint)<br/>AUTH_VERIFY_TLS (default: true)"]

        subgraph Policies["Access Policies"]
            direction LR
            SystemRes["System Resources<br/>(models, health)<br/>🔓 All users: READ"]
            UserRes["User Resources<br/>(new sessions, batches)<br/>🔐 Authenticated: CREATE"]
            OwnedRes["Owned Resources<br/>(conversations, files)<br/>🔒 Owner only:<br/>READ, UPDATE, DELETE"]
        end

        AuthConfig --> Policies
    end

    subgraph Secrets["Secrets (Environment Variables)"]
        direction TB
        subgraph RuntimeSecrets["Runtime Secrets"]
            VLLMToken["VLLM_API_TOKEN<br/>Bearer token for vLLM inference"]
            VLLMEmbedToken["VLLM_EMBEDDING_API_TOKEN<br/>Bearer token for vLLM embedding"]
            PGPassword["POSTGRES_PASSWORD<br/>PostgreSQL authentication"]
            CloudKeys["Cloud Provider Keys (optional)<br/>AWS_BEARER_TOKEN_BEDROCK<br/>WATSONX_API_KEY<br/>AZURE_API_KEY<br/>OPENAI_API_KEY"]
            VectorKeys["Vector DB Keys (optional)<br/>MILVUS_TOKEN<br/>Qdrant API key"]
            ToolKeys["Tool API Keys (optional)<br/>BRAVE_SEARCH_API_KEY<br/>TAVILY_SEARCH_API_KEY"]
        end

        subgraph BuildSecrets["Build-Time Secrets (Konflux)"]
            GitAuth["git_auth_secret<br/>kubernetes.io/basic-auth<br/>Tekton Git authentication"]
            RHAIIndex["rhel-ai-private-index-auth<br/>Opaque<br/>RHAI private PyPI index"]
            RHELSub["rhel-subscription-activation-key<br/>Opaque<br/>RHEL subscription"]
        end
    end

    KRBPAuth -->|"proxied request"| AppAuth

    style Note fill:#f0f0f0,stroke:#ccc,stroke-width:1px
    style Info fill:#fff,stroke:#ccc
    style GatewayAuth fill:#ffe6cc,stroke:#d79b00
    style KRBPAuth fill:#ffe6cc,stroke:#d79b00
    style AuthConfig fill:#dae8fc,stroke:#6c8ebf
    style SystemRes fill:#d5e8d4,stroke:#82b366
    style UserRes fill:#fff2cc,stroke:#d6b656
    style OwnedRes fill:#f8cecc,stroke:#b85450
    style VLLMToken fill:#e1d5e7,stroke:#9673a6
    style VLLMEmbedToken fill:#e1d5e7,stroke:#9673a6
    style PGPassword fill:#e1d5e7,stroke:#9673a6
    style CloudKeys fill:#e1d5e7,stroke:#9673a6
    style VectorKeys fill:#e1d5e7,stroke:#9673a6
    style ToolKeys fill:#e1d5e7,stroke:#9673a6
    style GitAuth fill:#f0e6ff,stroke:#9673a6
    style RHAIIndex fill:#f0e6ff,stroke:#9673a6
    style RHELSub fill:#f0e6ff,stroke:#9673a6
