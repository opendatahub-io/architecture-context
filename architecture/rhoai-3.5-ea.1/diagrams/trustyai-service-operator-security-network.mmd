graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        TASRoute["TAS Route<br/>443/TCP reencrypt TLS<br/>Auth: Bearer Token (SAR)"]
        GORCHRoute["GORCH Orchestrator Route<br/>443/TCP reencrypt TLS<br/>Auth: Bearer Token (SAR)"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP edge/reencrypt<br/>Auth: SAR (conditional)"]
        GORCHDetRoute["GORCH Detector Route<br/>443/TCP edge/reencrypt<br/>Auth: SAR (conditional)"]
        EvalHubRoute["EvalHub Route<br/>443/TCP reencrypt TLS<br/>Auth: Bearer Token (SAR)"]
        NemoRoute["NeMo Route<br/>443/TCP edge/reencrypt<br/>Auth: SAR (conditional)"]
    end

    subgraph Internal["INTERNAL SERVICES (ClusterIP)"]
        direction TB

        subgraph TAS_NS["TrustyAI Service"]
            TAS_Proxy["kube-rbac-proxy<br/>8443/TCP TLS 1.2+<br/>FIPS ciphers<br/>SAR enforcement"]
            TAS_App["TAS Application<br/>8080/TCP, 4443/TCP"]
        end

        subgraph GORCH_NS["Guardrails Orchestrator"]
            GORCH_Proxy["kube-rbac-proxy<br/>8432/TCP (orch)<br/>8490/TCP (gateway)<br/>8480/TCP (detector)"]
            GORCH_App["Orchestrator<br/>8032/TCP HTTPS"]
            GORCH_Health["Health Endpoint<br/>9443/TCP"]
        end

        subgraph EH_NS["EvalHub"]
            EH_App["EvalHub Application<br/>8443/TCP HTTPS<br/>OpenShift serving cert<br/>Internal SAR checks"]
        end

        subgraph Nemo_NS["NeMo Guardrails"]
            Nemo_Proxy["kube-rbac-proxy<br/>8443/TCP (conditional)"]
            Nemo_App["NeMo Server"]
        end

        subgraph Operator_NS["Operator Manager"]
            OpMgr["Operator Manager<br/>8080/TCP metrics (HTTP, no auth)<br/>8081/TCP health (HTTP, no auth)"]
        end

        subgraph LMES_NS["LMEvalJob Pods (Ephemeral)"]
            LMPod["LMEval Pod<br/>driver: 18080/TCP internal<br/>Status via pods/exec"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token"]
        KServeEP["KServe InferenceService<br/>8443/TCP HTTPS (Raw)<br/>80/TCP HTTP (Serverless)"]
        PgSQL["PostgreSQL<br/>configurable/TCP<br/>TLS optional<br/>Username/Password"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>HF_TOKEN"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Registry creds"]
        LLM["Target LLM<br/>varies HTTP/HTTPS<br/>API key/token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| TASRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHGWRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHDetRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| EvalHubRoute
    Client -->|"HTTPS/443<br/>TLS"| NemoRoute

    %% Ingress to Internal
    TASRoute -->|"HTTPS/8443<br/>reencrypt"| TAS_Proxy
    GORCHRoute -->|"HTTPS/8432<br/>reencrypt"| GORCH_Proxy
    GORCHGWRoute -->|"HTTPS/8490<br/>reencrypt"| GORCH_Proxy
    GORCHDetRoute -->|"HTTPS/8480<br/>reencrypt"| GORCH_Proxy
    EvalHubRoute -->|"HTTPS/8443<br/>reencrypt"| EH_App
    NemoRoute -->|"HTTPS/8443<br/>reencrypt"| Nemo_Proxy

    %% Proxy to App
    TAS_Proxy -->|"HTTP/8080"| TAS_App
    GORCH_Proxy -->|"HTTPS/8032"| GORCH_App
    Nemo_Proxy --> Nemo_App

    %% Internal to External
    OpMgr -->|"HTTPS/443<br/>SA Token"| K8sAPI
    TAS_App -->|"HTTPS/8443 or HTTP/80"| KServeEP
    TAS_App -->|"JDBC<br/>TLS optional"| PgSQL
    EH_App -->|"JDBC<br/>TLS optional"| PgSQL
    EH_App -->|"HTTPS/443<br/>SA Token"| K8sAPI
    GORCH_App -->|"HTTP/HTTPS<br/>TLS configurable"| LLM
    LMPod -->|"HTTPS/443<br/>HF_TOKEN"| HF
    LMPod -->|"HTTPS/443<br/>AWS IAM"| S3
    LMPod -->|"HTTPS/443<br/>Registry creds"| OCIReg
    LMPod -->|"HTTP/HTTPS<br/>API key"| LLM

    %% Prometheus scrape
    Prom["Prometheus"] -->|"HTTP/8080<br/>ServiceMonitor"| OpMgr
    Prom -->|"HTTP/8080<br/>ServiceMonitor"| TAS_App

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef proxy fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class TASRoute,GORCHRoute,GORCHGWRoute,GORCHDetRoute,EvalHubRoute,NemoRoute ingress
    class TAS_App,GORCH_App,GORCH_Health,EH_App,Nemo_App,OpMgr,LMPod internal
    class TAS_Proxy,GORCH_Proxy,Nemo_Proxy proxy
    class K8sAPI,KServeEP,PgSQL,HF,S3,OCIReg,LLM,Prom extsvc
