graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe-Managed)"]
        KServeIngress["KServe Ingress<br/>HTTPRoute / Route<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Per InferenceService"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph VLLMPod["vLLM CPU Pod (user 2000, group 0)"]
            direction TB
            AuthMW["Auth Middleware<br/>Bearer Token (optional)<br/>VLLM_API_KEY"]
            APIServer["OpenAI API Server<br/>FastAPI/Uvicorn<br/>8000/TCP HTTP<br/>TLS optional via CLI"]
            SSLRefresh["SSL Cert Refresher<br/>watchfiles hot-reload"]
            GRPCServer["gRPC Server<br/>50051/TCP gRPC/HTTP2<br/>plaintext, no auth<br/>reflection enabled"]
            Engine["AsyncLLM Engine V1<br/>Model loading, KV-cache<br/>continuous batching"]
            Kernels["CPU Kernels<br/>C/C++ Extensions<br/>OpenBLAS/LAPACK"]
        end

        subgraph Monitoring["Observability"]
            Prometheus["Prometheus<br/>OpenShift Monitoring<br/>Scrapes /metrics"]
            OTelCollector["OpenTelemetry Collector<br/>OTLP (optional)<br/>configurable port"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF_TOKEN<br/>Disable: HF_HUB_OFFLINE=1"]
        UsageStats["RHOAI Usage Stats<br/>console.redhat.com<br/>443/TCP HTTPS TLS 1.2+<br/>No auth<br/>Disable: VLLM_NO_USAGE_STATS=1"]
        ModelStorage["Model Storage<br/>PVC / S3<br/>varies"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| KServeIngress

    %% Ingress → Pod
    KServeIngress -->|"HTTP/8000<br/>TLS terminated at ingress<br/>Bearer Token (optional)"| AuthMW
    AuthMW --> APIServer

    %% Internal flows
    SSLRefresh -.->|"watches cert files"| APIServer
    APIServer --> Engine
    GRPCServer --> Engine
    Engine --> Kernels

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>GET /metrics<br/>No auth"| APIServer
    APIServer -.->|"OTLP<br/>configurable"| OTelCollector

    %% Egress
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Engine -->|"File I/O / S3 API"| ModelStorage
    APIServer -.->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| UsageStats

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef grpc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KServeIngress ingress
    class AuthMW,APIServer,SSLRefresh,Engine,Kernels pod
    class GRPCServer grpc
    class Prometheus,OTelCollector monitoring
    class HFHub,UsageStats,ModelStorage externalservice
