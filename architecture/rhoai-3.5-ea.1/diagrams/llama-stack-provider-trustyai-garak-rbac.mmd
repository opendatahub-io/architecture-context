graph TD
    subgraph "Service Account"
        SA["llamastack-garak-distribution-sa<br/>Namespace: deployment namespace"]
    end

    subgraph "Role Bindings"
        RB1["lsd-garak-dspa-api-access<br/>(RoleBinding)"]
        RB2["lsd-garak-pipeline-management<br/>(RoleBinding)"]
    end

    subgraph "Cluster Roles"
        CR1["lsd-garak-dspa-api-access<br/>(ClusterRole)"]
    end

    subgraph "Roles"
        R1["ds-pipeline-dspa<br/>(Role)"]
    end

    subgraph "API Resources - DSPA Access"
        DSPA_API["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications/api"]
    end

    subgraph "API Resources - Pipeline Management"
        Pipelines["Pipeline management resources<br/>(runs, experiments, pipelines)"]
    end

    subgraph "Secrets Accessed"
        Secret1["llama-stack-inference-model-secret<br/>(Opaque)<br/>Keys: VLLM_API_TOKEN<br/>Provisioned: Manual"]
        Secret2["postgres-secret<br/>(Opaque)<br/>Keys: POSTGRES_DB, POSTGRES_USER,<br/>POSTGRES_PASSWORD<br/>Provisioned: Manual"]
        Secret3["Data Connection secret<br/>(Opaque)<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT<br/>Provisioned: DSPA operator"]
    end

    subgraph "Network Access"
        NP["NetworkPolicy: allow-kfp-to-llamastack<br/>Selector: app: llama-stack<br/>Ingress: all pods in namespace<br/>Port: 8321/TCP"]
    end

    %% Service Account to Role Bindings
    SA -->|"bound via"| RB1
    SA -->|"bound via"| RB2

    %% Role Bindings to Roles
    RB1 -->|"grants"| CR1
    RB2 -->|"grants"| R1

    %% Roles to Resources
    CR1 -->|"get, create"| DSPA_API
    R1 -->|"pipeline operations"| Pipelines

    %% Secret access (environment variables)
    SA -.->|"env: VLLM_API_TOKEN"| Secret1
    SA -.->|"env: POSTGRES_*"| Secret2
    SA -.->|"env: AWS_*"| Secret3

    %% Network access
    SA -.->|"protected by"| NP

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB1 fill:#5ba3d9,stroke:#333,color:#fff
    style RB2 fill:#5ba3d9,stroke:#333,color:#fff
    style CR1 fill:#f5a623,stroke:#333
    style R1 fill:#f5a623,stroke:#333
    style DSPA_API fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff
    style Secret1 fill:#e74c3c,stroke:#333,color:#fff
    style Secret2 fill:#e74c3c,stroke:#333,color:#fff
    style Secret3 fill:#e74c3c,stroke:#333,color:#fff
    style NP fill:#9b59b6,stroke:#333,color:#fff
