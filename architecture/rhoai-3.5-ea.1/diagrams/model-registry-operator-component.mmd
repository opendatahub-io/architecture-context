graph TB
    subgraph Operator["Model Registry Operator (controller-runtime)"]
        direction TB
        MRReconciler["ModelRegistryReconciler<br/>Controller"]
        MCReconciler["ModelCatalogReconciler<br/>Controller (Singleton)"]
        SVM["StorageMigrationManager<br/>v1alpha1 → v1beta1"]
        MutWebhook["Mutating Webhook<br/>9443/TCP TLS"]
        ValWebhook["Validating Webhook<br/>9443/TCP TLS"]
        Metrics["Metrics Server<br/>8443/TCP HTTPS"]
        Health["Health/Ready<br/>8081/TCP HTTP"]
    end

    %% CRDs
    User[User / Admin] -->|"kubectl create"| ModelRegistryCR["ModelRegistry CR<br/>(v1beta1 storage)"]
    ModelRegistryCR -->|"admission"| MutWebhook
    ModelRegistryCR -->|"admission"| ValWebhook
    ModelRegistryCR -->|"watched by"| MRReconciler

    %% Per-Registry Resources Created
    subgraph PerRegistry["Per-Registry Resources"]
        direction TB
        RegDeployment["Deployment<br/>(rest-container + kube-rbac-proxy)"]
        RegService["Service<br/>8443/TCP HTTPS"]
        RegRoute["Route (OpenShift)<br/>reencrypt TLS"]
        RegPostgres["PostgreSQL<br/>5432/TCP (optional)"]
        RegRBAC["SA, Role, RoleBinding<br/>ClusterRoleBinding"]
        RegNetPol["NetworkPolicy"]
        RegGroup["OpenShift Group<br/>(user access)"]
    end

    MRReconciler -->|"creates/manages"| RegDeployment
    MRReconciler -->|"creates/manages"| RegService
    MRReconciler -->|"creates/manages"| RegRoute
    MRReconciler -->|"creates/manages"| RegPostgres
    MRReconciler -->|"creates/manages"| RegRBAC
    MRReconciler -->|"creates/manages"| RegNetPol
    MRReconciler -->|"creates/manages"| RegGroup

    %% Catalog Resources Created
    subgraph Catalog["Model Catalog Resources (Singleton)"]
        direction TB
        CatDeployment["Deployment<br/>(catalog + kube-rbac-proxy<br/>+ init containers)"]
        CatService["Service<br/>8443/TCP HTTPS"]
        CatRoute["Route (OpenShift)<br/>reencrypt TLS"]
        CatPostgres["model-catalog-postgres<br/>5432/TCP"]
        CatRBAC["SA, Roles, Bindings"]
    end

    MCReconciler -->|"creates/manages"| CatDeployment
    MCReconciler -->|"creates/manages"| CatService
    MCReconciler -->|"creates/manages"| CatRoute
    MCReconciler -->|"creates/manages"| CatPostgres
    MCReconciler -->|"creates/manages"| CatRBAC

    %% External Dependencies
    MRReconciler -->|"REST API 443/TCP"| K8sAPI["Kubernetes API Server"]
    MCReconciler -->|"REST API 443/TCP"| K8sAPI
    SVM -->|"migration.k8s.io"| K8sAPI
    MCReconciler -->|"reads"| PlatformMR["components.platform.opendatahub.io<br/>ModelRegistry"]
    MCReconciler -->|"reads"| AuthCR["services.platform.opendatahub.io<br/>Auth"]
    MRReconciler -->|"reads"| IngressConfig["config.openshift.io<br/>Ingress"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PerRegistry fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Catalog fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style MRReconciler fill:#4a90e2,color:#fff
    style MCReconciler fill:#4a90e2,color:#fff
    style SVM fill:#4a90e2,color:#fff
    style MutWebhook fill:#4a90e2,color:#fff
    style ValWebhook fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style Health fill:#4a90e2,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PlatformMR fill:#7ed321,stroke:#333
    style AuthCR fill:#7ed321,stroke:#333
    style IngressConfig fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#333
