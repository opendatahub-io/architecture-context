graph LR
    MLflow["MLflow Tracking Server<br/>v3.10.1+rhaiv.3"]

    %% Runtime Dependencies
    subgraph Runtime["Runtime Dependencies"]
        Python["Python 3.12"]
        FastAPI["FastAPI <1"]
        Flask["Flask <4"]
        Uvicorn["Uvicorn <1"]
        SQLAlchemy["SQLAlchemy >=1.4, <3"]
        Alembic["Alembic <2"]
        Cryptography["cryptography >=43, <47"]
        OTelSDK["OpenTelemetry SDK >=1.9, <3"]
        Psycopg2["psycopg2 2.9.11"]
    end

    %% RHOAI-Specific Dependencies
    subgraph RHOAIDeps["RHOAI-Specific"]
        K8sPlugins["mlflow-kubernetes-plugins 1.1.1"]
        PromExporter["prometheus-flask-exporter 0.23.2"]
        K8sPython["kubernetes Python SDK"]
    end

    %% Build-Time Dependencies
    subgraph BuildTime["Build-Time Dependencies"]
        NodeJS["Node.js 20"]
        YarnBerry["Yarn Berry"]
        Cachi2["Cachi2/Hermeto<br/>(hermetic prefetch)"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        PostgreSQL["PostgreSQL<br/>(psycopg2 2.9.x compatible)"]
        S3["S3-compatible Store"]
        GCS["Google Cloud Storage"]
        AzureBlob["Azure Blob Storage"]
        K8sAPI["Kubernetes API Server"]
    end

    %% Internal RHOAI Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        RHOAIDashboard["RHOAI Dashboard<br/>(Module Federation)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
        RhodsOperator["rhods-operator<br/>(deployment lifecycle)"]
    end

    %% Integration Points
    subgraph Integrations["Integration Points"]
        OTelCollectors["OpenTelemetry Collectors"]
        Prometheus["Prometheus<br/>(metrics scraping)"]
    end

    %% Runtime dependency edges
    MLflow -->|interpreter| Python
    MLflow -->|async web framework| FastAPI
    MLflow -->|legacy web framework| Flask
    MLflow -->|ASGI server| Uvicorn
    MLflow -->|ORM layer| SQLAlchemy
    MLflow -->|schema migrations| Alembic
    MLflow -->|envelope encryption| Cryptography
    MLflow -->|tracing support| OTelSDK
    MLflow -->|PostgreSQL adapter| Psycopg2

    %% RHOAI-specific edges
    MLflow -->|workspace mapping| K8sPlugins
    MLflow -->|metrics export| PromExporter
    MLflow -->|K8s API client| K8sPython

    %% Build-time edges
    MLflow -.->|UI build| NodeJS
    MLflow -.->|JS deps| YarnBerry
    MLflow -.->|hermetic build| Cachi2

    %% External service edges
    MLflow -->|tracking + registry DB| PostgreSQL
    MLflow -->|artifact storage| S3
    MLflow -->|artifact storage| GCS
    MLflow -->|artifact storage| AzureBlob
    MLflow -->|auth + workspace| K8sAPI

    %% Internal RHOAI edges
    RHOAIDashboard -->|embeds UI| MLflow
    KubeRBACProxy -->|auth proxy| MLflow
    RhodsOperator -->|manages lifecycle| MLflow

    %% Integration edges
    OTelCollectors -->|OTLP spans| MLflow
    Prometheus -->|scrapes metrics| MLflow

