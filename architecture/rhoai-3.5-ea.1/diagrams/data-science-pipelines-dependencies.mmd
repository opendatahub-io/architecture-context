graph LR
    DSP["Data Science Pipelines<br/>(Kubeflow Pipelines v2)"]

    %% External Dependencies (Required)
    DSP -->|"workflow execution<br/>Workflow CRDs"| Argo["Argo Workflows<br/>v3.5 / v3.7"]
    DSP -->|"metadata persistence<br/>3306/TCP"| MySQL["MySQL v8"]
    DSP -->|"metadata persistence<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>(alternative)"]
    DSP -->|"artifact storage<br/>S3 API 8333/TCP"| SeaweedFS["SeaweedFS / MinIO"]
    DSP -->|"execution lineage<br/>gRPC 8080/TCP"| MLMD["ML Metadata<br/>(MLMD) v2.16.0"]

    %% Kubernetes Infrastructure
    DSP -->|"TokenReview, SAR<br/>HTTPS 443/TCP"| K8sAPI["Kubernetes<br/>API Server"]

    %% Internal Platform Dependencies
    DSP -.->|"deployed via<br/>DSPA CRD"| Operator["rhods-operator /<br/>opendatahub-operator"]
    DSP -.->|"gRPC→HTTP proxy<br/>9090/TCP"| Envoy["Metadata<br/>Envoy Proxy"]

    %% Optional Cloud Storage
    DSP -.->|"cloud artifacts<br/>HTTPS 443/TCP"| AWSS3["AWS S3<br/>s3.amazonaws.com"]
    DSP -.->|"cloud artifacts<br/>HTTPS 443/TCP"| GCS["Google Cloud Storage<br/>storage.googleapis.com"]

    %% Integration Points (consumers of DSP)
    Dashboard["ODH Dashboard /<br/>RHOAI Console"] -->|"pipeline UI<br/>HTTP 3000/TCP"| DSP
    Operator -->|"lifecycle mgmt<br/>DSPA CR"| DSP

    %% Internal sub-component dependencies
    subgraph DSPInternal["DSP Internal Components"]
        direction TB
        API["API Server<br/>8888/8887/8443"]
        PA["Persistence Agent"]
        SWC["Scheduled Workflow<br/>Controller"]
        FE["Frontend UI<br/>3000"]
        CacheSrv["Cache Server<br/>Webhook 443"]
    end

    PA -->|"status reporting<br/>HTTP 8888"| API
    SWC -->|"create runs<br/>gRPC 8887"| API
    FE -->|"API proxy"| API
    CacheSrv -->|"cache mutation"| K8sAPI

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style SeaweedFS fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Envoy fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style AWSS3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style API fill:#6cb4ee,stroke:#333,color:#fff
    style PA fill:#6cb4ee,stroke:#333,color:#fff
    style SWC fill:#6cb4ee,stroke:#333,color:#fff
    style FE fill:#6cb4ee,stroke:#333,color:#fff
    style CacheSrv fill:#6cb4ee,stroke:#333,color:#fff
