graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB
        Note["This component has NO Kubernetes RBAC definitions.<br/>It is a stateless HTTP service with no Kubernetes API interactions."]
    end

    subgraph "Authentication Model"
        direction TB
        AuthNote["Gateway does NOT enforce authentication or authorization.<br/>It forwards headers as-is to the orchestrator."]

        Client["Client"] -->|"Authorization: Bearer token<br/>(not validated)"| Gateway["vllm-orchestrator-gateway"]
        Gateway -->|"Authorization header forwarded<br/>x-forwarded-* headers forwarded"| Orchestrator["FMS Guardrails Orchestrator"]
    end

    subgraph "Expected Auth Enforcement Points"
        direction TB
        EnforcementNote["Auth is expected to be enforced externally:"]
        E1["Platform Ingress<br/>(HTTPRoute / OpenShift Route)"]
        E2["Network Policy<br/>(kube-rbac-proxy sidecar)"]
        E3["Service Mesh<br/>(Istio AuthorizationPolicy)"]
        E4["Orchestrator<br/>(backend auth validation)"]
    end

    subgraph "TLS Identity (mTLS)"
        direction TB
        TLSCert["/etc/tls/private/tls.crt<br/>Client Certificate"]
        TLSKey["/etc/tls/private/tls.key<br/>Private Key"]
        CACert["/etc/tls/ca/service-ca.crt<br/>CA Certificate"]

        TLSCert -->|"PKCS#12 identity"| mTLSClient["mTLS Client Identity<br/>(to orchestrator)"]
        TLSKey -->|"PKCS#12 identity"| mTLSClient
        CACert -->|"server validation"| mTLSClient
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style AuthNote fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style EnforcementNote fill:#d1ecf1,stroke:#0c5460,stroke-width:1px,color:#0c5460
    style Client fill:#f9f9f9,stroke:#999
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333
    style E1 fill:#e8e8e8,stroke:#333
    style E2 fill:#e8e8e8,stroke:#333
    style E3 fill:#e8e8e8,stroke:#333
    style E4 fill:#e8e8e8,stroke:#333
    style TLSCert fill:#f5a623,stroke:#333
    style TLSKey fill:#f5a623,stroke:#333
    style CACert fill:#f5a623,stroke:#333
    style mTLSClient fill:#4a90e2,stroke:#333,color:#fff
