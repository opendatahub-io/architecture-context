graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Envoy Gateway<br/>inference-gateway<br/>80/TCP HTTP<br/>No TLS"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph EPP_Zone["EPP (Scheduling Control Plane)"]
            EPP["Endpoint Picker<br/>SA: ${EPP_NAME}<br/>Image: odh-llm-d-inference-scheduler<br/>FIPS: strictfipsruntime"]
            EPP_Ports["Ports:<br/>9002/TCP gRPC ext-proc<br/>9003/TCP gRPC health<br/>9090/TCP HTTP metrics<br/>5557/TCP ZMQ sub"]
        end

        subgraph Sidecar_Zone["P/D Sidecar (Data Plane Proxy)"]
            Sidecar["P/D Routing Sidecar<br/>Native sidecar on vLLM pods<br/>Image: odh-llm-d-routing-sidecar<br/>FIPS: strictfipsruntime"]
            Sidecar_TLS["TLS 1.2+<br/>ECDHE+AES-GCM<br/>ECDHE+ChaCha20<br/>SSRF Protection"]
        end

        subgraph vLLM_Zone["vLLM Model Servers"]
            DecoderLocal["vLLM Decoder<br/>(local, co-located)<br/>8001/TCP"]
            PrefillerRemote["vLLM Prefiller<br/>(remote)<br/>configurable port"]
            EncoderRemote["vLLM Encoder<br/>(remote)<br/>configurable port"]
            vLLMZMQ["vLLM Engines<br/>ZMQ PUB<br/>5555-5557/TCP"]
        end

        subgraph Tokenizer_Zone["Tokenizer"]
            UDSTokenizer["UDS Tokenizer<br/>gRPC over Unix Socket<br/>/tmp/tokenizer/*.socket"]
        end
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>9090/TCP HTTP<br/>every 15s"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>insecure"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN Auth"]
    end

    %% Flows - External to Ingress
    Client -->|"HTTP/80<br/>No Encryption<br/>No Auth"| Gateway

    %% Flows - Ingress to EPP
    Gateway -->|"gRPC ext-proc/9002<br/>No Encryption<br/>Cluster-internal trust"| EPP

    %% Flows - Ingress to Sidecar
    Gateway -->|"HTTP or HTTPS/8000<br/>TLS 1.2+ (configurable)<br/>No Auth"| Sidecar

    %% EPP outbound
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (Bearer)"| K8sAPI
    EPP -->|"gRPC/UDS<br/>No Encryption<br/>Local socket"| UDSTokenizer
    EPP -->|"ZMQ SUB/5555-5557<br/>No Encryption<br/>No Auth"| vLLMZMQ
    EPP -->|"gRPC/4317<br/>insecure<br/>No Auth"| OTLP
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub

    %% Sidecar outbound
    Sidecar -->|"HTTP or HTTPS/8001<br/>TLS 1.2+ (configurable)<br/>No Auth"| DecoderLocal
    Sidecar -->|"HTTP or HTTPS<br/>TLS 1.2+ (configurable)<br/>No Auth"| PrefillerRemote
    Sidecar -->|"HTTP or HTTPS<br/>TLS 1.2+ (configurable)<br/>No Auth"| EncoderRemote
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Sidecar -->|"gRPC/4317<br/>insecure<br/>No Auth"| OTLP

    %% Observability
    Prometheus -->|"HTTP/9090<br/>No Encryption"| EPP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef vllm fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,EPP_Ports clusterinternal
    class Sidecar,Sidecar_TLS sidecar
    class DecoderLocal,PrefillerRemote,EncoderRemote,vLLMZMQ vllm
    class UDSTokenizer clusterinternal
    class Prometheus,OTLP observability
    class K8sAPI,HFHub externalservice
