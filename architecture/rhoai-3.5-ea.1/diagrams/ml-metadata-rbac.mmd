graph TD
    subgraph Note["RBAC Model"]
        direction TB
        NoteText["ML Metadata does NOT define its own Kubernetes RBAC resources.<br/>All RBAC is managed by the deploying operator<br/>(DSP Operator / rhods-operator)."]
    end

    subgraph DeploymentRBAC["Deployment-Managed RBAC (External)"]
        direction TB
        DSPOp["DSP Operator /<br/>rhods-operator"]
        DSPOp -->|"provisions"| SA["Service Account<br/>(created by operator)"]
        DSPOp -->|"provisions"| RB["Role Bindings<br/>(created by operator)"]
    end

    subgraph ApplicationAuth["Application-Level Authentication"]
        direction TB

        subgraph InsecureMode["Default: Insecure Mode"]
            NoAuth["No Authentication<br/>SSLConfig not configured<br/>All gRPC clients have full access"]
        end

        subgraph MTLSMode["Optional: mTLS Mode"]
            SSLConfig["SSLConfig Proto"]
            ServerCert["Server Certificate<br/>(PEM)"]
            ServerKey["Server Private Key<br/>(PEM)"]
            CustomCA["Custom CA Certificate<br/>(PEM)"]
            ClientVerify["client_verify = true<br/>Require client certificates"]

            SSLConfig --> ServerCert
            SSLConfig --> ServerKey
            SSLConfig --> CustomCA
            SSLConfig --> ClientVerify
        end
    end

    subgraph APIAccess["MetadataStoreService API Access"]
        direction TB
        AllRPCs["All gRPC Methods<br/>(Put*, Get*, GetLineage*)"]
        AllRPCs -->|"No method-level<br/>authorization"| FullAccess["Full CRUD Access<br/>for any authenticated client"]
    end

    subgraph SecretsManagement["Secrets"]
        DBCreds["DB Credentials (Opaque)<br/>MySQL/PostgreSQL user+pass<br/>Provisioned by: operator<br/>Auto-Rotate: No"]
        TLSSecret["SSL Certificates (tls)<br/>Optional mTLS certs<br/>Provisioned by: manual/cert-manager"]
        DBSSLSecret["DB SSL Certs (Opaque)<br/>sslcert, sslkey, sslrootcert<br/>Provisioned by: operator"]
    end

    SA -.->|"identity for"| MLMD["MLMD gRPC Server Pod"]
    InsecureMode -.->|"default"| MLMD
    MTLSMode -.->|"when configured"| MLMD
    MLMD --> AllRPCs
    DBCreds -.->|"mounted"| MLMD
    TLSSecret -.->|"optional"| MLMD
    DBSSLSecret -.->|"optional"| MLMD

    %% Styling
    style NoteText fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style DSPOp fill:#7ed321,stroke:#333
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#4a90e2,stroke:#333,color:#fff
    style MLMD fill:#4a90e2,stroke:#333,color:#fff,stroke-width:3px
    style NoAuth fill:#ffcccc,stroke:#e74c3c,stroke-width:2px
    style SSLConfig fill:#d5e8d4,stroke:#82b366
    style ClientVerify fill:#d5e8d4,stroke:#82b366
    style AllRPCs fill:#dae8fc,stroke:#6c8ebf
    style FullAccess fill:#dae8fc,stroke:#6c8ebf
    style DBCreds fill:#f8cecc,stroke:#b85450
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style DBSSLSecret fill:#f8cecc,stroke:#b85450
