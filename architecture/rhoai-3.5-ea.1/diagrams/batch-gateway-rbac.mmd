graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["No Kubernetes RBAC roles are defined.<br/>Batch Gateway does not interact with<br/>the Kubernetes API directly."]
    end

    subgraph ServiceAccounts["Service Accounts (no RBAC bindings)"]
        SA_API["ServiceAccount:<br/>{release}-apiserver<br/>Namespace: {release}"]
        SA_Proc["ServiceAccount:<br/>{release}-processor<br/>Namespace: {release}"]
        SA_GC["ServiceAccount:<br/>{release}-gc<br/>Namespace: {release}"]
    end

    subgraph ApplicationAuth["Application-Level Authorization"]
        direction TB

        subgraph TenantIsolation["Multi-Tenant Isolation (Application Layer)"]
            Header["Request Header:<br/>X-MaaS-Username<br/>(last value, ext_authz compatible)"]
            Middleware["Tenant Middleware:<br/>Extract → Inject into context"]
            DBScope["DB Query Scoping:<br/>All queries filtered by tenantID"]
            PostValidation["Post-Retrieval Validation:<br/>Returns 404 on tenant mismatch<br/>(prevents enumeration attacks)"]
            FileIsolation["File Storage Isolation:<br/>SHA256(tenantID) as S3 folder prefix"]

            Header --> Middleware
            Middleware --> DBScope
            Middleware --> PostValidation
            Middleware --> FileIsolation
        end

        subgraph EndpointAuth["Endpoint Authentication"]
            BatchEndpoints["/v1/batches/*<br/>Auth: Tenant header (required)<br/>Methods: GET, POST"]
            FileEndpoints["/v1/files/*<br/>Auth: Tenant header (required)<br/>Methods: GET, POST, DELETE"]
            ObsEndpoints["/health, /ready, /metrics<br/>Auth: None<br/>Separate ports: 8081, 9090"]
            InferenceAuth["Inference Gateway<br/>Auth: Bearer token<br/>from /etc/.secrets/inference-api-key<br/>+ pass-through headers"]
        end
    end

    subgraph Secrets["Secret References"]
        Secret1["batch-gateway-secrets (Opaque)<br/>- redis-url<br/>- postgresql-url<br/>- inference-api-key<br/>- s3-secret-access-key<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        Secret2["{release}-apiserver-tls (kubernetes.io/tls)<br/>- tls.crt, tls.key<br/>Provisioned: cert-manager (optional)<br/>Auto-Rotate: Yes (if cert-manager)"]
    end

    SA_API -->|"mounts"| Secret1
    SA_API -->|"mounts (if TLS enabled)"| Secret2
    SA_Proc -->|"mounts"| Secret1
    SA_GC -->|"mounts"| Secret1

    SA_API -->|"serves"| BatchEndpoints
    SA_API -->|"serves"| FileEndpoints
    SA_API -->|"serves"| ObsEndpoints
    SA_Proc -->|"calls"| InferenceAuth

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_Proc fill:#e07b53,stroke:#333,color:#fff
    style SA_GC fill:#7eb77f,stroke:#333,color:#fff

    style Header fill:#f5a623,stroke:#333
    style Middleware fill:#f5a623,stroke:#333
    style DBScope fill:#f5a623,stroke:#333
    style PostValidation fill:#f5a623,stroke:#333
    style FileIsolation fill:#f5a623,stroke:#333

    style Secret1 fill:#ffcccc,stroke:#cc0000
    style Secret2 fill:#ffcccc,stroke:#cc0000

    style BatchEndpoints fill:#d5e8d4,stroke:#82b366
    style FileEndpoints fill:#d5e8d4,stroke:#82b366
    style ObsEndpoints fill:#d5e8d4,stroke:#82b366
    style InferenceAuth fill:#dae8fc,stroke:#6c8ebf

    style L1 fill:#fff2cc,stroke:#d6b656
