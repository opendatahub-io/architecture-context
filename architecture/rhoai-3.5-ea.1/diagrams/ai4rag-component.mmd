graph TB
    subgraph AI4RAG["ai4rag Library"]
        direction TB

        subgraph Core["ai4rag.core"]
            Experiment["AI4RAGExperiment<br/><i>Experiment Orchestrator</i>"]
            MPS["ModelsPreSelector<br/><i>Model Pre-Selection</i>"]
            Results["ExperimentResults<br/><i>Collection Reuse &amp; Tracking</i>"]

            subgraph HPO["ai4rag.core.hpo"]
                GAMOpt["GAMOptimizer<br/><i>GAM Surrogate Model</i>"]
                RandomOpt["RandomOptimizer<br/><i>Random Search</i>"]
            end
        end

        subgraph RAG["ai4rag.rag"]
            direction TB

            subgraph Templates["Templates"]
                BaseTemplate["BaseRAGTemplate"]
                SimpleRAG["SimpleRAGTemplate"]
            end

            subgraph Models["Foundation Models"]
                BaseFM["BaseFoundationModel"]
                OgxFM["OGXFoundationModel"]
            end

            subgraph Embeddings["Embedding Models"]
                BaseEmbed["BaseEmbeddingModel"]
                OgxEmbed["OGXEmbeddingModel"]
            end

            subgraph VectorStores["Vector Stores"]
                BaseVS["BaseVectorStore"]
                OgxVS["OGXVectorStore"]
                ChromaVS["ChromaVectorStore"]
            end

            Chunker["LangChainChunker<br/><i>RecursiveCharacterTextSplitter</i>"]
            Retriever["Retriever<br/><i>Similarity Search</i>"]
        end

        subgraph Eval["ai4rag.evaluator"]
            BaseEval["BaseEvaluator"]
            UnitxtEval["UnitxtEvaluator<br/><i>faithfulness, correctness</i>"]
        end

        subgraph SearchSpace["ai4rag.search_space"]
            Space["SearchSpace<br/><i>Constraint Pruning</i>"]
            Params["Parameter Definitions"]
        end

        subgraph Utils["ai4rag.utils"]
            EventHandler["BaseEventHandler"]
            LocalHandler["LocalEventHandler"]
            KFPHandler["KFPEventHandler"]
            Validators["Validators"]
        end
    end

    %% Internal flows
    Experiment -->|"1. optional pre-selection"| MPS
    Experiment -->|"2. optimize"| GAMOpt
    Experiment -->|"2. alt"| RandomOpt
    Experiment -->|"track results"| Results
    Experiment -->|"stream events"| EventHandler

    GAMOpt -->|"search space"| Space
    GAMOpt -->|"chunk documents"| Chunker
    GAMOpt -->|"embed &amp; index"| OgxEmbed
    GAMOpt -->|"store vectors"| OgxVS
    GAMOpt -->|"retrieve"| Retriever
    GAMOpt -->|"generate"| SimpleRAG
    GAMOpt -->|"evaluate"| UnitxtEval

    MPS -->|"embed"| OgxEmbed
    MPS -->|"local index"| ChromaVS
    MPS -->|"generate"| OgxFM
    MPS -->|"evaluate"| UnitxtEval

    SimpleRAG -->|"uses"| OgxFM
    Retriever -->|"queries"| BaseVS

    %% External integrations
    OgxFM -->|"HTTPS / API Key"| OGXServer["OGX Server<br/><i>Chat Completions</i>"]
    OgxEmbed -->|"HTTPS / API Key"| OGXServerEmbed["OGX Server<br/><i>Embeddings API</i>"]
    OgxVS -->|"HTTPS / API Key"| OGXServerVec["OGX Server<br/><i>Vector Stores &amp; IO</i>"]
    ChromaVS -->|"in-process"| ChromaDB["ChromaDB<br/><i>In-Memory</i>"]

    KFPHandler -->|"pipeline output"| KFP["Kubeflow Pipelines"]

    %% Styling
    style AI4RAG fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Core fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style RAG fill:#dcfce7,stroke:#22c55e,stroke-width:2px
    style Eval fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    style SearchSpace fill:#fce7f3,stroke:#ec4899,stroke-width:2px
    style Utils fill:#f3e8ff,stroke:#a855f7,stroke-width:2px
    style HPO fill:#bfdbfe,stroke:#60a5fa,stroke-width:1px

    style OGXServer fill:#f5f5f5,stroke:#999,stroke-width:2px
    style OGXServerEmbed fill:#f5f5f5,stroke:#999,stroke-width:2px
    style OGXServerVec fill:#f5f5f5,stroke:#999,stroke-width:2px
    style ChromaDB fill:#f5f5f5,stroke:#999,stroke-width:2px
    style KFP fill:#7ed321,stroke:#333,stroke-width:2px

    style Experiment fill:#4a90e2,color:#fff
    style GAMOpt fill:#60a5fa,color:#fff
    style MPS fill:#60a5fa,color:#fff
