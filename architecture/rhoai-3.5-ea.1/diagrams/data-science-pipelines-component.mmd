graph TB
    subgraph DSP["Data Science Pipelines Platform"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["API Server<br/>Go Service<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP Webhook"]
            FrontendUI["Frontend UI<br/>TypeScript/React<br/>3000/TCP HTTP"]
        end

        subgraph Orchestration["Orchestration Layer (Argo Task Pods)"]
            Driver["Driver<br/>Go CLI<br/>DAG orchestration, cache check,<br/>input resolution, pod spec patches"]
            Launcher["Launcher<br/>Go CLI (sidecar)<br/>Artifact download/upload,<br/>user code execution, MLMD publish"]
        end

        subgraph Controllers["Controller Layer"]
            PersistenceAgent["Persistence Agent<br/>Go Service<br/>Kubernetes Informers"]
            ScheduledWorkflow["Scheduled Workflow Controller<br/>Go Controller<br/>9090/TCP Prometheus"]
        end
    end

    subgraph CRDs["Custom Resources"]
        ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
        ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
        PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v1"]
        PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v1"]
        ArgoWorkflowCR["Workflow CR<br/>argoproj.io/v1alpha1"]
    end

    subgraph Storage["Storage Layer"]
        MySQL["MySQL / PostgreSQL<br/>3306/5432 TCP"]
        S3["SeaweedFS / MinIO / S3<br/>8333/9000 TCP"]
    end

    subgraph MetadataLayer["Metadata Layer"]
        MLMD["metadata-grpc-service<br/>MLMD gRPC<br/>8080/TCP"]
        MetadataEnvoy["metadata-envoy-service<br/>HTTP Proxy<br/>9090/TCP"]
    end

    subgraph External["External Systems"]
        ArgoController["Argo Workflows Controller"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
        CacheServer["Cache Server<br/>MutatingWebhook<br/>443/TCP HTTPS"]
        PlatformOperator["rhods-operator<br/>DSPA Controller"]
    end

    User["User / Data Scientist"] -->|"creates pipelines"| FrontendUI
    User -->|"REST/gRPC API"| APIServer
    FrontendUI -->|"proxy"| APIServer

    APIServer -->|"persists metadata"| MySQL
    APIServer -->|"stores artifacts & specs"| S3
    APIServer -->|"creates"| ArgoWorkflowCR
    APIServer -->|"validates/mutates"| PipelineVersionCR
    APIServer -->|"queries lineage"| MLMD
    APIServer -->|"TokenReview/SAR"| K8sAPI

    ArgoWorkflowCR -->|"executed by"| ArgoController
    ArgoController -->|"creates task pods with"| Driver
    Driver -->|"generates pod spec for"| Launcher
    Driver -->|"resolves inputs via"| MLMD
    Driver -->|"cache lookup"| APIServer
    Launcher -->|"downloads/uploads artifacts"| S3
    Launcher -->|"publishes results"| MLMD

    PersistenceAgent -->|"watches"| ArgoWorkflowCR
    PersistenceAgent -->|"watches"| ScheduledWorkflowCR
    PersistenceAgent -->|"reports status"| APIServer

    ScheduledWorkflow -->|"watches"| ScheduledWorkflowCR
    ScheduledWorkflow -->|"creates"| ArgoWorkflowCR
    ScheduledWorkflow -->|"creates runs"| APIServer

    MetadataEnvoy -->|"proxies gRPC→HTTP"| MLMD
    FrontendUI -->|"reads metadata"| MetadataEnvoy

    PlatformOperator -->|"deploys via DSPA CR"| DSP

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style FrontendUI fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#50c878,stroke:#333,color:#fff
    style Launcher fill:#50c878,stroke:#333,color:#fff
