    style S3 fill:#f5a623,stroke:#333,color:#fff
    style MLMD fill:#e67e22,stroke:#333,color:#fff
    style MetadataEnvoy fill:#e67e22,stroke:#333,color:#fff
    style ArgoController fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CacheServer fill:#999,stroke:#333,color:#fff
    style PlatformOperator fill:#999,stroke:#333,color:#fff
