graph TB
    subgraph EvalHubSystem["EvalHub System"]
        direction TB

        subgraph MainPod["eval-hub Pod"]
            EvalHubAPI["eval-hub<br/>Go REST API<br/>8080/TCP"]
            EvalHubAPI -->|validates| AuthMiddleware["Auth Middleware<br/>TokenReview + SAR"]
        end

        subgraph EvalJobPod["Evaluation Job Pod (per job)"]
            direction LR
            InitContainer["eval-runtime-init<br/>Go Init Container"]
            AdapterContainer["Adapter Container<br/>(lm-eval-harness, RAGAS, etc.)"]
            SidecarProxy["eval-runtime-sidecar<br/>Go Reverse Proxy<br/>8080/TCP"]
            InitContainer -.->|runs before| AdapterContainer
            AdapterContainer -->|localhost:8080| SidecarProxy
        end

        subgraph MCPServer["evalhub-mcp (optional)"]
            MCP["MCP Server<br/>Go<br/>3001/TCP or stdio"]
        end
    end

    %% External Users
    Client["Client / User<br/>(kubectl, SDK, UI)"] -->|"POST /api/v1/evaluations/jobs<br/>Bearer Token"| EvalHubAPI
    MCPClient["MCP Client<br/>(AI Agent)"] -->|"MCP Protocol<br/>tools/resources/prompts"| MCP
    MCP -->|"REST API calls"| EvalHubAPI

    %% CRD Management
    TrustyAIOp["TrustyAI Service Operator"] -->|"manages via<br/>EvalHub CR"| MainPod

    %% Job Creation Flow
    EvalHubAPI -->|"creates K8s Job"| EvalJobPod

    %% Sidecar Proxied Connections
    SidecarProxy -->|"HTTPS<br/>SA Token"| EvalHubAPI
    SidecarProxy -->|"HTTPS<br/>SA Token"| MLflow["MLflow Tracking Server"]
    SidecarProxy -->|"HTTPS<br/>OAuth2 Bearer"| OCIRegistry["OCI Registry"]

    %% Init Container
    InitContainer -->|"HTTPS<br/>AWS Credentials"| S3["S3-compatible Storage"]

    %% Direct Dependencies
    EvalHubAPI -->|"HTTPS/443<br/>In-cluster SA"| K8sAPI["Kubernetes API"]
    EvalHubAPI -->|"SQL/5432<br/>DB Credentials"| PostgreSQL["PostgreSQL / SQLite"]
    EvalHubAPI -->|"HTTPS<br/>SA Token"| MLflow
    EvalHubAPI -->|"gRPC/4317<br/>OTLP"| OTLPCollector["OTLP Collector"]
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>8080/TCP"| EvalHubAPI

    %% ConfigMap Hot Reload
    ConfigMaps["ConfigMaps<br/>(providers, collections)"] -.->|"fsnotify watch<br/>hot-reload"| EvalHubAPI

    %% Styling
    style EvalHubAPI fill:#4a90e2,stroke:#333,color:#fff
    style SidecarProxy fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style MCP fill:#4a90e2,stroke:#333,color:#fff
    style AuthMiddleware fill:#2c5f9e,stroke:#333,color:#fff
    style AdapterContainer fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style MLflow fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OCIRegistry fill:#f5a623,stroke:#333
    style OTLPCollector fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style MCPClient fill:#f9f9f9,stroke:#333
