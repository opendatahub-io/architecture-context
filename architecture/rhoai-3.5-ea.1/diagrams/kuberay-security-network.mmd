graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway<br/>(data-science-gateway / Envoy)<br/>443/TCP<br/>TLS 1.2+<br/>Path: /ray/{ns}/{cluster}"]
    end

    subgraph AuthLayer["AUTHENTICATION SIDECAR"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS/TLS<br/>SubjectAccessReview<br/>OIDC Token validation"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["KubeRay Operator<br/>SA: kuberay-operator"]
        WebhookSvc["kuberay-webhook-service<br/>443→9443/TCP HTTPS<br/>OpenShift serving cert"]
        MetricsSvc["Metrics: 8080/TCP HTTP<br/>Health: 8082/TCP HTTP"]
    end

    subgraph UserNS["RAY CLUSTER (User Namespace)"]
        direction TB

        subgraph HeadPodGroup["Head Pod"]
            RayHead["Ray Head Container<br/>6379, 8265, 10001,<br/>8080, 8000/TCP"]
            KRBPSidecar["kube-rbac-proxy<br/>sidecar 8443/TCP"]
        end

        Workers["Ray Worker Pods<br/>10001/TCP + worker ports"]
        HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>6379, 8265, 10001,<br/>8080, 8443/TCP"]
        ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
        HeadlessSvc["{cluster}-headless<br/>ClusterIP None"]
        NetPol["NetworkPolicy<br/>Pod-level isolation"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
        CertMgr["cert-manager<br/>443/TCP HTTPS TLS 1.2+"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Optional TLS"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
        OIDC["OpenShift OAuth/OIDC<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Token"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS<br/>OIDC Token fwd"| KRBP

    %% Auth → Dashboard
    KRBP -->|"HTTP/8265<br/>None (localhost)<br/>No auth"| RayHead
    KRBP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (SAR)"| K8sAPI

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator → cert-manager
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| CertMgr

    %% K8s API → Webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS<br/>API server mTLS"| WebhookSvc

    %% mTLS between Ray nodes
    RayHead <-->|"TCP/6379,10001<br/>mTLS<br/>cert-manager certs<br/>(90d rotation)"| Workers

    %% Peer discovery
    Workers -.->|"Peer discovery"| HeadlessSvc

    %% Prometheus scrape
    Prometheus -->|"HTTP/8080<br/>None<br/>No auth"| MetricsSvc

    %% OIDC config
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OIDC

    %% Optional Redis
    RayHead -.->|"TCP/6379<br/>Optional TLS<br/>Password auth"| Redis

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef netpol fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBP auth
    class Operator,WebhookSvc,MetricsSvc operator
    class RayHead,KRBPSidecar,Workers,HeadSvc,ServeSvc,HeadlessSvc cluster
    class K8sAPI,CertMgr,Redis,Prometheus,OIDC externalservice
    class NetPol netpol
