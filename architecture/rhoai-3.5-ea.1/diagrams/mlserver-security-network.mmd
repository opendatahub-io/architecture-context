graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe-Managed, TLS Termination)"]
        Gateway["KServe Gateway<br/>443/TCP → 8080/8081/TCP<br/>TLS 1.2+<br/>Bearer Token / mTLS"]
    end

    subgraph Pod["POD (KServe InferenceService)"]
        direction TB

        subgraph Servers["MLServer Servers"]
            RESTServer["REST Server (FastAPI/Uvicorn)<br/>8080/TCP HTTP<br/>V2 Dataplane API"]
            GRPCServer["gRPC Server (grpc.aio)<br/>8081/TCP gRPC/HTTP2<br/>V2 Dataplane API"]
            MetricsServer["Metrics Server<br/>8082/TCP HTTP<br/>/metrics endpoint"]
        end

        subgraph Security["Security Controls"]
            Allowlist["Trusted Runtime Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>Read-only 0444<br/>PRODUCTION mode"]
        end

        subgraph Engine["Inference Engine"]
            DataPlane["DataPlane Handler"]
            ModelRegistry["Model Registry"]
            Runtimes["Runtime Plugins<br/>sklearn, xgboost, lgbm, onnx"]
        end
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        KafkaBroker["Kafka Brokers<br/>9092/TCP<br/>Encryption: Configurable<br/>Auth: Configurable"]
        OTELCollector["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>Insecure (no TLS)<br/>Auth: None"]
        ModelStorage["Model Storage (S3/PVC)<br/>Varies (443/TCP for S3)<br/>HTTPS or Filesystem<br/>Auth: AWS IAM / K8s Volumes"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8082/TCP<br/>HTTP<br/>No Auth"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / mTLS"| Gateway

    %% Ingress → Pod (no encryption, pod-internal)
    Gateway -->|"HTTP/8080<br/>No TLS (pod-internal)<br/>No Auth (delegated)"| RESTServer
    Gateway -->|"gRPC/8081<br/>No TLS (pod-internal)<br/>No Auth (delegated)"| GRPCServer

    %% Internal pod flows
    RESTServer --> DataPlane
    GRPCServer --> DataPlane
    DataPlane --> ModelRegistry
    Allowlist -->|"validates runtime imports"| ModelRegistry
    ModelRegistry --> Runtimes

    %% Egress
    DataPlane -.->|"TCP/9092<br/>Configurable encryption"| KafkaBroker
    DataPlane -.->|"gRPC/4317<br/>Insecure"| OTELCollector
    ModelRegistry -.->|"HTTPS or FS<br/>Varies"| ModelStorage

    %% Monitoring
    Prometheus -->|"HTTP/8082<br/>No encryption<br/>No auth"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class RESTServer,GRPCServer,MetricsServer,DataPlane,ModelRegistry,Runtimes pod
    class Allowlist security
    class KafkaBroker,OTELCollector,ModelStorage egress
    class Prometheus monitoring
