    style TM_CR fill:#f5a623,color:#333
    style SR_CR fill:#f5a623,color:#333
    style CSR_CR fill:#f5a623,color:#333
    style LMC_CR fill:#f5a623,color:#333
    style LMNC_CR fill:#f5a623,color:#333
    style CloudStorage fill:#e8e8e8,color:#333
    style Istio fill:#e8e8e8,color:#333
    style Knative fill:#e8e8e8,color:#333
    style GatewayAPI fill:#e8e8e8,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style InfExtAPI fill:#e8e8e8,color:#333
    style WVA fill:#e8e8e8,color:#333
    style KEDA fill:#e8e8e8,color:#333
