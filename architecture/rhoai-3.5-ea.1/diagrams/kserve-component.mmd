graph TB
    subgraph KServe["KServe Component (RHOAI 3.5)"]
        direction TB

        subgraph Controllers["Controllers"]
            ISVC_Ctrl["kserve-controller-manager<br/>(Go Operator)<br/>Port: 8081/health, 9443/webhook"]
            LLMISVC_Ctrl["llmisvc-controller-manager<br/>(Go Operator)<br/>Port: 8081/health, 9443/webhook"]
            LM_Ctrl["localmodel-controller-manager<br/>(Go Operator)<br/>Port: 8081/health, 9443/webhook"]
        end

        subgraph Agents["Agents & Sidecars"]
            LMN_Agent["localmodelnode-agent<br/>(DaemonSet)<br/>Port: 8081/health"]
            KS_Agent["kserve-agent<br/>(Sidecar)<br/>Port: 9000/sync"]
            StorageInit["storage-initializer<br/>(Init Container)<br/>Python"]
        end

        subgraph Routing["Routing"]
            Router["kserve-router<br/>(Go Service)<br/>Port: 8080/HTTP"]
        end

        subgraph SDK["Python SDK"]
            PySDK["kserve Python SDK<br/>FastAPI REST + gRPC<br/>v1/v2/OpenAI protocols"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        ISVC_CR["InferenceService<br/>(v1beta1)"]
        LLMISVC_CR["LLMInferenceService<br/>(v1alpha2)"]
        LLMConfig_CR["LLMInferenceServiceConfig<br/>(v1alpha2)"]
        IG_CR["InferenceGraph<br/>(v1alpha1)"]
        TM_CR["TrainedModel<br/>(v1alpha1)"]
        SR_CR["ServingRuntime<br/>(v1alpha1)"]
        CSR_CR["ClusterServingRuntime<br/>(v1alpha1)"]
        LMC_CR["LocalModelCache<br/>(v1alpha1)"]
        LMNC_CR["LocalModelNamespaceCache<br/>(v1alpha1)"]
    end

    %% Controller watches
    ISVC_CR -->|watched by| ISVC_Ctrl
    IG_CR -->|watched by| ISVC_Ctrl
    TM_CR -->|watched by| ISVC_Ctrl
    SR_CR -->|watched by| ISVC_Ctrl
    CSR_CR -->|watched by| ISVC_Ctrl

    LLMISVC_CR -->|watched by| LLMISVC_Ctrl
    LLMConfig_CR -->|watched by| LLMISVC_Ctrl

    LMC_CR -->|watched by| LM_Ctrl
    LMNC_CR -->|watched by| LM_Ctrl

    %% Controller creates
    ISVC_Ctrl -->|creates| Deployments["Deployments<br/>Services<br/>HPAs"]
    ISVC_Ctrl -->|creates| KnativeSvc["Knative Services"]
    ISVC_Ctrl -->|creates| IngressRes["VirtualServices<br/>HTTPRoutes<br/>Ingresses"]

    LLMISVC_Ctrl -->|creates| LWSets["LeaderWorkerSets<br/>Deployments"]
    LLMISVC_Ctrl -->|creates| IPools["InferencePools<br/>HTTPRoutes"]
    LLMISVC_Ctrl -->|creates| VWA["VariantAutoscalings<br/>ScaledObjects"]
    LLMISVC_Ctrl -->|creates| Monitors["PodMonitors<br/>ServiceMonitors"]

    LM_Ctrl -->|creates| PVs["PVs / PVCs<br/>Download Jobs"]

    %% External dependencies
    ISVC_Ctrl -->|depends on| K8sAPI["Kubernetes API"]
    ISVC_Ctrl -->|depends on| Istio["Istio"]
    ISVC_Ctrl -->|depends on| Knative["Knative Serving"]
    ISVC_Ctrl -->|depends on| GatewayAPI["Gateway API"]

    LLMISVC_Ctrl -->|depends on| GatewayAPI
    LLMISVC_Ctrl -->|depends on| InfExtAPI["Inference Extension API"]
    LLMISVC_Ctrl -->|depends on| WVA["WVA Controller"]
    LLMISVC_Ctrl -->|depends on| KEDA["KEDA"]

    %% Agent egress
    StorageInit -->|downloads from| CloudStorage["S3 / GCS / Azure<br/>HuggingFace / HDFS"]
    KS_Agent -->|syncs from| CloudStorage

    %% Router routing
    IG_CR -->|routes via| Router

    %% Styling
    style ISVC_Ctrl fill:#4a90e2,color:#fff
    style LLMISVC_Ctrl fill:#4a90e2,color:#fff
    style LM_Ctrl fill:#4a90e2,color:#fff
    style LMN_Agent fill:#50c878,color:#fff
    style KS_Agent fill:#50c878,color:#fff
    style StorageInit fill:#50c878,color:#fff
    style Router fill:#9b59b6,color:#fff
    style PySDK fill:#e67e22,color:#fff
