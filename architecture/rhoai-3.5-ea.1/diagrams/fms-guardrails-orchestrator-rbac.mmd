graph TD
    subgraph NoRBAC["No Kubernetes RBAC"]
        direction TB
        Note["FMS Guardrails Orchestrator is a<br/>standalone service without<br/>Kubernetes API access.<br/><br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined."]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        subgraph HealthAuth["Health Endpoints (Port 8034)"]
            HealthEndpoints["/health, /info"]
            HealthPolicy["No authentication<br/>Open access"]
        end

        subgraph APIAuth["API Endpoints (Port 8033)"]
            APIEndpoints["/api/v1/*, /api/v2/*"]
            APIPolicy["Optional mTLS client certs<br/>rustls WebPkiClientVerifier<br/>Verify against provided CA"]
        end

        subgraph DownstreamAuth["Downstream Service Auth"]
            DetectorAuth["Detector Services<br/>Optional Bearer token<br/>(X-Forwarded-Access-Token<br/>passthrough or api_token config)"]
            gRPCAuth["gRPC Services (TGIS, NLP, Chunker)<br/>Optional mTLS client certs<br/>(per-service TLS config section)"]
            OpenAIAuth["OpenAI-compatible Server<br/>Optional Bearer token<br/>(api_token config)"]
        end
    end

    subgraph Secrets["Secrets & Certificates"]
        direction TB
        ServerCert["TLS_CERT_PATH<br/>(PEM - server cert)"]
        ServerKey["TLS_KEY_PATH<br/>(PEM - server key)"]
        ClientCA["TLS_CLIENT_CA_CERT_PATH<br/>(PEM - client CA for mTLS)"]
        ServiceCerts["Per-service TLS certs<br/>(config tls section, PEM)"]
        APITokens["API tokens<br/>(service.api_token config)"]
        ProvisionedBy["All provisioned externally<br/>(manual or cert-manager)"]
    end

    HealthEndpoints --> HealthPolicy
    APIEndpoints --> APIPolicy
    APIPolicy -->|"client cert verified against"| ClientCA

    style NoRBAC fill:#f0f0f0,stroke:#999,stroke-width:1px
    style Note fill:#fff,stroke:#ccc
    style HealthAuth fill:#d5e8d4,stroke:#82b366
    style APIAuth fill:#dae8fc,stroke:#6c8ebf
    style DownstreamAuth fill:#fff2cc,stroke:#d6b656
    style Secrets fill:#f8cecc,stroke:#b85450
    style HealthEndpoints fill:#d5e8d4,stroke:#82b366
    style HealthPolicy fill:#d5e8d4,stroke:#82b366
    style APIEndpoints fill:#dae8fc,stroke:#6c8ebf
    style APIPolicy fill:#dae8fc,stroke:#6c8ebf
    style DetectorAuth fill:#fff2cc,stroke:#d6b656
    style gRPCAuth fill:#fff2cc,stroke:#d6b656
    style OpenAIAuth fill:#fff2cc,stroke:#d6b656
    style ServerCert fill:#f8cecc,stroke:#b85450
    style ServerKey fill:#f8cecc,stroke:#b85450
    style ClientCA fill:#f8cecc,stroke:#b85450
    style ServiceCerts fill:#f8cecc,stroke:#b85450
    style APITokens fill:#f8cecc,stroke:#b85450
    style ProvisionedBy fill:#f8cecc,stroke:#b85450
