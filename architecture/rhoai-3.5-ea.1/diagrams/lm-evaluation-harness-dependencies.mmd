graph LR
    LMEval["lm-evaluation-harness<br/>(Batch Job)"]

    %% Internal RHOAI Dependencies
    LMEval -->|"creates Pod from image"| TrustyAI["TrustyAI LMEval<br/>Operator"]
    LMEval -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    LMEval -->|"completion requests<br/>HTTP(S)"| ModelEP["Model Inference<br/>Endpoint<br/>(vLLM / TGI)"]

    %% External Service Dependencies
    LMEval -->|"artifact push<br/>HTTPS/443"| OCIRegistry["OCI Registry<br/>(Quay)"]
    LMEval -->|"tokenizers, datasets<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LMEval -->|"experiment logging"| MLflow["MLflow Tracking<br/>Server"]
    LMEval -->|"dataset storage<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]

    %% Python Library Dependencies
    LMEval -->|"evaluation framework"| EleutherAI["EleutherAI lm_eval<br/>v0.4.8 (fork)"]
    LMEval -->|"EvalHub integration"| EvalHubSDK["eval-hub-sdk<br/>0.1.7"]
    LMEval -->|"tensor operations"| PyTorch["PyTorch<br/>2.6.0"]
    LMEval -->|"tokenizer loading"| Transformers["Transformers<br/>4.48.0"]
    LMEval -->|"task/metric framework"| Unitxt["Unitxt<br/>1.17.2"]
    LMEval -->|"dataset management"| Datasets["HF datasets<br/>3.1.0"]
    LMEval -->|"S3 access"| Boto3["boto3<br/>1.42.12"]
    LMEval -->|"OCI artifact creation"| Olot["olot<br/>0.1.15"]
    LMEval -->|"container image push"| Skopeo["skopeo<br/>(system)"]
    LMEval -.->|"watsonx backend<br/>(optional)"| WatsonX["ibm-watsonx-ai<br/>1.4.11"]
    LMEval -->|"distributed loading"| Accelerate["accelerate<br/>1.0.1"]
    LMEval -->|"adapter support"| PEFT["PEFT<br/>0.13.2"]

    %% Build/Runtime Dependencies
    LMEval -->|"runtime"| Python["Python 3.11<br/>(UBI9)"]
    LMEval -->|"TLS/crypto"| OpenSSL["OpenSSL<br/>(UBI9 system)"]

    %% Reverse dependencies (things that use this)
    TrustyAI -.->|"orchestrates"| LMEval

