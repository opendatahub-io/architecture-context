graph TD
    subgraph "RBAC Context"
        Note["No RBAC definitions in this repository.<br/>RBAC is managed by the TrustyAI LMEval Operator."]
    end

    subgraph "Container Security"
        direction TB
        Pod["Job Pod"]
        User["Non-root User<br/>UID: 65532<br/>GID: 65532"]
        NoPrivEsc["No Privilege Escalation"]
        Pod --> User
        Pod --> NoPrivEsc
    end

    subgraph "Credential Management"
        direction TB
        ModelSecret["Model Auth Secret<br/>(model.auth.secret_ref)<br/>Type: Opaque"]
        ModelSecretKeys["Keys:<br/>- api_key (OPENAI_API_KEY)<br/>- Authorization header<br/>- hf-token (optional)<br/>- ca_cert (optional)"]
        RegistryCreds["Registry Credentials<br/>Type: dockerconfigjson<br/>or username/password"]

        ModelSecret --> ModelSecretKeys
    end

    subgraph "Authentication Flows"
        direction TB
        ModelAuth["Model Endpoint Auth<br/>Bearer Token<br/>(OPENAI_API_KEY)<br/>Resolved by evalhub SDK"]
        HFAuth["HuggingFace Auth<br/>Bearer Token<br/>(HF_TOKEN)<br/>Optional - gated datasets"]
        EvalHubAuth["EvalHub Callback Auth<br/>Bearer Token<br/>Managed by evalhub SDK"]
        RegistryAuth["OCI Registry Auth<br/>Registry creds<br/>(dockerconfig or user/pass)"]
    end

    subgraph "Security Controls"
        direction TB
        CredSanitize["Credential Sanitization<br/>_sanitize_error_message()<br/>Redacts: Bearer tokens,<br/>API keys, passwords,<br/>URL credentials"]
        PathProtect["Path Traversal Protection<br/>_resolve_job_spec_path_for_read()<br/>Confined to /meta/<br/>CWE-22 mitigation"]
        SymlinkReject["Symlink Rejection<br/>raw_path.is_symlink() check<br/>For CA bundle paths<br/>CWE-61 mitigation"]
    end

    %% Relationships
    Pod -->|"uses"| ModelSecret
    Pod -->|"uses"| RegistryCreds
    ModelSecret -->|"resolves to"| ModelAuth
    ModelSecret -->|"resolves to"| HFAuth

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style User fill:#d5e8d4,stroke:#82b366
    style NoPrivEsc fill:#d5e8d4,stroke:#82b366
    style ModelSecret fill:#f5a623,stroke:#333,color:#fff
    style ModelSecretKeys fill:#ffe6cc,stroke:#d79b00
    style RegistryCreds fill:#f5a623,stroke:#333,color:#fff
    style ModelAuth fill:#e8e8e8,stroke:#333
    style HFAuth fill:#e8e8e8,stroke:#333
    style EvalHubAuth fill:#e8e8e8,stroke:#333
    style RegistryAuth fill:#e8e8e8,stroke:#333
    style CredSanitize fill:#f8cecc,stroke:#b85450
    style PathProtect fill:#f8cecc,stroke:#b85450
    style SymlinkReject fill:#f8cecc,stroke:#b85450
