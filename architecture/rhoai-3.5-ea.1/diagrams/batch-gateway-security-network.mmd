graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        HTTPRoute["llm-d-inference-gateway<br/>HTTPRoute<br/>TLS: Inherited from Gateway"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph NS_APIServer["API Server"]
            APIServer["apiserver<br/>SA: {release}-apiserver<br/>Ports: 8000/TCP (API), 8081/TCP (obs)<br/>Middleware: Tenant extraction,<br/>Security headers, Recovery<br/>Tenant isolation: query-scoped + 404"]
        end

        subgraph NS_Processor["Batch Processor"]
            Processor["batch-processor<br/>SA: {release}-processor<br/>Port: 9090/TCP (observability)<br/>Workers: 20, Global: 100,<br/>Per-model: 10 concurrency"]
        end

        subgraph NS_GC["Garbage Collector"]
            GC["batch-gc<br/>SA: {release}-gc<br/>No HTTP ports<br/>Interval: 30m, Concurrency: 10"]
        end
    end

    subgraph DataStores["DATA STORES"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>TLS optional, mTLS supported<br/>Auth: Connection URL from secret<br/>Roles: metadata, queue, events, cache"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS via DSN<br/>Auth: Connection URL from secret<br/>Alternative metadata backend"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access Key<br/>Tenant isolation: SHA256 folder prefix"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        InferenceGW["LLM Inference Gateway<br/>Configurable port<br/>HTTP/HTTPS, TLS 1.2+, mTLS<br/>Auth: Bearer token from secret<br/>Header: x-gateway-inference-objective"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>Plaintext (configurable)<br/>Auth: None"]
    end

    %% Ingress flows
    Client -->|"HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>Auth: X-MaaS-Username header"| HTTPRoute
    HTTPRoute -->|"8000/TCP<br/>HTTP/HTTPS<br/>TLS: inherited"| APIServer

    %% API Server egress
    APIServer -->|"6379/TCP Redis<br/>TLS optional<br/>Connection URL"| Redis
    APIServer -->|"5432/TCP PostgreSQL<br/>TLS via DSN<br/>Connection URL"| PostgreSQL
    APIServer -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Key"| S3

    %% Processor egress
    Processor -->|"6379/TCP Redis<br/>TLS optional<br/>Connection URL"| Redis
    Processor -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Key"| S3
    Processor -->|"Configurable<br/>HTTP/HTTPS, TLS 1.2+<br/>Bearer token"| InferenceGW

    %% GC egress
    GC -->|"6379/TCP Redis<br/>TLS optional<br/>Connection URL"| Redis
    GC -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Key"| S3

    %% Optional telemetry
    APIServer -.->|"4317/TCP gRPC<br/>OTLP traces"| OTel
    Processor -.->|"4317/TCP gRPC<br/>OTLP traces"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class HTTPRoute ingress
    class APIServer,Processor,GC internal
    class Redis,PostgreSQL,S3 datastore
    class InferenceGW,OTel externalservice
