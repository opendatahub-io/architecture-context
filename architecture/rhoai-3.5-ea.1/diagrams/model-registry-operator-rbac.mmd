graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["model-registry-operator<br/>-controller-manager<br/>(operator namespace)"]
        SA_Registry["&lt;name&gt;<br/>(per-registry namespace)"]
        SA_Catalog["model-catalog<br/>(registries namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-operator<br/>-manager-rolebinding"]
        CRB_AuthDel["&lt;name&gt;-auth-delegator<br/>(per-registry)"]
        CRB_CatAuth["model-catalog<br/>-auth-delegator"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-operator<br/>-manager-role"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph OperatorResources["Operator Manager Resources"]
        direction TB
        MR_CRD["modelregistry.opendatahub.io<br/>modelregistries<br/>+ /status, /finalizers"]
        Deployments["apps<br/>deployments"]
        CoreResources["core<br/>pods, services, serviceaccounts,<br/>configmaps, secrets, pvcs,<br/>endpoints, events"]
        Routes["route.openshift.io<br/>routes, routes/custom-host"]
        Groups["user.openshift.io<br/>groups"]
        RBAC_Resources["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
        Migration["migration.k8s.io<br/>storageversionmigrations"]
        CRD_Read["apiextensions.k8s.io<br/>customresourcedefinitions"]
        PlatformCRDs["components.platform<br/>.opendatahub.io<br/>modelregistries"]
        AuthCRDs["services.platform<br/>.opendatahub.io<br/>auths"]
        OCP_Config["config.openshift.io<br/>ingresses"]
    end

    subgraph AuthDelegation["Auth Delegation Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph PerRegistryRBAC["Per-Registry RBAC"]
        RegRole["registry-user-&lt;name&gt;<br/>(Role)"]
        RegBinding["registry-user-&lt;name&gt;<br/>(RoleBinding)"]
        RegGroup["&lt;name&gt;-users<br/>(OpenShift Group)"]
        CatAdminRole["model-catalog-admin<br/>(Role)"]
        CatAdminBinding["model-catalog-admin<br/>(RoleBinding)"]
        AdminGroups["Admin Groups<br/>(from Auth CR)"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager

    %% Operator permissions
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| MR_CRD
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Deployments
    CR_Manager -->|"varies per resource"| CoreResources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Routes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Groups
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| RBAC_Resources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| NetworkPolicies
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Migration
    CR_Manager -->|"get,list,watch"| CRD_Read
    CR_Manager -->|"get,list,watch"| PlatformCRDs
    CR_Manager -->|"get,list,watch"| AuthCRDs
    CR_Manager -->|"get,list,watch"| OCP_Config
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create"| SAR

    %% Per-registry auth delegation
    SA_Registry -->|"bound via"| CRB_AuthDel
    CRB_AuthDel -->|"grants"| CR_AuthDel
    CR_AuthDel -->|"create"| TokenReviews
    CR_AuthDel -->|"create"| SAR

    %% Catalog auth delegation
    SA_Catalog -->|"bound via"| CRB_CatAuth
    CRB_CatAuth -->|"grants"| CR_AuthDel

    %% Per-registry user access
    RegGroup -->|"bound via"| RegBinding
    RegBinding -->|"grants"| RegRole

    %% Catalog admin access
    AdminGroups -->|"bound via"| CatAdminBinding
    CatAdminBinding -->|"grants"| CatAdminRole

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Registry fill:#4a90e2,color:#fff
    style SA_Catalog fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_AuthDel fill:#f5a623,stroke:#333
    style CRB_Manager fill:#ffe6cc,stroke:#d79b00
    style CRB_AuthDel fill:#ffe6cc,stroke:#d79b00
    style CRB_CatAuth fill:#ffe6cc,stroke:#d79b00
    style MR_CRD fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style CoreResources fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Groups fill:#7ed321,stroke:#333
    style RBAC_Resources fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
    style Migration fill:#7ed321,stroke:#333
    style CRD_Read fill:#7ed321,stroke:#333
    style PlatformCRDs fill:#7ed321,stroke:#333
    style AuthCRDs fill:#7ed321,stroke:#333
    style OCP_Config fill:#7ed321,stroke:#333
    style TokenReviews fill:#d5e8d4,stroke:#82b366
    style SAR fill:#d5e8d4,stroke:#82b366
    style RegRole fill:#dae8fc,stroke:#6c8ebf
    style RegBinding fill:#dae8fc,stroke:#6c8ebf
    style RegGroup fill:#dae8fc,stroke:#6c8ebf
    style CatAdminRole fill:#dae8fc,stroke:#6c8ebf
    style CatAdminBinding fill:#dae8fc,stroke:#6c8ebf
    style AdminGroups fill:#dae8fc,stroke:#6c8ebf
