graph LR
    OGX["OGX Distribution<br/>(odh-ogx-core)"]

    %% Core Framework Dependencies (Required)
    OGX -->|"core framework"| OGXLib["OGX (ogx)<br/>v1.0.2+rhaiv.0"]
    OGX -->|"API definitions"| OGXApi["ogx-api<br/>v1.0.2+rhaiv.0"]
    OGX -->|"HTTP server"| FastAPI["FastAPI + uvicorn"]
    OGX -->|"ML framework"| PyTorch["PyTorch (CPU)"]
    OGX -->|"ORM"| SQLAlchemy["SQLAlchemy + asyncpg"]
    OGX -->|"HTTP client"| HTTPX["httpx"]

    %% Required Internal Dependencies
    OGX -->|"persistent storage<br/>TCP/5432"| PostgreSQL["PostgreSQL<br/>(KV, SQL, agent state)"]
    OGX -->|"inference<br/>HTTP(S)"| vLLM["vLLM Inference Server"]
    OGX -->|"embeddings<br/>HTTP(S)"| vLLMEmbed["vLLM Embedding Server"]

    %% Platform Dependencies
    OGX -.->|"TLS + auth<br/>ingress"| Gateway["RHOAI Gateway<br/>(Envoy + kube-rbac-proxy)"]
    OGX -.->|"deployment"| Operator["rhods-operator<br/>(RHOAI Operator)"]

    %% Optional Cloud Inference Providers
    OGX -->|"remote inference<br/>HTTPS/443"| Bedrock["AWS Bedrock"]
    OGX -->|"remote inference<br/>HTTPS/443"| Watsonx["IBM watsonx"]
    OGX -->|"remote inference<br/>HTTPS/443"| AzureOAI["Azure OpenAI"]
    OGX -->|"remote inference<br/>HTTPS/443"| VertexAI["Google Vertex AI"]
    OGX -->|"remote inference<br/>HTTPS/443"| OpenAI["OpenAI API"]

    %% Optional Vector Database Dependencies
    OGX -->|"vector ops<br/>TCP"| Milvus["Milvus<br/>(pymilvus 2.6.9)"]
    OGX -->|"vector ops<br/>TCP/5432"| PGVector["pgvector"]
    OGX -->|"vector ops<br/>6333/6334"| Qdrant["Qdrant"]

    %% Optional Storage & Tool Dependencies
    OGX -->|"file storage<br/>HTTPS/443"| S3["S3 / S3-compatible<br/>(boto3 1.35.88)"]
    OGX -->|"web search<br/>HTTPS/443"| Brave["Brave Search API"]
    OGX -->|"web search<br/>HTTPS/443"| Tavily["Tavily Search API"]
    OGX -->|"tool protocol"| MCP["MCP Servers<br/>(mcp >=1.23.0)"]

    %% Optional Observability
    OGX -.->|"telemetry<br/>OTLP/HTTP"| OTEL["OTEL Collector"]

    %% Auth
    OGX -.->|"JWT validation<br/>HTTPS/443"| OIDC["OAuth2/OIDC Provider"]

    %% Build-time only
    OGX -.->|"model download<br/>(build-time)"| HF["HuggingFace Hub<br/>(granite-embedding-125m)"]

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core framework - blue
    style OGXLib fill:#5ba3d9,stroke:#333,color:#fff
    style OGXApi fill:#5ba3d9,stroke:#333,color:#fff
    style FastAPI fill:#5ba3d9,stroke:#333,color:#fff
    style PyTorch fill:#5ba3d9,stroke:#333,color:#fff
    style SQLAlchemy fill:#5ba3d9,stroke:#333,color:#fff
    style HTTPX fill:#5ba3d9,stroke:#333,color:#fff

    %% Required internal - green
    style PostgreSQL fill:#82b366,stroke:#333,color:#fff
    style vLLM fill:#82b366,stroke:#333
    style vLLMEmbed fill:#82b366,stroke:#333

    %% Platform - orange
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style Operator fill:#ffe6cc,stroke:#d79b00

    %% Cloud providers - purple
    style Bedrock fill:#9673a6,stroke:#333,color:#fff
    style Watsonx fill:#9673a6,stroke:#333,color:#fff
    style AzureOAI fill:#9673a6,stroke:#333,color:#fff
    style VertexAI fill:#9673a6,stroke:#333,color:#fff
    style OpenAI fill:#9673a6,stroke:#333,color:#fff

    %% Optional services - yellow
    style Milvus fill:#d6b656,stroke:#333
    style PGVector fill:#d6b656,stroke:#333
    style Qdrant fill:#d6b656,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Brave fill:#999,stroke:#333,color:#fff
    style Tavily fill:#999,stroke:#333,color:#fff
    style MCP fill:#999,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff
    style OIDC fill:#f8cecc,stroke:#b85450
    style HF fill:#999,stroke:#333,color:#fff
