graph TB
    subgraph FeastOperator["feast-operator (Go Operator)"]
        Controller["FeatureStore Controller<br/>controller-runtime"]
        NotebookCtrl["Notebook ConfigMap<br/>Reconciler"]
        AuthzCtrl["AuthZ Reconciler<br/>(RBAC auto-access)"]
        TLSMgr["TLS Manager<br/>(service serving certs)"]
        ScalingMgr["Scaling Manager<br/>(HPA, PDB, topology)"]
        CronJobMgr["CronJob Manager<br/>(materialization)"]
        Controller --> NotebookCtrl
        Controller --> AuthzCtrl
        Controller --> TLSMgr
        Controller --> ScalingMgr
        Controller --> CronJobMgr
    end

    subgraph FeastServices["Feast Services (per FeatureStore CR)"]
        direction TB
        subgraph OnlineServer["Online Server"]
            PythonFS["Feature Server (Python)<br/>FastAPI + Uvicorn<br/>Port 6566/TCP"]
            GoFS["Feature Server (Go)<br/>net/http + gRPC<br/>Port 8080/TCP"]
        end
        subgraph OfflineServer["Offline Server"]
            OfflineFS["Feature Server (Python)<br/>Offline Store API<br/>Port 6566/TCP"]
        end
        subgraph RegistryServer["Registry Server"]
            RegistryFS["Registry REST API<br/>Port 6566/TCP"]
        end
        subgraph UIServer["UI Server"]
            FeastUI["Feast UI (React)<br/>Port 8888/TCP"]
        end
        MetricsFS["Prometheus Metrics<br/>Port 8000/TCP"]
    end

    User[Data Scientist / ML Engineer] -->|creates| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|watched by| Controller

    Controller -->|deploys & manages| FeastServices
    CronJobMgr -->|creates| MaterializeCJ["Materialization<br/>CronJob"]
    MaterializeCJ -->|calls| PythonFS

    NotebookCtrl -->|watches| NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]
    NotebookCtrl -->|injects| FeastConfig["Feast Config<br/>ConfigMap"]

    AuthzCtrl -->|fetches permissions| RegistryFS
    AuthzCtrl -->|creates| K8sRBAC["K8s Roles &<br/>RoleBindings"]

    PythonFS -->|reads/writes| OnlineStore["Online Store<br/>(Redis/PostgreSQL/<br/>DynamoDB/SQLite)"]
    OfflineFS -->|reads| OfflineStore["Offline Store<br/>(Snowflake/BigQuery/<br/>DuckDB/Spark)"]
    RegistryFS -->|stores metadata| RegistryBackend["Registry Backend<br/>(SQL/S3/GCS/file)"]

    PythonFS -->|validates tokens| AuthProvider["Auth Provider<br/>(OIDC / K8s API)"]

    Controller -->|CRUD| K8sAPI["Kubernetes API"]
    Controller -->|routes| OpenShiftAPI["OpenShift API"]

