graph TB
    subgraph CLI["odh-cli (rhai-cli / kubectl-odh)"]
        direction TB

        subgraph Commands["Command Layer (cobra)"]
            Lint["lint<br/>Upgrade Readiness"]
            Backup["backup<br/>Workload Export"]
            Deps["deps<br/>Dependency Mgmt"]
            Status["status<br/>Platform Health"]
            Logs["logs<br/>Log Aggregation"]
            Components["components<br/>Lifecycle Mgmt"]
            Get["get<br/>Resource Query"]
            Migrate["migrate<br/>Cluster Migration"]
            Version["version<br/>Version Info"]
        end

        subgraph LintEngine["Lint Framework"]
            CheckRegistry["Check Registry<br/>30+ Checks"]
            Executor["Sequential Executor"]
            DiagResult["DiagnosticResult<br/>Condition-based"]
            CheckRegistry --> Executor
            Executor --> DiagResult
        end

        subgraph BackupEngine["Backup Engine"]
            WorkloadDiscovery["Workload Discovery"]
            DepResolver["Dependency Resolver<br/>Registry Pattern"]
            ManifestWriter["Manifest Writer<br/>YAML Output"]
            WorkloadDiscovery --> DepResolver
            DepResolver --> ManifestWriter
        end

        subgraph MigrateEngine["Migration Framework"]
            ActionRegistry["Action Registry"]
            KueueRHBOK["Kueue RHBOK<br/>Migration"]
            ActionRegistry --> KueueRHBOK
        end

        subgraph ClientLayer["Client Layer"]
            K8sClient["client-go<br/>QPS=50, Burst=100"]
            CRClient["controller-runtime<br/>Read-Only Client"]
            OLMReader["OLM Reader<br/>CSV/Subscription"]
            VersionDetector["Version Detector<br/>DSC/DSCI/CSV"]
        end

        subgraph Output["Output Layer"]
            Envelope["Output Envelope<br/>JSON/YAML/Table"]
            Schema["JSON Schema"]
            TableWriter["Table Renderer"]
        end

        Lint --> LintEngine
        Backup --> BackupEngine
        Migrate --> MigrateEngine
        Deps --> ClientLayer
        Status --> ClientLayer
        Logs --> ClientLayer
        Components --> ClientLayer
        Get --> ClientLayer
        LintEngine --> CRClient
        BackupEngine --> K8sClient
        MigrateEngine --> K8sClient
        Lint --> Output
        Backup --> Output
        Status --> Output
        Get --> Output
    end

    subgraph Bundled["Bundled Tools (Container)"]
        YQ["yq<br/>FIPS-compliant"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Python/Shell scripts"]
        OC["oc / kubectl"]
        JQ["jq"]
    end

    subgraph ExternalAPIs["External APIs"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        OSCAPI["OpenShift API<br/>ClusterVersion, ImageStreams"]
        OLMAPI["OLM API<br/>Subscriptions, CSVs"]
    end

    subgraph ExternalServices["External Services"]
        GitHub["raw.githubusercontent.com<br/>443/TCP HTTPS"]
    end

    User["Cluster Admin<br/>(kubeconfig)"] -->|"CLI invocation"| CLI

    K8sClient -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    CRClient -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    OLMReader -->|"HTTPS/6443<br/>Bearer Token"| OLMAPI
    VersionDetector -->|"HTTPS/6443<br/>Bearer Token"| OSCAPI
    Deps -->|"HTTPS/443<br/>deps --refresh"| GitHub

    subgraph CRDs["CRDs Read (via K8s API)"]
        DSC["DataScienceCluster"]
        DSCI["DSCInitialization"]
        ComponentCRs["Component CRs"]
        Notebooks["Notebooks"]
        ISVC["InferenceService"]
        ServingRT["ServingRuntime"]
        RayCluster["RayCluster/RayJob"]
        DSPA["DSPA"]
        Guardrails["GuardrailsOrchestrator"]
        LlamaStack["LlamaStackDistribution"]
        HWProfile["HardwareProfile"]
        AccProfile["AcceleratorProfile"]
        Kueue["ClusterQueue/LocalQueue"]
        AppWrapper["AppWrapper"]
    end

    CRClient -->|"read-only"| CRDs

    style CLI fill:#4a90e2,stroke:#333,stroke-width:2px
    style Commands fill:#6ba5e7,stroke:#333
    style LintEngine fill:#5b9bd5,stroke:#333
    style BackupEngine fill:#5b9bd5,stroke:#333
    style MigrateEngine fill:#5b9bd5,stroke:#333
    style ClientLayer fill:#4a7fb5,stroke:#333
    style Output fill:#6ba5e7,stroke:#333
    style Bundled fill:#e8e8e8,stroke:#999
    style ExternalAPIs fill:#f5a623,stroke:#333
    style ExternalServices fill:#f5a623,stroke:#333
    style CRDs fill:#7ed321,stroke:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
