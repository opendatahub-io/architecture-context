graph LR
    TrustyAI["TrustyAI<br/>Explainability<br/>Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"lifecycle mgmt<br/>Kubernetes API"| Operator["trustyai-service-<br/>operator"]
    TrustyAI -->|"inference payloads<br/>REST + CloudEvents"| KServe["KServe"]
    TrustyAI -->|"inference payloads<br/>REST"| ModelMesh["ModelMesh"]
    TrustyAI -->|"CloudEvents<br/>inference events"| Knative["Knative Eventing"]

    %% External Framework Dependencies
    TrustyAI -->|"app framework<br/>REST, DI, health"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"v2 inference<br/>protocol"| gRPC["gRPC 1.75.0"]
    TrustyAI -->|"payload<br/>serialization"| Protobuf["Protobuf 3.25.5"]
    TrustyAI -->|"async networking<br/>transport"| Netty["Netty 4.1.125"]
    TrustyAI -->|"JSON ser/deser"| Jackson["Jackson 2.15.0"]
    TrustyAI -->|"constraint solver<br/>Counterfactual"| OptaPlanner["OptaPlanner 8.30.0"]

    %% Conditional Dependencies
    TrustyAI -.->|"database storage<br/>JDBC (conditional)"| Hibernate["Hibernate ORM<br/>6.2.13"]
    TrustyAI -.->|"S3 storage<br/>(conditional)"| MinIOClient["MinIO Client<br/>3.3.1"]
    TrustyAI -.->|"Java-Python<br/>exchange (optional)"| Arrow["Apache Arrow<br/>15.0.2"]
    TrustyAI -.->|"NLP processing<br/>(optional)"| OpenNLP["OpenNLP 1.9.2"]

    %% Infrastructure Dependencies
    TrustyAI -->|"metric scrape<br/>HTTP /q/metrics"| Prometheus["Prometheus<br/>(Micrometer)"]

    %% Storage Backends
    TrustyAI -.->|"JDBC 3306/TCP<br/>(when storage=DATABASE)"| MariaDB["MariaDB /<br/>MySQL"]
    TrustyAI -.->|"HTTP/HTTPS<br/>(when storage=MINIO)"| MinIO["MinIO / S3<br/>Storage"]
    TrustyAI -.->|"File I/O<br/>(when storage=PVC)"| PVC["Kubernetes<br/>PVC"]

    %% Integration Points (inbound)
    ModelMesh -->|"POST /consumer/kserve/v2<br/>8080/TCP"| TrustyAI
    KServe -->|"CloudEvents<br/>8080/TCP"| TrustyAI
    Prometheus -->|"GET /q/metrics<br/>8080/TCP"| TrustyAI

