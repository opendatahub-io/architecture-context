graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph ControlPlane["Control Plane (opendatahub namespace)"]
            Controller["maas-controller<br/>Go Operator<br/>8080/TCP metrics<br/>8081/TCP health"]
            Controller -->|"reconciles"| ConfigCR["Config CR<br/>(Cluster-scoped GC root)"]
            Controller -->|"reconciles"| TenantCR["Tenant CR<br/>(Platform singleton)"]
            Controller -->|"reconciles"| ModelRefCR["MaaSModelRef CR"]
            Controller -->|"reconciles"| AuthPolicyCR["MaaSAuthPolicy CR"]
            Controller -->|"reconciles"| SubscriptionCR["MaaSSubscription CR"]
            Controller -->|"reconciles"| ExternalModelCR["ExternalModel CR"]
        end

        subgraph DataPlane["Data Plane (opendatahub namespace)"]
            API["maas-api<br/>Go/Gin HTTP<br/>8080/TCP (HTTP)<br/>8443/TCP (HTTPS)<br/>9090/TCP metrics"]
            API -->|"stores hashes"| PostgreSQL[(PostgreSQL<br/>5432/TCP)]
        end

        subgraph GatewayPlane["Gateway Plane (openshift-ingress namespace)"]
            Gateway["maas-default-gateway<br/>Gateway API<br/>80/TCP, 443/TCP"]
            PayloadProc["payload-processing<br/>Envoy ext_proc<br/>9004/TCP gRPC<br/>9005/TCP metrics"]
        end
    end

    %% Controller creates downstream resources
    Controller -->|"deploys via kustomize"| API
    Controller -->|"deploys"| PayloadProc
    Controller -->|"creates"| KuadrantAuthPolicy["Kuadrant AuthPolicy"]
    Controller -->|"creates"| KuadrantRateLimit["Kuadrant TokenRateLimitPolicy"]
    Controller -->|"creates"| HTTPRoute["Gateway API HTTPRoute"]
    Controller -->|"creates"| ServiceEntry["Istio ServiceEntry"]
    Controller -->|"creates"| DestRule["Istio DestinationRule"]
    Controller -->|"creates"| EnvoyFilter["Istio EnvoyFilter"]
    Controller -->|"watches"| LLMISvc["KServe LLMInferenceService"]

    %% Data flow through Gateway
    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"AuthN/AuthZ"| Authorino["Kuadrant Authorino"]
    Authorino -->|"callback<br/>validate API key"| API
    Authorino -->|"callback<br/>select subscription"| API
    Gateway -->|"ext_proc<br/>gRPC/9004"| PayloadProc
    Gateway -->|"route traffic"| ModelEndpoint["Model Endpoint<br/>(KServe / External)"]

    %% External providers
    PayloadProc -->|"injects credentials"| ExternalProvider["External LLM Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS"]

    %% Styling
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef api fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef gateway fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef crd fill:#f8e71c,stroke:#333,stroke-width:1px,color:#333
    classDef external fill:#e8e8e8,stroke:#999,stroke-width:1px,color:#333
    classDef kuadrant fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    classDef istio fill:#466bb0,stroke:#333,stroke-width:1px,color:#fff

    class Controller controller
    class API api
    class Gateway,PayloadProc gateway
    class ConfigCR,TenantCR,ModelRefCR,AuthPolicyCR,SubscriptionCR,ExternalModelCR crd
    class Client,PostgreSQL,ExternalProvider,ModelEndpoint external
    class KuadrantAuthPolicy,KuadrantRateLimit,Authorino kuadrant
    class ServiceEntry,DestRule,EnvoyFilter,LLMISvc istio
    class HTTPRoute gateway
