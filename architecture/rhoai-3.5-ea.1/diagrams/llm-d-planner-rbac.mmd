graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["planner-gpu-reader<br/>Kind: ClusterRoleBinding<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["planner-gpu-reader<br/>Kind: ClusterRole"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core (v1)<br/>nodes"]
    end

    subgraph Verbs["Permitted Operations"]
        ListVerb["list"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"list"| Nodes

    subgraph Secrets["Secrets (Namespace: planner)"]
        PlannerSecrets["planner-secrets<br/>Type: Opaque<br/>Keys: postgres-password, model-catalog-token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        HFSecret["hf-token-secret<br/>Type: Opaque<br/>Keys: HF_TOKEN<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph NetworkPolicies["Network Policies"]
        NP["networkpolicy-model-catalog<br/>Namespace: rhoai-model-registries<br/>Type: Ingress"]
    end

    subgraph NPRules["Network Policy Rules"]
        NPAllow["Allow ingress from:<br/>Namespace: planner<br/>Port: 8443/TCP<br/>To: Model Catalog pods"]
    end

    NP -->|"defines"| NPAllow

    subgraph PodSecurity["Pod Security Context"]
        BackendSec["Backend API Pod<br/>runAsNonRoot: true<br/>allowPrivilegeEscalation: false<br/>capabilities: drop ALL<br/>seccompProfile: RuntimeDefault"]
    end

    SA -.->|"identity of"| BackendSec
    PlannerSecrets -.->|"mounted in"| BackendSec
    HFSecret -.->|"referenced by<br/>generated manifests"| BackendSec

    %% Auth Endpoints (no auth)
    subgraph AuthSummary["Authentication Summary"]
        NoAuth["Backend API Endpoints<br/>29 endpoints<br/>Auth: NONE<br/>CORS: * (all origins)"]
        RouteAuth["OpenShift Routes<br/>TLS edge termination<br/>No user authentication"]
        K8sAuth["Kubernetes API Access<br/>Auth: SA Token (automount)<br/>RBAC: nodes.list only"]
        MCAuth["Model Catalog Access<br/>Auth: Bearer Token<br/>(SA token or Secret)"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#f5a623,stroke:#333
    style CR fill:#f5a623,stroke:#333
    style Nodes fill:#7ed321,stroke:#333
    style ListVerb fill:#d5e8d4,stroke:#82b366
    style PlannerSecrets fill:#e6b8af,stroke:#cc4125
    style HFSecret fill:#e6b8af,stroke:#cc4125
    style NP fill:#dae8fc,stroke:#6c8ebf
    style NPAllow fill:#dae8fc,stroke:#6c8ebf
    style BackendSec fill:#d5e8d4,stroke:#82b366
    style NoAuth fill:#f4cccc,stroke:#cc0000
    style RouteAuth fill:#fff2cc,stroke:#d6b656
    style K8sAuth fill:#d5e8d4,stroke:#82b366
    style MCAuth fill:#d5e8d4,stroke:#82b366
