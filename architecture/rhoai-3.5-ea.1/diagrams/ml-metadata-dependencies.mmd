graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% External Build/Runtime Dependencies
    MLMD -->|"RPC framework"| gRPC["gRPC C++ 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protocol Buffers 3.21.12"]
    MLMD -->|"core utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL<br/>(bundled, non-FIPS)"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL f764f4e9"]
    MLMD -->|"build system"| Bazel["Bazel 5.3.0+"]

    %% Database Backend Dependencies
    MLMD -->|"embedded DB"| SQLite["SQLite 3.39.2"]
    MLMD -->|"MySQL client"| MySQLLib["libmysqlclient<br/>(bundled)"]
    MLMD -->|"PostgreSQL client"| LibPQ["libpq 12.17"]

    %% External Database Services
    MLMD -->|"metadata persistence<br/>3306/TCP"| MySQLDB["MySQL/MariaDB<br/>Database"]
    MLMD -->|"metadata persistence<br/>5432/TCP"| PostgreSQLDB["PostgreSQL<br/>Database"]

    %% Internal RHOAI Dependencies (consumers)
    KFP["Kubeflow Pipelines"] -->|"gRPC client<br/>8080/TCP"| MLMD
    DSP["Data Science Pipelines<br/>(RHOAI)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    PipelineUI["Pipeline UI<br/>Components"] -->|"gRPC client<br/>8080/TCP"| MLMD
    TFX["TFX Components"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Deployment dependency
    DSPOperator["DSP Operator"] -.->|"deploys &<br/>configures"| MLMD

    %% Python Library
    subgraph PythonEcosystem["Python Library Dependencies"]
        PyLib["ml-metadata<br/>Python Package"]
        PyLib -->|"bindings"| Pybind11["pybind11 2.10.1"]
        PyLib -->|"gRPC client"| Grpcio["grpcio >=1.8.6,<2"]
        PyLib -->|"protobuf"| PyProtobuf["protobuf >=3.13,<4"]
        PyLib -->|"utilities"| AbslPy["absl-py >=0.9,<2"]
    end
    PyLib -.->|"gRPC client mode<br/>8080/TCP"| MLMD

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style gRPC fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333
    style Abseil fill:#999,stroke:#333
    style BoringSSL fill:#e74c3c,stroke:#333,color:#fff
    style ZetaSQL fill:#999,stroke:#333
    style Bazel fill:#999,stroke:#333
    style SQLite fill:#999,stroke:#333
    style MySQLLib fill:#999,stroke:#333
    style LibPQ fill:#999,stroke:#333

    style MySQLDB fill:#f5a623,stroke:#333
    style PostgreSQLDB fill:#f5a623,stroke:#333

    style KFP fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style PipelineUI fill:#7ed321,stroke:#333
    style TFX fill:#7ed321,stroke:#333
    style DSPOperator fill:#7ed321,stroke:#333

    style PyLib fill:#9b59b6,stroke:#333,color:#fff
    style Pybind11 fill:#bdc3c7,stroke:#333
    style Grpcio fill:#bdc3c7,stroke:#333
    style PyProtobuf fill:#bdc3c7,stroke:#333
    style AbslPy fill:#bdc3c7,stroke:#333
