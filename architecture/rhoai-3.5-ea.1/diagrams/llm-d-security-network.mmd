graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Gateway Controller<br/>(Envoy / Istio / agentgateway)<br/>80/TCP → internal<br/>443/TCP → internal (if TLS)<br/>TLS: provider-dependent<br/>Auth: configurable"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (No default encryption)"]
        direction TB

        subgraph RoutingNS["Routing Layer"]
            EPP["llm-d EPP<br/>SA: {release-name}-epp<br/>80/TCP HTTP (proxy)<br/>9090/TCP HTTP (metrics)<br/>ext-proc gRPC (Gateway)"]
        end

        subgraph InferenceNS["Inference Layer"]
            ModelServer1["Model Server Pod (vLLM)<br/>llm-d-cuda / rocm / hpu / cpu<br/>UID: 2000 (CUDA) / root (others)<br/>8000/TCP HTTP (API + metrics)<br/>5556/TCP ZMQ (KV events)<br/>No TLS, No Auth"]
            ModelServer2["Model Server Pod (vLLM)<br/>8000/TCP HTTP<br/>No TLS, No Auth"]
        end

        subgraph DataPlane["Data Transfer Plane (Unencrypted)"]
            NIXL_UCX["NIXL/UCX Peers<br/>RDMA/TCP varies<br/>No encryption<br/>KV cache transfer"]
            NVSHMEM_Peers["NVSHMEM Peers<br/>RDMA/IB varies<br/>No encryption<br/>Multi-GPU shared memory"]
        end

        subgraph Observability["Observability"]
            Prometheus["Prometheus<br/>Scrapes 8000/TCP + 9090/TCP<br/>HTTP, No Auth"]
            OTEL["OTEL Collector<br/>4317/TCP gRPC<br/>No encryption"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>mTLS<br/>SA Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
    end

    %% Flows with security details
    Client -->|"HTTP 80/TCP or HTTPS 443/TCP<br/>TLS: provider-dependent<br/>Auth: configurable"| Gateway
    Gateway -->|"gRPC ext-proc<br/>No encryption<br/>No auth"| EPP
    EPP -->|"HTTP 8000/TCP<br/>No encryption<br/>Metrics scrape"| ModelServer1
    Gateway -->|"HTTP 8000/TCP<br/>No encryption<br/>No auth"| ModelServer1
    Gateway -->|"HTTP 8000/TCP<br/>No encryption<br/>No auth"| ModelServer2

    ModelServer1 -->|"ZMQ 5556/TCP<br/>No encryption<br/>KV events"| EPP

    ModelServer1 <-->|"RDMA/TCP varies<br/>No encryption<br/>KV cache"| NIXL_UCX
    ModelServer2 <-->|"RDMA/TCP varies<br/>No encryption<br/>KV cache"| NIXL_UCX
    ModelServer1 <-->|"RDMA/IB varies<br/>No encryption<br/>GPU memory"| NVSHMEM_Peers

    ModelServer1 -->|"/metrics 8000/TCP HTTP"| Prometheus
    EPP -->|"9090/TCP HTTP"| Prometheus
    ModelServer1 -->|"gRPC 4317/TCP<br/>No encryption"| OTEL
    EPP -->|"gRPC 4317/TCP<br/>No encryption"| OTEL

    EPP -->|"HTTPS 443/TCP<br/>mTLS<br/>SA Token"| K8sAPI

    ModelServer1 -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,ModelServer1,ModelServer2 internal
    class NIXL_UCX,NVSHMEM_Peers dataplane
    class Prometheus,OTEL observability
    class K8sAPI controlplane
    class HFHub externalservice
