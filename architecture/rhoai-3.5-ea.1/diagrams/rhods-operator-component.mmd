graph TB
    subgraph Operator["rhods-operator (RHOAI Platform Operator)"]
        direction TB

        subgraph Manager["manager Binary"]
            direction TB
            DSCController["DSC Controller<br/>DataScienceCluster lifecycle"]
            DSCIController["DSCI Controller<br/>DSCInitialization lifecycle"]
            GatewayController["Gateway Controller<br/>Ingress & auth infrastructure"]
            AuthController["Auth Controller<br/>RBAC & group management"]
            MonitoringController["Monitoring Controller<br/>Prometheus/COO stack"]
            CertConfigGen["CertConfigMap Generator<br/>Trusted CA bundle sync"]
            SetupController["Setup Controller<br/>Initial platform detection"]

            subgraph ComponentControllers["Component Controllers (16)"]
                direction LR
                DashCtrl["Dashboard"]
                KServeCtrl["KServe"]
                DSPCtrl["DSP"]
                MRCtrl["ModelRegistry"]
                KubeRayCtrl["KubeRay"]
                KueueCtrl["Kueue"]
                TrainingCtrl["TrainingOp"]
                TrainerCtrl["Trainer"]
                TrustyCtrl["TrustyAI"]
                FeastCtrl["Feast"]
                SparkCtrl["Spark"]
                OGXCtrl["OGX"]
                MLflowCtrl["MLflow"]
                MaaSCtrl["MaaS"]
                ModelCtrlCtrl["ModelCtrl"]
                WBCtrl["Workbenches"]
            end

            subgraph Webhooks["Admission Webhooks (14)"]
                direction LR
                ValDSC["DSC Validators<br/>(v1 + v2)"]
                MutDSC["DSC Defaulters<br/>(v1 + v2)"]
                ValDSCI["DSCI Validators<br/>(v1 + v2)"]
                HWProfileInj["HardwareProfile<br/>Injector"]
                ConnNotebook["Connection<br/>Notebook"]
                ConnISVC["Connection<br/>ISVC"]
                ConnLLMISVC["Connection<br/>LLMISVC"]
                MonitorInj["Monitor<br/>Injector"]
                DeprecationVal["Deprecation<br/>Validators"]
            end
        end

        subgraph CloudMgr["cloudmanager Binary (XKS only)"]
            AzureCtrl["Azure AKS Controller"]
            CoreWeaveCtrl["CoreWeave Controller"]
        end
    end

    %% Primary CRs
    DSCCR["DataScienceCluster CR<br/>(cluster-scoped singleton)"]
    DSCICR["DSCInitialization CR<br/>(cluster-scoped singleton)"]
    GatewayConfigCR["GatewayConfig CR"]
    AuthCR["Auth CR"]

    %% User
    Admin["Platform Admin"]

    %% External systems
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    OAuthServer["OpenShift OAuth<br/>443/TCP"]
    IstioEnvoy["Istio / Envoy<br/>Data Plane"]

    %% Flows
    Admin -->|creates| DSCCR
    Admin -->|creates| DSCICR
    DSCCR -->|watched by| DSCController
    DSCICR -->|watched by| DSCIController
    GatewayConfigCR -->|watched by| GatewayController
    AuthCR -->|watched by| AuthController

    DSCController -->|creates component CRs| ComponentControllers
    DSCIController -->|initializes| GatewayController
    DSCIController -->|initializes| AuthController
    DSCIController -->|initializes| MonitoringController

    GatewayController -->|configures| IstioEnvoy
    GatewayController -->|creates OAuthClient| OAuthServer

    Manager -->|CRUD resources| K8sAPI
    CloudMgr -->|Helm deploys| K8sAPI

    %% Styling
    style Operator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Manager fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CloudMgr fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ComponentControllers fill:#f0f0f0,stroke:#999,stroke-width:1px
    style Webhooks fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style DSCCR fill:#f5a623,stroke:#333
    style DSCICR fill:#f5a623,stroke:#333
    style GatewayConfigCR fill:#f5a623,stroke:#333
    style AuthCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style IstioEnvoy fill:#e8e8e8,stroke:#333
    style Admin fill:#bbdefb,stroke:#333
