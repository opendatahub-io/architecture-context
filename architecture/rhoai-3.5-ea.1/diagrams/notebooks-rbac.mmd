graph TD
    subgraph NotebookControllerManaged["Notebook Controller Managed RBAC"]
        direction TB

        subgraph ServiceAccounts["Service Accounts (per-notebook)"]
            NotebookSA["Per-Notebook ServiceAccount<br/>(created by Notebook Controller)"]
        end

        subgraph RoleBindings["Role Bindings (per-notebook)"]
            NotebookRB["Per-Notebook RoleBinding<br/>(created by Notebook Controller)"]
        end

        subgraph Roles["Roles / Permissions"]
            NotebookRole["Per-Notebook Role<br/>(namespace-scoped)"]
        end

        NotebookSA -->|"bound via"| NotebookRB
        NotebookRB -->|"grants"| NotebookRole
    end

    subgraph PodSecurity["Pod Security Context"]
        direction TB
        UserID["User: 1001 (non-root)"]
        NoPrivEsc["No privilege escalation"]
        ReadOnlyFS["Read-only root filesystem<br/>(where applicable)"]
    end

    subgraph AuthProxy["Authentication Proxy (kube-rbac-proxy)"]
        direction TB

        KRBAC["kube-rbac-proxy sidecar<br/>Injected by Notebook Controller<br/>Port: 8443/TCP"]

        subgraph AuthMechanisms["Authentication Mechanisms"]
            BearerToken["Bearer Token<br/>(user sessions via Gateway)"]
            SAToken["Service Account Token<br/>(culler, internal services)"]
        end

        subgraph AuthZPolicy["Authorization Policy"]
            RBACAuthZ["Kubernetes RBAC-based<br/>user authorization"]
        end

        KRBAC -->|"validates"| AuthMechanisms
        KRBAC -->|"enforces"| AuthZPolicy
    end

    subgraph ProtectedEndpoints["Protected Endpoints"]
        JupyterEndpoint["JupyterLab<br/>8888/TCP HTTP<br/>/lab, /api/kernels/"]
        CodeServerEndpoint["code-server<br/>80/TCP HTTP<br/>nginx → code-server"]
    end

    subgraph InternalEndpoints["Internal-Only Endpoints (No Auth)"]
        KernelsAPI["/api/kernels/<br/>Pod-internal only<br/>Consumed by culler<br/>via kube-rbac-proxy"]
        HealthEndpoint["/codeserver/healthz<br/>Pod-internal only<br/>Consumed by CGI script"]
    end

    subgraph SecretsManagement["Secrets (Mounted by Notebook Controller)"]
        DSPASecret["DSPA Connection Secret<br/>Type: Opaque<br/>Mount: /opt/app-root/runtimes/<br/>Auto-rotate: No"]
        CABundle["CA Certificate Bundle<br/>Type: Opaque<br/>Mount: /etc/pki/tls/custom-certs/ca-bundle.crt<br/>Auto-rotate: No"]
    end

    subgraph Consumers["RBAC Consumers"]
        Gateway["Platform Gateway<br/>(Envoy)"]
        Culler["Notebook Controller Culler"]
        Operator["rhods-operator"]
        Dashboard["ODH Dashboard"]
    end

    %% Auth flows
    Gateway -->|"HTTPS/443<br/>OAuth/OIDC"| KRBAC
    Culler -->|"HTTPS/8443<br/>SA token"| KRBAC
    KRBAC -->|"HTTP (pod-internal)"| ProtectedEndpoints

    %% Operator RBAC (separate from notebook RBAC)
    Operator -->|"SA auth<br/>6443/TCP"| K8sAPI["Kubernetes API<br/>ImageStream CRUD"]
    Dashboard -->|"SA auth<br/>6443/TCP"| K8sAPIRead["Kubernetes API<br/>ImageStream Read"]

    %% Secrets mounted into pods
    DSPASecret -.->|"mounted into"| JupyterEndpoint
    CABundle -.->|"mounted into"| JupyterEndpoint
    DSPASecret -.->|"mounted into"| CodeServerEndpoint
    CABundle -.->|"mounted into"| CodeServerEndpoint

    %% Styling
    style KRBAC fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style NotebookSA fill:#4a90e2,stroke:#333,color:#fff
    style NotebookRB fill:#dae8fc,stroke:#6c8ebf
    style NotebookRole fill:#f5a623,stroke:#333
    style JupyterEndpoint fill:#d5e8d4,stroke:#82b366
    style CodeServerEndpoint fill:#d5e8d4,stroke:#82b366
    style KernelsAPI fill:#fff2cc,stroke:#d6b656
    style HealthEndpoint fill:#fff2cc,stroke:#d6b656
    style DSPASecret fill:#e1d5e7,stroke:#9673a6
    style CABundle fill:#e1d5e7,stroke:#9673a6
    style UserID fill:#d5e8d4,stroke:#82b366
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style Culler fill:#dae8fc,stroke:#6c8ebf
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
