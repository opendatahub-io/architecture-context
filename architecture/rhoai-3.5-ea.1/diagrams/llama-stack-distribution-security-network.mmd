graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) — RHOAI Platform Layer"]
        direction TB
        Gateway["RHOAI Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.3 Termination<br/>JWT Validation"]
        KRBP["kube-rbac-proxy sidecar<br/>8443/TCP → 8321/TCP<br/>TLS → plaintext (localhost)<br/>K8s RBAC AuthZ"]
        Gateway --> KRBP
    end

    subgraph Application["APPLICATION (OGX Server)"]
        OGX["OGX Server (odh-ogx-core)<br/>8321/TCP HTTP (plaintext)<br/>Non-root: CNB_USER_ID<br/>OAuth2 JWT middleware (conditional)<br/>Image: quay.io/rhoai/odh-ogx-core-rhel9"]
    end

    subgraph RequiredBackends["REQUIRED BACKENDS"]
        PG["PostgreSQL<br/>5432/TCP<br/>plaintext (in-cluster)<br/>Username/Password"]
    end

    subgraph PrimaryInference["PRIMARY INFERENCE"]
        vLLM["vLLM Inference Server<br/>configurable port<br/>HTTP/HTTPS (TLS configurable)<br/>Bearer Token"]
        vLLME["vLLM Embedding Server<br/>configurable port<br/>HTTP/HTTPS (TLS configurable)<br/>Bearer Token"]
    end

    subgraph CloudInference["OPTIONAL CLOUD INFERENCE (443/TCP HTTPS TLS 1.2+)"]
        Bedrock["AWS Bedrock<br/>Bearer Token"]
        Watsonx["IBM watsonx<br/>API Key"]
        Azure["Azure OpenAI<br/>API Key"]
        VertexAI["Google Vertex AI<br/>App Default Creds"]
        OpenAI["OpenAI API<br/>API Key"]
    end

    subgraph VectorDBs["OPTIONAL VECTOR DATABASES"]
        Milvus["Milvus (remote)<br/>configurable port/TCP<br/>TLS optional (CA cert)<br/>Token Auth"]
        PGVector["pgvector<br/>5432/TCP<br/>plaintext<br/>Username/Password"]
        Qdrant["Qdrant<br/>6333/TCP (HTTP) or 6334/TCP (gRPC)<br/>HTTPS optional<br/>API Key"]
    end

    subgraph ExternalServices["OPTIONAL EXTERNAL SERVICES (443/TCP HTTPS TLS 1.2+)"]
        S3["S3 / S3-compatible<br/>AWS IAM Credentials"]
        Brave["Brave Search API<br/>API Key"]
        Tavily["Tavily Search API<br/>API Key"]
    end

    subgraph AuthProvider["AUTH PROVIDER"]
        OIDC["OAuth2 / OIDC Provider<br/>443/TCP HTTPS<br/>TLS (verify configurable)<br/>JWKS Endpoint (public)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer JWT"| Gateway
    KRBP -->|"HTTP/8321<br/>localhost (no encryption)<br/>Auth proxied"| OGX

    OGX -->|"TCP/5432<br/>plaintext<br/>User/Pass"| PG

    OGX -->|"HTTP(S)<br/>TLS configurable<br/>Bearer Token"| vLLM
    OGX -->|"HTTP(S)<br/>TLS configurable<br/>Bearer Token"| vLLME

    OGX -->|"HTTPS/443<br/>TLS 1.2+"| Bedrock
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| Watsonx
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| Azure
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| VertexAI
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| OpenAI

    OGX -->|"TCP<br/>TLS optional"| Milvus
    OGX -->|"TCP/5432<br/>plaintext"| PGVector
    OGX -->|"HTTP or gRPC<br/>6333 or 6334"| Qdrant

    OGX -->|"HTTPS/443<br/>TLS 1.2+"| S3
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| Brave
    OGX -->|"HTTPS/443<br/>TLS 1.2+"| Tavily

    OGX -.->|"HTTPS/443<br/>JWKS validation"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef required fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cloud fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,KRBP ingress
    class OGX application
    class PG,vLLM,vLLME required
    class Bedrock,Watsonx,Azure,VertexAI,OpenAI cloud
    class Milvus,PGVector,Qdrant,S3,Brave,Tavily optional
    class OIDC auth
