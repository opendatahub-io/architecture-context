    %% Dependency relationships
    AutogluonServer -->|"tabular prediction"| AutoGluonTabular
    AutogluonServer -->|"timeseries forecasting"| AutoGluonTS
    AutoGluonTabular -->|"deep learning backend"| PyTorch
    AutoGluonTabular -->|"gradient boosting"| LightGBM
    AutoGluonTabular -->|"gradient boosting"| XGBoost
    AutoGluonTabular -->|"ML utilities"| ScikitLearn
    AutoGluonTS -->|"Chronos models"| Transformers

    AutogluonServer -->|"REST/gRPC serving"| KServeSDK
    AutogluonServer -->|"model download"| KServeStorage
    KServeSDK -->|"REST API"| FastAPI
    KServeSDK -->|"ASGI server"| Uvicorn
    KServeSDK -->|"gRPC server"| GRPCIO
    KServeSDK -->|"metrics"| PromClient
    KServeStorage -->|"S3 access"| Boto3
    KServeStorage -->|"TLS/crypto"| Cryptography

    AutogluonServer -->|"data processing"| Pandas
    AutogluonServer -->|"numerics"| Numpy

    %% Platform relationships
    KServeCtrl -->|"deploys via CRD"| AutogluonServer
    StorageInit -->|"downloads models to /mnt/models"| AutogluonServer
    QueueProxy -->|"routes HTTP/8080"| AutogluonServer
    PlatformGW -->|"HTTPS ingress"| AutogluonServer
    PromServer -->|"scrapes /metrics"| AutogluonServer

    %% External storage
    KServeStorage -.->|"HTTPS/443"| S3
    KServeStorage -.->|"HTTPS/443"| GCS
    KServeStorage -.->|"HTTPS/443"| AzureBlob
    KServeStorage -.->|"HTTPS/443"| HuggingFace

