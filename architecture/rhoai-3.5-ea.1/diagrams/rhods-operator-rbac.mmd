graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["rhods-operator<br/>(operator namespace)"]
        SA_AuthProxy["kube-auth-proxy<br/>(applications namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["rhods-operator-manager<br/>binding"]
        CRB_AuthDelegate["kube-auth-proxy-tokenreview<br/>(system:auth-delegator)"]
        CRB_AdminGroup["data-science-admingroupcluster<br/>-rolebinding"]
        CRB_AllowedGroup["data-science-allowedgroupcluster<br/>-rolebinding"]
        CRB_KueueAdmin["kueue-admin<br/>-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["rhods-operator (manager)"]
        CR_AuthDelegate["system:auth-delegator"]
        CR_AdminGroup["data-science-admingroupcluster-role"]
        CR_AllowedGroup["data-science-allowedgroupcluster-role"]
        CR_KueueAdmin["kueue-batch-admin-role"]
    end

    subgraph Groups["User Groups (from Auth CR)"]
        AdminGroups["Admin Groups<br/>(configured in Auth CR)"]
        AllowedGroups["Allowed Groups<br/>(configured in Auth CR)"]
    end

    subgraph ODH_Resources["ODH Platform Resources"]
        DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters (+status,finalizers)"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations (+status,finalizers)"]
        CompCRDs["components.platform.opendatahub.io<br/>(16 component types:<br/>dashboards, kserves, kueues, rays,<br/>trustyais, modelregistries, etc.)"]
        SvcCRDs["services.platform.opendatahub.io<br/>auths, monitorings, gatewayconfigs<br/>(+status, +finalizers)"]
        HWProfile["infrastructure.opendatahub.io<br/>hardwareprofiles"]
        FeatureTracker["features.opendatahub.io<br/>featuretrackers"]
    end

    subgraph K8s_Resources["Kubernetes Core Resources"]
        GatewayRes["gateway.networking.k8s.io<br/>gateways, gatewayclasses, httproutes"]
        IstioRes["networking.istio.io<br/>destinationrules, envoyfilters"]
        RouteRes["route.openshift.io<br/>routes, routes/custom-host"]
        OAuthRes["oauth.openshift.io<br/>oauthclients"]
        RBACRes["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
        CRDRes["apiextensions.k8s.io<br/>customresourcedefinitions"]
        WebhookRes["admissionregistration.k8s.io<br/>validating/mutating webhooks,<br/>validatingadmissionpolicies"]
        MonitorRes["monitoring.coreos.com<br/>servicemonitors, podmonitors,<br/>prometheusrules, prometheuses"]
        CoreRes["core ('')<br/>namespaces, pods, services,<br/>secrets, configmaps, sa, events,<br/>pv, pvc, nodes"]
        AppsRes["apps<br/>deployments, statefulsets,<br/>daemonsets, replicasets"]
    end

    %% SA → CRB → CR bindings
    SA_Operator -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_AuthProxy -->|bound via| CRB_AuthDelegate
    CRB_AuthDelegate -->|grants| CR_AuthDelegate

    AdminGroups -->|bound via| CRB_AdminGroup
    CRB_AdminGroup -->|grants| CR_AdminGroup

    AllowedGroups -->|bound via| CRB_AllowedGroup
    CRB_AllowedGroup -->|grants| CR_AllowedGroup

    AdminGroups -->|bound via| CRB_KueueAdmin
    CRB_KueueAdmin -->|grants| CR_KueueAdmin

    %% CR → Resources (operator)
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"| DSC
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"| DSCI
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| CompCRDs
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| SvcCRDs
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| HWProfile
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| GatewayRes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| IstioRes
    CR_Manager -->|"get,list,watch,create,<br/>delete,update,patch"| RouteRes
    CR_Manager -->|"create,delete,list,<br/>watch,update,patch,get"| OAuthRes
    CR_Manager -->|"* (all verbs)"| RBACRes
    CR_Manager -->|"get,list,watch,create,<br/>patch,delete,update"| CRDRes
    CR_Manager -->|"get,list,watch,create,<br/>update,delete,patch"| WebhookRes
    CR_Manager -->|"get,create,delete,update,<br/>watch,list,patch,<br/>deletecollection"| MonitorRes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| CoreRes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| AppsRes

    %% CR → Resources (admin group)
    CR_AdminGroup -->|"get,list,watch,update,<br/>patch,delete,create"| DSC
    CR_AdminGroup -->|"get,list,watch,update,<br/>patch,delete,create"| HWProfile

    %% CR → Resources (allowed group)
    CR_AllowedGroup -->|"get,list,watch"| SvcCRDs

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_AuthProxy fill:#4a90e2,stroke:#333,color:#fff

    style CRB_Manager fill:#dae8fc,stroke:#6c8ebf
    style CRB_AuthDelegate fill:#dae8fc,stroke:#6c8ebf
    style CRB_AdminGroup fill:#dae8fc,stroke:#6c8ebf
    style CRB_AllowedGroup fill:#dae8fc,stroke:#6c8ebf
    style CRB_KueueAdmin fill:#dae8fc,stroke:#6c8ebf

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDelegate fill:#f5a623,stroke:#333,color:#fff
    style CR_AdminGroup fill:#f5a623,stroke:#333,color:#fff
    style CR_AllowedGroup fill:#f5a623,stroke:#333,color:#fff
    style CR_KueueAdmin fill:#f5a623,stroke:#333,color:#fff

    style AdminGroups fill:#e1d5e7,stroke:#9673a6
    style AllowedGroups fill:#e1d5e7,stroke:#9673a6

    style DSC fill:#7ed321,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333,color:#fff
    style CompCRDs fill:#7ed321,stroke:#333,color:#fff
    style SvcCRDs fill:#7ed321,stroke:#333,color:#fff
    style HWProfile fill:#7ed321,stroke:#333,color:#fff
    style FeatureTracker fill:#7ed321,stroke:#333,color:#fff

    style GatewayRes fill:#d5e8d4,stroke:#82b366
    style IstioRes fill:#d5e8d4,stroke:#82b366
    style RouteRes fill:#d5e8d4,stroke:#82b366
    style OAuthRes fill:#d5e8d4,stroke:#82b366
    style RBACRes fill:#d5e8d4,stroke:#82b366
    style CRDRes fill:#d5e8d4,stroke:#82b366
    style WebhookRes fill:#d5e8d4,stroke:#82b366
    style MonitorRes fill:#d5e8d4,stroke:#82b366
    style CoreRes fill:#d5e8d4,stroke:#82b366
    style AppsRes fill:#d5e8d4,stroke:#82b366
