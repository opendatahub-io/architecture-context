graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / X.509"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB

        subgraph OperatorPod["kubeflow-training-operator"]
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-managed certs)<br/>Certificate Auth"]
            MetricsPort["Metrics Endpoint<br/>8080/TCP HTTP<br/>No encryption<br/>No auth"]
            HealthPort["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end

        WebhookSecret["Secret: webhook-cert<br/>kubernetes.io/tls<br/>cert-controller auto-rotate"]
    end

    subgraph UserNS["USER NAMESPACES (per-job)"]
        direction TB

        subgraph TrainingPods["Training Job Pods"]
            MasterPod["Master/Chief Pod"]
            WorkerPods["Worker Pods<br/>(1..N replicas)"]
        end

        HeadlessSvc["Headless Service<br/>ClusterIP: None<br/>Inter-pod DNS"]

        subgraph MPIResources["MPI-Specific Resources"]
            LauncherPod["Launcher Pod<br/>SA: {job}-launcher<br/>Init: kubectl-delivery"]
            MPIWorkers["MPI Worker Pods"]
            MPIConfigMap["ConfigMap<br/>hostfile + kubexec.sh"]
        end

        subgraph PyTorchResources["PyTorch-Specific Resources"]
            NetPolicy["NetworkPolicy<br/>Pod isolation +<br/>monitoring whitelist"]
            HPAResource["HPA<br/>Elastic scaling"]
        end
    end

    subgraph OptionalSchedulers["OPTIONAL GANG SCHEDULERS"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        SchedulerPlugins["scheduler-plugins<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>OpenShift Monitoring<br/>PodMonitor discovery"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control Plane → Operator (Webhooks)
    K8sAPI -->|"HTTPS/9443<br/>TLS self-managed<br/>Certificate Auth<br/>5 validating webhooks"| WebhookServer

    %% Operator → Control Plane
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD Watch + CRUD"| K8sAPI

    %% Operator → User NS (creates resources)
    OperatorPod -.->|"Creates via API"| TrainingPods
    OperatorPod -.->|"Creates via API"| HeadlessSvc
    OperatorPod -.->|"Creates via API"| MPIResources
    OperatorPod -.->|"Creates via API"| PyTorchResources

    %% Inter-pod communication
    WorkerPods <-->|"TCP/framework-specific<br/>No encryption<br/>No auth<br/>Via headless DNS"| MasterPod
    WorkerPods <-->|"TCP/framework-specific<br/>No encryption"| HeadlessSvc

    %% MPI launcher → workers
    LauncherPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Launcher SA Token<br/>pods/exec"| K8sAPI
    K8sAPI -->|"pods/exec"| MPIWorkers

    %% Optional schedulers
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRD"| Volcano
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRD"| SchedulerPlugins

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth<br/>Scrape /metrics"| MetricsPort

    %% Cert management
    WebhookSecret -.->|"mounted at<br/>/tmp/k8s-webhook-server/<br/>serving-certs"| WebhookServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e8e8e8,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef secret fill:#e1d5e7,stroke:#9673a6

    class User external
    class K8sAPI controlplane
    class WebhookServer,MetricsPort,HealthPort operator
    class MasterPod,WorkerPods,HeadlessSvc,LauncherPod,MPIWorkers,MPIConfigMap,NetPolicy,HPAResource userns
    class Volcano,SchedulerPlugins optional
    class Prometheus monitoring
    class WebhookSecret secret
