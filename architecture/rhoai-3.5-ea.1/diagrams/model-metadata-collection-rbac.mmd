graph TD
    subgraph "model-metadata-collection RBAC"
        direction TB

        subgraph "Runtime (Data Container)"
            NoRBAC["No RBAC Required<br/><br/>The data container runs as a<br/>passive init container / sidecar.<br/>It does not interact with the<br/>Kubernetes API server.<br/><br/>USER: 1001 (non-root)<br/>CMD: sleep infinity"]
        end

        subgraph "Build-Time Credentials"
            direction TB

            subgraph "HuggingFace Auth"
                HFToken["HF_TOKEN<br/>(Environment Variable)"]
                HFPurpose["Purpose: API authentication<br/>for private/gated models"]
                HFProvisioning["Provisioned By: Manual (developer)<br/>Auto-Rotate: No<br/>Required: Optional"]
                HFToken --- HFPurpose
                HFPurpose --- HFProvisioning
            end

            subgraph "Container Registry Auth"
                RegistryCreds["Docker / Registry Credentials<br/>(Docker config / Tekton secret)"]
                RegistryPurpose["Purpose: OCI registry access<br/>registry.redhat.io, quay.io"]
                RegistryProvisioning["Provisioned By: Docker config / Tekton<br/>Auto-Rotate: No<br/>Required: Yes (for Red Hat registries)"]
                RegistryCreds --- RegistryPurpose
                RegistryPurpose --- RegistryProvisioning
            end
        end

        subgraph "Authentication Endpoints"
            direction TB

            HFEndpoint["HuggingFace API<br/>Method: GET<br/>Auth: Bearer Token (HF_TOKEN)<br/>Enforcement: HuggingFace server<br/>Policy: Optional - enables private models"]

            OCIEndpoint["OCI Registries<br/>Method: Registry v2 API<br/>Auth: Docker auth / SA<br/>Enforcement: Container registry<br/>Policy: Required for RH registry, public for some"]
        end
    end

    %% Styling
    style NoRBAC fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style HFToken fill:#fff2cc,stroke:#d6b656
    style RegistryCreds fill:#fff2cc,stroke:#d6b656
    style HFEndpoint fill:#dae8fc,stroke:#6c8ebf
    style OCIEndpoint fill:#dae8fc,stroke:#6c8ebf
