graph TB
    subgraph MLflowServer["MLflow Tracking Server"]
        direction TB
        subgraph WebFramework["Web Framework Layer"]
            FastAPI["FastAPI App<br/>(async routes)"]
            Flask["Flask App<br/>(protobuf REST handlers)"]
            Uvicorn["Uvicorn ASGI Server<br/>Port 5000/TCP"]
            FastAPI -->|wraps via WSGIMiddleware| Flask
            Uvicorn -->|serves| FastAPI
        end

        subgraph Middleware["Security Middleware"]
            CORSBlock["CORSBlockingMiddleware"]
            HostValid["HostValidationMiddleware"]
            SecurityHeaders["Security Headers"]
        end

        subgraph AuthLayer["Authentication Layer"]
            K8sAuth["Kubernetes Auth Provider<br/>(kubernetes-auth app)"]
            SAToken["SA Token Reader<br/>/var/run/secrets/...token"]
            PermCheck["Permission Checker<br/>(READ/EDIT/MANAGE)"]
            K8sAuth -->|reads| SAToken
            K8sAuth -->|enforces| PermCheck
        end

        subgraph APIRoutes["API Routes"]
            V2API["/api/2.0/mlflow/*<br/>Experiments, Runs, Metrics<br/>Models, Artifacts, Traces"]
            V3API["/ajax-api/3.0/mlflow/*<br/>Frontend-facing v3.0"]
            OTLPAPI["/v1/traces<br/>OTLP/HTTP Protobuf"]
            GatewayAPI["Gateway API<br/>Secrets encryption"]
            JobAPI["Job API<br/>Async job management"]
        end

        subgraph Storage["Storage Layer"]
            SQLStore["SQLAlchemy Store<br/>(workspace-aware)"]
            ArtifactRepo["Artifact Repository<br/>(plugin-based)"]
            TraceStore["Trace Store<br/>(SQL-backed)"]
            HueyQueue["Huey Task Queue<br/>(SQLite in /dev/shm)"]
        end

        subgraph Crypto["Crypto Layer"]
            EnvelopeEnc["Envelope Encryption<br/>AES-256-GCM<br/>PBKDF2-HMAC-SHA256"]
        end
    end

    subgraph WebUI["MLflow Web UI"]
        ReactApp["React/TypeScript SPA<br/>Experiments, Runs, Models, Traces"]
        FedModule["Federated Module Build<br/>(RHOAI Dashboard integration)"]
    end

    subgraph Clients["Client Libraries"]
        Skinny["MLflow Skinny<br/>(lightweight client)"]
        TracingSDK["MLflow Tracing<br/>(OpenTelemetry-based)"]
        FS2DB["fs2db Migration Tool"]
    end

    subgraph WorkspacePlugin["External Plugin"]
        K8sWorkspace["mlflow-kubernetes-plugins<br/>kubernetes:// URI scheme<br/>Namespace → Workspace mapping"]
    end

    %% Client connections
    User["Data Scientist / ML Engineer"] -->|Browser| ReactApp
    User -->|Python SDK| Skinny
    User -->|OTLP spans| TracingSDK

    ReactApp -->|HTTP requests| V3API
    Skinny -->|REST API| V2API
    TracingSDK -->|OTLP/HTTP| OTLPAPI

    %% Internal flows
    Middleware -.->|filters| APIRoutes
    AuthLayer -.->|authorizes| APIRoutes

    V2API --> SQLStore
    V2API --> ArtifactRepo
    V3API --> SQLStore
    OTLPAPI --> TraceStore
    JobAPI --> HueyQueue
    GatewayAPI --> EnvelopeEnc

    K8sWorkspace -.->|workspace context| SQLStore

    %% External dependencies
    SQLStore -->|5432/TCP| PostgreSQL["PostgreSQL<br/>Tracking + Registry DB"]
    ArtifactRepo -->|443/TCP| S3["S3/GCS/Azure<br/>Artifact Storage"]
    K8sAuth -->|443/TCP| K8sAPI["Kubernetes API Server"]
    K8sWorkspace -->|443/TCP| K8sAPI

    %% Sidecar
    KubeRBACProxy["kube-rbac-proxy<br/>Sidecar (8443/TCP)"] -->|localhost:5000| Uvicorn

