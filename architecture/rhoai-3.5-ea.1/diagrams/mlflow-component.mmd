    style MLflowServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style WebUI fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Clients fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style WorkspacePlugin fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style FastAPI fill:#4a90e2,color:#fff
    style Flask fill:#4a90e2,color:#fff
    style Uvicorn fill:#4a90e2,color:#fff
    style K8sAuth fill:#f5a623,color:#fff
    style PostgreSQL fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style KubeRBACProxy fill:#ff9800,color:#fff
    style User fill:#e1f5fe,stroke:#0288d1,stroke-width:2px
