graph TB
    subgraph KubeRayOperator["KubeRay Operator (ray-operator)"]
        direction TB

        subgraph Controllers["Controllers"]
            RCCtrl["RayCluster Controller<br/>Pod/Service lifecycle"]
            RJCtrl["RayJob Controller<br/>Job submission & tracking"]
            RSCtrl["RayService Controller<br/>Serve app management"]
            AuthCtrl["Authentication Controller<br/>HTTPRoute + kube-rbac-proxy"]
            mTLSCtrl["mTLS Controller<br/>cert-manager certs"]
            NPCtrl["NetworkPolicy Controller<br/>Pod network isolation"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutWH["Mutating Webhook<br/>mraycluster.kb.io<br/>Enforce secure defaults"]
            ValWH["Validating Webhook<br/>vraycluster.kb.io<br/>Name + worker validation"]
        end

        subgraph Metrics["Observability"]
            MetricsEP["Metrics Endpoint<br/>8080/TCP"]
            HealthEP["Health/Ready<br/>8082/TCP"]
        end
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    RayJobCR["RayJob CR<br/>ray.io/v1"]
    RayServiceCR["RayService CR<br/>ray.io/v1"]

    %% User interaction
    User["User / Data Scientist"] -->|kubectl create| RayClusterCR
    User -->|kubectl create| RayJobCR
    User -->|kubectl create| RayServiceCR

    %% Webhook intercepts
    RayClusterCR -->|intercept on create/update| MutWH
    MutWH -->|defaulted| ValWH
    ValWH -->|validated| RCCtrl

    %% Controller watches
    RayClusterCR -->|watched by| RCCtrl
    RayJobCR -->|watched by| RJCtrl
    RayServiceCR -->|watched by| RSCtrl

    %% Controller creates resources
    RCCtrl -->|creates| HeadPod["Head Pod<br/>+ kube-rbac-proxy sidecar"]
    RCCtrl -->|creates| WorkerPods["Worker Pods"]
    RCCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>6379, 8265, 10001, 8443"]
    RCCtrl -->|creates| ServeSvc["{cluster}-serve-svc<br/>8000"]
    RCCtrl -->|creates| HeadlessSvc["{cluster}-headless"]

    AuthCtrl -->|creates| HTTPRoute["HTTPRoute<br/>/ray/{ns}/{cluster}"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant<br/>kuberay-gateway-access"]
    AuthCtrl -->|creates| AuthCM["Auth ConfigMap<br/>kube-rbac-proxy config"]

    mTLSCtrl -->|creates| Issuer["cert-manager Issuer<br/>Self-signed CA"]
    mTLSCtrl -->|creates| HeadCert["Head TLS Certificate"]
    mTLSCtrl -->|creates| WorkerCert["Worker TLS Certificate"]

    NPCtrl -->|creates| NetPol["NetworkPolicy<br/>Pod isolation rules"]

    RJCtrl -->|creates via| RayClusterCR
    RJCtrl -->|submits job to| RayDashboard["Ray Dashboard<br/>8265/TCP"]
    RSCtrl -->|manages via| RayClusterCR
    RSCtrl -->|deploys apps to| RayDashboard

    %% External dependencies
    HTTPRoute -->|references| Gateway["Platform Gateway<br/>data-science-gateway"]
    Issuer -->|managed by| CertManager["cert-manager"]

    %% Condition coordination
    AuthCtrl -.->|sets AuthenticationReady| RCCtrl

    %% Styling
    style KubeRayOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controllers fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style Webhooks fill:#fff3e0,stroke:#e65100,stroke-width:1px
    style Metrics fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#4a90e2,stroke:#333
    style WorkerPods fill:#4a90e2,stroke:#333
    style Gateway fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
