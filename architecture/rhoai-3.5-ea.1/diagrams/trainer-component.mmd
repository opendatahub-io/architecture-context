graph TB
    subgraph TrainerOperator["Kubeflow Trainer Controller Manager"]
        direction TB
        Controller["TrainJob Controller<br/>(Reconciler)"]
        RTController["TrainingRuntime Controller"]
        CRTController["ClusterTrainingRuntime Controller"]
        WebhookServer["Webhook Server<br/>9443/TCP TLS"]
        CertRotation["Cert Controller<br/>(self-managed rotation)"]
        MetricsServer["Metrics Server<br/>8443/TCP HTTPS"]

        subgraph PluginFramework["Plugin Framework"]
            direction LR
            JobSetPlugin["JobSet Plugin<br/>(ComponentBuilder)"]
            TorchPlugin["Torch Plugin<br/>(MLPolicy)"]
            MPIPlugin["MPI Plugin<br/>(MLPolicy)"]
            TorchTunePlugin["TorchTune Plugin<br/>(MLPolicy)"]
            CoschedulingPlugin["Coscheduling Plugin<br/>(PodGroupPolicy)"]
            VolcanoPlugin["Volcano Plugin<br/>(PodGroupPolicy)"]
        end

        subgraph RHAIExtensions["RHAI Extensions (RHOAI)"]
            direction LR
            ProgressionTracking["Progression Tracking<br/>(polls /metrics on pods)"]
            NetworkPolicyMgr["NetworkPolicy Manager<br/>(pod isolation)"]
        end

        Controller --> PluginFramework
        Controller --> RHAIExtensions
        CertRotation -->|rotates certs| WebhookServer
    end

    %% User interaction
    User["User / Dashboard"] -->|creates| TrainJobCR["TrainJob CR"]
    User -->|creates| TrainingRuntimeCR["TrainingRuntime CR"]
    Admin["Platform Admin"] -->|creates| ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR"]

    %% CRD watches
    TrainJobCR -->|watched by| Controller
    TrainingRuntimeCR -->|watched by| RTController
    ClusterTrainingRuntimeCR -->|watched by| CRTController

    %% Webhook validation
    TrainJobCR -->|validated by| WebhookServer
    TrainingRuntimeCR -->|validated by| WebhookServer
    ClusterTrainingRuntimeCR -->|validated by| WebhookServer

    %% Created resources
    JobSetPlugin -->|creates| JobSetCR["JobSet CR<br/>(jobset.x-k8s.io)"]
    CoschedulingPlugin -->|creates| PodGroupCR["PodGroup CR<br/>(scheduling.x-k8s.io)"]
    VolcanoPlugin -->|creates| VolcanoPG["Volcano PodGroup CR<br/>(scheduling.volcano.sh)"]
    MPIPlugin -->|creates| SSHSecret["SSH Secret<br/>(MPI auth)"]
    MPIPlugin -->|creates| Hostfile["Hostfile ConfigMap"]
    NetworkPolicyMgr -->|creates| NetPol["NetworkPolicy<br/>(pod isolation)"]

    %% External dependencies
    JobSetCR -->|managed by| JobSetOp["JobSet Operator"]
    JobSetOp -->|creates| TrainingPods["Training Pods"]
    ProgressionTracking -->|polls /metrics<br/>28080/TCP HTTP| TrainingPods

    %% Prometheus
    Prometheus["Prometheus / OpenShift Monitoring"] -->|scrapes<br/>8443/TCP HTTPS| MetricsServer

