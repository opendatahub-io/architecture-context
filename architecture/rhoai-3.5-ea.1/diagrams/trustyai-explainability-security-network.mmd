graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client / Dashboard"]
    end

    subgraph Ingress["INGRESS (Managed by Operator)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → 4443/TCP or 8080/TCP<br/>TLS SIMPLE"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            TrustyAI["TrustyAI Service<br/>Port 8080/TCP HTTP (primary)<br/>Port 4443/TCP HTTPS (TLS cert files)<br/>No app-level auth<br/>UBI 9 / OpenJDK 17"]
        end

        subgraph NS_ModelServing["Model Serving Namespace"]
            ModelMesh["ModelMesh<br/>Payload Logger"]
        end

        subgraph NS_KServe["KServe Namespace"]
            KServeLogger["KServe<br/>Inference Logger"]
        end

        subgraph NS_Monitoring["Monitoring Namespace"]
            Prometheus["Prometheus Server"]
        end

        subgraph NS_Storage["Storage (in-cluster)"]
            PVC["PVC /inputs<br/>Local filesystem<br/>No encryption"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP JDBC<br/>Encryption: Configurable<br/>Auth: Username/Password"]
        MinIO["MinIO / S3<br/>HTTP/HTTPS<br/>Encryption: Configurable<br/>Auth: Access Key/Secret"]
        ModelServer["KServe Model Servers<br/>gRPC: Plaintext &#9888;<br/>HTTP: Configurable<br/>Auth: None"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Infrastructure auth"| Route
    Route -->|"HTTPS/4443 or HTTP/8080<br/>TLS cert files or plaintext"| TrustyAI

    %% Inbound cluster flows
    ModelMesh -->|"HTTP/8080<br/>No TLS, No Auth<br/>POST /consumer/kserve/v2"| TrustyAI
    KServeLogger -->|"HTTP/8080<br/>CloudEvents<br/>No TLS, No Auth"| TrustyAI
    Prometheus -->|"HTTP/8080<br/>No TLS, No Auth<br/>GET /q/metrics"| TrustyAI

    %% Storage flows
    TrustyAI -->|"File I/O<br/>No encryption"| PVC

    %% External service flows
    TrustyAI -->|"JDBC/3306<br/>Configurable encryption<br/>Username/Password"| MariaDB
    TrustyAI -->|"HTTP or HTTPS<br/>Configurable encryption<br/>Access Key/Secret"| MinIO
    TrustyAI -->|"gRPC (PLAINTEXT &#9888;)<br/>No TLS, No Auth<br/>Explainers only (disabled in RHOAI)"| ModelServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#fff7e6,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI service
    class ModelMesh,KServeLogger clusterinternal
    class Prometheus monitoring
    class PVC storage
    class MariaDB,MinIO externalservice
    class ModelServer warning
