graph LR
    VLLM["vLLM CPU<br/>LLM Inference Server"]

    %% Internal RHOAI Dependencies
    VLLM -->|"container image<br/>ServingRuntime CR"| KServe["KServe<br/>Model Serving Platform"]

    %% Core Runtime Dependencies
    VLLM -->|"model execution"| PyTorch["PyTorch CPU<br/>2.10.0+cpu"]
    VLLM -->|"HTTP API framework"| FastAPI["FastAPI<br/>>= 0.120.1"]
    VLLM -->|"ASGI server"| Uvicorn["Uvicorn"]
    VLLM -->|"event loop"| uvloop["uvloop"]

    %% ML Dependencies
    VLLM -->|"model loading<br/>tokenization"| Transformers["Transformers<br/>>= 4.56.0"]
    VLLM -->|"fast tokenization"| Tokenizers["Tokenizers<br/>>= 0.21.1"]
    VLLM -->|"tokenizer"| tiktoken["tiktoken<br/>>= 0.12.0"]

    %% Infrastructure Dependencies
    VLLM -->|"gRPC server"| gRPC["gRPC<br/>>= 1.76.0"]
    VLLM -->|"metrics"| PromClient["Prometheus Client<br/>>= 0.18.0"]
    VLLM -->|"tracing (optional)"| OTel["OpenTelemetry SDK<br/>>= 1.27.0"]

    %% Platform-Specific Dependencies
    VLLM -.->|"x86_64 optimization<br/>(optional)"| IPEX["Intel Extension<br/>for PyTorch 2.7.0"]
    VLLM -->|"linear algebra<br/>(ppc64le/s390x)"| OpenBLAS["OpenBLAS<br/>built from source"]
    VLLM -->|"NUMA memory<br/>(ppc64le/s390x)"| numactl["numactl<br/>built from source"]
    VLLM -->|"C/C++ toolchain"| GCC["gcc-toolset-14<br/>UBI9"]

    %% External Services
    VLLM -->|"model download<br/>HTTPS 443"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    VLLM -.->|"usage telemetry<br/>HTTPS 443"| RHStats["RHOAI Usage Stats<br/>console.redhat.com"]

    %% Integration Points (things that depend on vLLM)
    KServe -->|"routes traffic<br/>TLS termination"| VLLM
    PromMonitor["Prometheus<br/>OpenShift Monitoring"] -->|"scrapes /metrics<br/>HTTP 8000"| VLLM
    OTelCollector["OpenTelemetry<br/>Collector"] -.->|"receives traces<br/>OTLP"| VLLM
    ModelStorage["Model Storage<br/>PVC / S3"] -->|"pre-downloaded<br/>model weights"| VLLM

    %% Styling
    style VLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff

    %% Core Runtime
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style Uvicorn fill:#009688,stroke:#333,color:#fff
    style uvloop fill:#009688,stroke:#333,color:#fff

    %% ML
    style Transformers fill:#ff9d00,stroke:#333,color:#fff
    style Tokenizers fill:#ff9d00,stroke:#333,color:#fff
    style tiktoken fill:#ff9d00,stroke:#333,color:#fff

    %% Infrastructure
    style gRPC fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff

    %% Platform-Specific
    style IPEX fill:#0071c5,stroke:#333,color:#fff
    style OpenBLAS fill:#666,stroke:#333,color:#fff
    style numactl fill:#666,stroke:#333,color:#fff
    style GCC fill:#666,stroke:#333,color:#fff

    %% External Services
    style HFHub fill:#f5a623,stroke:#333
    style RHStats fill:#cc0000,stroke:#333,color:#fff

    %% Integration Points
    style PromMonitor fill:#e6522c,stroke:#333,color:#fff
    style OTelCollector fill:#4a90e2,stroke:#333,color:#fff
