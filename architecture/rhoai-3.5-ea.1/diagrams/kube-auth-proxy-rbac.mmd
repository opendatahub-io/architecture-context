graph TD
    subgraph Deployment["Deployment (Managed by rhods-operator)"]
        SA["ServiceAccount<br/>(operator-created per component)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings (operator-managed)"]
        CRB["ClusterRoleBinding<br/>(operator-managed)"]
    end

    subgraph ClusterRoles["ClusterRoles (operator-managed)"]
        CR["ClusterRole<br/>(operator-managed)"]
    end

    subgraph APIResources["API Resources Accessed"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        Users["user.openshift.io<br/>users"]
        OAuthTokens["oauth.openshift.io<br/>oauthaccesstokens"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR
    CR -->|"get"| Users
    CR -->|"get, delete"| OAuthTokens

    subgraph HardcodedAccess["Hardcoded Authorization (kube-rbac-proxy)"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["GET /metrics"]
    end

    PromSA -->|"unconditionally allowed<br/>(hardcoded in code)"| MetricsEndpoint

    subgraph AuthModes["Authentication Methods Supported"]
        direction TB
        K8sToken["K8s SA Token<br/>(TokenReview API)"]
        OAuthToken["OpenShift OAuth Token<br/>(sha256~ format)"]
        JWTToken["JWT Bearer Token<br/>(OIDC verification)"]
        BasicAuth["Basic Auth<br/>(htpasswd, bcrypt)"]
        SessionCookie["Session Cookie<br/>(AES-encrypted)"]
        ClientCert["Client Certificate<br/>(kube-rbac-proxy)"]
    end

    subgraph AuthzModes["Authorization Methods (RBAC Mode)"]
        direction TB
        HardcodedAuthz["1. Hardcoded Authorizer<br/>(Prometheus SA allowlist)"]
        StaticAuthz["2. Static Authorizer<br/>(config file pattern match)"]
        SARAuthz["3. SubjectAccessReview<br/>(K8s API delegation)"]
    end

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#f5a623,color:#fff
    style CR fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style Users fill:#7ed321,color:#fff
    style OAuthTokens fill:#7ed321,color:#fff
    style PromSA fill:#e74c3c,color:#fff
    style MetricsEndpoint fill:#e74c3c,color:#fff
    style HardcodedAccess fill:#fff0f0,stroke:#e74c3c,stroke-width:2px
    style AuthModes fill:#f5f5f5,stroke:#ccc
    style AuthzModes fill:#f5f5f5,stroke:#ccc
