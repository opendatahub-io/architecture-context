graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["End User Browser"]
        Admin["Platform Admin<br/>(kubectl/oc)"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["data-science-gateway<br/>Gateway API (Envoy)<br/>443/TCP → backends<br/>TLS 1.2+ TERMINATE<br/>EnvoyFilter ext_authz"]
        LegacyRoute["Legacy Dashboard Route<br/>443/TCP → 8080/TCP<br/>TLS Edge<br/>No auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB
        OperatorPod["rhods-operator Pod<br/>SA: rhods-operator<br/>Image: odh-rhel8-operator"]
        WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS (cert-manager)<br/>mTLS (kube-apiserver only)"]
    end

    subgraph AppsNS["APPLICATIONS NAMESPACE (redhat-ods-applications)"]
        direction TB
        AuthProxy["kube-auth-proxy<br/>SA: kube-auth-proxy<br/>8443/TCP HTTPS (service-ca TLS)<br/>Token review delegation"]
        AuthProxyMetrics["kube-auth-proxy metrics<br/>9000/TCP HTTP<br/>No auth"]
        DashRedirect["dashboard-redirect nginx<br/>8080/TCP HTTP<br/>No auth"]
        PromProxy["Prometheus Proxies<br/>9090/TCP HTTPS<br/>TLS (service-ca)<br/>SA RBAC"]
    end

    subgraph ComponentNS["COMPONENT NAMESPACES"]
        Components["Deployed Components<br/>(Dashboard, KServe, DSP,<br/>ModelRegistry, KubeRay, etc.)<br/>Managed via Kustomize + SSA"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuthClient credentials"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials"]
        SegmentIO["Segment.IO Telemetry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Write key"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (initial)"| Gateway
    User -->|"HTTPS/443<br/>TLS Edge"| LegacyRoute
    Admin -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig"| K8sAPI

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>ext_authz check"| AuthProxy
    LegacyRoute -->|"HTTP/8080<br/>No encryption<br/>301 redirect"| DashRedirect

    %% Auth → OAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2/OIDC flow"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC flow"| OIDC

    %% Gateway → Components
    Gateway -->|"HTTP(S)/varies<br/>Bearer token forwarded<br/>via HTTPRoute"| Components

    %% Operator → K8s API
    OperatorPod -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator → External
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Write key"| SegmentIO

    %% K8s API → Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-manager)<br/>mTLS client cert"| WebhookSvc

    %% Monitoring
    PromProxy -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA RBAC"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef apps fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef components fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,Admin external
    class Gateway,LegacyRoute ingress
    class OperatorPod,WebhookSvc operator
    class AuthProxy,AuthProxyMetrics,DashRedirect,PromProxy apps
    class Components components
    class K8sAPI,OAuthServer controlplane
    class OIDC,SegmentIO externalservice
