graph LR
    Trainer["Kubeflow Trainer<br/>Controller Manager"]

    %% External Dependencies (Required)
    Trainer -->|"CRD Create + Watch<br/>JobSet v1alpha2"| JobSet["JobSet Operator<br/>0.10.1"]
    Trainer -->|"controller framework"| ControllerRuntime["controller-runtime<br/>0.22.3"]
    Trainer -->|"cert rotation"| CertController["cert-controller<br/>(OPA) 0.14.0"]
    Trainer -->|"target platform"| K8s["Kubernetes<br/>1.34+"]

    %% Internal Platform Dependencies
    Trainer -->|"CRD Create<br/>PodGroup"| CoScheduling["scheduler-plugins<br/>(coscheduling)"]
    Trainer -->|"CRD Create<br/>Volcano PodGroup"| Volcano["Volcano<br/>Scheduler"]
    Trainer -->|"managedBy field<br/>delegation"| Kueue["Kueue<br/>(MultiKueue)"]
    Trainer -.->|"deployed by<br/>kustomize manifests"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]

    %% Integration Points (inbound)
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"PodMonitor scrape<br/>8443/TCP HTTPS"| Trainer
    K8sAPI["Kubernetes API Server"] -->|"webhook calls<br/>9443/TCP HTTPS"| Trainer

    %% Integration Points (outbound)
    Trainer -->|"polls /metrics<br/>28080/TCP HTTP"| TrainingPods["Training Pods"]
    Trainer -->|"ImageStream creation"| ImageStreams["OpenShift<br/>ImageStreams"]

    %% Runtime dependencies
    JobSet -->|"creates"| TrainingPods

