graph TB
    subgraph "RHAII Cluster Validation"
        direction TB
        CLI["rhaii-validator CLI<br/>kubectl rhaii-validate"]

        subgraph "Tier 1 — API-Level Checks"
            CRDCheck["CRD Checker<br/>Validates CRD existence"]
            OperatorCheck["Operator Health Checker<br/>Verifies running pods"]
        end

        subgraph "Tier 2 — Hardware-Level Checks"
            direction TB
            Controller["Controller<br/>Job lifecycle, RBAC,<br/>platform detection,<br/>report aggregation"]
            Runner["Runner<br/>Per-node GPU/RDMA checks"]
            JobRunner["JobRunner<br/>Multi-node server/client<br/>Job orchestrator"]
        end

        subgraph "Platform Config"
            PlatformYAML["Embedded YAML Configs<br/>OCP | AKS | EKS | CoreWeave"]
        end

        CLI -->|"in-process"| CRDCheck
        CLI -->|"in-process"| OperatorCheck
        CLI -->|"orchestrates"| Controller
        Controller -->|"deploys per-node Jobs"| Runner
        Controller -->|"deploys server/client Jobs"| JobRunner
        Controller -->|"loads defaults"| PlatformYAML
    end

    subgraph "Container Images"
        ValidatorImage["odh-rhaii-cluster-validator<br/>Go binary + CLI + agent mode"]
        ToolsImage["odh-rhaii-validator-tools<br/>iperf3 + perftest + CUDA"]
    end

    Runner -->|"runs inside"| ValidatorImage
    JobRunner -->|"uses for bandwidth tests"| ToolsImage

    subgraph "Kubernetes Resources"
        Jobs["Ephemeral Jobs<br/>(GPU check, bandwidth, pingmesh)"]
        ConfigMap["ConfigMap<br/>rhaii-validate-report"]
        RBAC["ClusterRole / ClusterRoleBinding<br/>rhaii-validator"]
        SA["ServiceAccount<br/>rhaii-validator"]
    end

    Controller -->|"creates"| Jobs
    Controller -->|"stores report"| ConfigMap
    Controller -->|"manages"| RBAC
    Controller -->|"creates"| SA

    subgraph "Validated Components"
        GatewayAPICRD["Gateway API CRDs"]
        InferencePoolCRD["InferencePool CRD"]
        LWSCRD["LeaderWorkerSet CRD"]
        CertManagerCRD["cert-manager CRD"]
        CertManagerOp["cert-manager Operator"]
        IstioOp["Istio Service Mesh"]
        LWSOperator["LWS Operator"]
    end

    CRDCheck -->|"validates existence"| GatewayAPICRD
    CRDCheck -->|"validates existence"| InferencePoolCRD
    CRDCheck -->|"validates existence"| LWSCRD
    CRDCheck -->|"validates existence"| CertManagerCRD
    OperatorCheck -->|"checks health"| CertManagerOp
    OperatorCheck -->|"checks health"| IstioOp
    OperatorCheck -->|"checks health"| LWSOperator

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    GPUDriver["NVIDIA / AMD GPU Driver"]
    RDMAFabric["InfiniBand / RoCE Fabric"]

    Controller -->|"REST API"| K8sAPI
    Runner -->|"nvidia-smi / rocm-smi"| GPUDriver
    Runner -->|"ibv_devices / sysfs"| RDMAFabric

    style CLI fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Runner fill:#4a90e2,stroke:#333,color:#fff
    style JobRunner fill:#4a90e2,stroke:#333,color:#fff
    style CRDCheck fill:#4a90e2,stroke:#333,color:#fff
    style OperatorCheck fill:#4a90e2,stroke:#333,color:#fff
    style PlatformYAML fill:#b8d4f0,stroke:#333
    style ValidatorImage fill:#f5a623,stroke:#333
    style ToolsImage fill:#f5a623,stroke:#333
    style ConfigMap fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style GPUDriver fill:#e8e8e8,stroke:#333
    style RDMAFabric fill:#e8e8e8,stroke:#333
    style GatewayAPICRD fill:#d5e8d4,stroke:#82b366
    style InferencePoolCRD fill:#d5e8d4,stroke:#82b366
    style LWSCRD fill:#d5e8d4,stroke:#82b366
    style CertManagerCRD fill:#d5e8d4,stroke:#82b366
    style CertManagerOp fill:#d5e8d4,stroke:#82b366
    style IstioOp fill:#d5e8d4,stroke:#82b366
    style LWSOperator fill:#d5e8d4,stroke:#82b366
