graph TB
    subgraph Clients["INTERNAL CLIENTS (Cluster-Internal)"]
        KFP["Kubeflow Pipelines SDK"]
        DSP["Data Science Pipelines"]
        PipelineUI["Pipeline UI Components"]
        TFX["TFX Components"]
    end

    subgraph Service["SERVICE (Internal - ClusterIP)"]
        direction TB
        MLMD["MLMD gRPC Server<br/>(metadata_store_server)<br/>Image: odh-mlmd-grpc-server-rhel9<br/>Port: 8080/TCP gRPC/HTTP2<br/>Crypto: BoringSSL (non-FIPS)<br/>TLS: Optional via SSLConfig<br/>mTLS: Optional (client_verify)"]
    end

    subgraph DatabaseLayer["EXTERNAL SERVICES (Database Backend)"]
        MySQL["MySQL / MariaDB<br/>Port: 3306/TCP<br/>Auth: Username/password<br/>Encryption: Optional SSL"]
        PostgreSQL["PostgreSQL<br/>Port: 5432/TCP<br/>Auth: Username/password<br/>Encryption: Optional SSL<br/>(sslmode configurable)"]
        SQLite["SQLite (Embedded)<br/>In-memory / file-based<br/>Dev/testing only"]
    end

    subgraph Secrets["SECRETS"]
        DBCreds["DB Credentials<br/>(Opaque)<br/>MySQL/PG user+pass"]
        TLSCerts["SSL Certificates<br/>(kubernetes.io/tls)<br/>Optional mTLS"]
        DBSSLCerts["DB SSL Certs<br/>(Opaque)<br/>sslcert, sslkey, sslrootcert"]
    end

    %% Client to MLMD flows
    KFP -->|"gRPC/HTTP2 :8080<br/>Optional TLS (BoringSSL)<br/>Optional mTLS (client_verify)<br/>Default: INSECURE"| MLMD
    DSP -->|"gRPC/HTTP2 :8080<br/>Optional TLS<br/>Optional mTLS"| MLMD
    PipelineUI -->|"gRPC/HTTP2 :8080<br/>Optional TLS<br/>Optional mTLS"| MLMD
    TFX -->|"gRPC/HTTP2 :8080<br/>Optional TLS<br/>Optional mTLS"| MLMD

    %% MLMD to database flows
    MLMD -->|"MySQL protocol :3306<br/>Optional SSL<br/>Username/password"| MySQL
    MLMD -->|"PostgreSQL protocol :5432<br/>Optional SSL (sslmode)<br/>Username/password"| PostgreSQL
    MLMD -->|"Embedded<br/>No network"| SQLite

    %% Secret references
    DBCreds -.->|"provisioned by<br/>DSP/Platform operator"| MLMD
    TLSCerts -.->|"optional<br/>cert-manager/manual"| MLMD
    DBSSLCerts -.->|"optional<br/>platform operator"| MLMD

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class KFP,DSP,PipelineUI,TFX client
    class MLMD service
    class MySQL,PostgreSQL,SQLite database
    class DBCreds,TLSCerts,DBSSLCerts secret
