graph LR
    EvalHub["EvalHub<br/>REST API + Sidecar + Init"]

    %% External Dependencies (Required)
    EvalHub -->|"TokenReview, SAR<br/>Job/ConfigMap CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API 1.29+"]
    EvalHub -->|"embedded<br/>default storage"| SQLite["SQLite<br/>(embedded, modernc.org)"]

    %% External Dependencies (Optional)
    EvalHub -->|"persistent storage<br/>SQL/5432"| PostgreSQL["PostgreSQL 12+"]
    EvalHub -->|"experiment tracking<br/>HTTPS"| MLflow["MLflow 2.0+"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["S3-compatible Storage<br/>(AWS SDK v2)"]
    EvalHub -->|"model artifact push/pull<br/>HTTPS/443"| OCIRegistry["OCI Registry v2"]

    %% Internal RHOAI Dependencies
    TrustyAIOp["TrustyAI Service<br/>Operator"] -->|"manages via<br/>EvalHub CR"| EvalHub
    EvalHubSDK["eval-hub-sdk<br/>(Python)"] -->|"client library<br/>HTTP/HTTPS"| EvalHub

    %% Evaluation Frameworks (K8s Jobs)
    EvalHub -->|"K8s Job<br/>167+ benchmarks"| LmEval["lm-evaluation-harness"]
    EvalHub -->|"K8s Job<br/>RAG eval"| RAGAS["RAGAS"]
    EvalHub -->|"K8s Job<br/>vuln scanning"| Garak["Garak"]
    EvalHub -->|"K8s Job<br/>perf benchmarking"| GuideLLM["GuideLLM"]
    EvalHub -->|"K8s Job<br/>lightweight eval"| LightEval["LightEval"]
    EvalHub -->|"K8s Job<br/>embedding benchmark"| MTEB["MTEB (via ibm-clear)"]

    %% Integration Points (inbound)
    EvalHub -.->|"job queue label<br/>kueue.x-k8s.io/queue-name"| Kueue["Kueue"]

    %% Observability
    EvalHub -->|"OTLP traces<br/>gRPC/4317"| OTLP["OTLP Collector"]
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/8080"| EvalHub

    %% ConfigMap hot reload
    ConfigMaps["ConfigMaps<br/>(providers, collections)"] -.->|"fsnotify watch<br/>hot-reload"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required External
    style K8sAPI fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333

    %% Optional External
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MLflow fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style OCIRegistry fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style TrustyAIOp fill:#7ed321,stroke:#333
    style EvalHubSDK fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333

    %% Evaluation Frameworks
    style LmEval fill:#4ecdc4,stroke:#333,color:#fff
    style RAGAS fill:#4ecdc4,stroke:#333,color:#fff
    style Garak fill:#4ecdc4,stroke:#333,color:#fff
    style GuideLLM fill:#4ecdc4,stroke:#333,color:#fff
    style LightEval fill:#4ecdc4,stroke:#333,color:#fff
    style MTEB fill:#4ecdc4,stroke:#333,color:#fff

    %% Observability
    style OTLP fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
