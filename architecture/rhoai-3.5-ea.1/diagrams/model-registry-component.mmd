graph TB
    subgraph ModelRegistry["Model Registry System"]
        direction TB

        subgraph ProxyService["Proxy Server (Go)"]
            Proxy["model-registry proxy<br/>:8080/TCP HTTP<br/>REST API v1alpha3"]
            DynRouter["DynamicRouter<br/>503 until DB ready"]
            HealthEndpoints["Health Endpoints<br/>/readyz/health<br/>/readyz/isDirty"]
            Proxy --> DynRouter
            Proxy --> HealthEndpoints
        end

        subgraph CatalogService["Catalog Service (Go)"]
            Catalog["model-registry catalog<br/>:8080/TCP HTTP<br/>v1alpha1 API"]
            LeaderElection["Leader Election<br/>pglock (PostgreSQL)<br/>15s heartbeat / 60s lock"]
            MCPServer["MCP Server<br/>Model Catalog Protocol"]
            Catalog --> LeaderElection
            Catalog --> MCPServer
        end

        subgraph ControllerComponent["Controller (Go)"]
            Controller["model-registry controller<br/>:8081/TCP (health)"]
            ISReconciler["InferenceService<br/>Reconciler"]
            Controller --> ISReconciler
        end

        subgraph CSIComponent["CSI Storage Initializer (Go)"]
            CSI["model-registry CSI<br/>KServe Provider"]
            URIResolver["model-registry://<br/>URI Resolver"]
            CSI --> URIResolver
        end

        subgraph UIComponent["UI (TypeScript + Go BFF)"]
            UI["model-registry UI<br/>:8080/TCP HTTP"]
            BFF["Backend-for-Frontend<br/>Go BFF"]
            UI --> BFF
        end

        subgraph AsyncJob["Async Upload Job (Python)"]
            Job["async-upload job<br/>One-shot K8s Job"]
            Signing["Sigstore Signing<br/>Fulcio + Rekor"]
            Job --> Signing
        end
    end

    %% External Dependencies
    User["User / Client"] -->|"HTTPS/443<br/>oauth2-proxy"| IstioGW["Istio Ingress<br/>Gateway"]
    IstioGW -->|"HTTP/8080<br/>mTLS"| Proxy
    IstioGW -->|"HTTP/8080<br/>mTLS"| Catalog

    %% Database connections
    Proxy -->|"TCP/3306<br/>Username/Password"| MySQL["MySQL 8.3+"]
    Proxy -->|"TCP/5432<br/>Username/Password"| PostgreSQL["PostgreSQL 16+"]
    Catalog -->|"TCP/5432<br/>Leader Election + Data"| PostgreSQL

    %% Controller interactions
    ISReconciler -->|"watches"| InferenceServiceCR["InferenceService CR<br/>(KServe v1beta1)"]
    ISReconciler -->|"HTTP/8080<br/>Bearer Token"| Proxy

    %% CSI interactions
    URIResolver -->|"HTTP/8080<br/>Fetch artifact URI"| Proxy
    URIResolver -->|"delegates download to"| KServeStorage["KServe Storage<br/>Providers"]

    %% UI interactions
    BFF -->|"HTTP/8080<br/>mTLS"| Proxy

    %% Async Job interactions
    Job -->|"HTTP/8080<br/>Update metadata"| Proxy
    Job -->|"HTTPS/443"| S3["S3 Object Store"]
    Job -->|"HTTPS/443"| OCIReg["OCI Registry"]
    Job -->|"HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Catalog sources
    Catalog -->|"HTTPS/443<br/>API key"| HuggingFace

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#4a90e2,stroke:#333,color:#fff
    style Job fill:#4a90e2,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style IstioGW fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style OCIReg fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style KServeStorage fill:#999,stroke:#333,color:#fff
    style User fill:#e8e8e8,stroke:#333
