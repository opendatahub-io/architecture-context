graph TB
    subgraph SparkOperator["Spark Operator (v2.3.0)"]
        direction TB

        subgraph ControllerDeployment["Controller Deployment"]
            SparkAppCtrl["SparkApplication<br/>Controller"]
            SchedCtrl["ScheduledSparkApplication<br/>Controller"]
            ConnectCtrl["SparkConnect<br/>Controller"]
            MutWebhookCtrl["MutatingWebhookConfig<br/>Controller"]
            ValWebhookCtrl["ValidatingWebhookConfig<br/>Controller"]
            SparkSubmit["spark-submit<br/>(local exec)"]
        end

        subgraph WebhookDeployment["Webhook Deployment"]
            MutSA["Mutating Webhook<br/>(SparkApplication)"]
            ValSA["Validating Webhook<br/>(SparkApplication)"]
            MutSSA["Mutating Webhook<br/>(ScheduledSparkApplication)"]
            ValSSA["Validating Webhook<br/>(ScheduledSparkApplication)"]
            MutPod["Mutating Webhook<br/>(Pod)"]
            ResQuota["ResourceQuota<br/>Validator"]
        end
    end

    %% CRDs
    SparkAppCR["SparkApplication CR<br/>(v1beta2)"]
    SchedSparkAppCR["ScheduledSparkApplication CR<br/>(v1beta2)"]
    SparkConnectCR["SparkConnect CR<br/>(v1alpha1)"]

    %% User interactions
    User["User / CI Pipeline"]
    User -->|"kubectl apply"| SparkAppCR
    User -->|"kubectl apply"| SchedSparkAppCR
    User -->|"kubectl apply"| SparkConnectCR

    %% CRD to Controller flows
    SparkAppCR -->|"watched by"| SparkAppCtrl
    SchedSparkAppCR -->|"watched by"| SchedCtrl
    SparkConnectCR -->|"watched by"| ConnectCtrl

    %% Controller actions
    SparkAppCtrl -->|"invokes"| SparkSubmit
    SchedCtrl -->|"creates on cron"| SparkAppCR
    SparkSubmit -->|"creates"| DriverPod["Driver Pod"]
    SparkSubmit -->|"creates"| ExecutorPods["Executor Pods"]

    %% Webhook interception
    SparkAppCR -.->|"admission"| MutSA
    SparkAppCR -.->|"admission"| ValSA
    SchedSparkAppCR -.->|"admission"| MutSSA
    SchedSparkAppCR -.->|"admission"| ValSSA
    DriverPod -.->|"admission"| MutPod
    ExecutorPods -.->|"admission"| MutPod
    MutPod -->|"injects volumes, env,<br/>sidecars, scheduling"| DriverPod
    MutPod -->|"injects volumes, env,<br/>sidecars, scheduling"| ExecutorPods

    %% SparkConnect flow
    ConnectCtrl -->|"creates"| ConnectPod["SparkConnect<br/>Server Pod"]
    ConnectCtrl -->|"creates"| ConnectSvc["SparkConnect<br/>Service"]
    ConnectClient["Spark Connect<br/>Client"] -->|"gRPC/15002"| ConnectSvc

    %% Services
    SparkAppCtrl -->|"creates"| UIService["Driver UI Service<br/>:4040"]
    SparkAppCtrl -->|"creates (optional)"| UIIngress["UI Ingress"]

    %% External dependencies
    K8sAPI["Kubernetes<br/>API Server"]
    SparkAppCtrl -->|"CRUD"| K8sAPI
    SchedCtrl -->|"CRUD"| K8sAPI
    ConnectCtrl -->|"CRUD"| K8sAPI
    MutWebhookCtrl -->|"updates CA bundle"| K8sAPI
    ValWebhookCtrl -->|"updates CA bundle"| K8sAPI

    %% Styling
    style SparkAppCtrl fill:#4a90e2,color:#fff
    style SchedCtrl fill:#4a90e2,color:#fff
    style ConnectCtrl fill:#4a90e2,color:#fff
    style MutWebhookCtrl fill:#4a90e2,color:#fff
    style ValWebhookCtrl fill:#4a90e2,color:#fff
    style SparkSubmit fill:#4a90e2,color:#fff
    style MutSA fill:#9b59b6,color:#fff
    style ValSA fill:#9b59b6,color:#fff
    style MutSSA fill:#9b59b6,color:#fff
    style ValSSA fill:#9b59b6,color:#fff
    style MutPod fill:#9b59b6,color:#fff
    style ResQuota fill:#9b59b6,color:#fff
    style SparkAppCR fill:#f5a623,color:#fff
    style SchedSparkAppCR fill:#f5a623,color:#fff
    style SparkConnectCR fill:#f5a623,color:#fff
    style DriverPod fill:#27ae60,color:#fff
    style ExecutorPods fill:#27ae60,color:#fff
    style ConnectPod fill:#27ae60,color:#fff
    style K8sAPI fill:#e8e8e8,color:#333
    style User fill:#3498db,color:#fff
    style ConnectClient fill:#3498db,color:#fff
