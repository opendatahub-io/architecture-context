graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Edge TLS)"]
        RouteUI["Route: planner<br/>443/TCP → 8501/TCP<br/>TLS Edge Termination<br/>Auth: None"]
        RouteAPI["Route: planner-backend<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination<br/>Auth: None"]
    end

    subgraph PlannerNS["NAMESPACE: planner (No Service Mesh)"]
        direction TB

        StreamlitUI["Streamlit UI<br/>8501/TCP HTTP<br/>quay.io/llm-d-planner/llm-d-planner-ui<br/>non-root, seccomp: RuntimeDefault"]

        BackendAPI["Backend API<br/>8000/TCP HTTP<br/>SA: planner-backend<br/>CORS: * | Auth: None<br/>29 unauthenticated endpoints<br/>non-root, caps dropped, seccomp: RuntimeDefault"]

        OllamaLLM["Ollama LLM<br/>11434/TCP HTTP<br/>granite3.3:2b / qwen2.5:7b<br/>PVC: 20Gi"]

        PostgreSQL["PostgreSQL 16<br/>5432/TCP<br/>Auth: Password<br/>PVC: 5Gi"]

        Simulator["vLLM Simulator (dev only)<br/>8080/TCP HTTP<br/>No GPU required"]
    end

    subgraph CrossNS["CROSS-NAMESPACE (In-Cluster)"]
        ModelCatalog["RHOAI Model Catalog<br/>NS: rhoai-model-registries<br/>8443/TCP HTTPS<br/>Service CA TLS<br/>NetworkPolicy: allow from planner"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| RouteUI
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| RouteAPI

    %% Ingress to Services
    RouteUI -->|"HTTP/8501<br/>Plaintext<br/>No Auth"| StreamlitUI
    RouteAPI -->|"HTTP/8000<br/>Plaintext<br/>No Auth"| BackendAPI

    %% Internal Service Communication
    StreamlitUI -->|"HTTP/8000<br/>Plaintext<br/>No Auth"| BackendAPI
    BackendAPI -->|"HTTP/11434<br/>Plaintext<br/>No Auth"| OllamaLLM
    BackendAPI -->|"PostgreSQL/5432<br/>Plaintext<br/>Password Auth"| PostgreSQL
    BackendAPI -.->|"HTTP/8080<br/>Plaintext<br/>Dev Only"| Simulator

    %% Cross-namespace
    BackendAPI -->|"HTTPS/8443<br/>Service CA TLS<br/>Bearer Token"| ModelCatalog

    %% External egress
    BackendAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN (optional)"| HuggingFace
    BackendAPI -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>RBAC: nodes.list"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef crossns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef devonly fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray:5

    class User external
    class RouteUI,RouteAPI ingress
    class StreamlitUI,BackendAPI,OllamaLLM,PostgreSQL internal
    class Simulator devonly
    class ModelCatalog crossns
    class HuggingFace,K8sAPI externalservice
