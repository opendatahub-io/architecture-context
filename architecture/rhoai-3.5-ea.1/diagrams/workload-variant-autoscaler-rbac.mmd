graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(system namespace)"]
        SA_Prom["kube-prometheus-stack-prometheus<br/>(monitoring namespace)"]
        SA_EPP["epp-metrics-reader<br/>(system namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_MetricsAuth["metrics-auth-rolebinding"]
        CRB_MetricsReader["metrics-reader-rolebinding"]
        CRB_PromAuth["prometheus-metrics-auth-rolebinding"]
        CRB_EPP["epp-metrics-reader-role-binding"]
        CRB_CMView["cluster-monitoring-view<br/>(OpenShift only)"]
    end

    subgraph RoleBindings["Role Bindings (namespace: system)"]
        RB_Leader["leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
        CR_EPPReader["epp-metrics-reader-role"]
        CR_CMView["cluster-monitoring-view<br/>(OpenShift)"]
        CR_Admin["variantautoscaling-admin-role"]
        CR_Editor["variantautoscaling-editor-role"]
        CR_Viewer["variantautoscaling-viewer-role"]
    end

    subgraph Roles["Roles (namespace: system)"]
        R_Leader["leader-election-role"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph LlmdAI["llmd.ai"]
            VA["variantautoscalings"]
            VAStatus["variantautoscalings/status"]
            VAFinalizers["variantautoscalings/finalizers"]
        end

        subgraph Core["core (v1)"]
            CM["configmaps"]
            Events["events"]
            NS["namespaces"]
            Pods["pods"]
            Secrets["secrets"]
            Services["services"]
            NodesRes["nodes"]
            NodesStatus["nodes/status"]
        end

        subgraph Apps["apps (v1)"]
            Deploy["deployments"]
            DeployScale["deployments/scale"]
            RS["replicasets"]
            SS["statefulsets"]
        end

        subgraph LWSGroup["leaderworkerset.x-k8s.io"]
            LWSRes["leaderworkersets"]
            LWSScale["leaderworkersets/scale"]
        end

        subgraph MonitoringGroup["monitoring.coreos.com"]
            SM["servicemonitors"]
        end

        subgraph InferenceGroup["inference.networking.k8s.io"]
            IP["inferencepools"]
        end

        subgraph AuthGroup["authentication / authorization"]
            TR["tokenreviews"]
            SAR["subjectaccessreviews"]
        end

        subgraph NonResourceURLs["Non-Resource URLs"]
            MetricsURL["/metrics"]
            PprofURL["/debug/pprof/*"]
        end

        subgraph CoordinationGroup["coordination.k8s.io"]
            Leases["leases"]
        end
    end

    %% Service Account → Bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_MetricsAuth
    SA_CM -->|bound via| RB_Leader
    SA_CM -->|bound via| CRB_CMView
    SA_Prom -->|bound via| CRB_MetricsReader
    SA_Prom -->|bound via| CRB_PromAuth
    SA_EPP -->|bound via| CRB_EPP

    %% Bindings → Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_MetricsAuth -->|grants| CR_MetricsAuth
    CRB_MetricsReader -->|grants| CR_MetricsReader
    CRB_PromAuth -->|grants| CR_MetricsAuth
    CRB_EPP -->|grants| CR_EPPReader
    CRB_CMView -->|grants| CR_CMView
    RB_Leader -->|grants| R_Leader

    %% manager-role → Resources
    CR_Manager -->|"CRUD + watch"| VA
    CR_Manager -->|"get, patch, update"| VAStatus
    CR_Manager -->|"update"| VAFinalizers
    CR_Manager -->|"get, list, update, watch"| CM
    CR_Manager -->|"create, patch"| Events
    CR_Manager -->|"get, list, watch"| NS
    CR_Manager -->|"get, list, watch"| Pods
    CR_Manager -->|"get, list, watch"| Secrets
    CR_Manager -->|"get, list, watch"| Services
    CR_Manager -->|"get, list, watch, update, patch"| NodesRes
    CR_Manager -->|"get, list, watch, update, patch"| Deploy
    CR_Manager -->|"get, update"| DeployScale
    CR_Manager -->|"get, list, watch"| RS
    CR_Manager -->|"get, list, watch"| SS
    CR_Manager -->|"get, list, watch, update, patch"| LWSRes
    CR_Manager -->|"get, update"| LWSScale
    CR_Manager -->|"get, list, watch"| SM
    CR_Manager -->|"get, list, watch"| IP

    %% metrics-auth-role → Resources
    CR_MetricsAuth -->|"create"| TR
    CR_MetricsAuth -->|"create"| SAR

    %% metrics-reader → Non-Resource URLs
    CR_MetricsReader -->|"get"| MetricsURL

    %% epp-metrics-reader-role → Non-Resource URLs
    CR_EPPReader -->|"get"| MetricsURL
    CR_EPPReader -->|"get"| PprofURL

    %% leader-election-role → Resources
    R_Leader -->|"CRUD + watch"| Leases
    R_Leader -->|"create, patch"| Events

    %% Aggregate roles
    CR_Admin -->|"all verbs"| VA
    CR_Admin -->|"all verbs"| VAStatus
    CR_Editor -->|"CRUD + watch"| VA
    CR_Viewer -->|"get, list, watch"| VA

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_MetricsAuth fill:#f5a623,stroke:#333
    style CR_MetricsReader fill:#f5a623,stroke:#333
    style CR_EPPReader fill:#f5a623,stroke:#333
    style CR_CMView fill:#f5a623,stroke:#333
    style CR_Admin fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style VA fill:#7ed321,stroke:#333
    style VAStatus fill:#7ed321,stroke:#333
    style VAFinalizers fill:#7ed321,stroke:#333
    style Deploy fill:#7ed321,stroke:#333
    style NodesRes fill:#7ed321,stroke:#333
    style LWSRes fill:#7ed321,stroke:#333
    style IP fill:#7ed321,stroke:#333
