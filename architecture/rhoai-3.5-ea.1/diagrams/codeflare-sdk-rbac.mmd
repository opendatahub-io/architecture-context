    style HTTPRoutes fill:#f5a623
    style Gateways fill:#f5a623
    style LocalQueues fill:#f5a623
    style Workloads fill:#f5a623
    style PriorityClasses fill:#f5a623

    style CreateCluster fill:#7ed321
    style SubmitJob fill:#7ed321
