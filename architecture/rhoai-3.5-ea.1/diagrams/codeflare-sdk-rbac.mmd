graph TD
    subgraph AuthMethods["Authentication Methods (via kube-authkit)"]
        OIDC["OIDC Token"]
        OAuth["OpenShift OAuth"]
        Bearer["Bearer Token"]
        KubeConfig["kubeconfig"]
        InCluster["In-Cluster<br/>Service Account"]
    end

    subgraph UserIdentity["Authenticated User Identity"]
        User["Authenticated User<br/>(Data Scientist / ML Engineer)"]
    end

    OIDC -->|"authenticates as"| User
    OAuth -->|"authenticates as"| User
    Bearer -->|"authenticates as"| User
    KubeConfig -->|"authenticates as"| User
    InCluster -->|"authenticates as"| User

    subgraph RequiredPermissions["Required RBAC Permissions (User Must Have)"]
        direction TB

        subgraph RayIO["API Group: ray.io"]
            RayClusters["rayclusters<br/>get, list, create, delete, patch"]
            RayJobs["rayjobs<br/>get, list, create, delete, patch"]
        end

        subgraph CoreAPI["API Group: core (\"\")"]
            Secrets["secrets<br/>get, list, create, delete"]
            Namespaces["namespaces<br/>get"]
        end

        subgraph RouteAPI["API Group: route.openshift.io"]
            Routes["routes<br/>get, list"]
        end

        subgraph GatewayAPI["API Group: gateway.networking.k8s.io"]
            HTTPRoutes["httproutes<br/>get, list"]
            Gateways["gateways<br/>get, list"]
        end

        subgraph KueueAPI["API Group: kueue.x-k8s.io"]
            LocalQueues["localqueues<br/>get, list"]
            Workloads["workloads<br/>get, list"]
            PriorityClasses["workloadpriorityclasses<br/>get, list"]
        end
    end

    User -->|"must have"| RayClusters
    User -->|"must have"| RayJobs
    User -->|"must have"| Secrets
    User -->|"must have"| Namespaces
    User -->|"must have"| Routes
    User -->|"must have"| HTTPRoutes
    User -->|"must have"| Gateways
    User -->|"must have"| LocalQueues
    User -->|"must have"| Workloads
    User -->|"must have"| PriorityClasses

    subgraph SDKOperations["SDK Operations Using Permissions"]
        CreateCluster["Create/Delete RayCluster"]
        SubmitJob["Submit/Delete RayJob"]
        ManageTLS["Read CA Secret /<br/>Create File Secret"]
        ResolveDashboard["Resolve Dashboard URL<br/>(HTTPRoute → Route fallback)"]
        CheckQueues["List Queues /<br/>Check Admission"]
    end

    RayClusters -->|"used by"| CreateCluster
    RayJobs -->|"used by"| SubmitJob
    Secrets -->|"used by"| ManageTLS
    Routes -->|"used by"| ResolveDashboard
    HTTPRoutes -->|"used by"| ResolveDashboard
    Gateways -->|"used by"| ResolveDashboard
    LocalQueues -->|"used by"| CheckQueues
    Workloads -->|"used by"| CheckQueues
    PriorityClasses -->|"used by"| CheckQueues
    Namespaces -->|"used by"| CreateCluster

