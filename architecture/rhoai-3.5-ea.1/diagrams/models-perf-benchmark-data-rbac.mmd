graph TD
    subgraph "models-perf-benchmark-data RBAC"
        direction TB

        Note["NOTE: This component defines NO RBAC resources.<br/>It inherits permissions from the model-catalog Deployment."]

        subgraph "Runtime Context"
            direction TB
            InitContainer["Init Container<br/>odh-model-performance-data"]
            ModelCatalogSA["ServiceAccount<br/>(inherited from model-catalog Deployment)"]
            InitContainer -->|"runs as"| ModelCatalogSA
        end

        subgraph "Offline Context (kafka-processor)"
            direction TB
            KafkaProc["kafka-processor<br/>Python CLI (not deployed)"]
            KafkaCreds["Kafka Credentials<br/>SASL_USERNAME / SASL_PASSWORD<br/>Type: Opaque (env vars)"]
            SSLCerts["SSL Certificates<br/>CA cert, Client cert, Client key<br/>Type: TLS files"]
            KafkaACL["Kafka Topic ACLs<br/>Enforced by Kafka broker"]

            KafkaProc -->|"authenticates with"| KafkaCreds
            KafkaProc -->|"optional mTLS"| SSLCerts
            KafkaCreds -->|"validated against"| KafkaACL
        end

        subgraph "Permissions Summary"
            direction TB
            P1["No ClusterRoles defined"]
            P2["No Roles defined"]
            P3["No RoleBindings defined"]
            P4["No ClusterRoleBindings defined"]
            P5["No CRDs managed"]
        end
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style ModelCatalogSA fill:#7ed321,stroke:#333
    style KafkaProc fill:#4a90e2,stroke:#333,color:#fff
    style KafkaCreds fill:#f5a623,stroke:#333
    style SSLCerts fill:#f5a623,stroke:#333
    style KafkaACL fill:#e8e8e8,stroke:#333
    style P1 fill:#f9f9f9,stroke:#ccc
    style P2 fill:#f9f9f9,stroke:#ccc
    style P3 fill:#f9f9f9,stroke:#ccc
    style P4 fill:#f9f9f9,stroke:#ccc
    style P5 fill:#f9f9f9,stroke:#ccc
