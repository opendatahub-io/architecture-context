graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"core inference<br/>engine (in-process)"| OVRuntime["OpenVINO Runtime<br/>2026.1"]
    OVMS -->|"LLM/image/audio<br/>pipelines (in-process)"| OVGenAI["OpenVINO GenAI<br/>2026.1"]
    OVMS -->|"tokenization<br/>(in-process)"| OVTokenizers["OpenVINO Tokenizers<br/>2026.1"]

    %% Framework Dependencies (Required)
    OVMS -->|"gRPC server"| gRPC["gRPC<br/>(bundled)"]
    OVMS -->|"HTTP/REST server"| Drogon["Drogon Framework<br/>(bundled)"]
    OVMS -->|"graph pipelines"| MediaPipe["MediaPipe<br/>(bundled)"]
    OVMS -->|"C++ utilities"| Boost["Boost<br/>1.68.0"]
    OVMS -->|"image processing"| OpenCV["OpenCV<br/>(bundled)"]
    OVMS -->|"JSON parsing"| RapidJSON["RapidJSON<br/>(bundled)"]

    %% Conditional Dependencies
    OVMS -.->|"S3 storage<br/>backend"| AWSSDK["AWS SDK C++<br/>(bundled)"]
    OVMS -.->|"Azure storage<br/>backend"| AzureSDK["Azure Storage SDK<br/>7.5.0"]
    OVMS -.->|"GCS storage<br/>backend"| GCSSDK["Google Cloud<br/>Storage SDK"]
    OVMS -.->|"HuggingFace<br/>model pull"| libgit2["libgit2<br/>(bundled)"]
    OVMS -.->|"custom Python<br/>nodes"| Python["Python 3.12"]
    OVMS -.->|"chat templates"| Jinja2["Jinja2<br/>3.1.6"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe<br/>InferenceService"] ==>|"deploys OVMS as<br/>serving runtime"| OVMS
    ModelMesh["Model Mesh"] -.->|"alternative<br/>backend"| OVMS

    %% Platform Integration Points
    KubeRBACProxy["kube-rbac-proxy<br/>(RHOAI sidecar)"] -->|"auth enforcement<br/>8443/TCP HTTPS"| OVMS
    Istio["Istio / Service Mesh"] -.->|"transparent mTLS"| OVMS
    StorageInit["KServe Storage<br/>Initializer"] -->|"pre-downloads model<br/>to shared volume"| OVMS
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP"| OVMS

    %% External Services
    OVMS -->|"model loading<br/>HTTPS/443"| S3["S3 Storage"]
    OVMS -->|"model loading<br/>HTTPS/443"| AzureBlob["Azure Blob Storage"]
    OVMS -->|"model loading<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    OVMS -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - orange
    style OVRuntime fill:#ff8a65,stroke:#333,color:#fff
    style OVGenAI fill:#ff8a65,stroke:#333,color:#fff
    style OVTokenizers fill:#ff8a65,stroke:#333,color:#fff

    %% Bundled frameworks - grey
    style gRPC fill:#999,stroke:#333,color:#fff
    style Drogon fill:#999,stroke:#333,color:#fff
    style MediaPipe fill:#999,stroke:#333,color:#fff
    style Boost fill:#999,stroke:#333,color:#fff
    style OpenCV fill:#999,stroke:#333,color:#fff
    style RapidJSON fill:#999,stroke:#333,color:#fff

    %% Conditional deps - lighter grey
    style AWSSDK fill:#bbb,stroke:#333
    style AzureSDK fill:#bbb,stroke:#333
    style GCSSDK fill:#bbb,stroke:#333
    style libgit2 fill:#bbb,stroke:#333
    style Python fill:#bbb,stroke:#333
    style Jinja2 fill:#bbb,stroke:#333

    %% Internal RHOAI - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e65100,stroke:#333,color:#fff

    %% External services - yellow
    style S3 fill:#f5a623,stroke:#333
    style AzureBlob fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
