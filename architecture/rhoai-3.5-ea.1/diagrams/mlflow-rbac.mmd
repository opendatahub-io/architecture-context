graph TD
    subgraph ExternalAuth["External Authentication (Platform-Managed)"]
        direction TB
        Gateway["RHOAI Platform Gateway<br/>TLS 1.2+ Termination"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>TokenReview validation"]
        Gateway -->|"forwards Bearer Token"| KubeRBACProxy
    end

    subgraph K8sAuth["Kubernetes Authentication Layer"]
        direction TB
        SAToken["ServiceAccount Token<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token<br/>(projected volume, auto-rotated)"]
        TokenCache["Token Cache<br/>60-second TTL"]
        SAToken -->|"read by"| TokenCache
    end

    subgraph MLflowAuth["MLflow Authorization (kubernetes-auth Plugin)"]
        direction TB

        subgraph PermissionLevels["Permission Levels"]
            READ["READ<br/>View experiments, runs,<br/>metrics, models"]
            EDIT["EDIT<br/>Create/modify experiments,<br/>runs, log metrics"]
            MANAGE["MANAGE<br/>Delete experiments,<br/>manage permissions"]
        end

        subgraph ResourceTypes["Protected Resource Types"]
            Experiments["Experiments<br/>/api/2.0/mlflow/experiments/*"]
            Runs["Runs<br/>/api/2.0/mlflow/runs/*"]
            Metrics["Metrics<br/>/api/2.0/mlflow/metrics/*"]
            RegisteredModels["Registered Models<br/>/api/2.0/mlflow/registered-models/*"]
            ModelVersions["Model Versions<br/>/api/2.0/mlflow/model-versions/*"]
            Traces["Traces<br/>/v1/traces"]
            Artifacts["Artifacts<br/>/api/2.0/mlflow/artifacts/*"]
            Workspaces["Workspaces<br/>/api/2.0/mlflow/workspaces/*"]
        end
    end

    subgraph WorkspaceIsolation["Workspace Isolation"]
        direction TB
        K8sNamespace["Kubernetes Namespace"]
        WorkspaceMap["mlflow-kubernetes-plugins<br/>kubernetes:// URI scheme"]
        MLflowWorkspace["MLflow Workspace<br/>(ContextVar per-request)"]
        SQLFilter["Workspace-Aware SQL Queries<br/>(workspace column filtering)"]

        K8sNamespace -->|"mapped by"| WorkspaceMap
        WorkspaceMap -->|"sets"| MLflowWorkspace
        MLflowWorkspace -->|"scopes"| SQLFilter
    end

    subgraph AuthExempt["Auth-Exempt Endpoints"]
        Health["/health — GET<br/>Liveness/readiness probe"]
        Version["/version — GET<br/>Version string"]
    end

    subgraph SecurityMiddleware["Security Middleware (All Endpoints)"]
        CORS["CORSBlockingMiddleware<br/>Blocks cross-origin<br/>POST, PUT, DELETE, PATCH"]
        HostValid["HostValidationMiddleware<br/>DNS rebinding protection<br/>Private IPs + localhost allowed"]
        SecHeaders["Security Headers<br/>Standard response headers"]
    end

    subgraph Secrets["Secret Management"]
        KEK["MLFLOW_CRYPTO_KEK_PASSPHRASE<br/>Key Encryption Key<br/>Manual rotation: mlflow crypto rotate-kek"]
        FlaskKey["MLFLOW_FLASK_SERVER_SECRET_KEY<br/>Session signing key<br/>Manual rotation"]
        DBUri["Database Connection URI<br/>PostgreSQL credentials<br/>Managed by platform operator"]
    end

    %% Auth flow
    KubeRBACProxy -->|"validated identity"| TokenCache
    TokenCache -->|"authenticates"| PermissionLevels
    READ -->|"authorizes access to"| ResourceTypes
    EDIT -->|"authorizes access to"| ResourceTypes
    MANAGE -->|"authorizes access to"| ResourceTypes

    %% Workspace flow
    TokenCache -->|"resolves namespace"| K8sNamespace

    %% Managed by
    RhodsOperator["rhods-operator<br/>(manages all RBAC externally)"] -.->|"provisions"| SAToken
    RhodsOperator -.->|"creates"| KubeRBACProxy
    RhodsOperator -.->|"manages"| Gateway

    %% Styling
    style Gateway fill:#4a90e2,color:#fff
    style KubeRBACProxy fill:#f5a623,color:#fff
    style SAToken fill:#fff3e0,stroke:#e65100
    style TokenCache fill:#fff3e0,stroke:#e65100
    style READ fill:#c8e6c9,stroke:#2e7d32
