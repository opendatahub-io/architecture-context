    style Traces fill:#e3f2fd,stroke:#1565c0
    style Artifacts fill:#e3f2fd,stroke:#1565c0
    style Workspaces fill:#e3f2fd,stroke:#1565c0
    style Health fill:#f5f5f5,stroke:#999
    style Version fill:#f5f5f5,stroke:#999
