graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_Deploy["Namespace: deployment namespace"]
            direction TB

            LLS["Llama Stack Server<br/>ClusterIP: 8321/TCP HTTP<br/>No Auth<br/>NetworkPolicy: allow-kfp-to-llamastack"]

            subgraph ProviderPod["Provider Pod"]
                Provider["trustyai-garak-lls-provider<br/>SA: llamastack-garak-distribution-sa<br/>Image: odh-trustyai-garak-lls-provider-dsp-rhel9"]
                GarakSubprocess["Garak Subprocess<br/>Semaphore: max 5 concurrent<br/>Timeout: 10800s"]
            end

            subgraph KFPPods["KFP Pipeline Pods (remote mode)"]
                KFPStep["6-step Pipeline DAG<br/>validate → resolve_taxonomy →<br/>sdg_generate → prepare_prompts →<br/>garak_scan → parse_results"]
            end

            subgraph EvalHubPod["eval-hub K8s Job (eval-hub mode)"]
                EvalHubSidecar["eval-hub Sidecar<br/>gRPC (no encryption)"]
            end
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        vLLM["vLLM Inference<br/>443/TCP HTTPS<br/>TLS (configurable)<br/>Bearer Token"]
        KFPAPI["KFP API (ds-pipeline-dspa)<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
        S3["S3/MinIO<br/>443/TCP HTTPS<br/>TLS<br/>AWS IAM Keys"]
        OCI["OCI Registry (Quay.io)<br/>443/TCP HTTPS<br/>TLS<br/>Bearer Token"]
        MLflow["MLflow Tracking<br/>443/TCP HTTPS<br/>TLS<br/>Bearer Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>No encryption<br/>Username/Password"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>No encryption<br/>No auth (NetworkPolicy)"| LLS

    %% Llama Stack to Provider (in-process)
    LLS ---|"in-process<br/>provider library"| Provider

    %% Provider execution modes
    Provider --> GarakSubprocess
    Provider -->|"HTTPS/443<br/>TLS<br/>SA Token"| KFPAPI
    Provider ---|"gRPC<br/>No encryption"| EvalHubSidecar

    %% Garak to external
    GarakSubprocess -->|"HTTPS/443<br/>TLS<br/>Bearer Token<br/>(VLLM_API_TOKEN)"| vLLM

    %% KFP pods
    KFPAPI -.->|"spawns"| KFPStep
    KFPStep -->|"HTTP/8321<br/>No encryption"| LLS
    KFPStep -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| vLLM

    %% eval-hub egress
    EvalHubSidecar -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| OCI
    EvalHubSidecar -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| MLflow
    Provider -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3

    %% PostgreSQL
    LLS -->|"TCP/5432<br/>No encryption<br/>Username/Password"| PostgreSQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef provider fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class LLS ingress
    class Provider,GarakSubprocess provider
    class KFPStep,EvalHubSidecar cluster
    class vLLM,KFPAPI,S3,OCI,MLflow egress
    class PostgreSQL warning
