    style PlatformIngress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style TLS fill:#ffe6cc,stroke:#d79b00
    style PlatformRBAC fill:#ffe6cc,stroke:#d79b00
    style NoServerAuth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style ChatEndpoint fill:#d5e8d4,stroke:#82b366
    style CheckEndpoint fill:#d5e8d4,stroke:#82b366
    style ModelsEndpoint fill:#d5e8d4,stroke:#82b366
    style ConfigsEndpoint fill:#fff2cc,stroke:#d6b656
    style ChallengesEndpoint fill:#fff2cc,stroke:#d6b656
    style HealthEndpoint fill:#fff2cc,stroke:#d6b656
    style OpenAIAuth fill:#e1d5e7,stroke:#9673a6
    style AzureAuth fill:#e1d5e7,stroke:#9673a6
    style AnthropicAuth fill:#e1d5e7,stroke:#9673a6
    style CohereAuth fill:#e1d5e7,stroke:#9673a6
    style NIMAuth fill:#e1d5e7,stroke:#9673a6
    style vLLMAuth fill:#e1d5e7,stroke:#9673a6
    style Secret1 fill:#f5f5f5,stroke:#666
    style Secret2 fill:#f5f5f5,stroke:#666
    style Secret3 fill:#f5f5f5,stroke:#666
    style Secret4 fill:#f5f5f5,stroke:#666
    style Secret5 fill:#f5f5f5,stroke:#666
    style NoK8sRBAC fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999
