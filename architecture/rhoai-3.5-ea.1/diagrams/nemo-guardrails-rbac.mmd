graph TD
    subgraph "NeMo Guardrails - Authentication & Authorization Model"
        direction TB

        subgraph "Platform-Level Security (Managed by RHOAI)"
            PlatformIngress["RHOAI Platform Ingress<br/>kube-rbac-proxy / Gateway API"]
            TLS["TLS Termination<br/>TLS 1.2+"]
            PlatformRBAC["Platform RBAC<br/>Kubernetes RBAC via kube-rbac-proxy"]

            PlatformIngress -->|terminates| TLS
            PlatformIngress -->|enforces| PlatformRBAC
        end

        subgraph "Application-Level Auth (NeMo Guardrails Server)"
            direction TB
            NoServerAuth["No Server-Level Authentication<br/>All endpoints accessible within cluster"]

            subgraph "Endpoint Auth Behavior"
                ChatEndpoint["POST /v1/chat/completions<br/>Auth: Forwarded to upstream LLM"]
                CheckEndpoint["POST /v1/guardrail/checks<br/>Auth: Forwarded if LLM needed"]
                ModelsEndpoint["GET /v1/models<br/>Auth: Forwarded to provider"]
                ConfigsEndpoint["GET /v1/rails/configs<br/>Auth: None required"]
                ChallengesEndpoint["GET /v1/challenges<br/>Auth: None required"]
                HealthEndpoint["GET /<br/>Auth: None (health check)"]
            end

            NoServerAuth --- ChatEndpoint
            NoServerAuth --- CheckEndpoint
            NoServerAuth --- ModelsEndpoint
            NoServerAuth --- ConfigsEndpoint
            NoServerAuth --- ChallengesEndpoint
            NoServerAuth --- HealthEndpoint
        end

        subgraph "Upstream LLM Provider Auth (Egress)"
            direction TB
            OpenAIAuth["OpenAI<br/>Bearer Token<br/>OPENAI_API_KEY"]
            AzureAuth["Azure OpenAI<br/>API Key header<br/>AZURE_OPENAI_API_KEY"]
            AnthropicAuth["Anthropic<br/>x-api-key header<br/>ANTHROPIC_API_KEY"]
            CohereAuth["Cohere<br/>Bearer Token<br/>COHERE_API_KEY"]
            NIMAuth["NVIDIA NIM<br/>API Key<br/>Configurable"]
            vLLMAuth["vLLM / TRT-LLM<br/>Bearer Token (optional)"]
        end

        ChatEndpoint -->|forwards auth| OpenAIAuth
        ChatEndpoint -->|forwards auth| AzureAuth
        ChatEndpoint -->|forwards auth| AnthropicAuth
        ChatEndpoint -->|forwards auth| CohereAuth
        ChatEndpoint -->|forwards auth| NIMAuth
        ChatEndpoint -->|forwards auth| vLLMAuth

        subgraph "Secrets Management"
            direction LR
            Secret1["LLM API Key<br/>Opaque env var<br/>Manual/Platform<br/>No auto-rotate"]
            Secret2["Azure OpenAI API Key<br/>Opaque env var<br/>Manual/Platform<br/>No auto-rotate"]
            Secret3["Anthropic API Key<br/>Opaque env var<br/>Manual/Platform<br/>No auto-rotate"]
            Secret4["Cohere API Key<br/>Opaque env var<br/>Manual/Platform<br/>No auto-rotate"]
            Secret5["Redis Credentials<br/>Opaque env var<br/>Manual/Platform<br/>No auto-rotate"]
        end

        OpenAIAuth -.->|reads| Secret1
        AzureAuth -.->|reads| Secret2
        AnthropicAuth -.->|reads| Secret3
        CohereAuth -.->|reads| Secret4
    end

    subgraph "Kubernetes RBAC"
        NoK8sRBAC["No Kubernetes RBAC Resources<br/>Defined by This Component<br/><br/>• No ClusterRoles<br/>• No ClusterRoleBindings<br/>• No Roles<br/>• No RoleBindings<br/><br/>RBAC managed entirely<br/>by RHOAI platform"]
    end

    Client["External Client"] -->|HTTPS/443<br/>TLS 1.2+| PlatformIngress
    PlatformIngress -->|HTTP/8000<br/>Auth header forwarded| NoServerAuth

