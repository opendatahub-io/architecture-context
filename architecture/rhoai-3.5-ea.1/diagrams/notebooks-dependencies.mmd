graph LR
    Notebooks["Notebooks<br/>(Workbench & Runtime Images)"]

    %% External Dependencies (Required)
    Notebooks -->|"runtime interpreter"| Python["Python 3.12<br/>(3.11 for N-3)"]
    Notebooks -->|"notebook IDE"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"VS Code IDE"| CodeServer["code-server 4.106"]
    Notebooks -->|"package installer"| UV["uv 0.11.13"]

    %% External Dependencies (Conditional - GPU)
    Notebooks -->|"GPU compute (NVIDIA)"| CUDA["NVIDIA CUDA<br/>12.9 / 13.0"]
    Notebooks -->|"GPU compute (AMD)"| ROCm["AMD ROCm<br/>6.4 / 7.1"]

    %% External Dependencies (Conditional - ML Frameworks)
    Notebooks -->|"deep learning"| PyTorch["PyTorch 2.10"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow 2.21"]
    Notebooks -->|"LLM optimization"| LLMCompressor["LLM Compressor 0.10"]
    Notebooks -->|"AI explainability"| TrustyAI["TrustyAI 0.6"]
    Notebooks -->|"TrustyAI backend"| Java17["Java 17 (OpenJDK)"]

    %% External Dependencies (Conditional - Tooling)
    Notebooks -->|"MongoDB CLI"| Mongocli["mongocli<br/>(Go, FIPS-compiled)"]
    Notebooks -->|"reverse proxy"| Nginx["nginx"]
    Notebooks -->|"CGI gateway"| Httpd["httpd (Apache)"]
    Notebooks -->|"pipeline execution"| Elyra["Elyra bootstrapper 4.3.1"]

    %% Internal RHOAI Dependencies
    RhodsOperator["rhods-operator /<br/>opendatahub-operator"] -->|"deploys ImageStreams"| Notebooks
    Dashboard["ODH Dashboard"] -->|"reads annotations<br/>for workbench UI"| Notebooks
    NotebookCtrl["Notebook Controller<br/>(kubeflow)"] -->|"creates pods,<br/>injects kube-rbac-proxy,<br/>mounts secrets"| Notebooks
    Culler["Notebook Controller<br/>Culler"] -->|"polls /api/kernels/<br/>for idle culling"| Notebooks
    DSPA["Data Science Pipelines<br/>(DSPA)"] -->|"pipeline backend<br/>for runtime images"| Notebooks
    AIPCC["AIPCC Pipeline"] -->|"provides RHEL<br/>base images"| Notebooks

    %% Integration Points (outbound from workbenches)
    Notebooks -->|"pipeline submission<br/>HTTP(S)/8888"| DSPAEndpoint["DSPA Endpoint"]
    Notebooks -->|"object storage<br/>HTTPS/443"| S3["S3 Storage"]
    Notebooks -->|"experiment tracking<br/>HTTP(S)/5000"| MLflow["MLflow Server"]
    Notebooks -->|"event streaming<br/>TCP/9092"| Kafka["Kafka Brokers"]
    Notebooks -->|"database ops<br/>TCP/27017"| MongoDB["MongoDB"]

    %% Build/CI Integration
    KonfluxCI["Konflux CI"] -->|"hermetic builds<br/>Dockerfile.konflux.*"| Notebooks
    Notebooks -->|"image push<br/>HTTPS/443"| Registry["Container Registry<br/>registry.redhat.io<br/>quay.io"]
    SecurityConfig["security-config<br/>(opendatahub-io)"] -.->|"Semgrep, gitleaks,<br/>CodeRabbit configs"| Notebooks

