graph TD
    subgraph "Service Account"
        SA["{bbr-name}-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB1["{release}-externalmodels-reader<br/>(ClusterRoleBinding — multi-ns)"]
        CRB2["ExternalModel controller binding<br/>(kubebuilder-generated)"]
        CRB3["ExternalProvider controller binding<br/>(kubebuilder-generated)"]
    end

    subgraph "ClusterRoles"
        CR1["{release}-externalmodels-reader"]
        CR2["ExternalModel controller role"]
        CR3["ExternalProvider controller role"]
    end

    subgraph "API Resources — BBR Plugin Access"
        Secrets_R["core / secrets"]
        MaaSModels["maas.opendatahub.io<br/>externalmodels"]
    end

    subgraph "API Resources — ExternalModel Controller"
        EM["inference.opendatahub.io<br/>externalmodels"]
        EM_Status["inference.opendatahub.io<br/>externalmodels/status"]
        EM_Finalizers["inference.opendatahub.io<br/>externalmodels/finalizers"]
        EP_Read["inference.opendatahub.io<br/>externalproviders"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
    end

    subgraph "API Resources — ExternalProvider Controller"
        EP["inference.opendatahub.io<br/>externalproviders"]
        EP_Status["inference.opendatahub.io<br/>externalproviders/status"]
        EP_Finalizers["inference.opendatahub.io<br/>externalproviders/finalizers"]
        Secrets_EP["core / secrets"]
        Services["core / services"]
        ServiceEntries["networking.istio.io<br/>serviceentries"]
        DestRules["networking.istio.io<br/>destinationrules"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% CR1 permissions
    CR1 -->|"get, list, watch"| Secrets_R
    CR1 -->|"get, list, watch"| MaaSModels

    %% CR2 permissions
    CR2 -->|"get, list, watch"| EM
    CR2 -->|"get, update, patch"| EM_Status
    CR2 -->|"update"| EM_Finalizers
    CR2 -->|"get, list, watch"| EP_Read
    CR2 -->|"get, list, watch,<br/>create, update, delete"| HTTPRoutes

    %% CR3 permissions
    CR3 -->|"get, list, watch"| EP
    CR3 -->|"get, update, patch"| EP_Status
    CR3 -->|"update"| EP_Finalizers
    CR3 -->|"get, list, watch"| Secrets_EP
    CR3 -->|"get, list, watch,<br/>create, update, delete"| Services
    CR3 -->|"get, list, watch,<br/>create, update, delete"| ServiceEntries
    CR3 -->|"get, list, watch,<br/>create, update, delete"| DestRules

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB1 fill:#6baed6,stroke:#333
    style CRB2 fill:#6baed6,stroke:#333
    style CRB3 fill:#6baed6,stroke:#333
    style CR1 fill:#f5a623,stroke:#333
    style CR2 fill:#f5a623,stroke:#333
    style CR3 fill:#f5a623,stroke:#333
    style Secrets_R fill:#7ed321,stroke:#333
    style MaaSModels fill:#7ed321,stroke:#333
    style EM fill:#7ed321,stroke:#333
    style EM_Status fill:#7ed321,stroke:#333
    style EM_Finalizers fill:#7ed321,stroke:#333
    style EP_Read fill:#7ed321,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style EP fill:#7ed321,stroke:#333
    style EP_Status fill:#7ed321,stroke:#333
    style EP_Finalizers fill:#7ed321,stroke:#333
    style Secrets_EP fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ServiceEntries fill:#7ed321,stroke:#333
    style DestRules fill:#7ed321,stroke:#333
