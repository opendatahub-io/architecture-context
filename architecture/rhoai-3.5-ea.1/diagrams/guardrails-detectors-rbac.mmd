graph TD
    subgraph "Guardrails Detectors RBAC & Auth Model"
        direction TB

        subgraph "Note: No Direct K8s RBAC"
            Note["These are application-level services<br/>that do NOT interact with the<br/>Kubernetes API directly.<br/><br/>RBAC is handled by KServe and<br/>Istio at the platform level."]
        end

        subgraph "KServe Auth Layer"
            KServeAuth["KServe Authentication<br/>Annotation: security.opendatahub.io/<br/>enable-auth: 'true'"]
        end

        subgraph "Istio mTLS Layer"
            IstioMTLS["Istio Sidecar<br/>TLS Mode: ISTIO_MUTUAL<br/>sidecar.istio.io/inject: 'true'"]
        end

        subgraph "Example Role Binding (from deploy manifests)"
            SA["ServiceAccount<br/>user-one"]
            RB["RoleBinding<br/>user-one-view"]
            CR["ClusterRole<br/>view"]
        end

        subgraph "Endpoint Auth Matrix"
            EP1["/api/v1/text/contents<br/>POST<br/>Auth: Istio mTLS + KServe auth"]
            EP2["/api/v1/text/generation<br/>POST (judge only)<br/>Auth: Istio mTLS + KServe auth"]
            EP3["/health<br/>GET<br/>Auth: None (unauthenticated)"]
            EP4["/metrics<br/>GET<br/>Auth: None (Prometheus scrape)"]
            EP5["/registry<br/>GET (built-in only)<br/>Auth: None"]
        end

        subgraph "Secrets"
            Secret1["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>Type: Opaque (S3 connection)<br/>Contents: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY<br/>Auto-rotate: No"]
        end
    end

    SA -->|bound via| RB
    RB -->|grants| CR

    KServeAuth -->|protects| EP1
    KServeAuth -->|protects| EP2
    IstioMTLS -->|encrypts| EP1
    IstioMTLS -->|encrypts| EP2
    IstioMTLS -->|encrypts| EP3
    IstioMTLS -->|encrypts| EP4
    IstioMTLS -->|encrypts| EP5

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KServeAuth fill:#d4edda,stroke:#155724,color:#155724
    style IstioMTLS fill:#d1ecf1,stroke:#0c5460,color:#0c5460
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style RB fill:#e8e8e8,stroke:#333
    style EP1 fill:#d5e8d4,stroke:#82b366
    style EP2 fill:#d5e8d4,stroke:#82b366
    style EP3 fill:#f8d7da,stroke:#721c24
    style EP4 fill:#f8d7da,stroke:#721c24
    style EP5 fill:#f8d7da,stroke:#721c24
    style Secret1 fill:#fff2cc,stroke:#d6b656
