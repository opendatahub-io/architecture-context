graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Pipeline["ml-pipeline"]
        SA_PA["ml-pipeline-persistenceagent-sa"]
        SA_SWC["ml-pipeline-scheduledworkflow-sa"]
        SA_Runner["pipeline-runner-sa"]
        SA_UI["ml-pipeline-ui-sa"]
        SA_Viewer["ml-pipeline-viewer-crd-sa"]
        SA_MetaWriter["kubeflow-pipelines-metadata-writer-sa"]
        SA_Cache["kubeflow-pipelines-cache-sa"]
        SA_CacheDeploy["kubeflow-pipelines-cache-deployer-sa"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-Scoped)"]
        RB_Pipeline["ml-pipeline"]
        RB_PA["ml-pipeline-persistenceagent-binding"]
        RB_SWC["ml-pipeline-scheduledworkflow-binding"]
        RB_Runner["pipeline-runner-binding"]
        RB_UI["ml-pipeline-ui"]
        RB_Viewer["ml-pipeline-viewer-crd-binding"]
        RB_MetaWriter["kubeflow-pipelines-metadata-writer-binding"]
        RB_Cache["kubeflow-pipelines-cache-binding"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_CacheDeploy["kubeflow-pipelines-cache-deployer-clusterrolebinding"]
    end

    subgraph Roles["Roles (Namespace-Scoped)"]
        R_Pipeline["ml-pipeline"]
        R_PA["ml-pipeline-persistenceagent-role"]
        R_SWC["ml-pipeline-scheduledworkflow-role"]
        R_Runner["pipeline-runner"]
        R_UI["ml-pipeline-ui"]
        R_Viewer["ml-pipeline-viewer-controller-role"]
        R_MetaWriter["kubeflow-pipelines-metadata-writer-role"]
        R_Cache["kubeflow-pipelines-cache-role"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_CacheDeploy["kubeflow-pipelines-cache-deployer-clusterrole"]
    end

    subgraph CRResources["ClusterRole Resources"]
        CertCSR["certificates.k8s.io<br/>certificatesigningrequests<br/>create, get, delete, watch"]
        CertApproval["certificates.k8s.io<br/>certificatesigningrequests/approval<br/>update"]
        WebhookConfig["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>create, get, list, patch, delete"]
        CertSigners["certificates.k8s.io<br/>signers (kubernetes.io/*)<br/>approve"]
    end

    %% SA → RoleBinding
    SA_Pipeline -->|"bound via"| RB_Pipeline
    SA_PA -->|"bound via"| RB_PA
    SA_SWC -->|"bound via"| RB_SWC
    SA_Runner -->|"bound via"| RB_Runner
    SA_UI -->|"bound via"| RB_UI
    SA_Viewer -->|"bound via"| RB_Viewer
    SA_MetaWriter -->|"bound via"| RB_MetaWriter
    SA_Cache -->|"bound via"| RB_Cache
    SA_CacheDeploy -->|"bound via"| CRB_CacheDeploy

    %% RoleBinding → Role
    RB_Pipeline -->|"grants"| R_Pipeline
    RB_PA -->|"grants"| R_PA
    RB_SWC -->|"grants"| R_SWC
    RB_Runner -->|"grants"| R_Runner
    RB_UI -->|"grants"| R_UI
    RB_Viewer -->|"grants"| R_Viewer
    RB_MetaWriter -->|"grants"| R_MetaWriter
    RB_Cache -->|"grants"| R_Cache

    %% ClusterRoleBinding → ClusterRole
    CRB_CacheDeploy -->|"grants"| CR_CacheDeploy

    %% ClusterRole → Resources
    CR_CacheDeploy -->|"access"| CertCSR
    CR_CacheDeploy -->|"access"| CertApproval
    CR_CacheDeploy -->|"access"| WebhookConfig
    CR_CacheDeploy -->|"access"| CertSigners

