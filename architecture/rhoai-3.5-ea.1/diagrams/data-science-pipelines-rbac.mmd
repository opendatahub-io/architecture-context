    style SA_Cache fill:#4a90e2,stroke:#333,color:#fff
    style SA_CacheDeploy fill:#4a90e2,stroke:#333,color:#fff

    style R_Pipeline fill:#f5a623,stroke:#333,color:#fff
    style R_PA fill:#f5a623,stroke:#333,color:#fff
    style R_SWC fill:#f5a623,stroke:#333,color:#fff
