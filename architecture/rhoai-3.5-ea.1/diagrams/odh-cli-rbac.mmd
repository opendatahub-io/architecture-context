graph TD
    subgraph AuthN["Authentication (kubeconfig)"]
        User["Cluster Admin<br/>(kubeconfig credentials)"]
        Token["Bearer Token /<br/>Client Certificate /<br/>OIDC"]
        User -->|"authenticates via"| Token
    end

    subgraph Note["Note: No ClusterRoles Installed"]
        direction LR
        Info["CLI uses authenticated user's<br/>existing RBAC permissions.<br/>Below shows MINIMUM required."]
    end

    Token -->|"identity"| RBAC

    subgraph RBAC["Required RBAC Permissions (user-provided)"]
        direction TB

        subgraph ReadOnly["READ-ONLY Access (get, list)"]
            direction TB

            subgraph PlatformCRDs["ODH Platform CRDs"]
                DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters"]
                DSCI["dscinitialization.opendatahub.io<br/>dscinitializations"]
                CompCRs["components.platform.opendatahub.io<br/>* (all component CRs)"]
            end

            subgraph WorkloadCRDs["ML Workload CRDs"]
                Notebooks["kubeflow.org<br/>notebooks, pytorchjobs"]
                KServe["serving.kserve.io<br/>inferenceservices,<br/>servingruntimes,<br/>llminferenceservices"]
                Ray["ray.io<br/>rayclusters, rayjobs"]
                DSPA["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapps"]
                Guardrails["trustyai.opendatahub.io<br/>guardrailsorchestrators"]
                LlamaStack["llamastack.io<br/>llamastackdistributions"]
            end

            subgraph InfraCRDs["Infrastructure CRDs"]
                HWProfile["infrastructure.opendatahub.io<br/>hardwareprofiles"]
                AccProfile["dashboard.opendatahub.io<br/>acceleratorprofiles,<br/>hardwareprofiles"]
                Kuadrant["kuadrant.io<br/>kuadrants"]
                Authorino["operator.authorino.kuadrant.io<br/>authorinos"]
                Kueue["kueue.x-k8s.io<br/>clusterqueues, localqueues"]
                AppWrapper["workload.codeflare.dev<br/>appwrappers"]
            end

            subgraph OLMResources["OLM Resources"]
                Subs["operators.coreos.com<br/>subscriptions, csvs,<br/>installplans"]
                PkgManifest["packages.operators.coreos.com<br/>packagemanifests"]
            end

            subgraph OpenShiftAPIs["OpenShift APIs"]
                ClusterVer["config.openshift.io<br/>clusterversions"]
                ImageStream["image.openshift.io<br/>imagestreams,<br/>imagestreamtags"]
                CRDDefs["apiextensions.k8s.io<br/>customresourcedefinitions"]
            end

            subgraph CoreAPIs["Core & Apps APIs"]
                Core["core (v1)<br/>namespaces, pods, pods/log,<br/>configmaps, secrets, pvcs,<br/>services, events, nodes"]
                AppsAPI["apps<br/>deployments, statefulsets,<br/>replicasets, daemonsets"]
                BatchAPI["batch<br/>jobs, cronjobs"]
            end
        end

        subgraph WriteAccess["WRITE Access (deps install ONLY)"]
            direction TB
            CreateNS["core (v1)<br/>namespaces<br/>Verbs: create"]
            CreateOLM["operators.coreos.com<br/>subscriptions, operatorgroups<br/>Verbs: get, list, create"]
        end
    end

    subgraph SecurityControls["Security Controls on Write Operations"]
        CatalogAL["Catalog Source Allowlist:<br/>• redhat-operators<br/>• community-operators<br/>• certified-operators<br/>• redhat-marketplace"]
        NSReject["Namespace Rejection:<br/>• kube-* (rejected)<br/>• openshift-* (rejected)"]
        ExitCodes["Permission Error Handling:<br/>401/403 → Exit Code 4 (AUTH)<br/>with actionable suggestions"]
    end

    WriteAccess -->|"validated by"| SecurityControls

