graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway / Istio<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ termination<br/>AuthN: kube-rbac-proxy / Gateway API<br/>Host: {isvc}.{ns}.{domain}"]
    end

    subgraph PodBoundary["POD BOUNDARY (InferenceService Pod)"]
        direction TB

        QueueProxy["Queue Proxy (sidecar)<br/>Request routing &amp; concurrency"]

        subgraph MainContainer["Main Container"]
            AutogluonServer["autogluonserver<br/>REST: 8080/TCP (FastAPI)<br/>gRPC: 8081/TCP (grpcio)<br/>Image: UBI base (non-root)<br/>No app-level TLS/auth"]
        end

        subgraph InitContainer["Init Container (runs first)"]
            StorageInit["Storage Initializer<br/>Downloads to /mnt/models"]
        end

        MountModels["/mnt/models<br/>(shared volume)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP service account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure credentials"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF token (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / mTLS"| Gateway
    Gateway -->|"HTTP/8080<br/>mTLS (Istio) or pod-internal"| QueueProxy
    QueueProxy -->|"HTTP/8080<br/>localhost (no TLS)<br/>No auth"| AutogluonServer

    StorageInit -->|"writes"| MountModels
    MountModels -->|"reads (model artifacts)"| AutogluonServer

    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage credentials (Secret)"| S3
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA (Secret)"| GCS
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure creds (Secret)"| Azure
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>HF token"| HF

    Prometheus -->|"HTTP/8080<br/>No auth<br/>/metrics"| AutogluonServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef volume fill:#f5f5f5,stroke:#666,stroke-width:1px

    class Client external
    class Gateway ingress
    class QueueProxy,AutogluonServer,StorageInit pod
    class S3,GCS,Azure,HF externalservice
    class Prometheus monitoring
    class MountModels volume
