graph TB
    subgraph "llama-stack-provider-ragas"
        direction TB

        subgraph InlineProvider["Inline Provider (inline::trustyai_ragas)"]
            RagasInlineEval[RagasEvaluatorInline<br/>ragas_inline_eval.py]
            InlineLLM[LlamaStackInlineLLM<br/>wrappers_inline.py]
            InlineEmbed[LlamaStackInlineEmbeddings<br/>wrappers_inline.py]
            RagasInlineEval -->|wraps LLM| InlineLLM
            RagasInlineEval -->|wraps embeddings| InlineEmbed
        end

        subgraph RemoteProvider["Remote Provider (remote::trustyai_ragas)"]
            RagasRemoteEval[RagasEvaluatorRemote<br/>ragas_remote_eval.py]
            RemoteLLM[LlamaStackRemoteLLM<br/>wrappers_remote.py]
            RemoteEmbed[LlamaStackRemoteEmbeddings<br/>wrappers_remote.py]
            KFPPipeline[KFP Pipeline Builder<br/>pipeline.py]
            KFPComponents[KFP Components<br/>components.py]
            RagasRemoteEval -->|builds pipeline| KFPPipeline
            KFPPipeline -->|uses| KFPComponents
            KFPComponents -->|wraps LLM| RemoteLLM
            KFPComponents -->|wraps embeddings| RemoteEmbed
        end

        subgraph SharedCore["Shared Core"]
            Config[RagasConfig / KubeflowConfig<br/>config.py]
            Compat[Compatibility Layer<br/>compat.py]
            ProviderSpec[Provider Spec Registry<br/>provider.py]
        end

        RagasInlineEval -->|reads config| Config
        RagasRemoteEval -->|reads config| Config
        InlineProvider -->|registered via| ProviderSpec
        RemoteProvider -->|registered via| ProviderSpec
        Compat -->|import fallback| InlineProvider
        Compat -->|import fallback| RemoteProvider
    end

    User[User / Client] -->|POST /alpha/eval/run_eval| LlamaStackServer
    LlamaStackServer[Llama Stack Server<br/>Port 8321/TCP] -->|delegates eval| RagasInlineEval
    LlamaStackServer -->|delegates eval| RagasRemoteEval

    InlineLLM -->|in-process API call| LlamaStackInference[Llama Stack Inference API]
    InlineEmbed -->|in-process API call| LlamaStackInference

    RagasRemoteEval -->|submit pipeline| KFP[Kubeflow Pipelines API<br/>443/TCP HTTPS]
    KFPComponents -->|HTTP calls| LlamaStackServer
    KFPComponents -->|store results| S3[S3 Object Storage<br/>443/TCP HTTPS]
    RagasRemoteEval -->|fetch results| S3

    LlamaStackInference -->|inference| InferenceBackend[Ollama / vLLM<br/>11434/TCP HTTP]

    RagasRemoteEval -->|read ConfigMap| TrustyAIOp[TrustyAI Operator ConfigMap<br/>Base Image Resolution]

    style RagasInlineEval fill:#4a90e2,color:#fff
    style RagasRemoteEval fill:#4a90e2,color:#fff
    style InlineLLM fill:#5ba3f5,color:#fff
    style InlineEmbed fill:#5ba3f5,color:#fff
    style RemoteLLM fill:#5ba3f5,color:#fff
    style RemoteEmbed fill:#5ba3f5,color:#fff
    style KFPPipeline fill:#5ba3f5,color:#fff
    style KFPComponents fill:#5ba3f5,color:#fff
    style Config fill:#9b59b6,color:#fff
    style Compat fill:#9b59b6,color:#fff
    style ProviderSpec fill:#9b59b6,color:#fff
    style LlamaStackServer fill:#f5a623,color:#fff
    style LlamaStackInference fill:#f5a623,color:#fff
    style KFP fill:#999,color:#fff
    style S3 fill:#999,color:#fff
    style InferenceBackend fill:#999,color:#fff
    style TrustyAIOp fill:#7ed321,color:#fff
    style User fill:#e8e8e8,stroke:#333
