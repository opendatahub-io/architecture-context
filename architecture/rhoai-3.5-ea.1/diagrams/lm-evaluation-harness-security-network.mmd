graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        Operator["TrustyAI LMEval Operator<br/>Creates Job Pods<br/>Mounts: job.json, secrets, PVC"]
    end

    subgraph JobPod["JOB POD (Ephemeral Batch)<br/>User: 65532:65532 (non-root)<br/>No privilege escalation"]
        direction TB

        subgraph AdapterLayer["LMEval Adapter (main.py)"]
            Adapter["EvalHub FrameworkAdapter<br/>Path traversal protection<br/>Symlink rejection<br/>Credential sanitization"]
        end

        subgraph EvalEngine["lm_eval Library"]
            LMEval["Evaluation Engine<br/>local-completions backend<br/>num_concurrent <= 128<br/>hashlib.sha256 (FIPS)"]
        end

        subgraph Volumes["Mounted Volumes"]
            JobSpecVol["/meta/job.json<br/>(ConfigMap)"]
            TestDataVol["/test_data<br/>(PVC - optional)"]
            SecretVol["Model Auth Secret<br/>(projected)"]
        end

        Adapter --> LMEval
        JobSpecVol -->|"confined read"| Adapter
        TestDataVol -.->|"offline auto-detect"| Adapter
        SecretVol -->|"credentials"| Adapter
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelEP["Model Inference Endpoint<br/>(vLLM / TGI / OpenAI)<br/>Configurable port<br/>TLS: configurable + custom CA<br/>Auth: OPENAI_API_KEY Bearer"]
        EvalHubSvc["EvalHub Service<br/>443/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token"]
        OCIReg["OCI Registry (Quay)<br/>443/TCP HTTPS<br/>TLS<br/>Auth: Registry creds"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN (optional)"]
        MLflowSvc["MLflow Tracking Server<br/>Configurable port<br/>Auth: via evalhub SDK"]
        S3Svc["S3 Storage<br/>443/TCP HTTPS<br/>TLS<br/>Auth: AWS IAM / HMAC"]
    end

    %% Control plane flow
    Operator -->|"Pod creation<br/>Kubernetes API<br/>ServiceAccount"| JobPod

    %% Egress flows
    LMEval -->|"POST /v1/completions<br/>HTTP(S) configurable<br/>TLS + custom CA<br/>OPENAI_API_KEY"| ModelEP
    Adapter -->|"POST callbacks<br/>HTTPS/443<br/>TLS<br/>Bearer Token"| EvalHubSvc
    Adapter -->|"Push artifacts<br/>HTTPS/443 via skopeo<br/>TLS<br/>Registry creds"| OCIReg
    LMEval -->|"GET tokenizers/datasets<br/>HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    Adapter -->|"Log metrics<br/>HTTP(S)<br/>via evalhub SDK"| MLflowSvc
    LMEval -.->|"GET data<br/>HTTPS/443<br/>AWS IAM"| S3Svc

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef jobpod fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef adapter fill:#4a90e2,stroke:#333,color:#fff
    classDef engine fill:#4a90e2,stroke:#333,color:#fff
    classDef volume fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px

    class Operator controlplane
    class Adapter adapter
    class LMEval engine
    class JobSpecVol,TestDataVol,SecretVol volume
    class ModelEP,EvalHubSvc,OCIReg,HFHub,MLflowSvc,S3Svc external
