graph TB
    subgraph EPP_Component["Endpoint Picker (EPP)"]
        direction TB
        ExtProc["gRPC ext-proc Server<br/>9002/TCP"]
        HealthGRPC["gRPC Health Check<br/>9003/TCP"]
        Metrics["Prometheus Metrics<br/>9090/TCP"]
        ZMQSub["ZMQ Subscriber<br/>5557/TCP"]

        subgraph Plugins["Plugin System (21+ plugins)"]
            direction LR
            Filters["Filters<br/>by-label, by-label-selector,<br/>roles"]
            Scorers["Scorers<br/>precise-prefix-cache,<br/>active-request, load-aware,<br/>session-affinity, no-hit-lru"]
            ProfileHandlers["Profile Handlers<br/>disagg-profile-handler,<br/>pd-profile-handler,<br/>dp-profile-handler"]
            Deciders["Deciders<br/>prefix-based-pd,<br/>always-disagg-pd,<br/>always-disagg-mm"]
            PrepareData["PrepareData<br/>tokenizer"]
            DataLayer["DataLayer<br/>models-extractor"]
        end

        KVIndex["KV-Cache Index<br/>(in-memory)"]

        ExtProc --> Plugins
        ZMQSub --> KVIndex
        KVIndex --> Scorers
    end

    subgraph Sidecar_Component["P/D Routing Sidecar (pd-sidecar)"]
        direction TB
        ProxyServer["HTTP/HTTPS Proxy<br/>8000/TCP"]
        HealthHTTP["/health endpoint"]

        subgraph Connectors["KV Transfer Connectors"]
            direction LR
            NIXLv2["NIXL v2<br/>(default)"]
            SharedStorage["Shared Storage"]
            SGLang["SGLang"]
            EPDConnector["EPD<br/>(multimodal)"]
        end

        SSRFProtection["SSRF Protection<br/>(InferencePool allowlist)"]
        DPHandler["Data Parallel<br/>Handler"]

        ProxyServer --> Connectors
        ProxyServer --> SSRFProtection
        ProxyServer --> DPHandler
    end

    UDSTokenizer["UDS Tokenizer<br/>gRPC over Unix Socket"]

    %% External interactions
    Client[Client] -->|HTTP/80| Gateway["Envoy Gateway<br/>(Gateway API)"]
    Gateway -->|gRPC ext-proc<br/>9002/TCP| ExtProc
    ExtProc -->|routing decision<br/>with headers| Gateway
    Gateway -->|HTTP/HTTPS<br/>8000/TCP| ProxyServer

    %% CRD interactions
    InferencePoolCR["InferencePool CR<br/>inference.networking.k8s.io/v1"] -->|watched by| ExtProc
    InferencePoolCR -->|watched by| SSRFProtection

    %% EPP dependencies
    ExtProc -->|tokenize prompts| UDSTokenizer
    ZMQSub -->|subscribe KV events<br/>ZMQ 5555-5557/TCP| vLLM_Pods["vLLM Model Servers"]

    %% Sidecar dependencies
    ProxyServer -->|decode<br/>8001/TCP| DecoderLocal["vLLM Decoder<br/>(local)"]
    ProxyServer -->|prefill<br/>configurable| PrefillerRemote["vLLM Prefiller<br/>(remote)"]
    ProxyServer -->|encode<br/>configurable| EncoderRemote["vLLM Encoder<br/>(remote)"]

    %% K8s API
    ExtProc -->|watch pods/pools<br/>443/TCP HTTPS| K8sAPI["Kubernetes API Server"]
    SSRFProtection -->|watch pods/pools<br/>443/TCP HTTPS| K8sAPI

    %% Observability
    ExtProc -->|traces<br/>4317/TCP gRPC| OTLP["OTLP Collector"]
    ProxyServer -->|traces<br/>4317/TCP gRPC| OTLP
    Metrics -->|scrape| Prometheus["Prometheus"]

    %% Styling
    style ExtProc fill:#4a90e2,color:#fff
    style HealthGRPC fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style ZMQSub fill:#4a90e2,color:#fff
    style ProxyServer fill:#4a90e2,color:#fff
    style HealthHTTP fill:#4a90e2,color:#fff
    style InferencePoolCR fill:#f5a623,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style UDSTokenizer fill:#7ed321,color:#fff
    style vLLM_Pods fill:#7ed321,color:#fff
    style DecoderLocal fill:#7ed321,color:#fff
    style PrefillerRemote fill:#7ed321,color:#fff
    style EncoderRemote fill:#7ed321,color:#fff
    style OTLP fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
