graph TD
    subgraph "vLLM CPU - Authentication & Authorization Model"
        direction TB

        subgraph "Note"
            NoRBAC["No Kubernetes RBAC Resources<br/>vLLM CPU is a container image, not an operator<br/>RBAC is managed by KServe at the InferenceService level"]
        end

        subgraph "Container Security Context"
            PodSecurity["Pod Security<br/>User: 2000 (non-root)<br/>Group: 0<br/>OpenShift arbitrary UID model"]
        end

        subgraph "Application-Level Authentication"
            direction TB

            AuthMW["AuthenticationMiddleware<br/>(FastAPI)"]

            subgraph "Protected Endpoints (Auth if VLLM_API_KEY set)"
                ChatCompletions["/v1/chat/completions<br/>POST"]
                Completions["/v1/completions<br/>POST"]
                Embeddings["/v1/embeddings<br/>POST"]
                Models["/v1/models<br/>GET"]
                Responses["/v1/responses<br/>POST"]
                Tokenize["/v1/tokenize<br/>POST"]
                Messages["/v1/messages<br/>POST"]
                LoRA["/v1/load_lora_adapter<br/>/v1/unload_lora_adapter<br/>POST"]
            end

            subgraph "Unprotected Endpoints (No Auth)"
                Health["/health<br/>GET"]
                Metrics["/metrics<br/>GET"]
                Version["/version<br/>GET"]
                Load["/load<br/>GET"]
                ServerInfo["/server_info<br/>GET"]
                Profile["/start_profile<br/>/stop_profile<br/>POST"]
            end

            AuthMW -->|"validates Bearer Token<br/>against --api-key<br/>or VLLM_API_KEY env"| ChatCompletions
            AuthMW -->|"validates"| Completions
            AuthMW -->|"validates"| Embeddings
            AuthMW -->|"validates"| Models
            AuthMW -->|"validates"| Responses
            AuthMW -->|"validates"| Tokenize
            AuthMW -->|"validates"| Messages
            AuthMW -->|"validates"| LoRA
        end

        subgraph "Secrets"
            HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: Manual/KServe<br/>Rotate: No"]
            SSLCert["SSL key/cert<br/>Type: kubernetes.io/tls<br/>Purpose: TLS encryption (optional)<br/>Provisioned: cert-manager/Manual<br/>Rotate: Yes (SSLCertRefresher)"]
            APIKey["VLLM_API_KEY<br/>Type: Opaque (env var)<br/>Purpose: API auth token<br/>Provisioned: Manual/KServe<br/>Rotate: No"]
        end
    end

    subgraph "KServe-Managed RBAC (External)"
        KServeRBAC["KServe manages:<br/>- ServiceAccount per InferenceService<br/>- RoleBindings for pod scheduling<br/>- NetworkPolicies (if configured)<br/>- Ingress/Route authentication"]
    end

    KServeRBAC -.->|"manages pod identity<br/>and network access"| PodSecurity

    %% Styling
    style NoRBAC fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style PodSecurity fill:#d4edda,stroke:#155724,stroke-width:2px
    style AuthMW fill:#4a90e2,stroke:#333,color:#fff
    style KServeRBAC fill:#7ed321,stroke:#333,color:#fff

    style ChatCompletions fill:#cce5ff,stroke:#004085
    style Completions fill:#cce5ff,stroke:#004085
    style Embeddings fill:#cce5ff,stroke:#004085
    style Models fill:#cce5ff,stroke:#004085
    style Responses fill:#cce5ff,stroke:#004085
    style Tokenize fill:#cce5ff,stroke:#004085
    style Messages fill:#cce5ff,stroke:#004085
    style LoRA fill:#cce5ff,stroke:#004085

    style Health fill:#d4edda,stroke:#155724
    style Metrics fill:#d4edda,stroke:#155724
    style Version fill:#d4edda,stroke:#155724
    style Load fill:#d4edda,stroke:#155724
    style ServerInfo fill:#d4edda,stroke:#155724
    style Profile fill:#d4edda,stroke:#155724

    style HFToken fill:#f8d7da,stroke:#721c24
    style SSLCert fill:#f8d7da,stroke:#721c24
    style APIKey fill:#f8d7da,stroke:#721c24
