graph TB
    subgraph UserLayer["User Layer"]
        UserScript["User Script / Notebook"]
    end

    subgraph TrainingHub["training-hub SDK"]
        direction TB

        subgraph PublicAPI["Public API (top-level functions)"]
            sft["sft()"]
            osft["osft()"]
            lora_sft["lora_sft()"]
            lora_grpo["lora_grpo()"]
            grpo["grpo()"]
        end

        subgraph CoreEngine["Core Engine"]
            Registry["AlgorithmRegistry<br/>Strategy Pattern"]
            Factory["create_algorithm()<br/>Factory Function"]
            ParamTranslation["Parameter Translation<br/>Layer"]
        end

        subgraph Algorithms["Algorithms"]
            SFTAlgo["SFT Algorithm<br/>Full-parameter supervised fine-tuning"]
            OSFTAlgo["OSFT Algorithm<br/>Orthogonal Subspace Fine-Tuning"]
            LoRASFTAlgo["LoRA SFT Algorithm<br/>Parameter-efficient fine-tuning"]
            LoRAGRPOAlgo["LoRA GRPO Algorithm<br/>RL from verifiable rewards"]
            FullGRPOAlgo["Full GRPO Algorithm<br/>Full-parameter GRPO"]
        end

        subgraph Backends["Backend Implementations"]
            ILabBackend["instructlab-training<br/>Backend"]
            MiniTrainerBackend["mini-trainer<br/>Backend"]
            UnslothBackend["Unsloth<br/>Backend"]
            ARTBackend["ART Backend<br/>(single-GPU subprocess)"]
            VerlBackend["verl Backend<br/>(multi-GPU FSDP)"]
        end

        subgraph Utilities["Utilities"]
            MemoryEst["Memory Estimator<br/>VRAM calculators per algorithm"]
            TimingEst["Timing Estimator<br/>Sample-based extrapolation"]
            Viz["Visualization<br/>Loss curves + EMA smoothing"]
            TorchrunUtils["torchrun Params<br/>Distributed orchestration"]
        end

        subgraph Validation["Validation"]
            ModelValidation["Model Validation Harness<br/>14+ architectures"]
        end
    end

    %% User to API
    UserScript -->|"function call"| sft
    UserScript -->|"function call"| osft
    UserScript -->|"function call"| lora_sft
    UserScript -->|"function call"| lora_grpo
    UserScript -->|"function call"| grpo

    %% API to Core
    sft --> Factory
    osft --> Factory
    lora_sft --> Factory
    lora_grpo --> Factory
    grpo --> Factory
    Factory -->|"lookup"| Registry
    Registry -->|"resolve"| ParamTranslation

    %% Core to Algorithms
    ParamTranslation --> SFTAlgo
    ParamTranslation --> OSFTAlgo
    ParamTranslation --> LoRASFTAlgo
    ParamTranslation --> LoRAGRPOAlgo
    ParamTranslation --> FullGRPOAlgo

    %% Algorithms to Backends
    SFTAlgo -->|"delegates to"| ILabBackend
    OSFTAlgo -->|"delegates to"| MiniTrainerBackend
    LoRASFTAlgo -->|"delegates to"| UnslothBackend
    LoRAGRPOAlgo -->|"delegates to"| ARTBackend
    LoRAGRPOAlgo -->|"delegates to"| VerlBackend
    FullGRPOAlgo -->|"delegates to"| VerlBackend

    %% Utilities connections
    MemoryEst -.->|"estimate VRAM"| SFTAlgo
    MemoryEst -.->|"estimate VRAM"| OSFTAlgo
    MemoryEst -.->|"estimate VRAM"| LoRASFTAlgo
    TorchrunUtils -.->|"distributed params"| ILabBackend
    TorchrunUtils -.->|"distributed params"| VerlBackend

    %% Styling
    classDef api fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef algo fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef backend fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef utility fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef user fill:#e8e8e8,stroke:#333,stroke-width:2px

    class sft,osft,lora_sft,lora_grpo,grpo api
    class SFTAlgo,OSFTAlgo,LoRASFTAlgo,LoRAGRPOAlgo,FullGRPOAlgo algo
    class ILabBackend,MiniTrainerBackend,UnslothBackend,ARTBackend,VerlBackend backend
    class MemoryEst,TimingEst,Viz,TorchrunUtils,ModelValidation utility
    class UserScript user
    class Registry,Factory,ParamTranslation api
