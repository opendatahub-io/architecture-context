graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% Generation Backend Dependencies
    Orch -->|"gRPC 8033/TCP<br/>Generate, GenerateStream,<br/>Tokenize, ModelInfo"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    Orch -->|"gRPC 8085/TCP<br/>TextGenerationTaskPredict,<br/>TokenizationTaskPredict"| CaikitNLP["caikit-NLP<br/>Server"]
    Orch -->|"HTTP 8080/TCP<br/>/v1/chat/completions,<br/>/v1/completions, /tokenize"| OpenAI["OpenAI-compatible<br/>Server (vLLM)"]

    %% Safety Service Dependencies
    Orch -->|"HTTP 8080/TCP<br/>/api/v1/text/contents,<br/>/chat, /context/doc,<br/>/generation"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orch -->|"gRPC 8085/TCP<br/>ChunkerTokenizationTaskPredict,<br/>BidiStreaming"| Chunkers["Chunker Services<br/>(caikit)"]

    %% Observability
    Orch -->|"OTLP 4317/4318 TCP<br/>traces + metrics"| OTEL["OpenTelemetry<br/>Collector"]

    %% Health checks (dashed)
    Orch -.->|"gRPC Health.Check"| TGIS
    Orch -.->|"gRPC Health.Check"| CaikitNLP
    Orch -.->|"GET /health"| OpenAI
    Orch -.->|"GET /health"| Detectors
    Orch -.->|"gRPC Health.Check"| Chunkers

    %% Rust Runtime Dependencies (subgraph)
    subgraph RuntimeDeps["Rust Runtime Stack"]
        direction TB
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Hyper["hyper 1.8.1<br/>(HTTP server)"]
        OtelSDK["opentelemetry 0.31.0<br/>(observability)"]
        Ginepro["ginepro<br/>(gRPC load balancing)"]
    end

    Orch -->|"built on"| RuntimeDeps

    %% Styling
    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#999,stroke:#333,color:#fff
    style CaikitNLP fill:#999,stroke:#333,color:#fff
    style OpenAI fill:#999,stroke:#333,color:#fff
    style Detectors fill:#f5a623,stroke:#333
    style Chunkers fill:#f5a623,stroke:#333
    style OTEL fill:#7ed321,stroke:#333
    style RuntimeDeps fill:#e8e8e8,stroke:#999
    style Tokio fill:#ddd,stroke:#999
    style Axum fill:#ddd,stroke:#999
    style Tonic fill:#ddd,stroke:#999
    style Rustls fill:#ddd,stroke:#999
    style Reqwest fill:#ddd,stroke:#999
    style Hyper fill:#ddd,stroke:#999
    style OtelSDK fill:#ddd,stroke:#999
    style Ginepro fill:#ddd,stroke:#999
