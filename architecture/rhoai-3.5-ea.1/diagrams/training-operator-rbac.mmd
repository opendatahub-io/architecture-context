graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>Namespace: opendatahub"]
        MPILauncherSA["{mpijob}-launcher<br/>Namespace: user-ns<br/>(per-job, auto-created)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        WebhookRB["training-operator-webhook<br/>(RoleBinding)<br/>Namespace: opendatahub"]
        MPIRoleBinding["{mpijob}-launcher<br/>(RoleBinding)<br/>Namespace: user-ns"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["training-operator<br/>(ClusterRole)"]
        CREdit["training-edit<br/>(aggregated to k8s edit)"]
        CRView["training-view<br/>(aggregated to k8s view)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        WebhookRole["training-operator-webhook<br/>(Role)"]
        MPIRole["{mpijob}-launcher<br/>(Role)"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        Pods["pods<br/>create, delete, get,<br/>list, patch, update, watch"]
        PodsExec["pods/exec<br/>create"]
        Services["services<br/>create, delete, get,<br/>list, watch"]
        ServiceAccounts["serviceaccounts<br/>create, get, list, watch"]
        ConfigMaps["configmaps<br/>create, list, update, watch"]
        Events["events<br/>create, delete, get,<br/>list, patch, update, watch"]
        Secrets["secrets<br/>(webhook role only)<br/>create, get, list,<br/>update, watch"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        PyTorchJobs["pytorchjobs<br/>+ /status + /finalizers"]
        TFJobs["tfjobs<br/>+ /status + /finalizers"]
        MPIJobs["mpijobs<br/>+ /status + /finalizers"]
        XGBoostJobs["xgboostjobs<br/>+ /status + /finalizers"]
        PaddleJobs["paddlejobs<br/>+ /status + /finalizers"]
        JAXJobs["jaxjobs<br/>+ /status + /finalizers"]
    end

    subgraph OtherResources["Other API Resources"]
        HPAs["autoscaling<br/>horizontalpodautoscalers"]
        RolesRes["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        SchedulerPG["scheduling.x-k8s.io<br/>podgroups"]
        NetPolicies["networking.k8s.io<br/>networkpolicies"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    SA -->|"bound via"| WebhookRB
    WebhookRB -->|"grants"| WebhookRole
    MPILauncherSA -->|"bound via"| MPIRoleBinding
    MPIRoleBinding -->|"grants"| MPIRole

    %% ClusterRole → Resources
    CR -->|"full CRUD"| Pods
    CR -->|"create"| PodsExec
    CR -->|"manage"| Services
    CR -->|"manage"| ServiceAccounts
    CR -->|"manage"| ConfigMaps
    CR -->|"full CRUD"| Events
    CR -->|"full CRUD"| PyTorchJobs
    CR -->|"full CRUD"| TFJobs
    CR -->|"full CRUD"| MPIJobs
    CR -->|"full CRUD"| XGBoostJobs
    CR -->|"full CRUD"| PaddleJobs
    CR -->|"full CRUD"| JAXJobs
    CR -->|"full CRUD"| HPAs
    CR -->|"manage"| RolesRes
    CR -->|"get, list,<br/>update, watch"| Webhooks
    CR -->|"full CRUD"| VolcanoPG
    CR -->|"full CRUD"| SchedulerPG
    CR -->|"full CRUD"| NetPolicies

    %% Webhook Role
    WebhookRole -->|"manage"| Secrets

    %% MPI Role
    MPIRole -->|"create"| PodsExec

    %% Aggregated roles
    CREdit -->|"full CRUD<br/>(all 6 job types)"| KubeflowResources
    CRView -->|"get, list, watch<br/>(all 6 job types)"| KubeflowResources

