graph LR
    ODH["ODH Dashboard<br/>(odh-dashboard)"]

    %% External Infrastructure Dependencies
    ODH -->|"runtime"| NodeJS["Node.js 22+"]
    ODH -->|"frontend"| React["React 18.2"]
    ODH -->|"UI library"| PF["PatternFly 6.4"]
    ODH -->|"backend framework"| Fastify["Fastify 4.28"]
    ODH -->|"module federation"| MF["@module-federation/runtime<br/>0.15.0"]
    ODH -->|"BFF language"| Go["Go 1.24-1.25"]

    %% Kubernetes Platform
    ODH -->|"K8s API CRUD<br/>6443/TCP"| K8sAPI["Kubernetes API Server"]
    ODH -->|"operator status<br/>CRD watch"| OLM["OLM<br/>(Subscriptions, CSVs)"]
    ODH -->|"workload scheduling<br/>CRD watch"| Kueue["Kueue"]

    %% RHOAI Platform Components (CRD Watch)
    ODH -->|"platform config<br/>CRD watch"| Operator["RHOAI Operator<br/>(DSC, DSCI)"]
    ODH -->|"model serving<br/>CRD watch"| KServe["KServe<br/>(InferenceService,<br/>ServingRuntime)"]
    ODH -->|"notebook mgmt<br/>CRD CRUD"| NotebookCtrl["Kubeflow Notebook<br/>Controller"]
    ODH -->|"registry mgmt<br/>CRD watch + REST proxy"| ModelReg["Model Registry<br/>Operator + Service"]
    ODH -->|"fairness/guardrails<br/>CRD watch + REST proxy"| TrustyAI["TrustyAI<br/>(Service, EvalHub,<br/>GuardrailsOrchestrator)"]
    ODH -->|"feature store<br/>CRD watch + REST proxy"| Feast["Feast Operator"]
    ODH -->|"experiment tracking<br/>CRD watch + REST proxy"| MLflow["MLflow Operator"]
    ODH -->|"MCP servers<br/>CRD watch"| OGX["OGX Operator<br/>(OGXServer)"]
    ODH -->|"NIM integration<br/>CRD watch"| NIM["NVIDIA NIM"]

    %% RHOAI Platform Components (REST API Proxy)
    ODH -->|"pipeline proxy<br/>HTTPS/8443"| Pipelines["DS Pipelines API"]
    ODH -->|"LLM proxy<br/>HTTP/8321"| LlamaStack["Llama Stack"]
    ODH -->|"observability proxy<br/>HTTP/8080"| Perses["Perses"]

    %% Monitoring
    ODH -->|"metrics query<br/>HTTPS/9092"| Thanos["Thanos Querier"]

    %% Ingress
    GW["Gateway API<br/>(data-science-gateway)"] -->|"HTTPRoute<br/>443 → 8443"| ODH

    %% Auth
    KRBAC["kube-rbac-proxy<br/>(odh-kube-auth-proxy)"] -->|"auth sidecar<br/>8443 → 8080"| ODH

    %% Integration consumers
    Console["OpenShift Console"] -.->|"consolelink"| ODH

