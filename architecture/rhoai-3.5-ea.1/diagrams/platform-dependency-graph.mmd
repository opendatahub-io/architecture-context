graph TB
    subgraph CorePlatform["Core Platform Services"]
        direction TB
        Istio["Istio / Sail<br/>Service Mesh + Gateway API"]
        Knative["Knative Serving<br/>Serverless (optional)"]
        Kueue["Kueue<br/>Resource Quota Management"]
        KRBP["kube-rbac-proxy<br/>Auth Sidecar"]
    end

    subgraph Operator["Platform Operator"]
        RhodsOp["rhods-operator<br/>Platform Root<br/>14+ components managed"]
    end

    subgraph Serving["Model Serving"]
        KServe["KServe<br/>InferenceService +<br/>LLMInferenceService"]
        ODHModelCtrl["odh-model-controller<br/>NetworkPolicy, Monitoring,<br/>Gateway Discovery"]
        LLMD["llm-d Stack<br/>vLLM + EPP + Routing"]
        WVA["WVA<br/>Autoscaler"]
        AIGW["ai-gateway-payload-processing<br/>ext-proc Plugins"]
        BatchGW["batch-gateway<br/>Batch Inference API"]
        MaaS["MaaS<br/>Models-as-a-Service"]
    end

    subgraph Dashboard["User Interface"]
        ODHDash["odh-dashboard<br/>7 Federated BFF Plugins<br/>Primary Entry Point"]
    end

    subgraph Training["Training & Development"]
        Notebooks["Kubeflow Notebook<br/>Controllers"]
        TrainerV2["Kubeflow Trainer v2<br/>TrainJob + JobSet"]
        TrainerV1["Training Operator v1<br/>PyTorchJob, MPIJob"]
        CodeFlare["CodeFlare SDK<br/>Ray Integration"]
        KubeRay["KubeRay Operator<br/>Ray Clusters"]
        Spark["Spark Operator"]
        TrainingHub["training-hub<br/>SDK Library"]
    end

    subgraph DataPipelines["Data Pipelines"]
        DSP["Data Science Pipelines<br/>KFP v2 + Argo"]
        Argo["Argo Workflows<br/>Pipeline DAG Execution"]
    end

    subgraph ModelMgmt["Model Management"]
        ModelReg["Model Registry<br/>Metadata + Catalog"]
        ModelRegOp["Model Registry Operator"]
        MLflow["MLflow Operator<br/>Experiment Tracking"]
    end

    subgraph Evaluation["Evaluation & Safety"]
        TrustyAI["TrustyAI Service Operator<br/>5 CRD Controllers"]
        EvalHub["EvalHub<br/>Evaluation Orchestration"]
        Guardrails["FMS Guardrails<br/>Orchestrator"]
        NeMo["NeMo Guardrails<br/>Content Safety"]
    end

    subgraph FeatureStore["Feature Store"]
        Feast["Feast<br/>Feature Server"]
    end

    subgraph NewPlatform["New Platform Services"]
        OGX["OGX Distribution<br/>(formerly LlamaStack)"]
    end

    %% rhods-operator deploys all components
    RhodsOp -->|deploys| KServe
    RhodsOp -->|deploys| ODHModelCtrl
    RhodsOp -->|deploys| ODHDash
    RhodsOp -->|deploys| DSP
    RhodsOp -->|deploys| Notebooks
    RhodsOp -->|deploys| TrainerV2
    RhodsOp -->|deploys| TrainerV1
    RhodsOp -->|deploys| KubeRay
    RhodsOp -->|deploys| Spark
    RhodsOp -->|deploys| ModelRegOp
    RhodsOp -->|deploys| MLflow
    RhodsOp -->|deploys| TrustyAI
    RhodsOp -->|deploys| Feast
    RhodsOp -->|deploys| OGX
    RhodsOp -->|deploys| WVA

    %% KServe integration hub
    ODHModelCtrl -->|InferenceService reconcile| KServe
    ModelReg -->|CRD sync| KServe
    TrustyAI -->|routing| KServe
    ODHDash -->|serving UI| KServe
    LLMD -->|LLMInferenceService| KServe
    WVA -->|autoscaling metrics| KServe
    AIGW -->|ext-proc routing| KServe
    BatchGW -->|batch inference| KServe
    MaaS -->|model access| KServe

    %% Dashboard integrations (17 outgoing deps)
    ODHDash -->|notebook mgmt| Notebooks
    ODHDash -->|model registry UI| ModelRegOp
    ODHDash -->|pipeline UI| DSP
    ODHDash -->|experiment tracking| MLflow
    ODHDash -->|evaluation UI| EvalHub
    ODHDash -->|feature store mgmt| Feast
    ODHDash -->|fairness/bias| TrustyAI

    %% kube-rbac-proxy usage
    KRBP -.->|auth sidecar| ODHDash
    KRBP -.->|auth sidecar| ModelRegOp
    KRBP -.->|auth sidecar| TrustyAI
    KRBP -.->|auth sidecar| OGX
    KRBP -.->|auth sidecar| EvalHub
    KRBP -.->|auth sidecar| Feast

    %% Pipeline dependencies
    DSP -->|DAG execution| Argo
    Argo -->|artifact I/O| DSP

    %% Training flow
    Notebooks -->|submit TrainJob| TrainerV2
    Notebooks -->|reads DSPA CR| DSP
    Notebooks -->|feature config| Feast
    Notebooks -->|RoleBindings| MLflow
    CodeFlare -->|Ray clusters| KubeRay

    %% Kueue transversal dependency
    Kueue -.->|quota mgmt| KubeRay
    Kueue -.->|quota mgmt| TrainerV2
    Kueue -.->|quota mgmt| EvalHub
    Kueue -.->|quota mgmt| Spark

    %% Evaluation flow
    EvalHub -->|eval results| MLflow
    TrustyAI -->|eval orchestration| EvalHub
    Guardrails -->|content safety| NeMo

    %% Ingress
    RhodsOp -->|gateway config| Istio

    %% Model Registry Operator manages Registry
    ModelRegOp -->|manages| ModelReg

