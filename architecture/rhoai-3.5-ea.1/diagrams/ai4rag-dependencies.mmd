graph LR
    AI4RAG["ai4rag<br/><i>RAG Optimization Engine</i><br/>Python Library"]

    %% External Dependencies (Python packages)
    AI4RAG -->|"document chunking<br/>vector store abstraction"| LangChain["langchain ~1.1.3"]
    AI4RAG -->|"ChromaDB integration"| LangChainChroma["langchain-chroma ~1.1.0"]
    AI4RAG -->|"text splitting strategies"| LangChainSplitters["langchain-text-splitters ~1.1.0"]
    AI4RAG -->|"OGX server SDK<br/>(chat, embed, vector)"| OGXClient["ogx-client ~1.0.0"]
    AI4RAG -->|"DataFrame ops<br/>benchmark data"| Pandas["pandas 2.2.*"]
    AI4RAG -->|"data validation<br/>model params"| Pydantic["pydantic 2.11.*"]
    AI4RAG -->|"GAM surrogate model<br/>for HPO"| PyGAM["pygam ~0.12.0"]
    AI4RAG -->|"label encoding<br/>categorical params"| ScikitLearn["scikit-learn 1.8.*"]
    AI4RAG -->|"RAG evaluation metrics"| Unitxt["unitxt ~1.26.1"]

    %% Internal Platform Dependencies
    AI4RAG -->|"chat completions<br/>HTTPS / API Key"| OGXServer["OGX Server<br/><i>Foundation Models</i>"]
    AI4RAG -->|"embeddings<br/>HTTPS / API Key"| OGXServerEmbed["OGX Server<br/><i>Embeddings</i>"]
    AI4RAG -->|"vector CRUD<br/>HTTPS / API Key"| OGXServerVec["OGX Server<br/><i>Vector Stores</i>"]
    AI4RAG -->|"in-memory vectors<br/>in-process Python"| ChromaDB["ChromaDB<br/><i>Local Vector DB</i>"]

    %% Platform consumers (reverse dependency)
    KFP["Kubeflow Pipelines<br/><i>RHOAI Pipeline Steps</i>"] -->|"embeds as library<br/>via KFPEventHandler"| AI4RAG

    %% Backend (behind OGX)
    OGXServer -.->|"backend"| VectorDB["Milvus / Qdrant"]
    OGXServerVec -.->|"backend"| VectorDB

    %% Styling
    style AI4RAG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Python package dependencies
    style LangChain fill:#999,stroke:#333
    style LangChainChroma fill:#999,stroke:#333
    style LangChainSplitters fill:#999,stroke:#333
    style OGXClient fill:#999,stroke:#333
    style Pandas fill:#999,stroke:#333
    style Pydantic fill:#999,stroke:#333
    style PyGAM fill:#999,stroke:#333
    style ScikitLearn fill:#999,stroke:#333
    style Unitxt fill:#999,stroke:#333

    %% Internal platform services
    style OGXServer fill:#f5a623,stroke:#333
    style OGXServerEmbed fill:#f5a623,stroke:#333
    style OGXServerVec fill:#f5a623,stroke:#333
    style ChromaDB fill:#f5a623,stroke:#333

    %% Platform consumer
    style KFP fill:#7ed321,stroke:#333

    %% Backend
    style VectorDB fill:#e8e8e8,stroke:#333
