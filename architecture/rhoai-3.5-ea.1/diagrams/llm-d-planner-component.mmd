graph TB
    subgraph PlannerPlatform["llm-d Planner Platform"]
        direction TB

        subgraph Frontend["Frontend Layer"]
            StreamlitUI["Streamlit UI<br/>Port: 8501/TCP<br/>Multi-tab workflow"]
        end

        subgraph BackendLayer["Backend Layer"]
            BackendAPI["Backend API<br/>FastAPI<br/>Port: 8000/TCP"]
            IntentExtractor["Intent Extractor<br/>NLP → Spec"]
            CapacityPlanner["Capacity Planner<br/>GPU Memory Calc"]
            GPURecommender["GPU Recommender<br/>Roofline Model"]
            RecommendationEngine["Recommendation Engine<br/>Multi-criteria Scoring"]
            ConfigGenerator["Configuration Generator<br/>Jinja2 Templates"]
            ClusterManager["Cluster Manager<br/>kubectl Integration"]
            KnowledgeBase["Knowledge Base<br/>Benchmarks + Catalog"]
        end

        subgraph DataLayer["Data Layer"]
            PostgreSQL["PostgreSQL<br/>Port: 5432/TCP<br/>Benchmark Data"]
            Ollama["Ollama LLM<br/>Port: 11434/TCP<br/>granite3.3:2b"]
        end

        subgraph Optional["Optional (Dev Only)"]
            Simulator["vLLM Simulator<br/>Port: 8080/TCP<br/>GPU-free Testing"]
        end
    end

    %% Frontend to Backend
    StreamlitUI -->|"HTTP/8000<br/>All API calls"| BackendAPI

    %% Backend internal modules
    BackendAPI --> IntentExtractor
    BackendAPI --> CapacityPlanner
    BackendAPI --> GPURecommender
    BackendAPI --> RecommendationEngine
    BackendAPI --> ConfigGenerator
    BackendAPI --> ClusterManager
    BackendAPI --> KnowledgeBase

    %% Backend to Data Layer
    IntentExtractor -->|"HTTP/11434<br/>/api/generate"| Ollama
    KnowledgeBase -->|"PostgreSQL/5432<br/>Benchmark queries"| PostgreSQL
    RecommendationEngine -->|"PostgreSQL/5432<br/>Scoring data"| PostgreSQL

    %% External Dependencies
    User["User Browser"] -->|"HTTPS/443<br/>via OpenShift Route"| StreamlitUI
    CLI["CLI User"] -->|"HTTP/8000<br/>Direct API"| BackendAPI

    CapacityPlanner -->|"HTTPS/443<br/>Model metadata"| HuggingFace["HuggingFace Hub API"]
    GPURecommender -->|"HTTPS/443<br/>Model config"| HuggingFace

    ClusterManager -->|"HTTPS/6443<br/>SA Token"| K8sAPI["Kubernetes API"]
    KnowledgeBase -.->|"HTTPS/8443<br/>Bearer Token"| ModelCatalog["RHOAI Model Catalog"]

    ConfigGenerator -->|"generates"| InferenceServiceCR["KServe InferenceService<br/>+ HPA + ServiceMonitor"]

    %% Styling
    style StreamlitUI fill:#4a90e2,stroke:#333,color:#fff
    style BackendAPI fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#7c3aed,stroke:#333,color:#fff
    style Simulator fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#ff9d00,stroke:#333,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style ModelCatalog fill:#ee0000,stroke:#333,color:#fff
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style User fill:#e8e8e8,stroke:#333
    style CLI fill:#e8e8e8,stroke:#333
    style IntentExtractor fill:#6cb4ee,stroke:#333
    style CapacityPlanner fill:#6cb4ee,stroke:#333
    style GPURecommender fill:#6cb4ee,stroke:#333
    style RecommendationEngine fill:#6cb4ee,stroke:#333
    style ConfigGenerator fill:#6cb4ee,stroke:#333
    style ClusterManager fill:#6cb4ee,stroke:#333
    style KnowledgeBase fill:#6cb4ee,stroke:#333
