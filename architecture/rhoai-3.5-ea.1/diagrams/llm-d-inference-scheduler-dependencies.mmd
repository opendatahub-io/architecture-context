graph LR
    Scheduler["llm-d-inference-scheduler<br/>(EPP + P/D Sidecar)"]

    %% External Dependencies (required)
    Scheduler -->|"ext-proc framework<br/>v1.4.0 (RH fork)"| GIE["Gateway API<br/>Inference Extension"]
    Scheduler -->|"KV-cache indexing<br/>v0.7.1"| KVCache["llm-d-kv-cache"]
    Scheduler -->|"ext-proc data plane"| EnvoyGW["Envoy Gateway"]
    Scheduler -->|"K8s client<br/>v0.23.3"| ControllerRuntime["controller-runtime"]
    Scheduler -->|"Gateway/HTTPRoute types<br/>v1.5.1"| GatewayAPI["gateway-api"]
    Scheduler -->|"metrics<br/>v1.23.2"| PromClient["prometheus/<br/>client_golang"]

    %% External Dependencies (optional)
    Scheduler -.->|"tracing<br/>v1.42.0"| OTEL["OpenTelemetry SDK"]
    Scheduler -.->|"KV events<br/>v0.17.0"| ZMQ["go-zeromq/zmq4"]
    Scheduler -.->|"API types<br/>v1.12.0"| OpenAIGo["openai-go"]

    %% Internal Platform Dependencies
    Scheduler -->|"HTTP API + ZMQ events"| vLLM["vLLM Model Servers"]
    Scheduler -->|"gRPC over UDS"| UDSTokenizer["UDS Tokenizer"]
    Scheduler -->|"gRPC ext-proc callback"| EnvoyGWInt["Envoy Gateway"]
    Scheduler -->|"CRD Watch"| InferencePool["InferencePool CRD<br/>(GIE)"]

    %% Integration Points (inbound)
    Gateway["Gateway API<br/>(Gateway CR)"] -->|"HTTP listener<br/>port 80"| Scheduler
    HTTPRoute["HTTPRoute"] -->|"routes / traffic<br/>to InferencePool"| Scheduler
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>9090/TCP every 15s"| Scheduler
    ServiceMonitor["ServiceMonitor<br/>(monitoring.coreos.com)"] -->|"configures scrape"| Prometheus

    %% External Services
    Scheduler -->|"distributed traces<br/>gRPC/4317"| OTLPCollector["OTLP Collector"]
    Scheduler -->|"tokenizer models<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    Scheduler -->|"watch resources<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]

