graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.3<br/>OAuth/OIDC"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Notebook CR)"]
        direction TB
        KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>RBAC-based user authZ<br/>Injected by Notebook Controller"]

        subgraph JupyterVariant["Jupyter Variant"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>User: 1001 (non-root)"]
        end

        subgraph CodeServerVariant["code-server Variant"]
            Nginx["nginx<br/>80/TCP HTTP"]
            Httpd["httpd CGI<br/>8080/TCP HTTP"]
            CodeSrv["code-server<br/>8888/TCP HTTP"]
            Nginx -->|proxy| CodeSrv
            Nginx -->|CGI /api/kernels/| Httpd
        end
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB
        Culler["Notebook Controller Culler<br/>SA: culler"]
        Operator["rhods-operator<br/>SA: rhods-operator"]
        Dashboard["ODH Dashboard<br/>SA: dashboard"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
    end

    subgraph EgressServices["EGRESS (External Services)"]
        direction TB
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        DSPA["DSPA Endpoint<br/>8888/TCP HTTP/S<br/>Bearer Token"]
        MLflow["MLflow Tracking<br/>5000/TCP HTTP/S<br/>Bearer Token"]
        Kafka["Kafka Brokers<br/>9092/TCP<br/>SASL/TLS"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS (optional)<br/>Credentials"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token/Basic"]
    end

    subgraph BuildPipeline["BUILD PIPELINE"]
        KonfluxCI["Konflux CI<br/>Hermetic builds<br/>cachi2 prefetch"]
        AIPCC["AIPCC Pipeline<br/>RHEL base images"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth/OIDC"| Gateway

    %% Ingress → Workbench
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KRBAC
    KRBAC -->|"HTTP/8888<br/>No encryption<br/>Pod-internal"| JupyterLab
    KRBAC -->|"HTTP/80<br/>No encryption<br/>Pod-internal"| Nginx

    %% Culler → Workbench
    Culler -->|"HTTPS/8443<br/>TLS<br/>SA token"| KRBAC

    %% Operator → K8s
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA auth"| K8sAPI
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA auth"| K8sAPI

    %% Workbench → Egress
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    JupyterLab -->|"HTTP(S)/8888<br/>Bearer Token"| DSPA
    JupyterLab -->|"HTTP(S)/5000<br/>Bearer Token"| MLflow
    JupyterLab -->|"TCP/9092<br/>SASL/TLS"| Kafka
    JupyterLab -->|"TCP/27017<br/>TLS (opt)<br/>Credentials"| MongoDB

    %% Build Pipeline
    KonfluxCI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| Registry
    AIPCC -->|"HTTPS/443<br/>TLS 1.2+"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBAC authproxy
    class JupyterLab,Nginx,Httpd,CodeSrv workbench
    class Culler,Operator,Dashboard,K8sAPI cluster
    class S3,DSPA,MLflow,Kafka,MongoDB,Registry egress
    class KonfluxCI,AIPCC build
