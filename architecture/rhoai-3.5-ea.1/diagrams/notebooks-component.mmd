graph TB
    subgraph "Notebooks Component (Container Image Library)"
        direction TB

        subgraph BaseLayer["Base Images Layer"]
            BaseCPU["Base CPU<br/>c9s + Python 3.12"]
            BaseCUDA["Base CUDA<br/>c9s + Python 3.12 + CUDA 12.9/13.0"]
            BaseROCm["Base ROCm<br/>c9s + Python 3.12 + ROCm 6.4/7.1"]
        end

        subgraph WorkbenchLayer["Jupyter Workbench Images"]
            JupyterMinimal["jupyter-minimal<br/>JupyterLab 4.5<br/>8888/TCP"]
            JupyterDS["jupyter-datascience<br/>NumPy, Pandas, scikit-learn<br/>Elyra, MLflow, CodeFlare"]
            JupyterPyTorch["jupyter-pytorch<br/>PyTorch 2.10<br/>CUDA / ROCm"]
            JupyterTF["jupyter-tensorflow<br/>TensorFlow 2.21<br/>CUDA / ROCm"]
            JupyterLLM["jupyter-pytorch-llmcompressor<br/>LLM Compressor 0.10<br/>CUDA only"]
            JupyterTrustyAI["jupyter-trustyai<br/>TrustyAI 0.6 + Java 17<br/>CPU only"]
        end

        subgraph CodeServerLayer["Code-Server Workbench"]
            CodeServer["codeserver-datascience<br/>VS Code in Browser<br/>80/TCP (nginx)"]
            CSNginx["nginx reverse proxy"]
            CSHttpd["httpd CGI gateway<br/>8080/TCP"]
            CSCGI["access.cgi<br/>Fake /api/kernels/"]
            CodeServer --> CSNginx
            CSNginx --> CSHttpd
            CSHttpd --> CSCGI
        end

        subgraph RuntimeLayer["Runtime Images (Headless)"]
            RTMinimal["runtime-minimal"]
            RTDS["runtime-datascience"]
            RTPyTorch["runtime-pytorch"]
            RTTF["runtime-tensorflow"]
            RTLLM["runtime-pytorch-llmcompressor"]
            RTROCmPT["runtime-rocm-pytorch"]
            RTROCmTF["runtime-rocm-tensorflow"]
        end

        subgraph ManifestLayer["ImageStream Manifests"]
            KustomizeBase["Kustomize Base<br/>manifests/rhoai/base/"]
            KustomizeOverlay["Kustomize Overlay<br/>manifests/rhoai/overlays/"]
            ParamsEnv["params.env<br/>Image SHA256 digests"]
            CommitEnv["commit.env<br/>Build commit hashes"]
            KustomizeBase --> KustomizeOverlay
            ParamsEnv --> KustomizeBase
            CommitEnv --> KustomizeBase
        end

        subgraph BuildSystem["Build & CI Infrastructure"]
            BuildInputs["buildinputs<br/>Go CLI Tool"]
            PylocksGen["pylocks_generator.py<br/>PEP 751 lockfiles"]
            GenKustomize["generate_kustomization.py<br/>Manifest generation"]
            TestSuite["Test Suite<br/>pytest + Playwright"]
            CVETooling["CVE Tooling<br/>Syft SBOM + JIRA"]
        end
    end

    %% Image hierarchy relationships
    BaseCPU -->|FROM| JupyterMinimal
    BaseCUDA -->|FROM| JupyterMinimal
    BaseROCm -->|FROM| JupyterMinimal
    JupyterMinimal -->|FROM| JupyterDS
    JupyterDS -->|FROM| JupyterPyTorch
    JupyterDS -->|FROM| JupyterTF
    JupyterDS -->|FROM| JupyterTrustyAI
    JupyterPyTorch -->|FROM| JupyterLLM
    JupyterDS -->|FROM| CodeServer

    %% Runtime mirrors workbench structure
    BaseCPU -.->|FROM| RTMinimal
    RTMinimal -.->|FROM| RTDS
    RTDS -.->|FROM| RTPyTorch
    RTDS -.->|FROM| RTTF
    RTPyTorch -.->|FROM| RTLLM

    %% External consumers
    Operator["rhods-operator /<br/>opendatahub-operator"]
    Dashboard["ODH Dashboard"]
    NotebookCtrl["Notebook Controller"]
    Culler["Notebook Culler"]

    KustomizeOverlay -->|deployed by| Operator
    Operator -->|creates ImageStreams| Dashboard
    Dashboard -->|reads annotations| KustomizeBase
    NotebookCtrl -->|creates pods from| WorkbenchLayer
    Culler -->|polls /api/kernels/| JupyterMinimal
    Culler -->|polls /api/kernels/| CSCGI

    %% Styling
    style BaseCPU fill:#e8e8e8,stroke:#666
    style BaseCUDA fill:#76b900,stroke:#333,color:#fff
    style BaseROCm fill:#ed1c24,stroke:#333,color:#fff
    style JupyterMinimal fill:#4a90e2,stroke:#333,color:#fff
    style JupyterDS fill:#4a90e2,stroke:#333,color:#fff
    style JupyterPyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style JupyterTF fill:#ff6f00,stroke:#333,color:#fff
    style JupyterLLM fill:#9b59b6,stroke:#333,color:#fff
    style JupyterTrustyAI fill:#27ae60,stroke:#333,color:#fff
    style CodeServer fill:#007acc,stroke:#333,color:#fff
    style Operator fill:#f5a623,stroke:#333
    style Dashboard fill:#f5a623,stroke:#333
    style NotebookCtrl fill:#f5a623,stroke:#333
    style Culler fill:#f5a623,stroke:#333
