graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress<br/>(Gateway API / kube-rbac-proxy)<br/>TLS termination<br/>Not defined in this repo"]
    end

    subgraph Application["APPLICATION (OGX Server Pod)"]
        direction TB
        OGX["odh-ogx-core<br/>8321/TCP HTTP (plaintext)<br/>Python 3.12 + FastAPI<br/>OAuth2/OIDC JWT (optional)<br/>Image: quay.io/opendatahub/odh-ogx-core<br/>Base: UBI 9 (RHOAI)"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS"]
        direction TB
        vLLM_Inf["vLLM Inference<br/>configurable port<br/>HTTP/HTTPS<br/>TLS configurable"]
        vLLM_Emb["vLLM Embedding<br/>configurable port<br/>HTTP/HTTPS<br/>TLS configurable"]
    end

    subgraph Database["DATABASE"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire<br/>plaintext (configurable)"]
    end

    subgraph VectorDatabases["VECTOR DATABASES (optional)"]
        direction TB
        Milvus["Milvus (remote)<br/>configurable port<br/>TCP, TLS configurable<br/>Custom CA + client certs"]
        PGVector["pgvector<br/>5432/TCP<br/>PostgreSQL wire<br/>plaintext"]
        Qdrant["Qdrant<br/>6333/TCP HTTP + 6334/TCP gRPC<br/>HTTPS configurable"]
    end

    subgraph CloudAPIs["EXTERNAL SERVICES (Cloud APIs, TLS 1.2+)"]
        direction TB
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>Bearer Token (12h TTL)"]
        Watsonx["IBM watsonx<br/>443/TCP HTTPS<br/>API key"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>App Default Creds"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS<br/>API key"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>API key"]
    end

    subgraph ToolServices["TOOL SERVICES (TLS 1.2+)"]
        direction TB
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>API key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>API key"]
    end

    %% External to Ingress
    Client -->|"HTTPS (expected)<br/>TLS termination"| Gateway

    %% Ingress to Application
    Gateway -->|"HTTP/8321<br/>plaintext (internal)<br/>OAuth2 Token passthrough"| OGX

    %% Application to Inference
    OGX -->|"HTTP(S)/configurable<br/>TLS configurable<br/>Bearer Token"| vLLM_Inf
    OGX -->|"HTTP(S)/configurable<br/>TLS configurable<br/>Bearer Token"| vLLM_Emb

    %% Application to Database
    OGX -->|"PostgreSQL/5432<br/>plaintext<br/>Username/password"| PostgreSQL

    %% Application to Vector DBs
    OGX -->|"TCP/configurable<br/>TLS + custom CA<br/>Token (optional)"| Milvus
    OGX -->|"PostgreSQL/5432<br/>plaintext<br/>Username/password"| PGVector
    OGX -->|"HTTP/6333 + gRPC/6334<br/>HTTPS configurable<br/>API key (optional)"| Qdrant

    %% Application to Cloud APIs
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Watsonx
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| VertexAI
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| AzureOAI
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI

    %% Application to Tool Services
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Brave
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Tavily

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef vectordb fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cloudapi fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef toolservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class OGX application
    class vLLM_Inf,vLLM_Emb inference
    class PostgreSQL database
    class Milvus,PGVector,Qdrant vectordb
    class Bedrock,Watsonx,VertexAI,AzureOAI,OpenAI cloudapi
    class S3,Brave,Tavily toolservice
