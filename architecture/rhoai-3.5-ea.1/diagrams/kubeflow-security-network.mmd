graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS (Gateway API - openshift-ingress)"]
        Gateway["data-science-gateway<br/>443/TCP → 8443/TCP or 8888/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Path: /notebook/{ns}/{name}"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER (per notebook pod)"]
        RBACProxy["{notebook-name}-kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>SA: {notebook-name}"]
    end

    subgraph K8sAuth["KUBERNETES AUTH APIs"]
        TokenReview["TokenReview API<br/>6443/TCP HTTPS TLS 1.2+<br/>Validates bearer token"]
        SAR["SubjectAccessReview API<br/>6443/TCP HTTPS TLS 1.2+<br/>Checks 'get notebooks' perm"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        NotebookPod["Notebook Pod (JupyterLab)<br/>8888/TCP HTTP<br/>CA: /etc/pki/tls/custom-certs<br/>Image: from ImageStream"]
        NBService["{notebook-name} Service<br/>80/TCP → 8888<br/>HTTP / No encryption"]
        ProxyService["{notebook-name}-kube-rbac-proxy<br/>Service 8443/TCP HTTPS<br/>TLS (serving cert)"]
        NetworkPolicy["NetworkPolicy<br/>(notebook isolation)"]
    end

    subgraph ControllerNS["CONTROLLER PLANE (opendatahub namespace)"]
        direction TB
        NBC["notebook-controller<br/>SA: notebook-controller-service-account<br/>8080/TCP metrics, 8081/TCP health"]
        ODHC["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>8080/TCP metrics, 8081/TCP health<br/>443/TCP webhook HTTPS"]

        subgraph ControllerSvc["Controller Services"]
            WebhookSvc["webhook-service<br/>443/TCP HTTPS<br/>TLS (serving cert)"]
            MetricsSvc["metrics-service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>SA token auth"]
        ImageStreamAPI["OpenShift ImageStream API<br/>6443/TCP HTTPS TLS 1.2+<br/>SA token auth"]
        DSPAAPI["DSPA API Server<br/>HTTPS TLS 1.2+<br/>SA token auth"]
    end

    %% User → Gateway → Auth → Notebook flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OIDC)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (serving cert)<br/>Bearer Token (fwd)"| RBACProxy
    RBACProxy -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| TokenReview
    RBACProxy -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| SAR
    RBACProxy -->|"HTTP/8888<br/>No encryption<br/>X-Auth-Request-User"| NotebookPod

    %% API Server webhook call
    K8sAPI -->|"HTTPS/443<br/>TLS (serving cert)<br/>Webhook CA"| WebhookSvc

    %% Controllers → API Server
    NBC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    ODHC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    ODHC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| ImageStreamAPI

    %% Culling flow
    NBC -->|"HTTP/8888<br/>No encryption<br/>No auth<br/>Poll /api/kernels"| NotebookPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8sauth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class RBACProxy auth
    class TokenReview,SAR k8sauth
    class NotebookPod,NBService,ProxyService,NetworkPolicy userns
    class NBC,ODHC,WebhookSvc,MetricsSvc controller
    class K8sAPI,ImageStreamAPI,DSPAAPI extsvc
