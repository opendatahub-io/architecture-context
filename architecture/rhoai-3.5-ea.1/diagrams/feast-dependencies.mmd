graph LR
    Feast["Feast Operator +<br/>Feature Store"]

    %% Internal RHOAI/ODH Dependencies
    Feast -.->|"deployed by<br/>kustomize overlay"| RHOAIOp["RHOAI Operator /<br/>ODH Operator"]
    Feast -->|"CRD watch<br/>config injection"| NotebookCtrl["ODH Notebook<br/>Controller"]
    Feast -->|"ServiceMonitor<br/>CRD creation"| Prometheus["Prometheus<br/>Operator"]
    Feast -->|"custom CA<br/>ConfigMap mount"| TrustedCA["ODH Trusted<br/>CA Bundle"]

    %% Platform Dependencies
    Feast -->|"CRUD, TokenReview<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    Feast -->|"Routes, certs<br/>HTTPS/443"| OpenShiftAPI["OpenShift API<br/>Server"]
    Feast -->|"service serving<br/>cert annotation"| ServingCerts["OpenShift Service<br/>Serving Certificates"]
    Feast -->|"JWT validation<br/>JWKS/HTTPS/443"| OIDC["OIDC Provider<br/>(Keycloak/Azure AD)"]

    %% Online Store Backends
    Feast -->|"online store<br/>Redis/6379"| Redis["Redis 4.x-7.x"]
    Feast -->|"online/offline/registry<br/>PG/5432"| PostgreSQL["PostgreSQL 12+"]
    Feast -->|"online store<br/>HTTPS/443 IAM"| DynamoDB["DynamoDB<br/>(AWS)"]
    Feast -.->|"online store<br/>dev/single-node"| SQLite["SQLite 3.x"]
    Feast -.->|"online store"| Cassandra["Cassandra 3.x+"]
    Feast -.->|"online store"| Elasticsearch["Elasticsearch 8.x+"]
    Feast -.->|"online store<br/>vector search"| Milvus["Milvus 2.x+"]
    Feast -.->|"online/offline"| MongoDB["MongoDB 4.x+"]

    %% Offline Store Backends
    Feast -->|"offline store<br/>HTTPS/443"| Snowflake["Snowflake"]
    Feast -->|"offline store<br/>HTTPS/443"| BigQuery["BigQuery<br/>(GCP)"]
    Feast -.->|"offline store"| DuckDB["DuckDB"]

    %% Registry Backends
    Feast -->|"registry store<br/>HTTPS/443 IAM"| S3["S3 (AWS)"]
    Feast -->|"registry store<br/>HTTPS/443 GCP SA"| GCS["GCS (GCP)"]

    %% Other Integrations
    Feast -.->|"transforms<br/>gRPC/6569"| TransformSvc["Transformation<br/>Service"]
    Feast -.->|"tracing<br/>OTLP/4317"| OTel["OpenTelemetry<br/>Collector"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal ODH/RHOAI - green
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style NotebookCtrl fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff

    %% Platform - gray
    style K8sAPI fill:#666,stroke:#333,color:#fff
    style OpenShiftAPI fill:#666,stroke:#333,color:#fff
    style ServingCerts fill:#666,stroke:#333,color:#fff
    style OIDC fill:#666,stroke:#333,color:#fff

    %% Online stores - orange
    style Redis fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style DynamoDB fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333
    style Cassandra fill:#f5a623,stroke:#333
    style Elasticsearch fill:#f5a623,stroke:#333
    style Milvus fill:#f5a623,stroke:#333
    style MongoDB fill:#f5a623,stroke:#333

    %% Offline stores - yellow
    style Snowflake fill:#e8c83a,stroke:#333
    style BigQuery fill:#e8c83a,stroke:#333
    style DuckDB fill:#e8c83a,stroke:#333

    %% Registry stores - light blue
    style S3 fill:#87ceeb,stroke:#333
    style GCS fill:#87ceeb,stroke:#333

    %% Other
    style TransformSvc fill:#9b59b6,stroke:#333,color:#fff
    style OTel fill:#9b59b6,stroke:#333,color:#fff
