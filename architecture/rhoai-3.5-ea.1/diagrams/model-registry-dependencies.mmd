graph LR
    MR["Model Registry<br/>(multi-component)"]

    %% Sub-components
    subgraph MRComponents["Model Registry Components"]
        direction TB
        Proxy["Proxy Server<br/>(Go REST API)"]
        Catalog["Model Catalog<br/>(Go REST Service)"]
        Controller["Controller<br/>(Go controller-runtime)"]
        CSI["CSI Initializer<br/>(Go KServe Provider)"]
        UIComp["UI + BFF<br/>(TypeScript + Go)"]
        AsyncJobComp["Async Upload Job<br/>(Python 3.12)"]
    end

    %% External Dependencies (Required)
    Proxy -->|"TCP/3306<br/>metadata store"| MySQL["MySQL 8.3+<br/>(Required - default)"]
    Proxy -->|"TCP/5432<br/>alt metadata store"| PostgreSQL["PostgreSQL 16+<br/>(Required - catalog)"]
    Catalog -->|"TCP/5432<br/>leader election + data"| PostgreSQL
    AsyncJobComp -->|"OCI push/pull"| Skopeo["Skopeo<br/>(Required - async job)"]

    %% External Dependencies (Optional)
    Controller -->|"CRD Watch<br/>InferenceService v1beta1"| KServe["KServe<br/>(Optional - controller)"]
    CSI -->|"StorageProvider<br/>model-registry:// URIs"| KServe
    Proxy -.->|"mTLS + AuthZ<br/>VirtualService"| Istio["Istio 1.x<br/>(Recommended)"]
    AsyncJobComp -.->|"artifact signing<br/>OIDC"| Sigstore["Sigstore<br/>(Optional - async job)"]

    %% Internal ODH Dependencies
    Dashboard["ODH Dashboard"] -->|"API consumer<br/>HTTP/8080"| MR
    Pipelines["RHOAI Operator"] -->|"deployment mgmt"| MR
    Controller -->|"REST API calls<br/>HTTP/8080 mTLS"| Proxy

    %% Integration Points - External Services
    AsyncJobComp -->|"model storage<br/>HTTPS/443 AWS IAM"| S3["S3 Object Stores"]
    AsyncJobComp -->|"model push/pull<br/>HTTPS/443 Docker Auth"| OCIReg["OCI Registries"]
    AsyncJobComp -->|"model download<br/>HTTPS/443 API Key"| HuggingFace["HuggingFace Hub"]
    Catalog -->|"catalog source<br/>HTTPS/443 API Key"| HuggingFace
    CSI -->|"model download<br/>HTTPS/443"| S3

    %% Kubernetes
    Controller -->|"CRD watch, service discovery<br/>HTTPS/443 SA Token"| K8sAPI["Kubernetes API"]
    UIComp -->|"SubjectAccessReviews<br/>HTTPS/443 SA Token"| K8sAPI

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style UIComp fill:#4a90e2,stroke:#333,color:#fff
    style AsyncJobComp fill:#4a90e2,stroke:#333,color:#fff

    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff

    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff
    style Sigstore fill:#999,stroke:#333,color:#fff

    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff

    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCIReg fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
