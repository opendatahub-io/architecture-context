graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub<br/>ServiceAccount<br/>(API server pod)"]
        SA_Test["test-sa<br/>(example user SA)"]
        SA_Sidecar["eval-job SA<br/>(sidecar projected token)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_FullAccess["eval-hub-service-full-access<br/>(example binding)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR_FullAccess["eval-hub-service-full-access<br/>(example role)"]
    end

    subgraph VirtualRBACResources["Virtual RBAC Resources<br/>(not actual CRDs — used for SAR checks)"]
        Evaluations["trustyai.opendatahub.io<br/>evaluations"]
        Collections["trustyai.opendatahub.io<br/>collections"]
        Providers["trustyai.opendatahub.io<br/>providers"]
        StatusEvents["trustyai.opendatahub.io<br/>status-events"]
        Experiments["mlflow.kubeflow.org<br/>experiments"]
    end

    subgraph K8sAuthFlow["K8s Auth Flow (per API request)"]
        direction LR
        BearerToken["Bearer Token<br/>(from X-Authorization header)"]
        TokenReview["K8s TokenReview<br/>(validate token → user identity)"]
        SAR["K8s SubjectAccessReview<br/>(check RBAC in X-Tenant namespace)"]
    end

    subgraph Endpoints["Protected Endpoints"]
        JobsEndpoint["/api/v1/evaluations/jobs<br/>POST: evaluations:create +<br/>experiments:create,get<br/>GET: evaluations:get<br/>DELETE: evaluations:delete"]
        EventsEndpoint["/api/v1/evaluations/jobs/{id}/events<br/>POST: status-events:create"]
        CollectionsEndpoint["/api/v1/evaluations/collections<br/>ALL: collections:{method}"]
        ProvidersEndpoint["/api/v1/evaluations/providers<br/>ALL: providers:{method}"]
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth)"]
        Health["/api/v1/health"]
        Metrics["/metrics"]
        OpenAPI["/openapi.yaml"]
        Docs["/docs"]
    end

    %% Binding flow
    SA_Test -->|"bound via"| CRB_FullAccess
    CRB_FullAccess -->|"grants"| CR_FullAccess

    %% Role permissions
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Evaluations
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Collections
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Providers
    CR_FullAccess -->|"create"| StatusEvents
    CR_FullAccess -->|"create, get"| Experiments

    %% Auth flow
    BearerToken -->|"validates"| TokenReview
    TokenReview -->|"checks permissions"| SAR
    SAR -->|"authorizes"| JobsEndpoint
    SAR -->|"authorizes"| EventsEndpoint
    SAR -->|"authorizes"| CollectionsEndpoint
    SAR -->|"authorizes"| ProvidersEndpoint

    %% SA usage
    SA_EvalHub -.->|"in-cluster token<br/>K8s API calls"| TokenReview
    SA_Sidecar -.->|"projected token<br/>sidecar → eval-hub"| BearerToken

    %% Styling
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Test fill:#4a90e2,stroke:#333,color:#fff
    style SA_Sidecar fill:#4a90e2,stroke:#333,color:#fff
    style CR_FullAccess fill:#f5a623,stroke:#333
    style CRB_FullAccess fill:#f5a623,stroke:#333
    style Evaluations fill:#7ed321,stroke:#333
    style Collections fill:#7ed321,stroke:#333
    style Providers fill:#7ed321,stroke:#333
    style StatusEvents fill:#7ed321,stroke:#333
    style Experiments fill:#7ed321,stroke:#333
    style BearerToken fill:#e8e8e8,stroke:#333
    style TokenReview fill:#e8e8e8,stroke:#333
    style SAR fill:#e8e8e8,stroke:#333
    style JobsEndpoint fill:#dae8fc,stroke:#6c8ebf
    style EventsEndpoint fill:#dae8fc,stroke:#6c8ebf
    style CollectionsEndpoint fill:#dae8fc,stroke:#6c8ebf
    style ProvidersEndpoint fill:#dae8fc,stroke:#6c8ebf
    style Health fill:#f0f0f0,stroke:#ccc
    style Metrics fill:#f0f0f0,stroke:#ccc
    style OpenAPI fill:#f0f0f0,stroke:#ccc
    style Docs fill:#f0f0f0,stroke:#ccc
