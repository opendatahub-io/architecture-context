graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Gateway["Gateway API Ingress"]
        HTTPRoute["HTTPRoute<br/>(llm-d-inference-gateway)"]
    end

    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph APIServer["API Server (apiserver)"]
            API["REST API<br/>Port 8000/TCP<br/>OpenAI Batch API Compatible"]
            Observability1["Observability<br/>Port 8081/TCP<br/>health / ready / metrics"]
            Middleware["Request Middleware<br/>Tenant Extraction<br/>Security Headers"]
            BatchHandler["Batch Handler<br/>/v1/batches/*"]
            FileHandler["File Handler<br/>/v1/files/*"]

            API --> Middleware
            Middleware --> BatchHandler
            Middleware --> FileHandler
        end

        subgraph Processor["Batch Processor (batch-processor)"]
            Poller["Queue Poller<br/>poll_interval: 5s"]
            Workers["Worker Pool<br/>20 concurrent workers"]
            Executor["Request Executor<br/>Global: 100 concurrency<br/>Per-model: 10 concurrency"]
            Finalizer["Job Finalizer<br/>Result upload & status"]
            Recovery["Crash Recovery<br/>Startup phase-aware recovery"]
            Observability2["Observability<br/>Port 9090/TCP<br/>health / ready / metrics"]

            Poller --> Workers
            Workers --> Executor
            Executor --> Finalizer
            Recovery -.->|startup| Workers
        end

        subgraph GC["Garbage Collector (batch-gc)"]
            Scanner["Expiration Scanner<br/>interval: 30m"]
            Cleaner["Resource Cleaner<br/>max_concurrency: 10"]

            Scanner --> Cleaner
        end
    end

    subgraph DataStores["Data Stores"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>Metadata, Queue, Events, Cache"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Alternative Metadata Store"]
        S3["S3-Compatible Storage<br/>443/TCP<br/>File Content (JSONL)"]
    end

    subgraph InferenceLayer["Inference Layer"]
        InferenceGW["LLM Inference Gateway<br/>HTTP/HTTPS<br/>OpenAI-compatible"]
    end

    %% External flows
    Client -->|"HTTP/HTTPS<br/>Tenant Header"| HTTPRoute
    HTTPRoute -->|"8000/TCP"| API

    %% API Server to data stores
    BatchHandler -->|"create/query jobs"| Redis
    BatchHandler -->|"alternative"| PostgreSQL
    FileHandler -->|"upload/download"| S3
    FileHandler -->|"file metadata"| Redis

    %% Processor flows
    Poller -->|"dequeue jobs<br/>(sorted set)"| Redis
    Executor -->|"inference requests<br/>Bearer token"| InferenceGW
    Executor -->|"read input JSONL"| S3
    Finalizer -->|"write output JSONL"| S3
    Finalizer -->|"update status"| Redis

    %% GC flows
    Cleaner -->|"delete expired metadata"| Redis
    Cleaner -->|"delete expired files"| S3

    %% Cancellation event flow
    BatchHandler -.->|"cancel event<br/>(blocking list)"| Redis
    Redis -.->|"cancel signal"| Workers

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style Middleware fill:#5b9bd5,stroke:#333,color:#fff
    style BatchHandler fill:#5b9bd5,stroke:#333,color:#fff
    style FileHandler fill:#5b9bd5,stroke:#333,color:#fff
    style Observability1 fill:#95b8d1,stroke:#333

    style Poller fill:#e07b53,stroke:#333,color:#fff
    style Workers fill:#e07b53,stroke:#333,color:#fff
    style Executor fill:#e07b53,stroke:#333,color:#fff
    style Finalizer fill:#e07b53,stroke:#333,color:#fff
    style Recovery fill:#d4a574,stroke:#333
    style Observability2 fill:#d4a574,stroke:#333

    style Scanner fill:#7eb77f,stroke:#333,color:#fff
    style Cleaner fill:#7eb77f,stroke:#333,color:#fff

    style Redis fill:#dc382c,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff

    style Client fill:#e8e8e8,stroke:#999
    style HTTPRoute fill:#ffe6cc,stroke:#d79b00
