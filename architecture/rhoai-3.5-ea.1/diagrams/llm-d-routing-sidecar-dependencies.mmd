graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies
    Sidecar -->|"HTTP(S)/8001<br/>decode requests"| vLLMDecoder["vLLM Decoder<br/>(local, co-located)"]
    Sidecar -->|"HTTP(S)/dynamic<br/>prefill requests"| vLLMPrefiller["vLLM Prefiller Pods<br/>(remote)"]
    Sidecar -->|"CRD Watch<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io<br/>v1alpha2"]
    Sidecar -->|"API Watch<br/>HTTPS/443"| K8sPods["Kubernetes Pods<br/>(matching pool selectors)"]

    %% Upstream Dependency (sets routing header)
    Scheduler["llm-d-inference-scheduler"] -.->|"sets x-prefiller-host-port<br/>header"| Sidecar

    %% External Go Dependencies
    Sidecar -->|"LRU cache"| LRU["hashicorp/golang-lru<br/>v2.0.7"]
    Sidecar -->|"request correlation"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"structured logging"| Logr["go-logr/logr<br/>v1.4.2"]

    %% Kubernetes Client Libraries (optional - SSRF only)
    Sidecar -.->|"dynamic client<br/>(SSRF only)"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -.->|"API types<br/>(SSRF only)"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"logging backend"| Klog["k8s.io/klog/v2<br/>v2.130.1"]

    %% Infrastructure
    Sidecar -->|"Kubernetes API<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style vLLMDecoder fill:#7ed321,stroke:#333,color:#fff
    style vLLMPrefiller fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style K8sPods fill:#7ed321,stroke:#333,color:#fff
    style Scheduler fill:#7ed321,stroke:#333,color:#fff
    style LRU fill:#f5a623,stroke:#333,color:#fff
    style UUID fill:#f5a623,stroke:#333,color:#fff
    style Logr fill:#f5a623,stroke:#333,color:#fff
    style ClientGo fill:#f5a623,stroke:#333,color:#fff
    style APIMachinery fill:#f5a623,stroke:#333,color:#fff
    style Klog fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
