graph TB
    subgraph External["EXTERNAL (Operator Workstation / CI Pipeline)"]
        Operator["Cluster Operator<br/>or CI/CD Pipeline"]
    end

    subgraph CLITool["CLI TOOL (Client-Side)"]
        direction TB
        subgraph Binary["rhai-cli Binary"]
            ClientWrapper["K8s Client Wrapper<br/>dynamic + metadata + discovery +<br/>OLM + core + authz clients"]
            RBACCheck["RBAC Pre-Check<br/>SelfSubjectAccessReview"]
            ClientWrapper --> RBACCheck
        end

        subgraph Container["Container Image (optional)<br/>quay.io/rhoai/odh-cli-rhel9"]
            ContainerBin["rhai-cli + oc + yq + jq + Python"]
            KUBECONFIG["KUBECONFIG<br/>/kubeconfig (mounted)"]
        end
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Target)"]
        direction TB

        subgraph APIServer["API Server Layer"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token / Client Cert / OIDC"]
        end

        subgraph PlatformCRs["Platform CRs (Read/Patch)"]
            DSC["DataScienceCluster<br/>dscoperator.opendatahub.io/v2"]
            DSCI["DSCInitialization<br/>dscoperator.opendatahub.io/v2"]
            ComponentCRs["Component CRs<br/>components.platform.opendatahub.io/v1alpha1"]
        end

        subgraph WorkloadCRs["Workload CRs (Read/Patch/Create/Delete)"]
            ISVC["InferenceService<br/>serving.kserve.io/v1beta1"]
            SR["ServingRuntime<br/>serving.kserve.io/v1alpha1"]
            Notebook["Notebook<br/>kubeflow.org/v1"]
            RayCluster["RayCluster<br/>ray.io/v1"]
            DSPA["DSPA<br/>v1 / v1alpha1"]
            Kueue["ClusterQueue / LocalQueue<br/>kueue.x-k8s.io/v1beta1"]
            TrustyAISvc["TrustyAIService<br/>opendatahub.io"]
            Guardrails["GuardrailsOrchestrator"]
            LlamaStack["LlamaStackDistribution<br/>opendatahub.io"]
            TrainingJobs["PyTorchJob / TFJob /<br/>MPIJob / XGBoostJob<br/>kubeflow.org/v1"]
        end

        subgraph OLMLayer["OLM (Read/Create)"]
            Subscription["Subscription<br/>operators.coreos.com/v1alpha1"]
            CSV["ClusterServiceVersion"]
            OperatorGroup["OperatorGroup<br/>operators.coreos.com/v1"]
        end

        subgraph OSRoutes["OpenShift Routes"]
            TrustyAIRoute["TrustyAI Service Route<br/>443/TCP HTTPS<br/>Bearer Token"]
            RayDashRoute["RayCluster Dashboard Route"]
        end
    end

    subgraph BuildTime["BUILD-TIME ONLY"]
        GitHub["github.com (odh-gitops)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
    end

    %% Flows
    Operator -->|"CLI invocation<br/>(local or in container)"| ClientWrapper
    ClientWrapper -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token /<br/>Client Cert"| K8sAPI

    K8sAPI --- PlatformCRs
    K8sAPI --- WorkloadCRs
    K8sAPI --- OLMLayer
    K8sAPI --- OSRoutes

    ClientWrapper -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| TrustyAIRoute

    CLI -.->|"Build time only<br/>HTTPS/443"| GitHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cli fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef apiserver fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef platformcr fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workloadcr fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef olm fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef route fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef buildtime fill:#e8e8e8,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Operator external
    class ClientWrapper,RBACCheck,ContainerBin,KUBECONFIG cli
    class K8sAPI apiserver
    class DSC,DSCI,ComponentCRs platformcr
    class ISVC,SR,Notebook,RayCluster,DSPA,Kueue,TrustyAISvc,Guardrails,LlamaStack,TrainingJobs workloadcr
    class Subscription,CSV,OperatorGroup olm
    class TrustyAIRoute,RayDashRoute route
    class GitHub buildtime
