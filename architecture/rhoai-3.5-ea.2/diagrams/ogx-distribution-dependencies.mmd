graph LR
    OGX["OGX Distribution<br/>(odh-ogx-core)"]

    %% Required External Dependencies
    OGX -->|"core framework<br/>v1.1.2+rhaiv.0"| OGXFramework["OGX Framework<br/>(opendatahub-io/ogx)"]
    OGX -->|"state persistence<br/>5432/TCP"| PostgreSQL["PostgreSQL 14+"]
    OGX -->|"runtime<br/>3.12"| Python["Python 3.12"]
    OGX -->|"ML framework"| PyTorch["PyTorch"]
    OGX -->|"doc processing"| Docling["Docling"]
    OGX -->|"tokenization"| Tiktoken["tiktoken"]
    OGX -->|"default embeddings"| GraniteEmbed["granite-embedding<br/>-125m-english"]

    %% Build-time Dependencies
    OGX -.->|"build-time<br/>package manager"| UV["uv 0.9+"]

    %% Internal Platform Dependencies
    OGX -->|"container base<br/>RHEL 9 + Python 3.12"| AIPCC["AIPCC base-images/cpu<br/>3.5.0-ea.2"]
    Operator["rhods-operator"] -->|"manages deployment<br/>lifecycle"| OGX
    Konflux["Konflux / Tekton"] -.->|"CI/CD build<br/>pipeline"| OGX

    %% Primary Integration - Inference
    OGX -->|"primary inference<br/>HTTP(S), Bearer Token"| vLLM_I["vLLM (inference)"]
    OGX -->|"embeddings<br/>HTTP(S), Bearer Token"| vLLM_E["vLLM (embedding)"]

    %% Optional Cloud Inference Providers
    OGX -.->|"HTTPS/443<br/>AWS IAM"| Bedrock["AWS Bedrock"]
    OGX -.->|"HTTPS/443<br/>API key"| WatsonX["IBM WatsonX"]
    OGX -.->|"HTTPS/443<br/>API key"| Azure["Azure OpenAI"]
    OGX -.->|"HTTPS/443<br/>GCP creds"| VertexAI["Google Vertex AI"]
    OGX -.->|"HTTPS/443<br/>API key"| OpenAI["OpenAI"]
    OGX -.->|"HTTPS/443<br/>API key"| Gemini["Google Gemini"]
    OGX -.->|"HTTPS/443<br/>API key"| Anthropic["Anthropic"]

    %% Optional Vector DBs
    OGX -.->|"TCP, TLS/mTLS<br/>Token"| Milvus["Milvus"]
    OGX -.->|"TCP/5432<br/>password"| Pgvector["pgvector"]
    OGX -.->|"HTTP/6333<br/>gRPC/6334"| Qdrant["Qdrant"]

    %% Optional Storage & Tools
    OGX -.->|"HTTPS/443<br/>AWS IAM"| S3["AWS S3"]
    OGX -.->|"HTTPS/443<br/>API key"| Brave["Brave Search"]
    OGX -.->|"HTTPS/443<br/>API key"| Tavily["Tavily Search"]
    OGX -.->|"HTTP/SSE<br/>configurable"| MCP["MCP Servers"]

    %% Auth & Observability
    OGX -.->|"JWKS validation<br/>HTTPS/443"| OIDC["OIDC/OAuth2 Provider"]
    OGX -.->|"OTLP export<br/>HTTP/gRPC"| OTel["OpenTelemetry Collector"]

    %% Platform consumers
    Gateway["Gateway API"] -->|"TLS termination<br/>→ HTTP/8321"| OGX

