graph LR
    Operator["LLM-D Batch Gateway<br/>Operator"]

    %% External Dependencies (required)
    Operator -->|"operator framework<br/>v0.23.3"| ControllerRuntime["controller-runtime"]
    Operator -->|"chart rendering<br/>v3.20.2"| Helm["Helm SDK v3"]

    %% External Dependencies (optional)
    Operator -.->|"HTTPRoute, ReferenceGrant<br/>v1.5.1"| GatewayAPI["Gateway API"]
    Operator -.->|"TLS provisioning<br/>v1.20.2"| CertManager["cert-manager"]
    Operator -.->|"monitoring CRDs<br/>v0.91.0"| PrometheusOp["Prometheus Operator"]

    %% Internal Platform Dependencies
    PlatformOp["opendatahub-operator /<br/>rhods-operator"] -->|"deploys, sets images<br/>via params.env"| Operator
    BatchGWChart["batch-gateway<br/>Helm Chart"] -->|"embedded at<br/>/charts/batch-gateway"| Operator

    %% Managed Workload Dependencies
    subgraph ManagedComponents["Managed Workload Dependencies"]
        direction TB
        PostgreSQL["PostgreSQL<br/>5432/TCP (required default)"]
        Redis["Redis / Valkey<br/>6379/TCP (alternative)"]
        S3["S3-Compatible Storage<br/>443/TCP"]
        InferenceGW["Inference Gateway<br/>(llm-d / GIE / EPP / vLLM)"]
        OTLPCollector["OTLP Collector<br/>4317/TCP gRPC (optional)"]
    end

    Operator -->|"job state storage"| PostgreSQL
    Operator -.->|"alt state storage"| Redis
    Operator -.->|"file storage"| S3
    Operator -->|"inference forwarding<br/>(processor)"| InferenceGW
    Operator -.->|"trace export"| OTLPCollector

    %% Core Platform
    Operator -->|"resource management<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% Integration Points (other components depending on this)
    Grafana["Grafana"] -.->|"dashboard ConfigMap<br/>auto-loaded by sidecar"| Operator

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Helm fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style PrometheusOp fill:#999,stroke:#333,color:#fff
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style BatchGWChart fill:#7ed321,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style Redis fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style InferenceGW fill:#f5a623,stroke:#333,color:#fff
    style OTLPCollector fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Grafana fill:#7ed321,stroke:#333,color:#fff
