graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>(Operator SA)"]
        SA_MLflow["mlflow-sa<br/>(MLflow Server SA)"]
        SA_GC["mlflow-gc-sa<br/>(GC CronJob SA)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller["controller-manager<br/>(ClusterRoleBinding)"]
        RB_Controller["controller-manager<br/>(RoleBinding, namespaced)"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding, Helm)"]
        CRB_GC["mlflow-gc<br/>(ClusterRoleBinding, Helm)"]
    end

    subgraph "ClusterRoles"
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_ManagerNS["manager-role<br/>(Role, namespaced)"]
        CR_MLflow["mlflow<br/>(ClusterRole, Helm-rendered)"]
        CR_GC["mlflow-gc<br/>(ClusterRole, Helm-rendered)"]
    end

    subgraph "Aggregate ClusterRoles (RBAC Aggregation)"
        CR_View["mlflow-view<br/>→ aggregated to view/edit/admin"]
        CR_Edit["mlflow-edit<br/>→ aggregated to edit/admin"]
        CR_Integration["mlflow-integration<br/>(standalone)"]
    end

    subgraph "Operator ClusterRole Resources"
        R_MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers<br/>CRUD"]
        R_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>CRUD"]
        R_ConsoleLinks["console.openshift.io<br/>consolelinks<br/>CRUD"]
        R_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create; CRUD (resourceNames: mlflow, mlflow-gc)"]
        R_Namespaces["core<br/>namespaces<br/>get, list, watch"]
        R_Secrets["core<br/>secrets (resourceNames:<br/>mlflow-artifact-connection)<br/>get, list, watch"]
        R_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get, list, watch"]
    end

    subgraph "Operator Namespaced Role Resources"
        R_CoreNS["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>CRUD"]
        R_Pods["core<br/>pods<br/>get, list, watch"]
        R_Deployments["apps<br/>deployments<br/>CRUD"]
        R_Jobs["batch<br/>jobs, cronjobs<br/>CRUD"]
        R_NetPol["networking.k8s.io<br/>networkpolicies<br/>CRUD"]
        R_SvcMon["monitoring.coreos.com<br/>servicemonitors<br/>CRUD"]
    end

    subgraph "MLflow Server ClusterRole Resources"
        R_ML_NS["core<br/>namespaces<br/>get, list, watch"]
        R_ML_Secrets["core<br/>secrets (resourceNames:<br/>mlflow-artifact-connection)<br/>get, list, watch"]
        R_ML_Configs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get, list, watch"]
    end

    subgraph "GC ClusterRole Resources"
        R_GC_Exp["mlflow.kubeflow.org<br/>experiments<br/>get, list, update"]
    end

    subgraph "Aggregate Role Resources"
        R_View["mlflow.opendatahub.io, mlflow.kubeflow.org<br/>mlflows, mlflowconfigs, datasets,<br/>experiments, registeredmodels, etc.<br/>get, list, watch"]
        R_EditRes["mlflow.opendatahub.io, mlflow.kubeflow.org<br/>mlflows, mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewaysecrets, gatewayendpoints, etc.<br/>CRUD"]
        R_IntRes["mlflow.kubeflow.org<br/>datasets, experiments,<br/>registeredmodels, gatewayendpoints<br/>get, list, create, update"]
    end

    %% Operator bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Controller
    CRB_Controller -->|grants| CR_Manager
    RB_Controller -->|grants| CR_ManagerNS

    %% MLflow server bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow

    %% GC bindings
    SA_GC -->|bound via| CRB_GC
    CRB_GC -->|grants| CR_GC

    %% Operator ClusterRole → Resources
    CR_Manager --> R_MLflows
    CR_Manager --> R_HTTPRoutes
    CR_Manager --> R_ConsoleLinks
    CR_Manager --> R_RBAC
    CR_Manager --> R_Namespaces
    CR_Manager --> R_Secrets
    CR_Manager --> R_MLflowConfigs

    %% Operator namespaced Role → Resources
    CR_ManagerNS --> R_CoreNS
    CR_ManagerNS --> R_Pods
    CR_ManagerNS --> R_Deployments
    CR_ManagerNS --> R_Jobs
    CR_ManagerNS --> R_NetPol
    CR_ManagerNS --> R_SvcMon

    %% MLflow ClusterRole → Resources
    CR_MLflow --> R_ML_NS
    CR_MLflow --> R_ML_Secrets
    CR_MLflow --> R_ML_Configs

    %% GC ClusterRole → Resources
    CR_GC --> R_GC_Exp

    %% Aggregate Roles → Resources
    CR_View --> R_View
    CR_Edit --> R_EditRes
    CR_Integration --> R_IntRes

