graph TB
    subgraph AP["Async Processor (llm-d-async)"]
        direction TB
        Main["cmd/main.go<br/>CLI Entry Point"]
        Workers["Worker Pool<br/>(configurable concurrency)"]
        MergePolicy["RequestMergePolicy<br/>(random-robin)"]

        subgraph FlowImpl["Flow Implementations"]
            RedisPubSub["RedisMQFlow<br/>Redis Pub/Sub"]
            RedisSortedSet["RedisSortedSetFlow<br/>Redis Sorted Set"]
            GCPPubSub["PubSubMQFlow<br/>GCP Pub/Sub"]
        end

        subgraph Gates["Flow Control Gates"]
            RedisGate["Redis Dispatch Gate"]
            PromSatGate["Prometheus Saturation Gate"]
            PromBudgetGate["Prometheus Budget Gate"]
            PromQueryGate["Prometheus Query Gate"]
            QuotaGate["Redis Quota Gate<br/>(rate-limit / concurrency)"]
            CompositeGate["Composite Gate<br/>(min budget across inner gates)"]
        end

        subgraph RetrySystem["Retry System"]
            RetryChannel["Retry Channel<br/>(in-process)"]
            RetryWorker["Retry Worker<br/>(exponential backoff + jitter)"]
            RetrySortedSet["Retry Sorted Set<br/>(score = future timestamp)"]
        end

        MetricsServer["Metrics Server<br/>:9090/TCP"]

        Main --> Workers
        Main --> FlowImpl
        FlowImpl --> MergePolicy
        MergePolicy --> Workers
        Workers -->|dispatch check| Gates
        Workers -->|retryable error| RetryChannel
        RetryChannel --> RetryWorker
        RetryWorker --> RetrySortedSet
        RetrySortedSet -->|due messages| MergePolicy
    end

    subgraph ProducerSDK["Producer SDK (Go Library)"]
        Producer["RedisSortedSetProducer<br/>Submit requests / retrieve results"]
    end

    %% External Systems
    Client["External Client<br/>(API Consumer)"]
    Redis["Redis<br/>6379/TCP"]
    GCPPub["GCP Pub/Sub<br/>443/TCP"]
    IGW["Inference Gateway (IGW)<br/>80/443 TCP"]
    Prometheus["Prometheus<br/>9090/TCP"]
    ModelServer["vLLM Model Servers"]

    %% Client interactions
    Client -->|uses| ProducerSDK
    Producer -->|ZADD / BRPOP| Redis

    %% Flow interactions
    RedisPubSub -->|SUBSCRIBE / PUBLISH| Redis
    RedisSortedSet -->|ZPOPMIN / ZADD / LPUSH| Redis
    GCPPubSub -->|Receive / Publish| GCPPub
    RetryWorker -->|ZADD / ZRANGEBYSCORE| Redis

    %% Gate interactions
    PromSatGate -->|PromQL query| Prometheus
    PromBudgetGate -->|PromQL query| Prometheus
    PromQueryGate -->|PromQL query| Prometheus
    RedisGate -->|GET budget key| Redis
    QuotaGate -->|rate-limit / concurrency ops| Redis

    %% Dispatch
    Workers -->|HTTP POST<br/>JSON payload| IGW
    IGW -->|routes to| ModelServer

    %% Styling
    style AP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ProducerSDK fill:#7ed321,stroke:#333,stroke-width:2px
    style FlowImpl fill:#5b9bd5,stroke:#333
    style Gates fill:#ed7d31,stroke:#333
    style RetrySystem fill:#a5a5a5,stroke:#333
    style IGW fill:#f5a623,stroke:#333
    style Redis fill:#d63b2f,stroke:#333,color:#fff
    style GCPPub fill:#4285f4,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style ModelServer fill:#999,stroke:#333
    style MetricsServer fill:#7ed321,stroke:#333
