graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% Core Framework Dependencies
    NemoGuardrails -->|"web framework"| FastAPI["FastAPI >=0.103"]
    NemoGuardrails -->|"ASGI server"| Uvicorn["uvicorn >=0.23"]
    NemoGuardrails -->|"LLM abstraction"| LangChain["LangChain >=0.2.14"]
    NemoGuardrails -->|"language parser"| Lark["Lark >=1.1.7"]
    NemoGuardrails -->|"data validation"| Pydantic["Pydantic >=1.10"]

    %% ML/NLP Dependencies
    NemoGuardrails -->|"nearest neighbor"| Annoy["Annoy >=1.17.3"]
    NemoGuardrails -->|"default embeddings"| FastEmbed["FastEmbed >=0.2.2"]
    NemoGuardrails -->|"ONNX runtime"| ONNX["onnxruntime >=1.17"]

    %% Optional ML Dependencies
    NemoGuardrails -.->|"PII detection"| Presidio["Presidio<br/>analyzer + anonymizer"]
    NemoGuardrails -.->|"NLP pipeline"| spaCy["spaCy >=3.4.4"]
    NemoGuardrails -.->|"injection detection"| YARA["yara-python >=4.5.1"]
    NemoGuardrails -.->|"local ML inference"| PyTorch["PyTorch >=2.0 (CPU)"]
    NemoGuardrails -.->|"sentence embeddings"| SentenceTransformers["SentenceTransformers >=2.2"]

    %% Observability Dependencies
    NemoGuardrails -.->|"tracing"| OpenTelemetry["OpenTelemetry<br/>api + distro + OTLP"]

    %% HTTP Dependencies
    NemoGuardrails -->|"async HTTP"| httpx["httpx >=0.24.1"]
    NemoGuardrails -->|"async HTTP"| aiohttp["aiohttp >=3.10.11"]

    %% Internal Platform Dependencies
    NemoGuardrails ==>|"chat completions<br/>HTTPS/443 Bearer Token"| UpstreamLLM["Upstream LLM<br/>(vLLM / TGI / NIM)"]
    NemoGuardrails ==>|"OTLP traces<br/>gRPC/4317"| OTelCollector["OpenTelemetry<br/>Collector"]

    %% External Service Integrations
    NemoGuardrails -.->|"embeddings + completions<br/>HTTPS/443"| OpenAI["OpenAI API"]
    NemoGuardrails -.->|"completions<br/>HTTPS/443"| AzureOpenAI["Azure OpenAI"]
    NemoGuardrails -.->|"jailbreak + embeddings<br/>HTTPS/443"| NIM["NVIDIA NIM"]
    NemoGuardrails -.->|"prompt protection<br/>HTTPS/443"| CiscoAI["Cisco AI Defense"]
    NemoGuardrails -.->|"fact checking"| AlignScore["AlignScore Server"]
    NemoGuardrails -.->|"thread storage<br/>Redis/6379"| Redis["Redis"]
    NemoGuardrails -.->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

