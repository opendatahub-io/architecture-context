graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS Termination)"]
        Gateway["Gateway API / Envoy Proxy<br/>443/TCP → 8321/TCP<br/>TLS termination<br/>Managed by rhods-operator"]
    end

    subgraph Application["APPLICATION LAYER (Plaintext HTTP)"]
        OGX["OGX Server (odh-ogx-core)<br/>8321/TCP HTTP (plaintext)<br/>OAuth2 JWT via JWKS<br/>Image: quay.io/rhoai/odh-ogx-core-rhel9<br/>Base: AIPCC CPU (RHEL 9 + Python 3.12)"]
    end

    subgraph RequiredEgress["REQUIRED EGRESS"]
        vLLM_I["vLLM Inference<br/>configurable port<br/>HTTP/HTTPS<br/>TLS (VLLM_TLS_VERIFY)<br/>Bearer Token"]
        vLLM_E["vLLM Embedding<br/>configurable port<br/>HTTP/HTTPS<br/>TLS (configurable)<br/>Bearer Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>plaintext<br/>username/password"]
    end

    subgraph CloudProviders["CONDITIONAL: Cloud Inference Providers (443/TCP HTTPS TLS 1.2+)"]
        Bedrock["AWS Bedrock<br/>AWS IAM/STS"]
        WatsonX["IBM WatsonX<br/>API key"]
        Azure["Azure OpenAI<br/>API key"]
        VertexAI["Google Vertex AI<br/>GCP credentials"]
        OpenAI["OpenAI API<br/>API key"]
        Gemini["Google Gemini<br/>API key"]
        Anthropic["Anthropic API<br/>API key"]
    end

    subgraph VectorDBs["CONDITIONAL: Vector Databases"]
        Milvus["Milvus (remote)<br/>configurable port<br/>TCP TLS/mTLS<br/>Token + CA/client certs"]
        Pgvector["pgvector<br/>5432/TCP<br/>plaintext<br/>username/password"]
        Qdrant["Qdrant<br/>6333/TCP HTTP, 6334/TCP gRPC<br/>HTTPS (configurable)<br/>API key"]
    end

    subgraph ToolsStorage["CONDITIONAL: Tools & Storage (443/TCP HTTPS TLS 1.2+)"]
        S3["AWS S3<br/>AWS IAM"]
        Brave["Brave Search API<br/>API key"]
        Tavily["Tavily Search API<br/>API key"]
    end

    subgraph AuthObs["CONDITIONAL: Auth & Observability"]
        JWKS["OIDC/OAuth2 JWKS<br/>443/TCP HTTPS<br/>TLS (AUTH_VERIFY_TLS)"]
        OTel["OpenTelemetry Collector<br/>configurable<br/>HTTP/gRPC"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token (JWT)"| Gateway
    Gateway -->|"HTTP/8321<br/>plaintext<br/>Bearer Token forwarded"| OGX

    OGX -->|"HTTP(S)/configurable<br/>TLS (configurable)<br/>Bearer Token"| vLLM_I
    OGX -->|"HTTP(S)/configurable<br/>TLS (configurable)<br/>Bearer Token"| vLLM_E
    OGX -->|"TCP/5432<br/>plaintext<br/>username/password"| PostgreSQL

    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/API key"| Bedrock
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| WatsonX
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Azure
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| VertexAI
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Gemini
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Anthropic

    OGX -.->|"TCP/configurable<br/>TLS/mTLS<br/>Token"| Milvus
    OGX -.->|"TCP/5432<br/>plaintext<br/>password"| Pgvector
    OGX -.->|"HTTP/6333 gRPC/6334<br/>HTTPS (configurable)<br/>API key"| Qdrant

    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM"| S3
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Brave
    OGX -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Tavily

    OGX -->|"HTTPS/443<br/>TLS<br/>JWKS fetch"| JWKS
    OGX -.->|"HTTP/gRPC<br/>configurable<br/>OTLP"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef required fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef conditional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef vectordb fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class OGX application
    class vLLM_I,vLLM_E,PostgreSQL required
    class Bedrock,WatsonX,Azure,VertexAI,OpenAI,Gemini,Anthropic conditional
    class Milvus,Pgvector,Qdrant vectordb
    class S3,Brave,Tavily conditional
    class JWKS,OTel auth
