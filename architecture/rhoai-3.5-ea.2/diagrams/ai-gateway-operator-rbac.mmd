graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["operator<br/>(redhat-ods-applications)"]
        SA_BatchGW["llm-d-batch-gateway-operator<br/>(redhat-ods-applications)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_BatchGW["llm-d-batch-gateway-operator<br/>(Cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_BatchGW["llm-d-batch-gateway-operator"]
        CR_Admin["llmbatchgateway-admin<br/>(aggregate)"]
        CR_View["llmbatchgateway-view<br/>(aggregate)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph ManagerResources["manager-role API Resources"]
        AIGateways["components.platform.opendatahub.io<br/>aigateways<br/>get,list,watch,create,<br/>update,patch,delete"]
        AIGatewaysStatus["components.platform.opendatahub.io<br/>aigateways/status<br/>get,update,patch"]
        AIGatewaysFinalizers["components.platform.opendatahub.io<br/>aigateways/finalizers<br/>update"]
