        Deployments["apps<br/>deployments<br/>full CRUD"]
        CoreResources["core<br/>services, serviceaccounts,<br/>configmaps<br/>full CRUD"]
        Secrets["core<br/>secrets<br/>create,get,list,patch,watch"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>create,list,watch<br/>(scoped CRUD for llmbatchgateways CRD)"]
        RBACResources["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create,list,watch<br/>(scoped CRUD for batch-gateway roles)"]
        RolesRes["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>full CRUD"]
        Certs["cert-manager.io<br/>certificates<br/>full CRUD"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>full CRUD"]
        RefGrants["gateway.networking.k8s.io<br/>referencegrants<br/>get,list,watch"]
        Monitoring["monitoring.coreos.com<br/>podmonitors, prometheusrules,<br/>servicemonitors<br/>full CRUD"]
        Events["events.k8s.io<br/>events<br/>create,patch"]
    end

    subgraph BatchGWResources["batch-gateway-operator API Resources"]
        BG_LLMBatch["batch.llm-d.ai<br/>llmbatchgateways<br/>get,list,patch,update,watch"]
        BG_Deployments["apps<br/>deployments<br/>full CRUD"]
        BG_Core["core<br/>configmaps, serviceaccounts,<br/>services<br/>full CRUD"]
        BG_Secrets["core<br/>secrets<br/>create,get,list,patch,watch"]
        BG_Certs["cert-manager.io<br/>certificates<br/>full CRUD"]
        BG_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>full CRUD"]
        BG_Monitoring["monitoring.coreos.com<br/>podmonitors, prometheusrules,<br/>servicemonitors<br/>full CRUD"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        LE_Resources["core, coordination.k8s.io<br/>configmaps, leases, events<br/>full CRUD"]
    end

