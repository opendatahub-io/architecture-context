graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        SA_Auth["Group: system:authenticated<br/>(all authenticated users)"]
        SA_Placeholder["ServiceAccount: placeholder<br/>(in ${NAMESPACE})"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Exec["${PROJECT_NAME}-exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        RB_SSRF["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role_Exec["${PROJECT_NAME}-exec-role"]
        Role_SSRF["ssrf-allowlist-role"]
    end

    subgraph Resources_Exec["API Resources (exec)"]
        PodsExec["core (&quot;&quot;)<br/>pods/exec"]
    end

    subgraph Resources_SSRF["API Resources (SSRF allowlist)"]
        Pods["core (&quot;&quot;)<br/>pods"]
        InferencePools["inference.networking.x-k8s.io<br/>inferencepools"]
    end

    %% Exec role chain
    SA_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| Role_Exec
    Role_Exec -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| Role_SSRF
    Role_SSRF -->|"get, watch, list"| Pods
    Role_SSRF -->|"get, watch, list"| InferencePools

    %% Styling
    style SA_Auth fill:#4a90e2,stroke:#333,color:#fff
    style SA_Placeholder fill:#4a90e2,stroke:#333,color:#fff
    style RB_Exec fill:#9b59b6,stroke:#333,color:#fff
    style RB_SSRF fill:#9b59b6,stroke:#333,color:#fff
    style Role_Exec fill:#f5a623,stroke:#333
    style Role_SSRF fill:#f5a623,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style InferencePools fill:#7ed321,stroke:#333
