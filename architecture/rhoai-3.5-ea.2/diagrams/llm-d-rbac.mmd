graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Interactive["interactive-pod<br/>(ServiceAccount)<br/>Namespace: deployment NS"]
        SA_ModelServer["model-server SA<br/>(ServiceAccount)<br/>automountServiceAccountToken: false"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Interactive["interactive-pod-editor-binding<br/>(RoleBinding)<br/>Namespace-scoped"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        Role_Interactive["interactive-pod-editor<br/>(Role)"]
    end

    subgraph APIResources["API Resources"]
        Pods["core<br/>pods, pods/log,<br/>pods/exec, pods/portforward"]
        Services["core<br/>services"]
        Deployments["apps<br/>deployments"]
        StatefulSets["apps<br/>statefulsets"]
        Jobs["batch<br/>jobs"]
        ConfigMaps["core<br/>configmaps"]
        Secrets_Res["core<br/>secrets"]
        Events["core<br/>events"]
        InferencePool["inference.networking.x-k8s.io<br/>inferencepools"]
        InferenceModel["inference.networking.x-k8s.io<br/>inferencemodels"]
    end

    subgraph ExternalSecrets["Secrets Referenced"]
        HFToken["hf-token<br/>Type: Opaque<br/>Hugging Face API token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        EPPToken["epp-token-secret<br/>Type: Opaque<br/>EPP auth token<br/>Provisioned: Manual (kustomize)<br/>Auto-Rotate: No"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        NoAuth["Container-level: None<br/>(auth added at platform level)"]
        PlatformAuth["RHOAI Platform:<br/>kube-rbac-proxy sidecar<br/>or OAuth proxy"]
        SAToken["EPP → K8s API:<br/>ServiceAccount Token<br/>HTTPS/6443"]
        BearerToken["vLLM → HF Hub:<br/>Bearer Token (HF_TOKEN)<br/>HTTPS/443"]
    end

    %% RBAC bindings
    SA_Interactive -->|"bound via"| RB_Interactive
    RB_Interactive -->|"grants"| Role_Interactive

    %% Role permissions
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Pods
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Services
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Deployments
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| StatefulSets
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Jobs
    Role_Interactive -->|"get, list, watch"| ConfigMaps
    Role_Interactive -->|"get, list, watch"| Secrets_Res
    Role_Interactive -->|"get, list, watch"| Events
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| InferencePool
    Role_Interactive -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| InferenceModel

    %% Model server has no API access
    SA_ModelServer -->|"NO Kubernetes API access<br/>(token not mounted)"| NoAuth

    %% Styling
    style SA_Interactive fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_ModelServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RB_Interactive fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Role_Interactive fill:#f5a623,stroke:#333,stroke-width:2px
    style Pods fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Services fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Deployments fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style StatefulSets fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Jobs fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ConfigMaps fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Secrets_Res fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Events fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style InferencePool fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style InferenceModel fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style HFToken fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style EPPToken fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style NoAuth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style PlatformAuth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style SAToken fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style BearerToken fill:#fff2cc,stroke:#d6b656,stroke-width:2px
