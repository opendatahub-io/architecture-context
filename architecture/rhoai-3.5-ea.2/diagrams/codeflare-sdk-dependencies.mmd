graph LR
    SDK["CodeFlare SDK<br/>v0.37.0<br/>Python Client Library"]

    %% Internal Platform Dependencies (via Kubernetes API)
    SDK -->|"creates RayCluster CRs<br/>ray.io/v1"| KubeRay["KubeRay Operator<br/>(reconciles clusters)"]
    SDK -->|"creates RayJob CRs<br/>ray.io/v1"| KubeRayJob["KubeRay Operator<br/>(reconciles jobs)"]
    SDK -->|"list LocalQueues,<br/>get WorkloadPriorityClass"| Kueue["Kueue<br/>kueue.x-k8s.io/v1beta1"]
    SDK -->|"list/get HTTPRoutes,<br/>get Gateway"| GatewayAPI["RHOAI Gateway<br/>gateway.networking.k8s.io/v1"]
    SDK -->|"get GatewayConfig"| GatewayConfig["ODH/RHOAI GatewayConfig<br/>services.platform.opendatahub.io/v1alpha1"]
    SDK -.->|"list Routes<br/>(RHOAI 2.x fallback)"| OSRoutes["OpenShift Routes<br/>route.openshift.io/v1"]
    SDK -.->|"list Ingresses<br/>(vanilla K8s fallback)"| K8sIngress["Kubernetes Ingress<br/>networking.k8s.io/v1"]

    %% Direct Runtime Connections
    SDK -->|"job submission<br/>8265/TCP mTLS"| RayDashboard["Ray Head Node<br/>(Dashboard)"]
    SDK -->|"ray.init()<br/>10001/TCP mTLS"| RayClient["Ray Head Node<br/>(Client Port)"]

    %% External Python Dependencies
    SDK -->|"distributed computing"| Ray["ray 2.55.1"]
    SDK -->|"K8s API client"| K8sPython["kubernetes >= 27.2.0"]
    SDK -->|"authentication"| KubeAuthkit["kube-authkit >= 0.4.0"]
    SDK -->|"OpenShift support"| OSClient["openshift-client 1.0.18"]
    SDK -->|"TLS cert generation"| Cryptography["cryptography 46.0.7"]
    SDK -->|"config validation"| Pydantic["pydantic >= 2.10.6"]
    SDK -->|"terminal output"| Rich["rich >= 12.5, < 15.0"]
    SDK -->|"notebook widgets"| IPyWidgets["ipywidgets 8.1.2"]

    %% Platform Resources (read-only)
    SDK -.->|"reads CA cert"| CASecret["CA Secret<br/>(KubeRay-provisioned)"]
    SDK -.->|"mounted in pods"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    SDK -.->|"default images"| RayImages["RHOAI Ray Images<br/>quay.io/modh/ray"]

    %% Infrastructure
    SDK -->|"all API operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

