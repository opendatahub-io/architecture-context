graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (Stateless)"]
        Gateway["vllm-orchestrator-gateway<br/>Rust/Axum Service<br/>8090/TCP HTTP (plaintext)<br/>POST /{route}/v1/chat/completions<br/>No auth enforcement"]
    end

    subgraph ConfigMounts["CONFIGURATION (Mounted)"]
        direction LR
        Config["config.yaml<br/>(ConfigMap)<br/>GATEWAY_CONFIG env"]
        ClientCert["TLS Client Cert<br/>/etc/tls/private/<br/>tls.crt + tls.key<br/>(kubernetes.io/tls)"]
        CACert["CA Certificate<br/>/etc/tls/ca/<br/>service-ca.crt<br/>(Service CA)"]
    end

    subgraph UpstreamServices["UPSTREAM SERVICES (Internal Platform)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>POST /api/v2/chat/completions-detection<br/>8085/TCP (configurable)<br/>HTTP or HTTPS"]

        subgraph OrchestratorBackends["Orchestrator Backends (Indirect)"]
            Detectors["Guardrails Detectors<br/>(e.g., regex-language)<br/>Content filtering"]
            LLM["vLLM / LLM Inference<br/>Chat completion generation"]
        end

        Orchestrator --> Detectors
        Orchestrator --> LLM
    end

    %% External → Gateway
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header<br/>(pass-through)"| Gateway

    %% Config mounts
    Config -.->|"startup read"| Gateway
    ClientCert -.->|"optional mTLS identity"| Gateway
    CACert -.->|"CA verification"| Gateway

    %% Gateway → Orchestrator
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>(openssl + native-tls)<br/>Authorization forwarded<br/>x-forwarded-* forwarded"| Orchestrator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#f5f5f5,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5
    classDef upstream fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef indirect fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class Gateway gateway
    class Config,ClientCert,CACert config
    class Orchestrator upstream
    class Detectors,LLM indirect
