graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB

        subgraph SharedFramework["Common JobController Framework"]
            CommonController["Common JobController<br/>Pod/Service lifecycle<br/>Expectation tracking<br/>Gang scheduling<br/>Status management"]
        end

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller<br/>Master/Worker topology<br/>Elastic training (HPA)"]
            TFCtrl["TFJob Controller<br/>PS/Worker/Chief/Evaluator"]
            XGBoostCtrl["XGBoostJob Controller<br/>Master/Worker + Rabit"]
            MPICtrl["MPIJob Controller<br/>Launcher/Worker + kubectl exec"]
            PaddleCtrl["PaddleJob Controller<br/>Collective or PS mode"]
            JAXCtrl["JAXJob Controller<br/>Worker-only (coordinator=worker-0)"]
        end

        subgraph Webhooks["Validating Webhooks (9443/TCP HTTPS)"]
            WHPyTorch["PyTorchJob Webhook"]
            WHTFJob["TFJob Webhook"]
            WHXGBoost["XGBoostJob Webhook"]
            WHJAXJob["JAXJob Webhook"]
            WHPaddle["PaddleJob Webhook"]
        end

        subgraph Observability["Observability"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP"]
            Health["Health/Ready Probes<br/>8081/TCP HTTP"]
        end

        PyTorchCtrl --> CommonController
        TFCtrl --> CommonController
        XGBoostCtrl --> CommonController
        MPICtrl --> CommonController
        PaddleCtrl --> CommonController
        JAXCtrl --> CommonController
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| PyTorchJobCR["PyTorchJob CR"]
    User -->|creates| TFJobCR["TFJob CR"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR"]
    User -->|creates| MPIJobCR["MPIJob CR"]
    User -->|creates| PaddleJobCR["PaddleJob CR"]
    User -->|creates| JAXJobCR["JAXJob CR"]

    %% CRD to Controller mapping
    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MPIJobCR -->|watched by| MPICtrl
    PaddleJobCR -->|watched by| PaddleCtrl
    JAXJobCR -->|watched by| JAXCtrl

    %% Webhook validation
    K8sAPI["Kubernetes API Server"] -->|admission callback| Webhooks

    %% Resources created
    CommonController -->|creates| WorkerPods["Worker/Master Pods"]
    CommonController -->|creates| HeadlessSvc["Headless Services<br/>(inter-pod networking)"]
    CommonController -->|creates| PodGroups["PodGroup CRs<br/>(gang scheduling)"]

    %% External integrations
    Metrics -.->|scraped by| Prometheus["Prometheus<br/>(openshift-monitoring)"]
    CommonController -->|CRUD via| K8sAPI

    %% Styling
    style TrainingOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style SharedFramework fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style Controllers fill:#fff3e0,stroke:#e65100,stroke-width:1px
    style Webhooks fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style Observability fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px

    style PyTorchCtrl fill:#4a90e2,color:#fff
    style TFCtrl fill:#4a90e2,color:#fff
    style XGBoostCtrl fill:#4a90e2,color:#fff
    style MPICtrl fill:#4a90e2,color:#fff
    style PaddleCtrl fill:#4a90e2,color:#fff
    style JAXCtrl fill:#4a90e2,color:#fff
    style CommonController fill:#2e7d32,color:#fff

    style PyTorchJobCR fill:#f5a623
    style TFJobCR fill:#f5a623
    style XGBoostJobCR fill:#f5a623
    style MPIJobCR fill:#f5a623
    style PaddleJobCR fill:#f5a623
    style JAXJobCR fill:#f5a623

    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style WorkerPods fill:#7ed321
    style HeadlessSvc fill:#7ed321
    style PodGroups fill:#7ed321
