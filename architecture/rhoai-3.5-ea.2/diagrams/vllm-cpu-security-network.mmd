graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Gateway"]
    end

    subgraph Platform["PLATFORM (KServe / ModelMesh)"]
        direction TB
        KServe["KServe ServingRuntime<br/>Manages container lifecycle"]
    end

    subgraph Workload["SERVICE (Non-root UID 2000, GID 0)"]
        direction TB

        subgraph Container["vllm-cpu Container (UBI 9 minimal)"]
            direction TB

            HTTPServer["HTTP API Server<br/>FastAPI + Uvicorn<br/>8000/TCP HTTP<br/>TLS optional (--ssl-keyfile)<br/>Auth: API key (optional)"]
            GRPCServ["gRPC Server (Optional)<br/>50051/TCP gRPC/HTTP2<br/>INSECURE (no TLS)<br/>Auth: None"]
            Engine["vLLM Engine (v1)<br/>PyTorch CPU + C++ Kernels<br/>IPEX (x86_64)"]

            HTTPServer --> Engine
            GRPCServ --> Engine
        end
    end

    subgraph Storage["LOCAL STORAGE"]
        ModelPVC["Model Storage<br/>PVC / S3 Mount<br/>Filesystem I/O<br/>Read-only"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Scraper"]
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN Bearer"]
        Stats["stats.vllm.ai<br/>443/TCP HTTPS<br/>DISABLED<br/>(VLLM_NO_USAGE_STATS=1)"]
        Tiktoken["tiktoken registry<br/>443/TCP HTTPS<br/>Pre-cached in image"]
    end

    %% Flows
    Client -->|"HTTP/8000<br/>TLS optional<br/>API key (optional)"| HTTPServer
    Client -->|"gRPC/50051<br/>INSECURE<br/>No auth"| GRPCServ

    KServe -.->|"Container lifecycle<br/>management"| Container

    Prometheus -->|"HTTP/8000<br/>GET /metrics<br/>No auth"| HTTPServer

    Engine -->|"Filesystem I/O<br/>No encryption<br/>POSIX perms"| ModelPVC
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HFHub
    Engine -.->|"DISABLED"| Stats
    Engine -.->|"Pre-cached<br/>in image"| Tiktoken

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef disabled fill:#f0f0f0,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class KServe platform
    class HTTPServer,GRPCServ,Engine workload
    class ModelPVC storage
    class Prometheus monitoring
    class HFHub egress
    class Stats,Tiktoken disabled
