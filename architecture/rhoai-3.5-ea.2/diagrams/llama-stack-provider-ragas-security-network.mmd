graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod Network)"]
        direction TB

        subgraph NS_App["Namespace: {user-namespace}"]
            subgraph LlamaStackPod["Llama Stack Server Pod"]
                direction LR
                InlineProvider["Inline Provider<br/>In-process eval<br/>No network egress"]
                RemoteProvider["Remote Provider<br/>KFP pipeline submission<br/>S3 result retrieval"]
            end
        end

        subgraph NS_Ollama["Namespace: {ollama-namespace}"]
            Ollama["Ollama<br/>SA: default<br/>11434/TCP HTTP"]
        end

        subgraph NS_KFP["Namespace: {kfp-namespace}"]
            KFPPods["KFP Pipeline Pods<br/>Step 1: retrieve_data<br/>Step 2: run_ragas_evaluation<br/>Secrets: aws-credentials,<br/>kubeflow-pipelines-token"]
        end

        subgraph NS_TrustyAI["Namespace: redhat-ods-applications"]
            TrustyAICM["TrustyAI Operator ConfigMap<br/>trustyai-service-operator-config<br/>Key: ragas-provider-image"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        KFP_API["Kubeflow Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (OAuth)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / kubeconfig"]
    end

    %% External to internal
    Client -->|"HTTP/8321<br/>No TLS<br/>No Auth<br/>(platform-level auth)"| LlamaStackPod

    %% Internal flows
    InlineProvider -->|"In-process<br/>Inference API"| Ollama
    LlamaStackPod -->|"HTTP/11434<br/>No TLS<br/>No Auth"| Ollama

    %% Remote provider egress
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KFP_API
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% KFP pod flows
    KFPPods -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LlamaStackPod
    KFPPods -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% ConfigMap read
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| TrustyAICM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef clusterInternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class LlamaStackPod,InlineProvider,RemoteProvider pod
    class Ollama,KFPPods,TrustyAICM clusterInternal
    class KFP_API,S3,K8sAPI externalService
