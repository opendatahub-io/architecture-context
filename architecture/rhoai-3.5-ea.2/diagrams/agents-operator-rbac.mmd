graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>NS: kagenti-system"]
        SA_BS["bundle-service<br/>NS: kagenti-system"]
        SA_Agent["default SA<br/>NS: agent namespace<br/>(dynamic)"]
        SA_OTel["otel-collector<br/>NS: agent namespaces"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_SCC["kagenti-operator-scc-authbridge<br/>(ClusterRoleBinding)"]
        CRB_AgentSCC["agent-authbridge-scc<br/>(ClusterRoleBinding, dynamic)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>NS: kagenti-system"]
        RB_MLflow["kagenti-mlflow-NAME<br/>NS: agent namespace<br/>(dynamic, per agent)"]
        RB_OTelMLflow["otel-collector-mlflow<br/>NS: agent + MLflow NS<br/>(dynamic)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_SCC["system:openshift:scc:<br/>kagenti-authbridge<br/>(ClusterRole)"]
        CR_MLflowEdit["mlflow-operator-<br/>mlflow-edit<br/>(ClusterRole, bind)"]
        CR_MLflowInteg["mlflow-operator-<br/>mlflow-integration<br/>(ClusterRole, bind)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role<br/>NS: kagenti-system"]
        R_MLflow["kagenti-mlflow-NAME<br/>NS: agent namespace<br/>(dynamic)"]
    end

    subgraph KagentiResources["agent.kagenti.dev Resources"]
        AgentCards["AgentCards<br/>agentcards/finalizers<br/>agentcards/status"]
        AgentRuntimes["AgentRuntimes<br/>agentruntimes/finalizers<br/>agentruntimes/status"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["ConfigMaps"]
        Secrets["Secrets"]
        Pods["Pods"]
        Services["Services"]
        ServiceAccts["ServiceAccounts"]
        Namespaces["Namespaces"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["Deployments<br/>deployments/finalizers"]
        StatefulSets["StatefulSets<br/>statefulsets/finalizers"]
        DaemonSets["DaemonSets"]
    end

    subgraph NetworkResources["Networking Resources"]
        NetworkPolicies["NetworkPolicies"]
        Ingresses["Ingresses"]
    end

    subgraph PlatformCRDs["Platform CRD Resources"]
        CertMgrRes["cert-manager.io<br/>Certificates, Issuers<br/>ClusterIssuers"]
        KeycloakRes["k8s.keycloak.org<br/>Keycloaks<br/>KeycloakRealmImports"]
        DSCRes["datasciencecluster<br/>DataScienceClusters"]
        MLflowRes["mlflow.opendatahub.io<br/>MLflows"]
        KuadrantRes["kuadrant.io<br/>Kuadrants"]
        TektonRes["operator.tekton.dev<br/>TektonConfigs"]
        RouteRes["route.openshift.io<br/>Routes"]
        NetworkOpRes["operator.openshift.io<br/>Networks, ZTWIMs"]
        SandboxRes["agents.x-k8s.io<br/>Sandboxes<br/>sandboxes/finalizers<br/>sandboxes/scale"]
    end

    subgraph SCCResource["Security Context Constraint"]
        SCC["kagenti-authbridge SCC<br/>Allows: CSI volumes (csi.spiffe.io)<br/>NET_ADMIN, RunAsUser 1337"]
    end

    %% Service Account to Binding
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_SCC
    SA_CM -->|bound via| RB_Leader
    SA_Agent -->|bound via| CRB_AgentSCC
    SA_OTel -->|bound via| RB_OTelMLflow

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_SCC -->|grants| CR_SCC
    CRB_AgentSCC -->|grants| CR_SCC
    RB_Leader -->|grants| R_Leader
    RB_MLflow -->|grants| R_MLflow
    RB_OTelMLflow -->|grants| CR_MLflowInteg

    %% Manager Role to Resources
    CR_Manager -->|"CRUD + watch"| AgentCards
    CR_Manager -->|"CRUD + watch"| AgentRuntimes
    CR_Manager -->|"CRUD + watch"| ConfigMaps
    CR_Manager -->|"CRUD + watch"| Secrets
    CR_Manager -->|"get,list,patch,watch"| Pods
    CR_Manager -->|"CRUD + watch"| Services
    CR_Manager -->|"create,get,list,patch,watch"| Namespaces
    CR_Manager -->|"get,list,patch,update,watch"| Deployments
    CR_Manager -->|"CRUD + watch"| StatefulSets
    CR_Manager -->|"CRUD + watch"| NetworkPolicies
    CR_Manager -->|"CRUD + watch"| CertMgrRes
    CR_Manager -->|"create,get,list,patch,update"| KeycloakRes
    CR_Manager -->|"get,list,watch"| DSCRes
    CR_Manager -->|"CRUD + watch"| MLflowRes
    CR_Manager -->|"CRUD + watch"| KuadrantRes
    CR_Manager -->|"get,list,patch,watch"| TektonRes
    CR_Manager -->|"create,get,list,update"| RouteRes
    CR_Manager -->|"get,list"| NetworkOpRes
    CR_Manager -->|"get,list,patch,update,watch"| SandboxRes

    %% SCC Role
    CR_SCC -->|"use"| SCC

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_BS fill:#4a90e2,color:#fff
    style SA_Agent fill:#4a90e2,color:#fff
    style SA_OTel fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
    style CR_MLflowEdit fill:#f5a623,color:#fff
    style CR_MLflowInteg fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style R_MLflow fill:#f5a623,color:#fff
    style AgentCards fill:#7ed321,color:#fff
    style AgentRuntimes fill:#7ed321,color:#fff
    style SCC fill:#e74c3c,color:#fff
