graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["planner-gpu-reader<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["planner-gpu-reader<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core<br/>nodes"]
    end

    subgraph Verbs["Allowed Operations"]
        ListVerb["list"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"list"| Nodes

    subgraph AppLevelAuth["Application-Level Authentication"]
        direction TB

        subgraph AdminEndpoints["Admin Database Endpoints"]
            UploadBenchmarks["/api/v1/db/upload-benchmarks<br/>POST"]
            ResetDB["/api/v1/db/reset<br/>POST"]
            VerifyAdmin["/api/v1/db/verify-admin<br/>POST"]
        end

        subgraph AuthMechanism["Auth Mechanism"]
            HMAC["x-admin-password header<br/>HMAC comparison<br/>(DB_ADMIN_PASSWORD env)"]
        end

        subgraph PublicEndpoints["Public Endpoints (No Auth)"]
            AllOther["All other /api/v1/* endpoints<br/>(27 endpoints total)<br/>Relies on network isolation"]
        end
    end

    UploadBenchmarks -->|"optional"| HMAC
    ResetDB -->|"required (if password set)"| HMAC
    VerifyAdmin -->|"verification"| HMAC

    subgraph SecretAccess["Secrets Accessed"]
        PlannerSecrets["planner-secrets (Opaque)<br/>- PostgreSQL password<br/>- HF_TOKEN<br/>- MODEL_CATALOG_TOKEN<br/>- LLM provider credentials<br/>- DB_ADMIN_PASSWORD<br/>Manual provisioning, No auto-rotate"]
        ServiceCA["planner-service-ca (ConfigMap)<br/>- OpenShift service-serving CA cert<br/>Annotation-injected, Auto-rotate: Yes"]
    end

    SA -->|"mounts"| PlannerSecrets
    SA -->|"mounts"| ServiceCA

    subgraph ExternalAuth["External Service Authentication"]
        K8sAuth["Kubernetes API<br/>Auth: ServiceAccount Token<br/>Auto-mounted"]
        CatalogAuth["RHOAI Model Catalog<br/>Auth: Bearer Token<br/>(SA or explicit)"]
        HFAuth["HuggingFace Hub<br/>Auth: Bearer HF_TOKEN<br/>(optional)"]
        OpenAIAuth["OpenAI API<br/>Auth: Bearer OPENAI_API_KEY<br/>(conditional)"]
        VertexAuth["Vertex AI<br/>Auth: GCP IAM<br/>(conditional)"]
        PGAuth["PostgreSQL<br/>Auth: Password<br/>(DATABASE_URL)"]
        OllamaAuth["Ollama<br/>Auth: None"]
    end

    SA -->|"authenticates to"| K8sAuth
    SA -->|"authenticates to"| CatalogAuth
    PlannerSecrets -->|"provides credentials"| HFAuth
    PlannerSecrets -->|"provides credentials"| OpenAIAuth
    PlannerSecrets -->|"provides credentials"| VertexAuth
    PlannerSecrets -->|"provides credentials"| PGAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#f5a623,stroke:#333
    style CR fill:#f5a623,stroke:#333
    style Nodes fill:#7ed321,stroke:#333
    style ListVerb fill:#e8e8e8,stroke:#333
    style HMAC fill:#e06666,stroke:#333,color:#fff
    style PlannerSecrets fill:#cc0000,stroke:#333,color:#fff
    style ServiceCA fill:#cc6600,stroke:#333,color:#fff
    style AllOther fill:#d5e8d4,stroke:#82b366
    style UploadBenchmarks fill:#ffe6cc,stroke:#d79b00
    style ResetDB fill:#ffe6cc,stroke:#d79b00
    style VerifyAdmin fill:#ffe6cc,stroke:#d79b00
