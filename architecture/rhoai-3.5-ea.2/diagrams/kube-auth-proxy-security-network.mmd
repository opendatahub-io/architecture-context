graph TB
    subgraph External["EXTERNAL CLIENTS (Untrusted)"]
        Browser["Browser Client"]
        APIClient["API / CLI Client"]
    end

    subgraph PodBoundary["POD BOUNDARY (Sidecar Deployment)"]
        direction TB

        Envoy["Envoy Proxy<br/>(ext_authz caller)"]

        subgraph ProxyContainer["kube-auth-proxy Container"]
            Proxy["kube-auth-proxy<br/>HTTP: 4180/TCP<br/>HTTPS: 443/TCP (optional)<br/>TLS 1.2+ (min enforced)<br/>FIPS: strictfipsruntime"]
        end

        UpstreamApp["Upstream Application<br/>(pre-authenticated)"]

        Envoy -->|"HTTP/4180<br/>plaintext (pod-local)<br/>ext_authz subrequest<br/>Forwarded headers"| Proxy
        Proxy -->|"Configurable port<br/>HTTP/HTTPS/Unix<br/>No auth (pre-authed)<br/>GAP-Auth + X-Forwarded-*"| UpstreamApp
    end

    subgraph IdentityProviders["IDENTITY PROVIDERS (TLS-encrypted)"]
        OIDC["OIDC Provider<br/>(Keycloak / DEX)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client credentials"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>OAuth2 client credentials"]
    end

    subgraph K8sAPIs["KUBERNETES / OPENSHIFT APIs (TLS-encrypted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (in-cluster CA)<br/>SA token auth"]
        OSUserAPI["OpenShift User API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer token (user's)"]
        OAuthTokenAPI["OpenShift OAuthAccessToken API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer token (user's)"]
    end

    subgraph SessionStore["SESSION STORE (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Optional password + ACL"]
    end

    %% External → Proxy
    Browser -->|"HTTP(S)/4180 or 443<br/>TLS 1.2+ (configurable)<br/>Session cookie"| Proxy
    APIClient -->|"HTTP(S)/4180 or 443<br/>TLS 1.2+ (configurable)<br/>Bearer: sha256~ / JWT / SA token"| Proxy

    %% Proxy → Identity Providers
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds<br/>OIDC discovery + token exchange"| OIDC
    Proxy -->|"HTTPS/443<br/>TLS 1.2+ (custom CA)<br/>OAuth2 client creds<br/>Endpoint auto-discovery"| OSAuth

    %% Proxy → K8s APIs
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview POST"| K8sAPI
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>User bearer token<br/>GET /users/~"| OSUserAPI
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>User bearer token<br/>DELETE token on sign-out"| OAuthTokenAPI

    %% Proxy → Redis
    Proxy -.->|"6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Session persistence"| Redis

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef pod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef idp fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8sapi fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sessionstore fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef upstream fill:#e8d5f5,stroke:#9673a6,stroke-width:2px
    classDef envoy fill:#f5a623,stroke:#333,stroke-width:2px

    class Browser,APIClient external
    class Proxy proxy
    class Envoy envoy
    class UpstreamApp upstream
    class OIDC,OSAuth idp
    class K8sAPI,OSUserAPI,OAuthTokenAPI k8sapi
    class Redis sessionstore
