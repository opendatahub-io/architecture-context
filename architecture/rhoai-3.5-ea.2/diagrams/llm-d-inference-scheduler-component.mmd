graph TB
    subgraph LLMDScheduler["llm-d Inference Scheduler"]
        subgraph EPPComponent["EPP (Endpoint Picker)"]
            ExtProcServer["ext-proc gRPC Server<br/>9002/TCP TLS"]
            HealthServer["Health gRPC Server<br/>9003/TCP"]
            MetricsServer["Prometheus Metrics<br/>9090/TCP"]
            PluginPipeline["Plugin Pipeline<br/>(Filters → Scorers → Pickers)"]
            Datastore["Datastore<br/>(Pods, Models, Objectives)"]
            DataLayer["Data Layer<br/>(Collectors, Extractors)"]
            KVCacheIndexer["KV Cache Indexer<br/>(llm-d-kv-cache)"]

            ExtProcServer -->|scheduling request| PluginPipeline
            PluginPipeline -->|query state| Datastore
            PluginPipeline -->|query metrics| DataLayer
            DataLayer -->|KV cache state| KVCacheIndexer
        end

        subgraph SidecarComponent["Routing Sidecar (pd-sidecar)"]
            SidecarProxy["HTTP/HTTPS Proxy<br/>8000/TCP TLS 1.2+"]
            ConnectorNIXL["NIXL v2 Connector"]
            ConnectorShared["Shared Storage Connector"]
            ConnectorSGLang["SGLang Connector"]
            SSRFAllowlist["SSRF Allowlist<br/>(InferencePool watcher)"]
            DataParallel["Data Parallel Router"]

            SidecarProxy -->|P/D routing| ConnectorNIXL
            SidecarProxy -->|P/D routing| ConnectorShared
            SidecarProxy -->|P/D routing| ConnectorSGLang
            SidecarProxy -->|validate targets| SSRFAllowlist
            SidecarProxy -->|DP routing| DataParallel
        end
    end

    %% External Inputs
    Client["External Client"] -->|HTTPS/443| EnvoyGW["Envoy Gateway"]
    EnvoyGW -->|gRPC ext-proc<br/>9002/TCP TLS| ExtProcServer
    EnvoyGW -->|HTTP/HTTPS<br/>8000/TCP| SidecarProxy

    %% CRDs Watched
    InferencePoolCR["InferencePool CR"] -->|watched by| Datastore
    InferenceModelCR["InferenceModelRewrite CR"] -->|watched by| Datastore
    InferenceObjCR["InferenceObjective CR"] -->|watched by| Datastore
    InferencePoolCR -->|watched by| SSRFAllowlist

    %% EPP Egress
    DataLayer -->|scrape metrics<br/>HTTP/HTTPS| vLLMPods["vLLM Model Server Pods"]
    KVCacheIndexer -->|ZMQ SUB<br/>5556-5557/TCP| vLLMPods

    %% Sidecar Egress
    ConnectorNIXL -->|HTTP/HTTPS<br/>8001/TCP| LocalvLLM["Local vLLM Decoder"]
    ConnectorNIXL -->|HTTP/HTTPS| RemotePrefiller["Remote Prefiller Pods"]
    ConnectorShared -->|HTTP/HTTPS| RemotePrefiller
    ConnectorSGLang -->|HTTP/HTTPS| RemotePrefiller

    %% Routing Decision
    ExtProcServer -->|selected endpoint| EnvoyGW

    %% Observability
    ExtProcServer -.->|OTLP traces<br/>4317/TCP| OTELCollector["OTLP Collector"]
    SidecarProxy -.->|OTLP traces<br/>4317/TCP| OTELCollector

    %% Styling
    style EPPComponent fill:#4a90e2,stroke:#2c5aa0,color:#fff
    style SidecarComponent fill:#7ed321,stroke:#5ca018,color:#fff
    style ExtProcServer fill:#357abd,stroke:#2c5aa0,color:#fff
    style SidecarProxy fill:#6bb51a,stroke:#5ca018,color:#fff
    style EnvoyGW fill:#f5a623,stroke:#d4891a,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#d4891a
    style InferenceModelCR fill:#f5a623,stroke:#d4891a
    style InferenceObjCR fill:#f5a623,stroke:#d4891a
    style vLLMPods fill:#e8e8e8,stroke:#999
    style LocalvLLM fill:#e8e8e8,stroke:#999
    style RemotePrefiller fill:#e8e8e8,stroke:#999
    style OTELCollector fill:#e8e8e8,stroke:#999
    style Client fill:#f9f9f9,stroke:#999
