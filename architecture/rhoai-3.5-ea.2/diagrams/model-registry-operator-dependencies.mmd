graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Framework Dependencies
    MRO -->|"operator framework"| CR["controller-runtime<br/>v0.24.1"]
    MRO -->|"HTTPRoute CRDs"| GatewayAPI["gateway-api<br/>v1.5.1"]
    MRO -.->|"legacy conversion only"| Istio["istio/client-go<br/>v1.30.1"]
    MRO -.->|"Route, Group, Config APIs"| OSApi["openshift/api"]
    MRO -.->|"TLS security profiles"| OSCRCommon["openshift/controller-<br/>runtime-common"]
    MRO -.->|"chaos testing"| Chaos["operator-chaos"]

    %% Internal RHOAI Platform Dependencies
    MRO -->|"HTTPRoute parentRef"| DSGateway["Data Science Gateway<br/>(Gateway CR)"]
    MRO -->|"deployed by"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    MRO -->|"owner reference"| CompCR["components.platform.<br/>opendatahub.io/<br/>ModelRegistry"]
    MRO -->|"reads adminGroups"| AuthCR["services.platform.<br/>opendatahub.io/Auth"]

    %% Container Image Dependencies
    MRO -->|"deploys"| RegistryImg["model-registry<br/>REST service image"]
    MRO -->|"deploys sidecar"| KRPImg["kube-rbac-proxy<br/>image"]
    MRO -->|"auto-provisions"| PGImg["PostgreSQL 16<br/>image"]
    MRO -->|"init containers"| MetadataImg["odh-model-metadata-<br/>collection image"]

    %% Platform Infrastructure
    MRO -->|"CRD watches, RBAC"| K8sAPI["Kubernetes API<br/>Server"]
    MRO -.->|"ingress domain,<br/>TLS profile"| OSConfig["config.openshift.io<br/>(Ingress, APIServer)"]
    MRO -.->|"Group CRUD<br/>(traditional OCP)"| UserAPI["user.openshift.io"]
    MRO -->|"auto TLS certs"| ServingCert["OpenShift Serving<br/>Cert Controller"]
    MRO -->|"CRD migration"| SVM["StorageVersion<br/>Migration API"]

    %% Integration Points (who depends on MRO)
    Dashboard["ODH Dashboard"] -.->|"UI management"| MRO
    DSP["Data Science<br/>Pipelines"] -.->|"model deployment"| MRO

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External framework deps (gray)
    style CR fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#bbb,stroke:#333
    style OSApi fill:#bbb,stroke:#333
    style OSCRCommon fill:#bbb,stroke:#333
    style Chaos fill:#bbb,stroke:#333

    %% Internal RHOAI deps (green)
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style CompCR fill:#7ed321,stroke:#333,color:#fff
    style AuthCR fill:#7ed321,stroke:#333,color:#fff

    %% Container images (blue-green)
    style RegistryImg fill:#50b5a9,stroke:#333,color:#fff
    style KRPImg fill:#50b5a9,stroke:#333,color:#fff
    style PGImg fill:#50b5a9,stroke:#333,color:#fff
    style MetadataImg fill:#50b5a9,stroke:#333,color:#fff

    %% Platform infrastructure (orange)
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OSConfig fill:#f5a623,stroke:#333,color:#fff
    style UserAPI fill:#f5a623,stroke:#333,color:#fff
    style ServingCert fill:#f5a623,stroke:#333,color:#fff
    style SVM fill:#f5a623,stroke:#333,color:#fff

    %% Reverse deps (light green)
    style Dashboard fill:#a8e06c,stroke:#333
    style DSP fill:#a8e06c,stroke:#333
