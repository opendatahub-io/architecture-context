graph TB
    subgraph "Pipelines Components"
        direction TB

        subgraph "Init Container"
            InitContainer["pipelines-components<br/>Init Container<br/>(Python 3.12, UBI9)"]
            Compiler["Pipeline Compiler<br/>(generate_managed_pipelines.py)"]
            Stager["Pipeline Stager<br/>(init_managed_pipelines.py)"]
            InitContainer --> Compiler
            InitContainer --> Stager
        end

        subgraph "Runtime Containers"
            AutoML["odh-automl<br/>(AutoGluon, PyTorch)<br/>AIPCC CPU Base"]
            AutoRAG["odh-autorag<br/>(Docling, LangChain, ai4rag)<br/>AIPCC CPU Base"]
        end

        subgraph "Component Library (kfp-components)"
            DataProc["Data Processing<br/>Components"]
            Training["Training<br/>Components"]
            Evaluation["Evaluation<br/>Components"]
            Deployment["Deployment<br/>Components"]
        end

        subgraph "Build & Validation Toolchain"
            CompileCheck["compile_check.py"]
            MetadataVal["validate_metadata.py"]
            BaseImageVal["validate_base_images.py"]
            Skeleton["generate_skeleton.py"]
            ReadmeGen["generate_readme"]
        end
    end

    %% Init Container Flow
    Compiler -->|"compiles managed: true<br/>pipelines at build time"| PipelineYAML["Compiled Pipeline<br/>YAML Specs"]
    Stager -->|"copies to shared volume<br/>/config/managed-pipelines"| SharedVol[("Shared Volume<br/>/config/managed-pipelines")]

    %% Runtime container usage
    DataProc -->|"base_image"| AutoML
    Training -->|"base_image"| AutoML
    DataProc -->|"base_image"| AutoRAG
    Training -->|"base_image"| AutoRAG

    %% RELATED_IMAGE override
    EnvVars["RELATED_IMAGE_*<br/>Environment Variables"] -.->|"triggers recompilation<br/>from source"| Compiler

    %% External consumers
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys init container<br/>in KFP API server pod"| InitContainer
    KFPServer["KFP API Server"] -->|"reads managed<br/>pipeline YAMLs"| SharedVol
    KFPOrch["KFP Orchestrator"] -->|"executes pipeline steps<br/>using component definitions"| DataProc
    KFPOrch -->|"executes pipeline steps"| Training
    KFPOrch -->|"executes pipeline steps"| Evaluation
    KFPOrch -->|"executes pipeline steps"| Deployment

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style AutoML fill:#e67e22,stroke:#333,color:#fff
    style AutoRAG fill:#e67e22,stroke:#333,color:#fff
    style DataProc fill:#27ae60,stroke:#333,color:#fff
    style Training fill:#27ae60,stroke:#333,color:#fff
    style Evaluation fill:#27ae60,stroke:#333,color:#fff
    style Deployment fill:#27ae60,stroke:#333,color:#fff
    style SharedVol fill:#f5a623,stroke:#333
    style DSPO fill:#9b59b6,stroke:#333,color:#fff
    style KFPServer fill:#9b59b6,stroke:#333,color:#fff
    style KFPOrch fill:#9b59b6,stroke:#333,color:#fff
    style CompileCheck fill:#95a5a6,stroke:#333
    style MetadataVal fill:#95a5a6,stroke:#333
    style BaseImageVal fill:#95a5a6,stroke:#333
    style Skeleton fill:#95a5a6,stroke:#333
    style ReadmeGen fill:#95a5a6,stroke:#333
