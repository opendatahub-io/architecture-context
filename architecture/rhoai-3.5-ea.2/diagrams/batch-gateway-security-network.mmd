graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(OpenAI-compatible)"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        GW["API Gateway (Kuadrant/Authorino)<br/>HTTPRoute → /v1/batches, /v1/files<br/>Auth: API Key / SA Token / OpenShift Token"]
    end

    subgraph Internal["INTERNAL (Cluster Network)"]
        direction TB

        subgraph NS_BG["Namespace: batch-gateway"]
            direction TB
            APIServer["API Server<br/>Port: 8000/TCP (API)<br/>Port: 8081/TCP (observability)<br/>SA: batch-gateway-apiserver<br/>Image: odh-llm-d-batch-gateway-apiserver"]
            Processor["Processor<br/>Port: 9090/TCP (metrics only)<br/>SA: batch-gateway-processor<br/>Image: odh-llm-d-batch-gateway-processor<br/>Volume: emptyDir (work artifacts)"]
            GC["Garbage Collector<br/>Port: 9091/TCP (metrics only)<br/>SA: batch-gateway-gc<br/>Image: odh-llm-d-batch-gateway-gc<br/>Replica: 1 (singleton)"]
        end

        subgraph NS_Obs["Observability"]
            Prometheus["Prometheus<br/>ServiceMonitor + PodMonitor"]
            OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP"]
            Grafana["Grafana<br/>Dashboard ConfigMap sidecar"]
        end
    end

    subgraph DataStores["DATA STORES"]
        PostgreSQL["PostgreSQL 12+<br/>5432/TCP<br/>pgx wire protocol<br/>TLS 1.2+"]
        Redis["Redis 6+ / Valkey 8+<br/>6379/TCP<br/>RESP protocol<br/>Optional TLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        LLMd["llm-d Inference Endpoint<br/>Configured/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.2+ with custom CA/mTLS"]
    end

    %% External → Ingress
    Client -->|"HTTPS or HTTP<br/>Optional TLS 1.2+<br/>Auth: API Key / SA Token"| GW

    %% Ingress → Internal
    GW -->|"HTTP/8000<br/>Optional TLS 1.2+<br/>X-MaaS-Username: tenant"| APIServer

    %% API Server → Data Stores
    APIServer -->|"pgx/5432<br/>TLS 1.2+<br/>Connection URL creds"| PostgreSQL
    APIServer -->|"RESP/6379<br/>Optional TLS<br/>Connection URL creds"| Redis
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Processor → Data Stores + Inference
    Processor -->|"pgx/5432<br/>TLS 1.2+<br/>Connection URL creds"| PostgreSQL
    Processor -->|"RESP/6379<br/>Optional TLS<br/>Connection URL creds"| Redis
    Processor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Processor -->|"HTTP(S)/Configured<br/>Optional TLS 1.2+<br/>Bearer Token"| LLMd

    %% GC → Data Stores
    GC -->|"pgx/5432<br/>TLS 1.2+<br/>Connection URL creds"| PostgreSQL
    GC -->|"RESP/6379<br/>Optional TLS<br/>Connection URL creds"| Redis
    GC -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Observability (dashed)
    APIServer -.->|"HTTP/8081<br/>No auth"| Prometheus
    Processor -.->|"HTTP/9090<br/>No auth"| Prometheus
    GC -.->|"HTTP/9091<br/>No auth"| Prometheus
    APIServer -.->|"gRPC/4317<br/>OTLP<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class GW ingress
    class APIServer,Processor,GC internal
    class PostgreSQL,Redis datastore
    class S3,LLMd externalservice
    class Prometheus,OTel,Grafana observability
