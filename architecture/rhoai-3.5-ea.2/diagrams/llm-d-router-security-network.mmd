graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway / Proxy Layer)"]
        Envoy["Envoy Proxy<br/>443/TCP → internal routing<br/>TLS 1.3 SIMPLE<br/>Gateway API HTTPRoute or Standalone"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph EPPPod["EPP Pod — NS: ${NAMESPACE} — SA: ${EPP_NAME}"]
            EPP["Endpoint Picker (EPP)<br/>Image: odh-llm-d-inference-scheduler<br/>9002/TCP gRPC ext-proc (TLS)<br/>9003/TCP gRPC health (plain)<br/>9090/TCP Prometheus (plain)<br/>5557/TCP ZMQ SUB (plain)<br/>⚠ No strictfipsruntime tag"]
        end

        subgraph SidecarPod["Decode Pod with Sidecar — NS: ${NAMESPACE}"]
            Sidecar["PD Sidecar<br/>Image: odh-llm-d-routing-sidecar<br/>8000/TCP HTTP(S)<br/>TLS 1.2+ MinVersion<br/>ECDHE+AES/CHACHA20 ciphers<br/>✓ strictfipsruntime<br/>SSRF protection available"]
        end

        ModelServers["Model Servers (vLLM/SGLang)<br/>8000/TCP metrics + inference<br/>⚠ InsecureSkipVerify=true default"]
        Tokenizer["Tokenizer Service<br/>UDS or HTTP<br/>Plaintext"]
        LatencyPredictor["Latency Predictor<br/>HTTP configurable port<br/>Plaintext"]
        PrefillServer["Remote Prefill Server<br/>dynamic/TCP<br/>TLS 1.2+ (optional)"]
        EncoderServer["Remote Encoder Server<br/>dynamic/TCP<br/>TLS 1.2+ (optional)"]
        LocalDecode["Local Decode vLLM<br/>8001/TCP<br/>TLS 1.2+ (optional)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>Plaintext"]
        MooncakeBoot["Mooncake Bootstrap<br/>8998/TCP HTTP<br/>Plaintext"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Auth: Varies (passthrough)"| Envoy

    %% Ingress → Internal
    Envoy -->|"gRPC/9002<br/>TLS (self-signed or cert)<br/>Auth: None (transport TLS)"| EPP
    Envoy -->|"HTTP(S)/8000<br/>TLS 1.2+ (optional)<br/>Auth: None"| Sidecar

    %% EPP → Internal
    EPP -->|"HTTP/8000<br/>⚠ InsecureSkipVerify=true<br/>Auth: None"| ModelServers
    EPP -->|"HTTP or UDS<br/>Plaintext<br/>Auth: None"| Tokenizer
    EPP -->|"HTTP<br/>Plaintext<br/>Auth: None"| LatencyPredictor

    %% EPP → External
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>Auth: SA Bearer Token"| K8sAPI
    EPP -.->|"gRPC/4317<br/>Plaintext<br/>Auth: None"| OTLP

    %% Sidecar → Internal
    Sidecar -->|"HTTP(S)/dynamic<br/>TLS 1.2+ (optional)<br/>Auth: None"| PrefillServer
    Sidecar -->|"HTTP(S)/dynamic<br/>TLS 1.2+ (optional)<br/>Auth: None"| EncoderServer
    Sidecar -->|"HTTP(S)/8001<br/>TLS 1.2+ (optional)<br/>Auth: None"| LocalDecode

    %% Sidecar → External (optional)
    Sidecar -.->|"HTTPS/443<br/>TLS<br/>Auth: SA Token"| K8sAPI
    Sidecar -.->|"HTTP/8998<br/>Plaintext"| MooncakeBoot

    %% Envoy → Model Server (routed)
    Envoy -->|"HTTP/8000<br/>Routed by EPP decision<br/>Auth: None"| ModelServers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Envoy ingress
    class EPP,Sidecar,PrefillServer,EncoderServer,LocalDecode internal
    class ModelServers,Tokenizer,LatencyPredictor warning
    class K8sAPI,OTLP,MooncakeBoot externalservice
