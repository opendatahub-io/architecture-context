graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Dashboard / CLI / SDK)"]
        IDE["IDE<br/>(Cursor / VS Code / Claude Code)"]
    end

    subgraph AuthBoundary["INGRESS (Auth Boundary)"]
        KRBP["kube-rbac-proxy<br/>443/TCP → 8080/TCP<br/>TLS 1.2+<br/>Bearer Token Validation<br/>Injects X-Tenant + X-User"]
    end

    subgraph EvalHubPod["EVAL-HUB POD (Trusted, pod-local)"]
        direction TB
        API["eval-hub API<br/>8080/TCP HTTP (API)<br/>8081/TCP HTTP (metrics)<br/>Image: quay.io/rhoai/odh-eval-hub-rhel9<br/>FIPS: strictfipsruntime"]
        MCPServer["evalhub-mcp<br/>3001/TCP HTTP or stdio<br/>Auth: rbac-proxy (cluster) / none (local)"]
    end

    subgraph EvalJobPod["EVALUATION JOB POD (K8s Job, ephemeral)"]
        direction TB
        Init["eval-runtime-init<br/>(Init Container)<br/>No network listener<br/>FIPS: strictfipsruntime"]
        RuntimeContainer["Evaluation Runtime<br/>(LM Eval Harness / Lighteval /<br/>Garak / GuiDeLLM / IBM CLEAR)"]
        SidecarProxy["eval-runtime-sidecar<br/>8080/TCP HTTP<br/>TLS 1.2+ outbound<br/>CA: /etc/pki/ca-trust/..."]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token (auto-rotated)"]
        PG["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>DB Credentials (secret)"]
        MLflow["MLflow Tracking<br/>configurable port<br/>HTTPS, TLS optional<br/>Bearer Token (5-min cache)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker config.json<br/>→ OCI v2 auth challenge"]
        OTEL["OTEL Collector<br/>4317/TCP gRPC<br/>TLS optional<br/>No Auth"]
        Prom["Prometheus<br/>scrapes 8081/TCP<br/>HTTP, No Auth"]
    end

    %% External → Auth
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KRBP
    IDE -->|"stdio or HTTP/3001<br/>TLS optional<br/>None or rbac-proxy"| MCPServer

    %% Auth → Eval Hub
    KRBP -->|"HTTP/8080<br/>None (pod-local)<br/>X-Tenant + X-User"| API

    %% MCP → API
    MCPServer -->|"HTTP(S)/8080<br/>TLS optional<br/>Bearer EVALHUB_TOKEN"| API

    %% Eval Hub → External Services
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    API -->|"TCP/5432<br/>TLS optional<br/>DB Creds"| PG
    API -->|"HTTP(S)<br/>TLS optional<br/>Bearer Token"| MLflow
    API -->|"gRPC/4317<br/>TLS optional<br/>None"| OTEL
    Prom -->|"HTTP/8081<br/>None<br/>No Auth"| API

    %% Job Pod flows
    Init -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM Creds"| S3
    RuntimeContainer -->|"HTTP/8080<br/>None (pod-local)<br/>No Auth"| SidecarProxy
    SidecarProxy -->|"HTTPS<br/>TLS 1.2+<br/>K8s SA Token"| API
    SidecarProxy -->|"HTTPS<br/>TLS 1.2+<br/>MLflow Bearer"| MLflow
    SidecarProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OCI v2 Auth"| OCIReg

    %% K8s creates job pod
    API -.->|"creates K8s Job"| EvalJobPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authboundary fill:#e8d5f5,stroke:#9b59b6,stroke-width:2px
    classDef evalhubpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef evaljobpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,IDE external
    class KRBP authboundary
    class API,MCPServer evalhubpod
    class Init,RuntimeContainer,SidecarProxy evaljobpod
    class K8sAPI,PG,MLflow,S3,OCIReg,OTEL,Prom externalservice
