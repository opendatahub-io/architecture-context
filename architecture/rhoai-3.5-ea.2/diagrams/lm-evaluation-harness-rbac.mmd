graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["This component defines NO RBAC resources.<br/>It runs as a batch Kubernetes Job pod.<br/>All RBAC is managed by the deploying operator:<br/><b>TrustyAI lm-eval-controller</b>"]
    end

    subgraph Operator["TrustyAI lm-eval-controller (manages RBAC)"]
        OperatorSA["Operator ServiceAccount<br/>(manages Job lifecycle)"]
    end

    subgraph JobExecution["Job Pod Execution Context"]
        JobSA["Job ServiceAccount<br/>(created by operator)"]
    end

    subgraph MountedSecrets["Secrets Accessed (Volume Mounts)"]
        ModelAuth["Model Auth Secret<br/>Type: Opaque<br/>Keys: API key, hf-token<br/>Provisioned by: User / Operator"]
        GitAuth["git-auth<br/>Type: kubernetes.io/basic-auth<br/>Git credentials for Tekton<br/>Provisioned by: Konflux / PaC"]
        OCIAuth["OCI Auth<br/>Type: kubernetes.io/dockerconfigjson<br/>Registry credentials<br/>Provisioned by: User / Platform"]
    end

    subgraph AuthMechanisms["Outbound Authentication"]
        BearerModel["Bearer Token<br/>OPENAI_API_KEY<br/>→ Model Endpoint"]
        BearerEvalHub["Bearer Token<br/>→ EvalHub Callbacks"]
        BearerHF["Bearer Token<br/>HF_TOKEN (optional)<br/>→ HuggingFace Hub"]
        BasicOCI["Basic Auth / Docker Config<br/>→ OCI Registry"]
        AWSIAM["AWS IAM Credentials<br/>ACCESS_KEY_ID + SECRET<br/>→ S3 Storage"]
        BearerMLflow["Bearer Token<br/>→ MLflow Server"]
    end

    OperatorSA -->|"creates Job with"| JobSA
    JobSA -->|"mounts"| ModelAuth
    JobSA -->|"mounts"| OCIAuth
    ModelAuth -->|"resolves to"| BearerModel
    ModelAuth -->|"resolves to"| BearerHF

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style OperatorSA fill:#7ed321,color:#fff
    style JobSA fill:#4a90e2,color:#fff
    style ModelAuth fill:#e1d5e7,stroke:#9673a6
    style GitAuth fill:#e1d5e7,stroke:#9673a6
    style OCIAuth fill:#e1d5e7,stroke:#9673a6
    style BearerModel fill:#f8cecc,stroke:#b85450
    style BearerEvalHub fill:#f8cecc,stroke:#b85450
    style BearerHF fill:#f8cecc,stroke:#b85450
    style BasicOCI fill:#f8cecc,stroke:#b85450
    style AWSIAM fill:#f8cecc,stroke:#b85450
    style BearerMLflow fill:#f8cecc,stroke:#b85450
