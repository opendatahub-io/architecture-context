graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies
    Sidecar -->|"reverse proxy<br/>HTTP(S)/8001"| DecoderVLLM["vLLM Decoder<br/>(local, co-located)"]
    Sidecar -->|"prefill requests<br/>HTTP(S)/variable"| PrefillerVLLM["vLLM Prefiller<br/>(remote pods)"]
    Sidecar -->|"CRD watch<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io"]
    Sidecar -->|"pod IP watch<br/>HTTPS/443"| K8sPods["Kubernetes Pods<br/>(pool selector match)"]
    Sidecar -.->|"consumes header<br/>x-prefiller-host-port"| Scheduler["llm-d-inference-scheduler<br/>(EPP)"]

    %% Architectural Integration
    GatewayAPIExt["Gateway API<br/>Inference Extension"] -.->|"manages pool"| InferencePool
    GatewayAPIExt -.->|"manages decoder pods"| DecoderVLLM

    %% External Build/Runtime Dependencies
    Sidecar -->|"API client"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"API types"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"proxy cache"| LRU["hashicorp/golang-lru<br/>v2.0.7"]
    Sidecar -->|"request IDs"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"logging"| Klog["k8s.io/klog/v2<br/>v2.130.1"]

    %% External Services
    Sidecar -->|"SSRF allowlist<br/>HTTPS/443 SA Token"| K8sAPI["Kubernetes API Server"]

