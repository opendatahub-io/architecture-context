    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DecoderVLLM fill:#7ed321,stroke:#333
    style PrefillerVLLM fill:#7ed321,stroke:#333
    style InferencePool fill:#7ed321,stroke:#333
    style K8sPods fill:#7ed321,stroke:#333
    style Scheduler fill:#7ed321,stroke:#333
    style GatewayAPIExt fill:#7ed321,stroke:#333
    style ClientGo fill:#999,stroke:#333,color:#fff
    style APIMachinery fill:#999,stroke:#333,color:#fff
    style LRU fill:#999,stroke:#333,color:#fff
