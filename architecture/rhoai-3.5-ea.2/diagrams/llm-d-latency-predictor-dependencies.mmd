graph LR
    LLP["llm-d-latency-predictor<br/>Latency Prediction Service"]

    %% Internal Platform Dependencies (llm-d ecosystem)
    LLP -->|"training data<br/>inbound 8000/TCP"| GatewayComp["llm-d Gateway<br/>Components"]
    LLP -->|"predictions<br/>inbound 8001/TCP"| GatewayRouter["llm-d Gateway<br/>Router"]

    %% Internal communication
    PredServer["Prediction Server<br/>(10 replicas)"] -->|"model sync<br/>HTTP 8000/TCP<br/>polling every 10s"| TrainServer["Training Server<br/>(1 replica)"]

    %% ML Framework Dependencies
    LLP -->|"default model backend"| XGBoost["XGBoost<br/>latest"]
    LLP -->|"optional backend"| LightGBM["LightGBM<br/>latest"]
    LLP -->|"optional backend"| BayesianRidge["scikit-learn<br/>BayesianRidge"]

    %% Runtime Dependencies
    LLP -->|"HTTP framework"| FastAPI["FastAPI<br/>+ uvicorn"]
    LLP -->|"numerical compute"| NumPy["NumPy + Pandas<br/>+ SciPy"]
    LLP -->|"model serialization"| Joblib["joblib"]
    LLP -->|"fast JSON"| ORJson["orjson"]
    LLP -->|"validation"| Pydantic["Pydantic"]
    LLP -->|"OpenMP runtime"| LibGomp["libgomp<br/>(system)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP 8000/TCP"| LLP

    %% Platform Dependencies
    RHOAI["RHOAI Operator<br/>(rhods-operator)"] -->|"manages deployment"| LLP
    PVC["PersistentVolume"] -->|"model storage"| TrainServer

    %% Base Image
    LLP -->|"base image"| UBI9["UBI9 Python 3.12<br/>registry.access.redhat.com"]

    %% Styling
    style LLP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PredServer fill:#4a90e2,stroke:#333,color:#fff
    style TrainServer fill:#4a90e2,stroke:#333,color:#fff
    style GatewayComp fill:#7ed321,stroke:#333,stroke-width:2px
    style GatewayRouter fill:#7ed321,stroke:#333,stroke-width:2px
    style RHOAI fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#333
    style XGBoost fill:#f5a623,stroke:#333
    style LightGBM fill:#f5a623,stroke:#333
    style BayesianRidge fill:#f5a623,stroke:#333
    style FastAPI fill:#999,stroke:#333,color:#fff
    style NumPy fill:#999,stroke:#333,color:#fff
    style Joblib fill:#999,stroke:#333,color:#fff
    style ORJson fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style LibGomp fill:#999,stroke:#333,color:#fff
    style UBI9 fill:#cc0000,stroke:#333,color:#fff
    style PVC fill:#e8e8e8,stroke:#333
