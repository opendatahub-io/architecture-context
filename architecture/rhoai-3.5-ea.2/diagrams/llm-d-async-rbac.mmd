graph TD
    subgraph "Service Account"
        SA["async-processor<br/>(ServiceAccount)<br/>Created by Helm chart"]
    end

    subgraph "RBAC Bindings"
        NoBind["No ClusterRoleBinding<br/>or RoleBinding defined"]
    end

    subgraph "Metrics Authentication (Optional)"
        MetricsAuth["controller-runtime<br/>WithAuthenticationAndAuthorization"]
        SAR["Kubernetes API Server<br/>SubjectAccessReview<br/>:443/TCP HTTPS"]
    end

    subgraph "External Auth Mechanisms"
        direction TB
        RedisAuth["Redis Auth<br/>Password in URL<br/>(redis:// or rediss://)"]
        GCPAuth["GCP OAuth2<br/>Application Default<br/>Credentials (ADC)"]
        IGWAuth["IGW Header Auth<br/>x-gateway-inference-objective<br/>(routing, not auth)"]
    end

    subgraph "Secrets"
        RedisCreds["redis-creds (Opaque)<br/>Redis connection URL<br/>Manual or chart-generated<br/>No auto-rotation"]
        TLSSecret["TLS Secret (kubernetes.io/tls)<br/>CA cert + client cert + key<br/>Manual or cert-manager<br/>mTLS to IGW"]
    end

    SA -->|"not bound"| NoBind
    SA -->|"pod identity"| MetricsAuth
    MetricsAuth -->|"delegates auth to"| SAR

    SA -.->|"mounts"| RedisCreds
    SA -.->|"mounts"| TLSSecret

    RedisCreds -->|"provides credentials"| RedisAuth
    TLSSecret -->|"provides client certs"| IGWAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style NoBind fill:#f9f9f9,stroke:#ccc,stroke-dasharray: 5 5
    style MetricsAuth fill:#f5a623,stroke:#333
    style SAR fill:#dae8fc,stroke:#6c8ebf
    style RedisAuth fill:#d63b2f,stroke:#333,color:#fff
    style GCPAuth fill:#4285f4,stroke:#333,color:#fff
    style IGWAuth fill:#7ed321,stroke:#333,color:#fff
    style RedisCreds fill:#fff2cc,stroke:#d6b656
    style TLSSecret fill:#fff2cc,stroke:#d6b656

    %% Note
    Note["NOTE: No Kubernetes RBAC roles are defined.<br/>The ServiceAccount has no cluster or namespace role bindings.<br/>Authentication is handled externally via Redis passwords,<br/>GCP OAuth2, and optional mTLS certificates."]
    style Note fill:#f0f0f0,stroke:#999,stroke-dasharray: 3 3
