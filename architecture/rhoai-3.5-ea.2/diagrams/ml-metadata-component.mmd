graph TB
    subgraph MLMDComponent["ML Metadata (MLMD) gRPC Server"]
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Server)<br/>Port 8080/TCP"]
        ServiceImpl["MetadataStoreServiceImpl<br/>(gRPC Service Layer)"]
        MetadataStore["MetadataStore<br/>(Core Logic)"]
        RDBMS["RDBMSMetadataAccessObject<br/>(Storage Abstraction)"]
        Proto["MetadataStoreService.proto<br/>(40+ RPC Methods)"]

        Server --> ServiceImpl
        ServiceImpl --> MetadataStore
        MetadataStore --> RDBMS
        Proto -.->|defines| ServiceImpl
    end

    subgraph PythonClient["ml-metadata Python Client"]
        DirectMode["Direct DB Mode<br/>(pybind11 C++ extension)"]
        GRPCMode["gRPC Client Mode<br/>(grpc Python library)"]
    end

    subgraph Consumers["Primary Consumers"]
        DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
        PipelineUI["Pipeline UI<br/>(Frontend)"]
    end

    subgraph Backends["Database Backends"]
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(In-Memory)"]
    end

    %% Consumer flows
    DSP -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    PipelineUI -->|"gRPC (indirect via API server)<br/>8080/TCP"| Server
    GRPCMode -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    %% Database flows
    RDBMS -->|"MySQL Protocol<br/>Optional SSL"| MySQL
    RDBMS -->|"PostgreSQL Protocol<br/>Optional SSL"| PostgreSQL
    RDBMS -->|"Embedded"| SQLite

    %% Direct mode
    DirectMode -->|"Direct SQL<br/>(pybind11)"| MySQL
    DirectMode -->|"Direct SQL<br/>(pybind11)"| PostgreSQL

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style ServiceImpl fill:#4a90e2,stroke:#333,color:#fff
    style MetadataStore fill:#4a90e2,stroke:#333,color:#fff
    style RDBMS fill:#4a90e2,stroke:#333,color:#fff
    style Proto fill:#f5a623,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelineUI fill:#7ed321,stroke:#333,color:#fff
    style DirectMode fill:#9b59b6,stroke:#333,color:#fff
    style GRPCMode fill:#9b59b6,stroke:#333,color:#fff
    style MySQL fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style SQLite fill:#e8e8e8,stroke:#333
