graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Dashboard["odh-dashboard<br/>(primary dashboard SA)"]
        SA_Modules["odh-dashboard-modules<br/>(BFF sidecar SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Dashboard["odh-dashboard<br/>(ClusterRoleBinding)"]
        CRB_AuthDelegator["odh-dashboard-auth-delegator<br/>(ClusterRoleBinding)"]
        CRB_Monitoring["odh-dashboard-monitoring<br/>(ClusterRoleBinding)"]
        CRB_Modules["odh-dashboard-modules<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Dashboard["odh-dashboard<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Dashboard["odh-dashboard<br/>(ClusterRole)"]
        CR_AuthDelegator["system:auth-delegator<br/>(ClusterRole)"]
        CR_Monitoring["cluster-monitoring-view<br/>(ClusterRole)"]
        CR_Modules["odh-dashboard-modules<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Dashboard["odh-dashboard<br/>(Role)"]
    end

    %% Bindings
    SA_Dashboard -->|"bound via"| CRB_Dashboard
    SA_Dashboard -->|"bound via"| CRB_AuthDelegator
    SA_Dashboard -->|"bound via"| CRB_Monitoring
    SA_Dashboard -->|"bound via"| RB_Dashboard
    SA_Modules -->|"bound via"| CRB_Modules

    CRB_Dashboard -->|"grants"| CR_Dashboard
    CRB_AuthDelegator -->|"grants"| CR_AuthDelegator
    CRB_Monitoring -->|"grants"| CR_Monitoring
    CRB_Modules -->|"grants"| CR_Modules
    RB_Dashboard -->|"grants"| R_Dashboard

    %% odh-dashboard ClusterRole Resources
    subgraph DashboardResources["odh-dashboard ClusterRole Resources"]
        direction LR
        subgraph CoreAPIs["Core APIs"]
            Nodes["nodes<br/>get, list"]
            ConfigMaps["configmaps<br/>CRUD + watch"]
            PVCs["persistentvolumeclaims<br/>CRUD + watch"]
            Secrets["secrets<br/>CRUD + watch"]
            Pods["pods<br/>get, list, watch"]
            SAs["serviceaccounts<br/>get, list, watch"]
            Services["services<br/>get, list, watch"]
        end

        subgraph StorageAPIs["Storage APIs"]
            StorageClasses["storageclasses<br/>update, patch"]
        end

        subgraph OpenShiftAPIs["OpenShift APIs"]
            MachineAutoscalers["machineautoscalers<br/>get, list"]
            MachineSets["machinesets<br/>get, list"]
            ClusterVersions["clusterversions<br/>get, watch, list"]
            Ingresses["ingresses<br/>get, watch, list"]
            CSVs["clusterserviceversions<br/>get, list, watch"]
            Routes["routes<br/>get, list, watch"]
            Users["users, groups<br/>get, list, watch"]
        end

        subgraph RBACAPIs["RBAC APIs"]
            RoleBindings["rolebindings<br/>list, get, create, patch, delete"]
            CRBs["clusterrolebindings<br/>list, get, create, patch, delete"]
            RolesRes["roles<br/>list, get, create, patch, delete"]
        end

        subgraph MLPlatformAPIs["ML Platform APIs"]
            Notebooks["notebooks (kubeflow.org)<br/>CRUD + watch"]
            DSCs["datascienceclusters<br/>list, watch, get"]
            DSCIs["dscinitializations<br/>list, watch, get"]
            InfSvc["inferenceservices<br/>get, list, watch"]
            ModelRegs["modelregistries<br/>CRUD + watch"]
            Auths["auths (services.platform)<br/>get"]
            OGXServers["ogxservers<br/>get, list, watch"]
            GuardrailsOrch["guardrailsorchestrators<br/>get, list, watch"]
            EvalHubs["evalhubs<br/>get, list, watch"]
            FeatureStores["featurestores<br/>get, list, watch"]
            MLflows["mlflows<br/>get, list, watch"]
        end

        subgraph AuthAPIs["Auth APIs"]
            TokenReviews["tokenreviews<br/>create"]
            SARs["subjectaccessreviews<br/>create"]
        end
    end

    CR_Dashboard -->|"manages"| CoreAPIs
    CR_Dashboard -->|"manages"| StorageAPIs
    CR_Dashboard -->|"manages"| OpenShiftAPIs
    CR_Dashboard -->|"manages"| RBACAPIs
    CR_Dashboard -->|"manages"| MLPlatformAPIs
    CR_Dashboard -->|"manages"| AuthAPIs

    %% odh-dashboard-modules ClusterRole Resources
    subgraph ModulesResources["odh-dashboard-modules ClusterRole Resources"]
        direction LR
        Mod_MLflows["mlflows<br/>get, list, watch"]
        Mod_Ingresses["ingresses<br/>get, list, watch"]
        Mod_SARs["subjectaccessreviews<br/>create"]
        Mod_Impersonate["users, groups, serviceaccounts<br/>impersonate"]
        Mod_AgentRuntimes["agentruntimes<br/>get, list"]
        Mod_Routes["routes<br/>get, list"]
        Mod_MCPServers["mcpserverregistrations<br/>get, list"]
    end

    CR_Modules -->|"manages"| ModulesResources

