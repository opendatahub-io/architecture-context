graph TD
    subgraph Note["RBAC Note"]
        direction TB
        NoteText["No RBAC manifests in eval-hub repository.<br/>RBAC is configured by the platform operator<br/>(rhods-operator) when deploying eval-hub.<br/><br/>The diagram below shows the runtime<br/>authentication and authorization model."]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph ExternalAuth["External Client Authentication"]
            ClientToken["Client Bearer Token<br/>(HTTPS/443)"]
            KRBPValidation["kube-rbac-proxy<br/>Token Validation"]
            HeaderInjection["Identity Header Injection<br/>X-Tenant + X-User"]

            ClientToken -->|"validated by"| KRBPValidation
            KRBPValidation -->|"injects"| HeaderInjection
        end

        subgraph EvalHubAuth["Eval-Hub API Authorization"]
            TenantScoping["Tenant-Scoped DB Queries<br/>(multi-tenant isolation)"]
            HeaderInjection -->|"scopes access to"| TenantScoping
        end

        subgraph PublicEndpoints["Public Endpoints (No Auth)"]
            Health["/api/v1/health<br/>GET"]
            OpenAPI["/openapi.yaml<br/>GET"]
            Docs["/docs<br/>GET"]
            MetricsEndpoint["/metrics<br/>GET (port 8081)"]
        end

        subgraph SidecarAuth["Sidecar Authentication (Job Pods)"]
            direction TB
            SA["K8s ServiceAccount<br/>(auto-mounted token)"]
            SAToken["/var/run/secrets/kubernetes.io/<br/>serviceaccount/token"]
            MLflowToken["/var/run/secrets/mlflow/token<br/>Bearer Token (5-min cache)"]
            DockerConfig["/etc/evalhub/.docker/config.json<br/>OCI v2 Auth Challenge"]
            AWSCreds["/var/run/secrets/test-data/<br/>AWS IAM Credentials"]

            SA -->|"mounts"| SAToken
            SAToken -->|"authenticates to<br/>eval-hub API"| EvalHubTarget["eval-hub API<br/>(HTTPS)"]
            MLflowToken -->|"authenticates to"| MLflowTarget["MLflow Tracking<br/>(HTTPS)"]
            DockerConfig -->|"authenticates to"| OCITarget["OCI Registry<br/>(HTTPS/443)"]
            AWSCreds -->|"authenticates to"| S3Target["S3 Storage<br/>(HTTPS/443)"]
        end

        subgraph MCPAuth["MCP Server Authentication"]
            MCPCluster["Cluster Mode<br/>Auth: kube-rbac-proxy<br/>(X-Tenant + X-User)"]
            MCPLocal["Local Mode<br/>Auth: None<br/>(development only)"]
            MCPToken["EVALHUB_TOKEN<br/>Bearer → eval-hub API"]
        end

        subgraph ProtectedResources["Protected API Resources"]
            Jobs["/api/v1/evaluations/jobs<br/>POST, GET, DELETE"]
            Collections["/api/v1/evaluations/collections<br/>POST, GET, PUT, PATCH, DELETE"]
            Providers["/api/v1/evaluations/providers<br/>POST, GET, PUT, PATCH, DELETE"]
        end

        TenantScoping -->|"controls access to"| ProtectedResources
    end

    subgraph Secrets["Secrets Inventory"]
        direction TB
        DBSecret["database credentials<br/>Type: Opaque<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
        MLflowSecret["MLflow token<br/>Type: Opaque<br/>Path: /var/run/secrets/mlflow/token<br/>Auto-rotate: No"]
        S3Secret["S3 credentials<br/>Type: Opaque<br/>Path: /var/run/secrets/test-data/<br/>Auto-rotate: No"]
        OCISecret["OCI registry credentials<br/>Type: kubernetes.io/dockerconfigjson<br/>Path: /etc/evalhub/.docker/config.json<br/>Auto-rotate: No"]
        K8sSASecret["K8s ServiceAccount token<br/>Type: kubernetes.io/service-account-token<br/>Auto-rotate: Yes (kubelet)"]
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style NoteText fill:#fff3cd,stroke:none
    style ClientToken fill:#4a90e2,stroke:#333,color:#fff
    style KRBPValidation fill:#9b59b6,stroke:#333,color:#fff
    style HeaderInjection fill:#9b59b6,stroke:#333,color:#fff
    style TenantScoping fill:#4a90e2,stroke:#333,color:#fff
    style Health fill:#27ae60,stroke:#333,color:#fff
    style OpenAPI fill:#27ae60,stroke:#333,color:#fff
    style Docs fill:#27ae60,stroke:#333,color:#fff
    style MetricsEndpoint fill:#27ae60,stroke:#333,color:#fff
    style SA fill:#e67e22,stroke:#333,color:#fff
    style SAToken fill:#f5a623,stroke:#333
    style MLflowToken fill:#f5a623,stroke:#333
    style DockerConfig fill:#f5a623,stroke:#333
    style AWSCreds fill:#f5a623,stroke:#333
    style Jobs fill:#3498db,stroke:#333,color:#fff
    style Collections fill:#3498db,stroke:#333,color:#fff
    style Providers fill:#3498db,stroke:#333,color:#fff
    style MCPCluster fill:#9b59b6,stroke:#333,color:#fff
    style MCPLocal fill:#e74c3c,stroke:#333,color:#fff
    style MCPToken fill:#f5a623,stroke:#333
    style DBSecret fill:#fff2cc,stroke:#d6b656
    style MLflowSecret fill:#fff2cc,stroke:#d6b656
    style S3Secret fill:#fff2cc,stroke:#d6b656
    style OCISecret fill:#fff2cc,stroke:#d6b656
    style K8sSASecret fill:#d5e8d4,stroke:#82b366
