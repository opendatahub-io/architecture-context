graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        Server["Axum HTTP Server<br/>Port 8080/TCP<br/>Plaintext HTTP"]
        HealthEndpoint["/health<br/>GET"]
        DetectionEndpoint["/api/v1/text/contents<br/>POST"]
        DetectorRegistry["Detector Registry<br/>(HashMap)"]
        BuiltinEmail["Built-in: email"]
        BuiltinSSN["Built-in: ssn"]
        BuiltinCC["Built-in: credit-card"]
        CustomRegex["Custom Regex<br/>(user-supplied patterns)"]
        RegexEngine["Rust regex crate<br/>(finite automaton,<br/>linear time, ReDoS-safe)"]

        Server --> HealthEndpoint
        Server --> DetectionEndpoint
        DetectionEndpoint --> DetectorRegistry
        DetectorRegistry --> BuiltinEmail
        DetectorRegistry --> BuiltinSSN
        DetectorRegistry --> BuiltinCC
        DetectorRegistry --> CustomRegex
        BuiltinEmail --> RegexEngine
        BuiltinSSN --> RegexEngine
        BuiltinCC --> RegexEngine
        CustomRegex --> RegexEngine
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| Server
    Server -->|"JSON Response<br/>(matches, offsets, scores)"| Orchestrator

    subgraph "Runtime Stack"
        Tokio["Tokio Async Runtime<br/>(multi-threaded)"]
        TowerHTTP["tower-http<br/>(tracing middleware)"]
        Tracing["tracing / tracing-subscriber<br/>(structured logging)"]
    end

    Server -.->|"runs on"| Tokio
    Server -.->|"middleware"| TowerHTTP
    Server -.->|"logging"| Tracing

    subgraph "Container"
        UBI9["UBI 9 Minimal"]
        Binary["regex-detector binary<br/>(Rust, dynamically linked)"]
        OpenSSL["compat-openssl11<br/>(installed, not used by app)"]
    end

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style DetectionEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style DetectorRegistry fill:#4a90e2,stroke:#333,color:#fff
    style RegexEngine fill:#7ed321,stroke:#333,color:#fff
    style Orchestrator fill:#f5a623,stroke:#333,color:#fff
    style BuiltinEmail fill:#50e3c2,stroke:#333
    style BuiltinSSN fill:#50e3c2,stroke:#333
    style BuiltinCC fill:#50e3c2,stroke:#333
    style CustomRegex fill:#bd10e0,stroke:#333,color:#fff
    style UBI9 fill:#e8e8e8,stroke:#333
    style Binary fill:#e8e8e8,stroke:#333
    style OpenSSL fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style TowerHTTP fill:#e8e8e8,stroke:#333
    style Tracing fill:#e8e8e8,stroke:#333
