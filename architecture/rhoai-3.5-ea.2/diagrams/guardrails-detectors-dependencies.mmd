graph LR
    GD["Guardrails Detectors<br/>(Built-in + HF + Judge)"]

    %% Internal RHOAI Dependencies
    GD -->|"inbound REST API<br/>8080/8000 TCP"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployment platform<br/>InferenceService"| KServe["KServe"]
    GD -->|"mTLS sidecar<br/>sidecar.istio.io/inject"| Istio["Istio Service Mesh"]
    GD -->|"outbound REST API<br/>8080/TCP"| vLLM["vLLM Server"]

    %% External Dependencies
    GD -->|"model storage<br/>9000/TCP HTTP"| S3["S3 Storage<br/>(MinIO)"]
    GD -->|"model download<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8080/8000 TCP"| GD

    %% Python Framework Dependencies
    GD -->|"web framework"| FastAPI["FastAPI 0.136.3"]
    GD -->|"ASGI server"| Uvicorn["uvicorn 0.34.0"]
    GD -->|"metrics"| PromClient["prometheus_client<br/>>=0.18.0"]
    GD -->|"ML inference"| Transformers["transformers 4.57.3<br/>(HF detector)"]
    GD -->|"tensor ops"| PyTorch["PyTorch<br/>(HF detector)"]
    GD -->|"judge library"| VLLMJudge["vllm-judge 0.1.8<br/>(Judge detector)"]
    GD -->|"schema validation"| JSONSchema["jsonschema 4.24.0<br/>(Built-in detector)"]

    %% Integration Points (other components using this)
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    DSP["Data Science<br/>Pipelines"] -.->|"auto deploy"| KServe

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style VLLMJudge fill:#999,stroke:#333,color:#fff
    style JSONSchema fill:#999,stroke:#333,color:#fff
    style Dashboard fill:#d5e8d4,stroke:#82b366
    style DSP fill:#d5e8d4,stroke:#82b366
