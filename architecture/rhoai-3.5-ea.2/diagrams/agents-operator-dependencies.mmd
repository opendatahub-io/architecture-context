graph LR
    KagentiOp["Kagenti Operator<br/>(agents-operator)"]

    %% External Dependencies (Required)
    KagentiOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.24.1"]

    %% External Dependencies (Conditional)
    KagentiOp -->|"webhook TLS<br/>TLS bridge CA<br/>shared trust"| CertManager["cert-manager<br/>v1.20.2"]
    KagentiOp -->|"Sigstore verify<br/>SignedAgentCard"| SigstoreGo["sigstore-go<br/>v1.2.1"]
    KagentiOp -->|"SPIFFE mTLS<br/>verified fetch"| GoSpiffe["go-spiffe/v2<br/>v2.7.0"]

    %% Internal RHOAI Dependencies
    KagentiOp -->|"client registration<br/>JWT validation<br/>token exchange"| Keycloak["Keycloak<br/>(k8s.keycloak.org)"]
    KagentiOp -->|"X.509/JWT SVIDs<br/>workload identity<br/>trust bundle"| SPIRE["SPIRE<br/>(Workload API)"]
    KagentiOp -->|"experiment tracking<br/>env var injection<br/>scoped RBAC"| MLflow["MLflow<br/>(mlflow.opendatahub.io)"]
    KagentiOp -->|"platform detection<br/>MLflow operand"| DSC["DataScienceCluster<br/>(datasciencecluster.opendatahub.io)"]
    KagentiOp -->|"ambient mesh<br/>namespace enrollment<br/>CA rotation"| Istio["Istio<br/>(istiod, ztunnel)"]
    KagentiOp -.->|"rate limiting<br/>(conditional)"| Kuadrant["Kuadrant<br/>(kuadrant.io)"]
    KagentiOp -.->|"pipeline config<br/>(conditional)"| Tekton["Tekton<br/>(operator.tekton.dev)"]
    KagentiOp -.->|"network validation<br/>(read only)"| OVN["OpenShift Network<br/>Operator"]
    KagentiOp -.->|"Sigstore verification<br/>(conditional)"| Sigstore["Sigstore<br/>(Rekor/Fulcio)"]
    KagentiOp -.->|"trace export<br/>(conditional)"| Phoenix["Phoenix<br/>4317/TCP gRPC"]
    KagentiOp -.->|"trust domain<br/>discovery"| ZTWIM["ZTWIM<br/>(Zero Trust WIM)"]

    %% Integration Points (components that depend on Kagenti)
    OTel["OTel Collector"] -.->|"config assembly<br/>rollout restart"| KagentiOp

    %% External Services
    KagentiOp -->|"CRD reconciliation<br/>webhook registration"| K8sAPI["Kubernetes API<br/>6443/TCP"]
    KagentiOp -->|"Keycloak Route<br/>TLS edge"| Routes["OpenShift Routes"]
    KagentiOp -->|"SCC for SPIRE CSI<br/>NET_ADMIN"| SCC["OpenShift SCC"]

    %% Styling
    style KagentiOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff

    %% Conditional external deps
    style CertManager fill:#999,stroke:#333,color:#fff
    style SigstoreGo fill:#999,stroke:#333,color:#fff
    style GoSpiffe fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI deps
    style Keycloak fill:#7ed321,stroke:#333,color:#fff
    style SPIRE fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style Kuadrant fill:#7ed321,stroke:#333,color:#fff
    style Tekton fill:#7ed321,stroke:#333,color:#fff
    style OVN fill:#7ed321,stroke:#333,color:#fff
    style ZTWIM fill:#7ed321,stroke:#333,color:#fff
    style OTel fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Routes fill:#f5a623,stroke:#333,color:#fff
    style SCC fill:#f5a623,stroke:#333,color:#fff
    style Sigstore fill:#f5a623,stroke:#333,color:#fff
    style Phoenix fill:#f5a623,stroke:#333,color:#fff
