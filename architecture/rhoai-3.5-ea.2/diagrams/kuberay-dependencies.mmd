graph LR
    KubeRay["KubeRay Operator<br/>v1.4.4"]

    %% External Dependencies (Required)
    KubeRay -->|"container orchestration<br/>6443/TCP HTTPS"| K8s["Kubernetes v1.29+"]
    KubeRay -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.22.1"]

    %% External Dependencies (Optional)
    KubeRay -->|"mTLS certs<br/>(when enabled)"| CertManager["cert-manager<br/>v1.18.2"]
    KubeRay -->|"HTTPRoute ingress<br/>(RHOAI auth)"| GatewayAPI["Gateway API<br/>v1.4.0"]
    KubeRay -->|"gang scheduling<br/>(optional)"| Volcano["Volcano<br/>v1.12.1"]
    KubeRay -->|"batch scheduling<br/>(optional)"| SchedPlugins["scheduler-plugins<br/>v0.31.8"]
    KubeRay -->|"GCS fault tolerance<br/>6379/TCP (optional)"| Redis["Redis<br/>(any version)"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys & configures"| KubeRay
    KubeRay -->|"HTTPRoute references"| DSGateway["data-science-gateway<br/>(Gateway CR)"]
    KubeRay -->|"OIDC auth sidecar<br/>8443/TCP HTTPS"| KRBProxy["kube-rbac-proxy<br/>(container image)"]
    KubeRay -->|"auth mode detection<br/>6443/TCP HTTPS"| OSAuth["OpenShift OAuth<br/>(config.openshift.io)"]

    %% NetworkPolicy peers
    OSIngress["OpenShift Ingress<br/>(openshift-ingress NS)"] -.->|"NetworkPolicy peer<br/>→ dashboard port"| KubeRay
    MonitoringNS["Monitoring NS"] -.->|"NetworkPolicy peer<br/>→ metrics port"| KubeRay

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -->|"UI management"| KubeRay
    DSPipelines["Data Science<br/>Pipelines"] -->|"auto-deploy models"| KubeRay

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8080/TCP HTTP"| KubeRay

    %% Batch scheduling integrations
    KubeRay -.->|"workload mgmt<br/>(optional)"| Kueue["Kueue<br/>(ManagedBy field)"]
    KubeRay -.->|"task group annotations<br/>(optional)"| YuniKorn["YuniKorn"]

