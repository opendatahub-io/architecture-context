graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["system:odh-model-controller<br/>(NS: opendatahub)"]
        SA_API["system:model-serving-api<br/>(NS: opendatahub)"]
        SA_CtrlMgr["system:controller-manager<br/>(NS: opendatahub)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["odh-model-controller-<br/>rolebinding-opendatahub"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_API["model-serving-api"]
        CRB_Metrics["metrics-auth-rolebinding"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(NS: system)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["odh-model-controller-role"]
        CR_Proxy["proxy-role"]
        CR_API["model-serving-api"]
        CR_Prom["kserve-prometheus-k8s"]
        CR_Metrics["metrics-reader"]
        CR_Editor["account-editor-role"]
        CR_Viewer["account-viewer-role"]
        CR_MetricsAuth["metrics-auth-role"]
    end

    subgraph Roles["Namespace Roles"]
        R_Leader["leader-election-role<br/>(NS: system)"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader
    SA_API -->|bound via| CRB_API
    SA_CtrlMgr -->|bound via| CRB_Metrics

    CRB_Main -->|grants| CR_Main
    CRB_Proxy -->|grants| CR_Proxy
    CRB_API -->|grants| CR_API
    CRB_Metrics -->|grants| CR_MetricsAuth
    RB_Leader -->|grants| R_Leader

    subgraph KServeResources["serving.kserve.io Resources"]
        ISVC["InferenceService<br/>+ finalizers"]
        SR["ServingRuntime<br/>+ finalizers"]
        IG["InferenceGraph<br/>+ finalizers"]
        LLMIS["LLMInferenceService<br/>+ status + finalizers"]
        LLMISC["LLMInferenceServiceConfig"]
    end

    subgraph NIMResources["nim.opendatahub.io Resources"]
        NIMAcct["Account<br/>+ status + finalizers"]
    end

    subgraph GatewayResources["gateway.networking.k8s.io Resources"]
        GW["Gateway<br/>+ finalizers"]
        HTTPRoute["HTTPRoute"]
    end

    subgraph KuadrantResources["kuadrant.io Resources"]
        AuthPolicy["AuthPolicy<br/>+ status"]
        KuadrantCR["Kuadrant"]
    end

    subgraph NetworkResources["Network Resources"]
        NetPol["NetworkPolicy<br/>(networking.k8s.io)"]
        EnvoyFilter["EnvoyFilter<br/>(networking.istio.io)"]
        Route["Route + custom-host<br/>(route.openshift.io)"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        SvcMon["ServiceMonitor<br/>(monitoring.coreos.com)"]
        PodMon["PodMonitor<br/>(monitoring.coreos.com)"]
        TrigAuth["TriggerAuthentication<br/>(keda.sh)"]
    end

    subgraph CoreResources["Core Resources"]
        Secrets["Secrets"]
        ConfigMaps["ConfigMaps"]
        ServiceAccts["ServiceAccounts"]
        Services["Services"]
        Namespaces["Namespaces"]
        Pods["Pods"]
        Events["Events"]
    end

    subgraph RBACResources["RBAC Resources"]
        CRBRes["ClusterRoleBindings"]
        RolesRes["Roles"]
        RoleBindingsRes["RoleBindings"]
    end

    subgraph OtherResources["Other Resources"]
        Templates["Templates<br/>(template.openshift.io)"]
        OSAuth["Authentications<br/>(config.openshift.io)"]
        MetricsK8s["Pods, Nodes<br/>(metrics.k8s.io)"]
        DSC["DataScienceClusters"]
        DSCI["DSCInitializations"]
    end

    %% Main role permissions
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ISVC
    CR_Main -->|"get,list,watch,<br/>create,update"| SR
    CR_Main -->|"get,list,watch,<br/>update"| IG
    CR_Main -->|"get,list,watch,<br/>update,patch,post"| LLMIS
    CR_Main -->|"get,list,watch"| LLMISC
    CR_Main -->|"get,list,watch,<br/>patch,update"| NIMAcct
    CR_Main -->|"get,list,watch,<br/>update,patch"| GW
    CR_Main -->|"get,list,watch"| HTTPRoute
    CR_Main -->|"full CRUD"| AuthPolicy
    CR_Main -->|"get,list,watch"| KuadrantCR
    CR_Main -->|"full CRUD"| NetPol
    CR_Main -->|"full CRUD"| EnvoyFilter
    CR_Main -->|"full CRUD"| Route
    CR_Main -->|"full CRUD"| SvcMon
    CR_Main -->|"full CRUD"| PodMon
    CR_Main -->|"full CRUD"| TrigAuth
    CR_Main -->|"full CRUD"| Secrets
    CR_Main -->|"full CRUD"| ConfigMaps
    CR_Main -->|"full CRUD"| ServiceAccts
    CR_Main -->|"full CRUD"| Services
    CR_Main -->|"full CRUD"| CRBRes
    CR_Main -->|"full CRUD"| RolesRes
    CR_Main -->|"full CRUD"| RoleBindingsRes
    CR_Main -->|"full CRUD"| Templates
    CR_Main -->|"get,list,watch"| OSAuth
    CR_Main -->|"get,list,watch"| MetricsK8s
    CR_Main -->|"get,list,watch"| DSC
    CR_Main -->|"get,list,watch"| DSCI
    CR_Main -->|"read + update"| Namespaces
    CR_Main -->|"read + update"| Pods
    CR_Main -->|"create,patch"| Events

    %% Proxy role
    CR_Proxy -->|"create"| TokenReview["TokenReviews<br/>(authentication.k8s.io)"]
    CR_Proxy -->|"create"| SAR["SubjectAccessReviews<br/>(authorization.k8s.io)"]

    %% API server role
    CR_API -->|"list"| GW
    CR_API -->|"get"| Namespaces

    %% Prometheus role
    CR_Prom -->|"get,list,watch"| Services
    CR_Prom -->|"get,list,watch"| Pods

    %% Metrics reader
    CR_Metrics -->|"get"| MetricsURL["/metrics<br/>(nonResourceURL)"]

    %% Editor/Viewer roles
    CR_Editor -->|"full CRUD"| NIMAcct
    CR_Viewer -->|"read + update"| NIMAcct

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_CtrlMgr fill:#4a90e2,stroke:#333,color:#fff

    style CR_Main fill:#f5a623,stroke:#333,color:#fff
    style CR_Proxy fill:#f5a623,stroke:#333,color:#fff
    style CR_API fill:#f5a623,stroke:#333,color:#fff
    style CR_Prom fill:#f5a623,stroke:#333,color:#fff
    style CR_Metrics fill:#f5a623,stroke:#333,color:#fff
    style CR_Editor fill:#f5a623,stroke:#333,color:#fff
    style CR_Viewer fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff

    style ISVC fill:#7ed321,stroke:#333
    style SR fill:#7ed321,stroke:#333
    style IG fill:#7ed321,stroke:#333
    style LLMIS fill:#7ed321,stroke:#333
    style LLMISC fill:#7ed321,stroke:#333
    style NIMAcct fill:#7ed321,stroke:#333
    style GW fill:#7ed321,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style KuadrantCR fill:#7ed321,stroke:#333
