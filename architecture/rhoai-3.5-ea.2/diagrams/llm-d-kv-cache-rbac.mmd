graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["⚠ No RBAC manifests defined in repository"]
        L2["RBAC managed externally by llm-d gateway"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/>(referenced in StatefulSet<br/>but not defined)"]
    end

    subgraph RBACStatus["RBAC Status"]
        direction TB
        NoRoles["❌ No ClusterRoles defined"]
        NoBindings["❌ No ClusterRoleBindings defined"]
        NoRoleBindings["❌ No RoleBindings defined"]
        NoNetPol["❌ No NetworkPolicies defined"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        UDSAuth["UDS Tokenizer<br/>Auth: Socket perms 0o700<br/>✅ Pod-internal only"]
        ZMQAuth["ZMQ PUB/SUB<br/>Auth: None<br/>⚠ Unauthenticated"]
        RedisAuth["Redis/Valkey<br/>Auth: None<br/>⚠ Unauthenticated"]
        HTTPAuth["HTTP Endpoints<br/>Auth: None<br/>⚠ Unauthenticated"]
        gRPCAuth["gRPC IndexerService<br/>Auth: None<br/>⚠ Unauthenticated"]
    end

    subgraph Secrets["Secrets"]
        direction TB
        HFSecret["vllm-p2p-secrets<br/>Type: Opaque<br/>Content: HF_TOKEN<br/>Purpose: HuggingFace model downloads<br/>Provisioned: Helm values / manual<br/>Auto-rotate: No"]
    end

    SA -.->|"referenced by"| NoRoles
    SA -.->|"no bindings"| NoBindings

    %% Styling
    style Legend fill:#f0f0f0,stroke:#ccc
    style L1 fill:#fff3cd,stroke:#ffc107
    style L2 fill:#fff3cd,stroke:#ffc107
    style SA fill:#4a90e2,color:#fff
    style NoRoles fill:#f8d7da,stroke:#dc3545
    style NoBindings fill:#f8d7da,stroke:#dc3545
    style NoRoleBindings fill:#f8d7da,stroke:#dc3545
    style NoNetPol fill:#f8d7da,stroke:#dc3545
    style UDSAuth fill:#d4edda,stroke:#28a745
    style ZMQAuth fill:#fff3cd,stroke:#ffc107
    style RedisAuth fill:#fff3cd,stroke:#ffc107
    style HTTPAuth fill:#fff3cd,stroke:#ffc107
    style gRPCAuth fill:#fff3cd,stroke:#ffc107
    style HFSecret fill:#cce5ff,stroke:#004085
