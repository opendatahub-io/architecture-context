graph LR
    EvalHub["Eval Hub<br/>REST API + Orchestrator"]

    %% External Dependencies (Required)
    EvalHub -->|"Job/ConfigMap CRUD<br/>HTTPS/443, SA token"| K8sAPI["Kubernetes API<br/>v0.36.2 client-go"]

    %% External Dependencies (Optional)
    EvalHub -->|"state persistence<br/>TCP/5432, DB creds"| PostgreSQL["PostgreSQL<br/>5.10+ pgx driver"]
    EvalHub -.->|"fallback DB<br/>embedded"| SQLite["SQLite<br/>modernc.org v1.52.0"]
    EvalHub -.->|"experiment tracking<br/>HTTP(S), bearer token"| MLflow["MLflow Tracking<br/>2.0+ API"]
    EvalHub -.->|"trace export<br/>gRPC/4317"| OTEL["OTEL Collector<br/>OTLP gRPC/HTTP"]

    %% Sidecar Dependencies
    EvalHub -.->|"test data download<br/>HTTPS/443, AWS IAM"| S3["S3-compatible Storage<br/>AWS SDK v2"]
    EvalHub -.->|"artifact access<br/>HTTPS/443, OCI v2 auth"| OCI["OCI Registry<br/>Distribution Spec v2"]

    %% Internal Platform Dependencies
    KRBP["kube-rbac-proxy"] -->|"injects X-Tenant +<br/>X-User headers"| EvalHub
    ODHDashboard["ODH Dashboard"] -.->|"UI management"| EvalHub
    RhodsOperator["rhods-operator"] -.->|"deploys + configures<br/>RBAC, HTTPRoute"| EvalHub

    %% Evaluation Runtime Images (Job containers)
    EvalHub -->|"creates K8s Jobs"| LMEval["LM Evaluation Harness<br/>quay.io/opendatahub/ta-lmes-job<br/>180+ benchmarks"]
    EvalHub -->|"creates K8s Jobs"| Lighteval["Lighteval<br/>quay.io/evalhub/community-lighteval<br/>30+ benchmarks"]
    EvalHub -.->|"creates K8s Jobs"| Garak["Garak<br/>Safety/adversarial testing"]
    EvalHub -.->|"creates K8s Jobs"| GuiDeLLM["GuiDeLLM<br/>Inference performance"]
    EvalHub -.->|"creates K8s Jobs"| IBMCLEAR["IBM CLEAR<br/>Evaluation framework"]

    %% MCP Integration
    MCPServer["evalhub-mcp<br/>MCP Server"] -->|"delegates via<br/>HTTP(S) + bearer"| EvalHub
    PythonSDK["eval-hub-sdk<br/>Python client library"] -->|"REST API calls<br/>HTTP(S)/8080"| EvalHub

    %% Metrics
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8081"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% Optional external
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style SQLite fill:#bbb,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style OTEL fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style OCI fill:#f5a623,stroke:#333
    style Prometheus fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style KRBP fill:#9b59b6,stroke:#333,color:#fff
    style ODHDashboard fill:#7ed321,stroke:#333
    style RhodsOperator fill:#9b59b6,stroke:#333,color:#fff

    %% Evaluation runtimes
    style LMEval fill:#e67e22,stroke:#333,color:#fff
    style Lighteval fill:#e67e22,stroke:#333,color:#fff
    style Garak fill:#e67e22,stroke:#333,color:#fff
    style GuiDeLLM fill:#e67e22,stroke:#333,color:#fff
    style IBMCLEAR fill:#e67e22,stroke:#333,color:#fff

    %% Clients
    style MCPServer fill:#4a90e2,stroke:#333,color:#fff
    style PythonSDK fill:#3498db,stroke:#333,color:#fff
