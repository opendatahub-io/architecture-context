graph TB
    subgraph KagentiOperator["Kagenti Operator (kagenti-system)"]
        direction TB
        Controller["kagenti-operator<br/>Go Operator<br/>Ports: 8081, 9443, 8443"]
        MutatingWebhook["Mutating Webhook<br/>9443/TCP HTTPS<br/>Sidecar Injection"]
        ValidatingWebhook["Validating Webhook<br/>9443/TCP HTTPS<br/>AgentCard + AgentRuntime"]
        Controller -->|registers| MutatingWebhook
        Controller -->|registers| ValidatingWebhook
    end

    subgraph BundleSvc["Bundle Service (kagenti-system)"]
        BundleService["bundle-service<br/>Go Service<br/>8080/TCP HTTP"]
    end

    subgraph AgentPod["Agent Pod (user namespace)"]
        direction LR
        AuthBridge["authbridge-proxy<br/>Sidecar Proxy<br/>8080/8081/8082/TCP"]
        AgentApp["Agent Application<br/>Container"]
        AuthBridge -->|reverse proxy<br/>localhost| AgentApp
    end

    %% CRDs
    User[User / Platform] -->|creates| AgentRuntimeCR["AgentRuntime CR<br/>agent.kagenti.dev/v1alpha1"]
    User -->|creates| AgentCardCR["AgentCard CR<br/>agent.kagenti.dev/v1alpha1"]
    User -->|creates| AuthzPolicyCR["AuthorizationPolicy CR<br/>agent.kagenti.dev/v1alpha1"]

    %% Controller watches
    AgentRuntimeCR -->|watched by| Controller
    AgentCardCR -->|watched by| Controller
    AuthzPolicyCR -->|watched by| BundleService

    %% Sidecar injection flow
    Controller -->|labels + hash| TargetDeployment["Target Deployment<br/>/ StatefulSet"]
    TargetDeployment -->|pod create| MutatingWebhook
    MutatingWebhook -->|injects sidecar| AgentPod

    %% AuthBridge dependencies
    AuthBridge -->|JWT validation<br/>token exchange| Keycloak["Keycloak<br/>OAuth2/OIDC"]
    AuthBridge -->|X.509 SVID<br/>mTLS identity| SPIRE["SPIRE<br/>Workload API"]
    AuthBridge -->|OPA bundles<br/>8080/TCP| BundleService

    %% Controller dependencies
    Controller -->|client registration<br/>realm management| Keycloak
    Controller -->|verified card fetch<br/>trust bundle| SPIRE
    Controller -->|webhook TLS<br/>TLS bridge CA| CertManager["cert-manager"]
    Controller -->|ambient mesh<br/>enrollment| Istio["Istio"]
    Controller -->|experiment tracking<br/>env injection| MLflow["MLflow"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style MutatingWebhook fill:#4a90e2,color:#fff
    style ValidatingWebhook fill:#4a90e2,color:#fff
    style BundleService fill:#4a90e2,color:#fff
    style AuthBridge fill:#50c878,color:#fff
    style AgentApp fill:#50c878,color:#fff
    style AgentRuntimeCR fill:#f5a623,color:#fff
    style AgentCardCR fill:#f5a623,color:#fff
    style AuthzPolicyCR fill:#f5a623,color:#fff
    style Keycloak fill:#e8e8e8,stroke:#333
    style SPIRE fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style MLflow fill:#7ed321,color:#fff
