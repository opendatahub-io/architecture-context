graph TB
    subgraph LMEvalJob["LMEval Job (odh-ta-lmes-job)"]
        direction TB
        Adapter["EvalHub Adapter<br/>(main.py → LMEvalAdapter)"]
        LMEvalLib["lm_eval Library<br/>(lm-evaluation-harness 0.4.8)"]
        TaskManager["Task Manager<br/>(150+ benchmark tasks)"]
        LocalCompletions["local-completions Backend<br/>(OpenAI-compatible client)"]
        Unitxt["Unitxt Framework<br/>(custom evaluation tasks)"]
        OfflineDetect["Offline Mode Detector<br/>(_seed_hf_offline_before_lm_eval_import)"]
        ErrorSanitizer["Error Sanitizer<br/>(_sanitize_error_message)"]

        Adapter -->|"run_benchmark_job()"| LMEvalLib
        LMEvalLib -->|"loads tasks"| TaskManager
        LMEvalLib -->|"sends requests"| LocalCompletions
        TaskManager -->|"custom tasks"| Unitxt
        Adapter -->|"detects /test_data"| OfflineDetect
        Adapter -->|"redacts credentials"| ErrorSanitizer
    end

    %% Inputs
    JobSpec["ConfigMap<br/>/meta/job.json"] -->|"reads job spec"| Adapter
    ModelSecret["Model Auth Secret<br/>(volume mount)"] -->|"resolves credentials"| Adapter

    %% Outbound connections
    LocalCompletions -->|"POST /v1/completions<br/>HTTPS/443"| ModelEndpoint["Model Serving Endpoint<br/>(vLLM, TGI, etc.)"]
    Adapter -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    Adapter -->|"OCI push<br/>HTTPS/443"| OCIRegistry["OCI Registry"]
    Adapter -->|"log metrics<br/>HTTPS/443"| MLflow["MLflow Tracking Server"]
    TaskManager -->|"download datasets<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Operator creates the job
    Operator["TrustyAI LMEval Operator<br/>(lmes-controller)"] -->|"creates K8s Job"| LMEvalJob

    %% Styling
    style Adapter fill:#4a90e2,color:#fff
    style LMEvalLib fill:#4a90e2,color:#fff
    style TaskManager fill:#4a90e2,color:#fff
    style LocalCompletions fill:#4a90e2,color:#fff
    style Unitxt fill:#4a90e2,color:#fff
    style OfflineDetect fill:#4a90e2,color:#fff
    style ErrorSanitizer fill:#4a90e2,color:#fff
    style JobSpec fill:#f5a623,color:#333
    style ModelSecret fill:#f5a623,color:#333
    style ModelEndpoint fill:#e8e8e8,color:#333
    style EvalHub fill:#7ed321,color:#333
    style OCIRegistry fill:#e8e8e8,color:#333
    style MLflow fill:#e8e8e8,color:#333
    style HFHub fill:#e8e8e8,color:#333
    style Operator fill:#7ed321,color:#333
