graph LR
    WVA["Workload Variant<br/>Autoscaler"]

    %% Required External Dependencies
    WVA -->|"PromQL queries<br/>HTTPS/9091"| Prometheus["Prometheus / Thanos<br/><i>Required</i>"]
    WVA -->|"operator framework<br/>reconcilers, leader election"| ControllerRuntime["controller-runtime<br/>v0.22.5<br/><i>Required</i>"]
    WVA -->|"InferencePool CRD<br/>v1 + v1alpha2"| GatewayAPIExt["gateway-api-inference-ext<br/>v1.2.1<br/><i>Required</i>"]
    WVA -->|"KV cache, queue,<br/>latency metrics"| vLLM["vLLM<br/><i>Required</i>"]
    WVA -->|"Kalman filter<br/>parameter learning"| KalmanFilter["llm-inferno/kalman-filter<br/>v0.1.2<br/><i>Required</i>"]
    WVA -->|"OLS linear regression"| Gonum["gonum<br/>v0.17.0<br/><i>Required</i>"]
    WVA -->|"pod-to-variant<br/>LRU cache"| GolangLRU["golang-lru<br/>v2.0.7<br/><i>Required</i>"]

    %% Optional External Dependencies
    WVA -.->|"ScaledObject CRD<br/>annotation-based discovery"| KEDA["KEDA<br/>v2.18.0<br/><i>Optional</i>"]
    WVA -.->|"multi-GPU group<br/>scale target"| LWS["LeaderWorkerSet<br/>v0.8.0<br/><i>Optional</i>"]
    WVA -.->|"ServiceMonitor CRD<br/>metrics scraping config"| PromOperator["prometheus-operator<br/>v0.89.0<br/><i>Optional</i>"]

    %% Internal Platform Dependencies
    WVA -->|"custom metric:<br/>wva_desired_replicas"| HPA["HPA (Kubernetes)<br/><i>Internal Platform</i>"]
    WVA -->|"endpoint pool data,<br/>scale-from-zero queue"| InferencePool["InferencePool<br/>(Gateway API)<br/><i>Internal Platform</i>"]
    WVA -->|"GPU inventory<br/>vendor node labels"| GPUOperator["GPU Operator<br/>NVIDIA/AMD/Intel<br/><i>Internal Platform</i>"]
    WVA -->|"OpenShift Thanos,<br/>service CA TLS"| UserWorkloadMon["OpenShift User<br/>Workload Monitoring<br/><i>Internal Platform</i>"]

    %% Consumers of WVA
    HPA -->|"reads wva_desired_replicas<br/>scales Deployments/LWS"| ScaleTargets["Deployments / LWS<br/><i>Scale Targets</i>"]

    %% Integration Points (things that interact with WVA)
    EPP["EPP (Gateway API Ext)<br/><i>Metrics Source</i>"] -->|"scheduler dispatch rate,<br/>flow control queue"| Prometheus
    vLLM -->|"inference metrics<br/>HTTP/8200"| Prometheus

    %% Kubernetes API (central)
    WVA -->|"Resource CRUD,<br/>leader election,<br/>scale subresource<br/>HTTPS/6443"| K8sAPI["Kubernetes API<br/><i>Control Plane</i>"]

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Prometheus fill:#e65100,stroke:#333,color:#fff
    style ControllerRuntime fill:#777,stroke:#333,color:#fff
    style GatewayAPIExt fill:#777,stroke:#333,color:#fff
    style vLLM fill:#777,stroke:#333,color:#fff
    style KalmanFilter fill:#777,stroke:#333,color:#fff
    style Gonum fill:#777,stroke:#333,color:#fff
    style GolangLRU fill:#777,stroke:#333,color:#fff

    %% Optional external
    style KEDA fill:#bbb,stroke:#333,color:#333
    style LWS fill:#bbb,stroke:#333,color:#333
    style PromOperator fill:#bbb,stroke:#333,color:#333

    %% Internal platform
    style HPA fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style GPUOperator fill:#7ed321,stroke:#333,color:#fff
    style UserWorkloadMon fill:#7ed321,stroke:#333,color:#fff

    %% Other
    style ScaleTargets fill:#f5a623,stroke:#333,color:#fff
    style EPP fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#d32f2f,stroke:#333,color:#fff
