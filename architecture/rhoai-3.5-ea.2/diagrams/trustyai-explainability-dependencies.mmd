graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% External Dependencies (frameworks & libraries)
    TrustyAI -->|"application framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"gRPC client transport"| GRPC["gRPC-Java 1.75.0"]
    TrustyAI -->|"KServe v2 protobuf"| Protobuf["protobuf-java 3.25.5"]
    TrustyAI -->|"async networking"| Netty["Netty 4.1.125.Final"]
    TrustyAI -->|"constraint solver (CF)"| OptaPlanner["OptaPlanner 8.30.0"]
    TrustyAI -->|"data interchange"| Arrow["Apache Arrow 15.0.2"]
    TrustyAI -->|"metrics export"| Micrometer["Micrometer<br/>(Prometheus)"]

    %% Conditional Dependencies (storage backends)
    TrustyAI -->|"JPA persistence<br/>(DATABASE mode)"| Hibernate["Hibernate ORM 6.2.13"]
    TrustyAI -->|"DB driver<br/>(DATABASE mode)"| MariaDBDriver["MariaDB/MySQL JDBC"]
    TrustyAI -->|"S3 storage<br/>(MINIO mode)"| MinIOSDK["MinIO SDK 3.3.1"]

    %% Internal Platform Dependencies
    TrustyAI -->|"gRPC + HTTP client<br/>(inference requests)"| KServeModelMesh["KServe / ModelMesh<br/>Model Servers"]
    TrustyAI -->|"CloudEvent receiver<br/>(inference payloads)"| KServeLogger["KServe InferenceLogger"]
    ModelMeshServing["ModelMesh Serving"] -->|"POST /consumer/kserve/v2<br/>(inference payloads)"| TrustyAI

    %% Platform integration
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrape /q/metrics<br/>(ServiceMonitor)"| TrustyAI
    Operator["TrustyAI Service<br/>Operator"] -.->|"deploys & manages<br/>(separate repo)"| TrustyAI
    Dashboard["OpenShift AI<br/>Dashboard"] -->|"REST API calls<br/>(bias/drift viz)"| TrustyAI

    %% Storage backends
    TrustyAI -->|"CSV file I/O<br/>(default mode)"| PVC["PVC Storage"]
    TrustyAI -->|"S3 API<br/>(MINIO mode)"| MinIOStore["MinIO Storage"]
    TrustyAI -->|"JDBC/3306<br/>(DATABASE mode)"| MariaDB["MariaDB / MySQL"]

    %% ConfigMap integration
    TrustyAI -->|"writes (init container)"| ModelServingCM["model-serving-config<br/>ConfigMap"]
    TrustyAICM["trustyai-config<br/>ConfigMap"] -->|"env vars"| TrustyAI

