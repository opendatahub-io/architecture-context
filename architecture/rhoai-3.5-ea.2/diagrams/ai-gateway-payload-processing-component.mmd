graph TB
    subgraph AGPP["AI Gateway Payload Processing"]
        direction TB

        subgraph ExtProc["ext_proc Server (9004/TCP gRPC)"]
            direction LR
            PluginPipeline["Plugin Pipeline"]
        end

        subgraph Plugins["Request/Response Plugins"]
            direction TB
            MPR["model-provider-resolver<br/>Resolves model → provider endpoint"]
            APITrans["api-translation<br/>Translates between API formats<br/>(OpenAI, Anthropic, Azure, Bedrock, Vertex)"]
            APIKey["apikey-injection<br/>Injects provider API keys<br/>(Bearer, SigV4, per-provider headers)"]
            NemoReq["nemo-request-guard<br/>Input content safety rails"]
            NemoResp["nemo-response-guard<br/>Output content safety rails"]
        end

        subgraph Controllers["Kubernetes Controllers"]
            direction TB
            EPCtrl["external-provider-controller<br/>Creates Service, ServiceEntry,<br/>DestinationRule per provider"]
            EMCtrl["external-model-controller<br/>Creates HTTPRoute per model"]
            LegacyCtrl["legacy-migration-controller<br/>Migrates maas.opendatahub.io →<br/>inference.opendatahub.io"]
        end

        HealthCheck["Health Check (9005/TCP HTTP)"]
    end

    %% CRDs
    ExternalProviderCR["ExternalProvider CR<br/>inference.opendatahub.io/v1alpha1"]
    ExternalModelCR["ExternalModel CR<br/>inference.opendatahub.io/v1alpha1"]
    LegacyCR["ExternalModel CR (legacy)<br/>maas.opendatahub.io"]

    %% Created Resources
    ExternalNameSvc["ExternalName Service<br/>(per provider)"]
    ServiceEntry["Istio ServiceEntry<br/>(per provider)"]
    DestRule["Istio DestinationRule<br/>(TLS SIMPLE)"]
    HTTPRoute["Gateway API HTTPRoute<br/>(per model)"]

    %% External Systems
    Gateway["Platform Gateway<br/>(Istio Envoy)"]
    K8sAPI["Kubernetes API Server"]
    NeMoSvc["NeMo Guardrails Service"]

    %% Plugin pipeline flow
    PluginPipeline --> MPR
    MPR --> APITrans
    APITrans --> APIKey
    MPR -.-> NemoReq
    NemoReq -.-> NemoResp

    %% Gateway interaction
    Gateway -->|"gRPC ext_proc<br/>9004/TCP"| ExtProc

    %% CRD watches
    ExternalProviderCR -->|"watched by"| EPCtrl
    ExternalProviderCR -->|"watched by"| MPR
    ExternalModelCR -->|"watched by"| EMCtrl
    ExternalModelCR -->|"watched by"| MPR
    LegacyCR -->|"watched by"| LegacyCtrl

    %% Resource creation
    EPCtrl -->|"creates"| ExternalNameSvc
    EPCtrl -->|"creates"| ServiceEntry
    EPCtrl -->|"creates"| DestRule
    EMCtrl -->|"creates"| HTTPRoute
    LegacyCtrl -->|"creates"| ExternalProviderCR
    LegacyCtrl -->|"creates"| ExternalModelCR

    %% External dependencies
    Controllers -->|"HTTPS/443"| K8sAPI
    NemoReq -->|"HTTP POST"| NeMoSvc
    NemoResp -->|"HTTP POST"| NeMoSvc

    %% Styling
    style AGPP fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ExtProc fill:#4a90e2,stroke:#333,color:#fff
    style PluginPipeline fill:#4a90e2,stroke:#333,color:#fff
    style MPR fill:#5ba3f5,stroke:#333,color:#fff
    style APITrans fill:#5ba3f5,stroke:#333,color:#fff
    style APIKey fill:#5ba3f5,stroke:#333,color:#fff
    style NemoReq fill:#5ba3f5,stroke:#333,color:#fff
    style NemoResp fill:#5ba3f5,stroke:#333,color:#fff
    style EPCtrl fill:#7ed321,stroke:#333,color:#fff
    style EMCtrl fill:#7ed321,stroke:#333,color:#fff
    style LegacyCtrl fill:#7ed321,stroke:#333,color:#fff
    style HealthCheck fill:#4a90e2,stroke:#333,color:#fff
    style ExternalProviderCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style LegacyCR fill:#f5a623,stroke:#333
    style ExternalNameSvc fill:#d5e8d4,stroke:#82b366
    style ServiceEntry fill:#d5e8d4,stroke:#82b366
    style DestRule fill:#d5e8d4,stroke:#82b366
    style HTTPRoute fill:#d5e8d4,stroke:#82b366
    style Gateway fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style NeMoSvc fill:#e8e8e8,stroke:#999
