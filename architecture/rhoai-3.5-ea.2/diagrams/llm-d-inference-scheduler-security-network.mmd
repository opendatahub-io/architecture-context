graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Gateway["INGRESS (Gateway)"]
        EnvoyGW["Envoy Gateway<br/>443/TCP → internal<br/>TLS 1.2+<br/>ext-proc routing"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod-to-Pod)"]
        direction TB

        subgraph EPPZone["EPP (Endpoint Picker) - StatefulSet"]
            EPP["EPP ext-proc Server<br/>SA: EPP controller<br/>Image: odh-llm-d-inference-scheduler<br/>FIPS: CGO_ENABLED=1 (no strictfipsruntime)"]
            EPPHealth["Health Server<br/>9003/TCP plaintext"]
            EPPMetrics["Metrics Server<br/>9090/TCP HTTP<br/>Optional auth"]
        end

        subgraph SidecarZone["Routing Sidecar (pd-sidecar) - Per-Pod"]
            Sidecar["Sidecar Proxy<br/>SA: sidecar SA<br/>Image: odh-llm-d-routing-sidecar<br/>FIPS: strictfipsruntime<br/>TLS 1.2+ ECDHE<br/>SSRF allowlist"]
        end

        subgraph ModelServers["Model Server Pods"]
            vLLMDecoder["Local vLLM Decoder<br/>8001/TCP"]
            vLLMMetrics["vLLM Metrics<br/>configurable/TCP"]
            vLLMKVEvents["vLLM KV-Events<br/>ZMQ 5556-5557/TCP"]
            RemotePrefiller["Remote Prefiller Pods<br/>configurable/TCP"]
            RemoteEncoder["Remote Encoder Pods<br/>configurable/TCP"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>plaintext (insecure)<br/>No auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>plaintext<br/>Optional auth"]
    end

    %% External → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / None"| EnvoyGW

    %% Gateway → EPP
    EnvoyGW -->|"gRPC/9002<br/>TLS (self-signed)<br/>No client auth"| EPP

    %% Gateway → Sidecar
    EnvoyGW -->|"HTTP(S)/8000<br/>TLS 1.2+<br/>No auth"| Sidecar

    %% EPP → Internal
    EPP -->|"HTTP(S)/configurable<br/>Optional TLS<br/>InsecureSkipVerify=true"| vLLMMetrics
    EPP -->|"ZMQ SUB/5556-5557<br/>plaintext<br/>No auth"| vLLMKVEvents
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Sidecar → Internal
    Sidecar -->|"HTTP(S)/8001<br/>Optional TLS<br/>No auth"| vLLMDecoder
    Sidecar -->|"HTTP(S)/configurable<br/>Optional TLS<br/>SSRF validated"| RemotePrefiller
    Sidecar -->|"HTTP(S)/configurable<br/>Optional TLS<br/>SSRF validated"| RemoteEncoder
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% External egress
    EPP -.->|"gRPC/4317<br/>plaintext<br/>No auth"| OTLP
    Sidecar -.->|"gRPC/4317<br/>plaintext<br/>No auth"| OTLP
    EPP -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HFHub
    Prometheus -.->|"HTTP/9090<br/>plaintext<br/>Optional auth"| EPPMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef modelserver fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class EnvoyGW gateway
    class EPP,EPPHealth,EPPMetrics,Sidecar internal
    class vLLMDecoder,vLLMMetrics,vLLMKVEvents,RemotePrefiller,RemoteEncoder modelserver
    class OTLP,HFHub,Prometheus externalservice
    class K8sAPI k8s
