graph TD
    subgraph "Pipelines Components RBAC Model"
        direction TB

        Note["NOTE: This component defines NO ClusterRoles<br/>or RoleBindings of its own.<br/>Pipeline-level RBAC is delegated to the<br/>KFP pipeline ServiceAccount."]

        subgraph "Platform-Provisioned ServiceAccount"
            PipelineSA["Pipeline ServiceAccount<br/>(pre-configured by platform operator)"]
        end

        subgraph "Required Permissions (by pipeline type)"
            direction TB

            subgraph "All Pipelines"
                PVC["PersistentVolumeClaims<br/>Verbs: get, create, mount"]
                Secrets["Secrets<br/>Verbs: get (for S3, HF, OGX credentials)"]
                Pods["Pods<br/>Verbs: create, get, list (pipeline steps)"]
            end

            subgraph "Fine-Tuning Pipelines"
                CTR["ClusterTrainingRuntime<br/>(training.kubeflow.org)<br/>Verbs: get, create, delete"]
                MR["ModelRegistry API<br/>(model-registry.kubeflow.org)<br/>Verbs: POST (register models)"]
            end

            subgraph "EvalHub Pipeline Variants (additional)"
                IS["InferenceService<br/>(serving.kserve.io)<br/>Verbs: create, delete"]
                SR["ServingRuntime<br/>(serving.kserve.io)<br/>Verbs: create, delete"]
                RWX["ReadWriteMany PVC<br/>Required for model sharing<br/>between training pod and KServe"]
            end
        end

        subgraph "Secrets Referenced by Pipelines"
            S3Secret["s3-secret<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY<br/>Provisioned by: User"]
            HFSecret["hf-token<br/>Type: Opaque<br/>Keys: HF_TOKEN<br/>Provisioned by: User"]
            K8sSecret["kubernetes-credentials<br/>Type: Opaque<br/>Keys: KUBERNETES_SERVER_URL,<br/>KUBERNETES_AUTH_TOKEN<br/>Provisioned by: Platform"]
            OCISecret["oci-pull-secret-model-download<br/>Type: Opaque<br/>Provisioned by: User"]
            MinIOSecret["minio-secret<br/>Type: Opaque<br/>Keys: access_key, secret_key<br/>Provisioned by: User"]
            LLMSecret["llm-credentials<br/>Type: Opaque<br/>Keys: api_key → LLM_API_KEY<br/>Provisioned by: User"]
            OGXSecret["ogx_secret_name<br/>Type: Opaque<br/>Keys: OGX_CLIENT_BASE_URL,<br/>OGX_CLIENT_API_KEY<br/>Provisioned by: User"]
        end

        PipelineSA -->|"needs access to"| PVC
        PipelineSA -->|"needs access to"| Secrets
        PipelineSA -->|"needs access to"| Pods
        PipelineSA -->|"fine-tuning pipelines"| CTR
        PipelineSA -->|"fine-tuning pipelines"| MR
        PipelineSA -->|"evalhub variants only"| IS
        PipelineSA -->|"evalhub variants only"| SR
        PipelineSA -.->|"evalhub variants only"| RWX

        Secrets -->|"mounts"| S3Secret
        Secrets -->|"mounts"| HFSecret
        Secrets -->|"mounts"| K8sSecret
        Secrets -->|"mounts"| OCISecret
        Secrets -->|"mounts"| MinIOSecret
        Secrets -->|"mounts"| LLMSecret
        Secrets -->|"mounts"| OGXSecret
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style PipelineSA fill:#4a90e2,stroke:#333,color:#fff
    style PVC fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style CTR fill:#f5a623,stroke:#333,color:#fff
    style MR fill:#f5a623,stroke:#333,color:#fff
    style IS fill:#e74c3c,stroke:#333,color:#fff
    style SR fill:#e74c3c,stroke:#333,color:#fff
    style RWX fill:#e74c3c,stroke:#333,color:#fff
    style S3Secret fill:#95a5a6,stroke:#333,color:#fff
    style HFSecret fill:#95a5a6,stroke:#333,color:#fff
    style K8sSecret fill:#95a5a6,stroke:#333,color:#fff
    style OCISecret fill:#95a5a6,stroke:#333,color:#fff
    style MinIOSecret fill:#95a5a6,stroke:#333,color:#fff
    style LLMSecret fill:#95a5a6,stroke:#333,color:#fff
    style OGXSecret fill:#95a5a6,stroke:#333,color:#fff
