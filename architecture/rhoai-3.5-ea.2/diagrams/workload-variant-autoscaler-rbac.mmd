    style CRB_Metrics fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Auth fill:#9b59b6,stroke:#333,color:#fff
    style CRB_EPP fill:#9b59b6,stroke:#333,color:#fff
    style CRB_MonView fill:#9b59b6,stroke:#333,color:#fff
    style RB_Leader fill:#9b59b6,stroke:#333,color:#fff

