graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager"]
        SA_Prom["kube-prometheus-stack-prometheus<br/><i>(monitoring namespace)</i>"]
        SA_EPP["epp-metrics-reader"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/><i>(cluster)</i>"]
        CRB_Metrics["metrics-reader-rolebinding<br/><i>(cluster)</i>"]
        CRB_Auth["metrics-auth-rolebinding<br/><i>(cluster)</i>"]
        CRB_EPP["epp-metrics-reader-role-binding<br/><i>(cluster)</i>"]
        CRB_MonView["manager-cluster-monitoring-view<br/><i>(cluster, OpenShift only)</i>"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/><i>(system namespace)</i>"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Metrics["metrics-reader"]
        CR_Auth["metrics-auth-role"]
        CR_EPP["epp-metrics-reader-role"]
        CR_MonView["cluster-monitoring-view<br/><i>(OpenShift)</i>"]
        CR_Admin["variantautoscaling-admin-role"]
        CR_Editor["variantautoscaling-editor-role"]
        CR_Viewer["variantautoscaling-viewer-role"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/><i>(system namespace)</i>"]
    end

    %% Binding connections
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Auth
    SA_CM -->|bound via| CRB_MonView
    SA_CM -->|bound via| RB_Leader
    SA_Prom -->|bound via| CRB_Metrics
    SA_EPP -->|bound via| CRB_EPP

    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    CRB_Auth -->|grants| CR_Auth
    CRB_EPP -->|grants| CR_EPP
    CRB_MonView -->|grants| CR_MonView
    RB_Leader -->|grants| R_Leader

    %% Manager role resources
    subgraph ManagerResources["manager-role Resources"]
        direction LR

        subgraph CoreAPI["core"]
            ConfigMaps["configmaps<br/><i>get,update,list,watch</i>"]
            Events["events<br/><i>create,patch</i>"]
            Namespaces["namespaces<br/><i>get,list,watch</i>"]
            NodesRes["nodes, nodes/status<br/><i>get,list,watch,update,patch</i>"]
            Pods["pods<br/><i>get,list,watch</i>"]
            Secrets["secrets<br/><i>get,list,watch</i>"]
            Services["services<br/><i>get,list,watch</i>"]
        end

        subgraph AppsAPI["apps"]
            Deployments["deployments,<br/>deployments/scale<br/><i>get,list,watch,update,patch</i>"]
            ReplicaSets["replicasets<br/><i>get,list,watch</i>"]
            StatefulSets["statefulsets<br/><i>get,list,watch</i>"]
        end

        subgraph AutoscalingAPI["autoscaling"]
            HPAs["horizontalpodautoscalers<br/><i>get,list,watch,patch,update</i>"]
        end

        subgraph CustomAPIs["Custom API Groups"]
            KEDARes["keda.sh<br/>scaledobjects<br/><i>get,list,watch</i>"]
            InfPoolRes["inference.networking<br/>inferencepools<br/><i>get,list,watch</i>"]
            LWSRes["leaderworkerset.x-k8s.io<br/>leaderworkersets/scale<br/><i>get,list,watch,update,patch</i>"]
            VARes["llmd.ai<br/>variantautoscalings<br/>/status /finalizers<br/><i>full CRUD</i>"]
            SMRes["monitoring.coreos.com<br/>servicemonitors<br/><i>get,list,watch</i>"]
        end
    end

    CR_Manager -->|permissions on| ManagerResources

    %% Other role resources
    subgraph MetricsResources["metrics-reader Resources"]
        MetricsURL["nonResourceURLs: /metrics<br/><i>get</i>"]
    end

    subgraph AuthResources["metrics-auth-role Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        SAReviews["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    subgraph EPPResources["epp-metrics-reader-role Resources"]
        EPPMetrics["nonResourceURLs:<br/>/metrics, /debug/pprof/*<br/><i>get</i>"]
    end

    subgraph VAAdminResources["VA User Roles Resources"]
        VAAdmin["variantautoscalings<br/>admin: *<br/>editor: CRUD<br/>viewer: read-only"]
    end

    CR_Metrics -->|permissions on| MetricsResources
    CR_Auth -->|permissions on| AuthResources
    CR_EPP -->|permissions on| EPPResources
    CR_Admin -->|permissions on| VAAdminResources
    CR_Editor -->|permissions on| VAAdminResources
    CR_Viewer -->|permissions on| VAAdminResources

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Metrics fill:#f5a623,stroke:#333,color:#fff
