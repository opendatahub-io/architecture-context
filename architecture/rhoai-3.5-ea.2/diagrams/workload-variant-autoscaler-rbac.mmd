    style Events fill:#7ed321,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style NodesRes fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style ReplicaSets fill:#7ed321,stroke:#333,color:#fff
    style StatefulSets fill:#7ed321,stroke:#333,color:#fff
    style HPAs fill:#7ed321,stroke:#333,color:#fff
    style KEDARes fill:#7ed321,stroke:#333,color:#fff
    style InfPoolRes fill:#7ed321,stroke:#333,color:#fff
