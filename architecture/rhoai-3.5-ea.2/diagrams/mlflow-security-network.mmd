graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Client / Python SDK"]
        Browser["Browser / React UI"]
        OTELAgent["OTEL Agent"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Platform Gateway<br/>HTTPRoute (Gateway API)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP (HTTPS) → 5000/TCP (HTTP)<br/>JWT via TokenReview<br/>AuthZ via SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER (Trusted)"]
        direction TB

        subgraph MLflowPod["MLflow Pod<br/>SA: mlflow | UID: 1000<br/>readOnlyRootFS | drop ALL caps<br/>seccomp: RuntimeDefault"]
            MLflow["MLflow Tracking Server<br/>5000/TCP HTTP<br/>Workspace-scoped RBAC<br/>AES-256-GCM envelope encryption"]
            Huey["Huey Task Queue<br/>SQLite in /dev/shm"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>Auth: Password (Secret)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount token"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>5000/TCP HTTP"]
        EvalHub["EvalHub Dashboard<br/>Module Federation<br/>HTTP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO<br/>9000/TCP, 443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        LLMProviders["LLM Providers<br/>(OpenAI, Anthropic, Bedrock)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key (Bearer)"]
        DNS["DNS (CoreDNS/OVN-K)<br/>53/UDP, 53/TCP<br/>5353/UDP, 5353/TCP"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (JWT)"| Gateway
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (JWT)"| Gateway
    OTELAgent -->|"HTTP/5000<br/>POST /v1/traces<br/>No Auth (OTLP)"| MLflow

    %% Ingress to auth
    Gateway -->|"HTTPS/8443<br/>TLS<br/>JWT forwarded"| KubeRBACProxy

    %% Auth to app
    KubeRBACProxy -->|"HTTP/5000<br/>localhost<br/>Authorized"| MLflow

    %% Egress flows
    MLflow -->|"PostgreSQL/5432<br/>Plaintext (in-cluster)<br/>Password auth"| PostgreSQL
    MLflow -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    MLflow -->|"HTTPS/9000,443<br/>TLS 1.2+<br/>AWS IAM"| S3
    MLflow -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LLMProviders
    MLflow -->|"DNS/53,5353<br/>Plaintext"| DNS

    %% Internal integrations
    Prometheus -->|"HTTP/5000<br/>GET /metrics"| MLflow
    EvalHub -->|"HTTP<br/>Module Federation<br/>JS bundles"| MLflow

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authLayer fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef appLayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internalService fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalService fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,Browser,OTELAgent external
    class Gateway ingress
    class KubeRBACProxy authLayer
    class MLflow,Huey appLayer
    class PostgreSQL,K8sAPI,Prometheus,EvalHub internalService
    class S3,LLMProviders,DNS externalService
