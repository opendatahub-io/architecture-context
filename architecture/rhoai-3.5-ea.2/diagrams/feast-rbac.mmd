graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Feast["feast-{name}<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(Cluster-scoped)"]
        CRB_Feast["feast-{name}-cluster-binding<br/>(Cluster-scoped, dynamic)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Feast["feast-{name}<br/>(FeatureStore namespace, dynamic)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Editor["featurestore-editor-role"]
        CR_Viewer["featurestore-viewer-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsRead["metrics-reader"]
        CR_TokenReview["feast-token-review-cluster-role<br/>(shared, dynamic)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
        R_Feast["feast-{name}<br/>(dynamic per FeatureStore)"]
    end

    subgraph ManagerResources["manager-role API Resources"]
        FeastDev["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers"]
        CoreResources["core (&quot;&quot;)<br/>configmaps, services,<br/>serviceaccounts, pvcs,<br/>namespaces, pods, secrets,<br/>pods/exec"]
        AppsResources["apps<br/>deployments"]
        BatchResources["batch<br/>cronjobs"]
        AutoscalingRes["autoscaling<br/>horizontalpodautoscalers"]
        PolicyRes["policy<br/>poddisruptionbudgets"]
        RBACResources["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles,<br/>clusterrolebindings"]
        AuthnRes["authentication.k8s.io<br/>tokenreviews"]
        RouteRes["route.openshift.io<br/>routes"]
        MonitorRes["monitoring.coreos.com<br/>servicemonitors"]
        KubeflowRes["kubeflow.org<br/>notebooks"]
        ApiExtRes["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph LeaderElectionResources["leader-election-role Resources"]
        LeaderConfigMaps["core (&quot;&quot;)<br/>configmaps"]
        LeaderLeases["coordination.k8s.io<br/>leases"]
    end

    subgraph MetricsResources["metrics-auth-role Resources"]
        MetricsTokenReview["authentication.k8s.io<br/>tokenreviews"]
        MetricsSubjectAccess["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph MetricsReaderRes["metrics-reader Resources"]
        MetricsEndpoint["(non-resource URL)<br/>/metrics"]
    end

    %% SA → Bindings
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Metrics
    SA_CM -->|"bound via"| RB_Leader
    SA_Feast -->|"bound via"| CRB_Feast
    SA_Feast -->|"bound via"| RB_Feast

    %% Bindings → Roles
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    CRB_Feast -->|"grants"| CR_TokenReview
    RB_Leader -->|"grants"| R_Leader
    RB_Feast -->|"grants"| R_Feast

    %% manager-role → Resources
    CR_Manager -->|"CRUD + watch"| FeastDev
    CR_Manager -->|"CRUD + watch<br/>(pods/secrets: read-only)"| CoreResources
    CR_Manager -->|"CRUD + watch"| AppsResources
    CR_Manager -->|"CRUD + watch"| BatchResources
    CR_Manager -->|"CRUD + watch"| AutoscalingRes
    CR_Manager -->|"CRUD + watch"| PolicyRes
    CR_Manager -->|"CRUD + watch"| RBACResources
    CR_Manager -->|"create"| AuthnRes
    CR_Manager -->|"CRUD + watch"| RouteRes
    CR_Manager -->|"CRUD + watch"| MonitorRes
    CR_Manager -->|"get, list, watch"| KubeflowRes
    CR_Manager -->|"get, list"| ApiExtRes

    %% leader-election → Resources
    R_Leader -->|"CRUD + watch"| LeaderConfigMaps
    R_Leader -->|"CRUD + watch"| LeaderLeases

    %% metrics-auth → Resources
    CR_MetricsAuth -->|"create"| MetricsTokenReview
    CR_MetricsAuth -->|"create"| MetricsSubjectAccess

    %% metrics-reader → Resources
    CR_MetricsRead -->|"get"| MetricsEndpoint

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Feast fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Editor fill:#f5a623,stroke:#333,color:#fff
    style CR_Viewer fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsRead fill:#f5a623,stroke:#333,color:#fff
    style CR_TokenReview fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style R_Feast fill:#f5a623,stroke:#333,color:#fff
    style FeastDev fill:#7ed321,stroke:#333,color:#fff
    style CoreResources fill:#7ed321,stroke:#333,color:#fff
    style AppsResources fill:#7ed321,stroke:#333,color:#fff
    style BatchResources fill:#7ed321,stroke:#333,color:#fff
    style AutoscalingRes fill:#7ed321,stroke:#333,color:#fff
    style PolicyRes fill:#7ed321,stroke:#333,color:#fff
    style RBACResources fill:#7ed321,stroke:#333,color:#fff
    style AuthnRes fill:#7ed321,stroke:#333,color:#fff
    style RouteRes fill:#7ed321,stroke:#333,color:#fff
    style MonitorRes fill:#7ed321,stroke:#333,color:#fff
    style KubeflowRes fill:#7ed321,stroke:#333,color:#fff
    style ApiExtRes fill:#7ed321,stroke:#333,color:#fff
