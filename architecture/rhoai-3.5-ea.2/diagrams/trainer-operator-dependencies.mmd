graph LR
    TrainerOp["Trainer Operator<br/>(controller-runtime)"]

    %% External Dependencies (required libraries/frameworks)
    TrainerOp -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    TrainerOp -->|"API types"| KubeflowTrainer["kubeflow/trainer/v2<br/>v2.2.0"]
    TrainerOp -->|"platform utilities<br/>(kustomize, GC, conditions)"| ODHPlatUtils["odh-platform-utilities<br/>v0.1.0"]
    TrainerOp -->|"API types (indirect)"| JobSetAPI["sigs.k8s.io/jobset<br/>v0.11.1"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"creates Trainer CR<br/>(default-trainer)"| TrainerOp
    TrainerOp -->|"CRD dependency check<br/>jobsets.jobset.x-k8s.io"| JobSetOp["JobSet Operator"]
    TrainerOp -->|"CR check<br/>JobSetOperator 'cluster'"| JobSetOpCR["JobSet Operator CR<br/>(OpenShift only)"]
    TrainerOp -->|"install status check<br/>operatorconditions"| OLM["OLM"]
    TrainerOp -->|"cluster type detection<br/>clusterversions"| OpenShiftAPI["OpenShift API"]

    %% Managed Components (deployed by trainer-operator)
    TrainerOp -->|"deploys (kustomize +<br/>server-side apply)"| KFTrainerCtrl["Kubeflow Trainer<br/>Controller"]
    TrainerOp -->|"creates/updates<br/>15 variants"| CTRs["ClusterTraining-<br/>Runtimes"]
    TrainerOp -->|"creates (OpenShift)<br/>3 variants"| ImgStreams["ImageStreams"]

    %% Integration Points (components that interact)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8080/TCP HTTP"| TrainerOp
    KFTrainerCtrl -->|"creates JobSets"| JobSetOp

    %% Downstream consumers
    User["Data Scientist"] -->|"creates TrainJob CR"| KFTrainerCtrl

    %% Styling
    style TrainerOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (gray)
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style KubeflowTrainer fill:#999,stroke:#333,color:#fff
    style ODHPlatUtils fill:#999,stroke:#333,color:#fff
    style JobSetAPI fill:#999,stroke:#333,color:#fff

    %% Internal platform (green)
    style PlatformOp fill:#7ed321,stroke:#333
    style JobSetOp fill:#7ed321,stroke:#333
    style JobSetOpCR fill:#7ed321,stroke:#333
    style OLM fill:#7ed321,stroke:#333
    style OpenShiftAPI fill:#7ed321,stroke:#333

    %% Managed components (light blue)
    style KFTrainerCtrl fill:#5dade2,stroke:#333,color:#fff
    style CTRs fill:#5dade2,stroke:#333,color:#fff
    style ImgStreams fill:#5dade2,stroke:#333,color:#fff

    %% External actors (orange)
    style Prometheus fill:#f5a623,stroke:#333
    style User fill:#d4e6f1,stroke:#333
