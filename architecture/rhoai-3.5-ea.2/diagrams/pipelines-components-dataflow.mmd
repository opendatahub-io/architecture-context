sequenceDiagram
    autonumber

    %% Flow 1: Managed Pipeline Staging
    rect rgb(230, 245, 255)
        Note over DSPO,KFPServer: Flow 1: Managed Pipeline Staging (Init Container)
        participant DSPO as DSPO
        participant InitContainer as pipelines-components<br/>Init Container
        participant SharedVol as Shared Volume<br/>/config/managed-pipelines
        participant KFPServer as KFP API Server

        DSPO->>InitContainer: Deploy as init container<br/>in KFP API server pod
        InitContainer->>InitContainer: Check RELATED_IMAGE_* env vars
        alt No RELATED_IMAGE_* set
            InitContainer->>SharedVol: Copy pre-compiled pipeline YAMLs<br/>(from /app to /config/managed-pipelines)
        else RELATED_IMAGE_* present
            InitContainer->>InitContainer: Recompile pipelines from source<br/>(inject overridden base images)
            InitContainer->>SharedVol: Write recompiled pipeline YAMLs
        end
        KFPServer->>SharedVol: Read managed-pipelines.json<br/>and compiled YAML specs
    end

    %% Flow 2: Fine-Tuning Pipeline
    rect rgb(255, 245, 230)
        Note over KFPOrch,ModelReg: Flow 2: Fine-Tuning Pipeline (SFT/LoRA/OSFT)
        participant KFPOrch as KFP Orchestrator
        participant DataDL as dataset_download<br/>Pod
        participant S3 as S3 Storage<br/>443/TCP HTTPS
        participant HF as HuggingFace Hub<br/>443/TCP HTTPS
        participant TrainPod as train_model Pod<br/>(ClusterTrainingRuntime)
        participant PVC as Workspace PVC
        participant EvalPod as evaluation Pod<br/>(lm-eval / EvalHub)
        participant KServe as KServe<br/>InferenceService
        participant RegPod as model_registry Pod
        participant ModelReg as Kubeflow Model<br/>Registry<br/>8080/TCP HTTP

        KFPOrch->>DataDL: Execute step (ServiceAccount)
        DataDL->>S3: Download dataset<br/>HTTPS/443, TLS 1.2+, AWS IAM
        DataDL->>HF: Download model/dataset<br/>HTTPS/443, TLS 1.2+, Bearer Token
        KFPOrch->>TrainPod: Execute training step (ServiceAccount)
        TrainPod->>PVC: Read/Write model artifacts<br/>(local filesystem)
        KFPOrch->>EvalPod: Execute evaluation step (ServiceAccount)
        EvalPod->>KServe: Query InferenceService<br/>HTTP/80, Bearer Token
        KFPOrch->>RegPod: Execute registration step (ServiceAccount)
        RegPod->>ModelReg: Register trained model<br/>HTTP/8080, Plaintext, No Auth
    end

    %% Flow 3: AutoML Training Pipeline
    rect rgb(230, 255, 230)
        Note over KFPOrch,PVC: Flow 3: AutoML Training Pipeline
        participant AutoMLLoader as automl_data_loader<br/>Pod (odh-automl image)
        participant AutoGluon as autogluon_training<br/>Pod (odh-automl image)
        participant Leaderboard as leaderboard_evaluation<br/>Pod

        KFPOrch->>AutoMLLoader: Execute data loading step
        AutoMLLoader->>S3: Download training data (CSV)<br/>HTTPS/443, TLS 1.2+, AWS IAM
        AutoMLLoader->>PVC: Write dataset to workspace
        KFPOrch->>AutoGluon: Execute training step
        AutoGluon->>PVC: Read data, write model artifacts
        KFPOrch->>Leaderboard: Execute evaluation step
        Leaderboard->>PVC: Read model artifacts, write results
    end

    %% Flow 4: AutoRAG Optimization Pipeline
    rect rgb(255, 230, 255)
        Note over KFPOrch,Milvus: Flow 4: AutoRAG Optimization Pipeline
        participant DocDisc as documents_discovery<br/>Pod (odh-autorag image)
        participant TextExt as text_extraction<br/>Pod (odh-autorag image)
        participant RAGOpt as rag_templates_optimization<br/>Pod (odh-autorag image)
        participant OGX as OGX API<br/>443/TCP HTTPS
        participant Milvus as Milvus<br/>19530/TCP gRPC

        KFPOrch->>DocDisc: Execute discovery step
        DocDisc->>S3: Discover documents<br/>HTTPS/443, TLS 1.2+, AWS IAM
        KFPOrch->>TextExt: Execute text extraction step
        TextExt->>TextExt: Process with Docling models<br/>(local /opt/app-root/docling-artifacts)
        KFPOrch->>RAGOpt: Execute RAG optimization step
        RAGOpt->>OGX: Generate embeddings<br/>HTTPS/443, TLS 1.2+, API key
        RAGOpt->>Milvus: Store/query vectors<br/>gRPC/19530, Plaintext, No Auth
    end
