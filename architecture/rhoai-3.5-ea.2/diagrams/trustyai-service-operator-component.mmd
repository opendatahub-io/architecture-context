graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        Manager["manager binary<br/>Go controller-runtime"]

        subgraph Controllers["Controllers (--enable-services)"]
            direction LR
            TAS["TAS Controller<br/>Fairness & Explainability"]
            LMES["LMES Controller<br/>LM Evaluation Service"]
            EvalHub["EvalHub Controller<br/>Centralized Evaluation Hub"]
            GORCH["GORCH Controller<br/>Guardrails Orchestrator"]
            NemoGR["NemoGuardrails Controller<br/>NVIDIA NeMo Guardrails"]
        end

        Manager --> TAS
        Manager --> LMES
        Manager --> EvalHub
        Manager --> GORCH
        Manager --> NemoGR
    end

    %% CRDs
    TrustyAIServiceCR["TrustyAIService CR<br/>v1alpha1, v1"]
    LMEvalJobCR["LMEvalJob CR<br/>v1alpha1"]
    EvalHubCR["EvalHub CR<br/>v1alpha1, v1"]
    GORCHCR["GuardrailsOrchestrator CR<br/>v1alpha1"]
    NemoCR["NemoGuardrails CR<br/>v1alpha1"]

    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    EvalHubCR -->|watched by| EvalHub
    GORCHCR -->|watched by| GORCH
    NemoCR -->|watched by| NemoGR

    %% TAS creates
    TAS -->|creates| TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy"]
    TAS -->|creates| TASRoute["OpenShift Route<br/>reencrypt TLS"]
    TAS -->|creates| TASServiceMon["ServiceMonitor"]
    TAS -->|patches| InferenceService["KServe<br/>InferenceService"]
    TAS -->|patches| ModelMeshDeploy["ModelMesh<br/>Deployment"]
    TAS -->|creates| IstioResources["DestinationRule<br/>VirtualService"]

    %% LMES creates
    LMES -->|creates| LMESPod["Evaluation Pod<br/>init: ta-lmes-driver<br/>main: ta-lmes-job"]
    LMES -->|exec| LMESPod

    %% EvalHub creates
    EvalHub -->|creates| EHDeployment["EvalHub Service<br/>Deployment + kube-rbac-proxy"]
    EvalHub -->|creates| MCPDeploy["MCP Server<br/>Deployment (optional)"]
    EvalHub -->|creates| EHRoute["OpenShift Routes"]
    EvalHub -->|watches| KueueWorkload["Kueue Workloads"]
    EvalHub -->|reads| HWProfile["HardwareProfiles"]
    EvalHub -->|manages| TenantNS["Tenant Namespaces<br/>SA, Roles, RoleBindings"]

    %% GORCH creates
    GORCH -->|creates| GORCHDeploy["Orchestrator Deployment<br/>+ Gateway Sidecar<br/>+ Built-in Detectors<br/>+ kube-rbac-proxy"]
    GORCH -->|watches| InferenceService
    GORCH -->|auto-generates| GORCHConfig["Orchestrator ConfigMap"]
    GORCH -->|creates| GORCHRoutes["OpenShift Routes<br/>orchestrator, gateway,<br/>health, built-in"]

    %% NemoGuardrails creates
    NemoGR -->|creates| NemoDeploy["NeMo Guardrails<br/>Deployment + kube-rbac-proxy"]
    NemoGR -->|creates| NemoRoute["OpenShift Route"]
    NemoGR -->|creates| EnvoyFilter["Istio EnvoyFilter"]
    NemoGR -->|watches| MCPGateway["MCPGatewayExtension<br/>(Kuadrant)"]
    NemoGR -->|reads| Gateway["Gateway<br/>(gateway.networking.k8s.io)"]

    %% Platform operator
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|deploys| Operator

    %% ConfigMap
    ConfigMap["trustyai-service-operator-config<br/>ConfigMap"] -->|read by| Manager

    %% Styling
    style Operator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controllers fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style Manager fill:#4a90e2,color:#fff
    style TAS fill:#42a5f5,color:#fff
    style LMES fill:#42a5f5,color:#fff
    style EvalHub fill:#42a5f5,color:#fff
    style GORCH fill:#42a5f5,color:#fff
    style NemoGR fill:#42a5f5,color:#fff
    style TrustyAIServiceCR fill:#f5a623
    style LMEvalJobCR fill:#f5a623
    style EvalHubCR fill:#f5a623
    style GORCHCR fill:#f5a623
    style NemoCR fill:#f5a623
    style PlatformOp fill:#7ed321,color:#fff
    style InferenceService fill:#7ed321
    style ModelMeshDeploy fill:#7ed321
    style KueueWorkload fill:#7ed321
    style HWProfile fill:#7ed321
    style MCPGateway fill:#7ed321
    style Gateway fill:#7ed321
    style ConfigMap fill:#fff9c4,stroke:#f9a825
