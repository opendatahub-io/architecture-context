graph TD
    subgraph "vllm-cpu Security Posture"
        direction TB

        subgraph "Container Runtime"
            Container["vllm-cpu Container<br/>UID: 2000 (non-root)<br/>GID: 0<br/>Image: UBI 9 minimal"]
        end

        subgraph "Kubernetes API Access"
            NoAccess["No Kubernetes API Access<br/>No ClusterRoles<br/>No RoleBindings<br/>No ServiceAccount privileges"]
        end

        subgraph "Authentication"
            direction LR
            APIAuth["HTTP API Auth<br/>/v1/* endpoints<br/>Optional API key<br/>(Bearer token)"]
            NoAuth["Unauthenticated Endpoints<br/>/health, /metrics<br/>/version, /load<br/>/server_info"]
            GRPCAuth["gRPC Auth<br/>Port 50051/TCP<br/>No authentication<br/>Insecure port"]
        end

        subgraph "Secrets (Platform-Injected)"
            HFToken["HF_TOKEN<br/>HuggingFace Bearer token<br/>Injected at runtime"]
            TLSCerts["TLS Certificates<br/>--ssl-keyfile / --ssl-certfile<br/>Injected at runtime"]
            APIKey["VLLM_API_KEY<br/>API key for /v1/* endpoints<br/>Injected at runtime"]
        end

        Container --- NoAccess
    end

    Note["Note: vllm-cpu is a stateless inference<br/>workload, NOT an operator.<br/>All RBAC and secrets are managed<br/>by the consuming platform<br/>(KServe / ModelMesh)."]

    %% Styling
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style NoAccess fill:#f9f9f9,stroke:#d32f2f,stroke-width:2px,stroke-dasharray: 5 5
    style APIAuth fill:#fff2cc,stroke:#d6b656
    style NoAuth fill:#d5e8d4,stroke:#82b366
    style GRPCAuth fill:#ffe6cc,stroke:#d79b00
    style HFToken fill:#e1d5e7,stroke:#9673a6
    style TLSCerts fill:#e1d5e7,stroke:#9673a6
    style APIKey fill:#e1d5e7,stroke:#9673a6
    style Note fill:#f5f5f5,stroke:#ccc,stroke-dasharray: 3 3
