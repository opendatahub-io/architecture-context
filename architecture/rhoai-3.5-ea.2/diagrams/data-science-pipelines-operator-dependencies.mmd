graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% Go Library Dependencies
    subgraph GoLibs["Go Libraries (Build-Time)"]
        CR["controller-runtime<br/>v0.23.3"]
        Manifestival["manifestival<br/>v0.7.2"]
        OSApi["openshift/api<br/>v0.0.0-20260331"]
        MinIOGo["minio-go<br/>v7.0.99"]
        MySQLDriver["go-sql-driver/mysql<br/>v1.9.3"]
        Viper["viper<br/>v1.21.0"]
        GoContainerReg["go-containerregistry<br/>v0.21.3"]
    end

    %% Platform Dependencies
    subgraph Platform["Platform Services"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
        OSAPI["OpenShift API<br/>443/TCP HTTPS"]
        ServiceCA["OpenShift Service CA<br/>Cert provisioning"]
        Prometheus["Prometheus /<br/>OpenShift Monitoring<br/>ServiceMonitor scrape"]
    end

    %% Internal RHOAI/ODH Dependencies
    subgraph InternalODH["Internal Platform Components"]
        RhodsOp["rhods-operator /<br/>opendatahub-operator<br/>Creates DSPA CRs"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
        ServiceCACM["openshift-service-ca.crt<br/>ConfigMap"]
    end

    %% Integration Points (Components DSPO enables)
    subgraph Integrations["Integration Targets"]
        KServe["KServe<br/>(serving.kserve.io)<br/>InferenceService CRs"]
        Ray["Ray<br/>(ray.io)<br/>RayCluster/RayJob CRs"]
        CodeFlare["CodeFlare<br/>(workload.codeflare.dev)<br/>AppWrapper CRs"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        ExtDB["External MariaDB/MySQL<br/>3306/TCP"]
        ExtS3["External S3 Storage<br/>443/TCP HTTPS"]
        OCIRegistry["OCI Container Registry<br/>443/TCP HTTPS"]
    end

    %% Build-time dependencies
    DSPO -.->|framework| CR
    DSPO -.->|manifest rendering| Manifestival
    DSPO -.->|OpenShift types| OSApi
    DSPO -.->|S3 health checks| MinIOGo
    DSPO -.->|DB health checks| MySQLDriver
    DSPO -.->|config mgmt| Viper
    DSPO -.->|image inspection| GoContainerReg

    %% Platform dependencies
    DSPO -->|CRD ops, RBAC| K8sAPI
    DSPO -->|Routes, images| OSAPI
    DSPO -->|TLS certs| ServiceCA
    Prometheus -->|scrapes metrics| DSPO

    %% Internal dependencies
    RhodsOp -->|creates DSPA CRs| DSPO
    DSPO -->|reads CA certs| CABundle
    DSPO -->|reads service CA| ServiceCACM

    %% Integration points
    DSPO -->|pipeline steps create| KServe
    DSPO -->|pipeline steps create| Ray
    DSPO -->|pipeline steps create| CodeFlare

    %% External services
    DSPO -->|metadata storage| ExtDB
    DSPO -->|artifact storage| ExtS3
    DSPO -->|managed pipeline images| OCIRegistry

