graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["maas-api<br/>(maas-api namespace)"]
        SA_Controller["maas-controller<br/>(opendatahub namespace)"]
        SA_PayloadProc["payload-processing<br/>(openshift-ingress namespace)"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_API["maas-api-binding<br/>(cluster-wide)"]
        CRB_API_Supp["maas-api-supplemental-binding<br/>(cluster-wide)"]
        CRB_Controller["maas-controller-role-binding<br/>(cluster-wide)"]
        CRB_Config["maas-controller-cluster-config-binding<br/>(cluster-wide)"]
        RB_LeaderElect["maas-controller-leader-election-binding<br/>(opendatahub namespace)"]
        CRB_Payload["payload-processing-reader-binding<br/>(cluster-wide)"]
    end

    subgraph Roles["ClusterRoles"]
        CR_API["maas-api"]
        CR_Controller["maas-controller-role"]
        CR_Config["maas-controller-cluster-config-role"]
        CR_LeaderElect["maas-controller-leader-election-role"]
        CR_Owner["maas-owner-role"]
        CR_Viewer["maas-viewer-role"]
        CR_Payload["payload-processing-reader"]
    end

    subgraph API_Resources["API Resources (maas-api)"]
        API_Secrets["core<br/>secrets<br/>get"]
        API_Namespaces["core<br/>namespaces<br/>get, list, watch, create"]
        API_SA["core<br/>serviceaccounts<br/>get, list, watch, create, delete"]
        API_SAToken["core<br/>serviceaccounts/token<br/>create"]
        API_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        API_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        API_MaasCRDs["maas.opendatahub.io<br/>maasauthpolicies, maasmodelrefs,<br/>maassubscriptions<br/>get, list, watch"]
        API_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>get, list, watch"]
    end

    subgraph Controller_Resources["API Resources (maas-controller)"]
        Ctrl_Core["core<br/>configmaps, serviceaccounts<br/>create, delete, get, list, patch, watch"]
        Ctrl_CoreRO["core<br/>secrets, endpoints, pods<br/>get, list, watch"]
        Ctrl_NS["core<br/>namespaces<br/>create, get, list, patch, update, watch"]
        Ctrl_Svc["core<br/>services<br/>full CRUD"]
        Ctrl_Apps["apps<br/>deployments<br/>create, delete, get, list, patch, watch"]
        Ctrl_Batch["batch<br/>cronjobs<br/>create, delete, get, list, patch, watch"]
        Ctrl_Gateway["gateway.networking.k8s.io<br/>httproutes<br/>full CRUD"]
        Ctrl_Kuadrant["kuadrant.io<br/>authpolicies, tokenratelimitpolicies,<br/>ratelimitpolicies<br/>full CRUD"]
        Ctrl_Maas["maas.opendatahub.io<br/>all custom resources<br/>full CRUD"]
        Ctrl_Inference["inference.opendatahub.io<br/>externalmodels, externalproviders<br/>full CRUD"]
        Ctrl_NetPol["networking.k8s.io<br/>networkpolicies<br/>create, delete, get, list, patch, watch"]
        Ctrl_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>create, delete, get, list, patch, watch"]
        Ctrl_Istio["telemetry.istio.io<br/>telemetries<br/>full CRUD"]
        Ctrl_Monitoring["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/>create, delete, get, list, patch, watch"]
    end

    subgraph Payload_Resources["API Resources (payload-processing)"]
        PP_Core["core<br/>configmaps, secrets<br/>get, list, watch"]
        PP_Maas["maas.opendatahub.io<br/>externalmodels<br/>get, list, watch, create, update"]
        PP_Inference["inference.opendatahub.io<br/>externalproviders, externalmodels<br/>full CRUD"]
    end

    subgraph AggregatedRoles["Aggregated User Roles"]
        Owner_Resources["maas.opendatahub.io<br/>maasmodelrefs, externalmodels<br/>full CRUD"]
        Viewer_Resources["maas.opendatahub.io<br/>maasmodelrefs, externalmodels<br/>get, list, watch"]
    end

    %% SA → Binding flows
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_API_Supp
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_Config
    SA_Controller -->|bound via| RB_LeaderElect
    SA_PayloadProc -->|bound via| CRB_Payload

    %% Binding → Role flows
    CRB_API -->|grants| CR_API
    CRB_Controller -->|grants| CR_Controller
    CRB_Config -->|grants| CR_Config
    RB_LeaderElect -->|grants| CR_LeaderElect
    CRB_Payload -->|grants| CR_Payload

    %% Role → Resources
    CR_API -->|permits| API_Secrets
    CR_API -->|permits| API_Namespaces
    CR_API -->|permits| API_SA
    CR_API -->|permits| API_SAToken
    CR_API -->|permits| API_TokenReview
    CR_API -->|permits| API_SAR
    CR_API -->|permits| API_MaasCRDs
    CR_API -->|permits| API_HTTPRoutes

    CR_Controller -->|permits| Ctrl_Core
    CR_Controller -->|permits| Ctrl_CoreRO
    CR_Controller -->|permits| Ctrl_NS
    CR_Controller -->|permits| Ctrl_Svc
    CR_Controller -->|permits| Ctrl_Apps
    CR_Controller -->|permits| Ctrl_Batch
    CR_Controller -->|permits| Ctrl_Gateway
    CR_Controller -->|permits| Ctrl_Kuadrant
    CR_Controller -->|permits| Ctrl_Maas
    CR_Controller -->|permits| Ctrl_Inference
    CR_Controller -->|permits| Ctrl_NetPol
    CR_Controller -->|permits| Ctrl_RBAC
    CR_Controller -->|permits| Ctrl_Istio
    CR_Controller -->|permits| Ctrl_Monitoring

    CR_Payload -->|permits| PP_Core
    CR_Payload -->|permits| PP_Maas
    CR_Payload -->|permits| PP_Inference

    CR_Owner -->|permits| Owner_Resources
    CR_Viewer -->|permits| Viewer_Resources

