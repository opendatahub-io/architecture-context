graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["${EPP_NAME}-binding"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["${EPP_NAME}"]
    end

    subgraph APIResources["API Resources"]
        subgraph GatewayAPIGroup["inference.networking.k8s.io"]
            InferencePools1["InferencePools"]
        end

        subgraph XK8sAPIGroup["inference.networking.x-k8s.io"]
            InferencePools2["InferencePools"]
            InferenceObjectives1["InferenceObjectives"]
            InferenceModelRewrites1["InferenceModelRewrites"]
        end

        subgraph LLMDAIGroup["llm-d.ai"]
            InferenceObjectives2["InferenceObjectives"]
            InferenceModelRewrites2["InferenceModelRewrites"]
        end

        subgraph CoreGroup["core ('')"]
            Pods["Pods"]
        end

        subgraph AuthNGroup["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph AuthZGroup["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Read-only permissions
    CR -->|"get, watch, list"| InferencePools1
    CR -->|"get, watch, list"| InferencePools2
    CR -->|"get, watch, list"| InferenceObjectives1
    CR -->|"get, watch, list"| InferenceModelRewrites1
    CR -->|"get, watch, list"| InferenceObjectives2
    CR -->|"get, watch, list"| InferenceModelRewrites2
    CR -->|"get, watch, list"| Pods

    %% Write permissions (security-sensitive)
    CR -->|"create ⚠"| TokenReviews
    CR -->|"create ⚠"| SubjectAccessReviews

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#b8d4f0,stroke:#333
    style CR fill:#f5a623,stroke:#333,color:#fff

    style InferencePools1 fill:#7ed321,stroke:#333,color:#fff
    style InferencePools2 fill:#7ed321,stroke:#333,color:#fff
    style InferenceObjectives1 fill:#7ed321,stroke:#333,color:#fff
    style InferenceModelRewrites1 fill:#7ed321,stroke:#333,color:#fff
    style InferenceObjectives2 fill:#7ed321,stroke:#333,color:#fff
    style InferenceModelRewrites2 fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff

    style TokenReviews fill:#ff6b6b,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#ff6b6b,stroke:#333,color:#fff
