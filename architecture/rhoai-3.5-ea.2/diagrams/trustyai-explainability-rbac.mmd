graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount<br/>Namespace: {user-namespace}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR["trustyai-role"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Granted Verbs"]
        direction LR
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"allows on"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph UsageContext["Usage Context"]
        direction TB
        InitContainer["Init Container<br/>Writes model-serving-config ConfigMap<br/>to register payload processor URL"]
        ConfigRead["Service Runtime<br/>Reads trustyai-config ConfigMap<br/>for service configuration"]
    end

    SA -.->|"used by"| InitContainer
    SA -.->|"used by"| ConfigRead

    subgraph AuthEnforcement["Authentication Enforcement (Platform-Level)"]
        direction TB
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x)<br/>Enforces RBAC on incoming requests"]
        OAuthProxy["oauth-proxy sidecar<br/>(RHOAI 2.x, legacy)<br/>OpenShift OAuth enforcement"]
        ServiceMonitorAuth["ServiceMonitor Auth<br/>bearerTokenFile:<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token"]
    end

    subgraph SecurityNotes["Security Notes"]
        Note1["⚠ No application-level auth<br/>All REST endpoints are unauthenticated<br/>in the Java application code"]
        Note2["⚠ ClusterRoleBinding grants cluster-wide<br/>ConfigMap CRUD — could be tightened<br/>to namespace-level RoleBindings"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#d5e8d4,stroke:#82b366
    style Delete fill:#f8cecc,stroke:#b85450
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Patch fill:#fff2cc,stroke:#d6b656
    style Update fill:#fff2cc,stroke:#d6b656
    style Watch fill:#d5e8d4,stroke:#82b366

    style KubeRBACProxy fill:#f8cecc,stroke:#b85450
    style OAuthProxy fill:#f8cecc,stroke:#b85450
    style ServiceMonitorAuth fill:#dae8fc,stroke:#6c8ebf

    style Note1 fill:#fff2cc,stroke:#d6b656
    style Note2 fill:#fff2cc,stroke:#d6b656
