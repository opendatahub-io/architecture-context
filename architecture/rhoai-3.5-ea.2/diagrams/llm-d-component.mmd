graph TB
    subgraph ClientLayer["Client Layer"]
        Client[External Client]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["llm-d-inference-gateway<br/>Gateway API<br/>80/TCP HTTP"]
    end

    subgraph RouterLayer["Intelligent Router (Helm Chart)"]
        Envoy["Envoy Proxy<br/>8081/TCP HTTP/HTTP2<br/>L7 Proxy"]
        EPP["Endpoint Picker (EPP)<br/>9002/TCP gRPC ext_proc<br/>Prefix-cache-aware routing"]
        Envoy -->|"gRPC ext_proc<br/>9002/TCP"| EPP
    end

    subgraph ModelServers["Model Server Pods"]
        direction TB
        subgraph DecodePool["Decode Pool (InferencePool)"]
            DecodePod1["Decode Pod<br/>vLLM 8000/TCP"]
            DecodePod2["Decode Pod<br/>vLLM 8000/TCP"]
        end
        subgraph PrefillPool["Prefill Pool (InferencePool)"]
            PrefillPod1["Prefill Pod<br/>vLLM 8000/TCP<br/>+ Routing Sidecar"]
            PrefillPod2["Prefill Pod<br/>vLLM 8000/TCP<br/>+ Routing Sidecar"]
        end
    end

    subgraph ContainerImages["Container Image Variants"]
        direction LR
        CUDA["llm-d-cuda<br/>NVIDIA CUDA<br/>vLLM + HPC libs"]
        GB200["llm-d-cuda-gb200<br/>GB200 variant"]
        CPU["llm-d-cpu<br/>CPU-only<br/>amd64/arm64"]
        ROCm["llm-d-rocm<br/>AMD ROCm<br/>MI300X"]
        XPU["llm-d-xpu<br/>Intel XPU"]
    end

    subgraph HPCLibraries["Compiled HPC Libraries (in CUDA image)"]
        direction LR
        UCX["UCX v1.20.0<br/>RDMA Transport"]
        UCCL["UCCL v0.1.1<br/>Collective Comms"]
        NVSHMEM["NVSHMEM v3.4.5<br/>GPU Shared Memory"]
        nixl["nixl v1.2.0<br/>KV Transfer"]
        FlashInfer["FlashInfer v0.6.12<br/>Attention Kernels"]
        DeepEP["DeepEP<br/>Expert Parallelism"]
        DeepGEMM["DeepGEMM<br/>MoE GEMM"]
        LMCache["LMCache v0.4.6<br/>KV Cache Offload"]
    end

    subgraph Tools["Diagnostic & Benchmarking"]
        RDMATools["llm-d-rdma-tools<br/>iperf3, perftest, nccl-tests"]
        InteractivePod["interactive-pod<br/>Benchmarking & Debugging"]
    end

    %% Traffic Flow
    Client -->|"HTTP 80/TCP"| Gateway
    Gateway -->|"HTTP/HTTP2 8081/TCP"| Envoy
    EPP -->|"HTTP 8000/TCP<br/>Health checks"| DecodePod1
    EPP -->|"HTTP 8000/TCP<br/>Health checks"| PrefillPod1
    Envoy -->|"HTTP 8000/TCP<br/>x-gateway-destination-endpoint"| DecodePod1
    Envoy -->|"HTTP 8000/TCP"| PrefillPod1

    %% KV Transfer
    PrefillPod1 -->|"nixl 5600/TCP<br/>RDMA KV Transfer"| DecodePod1

    %% EPP to K8s API
    EPP -->|"HTTPS 6443/TCP<br/>Pod Discovery"| K8sAPI["Kubernetes API"]

    %% Image composition
    CUDA -.->|"builds"| DecodePod1
    CUDA -.->|"builds"| PrefillPod1

    %% External services
    DecodePod1 -->|"HTTPS 443/TCP<br/>HF_TOKEN"| HFHub["Hugging Face Hub"]
    DecodePod1 -->|"gRPC 4317/TCP"| OTEL["OTEL Collector"]

    %% Styles
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Envoy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style DecodePod1 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style DecodePod2 fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style PrefillPod1 fill:#b6d7a8,stroke:#6aa84f,stroke-width:2px
    style PrefillPod2 fill:#b6d7a8,stroke:#6aa84f,stroke-width:2px
    style CUDA fill:#76b5c5,stroke:#333,stroke-width:2px
    style GB200 fill:#76b5c5,stroke:#333,stroke-width:2px
    style CPU fill:#76b5c5,stroke:#333,stroke-width:2px
    style ROCm fill:#76b5c5,stroke:#333,stroke-width:2px
    style XPU fill:#76b5c5,stroke:#333,stroke-width:2px
    style K8sAPI fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style HFHub fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style OTEL fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RDMATools fill:#e8e8e8,stroke:#999
    style InteractivePod fill:#e8e8e8,stroke:#999
