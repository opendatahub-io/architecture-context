graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["No Kubernetes RBAC resources<br/>defined in this repository.<br/>RBAC is managed by the<br/>platform operator (rhods-operator)."]
    end

    subgraph ApplicationAuth["Application-Level Auth (OGX Built-in)"]
        direction TB

        subgraph AuthMechanism["Authentication Mechanism"]
            OAuth2["OAuth2 Bearer Token (JWT)<br/>Validated via JWKS endpoint<br/>Issuer: AUTH_ISSUER env var<br/>Audience: AUTH_AUDIENCE (default: ogx)<br/>JWKS recheck: AUTH_JWKS_RECHECK_PERIOD (3600s)"]
        end

        subgraph AccessPolicy["Access Policy"]
            direction TB
            Health["/v1/health<br/>Unauthenticated<br/>No restrictions"]
            ReadUnowned["Unowned Resources<br/>READ: all users<br/>(authenticated or not)"]
            Create["Create Resources<br/>Requires authentication<br/>(valid JWT)"]
            CRUD["Read/Update/Delete<br/>Owned Resources<br/>Resource owner only"]
        end
    end

    subgraph Secrets["Secrets (Environment Variables)"]
        direction TB
        InferenceSecrets["Inference Auth<br/>─────────────<br/>VLLM_API_TOKEN<br/>OPENAI_API_KEY<br/>ANTHROPIC_API_KEY<br/>AZURE_API_KEY<br/>WATSONX_API_KEY<br/>AWS credentials"]
        DBSecrets["Database Auth<br/>─────────────<br/>POSTGRES_PASSWORD<br/>POSTGRES_USER"]
        VectorSecrets["Vector DB Auth<br/>─────────────<br/>MILVUS_TOKEN<br/>QDRANT_API_KEY"]
        ToolSecrets["Tool Auth<br/>─────────────<br/>BRAVE_SEARCH_API_KEY<br/>TAVILY_SEARCH_API_KEY"]
        BuildSecrets["Build-time Secrets<br/>─────────────<br/>rhel-ai-private-index-auth<br/>git_auth_secret"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC"]
        Operator["rhods-operator<br/>Manages Kubernetes RBAC<br/>for OGX deployment"]
        K8sRBAC["Kubernetes RBAC<br/>(ServiceAccount, Roles,<br/>RoleBindings)<br/>Defined by operator"]
        Operator --> K8sRBAC
    end

    OAuth2 --> AccessPolicy

    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style OAuth2 fill:#4a90e2,stroke:#333,color:#fff
    style Health fill:#7ed321,stroke:#333,color:#fff
    style ReadUnowned fill:#7ed321,stroke:#333,color:#fff
    style Create fill:#f5a623,stroke:#333,color:#fff
    style CRUD fill:#e74c3c,stroke:#333,color:#fff
    style InferenceSecrets fill:#f8cecc,stroke:#b85450
    style DBSecrets fill:#f8cecc,stroke:#b85450
    style VectorSecrets fill:#f8cecc,stroke:#b85450
    style ToolSecrets fill:#f8cecc,stroke:#b85450
    style BuildSecrets fill:#f8cecc,stroke:#b85450
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style K8sRBAC fill:#7ed321,stroke:#333,color:#fff
