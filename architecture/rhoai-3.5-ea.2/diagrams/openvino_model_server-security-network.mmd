graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-managed)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP<br/>TLS 1.3 Termination"]
        KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>AuthN: Service Account Token"]
    end

    subgraph Pod["POD (OVMS Container - UID 5000)"]
        direction TB

        subgraph RESTServer["REST Server (Drogon)"]
            REST["OVMS REST<br/>configurable/TCP HTTP<br/>Auth: API Key (optional)<br/>Encryption: None (plaintext)"]
        end

        subgraph gRPCServer["gRPC Server"]
            gRPC["OVMS gRPC<br/>configurable/TCP gRPC/HTTP2<br/>Auth: None<br/>Encryption: None (Insecure)"]
        end

        subgraph InferenceEngines["Inference Engines (in-process)"]
            OV["OpenVINO Runtime"]
            GenAI["OpenVINO GenAI<br/>LLM/VLM/STT/TTS"]
            MP["MediaPipe Graphs"]
        end

        Metrics["/metrics<br/>Prometheus<br/>No Auth"]
        Health["/v2/health/*<br/>Readiness/Liveness<br/>No Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / MinIO / Ceph<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Keys"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure Storage Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCS Service Account"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        Prometheus["Prometheus<br/>Metrics Scrape"]
        KServe["KServe / ModelMesh<br/>Container Runtime"]
    end

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SA Token"| KRBAC
    KRBAC -->|"HTTP/configurable<br/>Plaintext (localhost)<br/>No Auth"| REST

    %% Direct gRPC (when not via gateway)
    Client -.->|"gRPC/configurable<br/>Plaintext<br/>No Auth"| gRPC

    %% Internal processing
    REST --> OV
    REST --> GenAI
    REST --> MP
    gRPC --> OV
    gRPC --> MP

    %% Egress flows
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Key"| Azure
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>GCS SA"| GCS
    REST -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Platform
    Prometheus -->|"HTTP/configurable<br/>No Auth"| Metrics
    KServe -->|"Container Runtime"| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef insecure fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef health fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class Gateway,KRBAC ingress
    class REST,gRPC insecure
    class OV,GenAI,MP pod
    class S3,Azure,GCS,HFHub externalservice
    class Prometheus,KServe platform
    class Metrics,Health health
