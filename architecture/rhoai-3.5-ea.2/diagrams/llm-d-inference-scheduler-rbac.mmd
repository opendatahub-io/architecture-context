graph TD
    subgraph ServiceAccounts["Service Accounts"]
        EPPSA["EPP Controller SA<br/>(kserve/EPP namespace)"]
        SidecarSA["Sidecar SA<br/>(pod namespace)"]
        DevGroup["system:authenticated<br/>(Group - dev only)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        EPPCRB["EPP Controller<br/>ClusterRoleBinding"]
        EPPLeaderCRB["EPP Leader Election<br/>RoleBinding"]
        SidecarCRB["Sidecar Allowlist<br/>ClusterRoleBinding"]
        DevCRB["exec-rolebinding<br/>(${NAMESPACE})"]
    end

    subgraph ClusterRoles["Cluster Roles / Roles"]
        EPPRole["EPP Controller Role"]
        EPPLeaderRole["EPP Leader Election Role"]
        SidecarRole["Sidecar Allowlist Role"]
        DevRole["exec-role<br/>(dev only)"]
    end

    subgraph APIResources["API Resources"]
        subgraph Core["Core ('')"]
            Pods["pods"]
            Leases["leases"]
            PodsExec["pods/exec"]
        end

        subgraph InferenceGIE["inference.networking.x-k8s.io"]
            InferencePools["inferencepools"]
        end

        subgraph APIX["apix.gateway-api-inference-extension"]
            ModelRewrites["inferencemodelrewrites"]
            Objectives["inferenceobjectives"]
        end

        subgraph InferenceK8s["inference.networking.k8s.io"]
            InferencePoolsK8s["inferencepools"]
        end
    end

    %% EPP Controller bindings
    EPPSA -->|bound via| EPPCRB
    EPPCRB -->|grants| EPPRole
    EPPRole -->|"get, list, watch"| Pods
    EPPRole -->|"get, list, watch"| InferencePools
    EPPRole -->|"get, list, watch"| ModelRewrites
    EPPRole -->|"get, list, watch"| Objectives

    %% EPP Leader Election bindings
    EPPSA -->|bound via| EPPLeaderCRB
    EPPLeaderCRB -->|grants| EPPLeaderRole
    EPPLeaderRole -->|"get, list, watch,<br/>create, update, patch"| Leases

    %% Sidecar bindings
    SidecarSA -->|bound via| SidecarCRB
    SidecarCRB -->|grants| SidecarRole
    SidecarRole -->|"get, list, watch"| InferencePoolsK8s
    SidecarRole -->|"get, list, watch"| Pods

    %% Dev bindings
    DevGroup -->|bound via| DevCRB
    DevCRB -->|grants| DevRole
    DevRole -->|"create"| PodsExec

    %% Styling
    style EPPSA fill:#4a90e2,stroke:#333,color:#fff
    style SidecarSA fill:#4a90e2,stroke:#333,color:#fff
    style DevGroup fill:#e74c3c,stroke:#333,color:#fff

    style EPPRole fill:#f5a623,stroke:#333
    style EPPLeaderRole fill:#f5a623,stroke:#333
    style SidecarRole fill:#f5a623,stroke:#333
    style DevRole fill:#e74c3c,stroke:#333,color:#fff

    style Pods fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style PodsExec fill:#e74c3c,stroke:#333,color:#fff
    style InferencePools fill:#7ed321,stroke:#333
    style ModelRewrites fill:#7ed321,stroke:#333
    style Objectives fill:#7ed321,stroke:#333
    style InferencePoolsK8s fill:#7ed321,stroke:#333
