graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS ReEncrypt)"]
        RouteOnline["feast-online Route<br/>443/TCP → 443/6567 or 80/6566<br/>TLS ReEncrypt"]
        RouteOffline["feast-offline Route<br/>443/TCP → 443/8816 or 80/8815<br/>TLS ReEncrypt"]
        RouteRegistry["feast-registry Route<br/>443/TCP → 443/6570 or 80/6570<br/>TLS ReEncrypt"]
        RouteUI["feast-ui Route<br/>443/TCP → 443/8443 or 80/8888<br/>TLS ReEncrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (ClusterIP Services)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["Feast Operator<br/>SA: controller-manager<br/>Port: 8081 (health)<br/>FIPS: strictfipsruntime"]
        end

        subgraph UserNS["Namespace: {user-namespace}"]
            subgraph FeastPod["Feast Deployment (Multi-Container Pod)<br/>SA: feast-{name}"]
                OnlineServer["Online Server<br/>6566/TCP HTTP<br/>6567/TCP HTTPS<br/>8000/TCP metrics"]
                OfflineServer["Offline Server<br/>8815/TCP HTTP<br/>8816/TCP HTTPS"]
                RegistryServer["Registry Server<br/>6570/TCP gRPC<br/>6572/TCP REST"]
                UIServer["UI Server<br/>8888/TCP HTTP<br/>8443/TCP HTTPS"]
            end
            CronJob["Materialization CronJob<br/>kubectl exec"]
        end
    end

    subgraph PlatformServices["INTERNAL PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ServingCert["OpenShift Serving<br/>Cert Controller<br/>Auto-provision TLS"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP"]
        PlatformOp["rhods-operator<br/>Deploys Feast operator"]
        NotebookSvc["ODH Notebooks<br/>kubeflow.org/v1"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        OIDC["OIDC Provider<br/>(Keycloak/Azure AD)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public JWKS"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password Auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Username/Password"]
        DynamoDB["AWS DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        BigQuery["Google BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Username/Password"]
        S3GCS["S3/GCS Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM/SA creds"]
        Milvus["Milvus<br/>19530/TCP gRPC<br/>Optional TLS"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>OIDC/K8s Bearer"| RouteOnline
    Client -->|"HTTPS/443<br/>TLS<br/>OIDC/K8s Bearer"| RouteOffline
    Client -->|"HTTPS/443<br/>TLS<br/>OIDC/K8s Bearer"| RouteRegistry
    Client -->|"HTTPS/443<br/>TLS<br/>No Auth"| RouteUI

    %% Ingress → Services
    RouteOnline -->|"HTTP/6566 or HTTPS/6567<br/>OpenShift serving cert"| OnlineServer
    RouteOffline -->|"HTTP/8815 or HTTPS/8816<br/>OpenShift serving cert"| OfflineServer
    RouteRegistry -->|"gRPC/6570 or REST/6572<br/>OpenShift serving cert"| RegistryServer
    RouteUI -->|"HTTP/8888 or HTTPS/8443<br/>OpenShift serving cert"| UIServer

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"HTTP/6572<br/>Intra-comm JWT<br/>InsecureSkipVerify"| RegistryServer

    %% CronJob
    CronJob -->|"HTTPS/443<br/>SA token<br/>kubectl exec"| K8sAPI

    %% Service → External
    OnlineServer -->|"TCP/6379<br/>Optional TLS<br/>Password"| Redis
    OnlineServer -->|"TCP/5432<br/>Optional TLS<br/>User/Pass"| PostgreSQL
    OnlineServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| DynamoDB
    OfflineServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| BigQuery
    OfflineServer -->|"HTTPS/443<br/>TLS 1.2+<br/>User/Pass"| Snowflake
    RegistryServer -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA"| S3GCS
    OnlineServer -->|"gRPC/19530<br/>Optional TLS"| Milvus

    %% Auth flow
    OnlineServer -->|"HTTPS/443<br/>JWKS Discovery"| OIDC
    OfflineServer -->|"HTTPS/443<br/>JWKS Discovery"| OIDC
    RegistryServer -->|"HTTPS/443<br/>JWKS Discovery"| OIDC

    %% Platform
    Prometheus -->|"HTTP/8000<br/>No Auth"| OnlineServer
    ServingCert -.->|"Provisions TLS<br/>Secrets"| FeastPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class Operator,OnlineServer,OfflineServer,RegistryServer,UIServer,CronJob cluster
    class K8sAPI,ServingCert,Prometheus,PlatformOp,NotebookSvc platform
    class OIDC,Redis,PostgreSQL,DynamoDB,BigQuery,Snowflake,S3GCS,Milvus externalservice
