graph LR
    PC["Pipelines Components<br/>(Init Container +<br/>Component Library)"]

    %% Internal RHOAI Dependencies (consumers and integrations)
    PC -->|"init container<br/>deployed by"| DSPO["Data Science Pipelines<br/>Operator (DSPO)"]
    PC -->|"shared volume<br/>pipeline YAMLs"| KFPServer["KFP API Server"]
    PC -->|"KFP SDK<br/>step execution"| KFPOrch["KFP Orchestrator"]
    PC -->|"REST/gRPC<br/>80/443"| KServe["KServe"]
    PC -->|"CRD<br/>K8s API"| TrainingHub["Training Hub<br/>(ClusterTrainingRuntime)"]
    PC -->|"REST API<br/>8080/TCP"| ModelReg["Kubeflow Model<br/>Registry"]
    PC -->|"REST API<br/>443/TCP"| EvalHub["Eval Hub"]

    %% External Service Dependencies
    PC -->|"HTTPS/443<br/>AWS IAM"| S3["S3-compatible<br/>Storage"]
    PC -->|"HTTPS/443<br/>Bearer Token"| HFHub["HuggingFace Hub"]
    PC -->|"HTTPS/443<br/>API key"| OGX["OGX API"]
    PC -->|"gRPC/19530<br/>Plaintext"| Milvus["Milvus<br/>Vector DB"]
    PC -->|"HTTPS/gRPC/443<br/>API key"| SDGHub["LiteLLM /<br/>SDG Hub"]

    %% Python Library Dependencies
    PC -->|"core SDK"| KFP["kfp >=2.16.1"]
    PC -->|"K8s extensions"| KFPK8s["kfp-kubernetes >=2.16.1"]

    %% AutoML-specific dependencies
    subgraph AutoMLDeps["AutoML Runtime Dependencies"]
        AutoGluon["AutoGluon 1.5.0+rhaiv.3"]
        PyTorch["PyTorch 2.11.0"]
        ScikitLearn["scikit-learn >=1.7.2"]
    end
    PC -.->|"odh-automl image"| AutoMLDeps

    %% AutoRAG-specific dependencies
    subgraph AutoRAGDeps["AutoRAG Runtime Dependencies"]
        Docling["Docling 2.88.0"]
        LangChain["LangChain 1.1.3"]
        ai4rag["ai4rag 0.6.4"]
        ogx_client["ogx_client 1.1.0"]
        chromadb["chromadb 1.5.9"]
    end
    PC -.->|"odh-autorag image"| AutoRAGDeps

    %% Build-time dependency
    PC -.->|"build-time COPY<br/>OCI image layers"| DoclingModelcar["Docling Modelcar<br/>Images"]

    %% Shared dependencies
    PC -->|"S3 client"| boto3["boto3 >=1.43.23"]
    PC -->|"model loading"| transformers["transformers >=4.57.6"]

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style KFPServer fill:#7ed321,stroke:#333,color:#fff
    style KFPOrch fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style TrainingHub fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style EvalHub fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style OGX fill:#f5a623,stroke:#333,color:#fff
    style Milvus fill:#f5a623,stroke:#333,color:#fff
    style SDGHub fill:#f5a623,stroke:#333,color:#fff
    style DoclingModelcar fill:#f5a623,stroke:#333,color:#fff

    %% Python Libraries
    style KFP fill:#999,stroke:#333,color:#fff
    style KFPK8s fill:#999,stroke:#333,color:#fff
    style boto3 fill:#999,stroke:#333,color:#fff
    style transformers fill:#999,stroke:#333,color:#fff

    %% Runtime dep groups
    style AutoGluon fill:#e67e22,stroke:#333,color:#fff
    style PyTorch fill:#e67e22,stroke:#333,color:#fff
    style ScikitLearn fill:#e67e22,stroke:#333,color:#fff
    style Docling fill:#8e44ad,stroke:#333,color:#fff
    style LangChain fill:#8e44ad,stroke:#333,color:#fff
    style ai4rag fill:#8e44ad,stroke:#333,color:#fff
    style ogx_client fill:#8e44ad,stroke:#333,color:#fff
    style chromadb fill:#8e44ad,stroke:#333,color:#fff
