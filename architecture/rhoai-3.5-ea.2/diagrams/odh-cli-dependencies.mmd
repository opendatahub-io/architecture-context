graph LR
    ODHCLI["odh-cli<br/>(rhai-cli)"]

    %% External Dependencies
    ODHCLI -->|"all operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>1.28+"]
    ODHCLI -->|"OpenShift features<br/>6443/TCP HTTPS"| OSAPI["OpenShift API Server<br/>4.14+"]
    ODHCLI -->|"deps install<br/>6443/TCP HTTPS"| OLM["OLM<br/>(Operator Lifecycle Manager)"]
    ODHCLI -->|"lint checks<br/>6443/TCP HTTPS"| CertManager["cert-manager"]
    ODHCLI -.->|"build-time fetch<br/>443/TCP HTTPS"| OdhGitops["odh-gitops<br/>(GitHub)"]

    %% Internal ODH Dependencies (Go module)
    ODHCLI -->|"Go module import<br/>(clusterhealth pkg)"| OdhOperator["opendatahub-operator"]

    %% CRD Dependencies (Read/Patch)
    ODHCLI -->|"read/patch<br/>component state"| DSC["DataScienceCluster CR<br/>dscoperator.opendatahub.io/v2"]
    ODHCLI -->|"read<br/>namespace discovery"| DSCI["DSCInitialization CR<br/>dscoperator.opendatahub.io/v2"]

    %% Workload CRD Dependencies
    ODHCLI -->|"read/patch<br/>model serving migration"| ISVC["InferenceService<br/>serving.kserve.io/v1beta1"]
    ODHCLI -->|"read/patch<br/>multi→single model"| SR["ServingRuntime<br/>serving.kserve.io/v1alpha1"]
    ODHCLI -->|"read/patch<br/>container name fix"| Notebook["Notebook<br/>kubeflow.org/v1"]
    ODHCLI -->|"read/create/delete<br/>backup & recreate"| RayCluster["RayCluster<br/>ray.io/v1"]
    ODHCLI -->|"read/patch<br/>v1alpha1→v1 migration"| DSPA["DSPA<br/>v1 / v1alpha1"]
    ODHCLI -->|"read<br/>RHBOK migration"| Kueue["ClusterQueue / LocalQueue<br/>kueue.x-k8s.io/v1beta1"]
    ODHCLI -->|"read<br/>data backup"| TrustyAI["TrustyAIService<br/>opendatahub.io"]
    ODHCLI -->|"read/patch<br/>probe + schema migration"| Guardrails["GuardrailsOrchestrator"]
    ODHCLI -->|"read<br/>backup before OGX rename"| LlamaStack["LlamaStackDistribution<br/>opendatahub.io"]
    ODHCLI -->|"read<br/>v1→v2 readiness"| TrainingJobs["PyTorchJob / TFJob /<br/>MPIJob / XGBoostJob<br/>kubeflow.org/v1"]
    ODHCLI -->|"read<br/>v2 API check"| TrainJob["TrainJob<br/>trainer.kubeflow.org/v1"]

    %% External Service Dependencies
    ODHCLI -->|"metrics backup/restore<br/>443/TCP HTTPS"| TrustyAIRoute["TrustyAI REST API<br/>(via OpenShift Route)"]

