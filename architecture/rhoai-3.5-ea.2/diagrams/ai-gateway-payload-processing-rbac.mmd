graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["payload-processing-{release}<br/>(deployment namespace)"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["{release}-externalmodels-reader<br/>(Cluster-scoped when multiNamespace=true)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["{release}-externalmodels-reader"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        Secrets["core/v1<br/>secrets"]
        Services["core/v1<br/>services"]
    end

    subgraph MaaSResources["maas.opendatahub.io Resources"]
        MaaSExternalModels["maas.opendatahub.io<br/>externalmodels"]
    end

    subgraph InferenceResources["inference.opendatahub.io Resources"]
        ExtProviders["inference.opendatahub.io<br/>externalproviders"]
        ExtModels["inference.opendatahub.io<br/>externalmodels"]
        ExtProvidersStatus["inference.opendatahub.io<br/>externalproviders/status"]
        ExtModelsStatus["inference.opendatahub.io<br/>externalmodels/status"]
        ExtProvidersFinalizers["inference.opendatahub.io<br/>externalproviders/finalizers"]
        ExtModelsFinalizers["inference.opendatahub.io<br/>externalmodels/finalizers"]
    end

    subgraph GatewayAPIResources["gateway.networking.k8s.io Resources"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
    end

    subgraph IstioResources["networking.istio.io Resources"]
        ServiceEntries["networking.istio.io<br/>serviceentries"]
        DestinationRules["networking.istio.io<br/>destinationrules"]
    end

    %% Binding chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch,<br/>create, update, delete"| Services

    CR -->|"get, list, watch"| MaaSExternalModels

    CR -->|"get, list, watch,<br/>create, update"| ExtProviders
    CR -->|"get, list, watch,<br/>create, update"| ExtModels
    CR -->|"get, update, patch"| ExtProvidersStatus
    CR -->|"get, update, patch"| ExtModelsStatus
    CR -->|"update"| ExtProvidersFinalizers
    CR -->|"update"| ExtModelsFinalizers

    CR -->|"get, list, watch,<br/>create, update, delete"| HTTPRoutes

    CR -->|"get, list, watch,<br/>create, update, delete"| ServiceEntries
    CR -->|"get, list, watch,<br/>create, update, delete"| DestinationRules

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#5ba3f5,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff

    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style MaaSExternalModels fill:#d5e8d4,stroke:#82b366
    style ExtProviders fill:#7ed321,stroke:#333,color:#fff
    style ExtModels fill:#7ed321,stroke:#333,color:#fff
    style ExtProvidersStatus fill:#a8d98a,stroke:#82b366
    style ExtModelsStatus fill:#a8d98a,stroke:#82b366
    style ExtProvidersFinalizers fill:#a8d98a,stroke:#82b366
    style ExtModelsFinalizers fill:#a8d98a,stroke:#82b366
    style HTTPRoutes fill:#dae8fc,stroke:#6c8ebf
    style ServiceEntries fill:#ffe6cc,stroke:#d79b00
    style DestinationRules fill:#ffe6cc,stroke:#d79b00
