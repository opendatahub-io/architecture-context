graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_Operator["Namespace: workbenches-operator-system"]
            Controller["workbenches-operator<br/>Controller Manager<br/>SA: controller-manager<br/>UID: 65532 (non-root)<br/>FIPS: strictfipsruntime"]
            Metrics["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS (auto-provisioned)<br/>Auth: Bearer Token (SAR)"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>No encryption<br/>Auth: None"]
            Controller --- Metrics
            Controller --- Health
        end

        subgraph NS_Workbench["Namespace: rhods-notebooks"]
            WBDeploys["Workbench Deployments<br/>label: app.opendatahub.io/workbenches=true<br/>(Kubeflow Notebook Controller)"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        WorkbenchesCR["Workbenches CR<br/>components.platform.opendatahub.io/v1alpha1<br/>Cluster-scoped, singleton (name=default)"]

        Orchestrator["Platform Orchestrator<br/>(rhods-operator)<br/>Creates & projects config"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    %% Flows
    Orchestrator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI ---|manages| WorkbenchesCR

    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD: Workbenches, Namespaces,<br/>Deployments, SubjectAccessReviews"| K8sAPI

    Controller -.->|"LIST deployments<br/>(via K8s API)"| WBDeploys

    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token (SAR)"| Metrics

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef endpoint fill:#5ba5e6,stroke:#333,stroke-width:1px,color:#fff
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    classDef cr fill:#f5a623,stroke:#d79b00,stroke-width:2px,color:#fff
    classDef platform fill:#7ed321,stroke:#5ea018,stroke-width:2px,color:#fff
    classDef workload fill:#50c8e8,stroke:#3aa8c8,stroke-width:2px,color:#fff
    classDef monitoring fill:#e6e6e6,stroke:#999,stroke-width:1px

    class Controller operator
    class Metrics,Health endpoint
    class K8sAPI k8s
    class WorkbenchesCR cr
    class Orchestrator platform
    class WBDeploys workload
    class Prometheus monitoring
