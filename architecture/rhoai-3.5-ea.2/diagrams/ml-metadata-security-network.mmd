graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph Consumers["CONSUMERS"]
            DSP["Data Science Pipelines<br/>(ML Pipeline Controller)<br/>Namespace: {dspa-namespace}"]
            PipelineUI["Pipeline UI (Frontend)<br/>(indirect via API server)"]
        end

        subgraph MLMDService["MLMD SERVICE"]
            MLMD["MLMD gRPC Server<br/>(metadata_store_server)<br/>ClusterIP :8080/TCP<br/>gRPC/HTTP2<br/>UID: 65534 (non-root)<br/>Image: odh-mlmd-grpc-server (UBI9)"]
            TLSConfig["TLS: Optional SSLConfig<br/>Crypto: BoringSSL (via gRPC)<br/>mTLS: client_verify flag<br/>CA: custom_ca bundle"]
            MLMD --- TLSConfig
        end

        subgraph DatabaseLayer["DATABASE LAYER"]
            MySQL["MySQL / MariaDB<br/>3306/TCP<br/>SSL: Optional<br/>(cert/key/ca/cipher)<br/>Auth: Username/password"]
            PostgreSQL["PostgreSQL<br/>5432/TCP<br/>SSL: Optional<br/>(sslmode/sslcert/sslkey)<br/>Auth: Username/password"]
            SQLite["SQLite (In-Memory)<br/>Embedded, no network"]
        end
    end

    subgraph Secrets["SECRETS"]
        DBCreds["Database Credentials<br/>(Opaque)<br/>Provisioned by: DSP Controller<br/>Auto-Rotate: No"]
        TLSCerts["TLS Certificates<br/>(kubernetes.io/tls)<br/>Optional server key/cert + client CA<br/>Provisioned by: Manual/cert-manager"]
    end

    %% Consumer flows
    DSP -->|"gRPC/HTTP2 :8080<br/>Optional TLS/mTLS<br/>Primary consumer"| MLMD
    PipelineUI -->|"gRPC/HTTP2 :8080<br/>Optional TLS<br/>Lineage queries"| MLMD

    %% Database flows
    MLMD -->|"MySQL Protocol :3306<br/>Optional SSL<br/>Username/password"| MySQL
    MLMD -->|"PostgreSQL Protocol :5432<br/>Optional SSL<br/>Username/password"| PostgreSQL
    MLMD -->|"Embedded<br/>No network"| SQLite

    %% Secret references
    DBCreds -.->|"credentials"| MLMD
    TLSCerts -.->|"TLS config"| MLMD

    %% Styling
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef tlsinfo fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class DSP,PipelineUI consumer
    class MLMD service
    class TLSConfig tlsinfo
    class MySQL,PostgreSQL,SQLite database
    class DBCreds,TLSCerts secret
