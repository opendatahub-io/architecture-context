graph LR
    KServe["KServe<br/><i>Multi-Controller Operator</i>"]

    %% External Dependencies (Required/Conditional)
    KServe -->|"TLS certs<br/>(Required)"| CertMgr["cert-manager"]
    KServe -->|"VirtualService routing<br/>DestinationRule<br/>(Conditional)"| Istio["Istio /<br/>OpenShift Service Mesh"]
    KServe -->|"Serverless autoscaling<br/>(Conditional)"| Knative["Knative Serving"]
    KServe -->|"Prometheus-based<br/>autoscaling<br/>(Conditional)"| KEDA["KEDA"]
    KServe -->|"HTTPRoute/Gateway<br/>routing<br/>(Conditional)"| GatewayAPI["Gateway API CRDs<br/><i>v1</i>"]
    KServe -->|"EPP scheduler<br/>InferencePool<br/>(Conditional)"| IGE["Inference Gateway<br/>Extension"]
    KServe -->|"Multi-node<br/>distributed serving<br/>(Conditional)"| LWS["LeaderWorkerSet<br/>Operator"]
    KServe -->|"WVA-based autoscaling<br/>(Conditional)"| CMA["Custom Metrics<br/>Autoscaler"]
    KServe -->|"OTel collector<br/>sidecars<br/>(Conditional)"| OTelOp["OpenTelemetry<br/>Operator"]

    %% Internal Platform Dependencies
    KServe -.->|"Kserve CR<br/>lifecycle mgmt"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    KServe -.->|"cluster detection<br/>kustomize rendering"| ODHPlatUtils["odh-platform-utilities<br/><i>Go library</i>"]
    KServe -.->|"OpenShift Route<br/>for InferenceGraph"| OSRoute["OpenShift Route API<br/><i>route.openshift.io</i>"]
    KServe -.->|"OAuth proxy<br/>sidecar (legacy)"| OSOAuth["OpenShift OAuth"]

    %% Integration Points (components that integrate with KServe)
    Dashboard["ODH Dashboard"] -->|"UI model serving<br/>management"| KServe
    Pipelines["Data Science<br/>Pipelines"] -->|"auto-deploy<br/>models"| KServe
    ODHModelCtrl["odh-model-controller"] -->|"webhook intercept<br/>ISVC/IG mutation"| KServe
    Prometheus["Prometheus"] -->|"metrics scrape<br/>8080/TCP, 8443/TCP"| KServe

    %% External Services (Egress)
    KServe -->|"model download<br/>443/TCP HTTPS<br/>IAM/Access Key"| S3["S3-compatible<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS<br/>GCP SA"| GCS["Google Cloud<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS<br/>Azure Identity"| AzureBlob["Azure Blob<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS<br/>HF Token"| HFHub["HuggingFace Hub"]
    KServe -->|"model download<br/>Kerberos"| HDFS["HDFS Clusters"]

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style CertMgr fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style IGE fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style CMA fill:#999,stroke:#333,color:#fff
    style OTelOp fill:#999,stroke:#333,color:#fff

    %% Internal Platform
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style ODHPlatUtils fill:#7ed321,stroke:#333,color:#fff
    style OSRoute fill:#7ed321,stroke:#333,color:#fff
    style OSOAuth fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff
    style ODHModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
