graph TD
    subgraph PlatformAuth["Platform-Level Authentication (RHOAI)"]
        direction TB
        JWT["Bearer Token (JWT)"]
        TokenReview["Kubernetes TokenReview"]
        SAR["SubjectAccessReview"]

        JWT -->|"validated by"| TokenReview
        TokenReview -->|"authorizes via"| SAR
    end

    subgraph KubeRBACProxyLayer["kube-rbac-proxy Sidecar (8443/TCP)"]
        Proxy["kube-rbac-proxy<br/>TLS Termination + K8s RBAC"]
    end

    subgraph AppRBAC["Application-Level RBAC (MLflow)"]
        direction TB
        AuthMW["Auth Middleware"]

        subgraph Roles["Workspace-Scoped Roles"]
            AdminRole["Admin Role<br/>Full workspace management"]
            EditorRole["Editor Role<br/>Create/edit experiments, runs, models"]
            ReaderRole["Reader Role<br/>Read-only access"]
        end

        subgraph Permissions["Per-Resource Permissions"]
            ExpPerm["Experiments<br/>CRUD + search"]
            RunPerm["Runs<br/>CRUD + log metrics/params"]
            ModelPerm["Registered Models<br/>CRUD + versions"]
            VersionPerm["Model Versions<br/>CRUD + stage transitions"]
            GatewayPerm["Gateway Endpoints<br/>Invocations"]
        end

        subgraph AdminOnly["Admin-Only Operations"]
            UserMgmt["User Management<br/>/api/2.0/mlflow/users/*<br/>create, update, delete"]
            PermMgmt["Permission Management<br/>/api/3.0/mlflow/users/permissions/*<br/>grant, revoke"]
            RoleMgmt["Role Management<br/>/api/3.0/mlflow/roles/*<br/>create, update, delete"]
        end

        AuthMW -->|"checks"| Roles
        AdminRole -->|"grants"| ExpPerm
        AdminRole -->|"grants"| RunPerm
        AdminRole -->|"grants"| ModelPerm
        AdminRole -->|"grants"| VersionPerm
        AdminRole -->|"grants"| GatewayPerm
        AdminRole -->|"grants"| AdminOnly

        EditorRole -->|"grants"| ExpPerm
        EditorRole -->|"grants"| RunPerm
        EditorRole -->|"grants"| ModelPerm
        EditorRole -->|"grants"| VersionPerm
        EditorRole -->|"grants"| GatewayPerm

        ReaderRole -->|"grants read"| ExpPerm
        ReaderRole -->|"grants read"| RunPerm
        ReaderRole -->|"grants read"| ModelPerm
        ReaderRole -->|"grants read"| VersionPerm
    end

    subgraph NoAuth["No Authentication Required"]
        HealthEndpoint["/health, /version<br/>Public health/version"]
        MetricsEndpoint["/metrics<br/>Prometheus scrape"]
        OTLPEndpoint["/v1/traces<br/>OTLP standard (open)"]
    end

    subgraph ServiceAccounts["Kubernetes Service Accounts"]
        MLflowSA["mlflow<br/>ServiceAccount"]
        HelmSA["Helm-created SA<br/>(configurable)"]
    end

    subgraph HelmRBAC["Helm Chart RBAC (Optional)"]
        NamespaceRole["Namespace Role<br/>(namespace_rbac.extraRules)"]
        ClusterRole["Cluster Role<br/>(cluster_rbac.extraRules)"]
        NamespaceRB["Namespace RoleBinding"]
        ClusterRB["ClusterRoleBinding"]

        HelmSA -->|"bound via"| NamespaceRB
        HelmSA -->|"bound via"| ClusterRB
        NamespaceRB -->|"grants"| NamespaceRole
        ClusterRB -->|"grants"| ClusterRole
    end

    subgraph Secrets["Secrets & Crypto"]
        TLSSecret["mlflow-tls<br/>kubernetes.io/tls<br/>TLS cert/key"]
        DBSecret["mlflow-db-secret<br/>Opaque<br/>PostgreSQL URI"]
        KEK["MLFLOW_CRYPTO_KEK_PASSPHRASE<br/>env var<br/>AES-256-GCM envelope encryption<br/>PBKDF2-HMAC-SHA256 600K iter"]
        FlaskKey["MLFLOW_FLASK_SERVER_SECRET_KEY<br/>env var<br/>Session cookie signing"]
    end

    %% Flow: External request through auth layers
    JWT --> Proxy
    Proxy -->|"authorized request"| AuthMW
    SAR -.->|"K8s RBAC check"| Proxy

    %% Service account usage
    MLflowSA -->|"used by"| Proxy

    %% Styling
    style JWT fill:#f5a623,stroke:#333
    style Proxy fill:#ffe6cc,stroke:#d79b00
    style AuthMW fill:#4a90e2,stroke:#333,color:#fff
    style AdminRole fill:#e74c3c,stroke:#333,color:#fff
    style EditorRole fill:#f39c12,stroke:#333,color:#fff
    style ReaderRole fill:#27ae60,stroke:#333,color:#fff
    style MLflowSA fill:#4a90e2,stroke:#333,color:#fff
    style HelmSA fill:#4a90e2,stroke:#333,color:#fff
    style TLSSecret fill:#9b59b6,stroke:#333,color:#fff
    style DBSecret fill:#9b59b6,stroke:#333,color:#fff
    style KEK fill:#9b59b6,stroke:#333,color:#fff
    style FlaskKey fill:#9b59b6,stroke:#333,color:#fff
    style HealthEndpoint fill:#95a5a6,stroke:#333,color:#fff
    style MetricsEndpoint fill:#95a5a6,stroke:#333,color:#fff
    style OTLPEndpoint fill:#95a5a6,stroke:#333,color:#fff
