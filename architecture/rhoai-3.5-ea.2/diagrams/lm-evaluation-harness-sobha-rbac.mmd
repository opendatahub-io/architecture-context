graph TD
    subgraph JobPod["LMEval Job Pod"]
        SA["ServiceAccount<br/>(managed by LMEval Operator)"]
    end

    subgraph OperatorManaged["RBAC — Managed by TrustyAI LMEval Operator"]
        direction TB
        Note1["No RBAC definitions in this repository"]
        Note2["The TrustyAI LMEval Operator (lmes-controller)<br/>manages all RBAC for the job pods it creates"]
        Note3["Service account, roles, and bindings are<br/>configured by the operator at job creation time"]
    end

    subgraph Secrets["Secrets Accessed (Volume Mounts)"]
        ModelAuth["Model Auth Secret<br/>(model.auth.secret_ref)<br/>Type: Opaque<br/>Contains: API key, HF token, CA cert<br/>Provisioned by: User / LMEval Operator<br/>Auto-rotate: No"]
        OCIAuth["OCI Registry Auth<br/>(oci_auth_config_path)<br/>Type: dockerconfigjson<br/>Contains: Registry push credentials<br/>Provisioned by: User / Platform Operator<br/>Auto-rotate: No"]
        GitAuth["Git Auth Secret<br/>(git_auth_secret)<br/>Type: kubernetes.io/basic-auth<br/>Contains: Git credentials<br/>Provisioned by: Konflux / PipelinesAsCode<br/>Auto-rotate: No"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        ModelBearerAuth["Model Serving<br/>Bearer Token (OPENAI_API_KEY)<br/>Enforced: main.py:488-494"]
        HFTokenAuth["HuggingFace Hub<br/>Bearer Token (HF_TOKEN)<br/>Enforced: main.py:498-502<br/>Optional (gated repos only)"]
        EvalHubAuth["EvalHub Callback<br/>Bearer Token<br/>Enforced: eval-hub-sdk"]
        OCICredsAuth["OCI Registry<br/>Registry credentials<br/>Enforced: skopeo / eval-hub-sdk"]
        S3IAMAuth["S3 Storage<br/>AWS IAM credentials<br/>Enforced: boto3"]
    end

    SA -->|"volume mount"| ModelAuth
    SA -->|"volume mount"| OCIAuth
    SA -.->|"build-time only"| GitAuth
    SA -->|"uses"| OperatorManaged

    ModelAuth -->|"resolves to"| ModelBearerAuth
    ModelAuth -->|"resolves to"| HFTokenAuth
    OCIAuth -->|"resolves to"| OCICredsAuth

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style Note1 fill:#fff3cd,stroke:#ffc107,color:#333
    style Note2 fill:#fff3cd,stroke:#ffc107,color:#333
    style Note3 fill:#fff3cd,stroke:#ffc107,color:#333
    style ModelAuth fill:#f5a623,color:#333
    style OCIAuth fill:#f5a623,color:#333
    style GitAuth fill:#f5a623,color:#333,stroke-dasharray: 5 5
    style ModelBearerAuth fill:#7ed321,color:#333
    style HFTokenAuth fill:#7ed321,color:#333
    style EvalHubAuth fill:#7ed321,color:#333
    style OCICredsAuth fill:#7ed321,color:#333
    style S3IAMAuth fill:#7ed321,color:#333
