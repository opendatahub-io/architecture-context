graph LR
    TrainingHub["Training Hub SDK<br/>v0.8.1"]

    %% Core Required Dependencies
    subgraph CoreDeps["Core Dependencies (Required)"]
        direction TB
        torch["torch >=2.6.0"]
        transformers["transformers >=4.46.0"]
        datasets["datasets >=3.0.0"]
        peft["peft >=0.15.0"]
        pydantic["pydantic >=2.0.0"]
        accelerate["accelerate"]
        pandas["pandas"]
        numpy["numpy"]
        matplotlib["matplotlib"]
        numba["numba >=0.61.2"]
        timm["timm"]
    end

    %% Training Backend Dependencies
    subgraph TrainingBackends["Training Backends (Required)"]
        direction TB
        instructlab["instructlab-training<br/>>=0.11.0"]
        minitrainer["rhai-innovation-<br/>mini-trainer >=0.0.6"]
    end

    %% CUDA Optional Dependencies
    subgraph CUDADeps["CUDA Extras (Optional)"]
        direction TB
        flashattn["flash-attn >=2.7.0"]
        bitsandbytes["bitsandbytes >=0.45.0"]
        ligerkernel["liger-kernel"]
        mambassm["mamba-ssm >=2.2.4"]
    end

    %% LoRA Optional Dependencies
    subgraph LoRADeps["LoRA Extras (Optional)"]
        direction TB
        unsloth["unsloth >=2025.3.19"]
        trl["trl >=0.16.0"]
        xformers["xformers"]
    end

    %% GRPO Optional Dependencies
    subgraph GRPODeps["GRPO Extras (Optional)"]
        direction TB
        art["openpipe-art"]
        verl["verl >=0.3.1.post1"]
        litellm["litellm >=1.71.1<br/>!=1.82.7, !=1.82.8"]
        vllm["vllm"]
        mathverify["math-verify"]
    end

    %% GEPA Optional Dependencies
    subgraph GEPADeps["GEPA Extras (Optional)"]
        direction TB
        gepalib["gepa"]
        mlflow["mlflow"]
    end

    %% Internal Platform Dependencies
    subgraph InternalDeps["Internal RHOAI (Optional)"]
        direction TB
        itshub["ITS Hub<br/>Python API"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        direction TB
        hfhub["HuggingFace Hub<br/>HTTPS/443"]
        wandb["Weights & Biases<br/>HTTPS/443"]
        mlflowsvc["MLflow Server<br/>HTTP/HTTPS"]
        tboard["TensorBoard<br/>Local files"]
    end

