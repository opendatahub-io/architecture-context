graph TB
    subgraph "workbenches-operator"
        Controller["Workbenches Controller<br/>(controller-runtime)"]
        HealthProbe["Health Probes<br/>8081/TCP HTTP"]
        MetricsServer["Metrics Server<br/>8443/TCP HTTPS<br/>SubjectAccessReview Auth"]
        Controller --> HealthProbe
        Controller --> MetricsServer
    end

    subgraph "Reconciliation Logic"
        ConfigDeps["configureDependencies()<br/>Namespace Management"]
        CheckDeploy["checkDeployments()<br/>Health Monitoring"]
        KustomizeParams["computeKustomizeParams()<br/>(pending manifest application)"]
        Controller -->|reconcileManaged| ConfigDeps
        ConfigDeps --> CheckDeploy
        Controller -.->|computed but not applied| KustomizeParams
    end

    Orchestrator["Platform Orchestrator<br/>(rhods-operator /<br/>opendatahub-operator)"] -->|creates & projects config| WorkbenchesCR["Workbenches CR<br/>(Cluster-scoped)<br/>components.platform.opendatahub.io/v1alpha1"]
    WorkbenchesCR -->|watched by| Controller

    Controller -->|creates/labels| WBNamespace["Workbench Namespace<br/>(rhods-notebooks / opendatahub)"]
    Controller -->|lists deployments with<br/>app.opendatahub.io/workbenches=true| WBDeployments["Workbench Deployments<br/>(Kubeflow Notebook Controller)"]
    Controller -->|updates status| WorkbenchesCR

    subgraph "Status Conditions"
        Ready["Ready"]
        Provisioning["ProvisioningSucceeded"]
        Degraded["Degraded"]
        DeploymentsAvail["DeploymentsAvailable"]
    end

    Controller -->|reports| Ready
    Controller -->|reports| Provisioning
    Controller -->|reports| Degraded
    Controller -->|reports| DeploymentsAvail

    subgraph "Future GVKs (not yet watched)"
        Notebook["Notebook<br/>kubeflow.org/v1"]
        ImageStream["ImageStream<br/>image.openshift.io/v1"]
        HardwareProfile["HardwareProfile<br/>infrastructure.platform.opendatahub.io/v1"]
    end

    Controller -.->|planned| Notebook
    Controller -.->|planned| ImageStream
    Controller -.->|planned| HardwareProfile

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style HealthProbe fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style WorkbenchesCR fill:#f5a623,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style WBNamespace fill:#50c8e8,stroke:#333,color:#fff
    style WBDeployments fill:#50c8e8,stroke:#333,color:#fff
    style Notebook fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style ImageStream fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style HardwareProfile fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
