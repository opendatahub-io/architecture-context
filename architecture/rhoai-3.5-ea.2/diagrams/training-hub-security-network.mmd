graph TB
    subgraph TrainingPod["TRAINING JOB POD (RHOAI-managed container)"]
        direction TB

        subgraph SDK["Training Hub SDK (Python Library)"]
            direction LR
            SFT["SFT / OSFT<br/>Algorithms"]
            LoRA["LoRA SFT / GRPO<br/>Algorithms"]
            GEPA["GEPA<br/>Algorithm"]
            Profiling["Memory & Timing<br/>Estimators"]
        end
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Trusted)"]
        direction TB

        TorchDist["PyTorch Distributed<br/>Rendezvous<br/>TCP (master_port)<br/>No TLS, No Auth"]
        NCCL["NCCL Communication<br/>GPU-to-GPU<br/>No TLS, No Auth"]
        vLLMInt["vLLM Server<br/>(co-deployed)<br/>HTTP (configurable)<br/>API Key (optional)"]
        LocalFS["Local Filesystem / PVC<br/>Checkpoints, LoRA adapters,<br/>metrics JSONL, prompts"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Untrusted Network)"]
        direction TB

        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token (optional)"]
        WandB["Weights & Biases<br/>api.wandb.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        MLflow["MLflow Server<br/>(self-hosted/managed)<br/>HTTP/HTTPS (configurable)<br/>Token (optional)"]
        LLMExt["LLM Endpoint<br/>(via litellm)<br/>HTTPS (configurable)<br/>API Key<br/>litellm !=1.82.7,!=1.82.8"]
    end

    %% Egress flows from SDK to cluster-internal
    SFT -->|"torchrun subprocess<br/>TCP, No encryption"| TorchDist
    LoRA -->|"FSDP multi-GPU<br/>NCCL/TCP, No encryption"| NCCL
    LoRA -->|"Inference rollouts<br/>HTTP, API Key (opt)"| vLLMInt
    SFT -->|"Checkpoints & metrics"| LocalFS
    LoRA -->|"LoRA adapters"| LocalFS
    GEPA -->|"Optimized prompts"| LocalFS

    %% Egress flows from SDK to external
    SFT -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (opt)"| HF
    LoRA -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (opt)"| HF
    SFT -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WandB
    LoRA -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WandB
    GEPA -.->|"HTTP/S<br/>Token (opt)"| MLflow
    GEPA -->|"HTTPS<br/>API Key"| LLMExt

    %% Styling
    classDef pod fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    classDef sdk fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef clusterint fill:#fff3cd,stroke:#d6a800,stroke-width:2px
    classDef external fill:#f8d7da,stroke:#dc3545,stroke-width:2px

    class SFT,LoRA,GEPA,Profiling sdk
    class TorchDist,NCCL,vLLMInt,LocalFS clusterint
    class HF,WandB,MLflow,LLMExt external
