graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["llm-d-inference-gateway<br/>Gateway API v1<br/>80/TCP HTTP<br/>TLS: Configurable<br/>Auth: Configurable"]
    end

    subgraph Router["ROUTER (Intelligent Routing)"]
        Envoy["Envoy Proxy<br/>8081/TCP HTTP/HTTP2<br/>19000/TCP admin (localhost)<br/>Deployed via Helm"]
        EPP["Endpoint Picker (EPP)<br/>9002/TCP gRPC ext_proc<br/>Prefix-cache-aware routing<br/>Auth: None (co-located)"]
    end

    subgraph DataPlane["DATA PLANE (Model Servers)"]
        direction TB

        subgraph NS_Decode["Decode Pool (InferencePool)"]
            DecodePod["Decode Pods<br/>SA: automountSAToken=false<br/>8000/TCP HTTP<br/>Endpoints: /v1/completions,<br/>/v1/chat/completions, /health"]
        end

        subgraph NS_Prefill["Prefill Pool (InferencePool)"]
            PrefillPod["Prefill Pods<br/>SA: automountSAToken=false<br/>8000/TCP HTTP + 5600/TCP nixl<br/>Sidecar: routing-sidecar"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        ModelStorage["Model Storage (S3/GCS/PVC)<br/>443/TCP HTTPS or NFS<br/>TLS 1.2+ / None<br/>Auth: IAM / None"]
        OTEL["OTEL Collector<br/>4317/TCP gRPC OTLP<br/>Encryption: None (configurable)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
    end

    %% Traffic flows with security annotations
    Client -->|"HTTP/80<br/>No encryption (default)<br/>Auth: None (default)"| Gateway
    Gateway -->|"HTTP-HTTP2/8081<br/>No encryption (default)<br/>Auth: None"| Envoy
    Envoy -->|"gRPC/9002<br/>No encryption (localhost)<br/>Auth: None (co-located)"| EPP
    EPP -->|"HTTPS/6443<br/>TLS 1.2+<br/>Auth: SA Token"| K8sAPI
    EPP -->|"HTTP/8000<br/>No encryption<br/>Health probes"| DecodePod
    Envoy -->|"HTTP/8000<br/>No encryption<br/>x-gateway-destination-endpoint"| DecodePod
    Envoy -->|"HTTP/8000<br/>No encryption"| PrefillPod
    PrefillPod -->|"RDMA-TCP/5600<br/>No encryption<br/>nixl KV transfer"| DecodePod
    DecodePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    PrefillPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    DecodePod -->|"HTTPS or NFS<br/>TLS 1.2+ or None"| ModelStorage
    DecodePod -->|"gRPC OTLP/4317<br/>No encryption"| OTEL
    PrefillPod -->|"gRPC OTLP/4317<br/>No encryption"| OTEL

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef router fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Envoy,EPP router
    class DecodePod,PrefillPod dataplane
    class HFHub,ModelStorage,OTEL,K8sAPI externalservice
