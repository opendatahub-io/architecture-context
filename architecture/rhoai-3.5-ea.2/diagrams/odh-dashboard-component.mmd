    style KubeRBACProxy fill:#e74c3c,stroke:#c0392b,stroke-width:2px,color:#fff
    style Backend fill:#4a90e2,stroke:#357abd,stroke-width:2px,color:#fff
    style Frontend fill:#4a90e2,stroke:#357abd,stroke-width:2px,color:#fff
