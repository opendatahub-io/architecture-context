graph TB
    subgraph ExternalUsers["External Users"]
        User["Data Scientist / Admin<br/>(Browser)"]
    end

    subgraph PlatformIngress["Platform Ingress"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP HTTPS"]
    end

    subgraph DashboardPod["odh-dashboard Pod"]
        direction TB

        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SA: odh-dashboard"]

        subgraph CoreTier["Core Tier"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP"]
            Frontend["React/PatternFly 6 SPA<br/>Module Federation Host"]
            Backend -->|serves| Frontend
        end

        subgraph BFFSidecars["BFF Sidecar Containers (SA: odh-dashboard-modules)"]
            direction LR
            CoreBFF["core-bff<br/>8043/TCP"]
            GenAI["gen-ai BFF<br/>8143/TCP"]
            MaaS["maas BFF<br/>8243/TCP"]
            MLflow["mlflow BFF<br/>8343/TCP"]
            EvalHub["eval-hub BFF<br/>8543/TCP"]
            AutoML["automl BFF<br/>8643/TCP"]
            AutoRAG["autorag BFF<br/>8743/TCP"]
            AgentOps["agent-ops BFF<br/>8843/TCP"]
            ModelReg["model-registry BFF<br/>8043/TCP"]
        end

        KubeRBACProxy -->|"HTTP/8080<br/>X-Auth-Request-User"| Backend
        Backend -->|"/_mf/{name}/*<br/>HTTPS/TLS 1.2+"| GenAI
        Backend -->|"/_mf/*"| MaaS
        Backend -->|"/_mf/*"| MLflow
        Backend -->|"/_mf/*"| EvalHub
        Backend -->|"/_mf/*"| AutoML
        Backend -->|"/_mf/*"| AutoRAG
        Backend -->|"/_mf/*"| AgentOps
        Backend -->|"/_mf/*"| ModelReg
        GenAI -->|"inter-BFF<br/>HTTPS/8243"| MaaS
    end

    subgraph Operator["dashboard-operator Pod"]
        DashOp["dashboard-operator<br/>Go controller-runtime<br/>8443/TCP metrics<br/>9443/TCP webhook"]
    end

    subgraph K8sCluster["Kubernetes Cluster Services"]
        K8sAPI["K8s API Server<br/>6443/TCP HTTPS"]
        DashboardCR["Dashboard CR<br/>(components.platform.opendatahub.io)"]
        OdhConfig["OdhDashboardConfig CR"]
        NotebookCR["Notebook CR<br/>(kubeflow.org)"]
        InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io)"]
        ModelRegistryCR["ModelRegistry CR"]
    end

    subgraph UpstreamServices["Upstream Platform Services"]
        ModelRegSvc["Model Registry Service<br/>8080/TCP"]
        DSPAPI["DSP API Server<br/>HTTPS"]
        TrustyAI["TrustyAI Service<br/>443/TCP"]
        MLflowSvc["MLflow Service<br/>8443/TCP"]
        OGX["OGX API<br/>HTTPS"]
        LlamaStack["LlamaStack<br/>8321/TCP"]
        MaaSCtrl["MaaS Controller<br/>HTTPS"]
        EvalHubAPI["EvalHub REST API<br/>HTTPS"]
        PipelineSvr["Pipeline Server<br/>HTTPS"]
        S3["S3 Storage<br/>443/TCP"]
    end

    %% External flows
    User -->|"HTTPS/443"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+"| KubeRBACProxy

    %% Operator flows
    DashOp -->|"reconciles"| DashboardCR
    DashOp -->|"deploys"| DashboardPod
    DashOp -->|"watches"| K8sAPI

    %% Backend K8s flows
    Backend -->|"user_token<br/>HTTPS/6443"| K8sAPI
    K8sAPI --- OdhConfig
    K8sAPI --- NotebookCR
    K8sAPI --- InferenceServiceCR
    K8sAPI --- ModelRegistryCR

    %% BFF upstream flows
    ModelReg -->|"HTTP/8080"| ModelRegSvc
    GenAI -->|"HTTPS"| OGX
    GenAI -->|"HTTP/8321"| LlamaStack
    GenAI -->|"HTTPS/8443"| MLflowSvc
    MaaS -->|"HTTPS"| MaaSCtrl
    MLflow -->|"HTTPS"| MLflowSvc
    EvalHub -->|"HTTPS"| EvalHubAPI
    AutoML -->|"HTTPS"| PipelineSvr
    AutoML -->|"HTTPS/443"| S3
    AutoRAG -->|"HTTPS"| OGX
    AutoRAG -->|"HTTPS"| PipelineSvr
    AutoRAG -->|"HTTPS/443"| S3
    Backend -->|"HTTPS"| DSPAPI
    Backend -->|"HTTPS/443"| TrustyAI

