graph LR
    OGX["OGX Kubernetes Operator<br/>(ogx-k8s-operator)"]

    %% External Dependencies (Required)
    OGX -->|"operator framework<br/>v0.22.4"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    OGX -->|"manifest rendering"| Kustomize["kustomize/api<br/>v0.21.0"]
    OGX -->|"image label fetch<br/>v0.20.7"| GoContainerReg["go-containerregistry<br/>v0.20.7"]
    OGX -->|"webhook TLS certs<br/>(one of)"| CertProvider{"cert-manager<br/>OR<br/>service-serving-cert-signer"}

    %% External Dependencies (Optional)
    OGX -.->|"metrics scraping<br/>(optional)"| PromOperator["prometheus-operator CRDs<br/>(ServiceMonitor, PrometheusRule)"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| OGX
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -.->|"CA merge<br/>(auto-detected)"| OGX
    OGX -->|"base config from<br/>image labels"| DistImages["OGX Distribution Images<br/>(OCI labels)"]

    %% Integration Points (consumers of OGX)
    OGX -->|"CRUD resources<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    OGX -->|"status polling<br/>HTTP/8321"| OGXPods["OGX Server Pods"]
    OGX -->|"image labels<br/>HTTPS/443"| OCIReg["OCI Container Registries"]

    %% Managed Workload Dependencies (OGX Server, not operator)
    subgraph OGXServerEgress["OGX Server Pod Dependencies (not operator)"]
        direction TB
        vLLM["vLLM Endpoints"]
        OpenAI["OpenAI API"]
        AzureOAI["Azure OpenAI"]
        Bedrock["AWS Bedrock"]
        Vertex["Google Vertex AI"]
        WatsonX["IBM watsonx.ai"]
        PG["PostgreSQL / pgvector"]
        MilvusDB["Milvus"]
        QdrantDB["Qdrant"]
        RedisDB["Redis"]
        S3["S3-compatible Storage"]
    end

    OGXPods -.->|"inference"| vLLM
    OGXPods -.->|"inference"| OpenAI
    OGXPods -.->|"inference"| AzureOAI
    OGXPods -.->|"inference"| Bedrock
    OGXPods -.->|"inference"| Vertex
    OGXPods -.->|"inference"| WatsonX
    OGXPods -.->|"vector I/O"| PG
    OGXPods -.->|"vector I/O"| MilvusDB
    OGXPods -.->|"vector I/O"| QdrantDB
    OGXPods -.->|"KV storage"| RedisDB
    OGXPods -.->|"file storage"| S3

    %% Platform component integration
    OGXModule["OGX Module<br/>(scaffolded)"] -.->|"platform component<br/>CRD (future)"| OGX

    %% Legacy
    LegacyCRD["LlamaStackDistribution<br/>(legacy, read-only)"] -.->|"resource adoption<br/>migration"| OGX

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333
    style Kustomize fill:#999,stroke:#333
    style GoContainerReg fill:#999,stroke:#333
    style CertProvider fill:#999,stroke:#333
    style PromOperator fill:#999,stroke:#333,stroke-dasharray: 5 5
    style PlatformOp fill:#7ed321,stroke:#333,color:#333
    style CABundle fill:#7ed321,stroke:#333,color:#333
    style DistImages fill:#7ed321,stroke:#333,color:#333
    style K8sAPI fill:#f5a623,stroke:#333,color:#333
    style OGXPods fill:#d5e8d4,stroke:#333,color:#333
    style OCIReg fill:#f5a623,stroke:#333,color:#333
    style OGXModule fill:#b8d4f0,stroke:#333,color:#333,stroke-dasharray: 5 5
    style LegacyCRD fill:#e8e8e8,stroke:#333,color:#333,stroke-dasharray: 5 5
    style vLLM fill:#fff2cc,stroke:#d6b656
    style OpenAI fill:#fff2cc,stroke:#d6b656
    style AzureOAI fill:#fff2cc,stroke:#d6b656
    style Bedrock fill:#fff2cc,stroke:#d6b656
    style Vertex fill:#fff2cc,stroke:#d6b656
    style WatsonX fill:#fff2cc,stroke:#d6b656
    style PG fill:#ffe6cc,stroke:#d79b00
    style MilvusDB fill:#ffe6cc,stroke:#d79b00
    style QdrantDB fill:#ffe6cc,stroke:#d79b00
    style RedisDB fill:#ffe6cc,stroke:#d79b00
    style S3 fill:#ffe6cc,stroke:#d79b00
