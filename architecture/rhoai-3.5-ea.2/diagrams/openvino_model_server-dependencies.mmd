graph LR
    OVMS["OpenVINO Model Server<br/>(C++ Service)"]

    %% Core Inference Dependencies (Required)
    OVMS -->|"inference engine<br/>(in-process)"| OpenVINO["OpenVINO Runtime<br/>2026.1 (ODH fork)"]
    OVMS -->|"LLM/VLM/STT/TTS<br/>(in-process)"| GenAI["OpenVINO GenAI<br/>releases/2026/1"]
    OVMS -->|"tokenization<br/>(in-process)"| Tokenizers["OpenVINO Tokenizers<br/>releases/2026/1"]

    %% Framework Dependencies
    OVMS -->|"gRPC server"| gRPCpp["gRPC C++<br/>(Bazel-managed)"]
    OVMS -->|"HTTP server"| Drogon["Drogon<br/>(Bazel-managed)"]
    OVMS -->|"serialization"| Protobuf["Protocol Buffers<br/>(Bazel-managed)"]
    OVMS -->|"pipeline graphs"| MediaPipe["MediaPipe<br/>(Bazel-managed)"]

    %% Build Dependencies
    OVMS -->|"build system"| Bazel["Bazel 6.1.1"]
    OVMS -->|"image processing"| OpenCV["OpenCV<br/>(bundled)"]

    %% Cloud Storage Dependencies
    OVMS -->|"S3 model loading<br/>443/TCP HTTPS"| S3["S3 / MinIO / Ceph"]
    OVMS -->|"Azure model loading<br/>443/TCP HTTPS"| Azure["Azure Blob Storage"]
    OVMS -->|"GCS model loading<br/>443/TCP HTTPS"| GCS["Google Cloud Storage"]
    OVMS -->|"model download<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]

    %% Cloud SDK Dependencies
    OVMS -->|"Azure SDK"| AzureSDK["Azure Storage C++ SDK<br/>7.5.0"]
    AzureSDK -->|"HTTP transport"| cpprestsdk["cpprestsdk 2.10.16"]
    AzureSDK -->|"C++ utilities"| Boost["Boost 1.68.0"]

    %% Platform Dependencies (Internal RHOAI)
    KServe["KServe / ModelMesh"] -->|"container runtime"| OVMS
    Prometheus["Prometheus"] -->|"scrapes /metrics"| OVMS
    Gateway["Platform Gateway<br/>(Envoy)"] -->|"routes traffic"| OVMS

    %% Utility Dependencies
    OVMS -->|"metrics"| PromClient["Prometheus C++ Client<br/>(Bazel-managed)"]
    OVMS -->|"logging"| spdlog["spdlog<br/>(Bazel-managed)"]
    OVMS -->|"XML config"| pugixml["pugixml 1.13"]

    %% Optional
    OVMS -.->|"GPU inference<br/>(optional)"| GPUDriver["Intel GPU Drivers<br/>24.52 / 25.05"]
    OVMS -.->|"template processing<br/>(optional)"| Python["Python 3.12<br/>Jinja2"]

