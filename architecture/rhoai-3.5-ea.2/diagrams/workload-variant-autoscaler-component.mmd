graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB

        subgraph Controllers["Reconcilers"]
            VAReconciler["VariantAutoscaling<br/>Reconciler<br/><i>(deprecated CRD)</i>"]
            HPAReconciler["HPA Reconciler<br/><i>llm-d.ai/managed=true</i>"]
            SOReconciler["ScaledObject Reconciler<br/><i>llm-d.ai/managed=true</i>"]
            IPReconciler["InferencePool Reconciler"]
            CMReconciler["ConfigMap Reconciler"]
        end

        subgraph Engines["Analyzer Engines"]
            SatV2["Saturation V2 Engine<br/><i>Token-based capacity model</i>"]
            QueueModel["Queueing Model Engine<br/><i>SLO-driven, Kalman filter</i>"]
            ThroughputEng["Throughput Analyzer<br/><i>ITL linear model</i>"]
            SFZero["Scale-from-Zero Engine<br/><i>EPP queue detection</i>"]
        end

        subgraph Pipeline["Optimization Pipeline"]
            CostOpt["CostAware Optimizer<br/><i>Unlimited GPU mode</i>"]
            GreedyOpt["GreedyByScore Optimizer<br/><i>GPU-limited mode</i>"]
            STZEnforcer["Scale-to-Zero Enforcer"]
            GPULimiter["GPU Limiter"]
        end

        subgraph Coordinator["Coordinator (Experimental)"]
            CoordLoop["Leader-Elected Loop<br/><i>15s interval</i>"]
            GPURebalance["GPU Rebalance Plugin"]
            CoordLoop -->|dispatches| GPURebalance
        end

        Collector["Metrics Collector<br/><i>Prometheus + Pod Scraping</i>"]
        Datastore["In-Memory Datastore<br/><i>Namespace → Managed Scalers</i>"]
        DecisionCache["Decision Cache"]
        MetricsEmitter["Metrics Emitter<br/><i>wva_desired_replicas</i>"]

        %% Internal flows
        HPAReconciler -->|tracks namespaces| Datastore
        SOReconciler -->|tracks namespaces| Datastore
        IPReconciler -->|caches pools| Datastore
        CMReconciler -->|updates config| ConfigObj["Config Object"]

        Collector -->|feeds metrics| SatV2
        Collector -->|feeds metrics| QueueModel
        Collector -->|feeds metrics| ThroughputEng
        Collector -->|feeds metrics| SFZero

        SatV2 -->|AnalyzerResult| Pipeline
        QueueModel -->|AnalyzerResult| Pipeline
        ThroughputEng -->|AnalyzerResult| Pipeline

        CostOpt -->|optimal replicas| STZEnforcer
        GreedyOpt -->|optimal replicas| STZEnforcer
        STZEnforcer -->|enforced replicas| GPULimiter
        GPULimiter -->|final replicas| DecisionCache
        SFZero -->|scale-up signal| DecisionCache
        DecisionCache -->|publishes| MetricsEmitter
    end

    %% External entities
    VACR["VariantAutoscaling CR<br/><i>(deprecated)</i>"]
    ManagedHPA["HPA<br/><i>llm-d.ai/managed=true</i>"]
    ManagedSO["KEDA ScaledObject<br/><i>llm-d.ai/managed=true</i>"]
    InfPoolCR["InferencePool CR"]
    ConfigMaps["ConfigMaps<br/><i>Global + Namespace</i>"]

    VACR -->|watched by| VAReconciler
    ManagedHPA -->|watched by| HPAReconciler
    ManagedSO -->|watched by| SOReconciler
    InfPoolCR -->|watched by| IPReconciler
    ConfigMaps -->|watched by| CMReconciler

    Prometheus["Prometheus / Thanos<br/>9091/TCP HTTPS"]
    vLLM["vLLM Servers<br/><i>KV cache, queue, latency</i>"]
    EPP["EPP<br/><i>Flow control queue</i>"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    GPUOp["GPU Operator<br/><i>NVIDIA/AMD/Intel</i>"]

    Prometheus -->|PromQL results| Collector
    Collector -->|PromQL queries| Prometheus
    vLLM -.->|metrics via Prometheus| Prometheus
    EPP -.->|metrics via Prometheus<br/>+ direct scraping| Collector

    MetricsEmitter -->|/metrics 8443/TCP HTTPS| Prometheus
    ManagedHPA -->|reads wva_desired_replicas| Prometheus
    ManagedHPA -->|scale subresource| K8sAPI
    GPUOp -.->|node GPU labels| K8sAPI

    %% Styling
    style WVA fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style Engines fill:#dcfce7,stroke:#22c55e,stroke-width:1px
    style Pipeline fill:#fef3c7,stroke:#f59e0b,stroke-width:1px
    style Coordinator fill:#fce7f3,stroke:#ec4899,stroke-width:1px

    style VAReconciler fill:#93c5fd
    style HPAReconciler fill:#93c5fd
    style SOReconciler fill:#93c5fd
    style IPReconciler fill:#93c5fd
    style CMReconciler fill:#93c5fd

    style SatV2 fill:#86efac
    style QueueModel fill:#86efac
    style ThroughputEng fill:#86efac
    style SFZero fill:#86efac

    style CostOpt fill:#fde68a
    style GreedyOpt fill:#fde68a
    style STZEnforcer fill:#fde68a
    style GPULimiter fill:#fde68a

    style Prometheus fill:#e8e8e8,stroke:#666
    style vLLM fill:#e8e8e8,stroke:#666
    style EPP fill:#e8e8e8,stroke:#666
    style K8sAPI fill:#e8e8e8,stroke:#666
    style GPUOp fill:#e8e8e8,stroke:#666

    style VACR fill:#f5a623,stroke:#333
    style ManagedHPA fill:#f5a623,stroke:#333
    style ManagedSO fill:#f5a623,stroke:#333
