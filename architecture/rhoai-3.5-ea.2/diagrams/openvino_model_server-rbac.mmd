graph TD
    subgraph OVMSAuth["OVMS Authentication Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            Note1["No ClusterRoles or RoleBindings<br/>OVMS does not interact with K8s API<br/>RBAC managed by KServe/ModelMesh"]
        end

        subgraph PlatformAuth["Platform-Level Auth (Ingress)"]
            Gateway["Platform Gateway (Envoy)<br/>TLS 1.3 Termination"]
            KRBAC["kube-rbac-proxy<br/>Validates Service Account Token"]
            Gateway -->|"8443/TCP HTTPS"| KRBAC
        end

        subgraph AppAuth["Application-Level Auth"]
            direction TB
            APIKey["API Key Authentication<br/>(--api_key flag)"]

            subgraph Protected["Protected Endpoints (when API key set)"]
                REST_TFS["/v1/models/{name}:predict<br/>/v1/models/{name}:classify<br/>/v1/models/{name}:regress"]
                REST_KServe["/v2/models/{name}/infer"]
                REST_OpenAI["/v1/chat/completions<br/>/v1/completions<br/>/v1/embeddings"]
                REST_Cohere["/v1/rerank"]
                REST_Audio["/v1/audio/transcriptions<br/>/v1/audio/speech"]
                REST_Image["/v1/images/generations<br/>/v1/images/edits"]
            end

            subgraph Open["Open Endpoints (no auth)"]
                Health["/v2/health/ready<br/>/v2/health/live"]
                Metrics["/metrics"]
            end

            subgraph gRPCAuth["gRPC (No Auth)"]
                gRPC_KServe["GRPCInferenceService<br/>InsecureServerCredentials"]
                gRPC_TFS["TFS PredictionService<br/>InsecureServerCredentials"]
            end

            APIKey -->|"Authorization: Bearer"| Protected
        end

        subgraph Secrets["Secrets Used"]
            S3Creds["S3 credentials (Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY"]
            AzureCreds["Azure storage credentials (Opaque)<br/>Storage account key"]
            GCSCreds["GCS credentials (Opaque)<br/>Service account JSON"]
            HFToken["HuggingFace token (Opaque)<br/>HF Hub auth token"]
            APIKeyCred["API key (Opaque)<br/>Client auth key"]
        end
    end

    %% Connections
    KRBAC -->|"HTTP (plaintext, localhost)"| AppAuth

    %% Styling
    style NoK8sRBAC fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Note1 fill:#f8cecc,stroke:#b85450
    style PlatformAuth fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Gateway fill:#d5e8d4,stroke:#82b366
    style KRBAC fill:#d5e8d4,stroke:#82b366
    style AppAuth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style APIKey fill:#4a90e2,color:#fff
    style Protected fill:#fff2cc,stroke:#d6b656
    style Open fill:#e1d5e7,stroke:#9673a6
    style gRPCAuth fill:#f8cecc,stroke:#b85450
    style Secrets fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style S3Creds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style GCSCreds fill:#fff2cc,stroke:#d6b656
    style HFToken fill:#fff2cc,stroke:#d6b656
    style APIKeyCred fill:#fff2cc,stroke:#d6b656
