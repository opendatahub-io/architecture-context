graph LR
    BG["Batch Gateway<br/>(API Server + Processor + GC)"]

    %% Required External Dependencies
    BG -->|"pgx/5432<br/>metadata CRUD"| PostgreSQL["PostgreSQL 12+<br/>(Required)"]
    BG -->|"RESP/6379<br/>queue, events, cache"| Redis["Redis 6+ / Valkey 8+<br/>(Required)"]
    BG -->|"HTTP(S)<br/>inference dispatch"| LLMd["llm-d Inference Endpoint<br/>(Required - Processor)"]

    %% Conditional Dependencies
    BG -->|"HTTPS/443<br/>file blob storage"| S3["S3-Compatible Storage<br/>(Conditional: file_client.type=s3)"]

    %% Optional External Dependencies
    BG -.->|"auth delegation"| Kuadrant["Kuadrant / Authorino<br/>(Recommended)"]
    BG -.->|"gRPC/4317 OTLP<br/>trace export"| OTel["OpenTelemetry Collector<br/>(Optional)"]
    BG -.->|"HTTP scrape<br/>metrics"| Prometheus["Prometheus<br/>(Optional)"]
    BG -.->|"Certificate CR<br/>TLS provisioning"| CertManager["cert-manager<br/>(Optional)"]

    %% Internal Platform Dependencies
    BG -->|"HTTP REST<br/>inference scheduling"| EPP["llm-d Inference Scheduler / EPP<br/>(Internal Platform)"]
    BG -.->|"HTTPRoute CR<br/>ingress routing"| GatewayAPI["Gateway API<br/>gateway.networking.k8s.io<br/>(Optional)"]

    %% Observability consumers
    Prometheus -.->|"dashboard JSON"| Grafana["Grafana<br/>(Dashboard Sidecar)"]

    %% Styling
    style BG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#000
    style LLMd fill:#7ed321,stroke:#333,color:#000
    style EPP fill:#7ed321,stroke:#333,color:#000
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style OTel fill:#425cc7,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
