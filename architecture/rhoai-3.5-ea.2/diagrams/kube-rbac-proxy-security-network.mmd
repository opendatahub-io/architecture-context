graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        Prometheus["prometheus-k8s<br/>(openshift-monitoring)<br/>SA Token"]
    end

    subgraph PodBoundary["POD BOUNDARY"]
        direction TB

        subgraph ProxyContainer["kube-rbac-proxy Sidecar"]
            TLS["TLS Termination<br/>0.0.0.0:8443/TCP<br/>TLS 1.2+ (configurable)<br/>HTTP/2 enabled<br/>ClientAuth: RequestClientCert"]

            subgraph AuthN["Authentication (union)"]
                TokenReview["TokenReview<br/>Delegation"]
                OIDCValidation["OIDC JWT<br/>Validation"]
                X509Validation["X.509 Client<br/>Cert Validation"]
            end

            subgraph AuthZ["Authorization (union chain)"]
                direction TB
                HardcodedMetrics["1. Hardcoded Metrics<br/>prometheus-k8s SA<br/>→ GET /metrics → Allow"]
                StaticRules["2. Static Rules<br/>(configurable)"]
                SAR["3. SubjectAccessReview<br/>resourceAttributes from config"]
            end

            ProxyHandler["Reverse Proxy Handler<br/>Injects: x-remote-user,<br/>x-remote-groups headers"]
        end

        subgraph AppContainer["Upstream Application"]
            AppPort["Application Endpoint<br/>127.0.0.1:8081/TCP<br/>HTTP (loopback only)"]
        end
    end

    subgraph K8sCluster["KUBERNETES CLUSTER"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        OIDCIssuer["OIDC Issuer<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public endpoint"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token / OIDC JWT / X.509"| TLS
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Token<br/>GET /metrics"| TLS

    %% Internal auth flows
    TLS --> AuthN
    AuthN --> AuthZ
    AuthZ --> ProxyHandler

    %% Proxy to upstream (loopback)
    ProxyHandler -->|"HTTP/8081<br/>No encryption<br/>localhost only<br/>No auth"| AppPort

    %% Egress flows
    TokenReview -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST tokenreviews"| APIServer
    SAR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST subjectaccessreviews"| APIServer
    OIDCValidation -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth<br/>GET JWKS"| OIDCIssuer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef app fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef authn fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef authz fill:#ffe6cc,stroke:#d79b00,stroke-width:1px

    class Client,Prometheus external
    class TLS,ProxyHandler proxy
    class AppPort app
    class APIServer k8s
    class OIDCIssuer extsvc
    class TokenReview,OIDCValidation,X509Validation authn
    class HardcodedMetrics,StaticRules,SAR authz
