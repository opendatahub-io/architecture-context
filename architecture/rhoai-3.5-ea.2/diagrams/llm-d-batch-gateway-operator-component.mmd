graph TB
    subgraph Operator["LLM-D Batch Gateway Operator"]
        direction TB
        Controller["LLMBatchGateway<br/>Reconciler"]
        MetricsCtrl["Metrics Controller<br/>(self-healing monitoring)"]
        HelmRenderer["Helm Renderer<br/>(in-process chart rendering)"]
        SecretSync["Secret Sync<br/>(cross-namespace)"]

        Controller -->|renders via| HelmRenderer
        Controller -->|delegates| SecretSync
    end

    User["Data Scientist / Platform User"] -->|creates| LLMBatchGatewayCR["LLMBatchGateway CR<br/>(batch.llm-d.ai/v1alpha1)"]
    LLMBatchGatewayCR -->|watched by| Controller

    subgraph ManagedWorkloads["Managed Workloads (rendered from Helm chart)"]
        direction TB
        APIServer["API Server Deployment<br/>Port: 8000/TCP<br/>/v1/batches, /v1/files"]
        Processor["Processor Deployment<br/>Port: 9090/TCP<br/>AIMD concurrency control"]
        GC["Garbage Collector Deployment<br/>Port: 9091/TCP<br/>periodic cleanup"]
    end

    Controller -->|creates via SSA| APIServer
    Controller -->|creates via SSA| Processor
    Controller -->|creates via SSA| GC
    Controller -->|creates| APIServerSvc["API Server Service<br/>ClusterIP 8000/TCP"]
    Controller -->|creates| ConfigMaps["ConfigMaps<br/>(per-component config)"]
    Controller -->|creates| ServiceAccounts["ServiceAccounts<br/>(per-component)"]
    Controller -->|creates optional| HTTPRoute["HTTPRoute<br/>(Gateway API ingress)"]
    Controller -->|creates optional| Certificate["Certificate CR<br/>(cert-manager TLS)"]
    Controller -->|creates optional| ServiceMonitor["ServiceMonitor<br/>(Prometheus scraping)"]
    Controller -->|creates optional| PodMonitor["PodMonitor<br/>(processor/GC metrics)"]
    Controller -->|creates optional| PrometheusRule["PrometheusRule<br/>(alerting rules)"]

    MetricsCtrl -->|self-heals| OperatorMonitoring["Operator Monitoring<br/>(Service, ServiceMonitor,<br/>PrometheusRule)"]

    SecretSync -->|reads source| SourceSecret["Source Secret<br/>(cross-namespace)"]
    SecretSync -->|verifies| ReferenceGrant["ReferenceGrant<br/>(Gateway API)"]
    SecretSync -->|creates managed copy| ManagedSecret["{name}-credentials<br/>(local namespace copy)"]

    PlatformOp["opendatahub-operator /<br/>rhods-operator"] -->|deploys & sets images via<br/>params.env| Operator

    APIServer -->|reads/writes| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    Processor -->|dequeues jobs| PostgreSQL
    Processor -->|forwards requests| InferenceGW["Inference Gateway<br/>(llm-d / GIE / EPP)"]
    Processor -->|reads/writes| S3["S3 Storage<br/>443/TCP"]
    GC -->|cleans expired| PostgreSQL
    APIServer -->|stores files| S3

    style Controller fill:#4a90e2,color:#fff
    style MetricsCtrl fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style SecretSync fill:#4a90e2,color:#fff
    style LLMBatchGatewayCR fill:#f5a623,color:#fff
    style APIServer fill:#7ed321,color:#fff
    style Processor fill:#7ed321,color:#fff
    style GC fill:#7ed321,color:#fff
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style InferenceGW fill:#e8e8e8,stroke:#333
    style PlatformOp fill:#9b59b6,color:#fff
    style HTTPRoute fill:#f39c12,color:#fff
    style Certificate fill:#f39c12,color:#fff
    style ServiceMonitor fill:#f39c12,color:#fff
    style PodMonitor fill:#f39c12,color:#fff
    style PrometheusRule fill:#f39c12,color:#fff
    style ReferenceGrant fill:#f39c12,color:#fff
