graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller"]
        SA_Webhook["spark-operator-webhook"]
        SA_Spark["spark-operator-spark"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (operator namespace)"]
        RB_Spark["spark-operator-rolebinding<br/>(RoleBinding)"]
    end

    subgraph CR_Controller["ClusterRole: spark-operator-controller"]
        direction TB
        subgraph CoreAPI_C["Core API ('')"]
            Pods_C["pods<br/>create, delete, get,<br/>list, update, watch"]
            ConfigMaps_C["configmaps<br/>create, get, list,<br/>patch, update, watch"]
            Services_C["services<br/>create, delete, get, list,<br/>patch, update, watch"]
            PVCs_C["persistentvolumeclaims<br/>list, watch"]
            Events_C["events<br/>create, patch, update"]
            Nodes_C["nodes<br/>get"]
            ResourceQuotas_C["resourcequotas<br/>get, list, watch"]
        end
        subgraph SparkAPI_C["sparkoperator.k8s.io"]
            SparkApps_C["sparkapplications<br/>create, delete, get, list,<br/>watch, patch, update"]
            SparkAppsFin_C["sparkapplications/finalizers<br/>update"]
            SparkAppsStat_C["sparkapplications/status<br/>update, get, patch"]
            SchedApps_C["scheduledsparkapplications<br/>get, list, watch,<br/>patch, update"]
            SchedAppsFin_C["scheduledsparkapplications/<br/>finalizers - update"]
            SchedAppsStat_C["scheduledsparkapplications/<br/>status - get, patch, update"]
            SparkConnects_C["sparkconnects<br/>get, list, watch"]
            SparkConnectsFin_C["sparkconnects/finalizers<br/>update"]
        end
        subgraph ExtAPI_C["Extensions / Networking"]
            Ingresses_C["ingresses<br/>create, delete, get,<br/>list, update, watch"]
        end
        subgraph CRDAPI_C["apiextensions.k8s.io"]
            CRDs_C["customresourcedefinitions<br/>get"]
        end
        subgraph OSAPI_C["config.openshift.io"]
            APIServers_C["apiservers<br/>get"]
        end
    end

    subgraph CR_Webhook["ClusterRole: spark-operator-webhook"]
        direction TB
        subgraph CoreAPI_W["Core API ('')"]
            Pods_W["pods<br/>get, list, watch"]
            ConfigMaps_W["configmaps<br/>get, list, watch"]
        end
        subgraph AdmissionAPI_W["admissionregistration.k8s.io"]
            MutatingWH_W["mutatingwebhookconfigurations<br/>get, update"]
            ValidatingWH_W["validatingwebhookconfigurations<br/>get, update"]
        end
    end

    subgraph Role_Spark["Role: spark-operator-role<br/>(operator namespace)"]
        SparkNSPerms["namespace-scoped permissions<br/>for spark-submit driver creation"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    CRB_Controller -->|"grants"| CR_Controller

    SA_Webhook -->|"bound via"| CRB_Webhook
    CRB_Webhook -->|"grants"| CR_Webhook

    SA_Spark -->|"bound via"| RB_Spark
    RB_Spark -->|"grants"| Role_Spark

