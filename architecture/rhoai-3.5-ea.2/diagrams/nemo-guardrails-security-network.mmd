graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (No built-in auth)"]
        direction TB

        subgraph NS_Guardrails["Service: nemo-guardrails (ClusterIP)"]
            Server["NeMo Guardrails Server<br/>8000/TCP HTTP (plaintext)<br/>No built-in TLS or auth<br/>UBI 9 Python 3.12<br/>FIPS: MD5→SHA256 fallback"]
        end

        subgraph OptionalInternal["Optional Internal Services"]
            Redis["Redis<br/>6379/TCP<br/>Redis Protocol<br/>Auth: configurable"]
            OTel["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS optional"]
        end

        UpstreamLLM["Upstream LLM<br/>(vLLM / TGI / NIM)<br/>443/TCP or custom<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Outbound)"]
        direction TB
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer: OPENAI_API_KEY"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer: AZURE_OPENAI_API_KEY"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer: ANTHROPIC_API_KEY"]
        Cohere["Cohere API<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer: COHERE_API_KEY"]
        NIM["NVIDIA NIM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        CiscoAI["Cisco AI Defense<br/>443/TCP HTTPS TLS 1.2+<br/>Header: X-Cisco-AI-Defense-API-Key"]
        AlignScore["AlignScore API<br/>custom port<br/>HTTP/HTTPS configurable"]
        JailbreakSvc["Jailbreak Detection Server<br/>custom port<br/>HTTP configurable"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>Optional: HF_TOKEN"]
    end

    %% Inbound flow
    Client -->|"HTTP/8000<br/>Plaintext<br/>Forwarded headers<br/>⚠ No built-in auth"| Server

    %% Primary egress
    Server -->|"HTTPS/443+<br/>TLS 1.2+<br/>Bearer Token"| UpstreamLLM

    %% Optional internal
    Server -.->|"Redis/6379<br/>configurable auth"| Redis
    Server -.->|"OTLP/4317-4318<br/>TLS optional"| OTel

    %% External service egress
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| OpenAI
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| AzureOAI
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Anthropic
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Cohere
    Server -.->|"HTTPS/443+<br/>TLS 1.2+<br/>Bearer Token"| NIM
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key Header"| CiscoAI
    Server -.->|"HTTP/HTTPS<br/>configurable"| AlignScore
    Server -.->|"HTTP<br/>configurable"| JailbreakSvc
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>Optional HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef upstream fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Server server
    class UpstreamLLM upstream
    class Redis,OTel optional
    class OpenAI,AzureOAI,Anthropic,Cohere,NIM,CiscoAI,AlignScore,JailbreakSvc,HFHub externalservice
