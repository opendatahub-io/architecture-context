graph LR
    MLflow["MLflow<br/>Tracking Server"]

    %% External Dependencies (required)
    MLflow -->|"runtime interpreter"| Python["Python 3.12"]
    MLflow -->|"TLS & crypto<br/>(cryptography lib)"| OpenSSL["OpenSSL<br/>(UBI9-provided)"]

    %% External Dependencies (optional/recommended)
    MLflow -->|"backend store<br/>5432/TCP"| PostgreSQL["PostgreSQL 13+<br/>(recommended)"]
    MLflow -.->|"backend store<br/>(default, not prod)"| SQLite["SQLite 3.34+"]
    MLflow -->|"artifact storage<br/>9000/TCP, 443/TCP HTTPS"| S3["S3/MinIO"]

    %% Build-time only
    Node["Node.js 24<br/>(build-time only)"] -.->|"UI build<br/>(Yarn Berry)"| MLflow

    %% Internal RHOAI Platform Dependencies
    MLflow -->|"deployment mgmt"| RhodsOperator["rhods-operator"]
    MLflow -->|"ingress routing<br/>443/TCP HTTPS"| PlatformGateway["Platform Gateway<br/>(HTTPRoute)"]
    MLflow -->|"auth sidecar<br/>8443 → 5000"| KubeRBACProxy["kube-rbac-proxy"]
    MLflow -->|"workspace store<br/>& K8s auth"| K8sPlugins["mlflow-kubernetes-<br/>plugins"]
    K8sPlugins -->|"6443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumers of MLflow)
    EvalHub["EvalHub Dashboard"] -->|"module federation<br/>(compare runs, traces)"| MLflow
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>5000/TCP HTTP"| MLflow

    %% AI Gateway egress
    MLflow -->|"AI Gateway proxy<br/>443/TCP HTTPS"| LLMProviders["LLM Providers<br/>(OpenAI, Anthropic,<br/>Bedrock)"]

    %% OTEL integration
    OTELAgent["OTEL Agent"] -->|"POST /v1/traces<br/>5000/TCP HTTP"| MLflow

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style Python fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style SQLite fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style Node fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI dependencies
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style PlatformGateway fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style K8sPlugins fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333

    %% Integration consumers
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
