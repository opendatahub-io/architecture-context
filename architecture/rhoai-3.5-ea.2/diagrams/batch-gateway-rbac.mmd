graph TD
    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph ExternalAuth["External Auth (Gateway-Delegated)"]
            Client["External Client"]
            GW["API Gateway<br/>(Kuadrant / Authorino)"]
            Client -->|"API Key / SA Token<br/>OpenShift User Token"| GW
            GW -->|"Validates credentials<br/>Extracts tenant ID"| AuthDecision{"Auth Decision"}
            AuthDecision -->|"Allow"| Forward["Forward to API Server<br/>X-MaaS-Username: {tenant}"]
            AuthDecision -->|"Deny"| Reject["401/403 Rejection"]
        end

        subgraph TenantIsolation["Multi-Tenant Data Isolation"]
            direction TB
            TenantHeader["Tenant ID<br/>(X-MaaS-Username header)"]
            DBScope["PostgreSQL Queries<br/>WHERE tenant_id = {tenant}"]
            S3Scope["S3 Storage Paths<br/>SHA256(tenant_id)/..."]
            TenantHeader --> DBScope
            TenantHeader --> S3Scope
        end

        subgraph ServiceAccounts["Kubernetes Service Accounts"]
            direction TB
            SA_API["SA: batch-gateway-apiserver<br/>No K8s RBAC required"]
            SA_Proc["SA: batch-gateway-processor<br/>No K8s RBAC required"]
            SA_GC["SA: batch-gateway-gc<br/>No K8s RBAC required"]
        end

        subgraph InferenceAuth["Inference Endpoint Auth"]
            ProcClient["Processor HTTP Client"]
            BearerToken["Bearer Token<br/>(from secret or file)"]
            ProcClient -->|"Authorization header<br/>per-model API key"| BearerToken
            BearerToken -->|"POST inference request"| LLMd["llm-d Endpoint"]
        end

        subgraph Secrets["Secret Management"]
            direction TB
            MainSecret["batch-gateway-secrets (Opaque)<br/>Mount: /etc/.secrets/ (read-only)<br/>Access: os.OpenInRoot() (path traversal prevention)"]
            RedisURL["redis-url"]
            PGURL["postgresql-url"]
            InfKey["inference-api-key"]
            S3Key["s3-secret-access-key"]
            MainSecret --- RedisURL
            MainSecret --- PGURL
            MainSecret --- InfKey
            MainSecret --- S3Key

            TLSSecret["apiserver-tls (kubernetes.io/tls)<br/>Optional: cert-manager provisioned<br/>Auto-Rotate: Yes (if cert-manager)"]
        end

        subgraph Unauthenticated["Unauthenticated Endpoints (Internal-Only)"]
            Health["/health — Always 200 OK"]
            Ready["/ready — 200/503"]
            Metrics["/metrics — Prometheus"]
        end
    end

    Forward --> TenantHeader

    %% Styling
    style ExternalAuth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style TenantIsolation fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ServiceAccounts fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style InferenceAuth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Unauthenticated fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style AuthDecision fill:#fff,stroke:#333
    style Reject fill:#f44,stroke:#333,color:#fff
    style Forward fill:#4a4,stroke:#333,color:#fff
