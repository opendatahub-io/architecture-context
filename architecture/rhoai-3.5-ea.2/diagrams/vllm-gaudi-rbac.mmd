graph TD
    subgraph VLLMGaudi["vllm-gaudi Component"]
        Note["This component does NOT define<br/>any RBAC resources.<br/><br/>RBAC is fully managed by<br/>KServe and the platform operator."]
    end

    subgraph PodSecurity["Pod Security Context"]
        UID["UID: 2000<br/>(non-root)"]
        Container["odh-vllm-gaudi-rhel9<br/>Container"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (by KServe)"]
        KServeSA["ServiceAccount<br/>(KServe-managed)"]
        KServeRB["RoleBinding<br/>(KServe-managed)"]
        KServeRole["Role<br/>(KServe-managed)"]
    end

    subgraph AuthEnforcement["Authentication & Authorization"]
        subgraph Authenticated["Authenticated Endpoints"]
            V1Endpoints["/v1/* endpoints<br/>GET, POST"]
            BearerToken["Auth: Bearer Token<br/>Enforcement: kube-rbac-proxy<br/>Mechanism: SubjectAccessReview<br/>Policy: Platform RBAC"]
        end
        subgraph Unauthenticated["Unauthenticated Endpoints"]
            HealthEndpoint["/health<br/>GET<br/>Direct access for probes"]
        end
    end

    subgraph Secrets["Secrets"]
        ModelCreds["Model Credentials<br/>Type: Opaque<br/>Purpose: S3/storage credentials<br/>Provisioned by: User / KServe<br/>Auto-Rotate: No"]
    end

    KServeSA -->|bound via| KServeRB
    KServeRB -->|grants| KServeRole
    KServeSA -->|runs| Container
    Container -->|as| UID
    V1Endpoints -->|enforced by| BearerToken
    ModelCreds -->|mounted into| Container

    %% Styling
    style Note fill:#f0f0f0,stroke:#999,stroke-width:2px,stroke-dasharray: 5 5
    style UID fill:#4a90e2,stroke:#333,color:#fff
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeRB fill:#7ed321,stroke:#333,color:#fff
    style KServeRole fill:#7ed321,stroke:#333,color:#fff
    style V1Endpoints fill:#ffe6cc,stroke:#d79b00
    style BearerToken fill:#ffe6cc,stroke:#d79b00
    style HealthEndpoint fill:#d5e8d4,stroke:#82b366
    style ModelCreds fill:#f5a623,stroke:#333,color:#fff
