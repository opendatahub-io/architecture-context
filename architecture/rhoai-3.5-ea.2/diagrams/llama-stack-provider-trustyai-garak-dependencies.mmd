    Garak -->|"artifact transfer<br/>S3 API"| S3["S3-compatible Storage"]
    Garak -.->|"metrics/reports<br/>REST API (optional)"| MLflow["MLflow"]
    Garak -->|"artifact persistence<br/>OCI API"| OCI["OCI Registry"]
    Garak -->|"ConfigMap read<br/>garak-provider-image"| TrustyAIOp["trustyai-service-operator"]
    Garak -->|"ConfigMap read<br/>garak-provider-image (PR #2567)"| ODHOp["opendatahub-operator"]

    %% Integration Points (consumed by)
    Garak -->|"probe prompts<br/>/v1/chat/completions"| TargetLLM["Target LLM Endpoints"]
    Garak -->|"adversarial prompts<br/>/v1/chat/completions"| SDGEndpoint["SDG Model Endpoint"]
    Garak -->|"judge scoring<br/>/v1/chat/completions"| JudgeEndpoint["Judge Model Endpoint"]
    Garak -->|"TAP jailbreak<br/>/v1/chat/completions"| AttackerEndpoint["Attacker Model Endpoint"]
    Garak -->|"TAP evaluator<br/>/v1/chat/completions"| EvaluatorEndpoint["Evaluator Model Endpoint"]

    %% External Services
    Garak -.->|"model weights<br/>HF Token"| HFHub["HuggingFace Hub"]
    GarakFW -.->|"translation probe"| GoogleTranslate["Google Translate API"]

