graph LR
    Garak["TrustyAI Garak Adapter"]

    %% External Dependencies (Python packages)
    Garak -->|"core framework<br/>0.15.0+rhaiv.2"| GarakFW["garak<br/>(NVIDIA fork)"]
    Garak -->|"adapter interface<br/>>=0.4.0"| EvalHubSDK["eval-hub-sdk"]
    Garak -->|"pipeline SDK<br/>>=2.14.6"| KFP_SDK["kfp"]
    Garak -->|"K8s extensions<br/>>=2.14.6"| KFP_K8s["kfp-kubernetes"]
    Garak -->|"pipeline API<br/>>=2.14.6"| KFP_API["kfp-server-api"]
    Garak -->|"S3 client<br/>>=1.35.88"| Boto3["boto3"]
    Garak -->|"prompt generation<br/>>=0.9.4 (conditional)"| SDGHub["sdg-hub"]
    Garak -->|"data processing<br/>>=2.3.3"| Pandas["pandas"]
    Garak -->|"HTML reports<br/>>=3.1.6"| Jinja2["Jinja2"]

    %% Transitive Dependencies
    GarakFW -.->|"LLM abstraction<br/>1.84.0"| LiteLLM["litellm"]
