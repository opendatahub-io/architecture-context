graph LR
    Notebooks["Notebooks<br/>(Container Image<br/>Build System)"]

    %% Build System Dependencies
    Notebooks -->|"hermetic builds"| Konflux["Konflux<br/>CI/CD Pipeline"]
    Notebooks -->|"dep prefetch"| Cachi2["Cachi2 / Hermeto<br/>(build-time)"]
    Notebooks -->|"pkg manager"| UV["uv<br/>(latest)"]

    %% Base Image Dependencies (AIPCC)
    Notebooks -->|"CPU base"| AIPCCBase["AIPCC base-images/cpu<br/>quay.io/aipcc"]
    Notebooks -->|"CUDA 13.0 base"| AIPCC_CUDA13["AIPCC base-images/cuda-13.0<br/>quay.io/aipcc"]
    Notebooks -->|"CUDA 12.9 base"| AIPCC_CUDA12["AIPCC base-images/cuda-12.9<br/>quay.io/aipcc"]
    Notebooks -->|"ROCm 7.1 base"| AIPCC_ROCm["AIPCC base-images/rocm-7.1<br/>quay.io/aipcc"]

    %% Runtime Framework Dependencies
    Notebooks -->|"notebook IDE"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"VS Code IDE"| CodeServer["code-server 4.106.3"]
    Notebooks -->|"deep learning"| PyTorch["PyTorch<br/>(CUDA/ROCm)"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow<br/>(CUDA/ROCm)"]
    Notebooks -->|"model compression"| LLMCompressor["LLM Compressor"]
    Notebooks -->|"explainability"| TrustyAI["TrustyAI<br/>(+ Java 17)"]
    Notebooks -->|"pipeline bootstrap"| Elyra["Elyra KFP 4.3.1<br/>Bootstrapper"]

    %% System Dependencies
    Notebooks -->|"runtime"| Python["Python 3.12"]
    Notebooks -->|"runtime"| NodeJS["Node.js 22.21.1"]
    Notebooks -->|"reverse proxy"| Nginx["nginx"]
    Notebooks -->|"CGI"| Httpd["httpd"]
    Notebooks -->|"GPU compute"| CUDA["NVIDIA CUDA<br/>12.9 / 13.0"]
    Notebooks -->|"GPU compute"| ROCm["AMD ROCm 7.1"]

    %% Internal Platform Dependencies (consume notebooks)
    RhodsOp["rhods-operator"] -->|"reads manifests"| Notebooks
    ODHOp["opendatahub-operator"] -->|"reads manifests"| Notebooks
    NotebookCtrl["odh-notebook-<br/>controller"] -->|"deploys pods"| Notebooks
    Dashboard["RHOAI Dashboard"] -->|"reads annotations"| Notebooks
    KFP["Kubeflow Pipelines"] -->|"executes runtimes"| Notebooks

    %% External Services (runtime)
    Notebooks -.->|"data storage"| S3["S3 Object Storage"]
    Notebooks -.->|"image publish"| Quay["Quay.io Registry"]
    Notebooks -.->|"Python packages"| AIPCCPyPI["AIPCC PyPI Index<br/>packages.redhat.com"]

