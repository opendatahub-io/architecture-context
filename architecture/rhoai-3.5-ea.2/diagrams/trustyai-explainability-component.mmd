graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB
        subgraph ServiceLayer["explainability-service (Quarkus 3.8.5)"]
            direction LR
            ConsumerEP["Consumer Endpoint<br/>/consumer/kserve/v2"]
            CloudEventEP["CloudEvent Consumer<br/>(Funqy Knative)"]
            FairnessEP["Fairness Endpoints<br/>/metrics/group/fairness/spd<br/>/metrics/group/fairness/dir"]
            DriftEP["Drift Endpoints<br/>/metrics/drift/meanshift<br/>/metrics/drift/fouriermmd"]
            ExplainerEP["Explainer Endpoints<br/>/explainers/local/*<br/>(disabled in RHOAI)"]
            InfoEP["Info Endpoints<br/>/info, /info/tags, /info/names"]
            HealthEP["Health & Metrics<br/>/q/health/*, /q/metrics"]
        end

        subgraph Reconcilers["Inference Payload Reconcilers"]
            MMReconciler["ModelMesh Reconciler<br/>(Base64 protobuf matching)"]
            KSReconciler["KServe Reconciler<br/>(CloudEvent ID matching)"]
        end

        subgraph MetricsEngine["Metrics & Publishing"]
            PrometheusScheduler["PrometheusScheduler<br/>(periodic, default 5s)"]
            PrometheusPublisher["PrometheusPublisher<br/>(Micrometer gauges)"]
        end

        subgraph StorageLayer["Storage Abstraction"]
            direction LR
            PVCStorage["PVC Storage<br/>(CSV FileChannel I/O)"]
            MinIOStorage["MinIO Storage<br/>(S3 API)"]
            DBStorage["Hibernate Storage<br/>(MariaDB/MySQL)"]
            MemStorage["Memory Storage"]
        end

        subgraph CoreLib["explainability-core"]
            FairnessAlgo["Fairness: SPD, DIR"]
            DriftAlgo["Drift: Meanshift, FourierMMD"]
            ExplainAlgo["XAI: LIME, SHAP, CF,<br/>TSSaliency, PDP"]
        end

        subgraph Connectors["explainability-connectors"]
            KServeV1["KServe v1 HTTP Client"]
            KServeV2HTTP["KServe v2 HTTP Client"]
            KServeV2GRPC["KServe v2 gRPC Client<br/>(protobuf)"]
        end

        subgraph ArrowLib["explainability-arrow"]
            ArrowInterop["Apache Arrow Interop<br/>(TrustyAI-Python exchange)"]
        end
    end

    %% External actors
    ModelMesh["ModelMesh Serving"]
    KServeLogger["KServe InferenceLogger"]
    Client["Client / Dashboard"]
    Prometheus["Prometheus / OpenShift Monitoring"]
    KServeModelServer["KServe Model Servers"]

    %% Storage backends
    PVC["PVC<br/>(PersistentVolumeClaim)"]
    MinIO["MinIO<br/>(S3-compatible)"]
    MariaDB["MariaDB / MySQL<br/>(3306/TCP)"]

    %% Operator
    Operator["TrustyAI Service Operator<br/>(separate repo)"]

    %% Inbound flows
    ModelMesh -->|"POST /consumer/kserve/v2<br/>80/TCP HTTP"| ConsumerEP
    KServeLogger -->|"CloudEvent<br/>80/TCP HTTP"| CloudEventEP
    Client -->|"REST API<br/>80/TCP HTTP"| FairnessEP
    Client -->|"REST API<br/>80/TCP HTTP"| DriftEP
    Client -->|"REST API<br/>80/TCP HTTP"| InfoEP
    Prometheus -->|"Scrape /q/metrics<br/>80/TCP HTTP"| HealthEP

    %% Internal flows
    ConsumerEP --> MMReconciler
    CloudEventEP --> KSReconciler
    MMReconciler --> StorageLayer
    KSReconciler --> StorageLayer
    FairnessEP --> FairnessAlgo
    DriftEP --> DriftAlgo
    ExplainerEP --> ExplainAlgo
    ExplainAlgo --> Connectors
    PrometheusScheduler --> StorageLayer
    PrometheusScheduler --> PrometheusPublisher

    %% Storage to backends
    PVCStorage --> PVC
    MinIOStorage --> MinIO
    DBStorage --> MariaDB

    %% Outbound
    Connectors -->|"gRPC/HTTP<br/>plaintext"| KServeModelServer

    %% Operator management
    Operator -.->|"deploys & configures"| TrustyAI

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ServiceLayer fill:#dceefb,stroke:#4a90e2
    style CoreLib fill:#d5e8d4,stroke:#82b366
    style Connectors fill:#fff2cc,stroke:#d6b656
    style ArrowLib fill:#f8cecc,stroke:#b85450
    style StorageLayer fill:#e1d5e7,stroke:#9673a6
    style Reconcilers fill:#dae8fc,stroke:#6c8ebf
    style MetricsEngine fill:#dae8fc,stroke:#6c8ebf

    style ModelMesh fill:#f5f5f5,stroke:#999
    style KServeLogger fill:#f5f5f5,stroke:#999
    style Client fill:#f5f5f5,stroke:#999
    style Prometheus fill:#f5f5f5,stroke:#999
    style KServeModelServer fill:#f5f5f5,stroke:#999
    style PVC fill:#fff2cc,stroke:#d6b656
    style MinIO fill:#fff2cc,stroke:#d6b656
    style MariaDB fill:#fff2cc,stroke:#d6b656
    style Operator fill:#d5e8d4,stroke:#82b366
