graph TB
    subgraph LLMDKVCache["llm-d-kv-cache System"]
        direction TB

        subgraph GoLib["Go Library (consumed by llm-d gateway)"]
            Indexer["KV Cache Indexer<br/>Tracks block→pod mappings<br/>Scoring API"]
            EventsPipeline["KV Events Pipeline<br/>ZMQ PUB/SUB processing"]
            TokenPool["Tokenizer Pool<br/>UDS client connections"]

            subgraph Backends["Index Backends"]
                InMemory["In-Memory LRU<br/>100M key capacity"]
                Ristretto["Ristretto (Cost-Aware)<br/>Byte-level eviction"]
                RedisBackend["Redis/Valkey Client<br/>Pipelined + Lua scripts"]
            end

            EventsPipeline -->|updates| Indexer
            Indexer -->|queries| Backends
            TokenPool -->|tokenize prompts| Indexer
        end

        subgraph TokenizerSidecar["UDS Tokenizer Sidecar"]
            TokenizerService["TokenizationService<br/>Python gRPC<br/>UDS: /tmp/tokenizer/tokenizer-uds.socket"]
            HealthProbe["Health Probe<br/>:8082/TCP /healthz"]
        end

        subgraph FSBackend["llmd_fs_backend (vLLM Plugin)"]
            Manager["FS Manager<br/>Python orchestrator"]
            Worker["FS Worker<br/>Lookup/Prepare/Store"]
            StorageOffload["storage_offload<br/>C++17/CUDA Extension<br/>cudaMemcpy / GDS"]
            EventPub["Event Publisher<br/>ZMQ PUB :5559/TCP"]

            Manager --> Worker
            Worker --> StorageOffload
            Worker --> EventPub
        end

        subgraph PVCEvictor["PVC Evictor Daemon"]
            Activator["Activator Process<br/>statvfs monitoring"]
            Crawlers["N Crawler Processes<br/>Parallel file discovery"]
            Deleter["Deleter Process<br/>Batch rm via xargs"]
            FolderCleaner["Folder Cleaner<br/>(optional)"]

            Activator -->|threshold exceeded| Crawlers
            Crawlers -->|eligible files| Deleter
            Deleter -.->|empty dirs| FolderCleaner
        end
    end

    %% External connections
    TokenPool -->|gRPC over UDS| TokenizerService
    TokenizerService -->|download models| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]

    Gateway["llm-d-inference-scheduler<br/>(Gateway)"] -->|Go import| Indexer
    Gateway -->|ScoreRequest| Indexer

    vLLMPods["vLLM Inference Pods"] -->|ZMQ PUB :5557| EventsPipeline
    vLLMPods -->|plugin interface| Manager

    RedisBackend -->|6379/TCP| Redis["Redis / Valkey"]

    StorageOffload -->|POSIX I/O| SharedPVC["Shared PVC<br/>ReadWriteMany"]
    StorageOffload -->|NIXL / HTTP :9000| S3["S3 / MinIO"]

    Activator -->|monitors| SharedPVC
    Crawlers -->|scans| SharedPVC
    Deleter -->|deletes from| SharedPVC

    Indexer -->|gRPC :4317| OTLP["OTLP Collector"]
    Indexer -->|:8080 /metrics| Prometheus["Prometheus"]

    EventsPipeline -->|REST :443| K8sAPI["Kubernetes API<br/>Pod discovery"]

