graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            MaaSModelRefReconciler["MaaSModelRef<br/>Reconciler"]
            MaaSAuthPolicyReconciler["MaaSAuthPolicy<br/>Reconciler"]
            MaaSSubscriptionReconciler["MaaSSubscription<br/>Reconciler"]
            AITenantReconciler["AITenant<br/>Reconciler"]
            TenantReconciler["Tenant<br/>Reconciler"]
            LifecycleReconciler["Lifecycle<br/>Reconciler"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
            Webhook["Webhook Server<br/>9443/TCP"]
        end

        subgraph API["maas-api (Gin REST Service)"]
            ModelsEndpoint["/v1/models"]
            APIKeysEndpoint["/v1/api-keys"]
            SubscriptionsEndpoint["/v1/subscriptions"]
            InternalValidate["/internal/v1/api-keys/validate"]
            InternalSelect["/internal/v1/subscriptions/select"]
        end

        subgraph PayloadProc["payload-processing (Envoy ext_proc)"]
            PreAuth["Pre-Auth Processor<br/>Model Header Extraction"]
            PostAuth["Post-Auth Processor<br/>API Translation +<br/>Credential Injection"]
        end
    end

    %% CRDs
    MaaSModelRefCR["MaaSModelRef CR"]
    MaaSAuthPolicyCR["MaaSAuthPolicy CR"]
    MaaSSubscriptionCR["MaaSSubscription CR"]
    AITenantCR["AITenant CR"]
    TenantCR["Tenant CR"]
    ExternalModelCR["ExternalModel CR<br/>(maas.opendatahub.io)"]

    %% Generated Resources
    HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthPolicy["AuthPolicy<br/>(Kuadrant)"]
    TokenRateLimitPolicy["TokenRateLimitPolicy<br/>(Kuadrant)"]
    InferenceExternalModel["ExternalModel CR<br/>(inference.opendatahub.io)"]
    ExternalProvider["ExternalProvider CR"]

    %% External Dependencies
    Gateway["maas-default-gateway<br/>443/TCP HTTPS"]
    Authorino["Authorino<br/>(AuthN/AuthZ)"]
    Limitador["Limitador<br/>(Rate Limiting)"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    KServe["KServe<br/>LLMInferenceService"]
    K8sAPI["Kubernetes API<br/>443/TCP"]

    %% User
    Client["Client / Data Scientist"]

    %% CR → Reconciler flows
    MaaSModelRefCR -->|watched by| MaaSModelRefReconciler
    MaaSAuthPolicyCR -->|watched by| MaaSAuthPolicyReconciler
    MaaSSubscriptionCR -->|watched by| MaaSSubscriptionReconciler
    AITenantCR -->|watched by| AITenantReconciler
    TenantCR -->|watched by| TenantReconciler
    ExternalModelCR -->|watched by| ExternalModelReconciler

    %% Reconciler → Generated Resources
    MaaSModelRefReconciler -->|creates| HTTPRoute
    MaaSAuthPolicyReconciler -->|creates| AuthPolicy
    MaaSSubscriptionReconciler -->|creates| TokenRateLimitPolicy
    AITenantReconciler -->|bootstraps| TenantCR
    TenantReconciler -->|deploys| API
    TenantReconciler -->|deploys| PayloadProc
    ExternalModelReconciler -->|creates| InferenceExternalModel
    ExternalModelReconciler -->|creates| ExternalProvider

    %% API dependencies
    API -->|stores keys| PostgreSQL
    API -->|watches CRDs| K8sAPI
    API -->|probes models| Gateway

    %% Gateway flow
    Client -->|HTTPS/443| Gateway
    Gateway -->|ext_proc| PreAuth
    Gateway -->|AuthN| Authorino
    Authorino -->|callback| InternalValidate
    Authorino -->|callback| InternalSelect
    Gateway -->|ext_proc| PostAuth
    Gateway -->|routes via| HTTPRoute

    %% External
    AuthPolicy -->|enforced by| Authorino
    TokenRateLimitPolicy -->|enforced by| Limitador
    MaaSModelRefReconciler -->|watches| KServe

    %% Webhook
    Webhook -->|validates| AITenantCR
    Webhook -->|validates| MaaSAuthPolicyCR
    Webhook -->|validates| MaaSSubscriptionCR

    %% Styles
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#4a90e2,stroke:#333,color:#fff
    style PayloadProc fill:#4a90e2,stroke:#333,color:#fff
    style MaaSModelRefCR fill:#f5a623,stroke:#333
    style MaaSAuthPolicyCR fill:#f5a623,stroke:#333
    style MaaSSubscriptionCR fill:#f5a623,stroke:#333
    style AITenantCR fill:#f5a623,stroke:#333
    style TenantCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style TokenRateLimitPolicy fill:#7ed321,stroke:#333
    style InferenceExternalModel fill:#7ed321,stroke:#333
    style ExternalProvider fill:#7ed321,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style Authorino fill:#e8e8e8,stroke:#333
    style Limitador fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Client fill:#d5e8d4,stroke:#333
