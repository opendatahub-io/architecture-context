graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Platform["RHOAI Platform"]
        Gateway["Platform Gateway<br/>443/TCP HTTPS"]
        KServe["KServe ServingRuntime<br/>Pod Lifecycle & Scaling"]
        KRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
    end

    subgraph VLLMPod["vLLM Gaudi Pod"]
        subgraph PluginPackage["vllm_gaudi Plugin Package"]
            Platform_Plugin["HpuPlatform<br/>(Platform Plugin)"]
            AttentionBackends["Attention Backends<br/>HPUAttentionV1 | UnifiedAttn<br/>HPUMLAAttention | UnifiedMLA"]
            ModelOverrides["Model Overrides<br/>11 HPU-optimized models<br/>(pixtral, deepseek, qwen3, etc.)"]
            BucketingManager["Bucketing Manager<br/>Prompt/Decode/Unified buckets<br/>(exponential/linear strategies)"]
            HpuWorker["HPU Worker<br/>Model execution on Gaudi"]
            HpuModelRunner["HPU Model Runner<br/>Graph compilation & caching"]
            CustomOps["Custom Ops<br/>Cache ops, kernels,<br/>defragmentation, quantization"]
            SpecDecode["Speculative Decoding<br/>Eagle3/MTP"]
            KVOffload["KV Cache Offload<br/>CPU ↔ HPU swap"]
        end

        subgraph VLLMCore["vLLM Core Engine"]
            APIServer["OpenAI-compatible API Server<br/>8000/TCP HTTP"]
            Scheduler["Async Scheduler"]
        end

        Platform_Plugin -->|registers| VLLMCore
        AttentionBackends -->|selected by| Platform_Plugin
        ModelOverrides -->|patched into| VLLMCore
        BucketingManager -->|configures| HpuModelRunner
        HpuWorker -->|executes on| HPU
        HpuModelRunner -->|manages| HpuWorker
        CustomOps -->|used by| HpuWorker
        SpecDecode -->|accelerates| HpuWorker
        KVOffload -->|extends| HpuWorker
        Scheduler -->|dispatches to| HpuWorker
        APIServer -->|routes to| Scheduler
    end

    subgraph Hardware["Intel Gaudi Accelerators"]
        HPU["Gaudi 2/3 HPU<br/>Synapse AI 1.23.0"]
        HCCL["HCCL<br/>libfabric/verbs<br/>Inter-HPU collective ops"]
    end

    subgraph Storage["Model Storage"]
        S3["S3 / PVC<br/>Model Weights & Tokenizer"]
    end

    subgraph Distributed["Distributed Runtime"]
        Ray["Ray<br/>Worker Process Management"]
        NIXL["NIXL Connector<br/>Disaggregated KV Transfer"]
    end

    Client -->|HTTPS/443| Gateway
    Gateway -->|routes| KRBAC
    KRBAC -->|HTTP/8000| APIServer
    KServe -->|manages lifecycle| VLLMPod
    HpuWorker -->|SynapseAI API| HPU
    HpuWorker -->|all-reduce/all-gather| HCCL
    HpuWorker -->|load weights| S3
    Ray -->|orchestrates| HpuWorker
    NIXL -->|KV cache transfer| HpuWorker

