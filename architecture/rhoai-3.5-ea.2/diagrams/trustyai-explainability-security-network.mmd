graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Dashboard"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route: trustyai<br/>80/TCP<br/>TLS: None (tls: null)<br/>RHOAI 3.x: kube-rbac-proxy sidecar"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL SERVICES"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x auth enforcement)"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Port: 8080/TCP (HTTP)<br/>Port: 4443/TCP (HTTPS, optional)<br/>Image: registry.redhat.io/rhods/<br/>odh-trustyai-service-rhel8"]
        end

        subgraph NS_ModelServing["Model Serving Namespace"]
            ModelMesh["ModelMesh Serving"]
            KServeLogger["KServe InferenceLogger<br/>(CloudEvents)"]
        end

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor scrape"]
        end
    end

    subgraph StorageBackends["STORAGE BACKENDS"]
        direction LR
        PVC["PVC Storage<br/>Mount: /inputs<br/>Filesystem I/O<br/>(default mode)"]
        MinIO["MinIO<br/>S3 API<br/>HTTP<br/>Access Key + Secret Key"]
        MariaDB["MariaDB/MySQL<br/>3306/TCP<br/>JDBC<br/>Username + Password"]
    end

    subgraph ModelServers["MODEL SERVERS"]
        KServeServer["KServe Model Servers<br/>gRPC (v2 protocol)<br/>HTTP (v1/v2 protocol)<br/>Encryption: plaintext"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No TLS (manifest)<br/>No app-level auth"| Route

    %% Ingress → Service
    Route -->|"HTTP/80 → 8080<br/>plaintext<br/>kube-rbac-proxy (RHOAI 3.x)"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8080<br/>localhost"| TrustyAI

    %% Cluster-internal → TrustyAI
    ModelMesh -->|"HTTP/80<br/>POST /consumer/kserve/v2<br/>plaintext, no auth"| TrustyAI
    KServeLogger -->|"HTTP/80<br/>CloudEvent<br/>plaintext, no auth"| TrustyAI
    Prometheus -->|"HTTP/80<br/>GET /q/metrics<br/>Bearer Token (SA)"| TrustyAI

    %% TrustyAI → Storage
    TrustyAI -->|"Filesystem<br/>/inputs mount"| PVC
    TrustyAI -->|"HTTP S3 API<br/>Access Key auth"| MinIO
    TrustyAI -->|"JDBC/3306<br/>plaintext<br/>Username+Password"| MariaDB

    %% TrustyAI → Model Servers
    TrustyAI -->|"gRPC v2<br/>plaintext (usePlaintext())<br/>no auth"| KServeServer
    TrustyAI -->|"HTTP v1/v2<br/>plaintext<br/>no auth"| KServeServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef modelserver fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class KubeRBACProxy authproxy
    class TrustyAI,ModelMesh,KServeLogger,Prometheus internal
    class PVC,MinIO,MariaDB storage
    class KServeServer modelserver
