graph TB
    subgraph User["User / Operator"]
        Operator[Cluster Operator]
    end

    subgraph CLI["odh-cli (rhai-cli)"]
        direction TB
        Main[cmd/main.go<br/>Cobra Root Command]

        subgraph DiagnosticMode["Diagnostic Commands"]
            Lint[lint<br/>Upgrade readiness checks]
            Status[status<br/>Cluster health assessment]
            Components[components<br/>DSC component state]
            Deps[deps<br/>Dependency management]
            Events[events<br/>Platform event streaming]
            Logs[logs<br/>Pod log retrieval]
            Get[get<br/>Resource listing]
        end

        subgraph MigrationMode["Migration Commands"]
            MigratePrepare[migrate prepare<br/>Backup & validate]
            MigrateRun[migrate run<br/>Execute transformations]
            MigrateList[migrate list<br/>Available actions]
        end

        subgraph CoreLibs["Core Libraries"]
            ClientWrapper[K8s Client Wrapper<br/>dynamic/metadata/discovery/<br/>OLM/core/authz]
            ActionRegistry[Action Registry<br/>Version-aware migration actions]
            CheckRegistry[Check Registry<br/>38+ lint checks in 5 groups]
            StepRecorder[Step Recorder<br/>Hierarchical progress streaming]
            RBACCheck[RBAC Pre-Check<br/>SelfSubjectAccessReview]
        end

        subgraph EmbeddedData["Embedded Data"]
            DepsManifest[Dependency Manifest<br/>odh-gitops values.yaml<br/>embedded at build time]
        end

        Main --> Lint
        Main --> Status
        Main --> Components
        Main --> Deps
        Main --> Events
        Main --> Logs
        Main --> Get
        Main --> MigratePrepare
        Main --> MigrateRun
        Main --> MigrateList

        Lint --> CheckRegistry
        MigratePrepare --> ActionRegistry
        MigrateRun --> ActionRegistry
        ActionRegistry --> StepRecorder
        Deps --> DepsManifest

        CheckRegistry --> ClientWrapper
        ActionRegistry --> ClientWrapper
        Status --> ClientWrapper
        Components --> ClientWrapper
        Events --> ClientWrapper
        ClientWrapper --> RBACCheck
    end

    subgraph ContainerExtras["Container Image Extras"]
        YQ[yq<br/>YAML processor<br/>FIPS-compliant]
        OC[oc / kubectl<br/>from ose-cli-rhel9 base]
        Python[Python 3 + K8s SDK<br/>Legacy migration scripts]
        UpgradeHelpers[rhoai-upgrade-helpers<br/>Shell scripts at<br/>/opt/rhai-upgrade-helpers]
    end

    Operator -->|"kubectl odh ..."| Main
    ClientWrapper -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI[Kubernetes API Server]

