graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB

        Note["⚠ No RBAC manifests in this repository<br/>This is a stateless HTTP service, not a Kubernetes operator"]

        subgraph "Authentication Model"
            direction TB
            Endpoint["Endpoint:<br/>POST /{route_name}/v1/chat/completions"]
            AuthMech["Auth Mechanism:<br/>Authorization header pass-through"]
            Enforcement["Enforcement Point:<br/>None at gateway level"]
            Policy["Policy:<br/>Gateway forwards Authorization header<br/>to orchestrator without validation"]

            Endpoint --> AuthMech
            AuthMech --> Enforcement
            Enforcement --> Policy
        end

        subgraph "Expected External Auth Enforcement"
            direction TB
            Option1["kube-rbac-proxy sidecar<br/>(RHOAI 3.x pattern)"]
            Option2["Ingress Controller<br/>with authentication"]
            Option3["Network Policies<br/>(namespace isolation)"]
        end

        subgraph "Secrets Access"
            direction TB
            Secret1["TLS Client Cert<br/>/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls<br/>Provisioner: cert-manager /<br/>service-serving-cert-signer"]
            Secret2["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Type: Opaque (CA bundle)<br/>Provisioner: Kubernetes Service CA<br/>Auto-rotated by platform"]
        end

        Policy -->|"relies on"| Option1
        Policy -->|"relies on"| Option2
        Policy -->|"relies on"| Option3
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    style Endpoint fill:#4a90e2,color:#fff
    style AuthMech fill:#4a90e2,color:#fff
    style Enforcement fill:#d0021b,color:#fff
    style Policy fill:#f5a623,color:#fff
    style Option1 fill:#999,color:#fff
    style Option2 fill:#999,color:#fff
    style Option3 fill:#999,color:#fff
    style Secret1 fill:#e8e8e8,stroke:#999
    style Secret2 fill:#e8e8e8,stroke:#999
