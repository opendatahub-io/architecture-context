graph TB
    subgraph TrainingHub["Training Hub SDK"]
        direction TB

        subgraph Registry["Algorithm Registry"]
            AlgReg[AlgorithmRegistry<br/>Algorithm & Backend lookup]
            Factory[create_algorithm<br/>Factory function]
            AlgReg --> Factory
        end

        subgraph Algorithms["Training Algorithms"]
            direction LR
            SFT["SFT Algorithm<br/>Full-parameter fine-tuning"]
            OSFT["OSFT Algorithm<br/>Orthogonal Subspace FT"]
            LoRASFT["LoRA SFT Algorithm<br/>Parameter-efficient FT"]
            LoRAGRPO["LoRA GRPO Algorithm<br/>RL from verifiable rewards"]
            GRPO["GRPO Algorithm<br/>Full FT + GRPO"]
            GEPA["GEPA Algorithm<br/>Genetic-Pareto prompt opt."]
        end

        subgraph Backends["Pluggable Backends"]
            direction LR
            ILab["instructlab-training<br/>Backend"]
            MiniTrainer["mini-trainer<br/>Backend"]
            UnslothBE["Unsloth/TRL<br/>Backend"]
            ARTBE["ART Backend<br/>(single-GPU)"]
            VerlBE["verl Backend<br/>(multi-GPU FSDP)"]
            GepaBE["gepa Backend"]
            MLflowBE["MLflow Backend"]
        end

        subgraph Utilities["Shared Utilities"]
            direction LR
            PEFTExt["PEFT Extender<br/>LoRA param composition"]
            TorchUtils["Torchrun Utils<br/>Distributed config"]
            MemEst["Memory Estimator<br/>GPU VRAM estimation"]
            TimeEst["Timing Estimator<br/>Runtime prediction"]
            Viz["Visualization<br/>Loss curve plotting"]
            Rewards["Reward Functions<br/>tool_call / binary"]
        end

        subgraph Adapters["Integration Adapters"]
            ITSRollout["ITS Hub Rollout<br/>Adapter"]
            VerlAgent["verl Tool Agent<br/>Loop"]
        end
    end

    User[User / RHOAI Component] -->|"sft() / osft() / lora_sft()<br/>lora_grpo() / grpo() / gepa()"| Registry

    %% Algorithm to Backend mappings
    Factory --> SFT
    Factory --> OSFT
    Factory --> LoRASFT
    Factory --> LoRAGRPO
    Factory --> GRPO
    Factory --> GEPA

    SFT --> ILab
    OSFT --> MiniTrainer
    LoRASFT --> UnslothBE
    LoRAGRPO --> ARTBE
    LoRAGRPO --> VerlBE
    GRPO --> VerlBE
    GEPA --> GepaBE
    GEPA --> MLflowBE

    %% Shared utilities used by algorithms
    LoRASFT -.-> PEFTExt
    LoRAGRPO -.-> PEFTExt
    SFT -.-> TorchUtils
    OSFT -.-> TorchUtils
    LoRAGRPO -.-> Rewards
    ITSRollout -.-> LoRAGRPO
    VerlAgent -.-> VerlBE

    %% External connections
    ILab -->|"model download"| HF[HuggingFace Hub<br/>443/TCP HTTPS]
    MiniTrainer -->|"model download"| HF
    UnslothBE -->|"model download"| HF
    ARTBE -->|"inference rollouts"| vLLM[vLLM Server<br/>HTTP]
    VerlBE -->|"distributed training"| NCCL[NCCL / TCP<br/>Multi-GPU]
    GepaBE -->|"LLM evaluation"| LLMEndpoint[LLM Endpoint<br/>via litellm]
    MLflowBE -->|"prompt registry"| MLflow[MLflow Server]

    ILab -->|checkpoints| FS[Local Filesystem]
    MiniTrainer -->|checkpoints| FS
    UnslothBE -->|LoRA adapters| FS
    ARTBE -->|LoRA adapters| FS
    VerlBE -->|checkpoints| FS

    %% Experiment tracking
    Algorithms -.->|"metrics"| WandB[W&B<br/>443/TCP HTTPS]
    Algorithms -.->|"metrics"| MLflow
    Algorithms -.->|"events"| TB[TensorBoard<br/>Local files]

    %% Styling
    style TrainingHub fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Registry fill:#fff3cd,stroke:#d6a800,stroke-width:2px
    style Algorithms fill:#d4edda,stroke:#28a745,stroke-width:2px
    style Backends fill:#f8d7da,stroke:#dc3545,stroke-width:2px
    style Utilities fill:#e2e3f1,stroke:#6c63ff,stroke-width:2px
    style Adapters fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style User fill:#4a90e2,color:#fff
    style HF fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style NCCL fill:#e8e8e8,stroke:#333
    style LLMEndpoint fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style WandB fill:#e8e8e8,stroke:#333
    style TB fill:#e8e8e8,stroke:#333
    style FS fill:#e8e8e8,stroke:#333
