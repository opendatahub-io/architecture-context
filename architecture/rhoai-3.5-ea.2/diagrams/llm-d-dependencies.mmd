graph LR
    LLMD["llm-d<br/>Distributed Inference Stack"]

    %% Core Runtime Dependency
    LLMD -->|"model serving engine<br/>v0.23.0, built from source"| vLLM["vLLM v0.23.0"]

    %% Internal llm-d Dependencies
    LLMD -->|"Helm chart + gRPC ext_proc<br/>9002/TCP"| Router["llm-d Router (EPP)"]
    LLMD -->|"KV cache transfer sidecar<br/>P/D disaggregation"| RoutingSidecar["llm-d-routing-sidecar"]
    LLMD -->|"KV cache management"| KVCache["llm-d-kv-cache"]
    LLMD -->|"performance benchmarking"| Benchmark["llm-d-benchmark"]
    LLMD -->|"InferencePool CRD<br/>pod grouping"| GAIE["GAIE v1.5.0"]

    %% HPC Communication Libraries (compiled)
    LLMD -->|"RDMA transport<br/>compiled v1.20.0"| UCX["UCX v1.20.0"]
    LLMD -->|"collective comms<br/>compiled v0.1.1"| UCCL["UCCL v0.1.1"]
    LLMD -->|"GPU shared memory<br/>compiled v3.4.5"| NVSHMEM["NVSHMEM v3.4.5"]
    LLMD -->|"KV transfer<br/>compiled v1.2.0, 5600/TCP"| nixl["nixl v1.2.0"]
    LLMD -->|"GPU RDMA copy<br/>compiled v2.5.2"| gdrcopy["gdrcopy v2.5.2"]

    %% HPC Compute Libraries (compiled)
    LLMD -->|"attention kernels<br/>compiled v0.6.12"| FlashInfer["FlashInfer v0.6.12"]
    LLMD -->|"MoE expert parallelism<br/>compiled"| DeepEP["DeepEP"]
    LLMD -->|"MoE GEMM kernels<br/>compiled"| DeepGEMM["DeepGEMM"]
    LLMD -->|"KV cache offload<br/>compiled v0.4.6"| LMCache["LMCache v0.4.6"]
    LLMD -->|"distributed KV store<br/>LMCache backend 0.2.33"| InfiniStore["InfiniStore 0.2.33"]

    %% Platform Dependencies
    LLMD -->|"L7 proxy<br/>8081/TCP HTTP/HTTP2"| Envoy["Envoy Proxy"]
    LLMD -->|"traffic ingress<br/>Gateway/HTTPRoute CRDs"| GatewayAPI["Gateway API v1"]
    LLMD -->|"container orchestration<br/>1.29+"| K8s["Kubernetes 1.29+"]
    LLMD -->|"chart deployment<br/>3.x"| Helm["Helm 3.x"]
    LLMD -->|"CUDA runtime<br/>13.0.2"| CUDA["NVIDIA CUDA 13.0.2"]
    LLMD -->|"tracing SDK<br/>>=1.39.1"| OTEL["OpenTelemetry SDK"]

    %% Optional platform integrations
    LLMD -.->|"optional service mesh"| Istio["Istio"]
    LLMD -.->|"optional gateway impl"| kgateway["kgateway"]
    LLMD -.->|"multi-pod topology"| LWS["LeaderWorkerSet"]

    %% Reverse dependencies (things that depend on llm-d)
    Prometheus["Prometheus"] -->|"PodMonitor scrape<br/>8000/TCP /metrics"| LLMD
    RHOAI["RHOAI Platform"] -.->|"injects kube-rbac-proxy<br/>or OAuth proxy"| LLMD

