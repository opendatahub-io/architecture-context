graph TB
    subgraph CommonFramework["Common Framework"]
        BaseAPI["DetectorBaseAPI<br/>(FastAPI Subclass)"]
        InstrDet["InstrumentedDetector<br/>(Base Class)"]
        Schemas["Pydantic Schemas<br/>(Request/Response)"]
        Metrics["Prometheus Instrumentation<br/>(trustyai_guardrails_*)"]
        Health["/health Endpoint"]
        MetricsEP["/metrics Endpoint"]
        BaseAPI --> InstrDet
        BaseAPI --> Schemas
        BaseAPI --> Metrics
        BaseAPI --> Health
        BaseAPI --> MetricsEP
    end

    subgraph BuiltIn["Built-in Detector (Port 8080)"]
        BuiltInApp["Built-in Detector App"]
        Registry["BaseDetectorRegistry"]
        RegexDet["Regex PII Detectors<br/>(email, phone, SSN, etc.)"]
        FileTypeDet["File-Type Detectors<br/>(JSON/XML/YAML + schema)"]
        CustomDet["Custom Detectors<br/>(user Python code + AST sandbox)"]
        BuiltInApp --> Registry
        Registry --> RegexDet
        Registry --> FileTypeDet
        Registry --> CustomDet
    end

    subgraph HFDetector["HuggingFace Detector (Port 8000)"]
        HFApp["HuggingFace Detector App"]
        SeqClass["AutoModelForSequenceClassification<br/>(binary/multi-label)"]
        TokClass["AutoModelForTokenClassification<br/>(NER-style spans)"]
        CausalLM["GraniteForCausalLM<br/>(generative risk assessment)"]
        HFApp --> SeqClass
        HFApp --> TokClass
        HFApp --> CausalLM
    end

    subgraph JudgeDetector["LLM Judge Detector (Port 8000)"]
        JudgeApp["LLM Judge Detector App"]
        VLLMJudge["vllm_judge Library<br/>(safety, toxicity, accuracy,<br/>helpfulness, clarity)"]
        JudgeApp --> VLLMJudge
    end

    %% Common framework usage
    BuiltInApp -.->|extends| BaseAPI
    HFApp -.->|extends| BaseAPI
    JudgeApp -.->|extends| BaseAPI

    %% External interactions
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| JudgeApp

    VLLMJudge -->|HTTP 8080/TCP| vLLM["vLLM Server<br/>(OpenAI-compatible)"]

    KServe["KServe Platform"] -->|manages lifecycle| HFApp
    KServe -->|manages lifecycle| JudgeApp
    KServe -->|storage init| S3["S3 Storage<br/>(MinIO)"]

    Istio["Istio Service Mesh"] -.->|mTLS sidecar| BuiltInApp
    Istio -.->|mTLS sidecar| HFApp
    Istio -.->|mTLS sidecar| JudgeApp

    Prometheus["Prometheus"] -->|scrapes /metrics| MetricsEP

    %% Styling
    style BaseAPI fill:#4a90e2,stroke:#333,color:#fff
    style InstrDet fill:#4a90e2,stroke:#333,color:#fff
    style BuiltInApp fill:#7ed321,stroke:#333,color:#fff
    style HFApp fill:#7ed321,stroke:#333,color:#fff
    style JudgeApp fill:#7ed321,stroke:#333,color:#fff
    style Registry fill:#50c878,stroke:#333,color:#fff
    style RegexDet fill:#82b366,stroke:#333
    style FileTypeDet fill:#82b366,stroke:#333
    style CustomDet fill:#82b366,stroke:#333
    style SeqClass fill:#82b366,stroke:#333
    style TokClass fill:#82b366,stroke:#333
    style CausalLM fill:#82b366,stroke:#333
    style VLLMJudge fill:#82b366,stroke:#333
    style Orchestrator fill:#f5a623,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
