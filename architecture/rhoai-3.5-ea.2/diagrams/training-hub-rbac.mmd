graph TD
    subgraph LibraryScope["Training Hub (Python Library)"]
        Note["Training Hub does not define its own<br/>Kubernetes RBAC resources.<br/><br/>RBAC for training jobs is managed by<br/>the orchestrating RHOAI platform component."]
    end

    subgraph InheritedRBAC["Inherited RBAC (from RHOAI Orchestrator)"]
        direction TB

        SA["ServiceAccount<br/>(set by orchestrator)"]
        Pod["Training Job Pod<br/>runs training-hub"]

        SA -->|"pod identity"| Pod
    end

    subgraph CredentialSources["Credentials (Environment Variables)"]
        direction TB

        HFToken["HF_TOKEN<br/>HuggingFace Hub access<br/>(optional, gated models)"]
        WANDBKey["WANDB_API_KEY<br/>Weights & Biases tracking<br/>(optional)"]
        MLflowToken["MLFLOW_TRACKING_TOKEN<br/>MLflow server auth<br/>(optional)"]
        LLMKeys["LLM API Keys<br/>(provider-specific via litellm)<br/>(optional, GEPA only)"]
        vLLMKey["vLLM API Key<br/>(optional, GRPO only)"]
    end

    subgraph ExternalAccess["External Service Access"]
        direction TB

        HF["HuggingFace Hub<br/>443/TCP HTTPS"]
        WandB["Weights & Biases<br/>443/TCP HTTPS"]
        MLflow["MLflow Server<br/>HTTP/HTTPS"]
        LLMEndpoint["LLM Endpoint<br/>HTTPS"]
        vLLM["vLLM Server<br/>HTTP"]
    end

    Pod -->|"env var"| HFToken
    Pod -->|"env var"| WANDBKey
    Pod -->|"env var"| MLflowToken
    Pod -->|"env var"| LLMKeys
    Pod -->|"env var"| vLLMKey

    HFToken -->|"Bearer Token"| HF
    WANDBKey -->|"API Key"| WandB
    MLflowToken -->|"Token Auth"| MLflow
    LLMKeys -->|"API Key"| LLMEndpoint
    vLLMKey -->|"API Key"| vLLM

    subgraph SupplyChainSecurity["Supply Chain Security"]
        LiteLLM["litellm dependency<br/>Versions 1.82.7 & 1.82.8 EXCLUDED<br/>(TeamPCP attack, 2026-03-24)"]
    end

    %% Styling
    style LibraryScope fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style InheritedRBAC fill:#fff3cd,stroke:#d6a800,stroke-width:2px
    style CredentialSources fill:#d4edda,stroke:#28a745,stroke-width:2px
    style ExternalAccess fill:#f8d7da,stroke:#dc3545,stroke-width:2px
    style SupplyChainSecurity fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style Note fill:#e8f4fd,stroke:#4a90e2
    style SA fill:#4a90e2,color:#fff
    style Pod fill:#4a90e2,color:#fff
    style LiteLLM fill:#f44336,color:#fff
