graph TB
    subgraph KServe["KServe Platform (rhoai-3.5-ea.2)"]
        direction TB

        subgraph Controllers["Controllers"]
            CtrlMgr["kserve-controller-manager<br/><i>Go Operator</i><br/>8080/TCP metrics | 9443/TCP webhooks | 8081/TCP health"]
            LLMCtrl["llmisvc-controller<br/><i>Go Operator</i><br/>8443/TCP secure metrics | 9443/TCP webhooks | 8081/TCP health"]
            LocalModelCtrl["localmodel-controller<br/><i>Go Operator</i><br/>8080/TCP metrics | 9443/TCP webhooks | 8081/TCP health"]
            LocalModelNodeAgent["localmodelnode-agent<br/><i>Go Operator (per-node)</i><br/>8080/TCP metrics | 8081/TCP health"]
            ModuleCtrl["kserve-module-controller<br/><i>Go Operator</i><br/>8081/TCP health"]
        end

        subgraph Sidecars["Sidecars & Init Containers"]
            Agent["kserve-agent<br/><i>Go sidecar</i><br/>9081/TCP agent | 8080/TCP proxy | 9083/TCP log"]
            Router["inference-graph-router<br/><i>Go sidecar</i><br/>8080/TCP HTTP/HTTPS"]
            StorageInit["storage-initializer<br/><i>Python 3.11 init container</i><br/>No network listener"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP TLS)"]
            MutatingWH["Mutating Webhooks<br/>• Pod mutator (sidecar injection)<br/>• InferenceService defaulter<br/>• LLMInferenceService defaulter"]
            ValidatingWH["Validating Webhooks<br/>• InferenceService validator<br/>• LLMInferenceService validator<br/>• ServingRuntime validator<br/>• LocalModel validators<br/>• TrainedModel validator"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/><i>v1beta1 Namespaced</i>"]
        LLMISVC["LLMInferenceService<br/><i>v1alpha2 Namespaced</i>"]
        LLMConfig["LLMInferenceServiceConfig<br/><i>v1alpha2 Namespaced</i>"]
        IG["InferenceGraph<br/><i>v1alpha1 Namespaced</i>"]
        SR["ServingRuntime<br/><i>v1alpha1 Namespaced</i>"]
        CSR["ClusterServingRuntime<br/><i>v1alpha1 Cluster</i>"]
        TM["TrainedModel<br/><i>v1alpha1 Namespaced</i>"]
        LMC["LocalModelCache<br/><i>v1alpha1 Cluster</i>"]
        LMNC["LocalModelNamespaceCache<br/><i>v1alpha1 Namespaced</i>"]
        LMNG["LocalModelNodeGroup<br/><i>v1alpha1 Cluster</i>"]
        LMN["LocalModelNode<br/><i>v1alpha1 Cluster</i>"]
        CSC["ClusterStorageContainer<br/><i>v1alpha1 Cluster</i>"]
        KserveCR["Kserve CR<br/><i>v1alpha1 Cluster</i>"]
    end

    %% User interactions
    User["Data Scientist / User"] -->|creates| ISVC
    User -->|creates| LLMISVC
    User -->|creates| IG

    %% Controller watches
    ISVC -->|watched by| CtrlMgr
    LLMISVC -->|watched by| LLMCtrl
    LLMConfig -->|watched by| LLMCtrl
    IG -->|watched by| CtrlMgr
    TM -->|watched by| CtrlMgr
    SR -->|watched by| CtrlMgr
    CSR -->|watched by| CtrlMgr
    LMC -->|watched by| LocalModelCtrl
    LMNC -->|watched by| LocalModelCtrl
    LMN -->|watched by| LocalModelNodeAgent
    KserveCR -->|watched by| ModuleCtrl

    %% Controller creates resources
    CtrlMgr -->|creates| Deployments["Deployments<br/>Services<br/>HPAs"]
    CtrlMgr -->|creates| IngressRes["HTTPRoutes<br/>VirtualServices<br/>Ingresses"]
    LLMCtrl -->|creates| LLMRes["Deployments<br/>HTTPRoutes<br/>InferencePools<br/>DestinationRules"]
    LocalModelCtrl -->|creates| StorageRes["PVs / PVCs"]
    LocalModelNodeAgent -->|creates| DownloadJobs["Download Jobs"]
    ModuleCtrl -->|deploys via kustomize| KServe

    %% Webhook connections
    CtrlMgr -->|serves| MutatingWH
    CtrlMgr -->|serves| ValidatingWH
    LLMCtrl -->|serves| ValidatingWH

    %% Sidecar injection
    MutatingWH -->|injects| Agent
    MutatingWH -->|injects| StorageInit

