graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-wide)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction LR

        subgraph CoreAPI["Core API (\"\")"]
            ConfigMaps["configmaps<br/>create, get, list,<br/>patch, update, watch"]
            Secrets["secrets<br/>create, get, list,<br/>patch, update, watch"]
            Events["events<br/>create, patch,<br/>update, watch"]
            LimitRanges["limitranges<br/>get, list, watch"]
            Pods["pods<br/>get, list<br/>(RHOAI progression)"]
        end

        subgraph TrainerAPI["trainer.kubeflow.org"]
            TrainJobs["trainjobs<br/>get, list, patch,<br/>update, watch"]
            TrainJobStatus["trainjobs/status<br/>get, patch, update"]
            Runtimes["trainingruntimes<br/>clustertrainingruntimes<br/>get, list, patch,<br/>update, watch"]
            Finalizers["*/finalizers<br/>get, patch, update"]
        end

        subgraph JobSetAPI["jobset.x-k8s.io"]
            JobSets["jobsets<br/>create, get, list,<br/>patch, update, watch"]
        end

        subgraph SchedulingAPI["scheduling.x-k8s.io /<br/>scheduling.volcano.sh"]
            PodGroups["podgroups<br/>create, get, list,<br/>patch, update, watch"]
        end

        subgraph NetworkAPI["networking.k8s.io"]
            NetworkPolicies["networkpolicies<br/>get, list, watch,<br/>create, update, patch<br/>(RHOAI)"]
        end

        subgraph AdmissionAPI["admissionregistration.k8s.io"]
            WebhookConfigs["validatingwebhook-<br/>configurations<br/>get, list, update, watch"]
        end

        subgraph CoordAPI["coordination.k8s.io"]
            Leases["leases<br/>create, get,<br/>list, update"]
        end

        subgraph NodeAPI["node.k8s.io"]
            RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        end
    end

    SA -->|bound via| CRB
    CRB -->|grants| ControllerRole

    %% User-facing roles
    subgraph UserRoles["User-Facing ClusterRoles"]
        TrainingAdmin["training-admin<br/>trainjobs, runtimes: full CRUD"]
        TrainingEdit["training-edit<br/>trainjobs: CRUD<br/>runtimes: read-only"]
        TrainingView["training-view<br/>trainjobs, runtimes: read-only"]
    end

    %% Styles
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#6baed6,color:#fff
    style ControllerRole fill:#f5f5f5,stroke:#333
    style ConfigMaps fill:#7ed321
    style Secrets fill:#7ed321
    style Events fill:#7ed321
    style LimitRanges fill:#7ed321
    style Pods fill:#e6550d,color:#fff
    style TrainJobs fill:#f5a623
    style TrainJobStatus fill:#f5a623
    style Runtimes fill:#f5a623
    style Finalizers fill:#f5a623
    style JobSets fill:#9e9ac8,color:#fff
    style PodGroups fill:#9e9ac8,color:#fff
    style NetworkPolicies fill:#e6550d,color:#fff
    style WebhookConfigs fill:#bcbddc
    style Leases fill:#bcbddc
    style RuntimeClasses fill:#bcbddc
    style TrainingAdmin fill:#d62728,color:#fff
    style TrainingEdit fill:#ff7f0e,color:#fff
    style TrainingView fill:#2ca02c,color:#fff
