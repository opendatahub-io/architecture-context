graph TB
    subgraph RhodsOperator["rhods-operator (Platform Orchestrator)"]
        direction TB

        subgraph ManagerBinary["manager Binary"]
            direction TB
            DSCController["DSC Controller<br/>Orchestrates component CRs<br/>from DataScienceCluster spec"]
            DSCIController["DSCI Controller<br/>Platform init: namespaces,<br/>auth, monitoring, CA bundles"]

            subgraph ServiceControllers["Service Controllers"]
                GatewayCtrl["Gateway Controller<br/>Deploys ingress stack:<br/>Gateway API, Envoy,<br/>kube-auth-proxy, Routes"]
                AuthCtrl["Auth Controller<br/>RBAC groups, roles,<br/>bindings management"]
                MonitoringCtrl["Monitoring Controller<br/>Prometheus, Tempo,<br/>OTel, Perses"]
                CertConfigMap["CertConfigMap Generator<br/>Trusted CA bundle<br/>propagation"]
            end

            subgraph ComponentControllers["Component Controllers (16)"]
                Dashboard["Dashboard"]
                KServe["KServe"]
                Kueue["Kueue"]
                DSP["DataScience<br/>Pipelines"]
                Workbenches["Workbenches"]
                ModelRegistry["Model<br/>Registry"]
                ModelController["Model<br/>Controller"]
                Ray["Ray"]
                TrustyAI["TrustyAI"]
                TrainingOp["Training<br/>Operator"]
                Trainer["Trainer"]
                Feast["Feast<br/>Operator"]
                OGX["OGX"]
                MLflow["MLflow<br/>Operator"]
                Spark["Spark<br/>Operator"]
                MaaS["Models as<br/>Service"]
            end

            ModulesCtrl["Modules Controller<br/>Out-of-tree operators<br/>via Helm/Kustomize"]
        end

        subgraph CloudManagerBinary["cloudmanager Binary"]
            direction LR
            AWSCtrl["AWS EKS<br/>Controller"]
            AzureCtrl["Azure AKS<br/>Controller"]
            CoreWeaveCtrl["CoreWeave<br/>Controller"]
        end
    end

    %% CRD Hierarchy
    User["User / Admin"] -->|creates| DSCCR["DataScienceCluster CR<br/>(v1/v2)"]
    User -->|creates| DSCICR["DSCInitialization CR<br/>(v1/v2)"]
    DSCCR -->|watched by| DSCController
    DSCICR -->|watched by| DSCIController

    %% DSC → Components
    DSCController -->|creates/manages| ComponentCRs["Component CRs<br/>(Dashboard, KServe, Kueue, ...)"]
    ComponentCRs -->|watched by| ComponentControllers

    %% DSCI → Services
    DSCIController -->|creates/manages| ServiceCRs["Service CRs<br/>(GatewayConfig, Auth, Monitoring)"]
    ServiceCRs -->|watched by| ServiceControllers

    %% Gateway Stack
    GatewayCtrl -->|creates| GatewayCR["Gateway CR<br/>(Gateway API)"]
    GatewayCtrl -->|creates| EnvoyFilter["EnvoyFilter<br/>(ext_authz + Lua)"]
    GatewayCtrl -->|creates| KubeAuthProxy["kube-auth-proxy<br/>Deployment"]
    GatewayCtrl -->|creates| HTTPRoutes["HTTPRoute CRs"]
    GatewayCtrl -->|creates| OcpRoutes["OpenShift Routes<br/>(redirects)"]

    %% Cloud Manager CRDs
    CloudCR["Cloud CRs<br/>(AWS/Azure/CoreWeave)"] -->|watched by| CloudManagerBinary
    CloudManagerBinary -->|deploys via Helm| InfraDeps["cert-manager<br/>Sail/Istio<br/>LWS Operator<br/>Gateway API"]

    %% External Dependencies
    ManagerBinary -->|API calls| K8sAPI["Kubernetes API<br/>6443/TCP"]
    ManagerBinary -->|reads config| OpenShiftAPI["OpenShift API<br/>(TLS profile, auth config)"]

    %% Styling
    style RhodsOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style ManagerBinary fill:#dcedc8,stroke:#689f38,stroke-width:2px
    style CloudManagerBinary fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style ServiceControllers fill:#f3e5f5,stroke:#8e24aa,stroke-width:1px
    style ComponentControllers fill:#e3f2fd,stroke:#1565c0,stroke-width:1px
    style DSCController fill:#4a90e2,color:#fff
    style DSCIController fill:#4a90e2,color:#fff
    style GatewayCtrl fill:#7b1fa2,color:#fff
    style AuthCtrl fill:#7b1fa2,color:#fff
    style MonitoringCtrl fill:#7b1fa2,color:#fff
    style CertConfigMap fill:#7b1fa2,color:#fff
    style ModulesCtrl fill:#689f38,color:#fff
    style DSCCR fill:#f5a623
    style DSCICR fill:#f5a623
    style ComponentCRs fill:#f5a623
    style ServiceCRs fill:#f5a623
    style CloudCR fill:#f5a623
    style GatewayCR fill:#ffcc80
    style EnvoyFilter fill:#ffcc80
    style KubeAuthProxy fill:#ffcc80
    style HTTPRoutes fill:#ffcc80
    style OcpRoutes fill:#ffcc80
    style K8sAPI fill:#e8e8e8
    style OpenShiftAPI fill:#e8e8e8
    style InfraDeps fill:#e8e8e8
