graph LR
    Feast["Feast<br/>Feature Store"]

    %% Internal Platform Dependencies
    Feast -->|"CRD-based deployment<br/>Kustomize manifests"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    Feast -->|"TLS cert auto-provisioning<br/>Service annotation"| ServingCert["OpenShift Serving<br/>Cert Controller"]
    Feast -->|"ServiceMonitor CRD<br/>Metrics scraping (8000/TCP)"| PrometheusOp["Prometheus<br/>Operator"]
    Feast -->|"Watch Notebooks<br/>Inject feast-config ConfigMap"| ODHNotebooks["OpenDataHub<br/>Notebooks<br/>(kubeflow.org)"]

    %% External Framework Dependencies
    Feast -->|"Operator framework"| ControllerRuntime["controller-runtime<br/>v0.20.x"]
    Feast -->|"REST API framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"gRPC server"| gRPC["gRPC Python<br/>>=1.56.2"]
    Feast -->|"ASGI server"| Gunicorn["gunicorn /<br/>uvicorn"]
    Feast -->|"JWT auth"| PyJWT["PyJWT"]
    Feast -->|"Metrics"| PromClient["prometheus_client<br/>>=0.20.0"]
    Feast -->|"Columnar data (Go)"| Arrow["Apache Arrow<br/>v17.0.0"]

    %% External Store Backends
    Feast -->|"Online store<br/>TCP/6379"| Redis["Redis"]
    Feast -->|"Online/Offline store<br/>TCP/5432"| PostgreSQL["PostgreSQL"]
    Feast -->|"Online store<br/>HTTPS/443"| DynamoDB["AWS DynamoDB"]
    Feast -->|"Offline store<br/>HTTPS/443"| BigQuery["Google BigQuery"]
    Feast -->|"Offline/Registry<br/>HTTPS/443"| Snowflake["Snowflake"]
    Feast -->|"Registry persistence<br/>HTTPS/443"| S3GCS["S3 / GCS"]
    Feast -->|"Vector search<br/>gRPC/19530"| Milvus["Milvus"]

    %% External Services
    Feast -->|"Token validation<br/>JWKS (HTTPS/443)"| OIDC["OIDC Provider<br/>(Keycloak/Azure AD)"]
    Feast -->|"Data lineage<br/>HTTP/HTTPS"| OpenLineage["OpenLineage API"]

    %% Platform dependencies
    Feast -->|"Resource CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

    %% Integration Points (others depending on Feast)
    Dashboard["ODH Dashboard"] -.->|"UI management"| Feast
    Pipelines["Data Science<br/>Pipelines"] -.->|"Feature retrieval"| Feast

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (green)
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style ServingCert fill:#7ed321,stroke:#333,color:#fff
    style PrometheusOp fill:#7ed321,stroke:#333,color:#fff
    style ODHNotebooks fill:#7ed321,stroke:#333,color:#fff

    %% Framework dependencies (light blue)
    style ControllerRuntime fill:#dae8fc,stroke:#6c8ebf
    style FastAPI fill:#dae8fc,stroke:#6c8ebf
    style gRPC fill:#dae8fc,stroke:#6c8ebf
    style Gunicorn fill:#dae8fc,stroke:#6c8ebf
    style PyJWT fill:#dae8fc,stroke:#6c8ebf
    style PromClient fill:#dae8fc,stroke:#6c8ebf
    style Arrow fill:#dae8fc,stroke:#6c8ebf

    %% External stores (orange)
    style Redis fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style DynamoDB fill:#f5a623,stroke:#333,color:#fff
    style BigQuery fill:#f5a623,stroke:#333,color:#fff
    style Snowflake fill:#f5a623,stroke:#333,color:#fff
    style S3GCS fill:#f5a623,stroke:#333,color:#fff
    style Milvus fill:#f5a623,stroke:#333,color:#fff

    %% External services (gray)
