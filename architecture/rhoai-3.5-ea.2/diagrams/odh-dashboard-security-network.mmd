graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser<br/>Data Scientist / Admin"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>HTTPRoute routing"]
    end

    subgraph AuthBoundary["AUTHENTICATION BOUNDARY"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS 1.2+ (service-serving-cert)<br/>TokenReview + SAR<br/>SA: odh-dashboard"]
    end

    subgraph AppTier["APPLICATION TIER (Dashboard Pod)"]
        direction TB

        Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP (localhost)<br/>SA: odh-dashboard"]

        subgraph BFFSidecars["BFF SIDECARS (SA: odh-dashboard-modules)"]
            direction LR
            ModelRegBFF["model-registry BFF<br/>8043/TCP HTTPS"]
            GenAIBFF["gen-ai BFF<br/>8143/TCP HTTPS"]
            MaaSBFF["maas BFF<br/>8243/TCP HTTPS"]
            MLflowBFF["mlflow BFF<br/>8343/TCP HTTPS"]
            EvalHubBFF["eval-hub BFF<br/>8543/TCP HTTPS"]
            AutoMLBFF["automl BFF<br/>8643/TCP HTTPS"]
            AutoRAGBFF["autorag BFF<br/>8743/TCP HTTPS"]
            AgentOpsBFF["agent-ops BFF<br/>8843/TCP HTTPS"]
        end
    end

    subgraph OperatorTier["OPERATOR (Separate Pod)"]
        Operator["dashboard-operator<br/>8443/TCP metrics<br/>9443/TCP webhook<br/>TLS 1.2+"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["K8s API Server<br/>6443/TCP HTTPS<br/>SA token / User Bearer"]
        ModelRegSvc["Model Registry<br/>8080/TCP HTTP"]
        DSP["DSP API Server<br/>HTTPS"]
        TrustyAI["TrustyAI<br/>443/TCP HTTPS"]
        MLflowSvc["MLflow Service<br/>8443/TCP HTTPS"]
        OGX["OGX API<br/>HTTPS"]
        LlamaStack["LlamaStack<br/>8321/TCP HTTP"]
        MaaSCtrl["MaaS Controller<br/>HTTPS"]
        EvalHubAPI["EvalHub API<br/>HTTPS"]
        PipelineSvr["Pipeline Server<br/>HTTPS"]
        Perses["Perses<br/>8080/TCP HTTP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
        Segment["Segment Analytics<br/>443/TCP HTTPS<br/>API key"]
    end

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth session"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>X-Forwarded headers"| KRBAC
    KRBAC -->|"HTTPS/6443<br/>TokenReview + SAR"| K8sAPI
    KRBAC -->|"HTTP/8080<br/>localhost only<br/>X-Auth-Request-User/Groups"| Backend

    %% Backend to BFF sidecars
    Backend -->|"HTTPS/8043-8843<br/>TLS 1.2+ (shared cert)<br/>x-forwarded-access-token"| ModelRegBFF
    Backend -->|"HTTPS/8143<br/>x-forwarded-access-token"| GenAIBFF
    Backend -->|"HTTPS/8243"| MaaSBFF
    Backend -->|"HTTPS/8343"| MLflowBFF
    Backend -->|"HTTPS/8543"| EvalHubBFF
    Backend -->|"HTTPS/8643"| AutoMLBFF
    Backend -->|"HTTPS/8743"| AutoRAGBFF
    Backend -->|"HTTPS/8843"| AgentOpsBFF

    %% Inter-BFF
    GenAIBFF -->|"HTTPS/8243<br/>TLS 1.2+<br/>x-forwarded-access-token"| MaaSBFF

    %% Backend direct upstream
    Backend -->|"HTTPS/6443<br/>User Bearer token"| K8sAPI
    Backend -->|"HTTPS<br/>user_token"| DSP
    Backend -->|"HTTPS/443<br/>user_token"| TrustyAI

    %% BFF upstream
    ModelRegBFF -->|"HTTP/8080<br/>user_token"| ModelRegSvc
    GenAIBFF -->|"HTTPS<br/>user_token"| OGX
    GenAIBFF -->|"HTTP/8321<br/>user_token"| LlamaStack
    GenAIBFF -->|"HTTPS/8443<br/>user_token"| MLflowSvc
    MaaSBFF -->|"HTTPS<br/>user_token"| MaaSCtrl
    MLflowBFF -->|"HTTPS<br/>user_token"| MLflowSvc
    EvalHubBFF -->|"HTTPS<br/>user_token"| EvalHubAPI
    AutoMLBFF -->|"HTTPS<br/>user_token"| PipelineSvr
    AutoMLBFF -->|"HTTPS/443<br/>AWS creds"| S3
    AutoRAGBFF -->|"HTTPS<br/>user_token"| OGX
    AutoRAGBFF -->|"HTTPS<br/>user_token"| PipelineSvr
    AutoRAGBFF -->|"HTTPS/443<br/>AWS creds"| S3

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>SA token"| K8sAPI

    %% Telemetry
    Backend -.->|"HTTPS/443<br/>API key (optional)"| Segment

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authboundary fill:#f8cecc,stroke:#b85450,stroke-width:3px
    classDef apptier fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBAC authboundary
    class Backend,ModelRegBFF,GenAIBFF,MaaSBFF,MLflowBFF,EvalHubBFF,AutoMLBFF,AutoRAGBFF,AgentOpsBFF apptier
    class Operator operator
    class K8sAPI,ModelRegSvc,DSP,TrustyAI,MLflowSvc,OGX,LlamaStack,MaaSCtrl,EvalHubAPI,PipelineSvr,Perses clusterservice
    class S3,Segment externalservice
