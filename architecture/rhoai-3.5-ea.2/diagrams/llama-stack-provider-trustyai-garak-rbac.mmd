graph TD
    subgraph ServiceAccounts["Service Accounts"]
        JobSA["Job Service Account<br/>(eval-hub provisioned)"]
    end

    subgraph RoleBindings["Role Bindings"]
        SecretRB["evalhub-secret-reader<br/>(RoleBinding)<br/>Namespace: redhat-ods-applications<br/>or opendatahub"]
    end

    subgraph Roles["Roles (Expected)"]
        SecretRole["secret-reader<br/>(Role)"]
        ConfigMapRole["configmap-reader<br/>(Role - optional)"]
    end

    subgraph APIResources["API Resources"]
        Secrets["core (&quot;&quot;)<br/>secrets"]
        ConfigMaps["core (&quot;&quot;)<br/>configmaps"]
    end

    subgraph SecretInstances["Secret Instances Accessed"]
        ModelAuth["model-auth<br/>(Opaque)<br/>API keys for target/judge/<br/>attacker/evaluator/SDG models<br/>Mount: /mnt/model-auth"]
        DataConn["Data Connection Secret<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_S3_BUCKET<br/>AWS_DEFAULT_REGION"]
    end

    subgraph ConfigMapInstances["ConfigMap Instances Accessed"]
        TrustyAIConfig["trustyai-service-operator-config<br/>(ConfigMap)<br/>Key: garak-provider-image<br/>Purpose: KFP base image reference"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        BearerAuth["Target LLM /v1/*<br/>API Key (Bearer)<br/>via model-auth Secret<br/>Enforcement: resolve_api_key()"]
        SATokenAuth["KFP API<br/>SA Token or KFP_AUTH_TOKEN<br/>From: /var/run/secrets/<br/>kubernetes.io/serviceaccount/token"]
        AWSAuth["S3 Storage<br/>AWS IAM credentials<br/>From: Data Connection Secret<br/>Enforcement: boto3 client"]
    end

    %% Bindings
    JobSA -->|"bound via"| SecretRB
    SecretRB -->|"grants"| SecretRole

    %% Permissions
    SecretRole -->|"get"| Secrets
    ConfigMapRole -->|"get"| ConfigMaps

    %% Resource instances
    Secrets -.->|"includes"| ModelAuth
    Secrets -.->|"includes"| DataConn
    ConfigMaps -.->|"includes"| TrustyAIConfig

    %% Auth mechanisms use secrets
    ModelAuth -.->|"provides keys"| BearerAuth
    DataConn -.->|"provides creds"| AWSAuth
    JobSA -.->|"provides token"| SATokenAuth

    %% Styling
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style SecretRB fill:#9b59b6,stroke:#333,color:#fff
    style SecretRole fill:#f5a623,stroke:#333,color:#fff
    style ConfigMapRole fill:#f5a623,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style ModelAuth fill:#e74c3c,stroke:#333,color:#fff
    style DataConn fill:#e74c3c,stroke:#333,color:#fff
    style TrustyAIConfig fill:#3498db,stroke:#333,color:#fff
    style BearerAuth fill:#95a5a6,stroke:#333,color:#fff
    style SATokenAuth fill:#95a5a6,stroke:#333,color:#fff
    style AWSAuth fill:#95a5a6,stroke:#333,color:#fff
