graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% Build Dependencies
    MLMD -->|"build system"| Bazel["Bazel 5.3.0"]
    MLMD -->|"RPC framework"| gRPC["gRPC 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protobuf 3.21.12"]
    MLMD -->|"SQL filter parsing"| ZetaSQL["ZetaSQL f764f4e"]
    MLMD -->|"C++ utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL 648cbaf"]
    MLMD -->|"CLI flags"| gflags["gflags"]
    MLMD -->|"logging"| glog["glog"]

    %% Database Backends
    MLMD -->|"persistent storage<br/>3306/TCP"| MySQL["MySQL / MariaDB<br/>(MariaDB Connector/C)"]
    MLMD -->|"persistent storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 12.17<br/>(libpq)"]
    MLMD -->|"in-memory storage"| SQLite["SQLite 3.39.2"]

    %% Internal Platform Dependencies
    DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    PipelineUI["Pipeline UI<br/>(Frontend)"] -->|"gRPC client (indirect)<br/>8080/TCP"| MLMD

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Build deps - gray
    style Bazel fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style ZetaSQL fill:#999,stroke:#333,color:#fff
    style Abseil fill:#999,stroke:#333,color:#fff
    style BoringSSL fill:#999,stroke:#333,color:#fff
    style gflags fill:#999,stroke:#333,color:#fff
    style glog fill:#999,stroke:#333,color:#fff

    %% Database backends - orange
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333,color:#fff

    %% Internal platform consumers - green
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelineUI fill:#7ed321,stroke:#333,color:#fff
