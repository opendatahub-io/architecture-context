graph TB
    subgraph BuildTime["BUILD-TIME ENVIRONMENT (CI/CD Pipeline)"]
        direction TB

        subgraph CIRunner["CI/CD Runner (Konflux Tekton)"]
            Extractor["model-extractor<br/>(Go CLI)<br/>No K8s API access<br/>No RBAC required"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time Only)"]
        direction TB
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (optional)"]
        RedHatReg["Red Hat Container Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Anonymous"]
    end

    subgraph Runtime["RUNTIME ENVIRONMENT (Kubernetes Cluster)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-operator"]
            Operator["rhods-operator<br/>Deployment orchestrator"]
        end

        subgraph AppNS["Namespace: redhat-ods-applications"]
            DataContainer["odh-model-metadata-collection<br/>(ubi9-minimal)<br/>CMD: sleep infinity<br/>VOLUME: /app/data<br/>No network services<br/>No K8s API access<br/>No RBAC required"]
            Dashboard["RHOAI Dashboard<br/>Reads /app/data/*.yaml<br/>via volume mount"]
        end
    end

    subgraph ContainerReg["CONTAINER REGISTRY (Image Pull)"]
        QuayRegistry["quay.io/opendatahub/<br/>odh-model-metadata-collection<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% Build-time egress flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional HF_TOKEN)"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Anonymous"| RedHatReg

    %% Runtime flows
    Operator -->|"Image pull<br/>HTTPS/443<br/>Image pull secret"| QuayRegistry
    Operator -->|"Deploy as<br/>init container/sidecar"| DataContainer
    DataContainer -->|"Volume mount<br/>/app/data/*.yaml<br/>Filesystem only<br/>No network"| Dashboard

    %% Styling
    classDef buildtime fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef runtime fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef registry fill:#fce4ec,stroke:#c62828,stroke-width:2px

    class Extractor buildtime
    class HuggingFace,RedHatReg external
    class Operator,DataContainer,Dashboard runtime
    class QuayRegistry registry
