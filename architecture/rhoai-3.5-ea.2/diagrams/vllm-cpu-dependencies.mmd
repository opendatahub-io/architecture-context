graph LR
    VllmCpu["vllm-cpu<br/>CPU Inference Server"]

    %% Platform Dependencies (Internal RHOAI)
    VllmCpu -->|"deployed as<br/>ServingRuntime"| KServe["KServe / ModelMesh"]
    VllmCpu -->|"metrics scrape<br/>HTTP 8000/TCP"| Prometheus["Prometheus"]
    VllmCpu -->|"ingress routing<br/>TLS termination"| GatewayAPI["Gateway API / Envoy"]

    %% Runtime Dependencies (Frameworks)
    VllmCpu -->|"tensor ops"| PyTorch["PyTorch CPU<br/>2.11.0+cpu"]
    VllmCpu -->|"model loading"| Transformers["transformers<br/>>= 4.56.0"]
    VllmCpu -->|"HTTP server"| FastAPI["FastAPI<br/>>= 0.120.1"]
    VllmCpu -->|"ASGI server"| Uvicorn["Uvicorn"]
    VllmCpu -->|"CPU optimizations<br/>(x86_64 only)"| IPEX["Intel Extension<br/>for PyTorch 2.7.0"]

    %% Native Libraries
    VllmCpu -->|"CPU kernels"| OpenBLAS["OpenBLAS<br/>(ppc64le, s390x)"]
    VllmCpu -->|"threading"| LibOMP["libomp<br/>(OpenMP)"]
    VllmCpu -->|"memory alloc"| TCMalloc["tcmalloc<br/>(LD_PRELOAD)"]

    %% Tokenizers
    VllmCpu -->|"GPT tokenizer"| Tiktoken["tiktoken<br/>>= 0.12.0"]
    VllmCpu -->|"LLaMA tokenizer"| SentencePiece["sentencepiece"]

    %% External Services (Egress)
    VllmCpu -->|"model downloads<br/>HTTPS 443/TCP"| HFHub["HuggingFace Hub"]
    VllmCpu -->|"model weights<br/>filesystem"| ModelStorage["Model Storage<br/>(PVC / S3)"]

    %% Optional
    VllmCpu -.->|"gRPC interface"| GRPC["grpcio<br/>>= 1.76.0"]
    VllmCpu -.->|"Anthropic compat"| Anthropic["anthropic<br/>>= 0.71.0"]
    VllmCpu -.->|"OpenAI compat"| OpenAI["openai<br/>>= 2.0.0"]

    %% Styling
    style VllmCpu fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff

    %% Core Frameworks
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style Transformers fill:#ffcc00,stroke:#333,color:#333
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style Uvicorn fill:#009688,stroke:#333,color:#fff
    style IPEX fill:#0071c5,stroke:#333,color:#fff

    %% Native Libraries
    style OpenBLAS fill:#999,stroke:#333,color:#fff
    style LibOMP fill:#999,stroke:#333,color:#fff
    style TCMalloc fill:#999,stroke:#333,color:#fff

    %% Tokenizers
    style Tiktoken fill:#999,stroke:#333,color:#fff
    style SentencePiece fill:#999,stroke:#333,color:#fff

    %% External Services
    style HFHub fill:#f5a623,stroke:#333,color:#333
    style ModelStorage fill:#f5a623,stroke:#333,color:#333

    %% Optional
    style GRPC fill:#ccc,stroke:#999
    style Anthropic fill:#ccc,stroke:#999
    style OpenAI fill:#ccc,stroke:#999
