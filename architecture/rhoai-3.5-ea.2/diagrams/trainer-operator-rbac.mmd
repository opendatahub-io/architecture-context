    CR_Manager -->|"get"| ClusterVersions
    CR_Manager -->|"get,list"| JobSetOperators
    CR_Manager -->|"list"| OpConditions

    %% Metrics reader
    CR_Metrics -->|"get"| MetricsURL

    %% Aggregate roles (for platform users)
    CR_Admin -->|"* (all verbs)"| TrainerCR
    CR_Editor -->|"create,delete,get,<br/>list,patch,update,watch"| TrainerCR
    CR_Viewer -->|"get,list,watch"| TrainerCR

