    CR_Manager -->|"get,list"| Pods
    CR_Manager -->|"get,list,watch"| LimitRanges
    CR_Manager -->|"full CRUD"| Deployments
    CR_Manager -->|"get,list,watch,<br/>create,update,patch"| CRDs
    CR_Manager -->|"full CRUD"| ValWebhooks
