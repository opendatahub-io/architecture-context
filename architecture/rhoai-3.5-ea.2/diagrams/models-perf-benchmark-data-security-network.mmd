graph TB
    subgraph CITools["CI/DEVELOPER TOOLS (Not shipped)"]
        direction TB
        APIClient["api-client<br/>Python 3.12 CLI<br/>No server port"]
        KafkaProc["kafka-processor<br/>Python 3.12 CLI<br/>No server port"]
        ColdStartScript["cold-start-vram-data<br/>enrichment script"]
    end

    subgraph ExternalSources["EXTERNAL DATA SOURCES"]
        direction TB
        ValAPI["model-validation API<br/>GET /api/v1/*<br/>HTTPS (configurable)"]
        KafkaBroker["Kafka / Redpanda<br/>9092/TCP internal<br/>19092/TCP external<br/>SSL/TLS + SASL (optional)"]
    end

    subgraph BuildPhase["BUILD PHASE (Konflux)"]
        direction TB
        LocalFS["Local Filesystem<br/>data/<br/>JSON + NDJSON<br/>⚠️ CONFIDENTIAL"]
        KonfluxBuild["Konflux Build<br/>Dockerfile.konflux<br/>Base: UBI 9 minimal<br/>User: UID 1001"]
        ContainerRegistry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
    end

    subgraph Runtime["RUNTIME (Production Cluster)"]
        direction TB

        subgraph ModelCatalogDeploy["model-catalog Deployment<br/>Namespace: odh-model-registries"]
            direction TB
            InitContainer["Init Container<br/>odh-model-performance-data<br/>UID 1001 (non-root)<br/>No network ports<br/>No RBAC"]
            SharedVolume["Shared emptyDir Volume"]
            ModelCatalog["model-catalog<br/>Main Container<br/>Reads data at startup"]
        end

        Operator["model-registry-operator<br/>Manages Deployment"]
        OSRegistry["OpenShift Registry<br/>5000/TCP HTTPS<br/>TLS"]
    end

    %% CI/Developer flows
    ValAPI -->|HTTPS<br/>TLS configurable<br/>No auth required| APIClient
    KafkaBroker -->|Kafka Protocol<br/>SSL/TLS optional<br/>SASL optional| KafkaProc

    APIClient -->|File I/O<br/>No encryption| LocalFS
    KafkaProc -->|File I/O<br/>No encryption| LocalFS
    ColdStartScript -->|File I/O<br/>enrichment| LocalFS

    %% Build flows
    LocalFS -->|COPY data/| KonfluxBuild
    KonfluxBuild -->|HTTPS/443<br/>TLS 1.2+<br/>Registry auth| ContainerRegistry

    %% Runtime flows
    OSRegistry -->|HTTPS/5000<br/>TLS<br/>Image pull| InitContainer
    InitContainer -->|File I/O<br/>Copy benchmarks| SharedVolume
    SharedVolume -->|File I/O<br/>Read at startup| ModelCatalog
    Operator -.->|Manages<br/>Deployment spec| ModelCatalogDeploy

    %% Styling
    classDef citools fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef build fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef confidential fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class APIClient,KafkaProc,ColdStartScript citools
    class ValAPI,KafkaBroker external
    class KonfluxBuild,ContainerRegistry build
    class InitContainer,SharedVolume,ModelCatalog runtime
    class LocalFS confidential
    class Operator,OSRegistry operator
