graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["ogx-k8s-operator-<br/>controller-manager"]
        SA_Instance["{instance}-sa<br/>(per OGXServer)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["ogx-k8s-operator-<br/>manager-rolebinding"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(ns: ogx-k8s-operator-system)"]
        RB_Instance["{instance}-rb<br/>(per OGXServer namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/>(ns: ogx-k8s-operator-system)"]
    end

    subgraph OGXResources["OGX API Resources"]
        OGXServers["ogx.io<br/>OGXServers<br/>get, list, watch,<br/>create, update, patch, delete"]
        OGXStatus["ogx.io<br/>OGXServers/status<br/>get, patch, update"]
        OGXFinalizers["ogx.io<br/>OGXServers/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Resources"]
        Services["core<br/>Services<br/>get, list, watch,<br/>create, update, patch, delete"]
        ServiceAccts["core<br/>ServiceAccounts<br/>get, list, watch,<br/>create, update, patch, delete"]
        ConfigMaps["core<br/>ConfigMaps<br/>get, list, watch,<br/>create, update, patch"]
        PVCs["core<br/>PersistentVolumeClaims<br/>get, list, watch,<br/>create, update, patch"]
        Secrets["core<br/>Secrets<br/>get, list, watch"]
        Pods["core<br/>Pods<br/>list"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>Deployments<br/>get, list, watch,<br/>create, update, patch, delete"]
        ReplicaSets["apps<br/>ReplicaSets<br/>get, list, watch"]
    end

    subgraph NetworkResources["Networking API Resources"]
        Ingresses["networking.k8s.io<br/>Ingresses<br/>get, list, watch,<br/>create, update, patch, delete"]
        NetPolicies["networking.k8s.io<br/>NetworkPolicies<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph PolicyResources["Policy / Autoscaling Resources"]
        PDBs["policy<br/>PodDisruptionBudgets<br/>get, list, watch,<br/>create, update, patch, delete"]
        HPAs["autoscaling<br/>HorizontalPodAutoscalers<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors<br/>get, list, watch,<br/>create, update, patch, delete"]
        PrometheusRules["monitoring.coreos.com<br/>PrometheusRules<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph RBACResources["RBAC API Resources"]
        CRDs["apiextensions.k8s.io<br/>CustomResourceDefinitions<br/>get, list, watch"]
        ClusterRoleBindingsRes["rbac.authorization.k8s.io<br/>ClusterRoleBindings<br/>get, list, delete"]
        ClusterRolesRes["rbac.authorization.k8s.io<br/>ClusterRoles<br/>get, list, watch"]
        RoleBindingsRes["rbac.authorization.k8s.io<br/>RoleBindings<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        SCCs["security.openshift.io<br/>SecurityContextConstraints<br/>use"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager

    SA_Operator -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| R_Leader

    %% Instance SA bindings (OpenShift only)
    SA_Instance -->|"bound via<br/>(OpenShift only)"| RB_Instance
    RB_Instance -->|"grants"| CR_SCC

    %% manager-role permissions
    CR_Manager -->|"manages"| OGXServers
    CR_Manager -->|"manages"| OGXStatus
    CR_Manager -->|"manages"| OGXFinalizers
    CR_Manager -->|"manages"| Deployments
    CR_Manager -->|"reads"| ReplicaSets
    CR_Manager -->|"manages"| Services
    CR_Manager -->|"manages"| ServiceAccts
    CR_Manager -->|"manages"| ConfigMaps
    CR_Manager -->|"manages"| PVCs
    CR_Manager -->|"reads"| Secrets
    CR_Manager -->|"reads"| Pods
    CR_Manager -->|"manages"| Ingresses
    CR_Manager -->|"manages"| NetPolicies
    CR_Manager -->|"manages"| PDBs
    CR_Manager -->|"manages"| HPAs
    CR_Manager -->|"manages"| ServiceMonitors
    CR_Manager -->|"manages"| PrometheusRules
    CR_Manager -->|"reads"| CRDs
    CR_Manager -->|"manages"| ClusterRoleBindingsRes
    CR_Manager -->|"reads"| ClusterRolesRes
    CR_Manager -->|"manages"| RoleBindingsRes
    CR_Manager -->|"uses"| SCCs

