graph TB
    subgraph TrainerOp["Trainer Operator"]
        direction TB
        Controller["trainer-operator<br/>(Go Operator, controller-runtime)"]
        Controller -->|renders manifests| Kustomize["Kustomize Renderer<br/>(odh-platform-utilities)"]
        Controller -->|checks| DepCheck["Dependency Checker<br/>(JobSet CRD, OLM, OpenShift)"]
        Controller -->|manages| GC["Garbage Collector<br/>(labeled resource cleanup)"]
    end

    subgraph ManagedResources["Managed Resources"]
        direction TB
        TrainerCtrl["Kubeflow Trainer Controller<br/>(Upstream Deployment)"]
        Runtimes["ClusterTrainingRuntimes<br/>(15 variants: CUDA/ROCm/CPU)"]
        ImageStreams["Training Hub ImageStreams<br/>(OpenShift only, 3 accelerator variants)"]
        Webhooks["ValidatingWebhookConfigurations"]
        NetPolicies["NetworkPolicies"]
        PodMons["PodMonitors"]
    end

    %% CR Input
    PlatformOp["rhods-operator<br/>(Platform Operator)"] -->|creates| TrainerCR["Trainer CR<br/>(default-trainer)<br/>ManagementState: Managed/Removed"]
    TrainerCR -->|watched by| Controller

    %% Operator deploys managed resources
    Controller -->|server-side apply| TrainerCtrl
    Controller -->|creates/updates| Runtimes
    Controller -->|creates/updates<br/>OpenShift only| ImageStreams
    Controller -->|manages| Webhooks
    Controller -->|manages| NetPolicies
    Controller -->|manages| PodMons

    %% Downstream watch for drift correction
    TrainerCtrl -.->|drift watch<br/>label: platform.opendatahub.io/part-of=trainer| Controller

    %% User interaction with managed controller
    User["Data Scientist"] -->|creates| TrainJob["TrainJob CR"]
    TrainJob -->|reconciled by| TrainerCtrl
    TrainerCtrl -->|creates| JobSet["JobSet<br/>(distributed training workload)"]

    %% External dependencies
    Controller -->|dependency check| JobSetOp["JobSet Operator<br/>(CRD + CR)"]
    Controller -->|API calls| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Metrics
    Prometheus["Prometheus"] -->|scrapes /metrics<br/>8080/TCP HTTP| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Kustomize fill:#4a90e2,stroke:#333,color:#fff
    style DepCheck fill:#4a90e2,stroke:#333,color:#fff
    style GC fill:#4a90e2,stroke:#333,color:#fff
    style TrainerCtrl fill:#7ed321,stroke:#333
    style Runtimes fill:#7ed321,stroke:#333
    style ImageStreams fill:#7ed321,stroke:#333
    style Webhooks fill:#7ed321,stroke:#333
    style NetPolicies fill:#7ed321,stroke:#333
    style PodMons fill:#7ed321,stroke:#333
    style TrainerCR fill:#f5a623,stroke:#333
    style TrainJob fill:#f5a623,stroke:#333
    style JobSet fill:#f5a623,stroke:#333
    style PlatformOp fill:#e8e8e8,stroke:#333
    style JobSetOp fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style User fill:#d4e6f1,stroke:#333
