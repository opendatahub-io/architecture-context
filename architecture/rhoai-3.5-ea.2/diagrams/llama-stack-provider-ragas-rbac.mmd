graph TD
    subgraph "Llama Stack Server Pod"
        SA["Pod ServiceAccount<br/>{llama-stack-sa}"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        SAToken["ServiceAccount Token<br/>(in-cluster)"]
        Kubeconfig["kubeconfig Credentials<br/>(external)"]
        BearerToken["Bearer Token<br/>(OpenShift OAuth)"]
        AWSCreds["AWS IAM Credentials<br/>(Secret: aws-credentials)"]
    end

    subgraph "Secrets (Manually Provisioned)"
        direction TB
        KFPTokenSecret["kubeflow-pipelines-token<br/>Type: Opaque<br/>Auto-Rotate: No<br/>NOTE: No refresh mechanism"]
        AWSSecret["aws-credentials<br/>Type: Opaque<br/>Keys: ACCESS_KEY_ID,<br/>SECRET_ACCESS_KEY,<br/>DEFAULT_REGION<br/>Auto-Rotate: No"]
        InferenceSecret["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Keys: URL, API_TOKEN,<br/>TLS_VERIFY, MODEL_NAME<br/>Auto-Rotate: No"]
    end

    subgraph "Target Resources"
        direction TB
        K8sConfigMap["Kubernetes API<br/>ConfigMap: trustyai-service-operator-config<br/>Namespaces: redhat-ods-applications,<br/>opendatahub<br/>Verbs: get"]
        KFPAPI["Kubeflow Pipelines API<br/>Actions: create_run,<br/>get_run, terminate_run<br/>Port: 443/TCP HTTPS"]
        S3Bucket["S3 Storage<br/>Actions: PUT (write JSONL),<br/>GET (read results)<br/>Port: 443/TCP HTTPS"]
        LlamaStackEval["Llama Stack Eval API<br/>Port: 8321/TCP HTTP<br/>Auth: None<br/>(platform-level only)"]
    end

    %% SA to auth mechanisms
    SA -->|"in-cluster token"| SAToken
    SA -->|"loads from env or file"| Kubeconfig

    %% Auth to secrets
    KFPTokenSecret -->|"provides"| BearerToken
    AWSSecret -->|"provides"| AWSCreds

    %% Auth to targets
    SAToken -->|"HTTPS/443<br/>TLS 1.2+"| K8sConfigMap
    Kubeconfig -->|"extracts api_key<br/>authorization header"| BearerToken
    BearerToken -->|"HTTPS/443<br/>TLS 1.2+"| KFPAPI
    AWSCreds -->|"HTTPS/443<br/>TLS 1.2+"| S3Bucket

    %% Inference secret
    InferenceSecret -->|"configures vLLM<br/>backend connection"| LlamaStackEval

    %% No RBAC note
    NoRBAC["No ClusterRoles or RoleBindings<br/>defined by this component.<br/>Uses pod SA for K8s API access."]

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style KFPTokenSecret fill:#f8cecc,stroke:#b85450
    style AWSSecret fill:#f8cecc,stroke:#b85450
    style InferenceSecret fill:#f8cecc,stroke:#b85450
    style SAToken fill:#f5a623,stroke:#333
    style Kubeconfig fill:#f5a623,stroke:#333
    style BearerToken fill:#f5a623,stroke:#333
    style AWSCreds fill:#f5a623,stroke:#333
    style K8sConfigMap fill:#7ed321,stroke:#333
    style KFPAPI fill:#7ed321,stroke:#333
    style S3Bucket fill:#7ed321,stroke:#333
    style LlamaStackEval fill:#7ed321,stroke:#333
    style NoRBAC fill:#fff2cc,stroke:#d6b656,stroke-dasharray: 5 5
