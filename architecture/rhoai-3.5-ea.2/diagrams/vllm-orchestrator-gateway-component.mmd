graph TB
    subgraph "vllm-orchestrator-gateway (Rust/Axum)"
        direction TB
        ConfigLoader["Config Loader<br/>(config.rs)<br/>YAML parsing + validation"]
        Router["Axum Router<br/>(main.rs)<br/>Dynamic route registration"]
        ChatHandler["Chat Completion Handler<br/>(api.rs)<br/>Request transformation"]
        StreamHandler["SSE Stream Handler<br/>(main.rs)<br/>Streaming proxy + detection"]
        TLSBuilder["TLS Client Builder<br/>(main.rs)<br/>mTLS / PKCS#12 setup"]
        HeaderForwarder["Header Forwarder<br/>(main.rs)<br/>Authorization + x-forwarded-*"]

        ConfigLoader -->|"registers routes"| Router
        Router -->|"POST /{route}/v1/chat/completions"| ChatHandler
        ChatHandler -->|"stream=false"| NonStream["Non-Streaming Response"]
        ChatHandler -->|"stream=true"| StreamHandler
        TLSBuilder -->|"reqwest client"| ChatHandler
        HeaderForwarder -->|"selective pass-through"| ChatHandler
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST 8090/TCP<br/>Authorization header"| Router

    subgraph "Configuration (mounted)"
        ConfigFile["config.yaml<br/>(ConfigMap mount)<br/>GATEWAY_CONFIG env"]
        TLSCert["TLS Client Cert<br/>/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt"]
    end

    ConfigFile -->|"startup read"| ConfigLoader
    TLSCert -->|"optional mTLS"| TLSBuilder
    CACert -->|"CA verification"| TLSBuilder

    subgraph "Upstream Services"
        Orchestrator["FMS Guardrails Orchestrator<br/>POST /api/v2/chat/completions-detection<br/>8085/TCP"]
        Detectors["Guardrails Detectors<br/>(e.g., regex-language)<br/>via orchestrator"]
        LLM["vLLM / LLM Inference<br/>via orchestrator"]
    end

    ChatHandler -->|"HTTP/HTTPS<br/>optional mTLS<br/>injected detectors"| Orchestrator
    StreamHandler -->|"HTTP/HTTPS SSE<br/>optional mTLS"| Orchestrator
    Orchestrator -->|"detection pipeline"| Detectors
    Orchestrator -->|"inference request"| LLM

    subgraph "Fallback Logic"
        FallbackCheck{"Detection<br/>found?"}
        FallbackMsg["Replace response with<br/>configured fallback_message"]
        PassThrough["Return orchestrator<br/>response as-is"]
    end

    NonStream --> FallbackCheck
    StreamHandler --> FallbackCheck
    FallbackCheck -->|"Yes + fallback configured"| FallbackMsg
    FallbackCheck -->|"No"| PassThrough

    style ConfigLoader fill:#4a90e2,color:#fff
    style Router fill:#4a90e2,color:#fff
    style ChatHandler fill:#4a90e2,color:#fff
    style StreamHandler fill:#4a90e2,color:#fff
    style TLSBuilder fill:#4a90e2,color:#fff
    style HeaderForwarder fill:#4a90e2,color:#fff
    style Orchestrator fill:#7ed321,color:#fff
    style Detectors fill:#7ed321,color:#fff
    style LLM fill:#7ed321,color:#fff
    style Client fill:#f5a623,color:#fff
    style ConfigFile fill:#e8e8e8,stroke:#999
    style TLSCert fill:#e8e8e8,stroke:#999
    style CACert fill:#e8e8e8,stroke:#999
    style FallbackMsg fill:#d0021b,color:#fff
    style PassThrough fill:#50e3c2,color:#fff
