graph TB
    subgraph Pod["Application Pod"]
        direction TB

        subgraph Sidecar["kube-rbac-proxy Sidecar"]
            TLSTermination["TLS Termination<br/>8443/TCP<br/>TLS 1.2+"]
            AuthNFilter["Authentication Filter"]
            TokenReviewAuth["TokenReview<br/>Authenticator"]
            OIDCAuth["OIDC JWT<br/>Authenticator"]
            X509Auth["X.509 Client Cert<br/>Authenticator"]
            AuthZChain["Authorization Chain"]
            HardcodedAuthZ["Hardcoded Metrics<br/>Authorizer"]
            StaticAuthZ["Static Rules<br/>Authorizer"]
            SARAuthZ["SubjectAccessReview<br/>Authorizer"]
            PathFilter["Path Filter<br/>(allow-paths / ignore-paths)"]
            ReverseProxy["Reverse Proxy<br/>Handler"]
            CertReloader["CertReloader<br/>(hot-reload, 1min poll)"]
            SanitizingFilter["Log Sanitization<br/>Filter"]
        end

        subgraph App["Upstream Application Container"]
            AppEndpoint["Application<br/>127.0.0.1:8081/TCP<br/>HTTP"]
        end
    end

    Client["External Client<br/>(Bearer Token / OIDC / X.509)"] -->|"HTTPS/8443<br/>TLS 1.2+"| TLSTermination
    TLSTermination --> PathFilter
    PathFilter --> AuthNFilter
    AuthNFilter --> TokenReviewAuth
    AuthNFilter --> OIDCAuth
    AuthNFilter --> X509Auth
    TokenReviewAuth -->|"authenticated"| AuthZChain
    OIDCAuth -->|"authenticated"| AuthZChain
    X509Auth -->|"authenticated"| AuthZChain
    AuthZChain --> HardcodedAuthZ
    HardcodedAuthZ -->|"not matched"| StaticAuthZ
    StaticAuthZ -->|"not matched"| SARAuthZ
    HardcodedAuthZ -->|"Allow"| ReverseProxy
    StaticAuthZ -->|"Allow"| ReverseProxy
    SARAuthZ -->|"Allow"| ReverseProxy
    ReverseProxy -->|"HTTP/8081<br/>localhost"| AppEndpoint

    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"] -.->|"TokenReview<br/>response"| TokenReviewAuth
    TokenReviewAuth -.->|"TokenReview<br/>request"| K8sAPI
    SARAuthZ -.->|"SubjectAccessReview<br/>request"| K8sAPI
    K8sAPI -.->|"SAR response"| SARAuthZ
    OIDCIssuer["OIDC Issuer<br/>443/TCP HTTPS"] -.->|"JWKS / Discovery"| OIDCAuth
    CertReloader -.->|"watches"| TLSCert["TLS Cert/Key Files"]

    Prometheus["prometheus-k8s<br/>(openshift-monitoring)"] -->|"HTTPS/8443<br/>GET /metrics"| TLSTermination

    style TLSTermination fill:#4a90e2,color:#fff
    style AuthNFilter fill:#4a90e2,color:#fff
    style AuthZChain fill:#4a90e2,color:#fff
    style ReverseProxy fill:#4a90e2,color:#fff
    style HardcodedAuthZ fill:#f5a623,color:#fff
    style SARAuthZ fill:#f5a623,color:#fff
    style StaticAuthZ fill:#f5a623,color:#fff
    style TokenReviewAuth fill:#7ed321,color:#fff
    style OIDCAuth fill:#7ed321,color:#fff
    style X509Auth fill:#7ed321,color:#fff
    style AppEndpoint fill:#9b59b6,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OIDCIssuer fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e74c3c,color:#fff
    style CertReloader fill:#95a5a6,color:#fff
    style SanitizingFilter fill:#95a5a6,color:#fff
    style PathFilter fill:#4a90e2,color:#fff
