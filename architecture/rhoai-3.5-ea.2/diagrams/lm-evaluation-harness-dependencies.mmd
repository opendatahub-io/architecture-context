graph LR
    LMEval["LM Evaluation Harness<br/>(Batch Job)"]

    %% Internal RHOAI Platform Dependencies
    LMEval -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    LMEval -->|"inference requests<br/>HTTPS/443"| ModelEndpoint["Model Inference<br/>Endpoint"]
    LMEval -->|"experiment logging<br/>HTTPS/443"| MLflow["MLflow Tracking<br/>Server"]

    %% Deploying Operator
    TrustyAI["TrustyAI<br/>lm-eval-controller"] -->|"creates Job"| LMEval

    %% External Service Dependencies
    LMEval -->|"OCI artifact push<br/>HTTPS/443"| OCIRegistry["OCI Registry"]
    LMEval -->|"datasets, tokenizers<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LMEval -->|"model/dataset files<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]

    %% Kubernetes Dependencies
    LMEval -->|"job spec<br/>volume mount"| ConfigMap["Kubernetes<br/>ConfigMap"]
    LMEval -->|"credentials<br/>volume mount"| Secret["Kubernetes<br/>Secret"]

    %% Key Python Library Dependencies
    subgraph PythonDeps["Core Python Dependencies"]
        direction TB
        EvalHubSDK["eval-hub-sdk 0.1.7<br/>(EvalHub adapter)"]
        PyTorch["torch 2.6.0<br/>(tensor ops)"]
        Transformers["transformers 4.48.0<br/>(tokenizers)"]
        Datasets["datasets 3.1.0<br/>(benchmark data)"]
        Accelerate["accelerate 1.0.1<br/>(distributed)"]
        Unitxt["unitxt 1.17.2<br/>(custom tasks)"]
        PEFT["peft 0.13.2<br/>(LoRA adapters)"]
        Boto3["boto3 1.42.12<br/>(S3 access)"]
        OLOT["olot 0.1.15<br/>(OCI artifacts)"]
        Sklearn["scikit-learn 1.5.2<br/>(ML metrics)"]
    end

    LMEval -->|"uses"| PythonDeps

    %% System Dependencies
    LMEval -->|"OCI push tool"| Skopeo["skopeo<br/>(system binary)"]

    %% Optional Dependencies
    LMEval -.->|"optional"| WatsonX["ibm-watsonx-ai 1.4.11<br/>(watsonx backend)"]

    %% Styling
    style LMEval fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style ModelEndpoint fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style ConfigMap fill:#e1d5e7,stroke:#9673a6
    style Secret fill:#e1d5e7,stroke:#9673a6
    style Skopeo fill:#999,stroke:#333,color:#fff
    style WatsonX fill:#999,stroke:#333,color:#fff
    style EvalHubSDK fill:#dae8fc,stroke:#6c8ebf
    style PyTorch fill:#dae8fc,stroke:#6c8ebf
    style Transformers fill:#dae8fc,stroke:#6c8ebf
    style Datasets fill:#dae8fc,stroke:#6c8ebf
