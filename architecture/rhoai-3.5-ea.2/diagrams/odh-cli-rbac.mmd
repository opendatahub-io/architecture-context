graph TD
    subgraph AuthModel["Authentication Model"]
        direction TB
        Kubeconfig["KUBECONFIG<br/>(User-provided)"]
        AuthMethods["Auth Methods:<br/>Bearer Token<br/>Client Certificate<br/>OIDC"]
        Kubeconfig --> AuthMethods
    end

    subgraph PreCheck["RBAC Pre-Check (Runtime)"]
        direction TB
        SSAR["SelfSubjectAccessReview<br/>(pkg/util/kube/rbac/check.go)"]
        GracefulDegrade["Graceful Degradation<br/>Reports missing permissions<br/>instead of opaque RBAC errors"]
        SSAR --> GracefulDegrade
    end

    subgraph LintPermissions["Lint Command Permissions (Read-Only)"]
        direction TB
        LintDSC["DSC / DSCI / Component CRs<br/>Verbs: get, list"]
        LintISVC["InferenceServices<br/>Verbs: get, list"]
        LintNotebooks["Notebooks<br/>Verbs: get, list"]
        LintDSPA["DSPAs<br/>Verbs: get, list"]
        LintKueue["ClusterQueues / LocalQueues<br/>Verbs: get, list"]
        LintOLM["OLM Subscriptions / CSVs<br/>Verbs: get, list"]
        LintOSVersion["ClusterVersion<br/>Verbs: get"]
        LintRay["RayClusters<br/>Verbs: get, list"]
        LintGuardrails["GuardrailsOrchestrator<br/>Verbs: get, list"]
        LintLlama["LlamaStackDistribution<br/>Verbs: get, list"]
        LintTraining["Training Jobs (v1)<br/>Verbs: get, list"]
    end

    subgraph MigratePermissions["Migrate Command Permissions (Read + Write)"]
        direction TB
        MigISVC["InferenceServices<br/>Verbs: get, list, patch"]
        MigSR["ServingRuntimes<br/>Verbs: get, list, patch"]
        MigNotebook["Notebooks<br/>Verbs: get, list, patch"]
        MigRay["RayClusters<br/>Verbs: get, list, create, delete"]
        MigDSPA["DSPAs<br/>Verbs: get, list, patch"]
        MigDSC["DataScienceCluster<br/>Verbs: get, patch"]
        MigCM["ConfigMaps<br/>Verbs: get, patch"]
        MigDeploy["Deployments<br/>Verbs: get, patch"]
        MigGuardrails["GuardrailsOrchestrator<br/>Verbs: get, list, patch"]
        MigSecrets["Secrets<br/>Verbs: get, list (read-only for backup)"]
    end

    subgraph DepsPermissions["Deps Install Permissions"]
        direction TB
        DepsSubscription["Subscriptions<br/>Verbs: get, list, create"]
        DepsCSV["ClusterServiceVersions<br/>Verbs: get, list, watch"]
        DepsOG["OperatorGroups<br/>Verbs: get, list, create"]
    end

    subgraph TrustyAIPerms["TrustyAI REST API Permissions"]
        direction TB
        TrustyAIRouteAccess["TrustyAI Service Route<br/>Methods: GET, POST<br/>Auth: Bearer Token via Route"]
    end

    AuthMethods -->|"authenticates"| SSAR
    SSAR -->|"checks before"| LintPermissions
    SSAR -->|"checks before"| MigratePermissions
    SSAR -->|"checks before"| DepsPermissions

    %% Note: No ClusterRoles installed
    Note["NOTE: odh-cli does NOT install<br/>ClusterRoles or RoleBindings.<br/>It uses the authenticated user's<br/>existing RBAC permissions."]

    style Kubeconfig fill:#4a90e2,stroke:#333,color:#fff
    style AuthMethods fill:#4a90e2,stroke:#333,color:#fff
    style SSAR fill:#f5a623,stroke:#333
    style GracefulDegrade fill:#f5a623,stroke:#333
    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    style LintDSC fill:#d5e8d4,stroke:#82b366
