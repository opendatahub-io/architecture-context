graph TB
    subgraph AutoGluonServer["KServe AutoGluon Server"]
        direction TB
        Main["__main__.py<br/>Entrypoint"]
        DetectedModel["AutoGluonDetectedModel<br/>Facade / Auto-Detector"]
        TabularModel["AutoGluonTabularModel<br/>TabularPredictor (v1+v2)"]
        TimeSeriesModel["AutoGluonTimeSeriesModel<br/>TimeSeriesPredictor (v1 only)"]
        VersionCompat["version_compat.py<br/>Version Compatibility"]
        RuntimePaths["runtime_paths.py<br/>Container Path Handling"]
        ModelRepo["AutoGluonModelRepository<br/>Model Repository"]

        Main -->|creates| DetectedModel
        DetectedModel -->|auto-detects &<br/>delegates to| TabularModel
        DetectedModel -->|auto-detects &<br/>delegates to| TimeSeriesModel
        DetectedModel -->|validates| VersionCompat
        DetectedModel -->|ensures paths| RuntimePaths
        Main -->|registers with| ModelRepo
    end

    subgraph KServeSDK["KServe SDK (vendored 0.19.0)"]
        ModelServer["ModelServer<br/>HTTP/gRPC Server"]
        ModelInterface["kserve.Model<br/>Base Interface"]
        ProtocolHandler["Protocol Handler<br/>v1/v2 REST + gRPC"]
    end

    subgraph KServeStorage["KServe Storage (vendored 0.19.0)"]
        StorageModule["Storage Module<br/>Model Download"]
    end

    %% Internal connections
    DetectedModel -->|implements| ModelInterface
    Main -->|starts| ModelServer
    ModelServer -->|routes requests via| ProtocolHandler

    %% External interactions
    User[Data Scientist] -->|creates| ISVC["InferenceService CR<br/>modelFormat: autogluon"]
    KServeCtrl["KServe Controller"] -->|watches| ISVC
    KServeCtrl -->|creates pod running| AutoGluonServer

    %% Inference flow
    Client[Inference Client] -->|POST /v1/models/m:predict<br/>POST /v2/models/m/infer| ModelServer
    ModelServer -->|delegates| DetectedModel

    %% Storage flow
    StorageModule -->|downloads from| ObjectStorage["Object Storage<br/>S3 / GCS / Azure / HF"]

    %% Service mesh
    Istio["Istio Sidecar"] -.->|mTLS enforcement| AutoGluonServer
    Prometheus["Prometheus"] -->|scrapes :8080/metrics| ModelServer

    %% Styling
    style AutoGluonServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style KServeSDK fill:#6c5ce7,stroke:#333,stroke-width:2px,color:#fff
    style KServeStorage fill:#6c5ce7,stroke:#333,stroke-width:2px,color:#fff
