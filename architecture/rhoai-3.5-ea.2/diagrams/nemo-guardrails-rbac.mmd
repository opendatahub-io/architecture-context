graph TD
    subgraph Notice["RBAC Notice"]
        direction TB
        Info["ℹ️ NeMo Guardrails is NOT a Kubernetes operator<br/>No ClusterRoles, Roles, or RoleBindings defined"]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph NoBuiltInAuth["No Built-In Authentication"]
            Endpoint1["/v1/chat/completions<br/>POST"]
            Endpoint2["/v1/guardrail/checks<br/>POST"]
            Endpoint3["/v1/rails/configs<br/>GET"]
            Endpoint4["/v1/models<br/>GET"]
            Endpoint5["/v1/challenges<br/>GET"]
            HealthCheck["/<br/>GET (health)"]
        end

        subgraph HeaderForwarding["Header Forwarding (Passthrough)"]
            FwdHeaders["Client auth headers forwarded<br/>to upstream LLM provider"]
        end

        subgraph ExternalAuth["External Auth Enforcement (Recommended)"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x pattern)"]
            Istio["Istio AuthorizationPolicy<br/>(Service Mesh)"]
            NetworkPolicy["Kubernetes NetworkPolicy<br/>(namespace isolation)"]
        end
    end

    subgraph Secrets["Sensitive Environment Variables"]
        direction TB
        Secret1["OPENAI_API_KEY<br/>OpenAI auth<br/>Manual, no rotation"]
        Secret2["AZURE_OPENAI_API_KEY<br/>Azure OpenAI auth<br/>Manual, no rotation"]
        Secret3["ANTHROPIC_API_KEY<br/>Anthropic auth<br/>Manual, no rotation"]
        Secret4["COHERE_API_KEY<br/>Cohere auth<br/>Manual, no rotation"]
        Secret5["AI_DEFENSE_API_KEY<br/>Cisco AI Defense auth<br/>Manual, no rotation"]
        Secret6["MAIN_MODEL_BASE_URL<br/>May contain auth tokens<br/>Manual, no rotation"]
    end

    Endpoint1 -->|"headers passthrough"| FwdHeaders
    Endpoint4 -->|"Authorization header"| FwdHeaders

    ExternalAuth -->|"protects"| NoBuiltInAuth

    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Endpoint1 fill:#4a90e2,stroke:#333,color:#fff
    style Endpoint2 fill:#4a90e2,stroke:#333,color:#fff
    style Endpoint3 fill:#4a90e2,stroke:#333,color:#fff
    style Endpoint4 fill:#4a90e2,stroke:#333,color:#fff
    style Endpoint5 fill:#4a90e2,stroke:#333,color:#fff
    style HealthCheck fill:#4a90e2,stroke:#333,color:#fff
    style FwdHeaders fill:#f5a623,stroke:#333
    style KubeRBACProxy fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style NetworkPolicy fill:#7ed321,stroke:#333
    style Secret1 fill:#e74c3c,stroke:#333,color:#fff
    style Secret2 fill:#e74c3c,stroke:#333,color:#fff
    style Secret3 fill:#e74c3c,stroke:#333,color:#fff
    style Secret4 fill:#e74c3c,stroke:#333,color:#fff
    style Secret5 fill:#e74c3c,stroke:#333,color:#fff
    style Secret6 fill:#e74c3c,stroke:#333,color:#fff
