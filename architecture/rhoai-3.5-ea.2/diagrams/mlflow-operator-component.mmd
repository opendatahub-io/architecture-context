graph TB
    subgraph "MLflow Operator Component"
        direction TB
        Operator["mlflow-operator<br/>(Go, controller-runtime)<br/>Port: 8081/TCP health, 8443/TCP metrics"]
        HelmEngine["Helm Chart Engine<br/>(in-process rendering)"]
        Operator -->|renders chart| HelmEngine
    end

    subgraph "Managed MLflow Stack"
        direction TB
        MLflowServer["MLflow Server<br/>(Python Application)<br/>Port: 8443/TCP HTTPS"]
        MigrationJob["Migration Job<br/>(mlflow db upgrade)<br/>On version change"]
        GCCronJob["GC CronJob<br/>(garbage collection)<br/>Periodic cleanup"]
    end

    subgraph "Custom Resources"
        MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
        MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespaced"]
    end

    subgraph "Managed Kubernetes Resources"
        Deployment["Deployment<br/>(MLflow server pods)"]
        Service["Service (ClusterIP)<br/>mlflow:8443"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
        NetworkPolicy["NetworkPolicy<br/>(ingress + egress rules)"]
        ConsoleLink["ConsoleLink<br/>(OpenShift console menu)"]
        ServiceMonitor["ServiceMonitor<br/>(Prometheus scraping)"]
        PVC["PVC<br/>(optional, SQLite/file storage)"]
        RBAC["ClusterRoles & Bindings<br/>(mlflow, mlflow-gc, aggregates)"]
    end

    %% CR Watches
    MLflowCR -->|watched by| Operator
    MLflowConfigCR -->|watched by| Operator

    %% Operator creates resources via Helm rendering
    HelmEngine -->|Server-Side Apply| Deployment
    HelmEngine -->|Server-Side Apply| Service
    HelmEngine -->|Server-Side Apply| HTTPRoute
    HelmEngine -->|Server-Side Apply| NetworkPolicy
    HelmEngine -->|Server-Side Apply| ConsoleLink
    HelmEngine -->|Server-Side Apply| ServiceMonitor
    HelmEngine -->|Server-Side Apply| PVC
    HelmEngine -->|Server-Side Apply| RBAC

    %% Operator manages lifecycle
    Operator -->|orchestrates| MigrationJob
    Operator -->|creates| GCCronJob

    %% Deployment runs MLflow
    Deployment -->|runs| MLflowServer

    %% External dependencies
    MLflowServer -->|auth via SSAR| K8sAPI["Kubernetes API Server"]
    MLflowServer -->|metadata store| Database["PostgreSQL / MySQL"]
    MLflowServer -->|artifact storage| S3["S3-compatible Storage"]
    Operator -->|CRUD, watch, SSA| K8sAPI

    %% Platform integrations
    HTTPRoute -->|parent ref| Gateway["data-science-gateway<br/>(Gateway API)"]
    Service -->|cert provisioning| ServiceCA["OpenShift service-ca"]
    MLflowServer -->|CA bundle| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style HelmEngine fill:#4a90e2,stroke:#333,color:#fff
    style MLflowServer fill:#50c878,stroke:#333,stroke-width:2px,color:#fff
    style MigrationJob fill:#50c878,stroke:#333,color:#fff
    style GCCronJob fill:#50c878,stroke:#333,color:#fff
    style MLflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style Deployment fill:#b8d4e3,stroke:#333
    style Service fill:#b8d4e3,stroke:#333
    style HTTPRoute fill:#b8d4e3,stroke:#333
    style NetworkPolicy fill:#b8d4e3,stroke:#333
    style ConsoleLink fill:#b8d4e3,stroke:#333
    style ServiceMonitor fill:#b8d4e3,stroke:#333
    style PVC fill:#b8d4e3,stroke:#333
    style RBAC fill:#b8d4e3,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Database fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style CABundle fill:#e8e8e8,stroke:#333
