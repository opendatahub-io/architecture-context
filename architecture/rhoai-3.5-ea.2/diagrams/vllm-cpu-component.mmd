graph TB
    subgraph "vllm-cpu Inference Server"
        direction TB

        subgraph "HTTP API Layer (FastAPI + Uvicorn)"
            APIServer["API Server<br/>Port 8000/TCP"]
            AuthMW["Auth Middleware<br/>(optional API key)"]
            APIServer --> AuthMW
        end

        subgraph "OpenAI-Compatible Endpoints"
            ChatCompletions["/v1/chat/completions"]
            Completions["/v1/completions"]
            Embeddings["/v1/embeddings"]
            Models["/v1/models"]
            Responses["/v1/responses"]
            AudioTranscriptions["/v1/audio/transcriptions"]
            Score["/v1/score"]
            Tokenize["/v1/tokenize"]
            Detokenize["/v1/detokenize"]
        end

        subgraph "Operational Endpoints"
            Health["/health"]
            Metrics["/metrics"]
            Version["/version"]
            Load["/load"]
            ServerInfo["/server_info"]
            LoRALoad["/v1/load_lora_adapter"]
            LoRAUnload["/v1/unload_lora_adapter"]
        end

        subgraph "Inference Engine"
            VLLMEngine["vLLM Engine (v1)<br/>CPU Backend"]
            CPUKernels["C++ CPU Kernels<br/>(CMake Extensions)"]
            VLLMEngine --> CPUKernels
        end

        subgraph "gRPC Interface (Optional)"
            GRPCServer["gRPC Server<br/>Port 50051/TCP"]
            GRPCHealth["grpc.health.v1.Health"]
            GRPCServer --> GRPCHealth
        end

        AuthMW --> ChatCompletions
        AuthMW --> Completions
        AuthMW --> Embeddings
        AuthMW --> Models
        AuthMW --> Responses
        AuthMW --> AudioTranscriptions
        AuthMW --> Score
        AuthMW --> Tokenize
        AuthMW --> Detokenize

        ChatCompletions --> VLLMEngine
        Completions --> VLLMEngine
        Embeddings --> VLLMEngine
        Responses --> VLLMEngine
        AudioTranscriptions --> VLLMEngine
        Score --> VLLMEngine
        Tokenize --> VLLMEngine
        Detokenize --> VLLMEngine

        GRPCServer --> VLLMEngine
    end

    %% External Consumers
    Client["Client / KServe Gateway"]
    Prometheus["Prometheus Scraper"]

    %% External Services
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    ModelStorage["Model Storage<br/>(PVC / S3)"]

    %% Runtime Platform
    KServe["KServe / ModelMesh<br/>ServingRuntime"]

    %% Connections
    Client -->|"HTTP 8000/TCP<br/>API key (optional)"| APIServer
    Client -->|"gRPC 50051/TCP"| GRPCServer
    Prometheus -->|"HTTP 8000/TCP<br/>scrape /metrics"| Metrics

    VLLMEngine -->|"Read model weights"| ModelStorage
    VLLMEngine -->|"HTTPS 443/TCP<br/>HF_TOKEN Bearer"| HFHub

    KServe -.->|"Manages container<br/>lifecycle"| APIServer

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style CPUKernels fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AuthMW fill:#e8a838,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
    style HFHub fill:#f5a623,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Health fill:#82b366,stroke:#333
    style Metrics fill:#82b366,stroke:#333
