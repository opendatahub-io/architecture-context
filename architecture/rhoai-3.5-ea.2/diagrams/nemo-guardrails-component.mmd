graph TB
    subgraph NemoGuardrails["NeMo Guardrails Server"]
        direction TB
        API["FastAPI Server<br/>Port 8000/TCP"]
        ColangRuntime["Colang Runtime<br/>(v1.0 + v2.x)"]

        subgraph GuardrailLibrary["Guardrail Library"]
            InputRails["Input Rails"]
            OutputRails["Output Rails"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            InjectionDetect["Injection Detection<br/>(YARA)"]
            SensitiveData["Sensitive Data Detection<br/>(Presidio + spaCy)"]
            Hallucination["Hallucination Detection"]
            FactCheck["Fact Checking"]
            TopicSafety["Topic Safety"]
            RegexRails["Regex Rails"]
            LlamaGuard["Llama Guard"]
        end

        subgraph KnowledgeBase["Knowledge Base"]
            DocChunker["Document Chunker"]
            AnnoyIndex["Annoy NN Index"]
        end

        subgraph EmbeddingProviders["Embedding Providers"]
            FastEmbed["FastEmbed<br/>(default)"]
            OAIEmbed["OpenAI Embeddings"]
            STEmbed["SentenceTransformers"]
            NIMEmbed["NIM Embeddings"]
        end

        subgraph Tracing["Tracing System"]
            OTelAdapter["OpenTelemetry Adapter"]
            FSAdapter["Filesystem Adapter"]
        end

        API -->|routes requests| ColangRuntime
        ColangRuntime -->|executes| InputRails
        ColangRuntime -->|executes| OutputRails
        InputRails --> ContentSafety
        InputRails --> JailbreakDetect
        InputRails --> InjectionDetect
        InputRails --> SensitiveData
        OutputRails --> Hallucination
        OutputRails --> FactCheck
        OutputRails --> TopicSafety
        OutputRails --> RegexRails
        ColangRuntime -->|semantic search| KnowledgeBase
        KnowledgeBase -->|embeddings| EmbeddingProviders
        API -->|traces| Tracing
    end

    Client["Client Application"] -->|POST /v1/chat/completions<br/>POST /v1/guardrail/checks| API
    API -->|forwards approved requests| UpstreamLLM["Upstream LLM<br/>(vLLM / TGI / NIM / OpenAI)"]

    JailbreakDetect -.->|optional| NIMJailbreak["NIM Jailbreak Service"]
    FactCheck -.->|optional| AlignScore["AlignScore Server"]
    ContentSafety -.->|optional| CiscoAI["Cisco AI Defense"]
    OTelAdapter -->|OTLP| Collector["OpenTelemetry Collector"]

