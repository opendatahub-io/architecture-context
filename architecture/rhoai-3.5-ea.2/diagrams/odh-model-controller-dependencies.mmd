graph LR
    ODH["odh-model-controller<br/>+ model-serving-api"]

    %% External Dependencies (Required)
    ODH -->|"controller framework"| CR["controller-runtime<br/>v0.20+"]
    ODH -->|"CRD watches + status"| KServe["KServe<br/>v0.17.0-rc1"]
    ODH -->|"ServiceMonitor<br/>PodMonitor CRDs"| PromOp["Prometheus Operator<br/>v0.89.0"]
    ODH -->|"Route, Template,<br/>Auth CRDs"| OSAPI["OpenShift API"]

    %% External Dependencies (Conditional)
    ODH -->|"AuthPolicy CRDs<br/>(LLM features)"| Kuadrant["Kuadrant<br/>v1.4.2"]
    ODH -->|"AuthN/AuthZ backend<br/>(LLM features)"| Authorino["Authorino<br/>v0.22.0"]
    ODH -->|"EnvoyFilter CRDs<br/>(LLM features)"| Istio["Istio<br/>v1.27.8"]
    ODH -->|"TriggerAuth<br/>(autoscaling)"| KEDA["KEDA<br/>v2.18.3"]
    ODH -->|"Gateway, HTTPRoute<br/>(LLM features)"| GatewayAPI["Gateway API<br/>v1"]
    ODH -.->|"model version tracking<br/>(optional)"| KFHub["Kubeflow Hub<br/>v0.3.9"]
    ODH -.->|"NIM API key validation<br/>(NIM features)"| NGC["NVIDIA NGC API"]

    %% Internal RHOAI Dependencies
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>HTTPS/8443"| ODH
    RhodsOp["rhods-operator"] -->|"deploys via<br/>kustomize"| ODH
    ODH -->|"CRD Watch +<br/>Status Update"| KServe
    ODH -->|"Route creation"| OSRouting["OpenShift Routing"]
    ODH -.->|"REST API<br/>(optional)"| ModelReg["Model Registry"]
    ODH -->|"TLS certs"| CertMgr["cert-manager /<br/>OpenShift service-ca"]

    %% Resources Created
    ODH -->|"creates"| Routes["Routes"]
    ODH -->|"creates"| NetPol["NetworkPolicies"]
    ODH -->|"creates"| SvcMon["ServiceMonitors"]
    ODH -->|"creates"| AuthPol["AuthPolicies"]
    ODH -->|"creates"| EnvFilter["EnvoyFilters"]
    ODH -->|"creates"| TrigAuth["TriggerAuths"]

    %% External Services
    ODH -->|"API key validation<br/>HTTPS/443"| NGC
    ODH -->|"image manifests<br/>HTTPS/443"| NVCR["nvcr.io"]
    ODH -->|"resource CRUD<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style CR fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff
    style OSAPI fill:#999,stroke:#333,color:#fff

    %% Conditional external
    style Kuadrant fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Authorino fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Istio fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style KEDA fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style GatewayAPI fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style KFHub fill:#b8b8b8,stroke:#333,stroke-dasharray: 5 5,color:#fff

    %% Internal RHOAI
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style OSRouting fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style CertMgr fill:#7ed321,stroke:#333,color:#fff

    %% Created resources
    style Routes fill:#e8f5e9,stroke:#388e3c
    style NetPol fill:#e8f5e9,stroke:#388e3c
    style SvcMon fill:#e8f5e9,stroke:#388e3c
    style AuthPol fill:#e8f5e9,stroke:#388e3c
    style EnvFilter fill:#e8f5e9,stroke:#388e3c
    style TrigAuth fill:#e8f5e9,stroke:#388e3c

    %% External services
    style NGC fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
