graph TD
    subgraph NotebooksComponent["Notebooks Component — No RBAC Defined"]
        direction TB
        Note["This component does not define<br/>its own RBAC resources.<br/>All images run as unprivileged<br/>user UID 1001."]
    end

    subgraph PlatformRBAC["Platform-Level RBAC (managed by odh-notebook-controller)"]
        direction TB

        subgraph AuthFlow["Authentication Flow"]
            User["Data Scientist<br/>(OpenShift User)"]
            OAuthProxy["OpenShift OAuth<br/>(Platform Gateway)"]
            KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar, injected by<br/>odh-notebook-controller)"]
        end

        subgraph AuthZ["Authorization"]
            SAR["SubjectAccessReview<br/>against namespace RBAC"]
            NamespaceRBAC["Namespace RoleBinding<br/>(user must have access<br/>to workbench namespace)"]
        end

        subgraph WorkbenchPod["Workbench Pod"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>No auth (delegated)"]
            CodeServer["code-server<br/>8787/TCP HTTP<br/>--auth none (delegated)"]
        end
    end

    subgraph OperatorRBAC["Operator RBAC (manages notebook lifecycle)"]
        direction TB

        subgraph ControllerSA["Service Account"]
            NotebookCtrlSA["odh-notebook-controller<br/>ServiceAccount"]
        end

        subgraph ControllerPerms["Controller Permissions"]
            NotebookCR["Notebook CR<br/>(kubeflow.org)"]
            Pods["Pods<br/>(core)"]
            Services["Services<br/>(core)"]
            Routes["Routes / HTTPRoutes<br/>(networking)"]
            ImageStreams["ImageStreams<br/>(image.openshift.io)"]
        end
    end

    %% Auth flow
    User -->|"OpenShift OAuth token"| OAuthProxy
    OAuthProxy -->|"Bearer token"| KubeRBACProxy
    KubeRBACProxy -->|"validates"| SAR
    SAR -->|"checks"| NamespaceRBAC
    KubeRBACProxy -->|"proxies to<br/>(if authorized)"| JupyterLab
    KubeRBACProxy -->|"proxies to<br/>(if authorized)"| CodeServer

    %% Controller flow
    NotebookCtrlSA -->|"manages"| NotebookCR
    NotebookCtrlSA -->|"creates/manages"| Pods
    NotebookCtrlSA -->|"creates"| Services
    NotebookCtrlSA -->|"creates"| Routes
    NotebookCtrlSA -->|"reads"| ImageStreams

    %% Styling
    style NotebooksComponent fill:#f0f0f0,stroke:#999,stroke-width:2px,stroke-dasharray: 5 5
    style Note fill:#fff,stroke:#ccc
    style PlatformRBAC fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style OperatorRBAC fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style User fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#f5a623,stroke:#333
    style SAR fill:#f5a623,stroke:#333
    style NotebookCtrlSA fill:#4a90e2,stroke:#333,color:#fff
    style JupyterLab fill:#7ed321,stroke:#333
    style CodeServer fill:#7ed321,stroke:#333
    style NotebookCR fill:#e1d5e7,stroke:#9673a6
    style Pods fill:#e1d5e7,stroke:#9673a6
    style Services fill:#e1d5e7,stroke:#9673a6
    style Routes fill:#e1d5e7,stroke:#9673a6
    style ImageStreams fill:#e1d5e7,stroke:#9673a6
