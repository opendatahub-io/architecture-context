graph TD
    subgraph RuntimeSecurity["Runtime Security Profile"]
        direction TB
        InitContainer["Init Container<br/>odh-model-performance-data"]
        UID["Runs as UID 1001<br/>(non-root)"]
        NoRBAC["No RBAC Required<br/>No ClusterRoles<br/>No RoleBindings"]
        NoAPI["No Kubernetes API Access<br/>(data-only container)"]
        NoPorts["No Network Ports<br/>(no services exposed)"]

        InitContainer --- UID
        InitContainer --- NoRBAC
        InitContainer --- NoAPI
        InitContainer --- NoPorts
    end

    subgraph CISecrets["CI/Developer Secrets (Not in production)"]
        direction TB

        subgraph KafkaAuth["Kafka Authentication"]
            KafkaCreds["Secret: Kafka SASL Credentials<br/>Type: Opaque"]
            SASLUser["SASL_USERNAME"]
            SASLPass["SASL_PASSWORD"]
            KafkaCreds --- SASLUser
            KafkaCreds --- SASLPass
        end

        subgraph TLSCerts["TLS Certificates"]
            SSLCerts["Secret: SSL Certificates<br/>Type: kubernetes.io/tls"]
            CACert["SSL_CA_LOCATION"]
            ClientCert["SSL_CERTIFICATE_LOCATION"]
            ClientKey["SSL_KEY_LOCATION"]
            SSLCerts --- CACert
            SSLCerts --- ClientCert
            SSLCerts --- ClientKey
        end

        subgraph APIAuth["API Client TLS Config"]
            TLSVerify["API_TLS_VERIFY<br/>Default: true<br/>⚠️ Can be disabled"]
            HostnameCheck["API_TLS_HOSTNAME_CHECK<br/>Default: true<br/>⚠️ Can be disabled"]
        end
    end

    subgraph Consumers["Secret Consumers"]
        KafkaProcessor["kafka-processor<br/>(CI/developer tool)"]
        APIClientTool["api-client<br/>(CI/developer tool)"]
    end

    KafkaCreds -->|used by| KafkaProcessor
    SSLCerts -->|used by| KafkaProcessor
    SSLCerts -->|used by| APIClientTool
    TLSVerify -->|configures| APIClientTool
    HostnameCheck -->|configures| APIClientTool

    subgraph FIPSCompliance["FIPS Compliance"]
        DataOnly["Data-only container:<br/>No compiled binaries"]
        UBI9["UBI 9 Minimal base:<br/>OpenSSL FIPS-validated"]
        Inherited["FIPS compliance<br/>inherited from base image"]
        DataOnly --- UBI9
        UBI9 --- Inherited
    end

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style UID fill:#d5e8d4,stroke:#82b366
    style NoRBAC fill:#d5e8d4,stroke:#82b366
    style NoAPI fill:#d5e8d4,stroke:#82b366
    style NoPorts fill:#d5e8d4,stroke:#82b366
    style KafkaCreds fill:#f8cecc,stroke:#b85450
    style SSLCerts fill:#f8cecc,stroke:#b85450
    style TLSVerify fill:#fff2cc,stroke:#d6b656
    style HostnameCheck fill:#fff2cc,stroke:#d6b656
    style KafkaProcessor fill:#7ed321,stroke:#333
    style APIClientTool fill:#7ed321,stroke:#333
    style DataOnly fill:#e1d5e7,stroke:#9673a6
    style UBI9 fill:#e1d5e7,stroke:#9673a6
    style Inherited fill:#e1d5e7,stroke:#9673a6
