graph TB
    subgraph OGXOperator["OGX Kubernetes Operator"]
        direction TB
        Controller["OGXServer Controller<br/>(controller-runtime)"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS"]
        ConfigGen["Config Generation Pipeline<br/>(in-process)"]
        Kustomizer["Kustomize Manifest Renderer<br/>(5-stage plugin chain)"]
        LegacyAdopt["Legacy Adoption Handler<br/>(LlamaStackDistribution migration)"]

        Controller -->|"validates CRs"| Webhook
        Controller -->|"generates config"| ConfigGen
        Controller -->|"renders manifests"| Kustomizer
        Controller -->|"adopts legacy resources"| LegacyAdopt
    end

    subgraph OGXModule["OGX Module (Scaffolded)"]
        ModuleController["OGX Component Controller<br/>(reconciler not yet implemented)"]
    end

    subgraph ConfigGenCLI["configgen CLI (Dev Tool)"]
        CLI["Offline Config Generator<br/>(Go CLI)"]
    end

    %% CRDs
    OGXServerCR["OGXServer CR<br/>(ogx.io/v1beta1)<br/>Namespaced"]
    LegacyCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)<br/>Legacy/Read-only"]
    PlatformCR["OGX CR<br/>(components.platform.opendatahub.io/v1alpha1)<br/>Cluster-scoped"]

    User["User / Data Scientist"] -->|"kubectl apply"| OGXServerCR
    OGXServerCR -->|"watched by"| Controller

    LegacyCR -.->|"read for adoption"| LegacyAdopt
    PlatformCR -.->|"managed by (future)"| ModuleController

    %% Managed Resources
    subgraph ManagedResources["Managed K8s Resources (per OGXServer)"]
        Deployment["Deployment<br/>(OGX Server Pod)"]
        Service["Service<br/>8321/TCP"]
        PVC["PersistentVolumeClaim"]
        ConfigMap["ConfigMap<br/>(content-hashed, immutable)"]
        NetPol["NetworkPolicy"]
        HPA["HorizontalPodAutoscaler"]
        PDB["PodDisruptionBudget"]
        Ingress["Ingress<br/>(optional)"]
        SA["ServiceAccount"]
        RB["RoleBinding<br/>(anyuid SCC)"]
    end

    Controller -->|"creates/reconciles"| Deployment
    Controller -->|"creates/reconciles"| Service
    Controller -->|"creates/reconciles"| PVC
    ConfigGen -->|"creates immutable"| ConfigMap
    Controller -->|"creates/reconciles"| NetPol
    Controller -->|"creates/reconciles"| HPA
    Controller -->|"creates/reconciles"| PDB
    Controller -->|"creates/reconciles"| Ingress
    Controller -->|"creates/reconciles"| SA
    Controller -->|"creates/reconciles"| RB

    %% External Dependencies
    ConfigGen -->|"fetch base config<br/>443/TCP HTTPS"| OCIRegistry["OCI Container Registry"]
    Controller -->|"status polling<br/>8321/TCP HTTP"| OGXPod["OGX Server Pod"]
    Controller -->|"CRUD resources<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Platform Integration
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| OGXOperator
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -.->|"auto-detected<br/>CA merge"| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style ConfigGen fill:#4a90e2,stroke:#333,color:#fff
    style Kustomizer fill:#4a90e2,stroke:#333,color:#fff
    style LegacyAdopt fill:#4a90e2,stroke:#333,color:#fff
    style ModuleController fill:#b8d4f0,stroke:#333,color:#333
    style CLI fill:#b8d4f0,stroke:#333,color:#333
    style OGXServerCR fill:#f5a623,stroke:#333,color:#333
    style LegacyCR fill:#f5a623,stroke:#333,color:#333,stroke-dasharray: 5 5
    style PlatformCR fill:#f5a623,stroke:#333,color:#333,stroke-dasharray: 5 5
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PlatformOp fill:#7ed321,stroke:#333,color:#333
    style CABundle fill:#7ed321,stroke:#333,color:#333
    style OGXPod fill:#d5e8d4,stroke:#333
    style User fill:#fff,stroke:#333
