graph TB
    subgraph InitPhase["INIT PHASE (Runs once at pod startup, no network)"]
        direction TB

        subgraph DSPAPod["KFP API Server Pod (Namespace: dspa-namespace)"]
            InitContainer["pipelines-components<br/>Init Container<br/>Image: UBI9 Python 3.12<br/>NO NETWORK ACCESS"]
            SharedVol[("Shared Volume<br/>/config/managed-pipelines<br/>emptyDir")]
            KFPServer["KFP API Server<br/>Reads pipeline YAMLs"]

            InitContainer -->|"Local filesystem<br/>No encryption<br/>No auth"| SharedVol
            KFPServer -->|"Local filesystem<br/>No encryption<br/>No auth"| SharedVol
        end
    end

    subgraph RuntimePhase["RUNTIME PHASE (Short-lived pipeline step pods)"]
        direction TB

        subgraph PipelinePods["Pipeline Step Pods (Namespace: user-namespace)"]
            AutoMLPod["AutoML Step Pod<br/>Image: odh-automl<br/>Base: AIPCC CPU<br/>SA: pipeline-run-sa"]
            AutoRAGPod["AutoRAG Step Pod<br/>Image: odh-autorag<br/>Base: AIPCC CPU<br/>SA: pipeline-run-sa"]
            FineTunePod["Fine-Tuning Step Pod<br/>SA: pipeline-run-sa"]
        end
    end

    subgraph ExternalTLS["EXTERNAL SERVICES (TLS 1.2+)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS Signature V4"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (HF_TOKEN)"]
        OGX["OGX API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        EvalHub["Eval Hub API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
        SDGHub["LiteLLM / SDG Hub<br/>443/TCP HTTPS/gRPC<br/>TLS 1.2+<br/>Auth: API key"]
    end

    subgraph InCluster["IN-CLUSTER SERVICES (Plaintext)"]
        ModelReg["Kubeflow Model Registry<br/>8080/TCP HTTP<br/>Plaintext<br/>Auth: None"]
        Milvus["Milvus Vector DB<br/>19530/TCP gRPC<br/>Plaintext<br/>Auth: None"]
        KServe["KServe InferenceService<br/>80/TCP or 443/TCP<br/>HTTP/HTTPS<br/>Auth: Bearer Token (optional)"]
    end

    %% AutoML egress
    AutoMLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3-secret)"| S3

    %% AutoRAG egress
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3-secret)"| S3
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API key (ogx_secret)"| OGX
    AutoRAGPod -->|"gRPC/19530<br/>Plaintext<br/>No Auth"| Milvus

    %% Fine-Tuning egress
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3-secret)"| S3
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (hf-token)"| HFHub
    FineTunePod -->|"HTTP/80<br/>Bearer Token"| KServe
    FineTunePod -->|"HTTP/8080<br/>Plaintext<br/>No Auth"| ModelReg
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| EvalHub
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>API key (llm-credentials)"| SDGHub

    %% Styling
    classDef initcontainer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtimepod fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    classDef externaltls fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef incluster fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef volume fill:#f5a623,stroke:#333,stroke-width:2px
    classDef kfpserver fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    class InitContainer initcontainer
    class AutoMLPod,AutoRAGPod,FineTunePod runtimepod
    class S3,HFHub,OGX,EvalHub,SDGHub externaltls
    class ModelReg,Milvus,KServe incluster
    class SharedVol volume
    class KFPServer kfpserver
