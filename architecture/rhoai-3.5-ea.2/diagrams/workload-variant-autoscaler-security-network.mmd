graph TB
    subgraph External["EXTERNAL METRICS SOURCES"]
        direction TB
        vLLM["vLLM Inference Servers<br/>8200/TCP HTTP<br/>No Encryption<br/>Metrics: KV cache, queue,<br/>latency, throughput"]
        EPP["EPP (Gateway API Ext)<br/>HTTP<br/>Optional Bearer Token<br/>Metrics: dispatch rate,<br/>flow control queue"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph MonitoringZone["Monitoring Zone"]
            Prometheus["Prometheus / Thanos Querier<br/>9091/TCP (OpenShift) · 9090/TCP (k8s)<br/>HTTPS · TLS 1.2+<br/>Bearer Token (SA)"]
        end

        subgraph WVAZone["WVA Controller Zone"]
            direction TB
            WVA["WVA Controller Manager<br/>NS: wva-system<br/>SA: controller-manager<br/>Image: llm-d-workload-variant-autoscaler:v0.7.0"]

            subgraph WVAPorts["Exposed Ports"]
                MetricsPort["8443/TCP · HTTPS<br/>TLS 1.2+ (self-signed)<br/>Bearer Token (TokenReview)<br/>/metrics"]
                HealthPort["8081/TCP · HTTP<br/>No Auth<br/>/healthz · /readyz"]
            end
        end

        subgraph ScalingZone["Scaling Zone"]
            HPA["HPA / KEDA<br/>Reads wva_desired_replicas<br/>from Prometheus"]
        end

        subgraph K8sZone["Kubernetes Control Plane"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP · HTTPS<br/>TLS 1.2+<br/>SA Token"]
        end

        subgraph WatchedResources["Watched Resources (via K8s API)"]
            direction LR
            ManagedHPA["HPA<br/>llm-d.ai/managed=true"]
            ManagedSO["ScaledObject<br/>llm-d.ai/managed=true"]
            InfPool["InferencePool CR"]
            VACR["VariantAutoscaling CR<br/>(deprecated)"]
            CMs["ConfigMaps<br/>Global + NS"]
            Nodes["Nodes<br/>GPU labels"]
        end
    end

    %% Egress flows from WVA
    WVA -->|"PromQL queries<br/>HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA)"| Prometheus
    WVA -->|"Resource CRUD + Leader Election<br/>HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    WVA -->|"Direct pod scraping (fallback)<br/>HTTP/8200<br/>Bearer Token (optional)"| vLLM

    %% Prometheus scrapes WVA
    Prometheus -->|"Scrape /metrics<br/>HTTPS/8443<br/>TLS 1.2+ (self-signed)<br/>Bearer Token"| MetricsPort

    %% Prometheus scrapes sources
    vLLM -->|"Scraped by Prometheus<br/>HTTP/8200"| Prometheus
    EPP -->|"Scraped by Prometheus<br/>HTTP"| Prometheus

    %% HPA reads from Prometheus and scales via API
    HPA -->|"Read external metric<br/>HTTPS/9091"| Prometheus
    HPA -->|"PATCH scale subresource<br/>HTTPS/6443<br/>SA Token"| K8sAPI

    %% Watch flows
    K8sAPI -.->|watch events| WVA

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef wva fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef scaling fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef port fill:#b3d9ff,stroke:#4a86c8,stroke-width:1px
    classDef resource fill:#f5f5f5,stroke:#999,stroke-width:1px

    class vLLM,EPP external
    class Prometheus monitoring
    class WVA wva
    class MetricsPort,HealthPort port
    class K8sAPI controlplane
    class HPA scaling
    class ManagedHPA,ManagedSO,InfPool,VACR,CMs,Nodes resource
