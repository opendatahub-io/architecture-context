    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style SWFController fill:#4a90e2,stroke:#333,color:#fff
    style ViewerController fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style CacheDeployer fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#50c878,stroke:#333,color:#fff
    style VizServer fill:#50c878,stroke:#333,color:#fff
    style Driver fill:#9b59b6,stroke:#333,color:#fff
    style Launcher fill:#9b59b6,stroke:#333,color:#fff
    style SWFCR fill:#f5a623,stroke:#333
    style ViewerCR fill:#f5a623,stroke:#333
    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style Argo fill:#e8e8e8,stroke:#333
    style DB fill:#e8e8e8,stroke:#333
