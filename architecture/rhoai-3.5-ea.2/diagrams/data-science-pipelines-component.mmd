graph TB
    subgraph DSP["Data Science Pipelines (KFP v2)"]
        direction TB

        subgraph ControlPlane["Control Plane Services"]
            APIServer["ml-pipeline<br/>(API Server)<br/>Go Service<br/>8888/TCP REST · 8887/TCP gRPC"]
            PersistenceAgent["ml-pipeline-persistenceagent<br/>Go Service<br/>(background agent)"]
            SWFController["ml-pipeline-scheduledworkflow<br/>Go Controller<br/>9090/TCP metrics"]
            ViewerController["ml-pipeline-viewer-crd<br/>Go Controller<br/>(controller-runtime)"]
            CacheServer["cache-server<br/>Go Webhook<br/>8443/TCP TLS"]
            CacheDeployer["cache-deployer<br/>Go Utility<br/>(cert management)"]
        end

        subgraph Frontend["Frontend"]
            UI["ml-pipeline-ui<br/>Node.js/Express + React<br/>3000/TCP"]
            VizServer["ml-pipeline-visualizationserver<br/>Python Service<br/>8888/TCP"]
        end

        subgraph DataPlane["Data Plane (Ephemeral - per pipeline step)"]
            Driver["ml-pipeline-driver<br/>Go CLI<br/>(Argo task container)"]
            Launcher["ml-pipeline-launcher<br/>Go CLI<br/>(Argo task container)"]
        end
    end

    %% CRDs
    SWFCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]

    %% External Dependencies
    Argo["Argo Workflows<br/>v3.7.14"]
    DB["MySQL / PostgreSQL<br/>3306/5432 TCP"]
    MLMD["ML Metadata (MLMD)<br/>gRPC 8080/TCP"]
    ObjectStore["MinIO / SeaweedFS / S3<br/>9000/TCP"]
    K8sAPI["Kubernetes API<br/>443/TCP"]
    Envoy["Envoy Proxy<br/>gRPC-Web 9090/TCP"]

    %% Internal Platform
    DSPO["data-science-pipelines-operator<br/>(DSPO)"]
    Istio["Istio Service Mesh"]

    %% User
    User["User / Data Scientist"]

    %% Relationships
    User -->|"creates pipelines & runs"| UI
    UI -->|"proxies API requests"| APIServer
    UI -->|"renders visualizations"| VizServer

    APIServer -->|"persists metadata"| DB
    APIServer -->|"stores artifacts/specs"| ObjectStore
    APIServer -->|"submits Workflows"| Argo
    APIServer -->|"queries artifacts"| MLMD
    APIServer -->|"validates tokens"| K8sAPI
    APIServer -->|"watches/validates"| PipelineCR
    APIServer -->|"watches/validates"| PipelineVersionCR

    SWFController -->|"watches"| SWFCR
    SWFController -->|"creates runs via gRPC"| APIServer
    SWFController -->|"creates Workflows"| Argo

    ViewerController -->|"watches"| ViewerCR
    ViewerController -->|"creates Deployments/Services"| K8sAPI

    PersistenceAgent -->|"watches Workflows"| K8sAPI
    PersistenceAgent -->|"reports status via gRPC"| APIServer

    CacheServer -->|"intercepts pod creation"| K8sAPI
    CacheDeployer -->|"manages TLS certs"| CacheServer

    Driver -->|"resolves inputs"| MLMD
    Driver -->|"checks cache"| APIServer
    Launcher -->|"downloads/uploads artifacts"| ObjectStore
    Launcher -->|"records results"| MLMD

    Argo -->|"creates task pods"| Driver
    Argo -->|"creates task pods"| Launcher

    DSPO -->|"deploys & manages"| DSP
    Istio -->|"mTLS & AuthorizationPolicy"| DSP

    Envoy -->|"proxies gRPC-Web"| MLMD

