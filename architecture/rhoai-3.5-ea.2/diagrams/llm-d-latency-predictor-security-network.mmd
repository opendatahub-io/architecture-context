graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        GatewayComp["llm-d Gateway Components<br/>Training data source"]
        GatewayRouter["llm-d Gateway Router<br/>Prediction consumer"]
        Prometheus["Prometheus<br/>Metrics scraper"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (No Auth, No TLS)"]
        direction TB

        subgraph TrainingSvc["training-service (ClusterIP 8000/TCP)"]
            TrainingPod["Training Server Pod<br/>Image: odh-latency-predictor-training<br/>Port: 8000/TCP HTTP (plaintext)<br/>Replicas: 1<br/>Volume: PVC (models)"]
        end

        subgraph TrainingSvcExt["training-service-external (LB 8080/TCP)"]
            TrainingExtNote["WARNING: Exposes training<br/>server externally<br/>8080 → 8000/TCP"]
        end

        subgraph PredictionSvc["prediction-service (LB 80→8001/TCP)"]
            PredictionPod["Prediction Server Pod (x10)<br/>Image: odh-latency-predictor-prediction<br/>Port: 8001/TCP HTTP (plaintext)<br/>Workers: 8 (uvicorn)<br/>Volume: emptyDir (model cache)"]
        end
    end

    %% External → Cluster flows
    GatewayComp -->|"POST /add_training_data_bulk<br/>HTTP/8000 · No TLS · No Auth<br/>Latency traces (TTFT/TPOT)"| TrainingPod
    GatewayRouter -->|"POST /predict/bulk/strict<br/>HTTP/80→8001 · No TLS · No Auth<br/>Feature vectors"| PredictionPod
    Prometheus -->|"GET /metrics<br/>HTTP/8000 · No TLS · No Auth"| TrainingPod

    %% Internal flows
    PredictionPod -->|"GET /model/{name}/download<br/>HTTP/8000 · No TLS · No Auth<br/>Model files (joblib)<br/>MD5 change detection only"| TrainingPod

    %% External exposure
    TrainingExtNote -.->|"exposes"| TrainingPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef warning fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef noauth fill:#fff3cd,stroke:#856404,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class GatewayComp,GatewayRouter,Prometheus external
    class TrainingExtNote warning
    class TrainingPod,PredictionPod service
    class TrainingSvc,PredictionSvc noauth
