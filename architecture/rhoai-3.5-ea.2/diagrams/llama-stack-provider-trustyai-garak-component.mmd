graph TB
    subgraph EvalHub_Integration["eval-hub Integration Layer"]
        GarakAdapter["GarakAdapter<br/>(FrameworkAdapter)"]
        KFPAdapter["KFP Adapter<br/>(kfp_adapter.py)"]
        KFPPipeline["KFP Pipeline Definition<br/>(6-step pipeline)"]
        S3Utils["S3 Utilities<br/>(s3_utils.py)"]
        GarakAdapter -->|KFP mode| KFPAdapter
        KFPAdapter --> KFPPipeline
        KFPAdapter --> S3Utils
    end

    subgraph Core_Logic["Core Module (Framework-Agnostic)"]
        CommandBuilder["Command Builder<br/>(command_builder.py)"]
        ConfigResolver["Config Resolution<br/>(config_resolution.py)"]
        GarakRunner["Garak Runner<br/>(garak_runner.py)"]
        PipelineSteps["Pipeline Steps<br/>(pipeline_steps.py)"]
        CommandBuilder --> GarakRunner
        ConfigResolver --> CommandBuilder
        PipelineSteps --> GarakRunner
    end

    subgraph Config_Models["Configuration & Models"]
        Config["Config Models<br/>(config.py)"]
        GarakCmdConfig["Garak Command Config<br/>(garak_command_config.py)"]
        Constants["Constants<br/>(constants.py)"]
        Errors["Error Types<br/>(errors.py)"]
    end

    subgraph SDG_Module["SDG Module"]
        SDG["Synthetic Data Generation<br/>(sdg.py)"]
        Intents["Intent Stub Generator<br/>(intents.py)"]
        SDG --> Intents
    end

    subgraph Result_Processing["Result Processing"]
        ResultUtils["Result Utils<br/>(result_utils.py)<br/>JSONL/AVID parsing,<br/>ART HTML reports,<br/>Vega visualizations"]
    end

    %% Internal connections
    GarakAdapter -->|simple mode| GarakRunner
    GarakAdapter --> ConfigResolver
    GarakAdapter --> ResultUtils
    GarakAdapter --> SDG
    GarakAdapter --> Config
    KFPPipeline --> PipelineSteps
    PipelineSteps --> SDG
    PipelineSteps --> Intents
    PipelineSteps --> ResultUtils
    GarakRunner --> GarakCmdConfig

    %% External interactions
    EvalHubService["eval-hub Service<br/>(JobSpec, Callbacks)"]
    TargetLLM["Target LLM<br/>(OpenAI-compatible /v1)"]
    SDGModel["SDG Model Endpoint"]
    KFPService["Kubeflow Pipelines API"]
    S3Storage["S3-compatible Storage"]
    MLflow["MLflow Tracking"]
    OCIRegistry["OCI Registry"]

    EvalHubService -->|JobSpec| GarakAdapter
    GarakAdapter -->|status/results| EvalHubService
    GarakRunner -->|probe prompts| TargetLLM
    SDG -->|generate prompts| SDGModel
    KFPAdapter -->|submit/poll| KFPService
    S3Utils -->|upload/download| S3Storage
    GarakAdapter -.->|optional| MLflow
    GarakAdapter -.->|artifacts| OCIRegistry

