    style S3Utils fill:#4a90e2,stroke:#333,color:#fff
    style CommandBuilder fill:#50c878,stroke:#333,color:#fff
    style ConfigResolver fill:#50c878,stroke:#333,color:#fff
    style GarakRunner fill:#50c878,stroke:#333,color:#fff
    style PipelineSteps fill:#50c878,stroke:#333,color:#fff
    style Config fill:#9b59b6,stroke:#333,color:#fff
    style GarakCmdConfig fill:#9b59b6,stroke:#333,color:#fff
    style Constants fill:#9b59b6,stroke:#333,color:#fff
    style Errors fill:#9b59b6,stroke:#333,color:#fff
    style SDG fill:#e67e22,stroke:#333,color:#fff
    style Intents fill:#e67e22,stroke:#333,color:#fff
    style ResultUtils fill:#c0392b,stroke:#333,color:#fff
