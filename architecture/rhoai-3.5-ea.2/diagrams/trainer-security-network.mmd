graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / SA Token"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB

        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/odh-trainer"]

        subgraph ControllerPorts["Controller Ports"]
            Health["8081/TCP HTTP<br/>/healthz, /readyz"]
            Metrics["8443/TCP HTTPS<br/>/metrics (TLS)"]
            WebhookPort["9443/TCP HTTPS<br/>/validate-* (TLS)"]
        end

        Controller --- ControllerPorts
    end

    subgraph Monitoring["OPENSHIFT MONITORING"]
        Prometheus["Prometheus<br/>(PodMonitor)"]
    end

    subgraph TrainingNS["TRAINING NAMESPACE (user namespace)"]
        direction TB

        subgraph TrainingPodGroup["Training Pods (JobSet-managed)"]
            Rank0["Training Pod (rank 0)<br/>28080/TCP HTTP /metrics"]
            RankN["Training Pods (rank 1..N)<br/>29500/TCP TCP rendezvous<br/>Dynamic TCP/UDP NCCL/gloo"]
        end

        NetPol["NetworkPolicy (per-TrainJob)<br/>• Allow same-job inter-pod<br/>• Allow controller → 28080/TCP<br/>• Deny all other ingress"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control Plane ↔ Controller
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-controller)<br/>API server client cert"| WebhookPort
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD: TrainJob, JobSet,<br/>PodGroup, NetworkPolicy,<br/>Secret, ConfigMap"| K8sAPI

    %% Prometheus → Controller
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>PodMonitor scrape"| Metrics

    %% Controller → Training Pods (progression tracking)
    Controller -->|"HTTP/28080<br/>No TLS<br/>No Auth<br/>NetworkPolicy enforced<br/>(RHAI progression)"| Rank0

    %% Inter-pod training
    Rank0 <-->|"TCP/29500 rendezvous<br/>TCP/UDP dynamic NCCL/gloo<br/>No TLS, No Auth<br/>NetworkPolicy: same-job"| RankN

    %% Styles
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef training fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,Health,Metrics,WebhookPort controller
    class Prometheus monitoring
    class Rank0,RankN training
    class NetPol netpol
