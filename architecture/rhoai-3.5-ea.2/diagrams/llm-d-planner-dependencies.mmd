graph LR
    Planner["llm-d-planner<br/>(FastAPI + Streamlit)"]

    %% External Dependencies (Required)
    Planner -->|"TCP/5432<br/>Password auth"| PostgreSQL["PostgreSQL 16<br/>(Required)"]
    Planner -->|"HTTP/11434<br/>No auth"| Ollama["Ollama<br/>qwen2.5:7b<br/>(Default LLM)"]

    %% External Dependencies (Conditional LLM Providers)
    Planner -.->|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API<br/>(Conditional:<br/>LLM_PROVIDER=openai)"]
    Planner -.->|"HTTPS/443<br/>GCP IAM"| VertexAI["Vertex AI<br/>(Conditional:<br/>LLM_PROVIDER=vertex)"]

    %% External Dependencies (APIs)
    Planner -->|"HTTPS/443<br/>Bearer HF_TOKEN"| HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>(Model metadata)"]

    %% Internal RHOAI Dependencies
    Planner -->|"HTTPS/8443<br/>Bearer Token<br/>Service CA TLS"| ModelCatalog["RHOAI Model Catalog<br/>v1alpha1 API<br/>(Model + benchmark sync)"]

    %% Platform Dependencies
    Planner -->|"HTTPS/6443<br/>SA Token"| K8sAPI["Kubernetes API<br/>(GPU detection,<br/>InferenceService CRUD)"]

    %% Generated Target CRDs
    Planner -->|"generates YAML"| KServe["KServe<br/>InferenceService v1beta1<br/>(Deployment target)"]
    Planner -->|"generates YAML"| ServiceMonitor["Prometheus<br/>ServiceMonitor<br/>(Metrics scraping)"]
    Planner -->|"generates ConfigMap"| Grafana["Grafana<br/>Dashboard ConfigMap<br/>(SLO visualization)"]
    Planner -->|"generates YAML"| HPA["HPA<br/>autoscaling/v2<br/>(Pod autoscaling)"]

    %% Platform Infrastructure
    Planner -->|"TLS edge<br/>termination"| Routes["OpenShift Routes<br/>(External access)"]
    Planner -->|"reads node labels"| GPUOperator["NVIDIA GPU Operator<br/>nvidia.com/gpu.product<br/>(GPU detection)"]
    Planner -.->|"CA injection"| ServiceCA["OpenShift Service CA<br/>(Certificate injection)"]

    %% Library Dependencies
    Planner -->|"Python library"| LLMOptimizer["BentoML llm-optimizer<br/>(Roofline GPU estimation)"]

    %% Optional
    Planner -.->|"generates YAML<br/>(commented out)"| KEDA["KEDA<br/>ScaledObject<br/>(Optional scaling)"]

    %% Styling
    style Planner fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#999,stroke:#333,color:#fff

    %% Conditional external
    style OpenAI fill:#bbb,stroke:#333,stroke-dasharray: 5
    style VertexAI fill:#bbb,stroke:#333,stroke-dasharray: 5

    %% External APIs
    style HuggingFace fill:#f5a623,stroke:#333

    %% Internal RHOAI
    style ModelCatalog fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333
    style Grafana fill:#7ed321,stroke:#333

    %% Platform
    style K8sAPI fill:#f5a623,stroke:#333
    style Routes fill:#f5a623,stroke:#333
    style GPUOperator fill:#f5a623,stroke:#333
    style ServiceCA fill:#f5a623,stroke:#333,stroke-dasharray: 5
    style HPA fill:#7ed321,stroke:#333
    style KEDA fill:#7ed321,stroke:#333,stroke-dasharray: 5

    %% Library
    style LLMOptimizer fill:#e8e8e8,stroke:#333
