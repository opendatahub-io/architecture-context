graph LR
    AGServer["KServe AutoGluon Server<br/>Python ML Inference Server"]

    %% Core ML Dependencies
    subgraph MLBackends["ML Backends"]
        AutoGluonTab["autogluon.tabular<br/>1.5.0+rhaiv.3"]
        AutoGluonTS["autogluon.timeseries<br/>1.5.0+rhaiv.3"]
        LightGBM["lightgbm<br/>4.6.0"]
        XGBoost["xgboost<br/>3.1.3"]
        PyTorch["torch<br/>2.11.0"]
        FastAI["fastai<br/>2.8.7"]
        SKLearn["scikit-learn<br/>1.7.2"]
    end

    %% KServe Framework Dependencies
    subgraph KServeFramework["KServe Framework (vendored)"]
        KServe["kserve<br/>0.19.0"]
        KServeStorage["kserve-storage<br/>0.19.0"]
    end

    %% Server Dependencies
    subgraph ServerStack["Server Stack"]
        Uvicorn["uvicorn<br/>0.49.0"]
        FastAPI["fastapi<br/>0.136.3"]
        GRPC["grpcio<br/>1.81.0"]
    end

    %% Data Libraries
    subgraph DataLibs["Data Libraries"]
        Pandas["pandas<br/>2.3.3"]
        NumPy["numpy<br/>2.1.0"]
    end

    %% Optional / Storage
    subgraph StorageClients["Storage Clients (optional)"]
        Boto3["boto3<br/>1.43.24"]
        HFHub["huggingface-hub<br/>0.36.2"]
    end

    %% Platform Dependencies
    subgraph Platform["Internal RHOAI Platform"]
        KServeCtrl["KServe Controller"]
        KServeCSR["KServe<br/>ClusterServingRuntime"]
        Istio["Istio / Service Mesh"]
    end

    %% External Services
    subgraph ExtServices["External Services"]
        S3["S3-compatible Storage"]
        GCS["Google Cloud Storage"]
        AzureBlob["Azure Blob Storage"]
        HFService["Hugging Face Hub"]
    end

    %% Monitoring
    Prometheus["Prometheus"]

    %% Core dependencies
    AGServer -->|tabular inference| AutoGluonTab
    AGServer -->|time series inference| AutoGluonTS
    AGServer -->|serving framework| KServe
    AGServer -->|model download| KServeStorage

    %% ML backend chain
    AutoGluonTab -->|backend| LightGBM
    AutoGluonTab -->|backend| XGBoost
    AutoGluonTab -->|backend| PyTorch
    AutoGluonTab -->|backend| FastAI
    AutoGluonTab -->|backend| SKLearn
    AutoGluonTS -->|backend| PyTorch

    %% Server chain
    KServe -->|HTTP| Uvicorn
    KServe -->|REST API| FastAPI
    KServe -->|gRPC| GRPC
    KServe -->|data| Pandas
    KServe -->|data| NumPy

    %% Storage chain
    KServeStorage -->|S3 access| Boto3
    KServeStorage -->|HF access| HFHub

    %% Platform integration
    KServeCtrl -->|creates pods| AGServer
    KServeCSR -->|defines runtime| AGServer
    Istio -.->|mTLS sidecar| AGServer

    %% External service connections
    KServeStorage -->|model download| S3
    KServeStorage -->|model download| GCS
    KServeStorage -->|model download| AzureBlob
    KServeStorage -->|model download| HFService

    %% Monitoring
    Prometheus -->|scrapes metrics| AGServer

