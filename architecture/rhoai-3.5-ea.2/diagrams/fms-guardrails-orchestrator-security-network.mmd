graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / AI Application"]
    end

    subgraph Ingress["ORCHESTRATOR TLS BOUNDARY"]
        direction TB
        subgraph APIServer["Main API Server"]
            GuardrailsAPI["fms-guardrails-orchestr8<br/>8033/TCP HTTP/HTTPS<br/>rustls (ring backend)<br/>TLS: SIMPLE or MUTUAL<br/>Auth: Header passthrough"]
        end
        subgraph HealthSrv["Health Server"]
            HealthAPI["Health Server<br/>8034/TCP HTTP<br/>No TLS (K8s probes)<br/>Auth: None"]
        end
    end

    subgraph GenerationBackends["DOWNSTREAM - Generation Backends"]
        direction TB
        TGIS["TGIS<br/>configurable/TCP<br/>gRPC/HTTP2<br/>Optional mTLS<br/>RPCs: Generate, Tokenize"]
        CaikitNLP["caikit-nlp<br/>configurable/TCP<br/>gRPC/HTTP2<br/>Optional mTLS<br/>RPCs: TextGeneration, Tokenization"]
        vLLM["OpenAI Server (vLLM)<br/>configurable (8080)/TCP<br/>HTTP/HTTPS<br/>Optional Bearer Token"]
    end

    subgraph DetectionServices["DOWNSTREAM - Detection & Chunking"]
        direction TB
        Detectors["Content Detector Services<br/>configurable (8080)/TCP<br/>HTTP/HTTPS<br/>Optional TLS<br/>APIs: /api/v1/text/*"]
        Chunkers["Chunker Services<br/>configurable (8085)/TCP<br/>gRPC/HTTP2<br/>Optional mTLS<br/>RPCs: ChunkerTokenization"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>No encryption<br/>Traces + Metrics"]
    end

    %% Inbound flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>Optional TLS 1.2+ (rustls/ring)<br/>Auth: X-Forwarded-Access-Token<br/>→ Bearer rewrite"| GuardrailsAPI
    Client -->|"HTTP 8034/TCP<br/>No TLS<br/>/health, /info"| HealthAPI

    %% Generation egress
    GuardrailsAPI -->|"gRPC/HTTP2<br/>Optional mTLS (tonic)<br/>Client certs"| TGIS
    GuardrailsAPI -->|"gRPC/HTTP2<br/>Optional mTLS (tonic)<br/>Client certs"| CaikitNLP
    GuardrailsAPI -->|"HTTP/HTTPS<br/>Optional TLS (hyper-rustls)<br/>Bearer token (env var)"| vLLM

    %% Detection egress
    GuardrailsAPI -->|"HTTP/HTTPS<br/>Optional TLS (hyper-rustls)<br/>detector-id header"| Detectors
    GuardrailsAPI -->|"gRPC/HTTP2<br/>Optional mTLS (tonic)<br/>Client certs"| Chunkers

    %% Observability egress
    GuardrailsAPI -.->|"gRPC or HTTP<br/>OTLP export"| OTLP

    %% Health checks to downstream
    HealthAPI -.->|"health()"| TGIS
    HealthAPI -.->|"health()"| CaikitNLP
    HealthAPI -.->|"GET /health"| Detectors
    HealthAPI -.->|"health()"| Chunkers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef generation fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef detection fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class GuardrailsAPI,HealthAPI ingress
    class TGIS,CaikitNLP,vLLM generation
    class Detectors,Chunkers detection
    class OTLP observability
