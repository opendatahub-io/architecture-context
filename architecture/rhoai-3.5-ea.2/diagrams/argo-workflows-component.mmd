graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB

        subgraph Controller["workflow-controller"]
            WFC[Workflow Controller<br/>Go Operator<br/>9090/TCP metrics, 6060/TCP health]
            CronWorker[Cron Worker<br/>8 workers]
            PodCleanup[Pod Cleanup<br/>4 workers]
            ArchiveWorker[Archive Worker<br/>8 workers]
            WorkflowWorkers[Workflow Workers<br/>32 workers]
            LeaderElection[Leader Election<br/>coordination.k8s.io Lease]

            WFC --> CronWorker
            WFC --> PodCleanup
            WFC --> ArchiveWorker
            WFC --> WorkflowWorkers
            WFC --> LeaderElection
        end

        subgraph Executor["argoexec (sidecar)"]
            Emissary[Emissary Executor<br/>Wraps user container]
            ArtifactMgr[Artifact Manager<br/>Upload/Download]
            OutputCollector[Output Collector<br/>stdout/stderr capture]

            Emissary --> ArtifactMgr
            Emissary --> OutputCollector
        end
    end

    %% CRDs
    WorkflowCR[Workflow CR<br/>argoproj.io/v1alpha1]
    WFTemplateCR[WorkflowTemplate CR]
    ClusterWFTemplateCR[ClusterWorkflowTemplate CR]
    CronWorkflowCR[CronWorkflow CR]
    TaskSetCR[WorkflowTaskSet CR]
    TaskResultCR[WorkflowTaskResult CR]
    ArtifactGCCR[WorkflowArtifactGCTask CR]

    %% External actors
    DSP[Data Science Pipelines<br/>API Server]
    K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]

    %% Flows
    DSP -->|creates| WorkflowCR
    WorkflowCR -->|watched by| WFC
    CronWorkflowCR -->|watched by| CronWorker
    WFC -->|creates Pods with| Emissary
    WFC -->|manages| TaskSetCR
    Emissary -->|creates| TaskResultCR
    WFC -->|manages| ArtifactGCCR
    WFC -->|reads| WFTemplateCR
    WFC -->|reads| ClusterWFTemplateCR

    WFC -->|CRUD via| K8sAPI
    Emissary -->|reports results via| K8sAPI

    %% External dependencies
    ArtifactStore[S3 / GCS / Azure Blob<br/>Artifact Storage<br/>443/TCP HTTPS]
    SQLDb[PostgreSQL / MySQL<br/>Workflow Archive<br/>5432/3306 TCP]
    Prometheus[Prometheus<br/>Metrics Scrape<br/>9090/TCP HTTP]

    ArtifactMgr -->|upload/download| ArtifactStore
    ArchiveWorker -->|archive workflows| SQLDb
    Prometheus -->|scrapes| WFC

