graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway<br/>HTTPRoute (KServe-managed)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)"]
        KRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP → 8000/TCP<br/>TLS 1.2+<br/>SubjectAccessReview"]
    end

    subgraph Application["APPLICATION (vLLM Gaudi Pod)"]
        direction TB
        VLLM["vLLM Server (vllm-gaudi)<br/>odh-vllm-gaudi-rhel9<br/>8000/TCP HTTP (plaintext)<br/>UID: 2000 (non-root)<br/><br/>Endpoints:<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>POST /v1/embeddings<br/>GET /health (unauthenticated)"]

        FIPSWarning["FIPS GAP<br/>OpenSSL FIPS provider<br/>REMOVED at build time"]
    end

    subgraph HardwareLayer["HARDWARE LAYER (Intel Gaudi)"]
        HPU["Intel Gaudi 2/3 HPU<br/>Synapse AI 1.23.0<br/>habanalabs-thunk"]
        PeerHPU["Peer HPU Workers<br/>(rank 1-N)<br/>HCCL collective ops"]
    end

    subgraph RuntimeEgress["EGRESS (Runtime)"]
        ModelStorage["Model Storage<br/>PVC / S3<br/>HTTPS/443 TLS 1.2+<br/>AWS IAM / ServiceAccount"]
    end

    subgraph BuildEgress["EGRESS (Build-Time Only)"]
        Habana["Habana Artifactory<br/>443/TCP HTTPS"]
        PyPI["PyPI<br/>443/TCP HTTPS"]
        GitHub["GitHub<br/>443/TCP HTTPS"]
        BuildWarning["BUILD HERMETICITY GAP<br/>hermetic: false<br/>No lock files"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>SubjectAccessReview"| KRBAC
    KRBAC -->|"HTTP/8000<br/>Plaintext (localhost)<br/>Pre-authenticated"| VLLM
    VLLM -->|"Synapse AI<br/>Device API"| HPU
    HPU -->|"HCCL (libfabric/verbs)<br/>Ephemeral ports<br/>No encryption"| PeerHPU
    VLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| ModelStorage

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#e8d5f5,stroke:#7b2d8e,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef buildonly fill:#e0e0e0,stroke:#999,stroke-width:1px,stroke-dasharray: 3 3

    class Client external
    class Gateway,KRBAC ingress
    class VLLM application
    class HPU,PeerHPU hardware
    class ModelStorage egress
    class FIPSWarning,BuildWarning warning
    class Habana,PyPI,GitHub buildonly
