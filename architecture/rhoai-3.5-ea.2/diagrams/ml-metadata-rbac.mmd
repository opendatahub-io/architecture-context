graph TD
    subgraph Legend["RBAC Overview"]
        direction TB
        Note["ML Metadata does not define<br/>Kubernetes RBAC resources.<br/><br/>It is a standalone gRPC service<br/>that relies on network-level security<br/>and optional gRPC mTLS for access control."]
    end

    subgraph TransportSecurity["Transport-Level Access Control"]
        direction TB
        SSLConfig["SSLConfig (Protobuf)<br/>Configures gRPC TLS"]
        ServerCert["Server Certificate<br/>(server_key + server_cert)"]
        ClientCA["Custom CA<br/>(custom_ca)"]
        ClientVerify["client_verify Flag<br/>(mTLS Enforcement)"]

        SSLConfig --> ServerCert
        SSLConfig --> ClientCA
        SSLConfig --> ClientVerify
    end

    subgraph AccessPatterns["Access Patterns"]
        direction TB
        DSP["Data Science Pipelines"]
        PipelineUI["Pipeline UI"]
        PythonClient["Python Client (ml-metadata)"]

        DSP -->|"gRPC 8080/TCP<br/>Optional mTLS"| GRPCEndpoint["MetadataStoreService<br/>40+ RPC Methods"]
        PipelineUI -->|"gRPC 8080/TCP<br/>Optional mTLS"| GRPCEndpoint
        PythonClient -->|"gRPC 8080/TCP<br/>Optional mTLS"| GRPCEndpoint
    end

    subgraph DatabaseAuth["Database Authentication"]
        direction TB
        DBCreds["Database Credentials<br/>(Opaque Secret)"]
        MySQLAuth["MySQL: Username/password<br/>+ SSLOptions<br/>(cert/key/ca/capath/cipher/<br/>verify_server_cert)"]
        PGAuth["PostgreSQL: Username/password<br/>+ SSLOptions<br/>(sslmode/sslcert/sslkey/<br/>sslrootcert)"]

        DBCreds --> MySQLAuth
        DBCreds --> PGAuth
    end

    ClientVerify -.->|"enforces"| GRPCEndpoint

    %% Styling
    style Note fill:#f9f9f9,stroke:#999,stroke-width:1px
    style SSLConfig fill:#4a90e2,stroke:#333,color:#fff
    style ServerCert fill:#dae8fc,stroke:#6c8ebf
    style ClientCA fill:#dae8fc,stroke:#6c8ebf
    style ClientVerify fill:#f5a623,stroke:#333,color:#fff
    style GRPCEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelineUI fill:#7ed321,stroke:#333,color:#fff
    style PythonClient fill:#7ed321,stroke:#333,color:#fff
    style DBCreds fill:#f8cecc,stroke:#b85450
    style MySQLAuth fill:#fff2cc,stroke:#d6b656
    style PGAuth fill:#fff2cc,stroke:#d6b656
