graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Services"]
            RESTServer["REST Server<br/>(FastAPI/Uvicorn)<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>(grpcio)<br/>Port 8081/TCP"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>Port 8082/TCP"]
        end

        subgraph DataLayer["Data Plane"]
            DataPlane["DataPlane Handler<br/>(Inference Orchestrator)"]
            ModelRegistry["Model Registry<br/>(Model Lifecycle)"]
            ModelRepository["Model Repository<br/>(Filesystem Loader)"]
            Middleware["Middleware Chain<br/>(CloudEvents, Caching)"]
        end

        subgraph Runtimes["Bundled Runtimes (RHOAI)"]
            SKLearn["mlserver-sklearn<br/>(SKLearnModel)"]
            XGBoost["mlserver-xgboost<br/>(XGBoostModel)"]
            LightGBM["mlserver-lightgbm<br/>(LightGBMModel)"]
            ONNX["mlserver-onnx<br/>(OnnxModel)"]
        end

        subgraph Advanced["Advanced Features"]
            AdaptiveBatch["Adaptive Batching<br/>(per-model config)"]
            ParallelWorkers["Parallel Workers<br/>(multiprocessing pool)"]
            ResponseCache["Response Cache<br/>(in-memory LRU)"]
            KafkaHandler["Kafka Handler<br/>(async inference)"]
        end

        subgraph Security["Security Layer"]
            TrustedRuntimes["Trusted Runtimes Allowlist<br/>(/etc/mlserver/trusted-runtimes.json)"]
        end
    end

    %% Core routing
    RESTServer -->|V2 Dataplane API| DataPlane
    GRPCServer -->|V2 Dataplane API| DataPlane
    KafkaHandler -->|async requests| DataPlane

    %% DataPlane orchestration
    DataPlane --> Middleware
    DataPlane --> ModelRegistry
    DataPlane --> AdaptiveBatch
    DataPlane --> ResponseCache
    ModelRegistry --> ModelRepository

    %% Runtime dispatch
    DataPlane -->|dispatch| SKLearn
    DataPlane -->|dispatch| XGBoost
    DataPlane -->|dispatch| LightGBM
    DataPlane -->|dispatch| ONNX

    %% Security validation
    ModelRepository -->|validates| TrustedRuntimes
    TrustedRuntimes -.->|blocks untrusted| ModelRepository

    %% Parallel workers
    ParallelWorkers -->|IPC queues| DataPlane

    %% Metrics collection
    RESTServer -->|request metrics| MetricsServer
    GRPCServer -->|request metrics| MetricsServer

    %% External interactions
    Client["Client"] -->|HTTP POST /v2/models/.../infer| RESTServer
    Client -->|gRPC ModelInfer| GRPCServer
    Kubelet["Kubernetes Kubelet"] -->|GET /v2/health/live| RESTServer
    Kubelet -->|GET /v2/health/ready| RESTServer
    PromScraper["Prometheus"] -->|GET /metrics| MetricsServer
    ModelStorage["/mnt/models<br/>(PVC/Init Container)"] -->|model artifacts| ModelRepository

    %% Styling
    style RESTServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#5b6abf,stroke:#333,color:#fff
    style ModelRegistry fill:#5b6abf,stroke:#333,color:#fff
    style ModelRepository fill:#5b6abf,stroke:#333,color:#fff
    style Middleware fill:#5b6abf,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff
    style TrustedRuntimes fill:#e74c3c,stroke:#333,color:#fff
    style AdaptiveBatch fill:#f5a623,stroke:#333,color:#fff
    style ParallelWorkers fill:#f5a623,stroke:#333,color:#fff
    style ResponseCache fill:#f5a623,stroke:#333,color:#fff
    style KafkaHandler fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style Kubelet fill:#f9f9f9,stroke:#999
    style PromScraper fill:#f9f9f9,stroke:#999
    style ModelStorage fill:#f9f9f9,stroke:#999
