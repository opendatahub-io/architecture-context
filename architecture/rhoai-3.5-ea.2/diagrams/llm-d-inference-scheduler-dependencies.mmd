graph LR
    LLMDScheduler["llm-d Inference<br/>Scheduler"]

    %% External Dependencies (Required)
    LLMDScheduler -->|"ext-proc routing<br/>gRPC/9002"| EnvoyGW["Envoy Gateway<br/>(with ext-proc)<br/>Gateway API compat"]
    LLMDScheduler -->|"CRD types<br/>Go library"| GatewayAPICRDs["Gateway API CRDs<br/>v1.5.1"]
    LLMDScheduler -->|"scheduling framework<br/>Go library"| GIE["Gateway API Inference<br/>Extension (GIE)<br/>v1.5.0"]
    LLMDScheduler -->|"model serving<br/>metrics + API"| vLLM["vLLM<br/>0.8.x+"]

    %% External Dependencies (Optional)
    LLMDScheduler -.->|"mTLS / traffic mgmt<br/>(data parallel mode)"| Istio["Istio<br/>1.28+"]
    LLMDScheduler -.->|"KV cache indexer<br/>Go library"| KVCacheLib["llm-d-kv-cache<br/>v0.7.1"]
    LLMDScheduler -.->|"trace export<br/>gRPC/4317"| OTELCollector["OpenTelemetry<br/>Collector"]
    LLMDScheduler -.->|"tokenizer download<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]
    LLMDScheduler -.->|"KV cache events<br/>ZMQ/5556-5557"| ZeroMQ["ZeroMQ v4"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"CRD Watch<br/>HTTPS/443"| K8sAPI["Kubernetes<br/>API Server"]
    LLMDScheduler -->|"metrics scraping<br/>HTTP/HTTPS"| vLLMMetrics["vLLM Model Server<br/>Pods (metrics)"]
    LLMDScheduler -->|"KV cache events<br/>ZMQ PUB/SUB"| vLLMKV["vLLM Model Server<br/>Pods (KV events)"]
    LLMDScheduler -->|"inference requests<br/>HTTP/HTTPS"| vLLMAPI["vLLM Model Server<br/>Pods (API)"]

    %% Integration Points (consumed by others)
    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTP/9090"| LLMDScheduler

    %% Styling
    style LLMDScheduler fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external (dark gray)
    style EnvoyGW fill:#666,stroke:#333,color:#fff
    style GatewayAPICRDs fill:#666,stroke:#333,color:#fff
    style GIE fill:#666,stroke:#333,color:#fff
    style vLLM fill:#666,stroke:#333,color:#fff

    %% Optional external (light gray)
    style Istio fill:#999,stroke:#333,color:#fff
    style KVCacheLib fill:#999,stroke:#333,color:#fff
    style OTELCollector fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style ZeroMQ fill:#999,stroke:#333,color:#fff

    %% Internal platform (green)
    style K8sAPI fill:#7ed321,stroke:#333,color:#fff
    style vLLMMetrics fill:#7ed321,stroke:#333,color:#fff
    style vLLMKV fill:#7ed321,stroke:#333,color:#fff
    style vLLMAPI fill:#7ed321,stroke:#333,color:#fff

    %% Consumers (orange)
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
