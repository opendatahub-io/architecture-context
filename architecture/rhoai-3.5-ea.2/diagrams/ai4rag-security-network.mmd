graph TB
    subgraph Consumer["CONSUMING SERVICE (Trusted - Same Process)"]
        KFP["Kubeflow Pipeline Component"]
        CLI["CLI Tool"]
        Notebook["Jupyter Notebook"]
    end

    subgraph Library["AI4RAG LIBRARY (In-Process, No Network Ports)"]
        direction TB

        subgraph Core["Core Orchestration"]
            Experiment["AI4RAGExperiment"]
            MPS["ModelsPreSelector"]
            GAM["GAMOptimizer"]
        end

        subgraph Pipeline["RAG Pipeline"]
            SimpleRAG["SimpleRAGTemplate"]
            Retriever["Retriever"]
            LCChunker["LangChainChunker<br/>(tiktoken)"]
            DocChunker["DoclingChunker"]
        end

        subgraph Eval["Evaluation"]
            UnitxtEval["UnitxtEvaluator"]
        end

        subgraph VS["Vector Store Adapters"]
            OgxVS["OGXVectorStore"]
            ChromaVS["ChromaVectorStore"]
        end

        subgraph Models["Model Adapters"]
            OgxFM["OGXFoundationModel"]
            OgxEmb["OGXEmbeddingModel"]
        end

        subgraph Events["Event Handlers"]
            LocalEH["LocalEventHandler<br/>(JSON to disk)"]
            KFPEH["KFPEventHandler<br/>(in-memory)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OGX["OGX Server<br/>Configurable Port<br/>HTTPS / TLS 1.2+<br/>API Key (Bearer)"]
        ChromaDB["ChromaDB<br/>(in-memory, ephemeral)<br/>No Network"]
    end

    %% Consumer to Library (in-process, no network)
    KFP -->|Python import<br/>In-process<br/>No network| Experiment
    CLI -->|Python import<br/>In-process<br/>No network| Experiment
    Notebook -->|Python import<br/>In-process<br/>No network| Experiment

    %% Internal flows (all in-process)
    Experiment --> MPS
    Experiment --> GAM
    Experiment --> SimpleRAG
    Experiment --> UnitxtEval
    SimpleRAG --> Retriever
    Retriever --> OgxVS
    Retriever --> ChromaVS
    SimpleRAG --> OgxFM
    Experiment --> LocalEH
    Experiment --> KFPEH

    %% Egress flows (the ONLY network boundary)
    OgxVS -->|"HTTPS / Configurable Port<br/>TLS 1.2+<br/>API Key (Bearer)<br/>vector_stores + vector_io"| OGX
    OgxFM -->|"HTTPS / Configurable Port<br/>TLS 1.2+<br/>API Key (Bearer)<br/>chat.completions"| OGX
    OgxEmb -->|"HTTPS / Configurable Port<br/>TLS 1.2+<br/>API Key (Bearer)<br/>embeddings.create"| OGX
    ChromaVS -->|"In-process<br/>No network<br/>No auth"| ChromaDB

    %% Styling
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef library fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    classDef core fill:#4a90e2,color:#fff,stroke:#333
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ogx fill:#f5a623,stroke:#333,stroke-width:2px

    class KFP,CLI,Notebook consumer
    class Experiment,MPS,GAM,SimpleRAG,Retriever,LCChunker,DocChunker,UnitxtEval,OgxVS,ChromaVS,OgxFM,OgxEmb,LocalEH,KFPEH library
    class ChromaDB external
    class OGX ogx
