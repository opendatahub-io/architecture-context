graph TB
    subgraph External["External Clients"]
        Agent["AI Agent<br/>(Claude / GPT / Llama)"]
    end

    subgraph RHOAIMCPServer["RHOAI MCP Server"]
        direction TB

        subgraph Transport["Transport Layer"]
            SSE["SSE Endpoint<br/>/sse :8000"]
            HTTP["Streamable HTTP<br/>/messages :8000"]
            STDIO["stdio Transport"]
            Health["Health Endpoint<br/>/health :8000"]
        end

        subgraph Auth["Authentication & Authorization"]
            OIDCMiddleware["OIDC Auth Middleware<br/>(ASGI)"]
            JWTValidator["JWT Validator<br/>(JWKS)"]
            TokenReview["TokenReview Validator<br/>(OCP OAuth)"]
            RBACFilter["RBAC Tool Filter<br/>(SubjectAccessReview)"]
            WorkflowToken["Workflow Token<br/>(HMAC-SHA256)"]
        end

        subgraph Core["Core Framework"]
            FastMCP["FastMCP Server"]
            PluginMgr["Plugin Manager<br/>(pluggy)"]
            K8sClient["K8s Client<br/>(kubernetes-python)"]
            Config["Config<br/>(pydantic-settings)"]
        end

        subgraph DomainPlugins["Domain Plugins"]
            Notebooks["Notebooks Plugin<br/>(kubeflow.org/Notebook)"]
            Inference["Inference Plugin<br/>(serving.kserve.io)"]
            Pipelines["Pipelines Plugin<br/>(opendatahub.io/DSPA)"]
            Training["Training Plugin<br/>(trainer.kubeflow.org)"]
            Connections["Connections Plugin<br/>(Secrets)"]
            Storage["Storage Plugin<br/>(PVCs)"]
            ModelReg["Model Registry Plugin<br/>(REST API)"]
            Quickstarts["Quickstarts Plugin<br/>(Helm)"]
            Projects["Projects Plugin<br/>(OpenShift)"]
        end

        subgraph CompositePlugins["Composite Plugins"]
            ClusterComposite["Cluster Composites<br/>(cluster_summary)"]
            TrainingComposite["Training Composites<br/>(unified training)"]
            MetaComposite["Meta Composites<br/>(suggest_tools)"]
            PlannerComposite["Planner Composites<br/>(model recommend)"]
        end
    end

    subgraph PlatformServices["Platform Services"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
        ModelRegSvc["Model Registry Service<br/>8080/8443 HTTP/HTTPS"]
        ModelCatSvc["Model Catalog Service<br/>8080/8443 HTTP/HTTPS"]
        PlannerSvc["Planner Service<br/>8000/TCP HTTP"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS"]
    end

    %% External connections
    Agent -->|"MCP over SSE/HTTP"| SSE
    Agent -->|"MCP over SSE/HTTP"| HTTP
    Agent -->|"MCP over stdio"| STDIO

    %% Auth flow
    SSE --> OIDCMiddleware
    HTTP --> OIDCMiddleware
    OIDCMiddleware --> JWTValidator
    OIDCMiddleware --> TokenReview
    OIDCMiddleware --> RBACFilter
    RBACFilter --> FastMCP

    %% Core connections
    FastMCP --> PluginMgr
    PluginMgr --> DomainPlugins
    PluginMgr --> CompositePlugins
    FastMCP --> K8sClient
    FastMCP --> Config

    %% Domain plugin to K8s
    Notebooks --> K8sClient
    Inference --> K8sClient
    Pipelines --> K8sClient
    Training --> K8sClient
    Connections --> K8sClient
    Storage --> K8sClient
    Projects --> K8sClient

    %% External service connections
    K8sClient -->|"HTTPS/443<br/>Bearer Token"| K8sAPI
    ModelReg -->|"HTTP(S)/8080-8443"| ModelRegSvc
    ModelReg -->|"HTTP(S)/8080-8443"| ModelCatSvc
    PlannerComposite -->|"HTTP/8000"| PlannerSvc
    JWTValidator -->|"HTTPS/443<br/>JWKS"| OIDCProvider
    TokenReview -->|"HTTPS/443<br/>TokenReview API"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef transport fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef core fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef domain fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef composite fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Agent external
    class SSE,HTTP,STDIO,Health transport
    class OIDCMiddleware,JWTValidator,TokenReview,RBACFilter,WorkflowToken auth
    class FastMCP,PluginMgr,K8sClient,Config core
    class Notebooks,Inference,Pipelines,Training,Connections,Storage,ModelReg,Quickstarts,Projects domain
    class ClusterComposite,TrainingComposite,MetaComposite,PlannerComposite composite
    class K8sAPI,ModelRegSvc,ModelCatSvc,PlannerSvc,OIDCProvider platform
