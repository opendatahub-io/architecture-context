graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        Operator["TrustyAI lm-eval-controller<br/>Creates Job + ConfigMap + Secrets"]
    end

    subgraph JobPod["JOB POD (Batch - No Ingress)"]
        direction TB

        subgraph SecurityControls["Security Controls"]
            Sanitizer["Error Sanitizer<br/>Strips: Bearer tokens, API keys,<br/>URL userinfo, query params"]
            CAValidator["CA Cert Validator<br/>Rejects symlinks<br/>(anti-traversal)"]
            PathGuard["Job Spec Guard<br/>Confined to /meta/<br/>(anti-CWE-22)"]
        end

        subgraph Core["Evaluation Core"]
            Adapter["LMEval Adapter<br/>main.py"]
            Engine["lm-evaluation-harness<br/>lm_eval/"]
        end

        subgraph Inputs["Mounted Inputs"]
            JobSpec["/meta/job.json<br/>(ConfigMap)"]
            Creds["Model Auth Secret<br/>(Volume mount)<br/>API key + HF token"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (All Egress - TLS 1.2+)"]
        direction TB

        ModelEndpoint["Model Inference Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Auth: Bearer Token (OPENAI_API_KEY)<br/>POST /v1/completions"]

        EvalHubSvc["EvalHub Callback Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token<br/>Status lifecycle callbacks"]

        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Basic / Docker config<br/>Push via skopeo"]

        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (HF_TOKEN)<br/>Datasets + tokenizers"]

        S3Store["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+ (AWS_CA_BUNDLE)<br/>Auth: AWS IAM credentials<br/>Model/dataset files"]

        MLflowSvc["MLflow Tracking Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token<br/>Experiment metrics"]
    end

    %% Control plane flow
    Operator -->|"Creates Job<br/>Mounts ConfigMap + Secrets"| JobPod

    %% Egress flows
    Engine -->|"HTTPS/443<br/>TLS 1.2+ (custom CA)<br/>Bearer Token<br/>up to 128 concurrent"| ModelEndpoint
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Sanitized errors only"| EvalHubSvc
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Basic auth"| OCIReg
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN (optional)<br/>Disabled in offline mode"| HFHub
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3Store
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| MLflowSvc

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef jobpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef input fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Operator controlplane
    class Adapter,Engine jobpod
    class Sanitizer,CAValidator,PathGuard security
    class JobSpec,Creds input
    class ModelEndpoint,EvalHubSvc,OCIReg,HFHub,S3Store,MLflowSvc external
