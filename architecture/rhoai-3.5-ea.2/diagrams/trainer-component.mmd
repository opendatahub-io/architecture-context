graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        Controller["trainer-controller-manager<br/>(Go, controller-runtime)"]
        Webhooks["Validation Webhooks<br/>9443/TCP HTTPS"]
        CertController["cert-controller (OPA)<br/>Certificate Management"]

        subgraph Plugins["Runtime Framework Plugins"]
            JobSetPlugin["JobSet Plugin<br/>Builds JobSet workloads"]
            TorchPlugin["Torch Plugin<br/>PyTorch torchrun/torchtune"]
            MPIPlugin["MPI Plugin<br/>SSH keys, hostfiles"]
            CoschedulingPlugin["Coscheduling Plugin<br/>PodGroup (scheduler-plugins)"]
            VolcanoPlugin["Volcano Plugin<br/>PodGroup (Volcano)"]
        end

        subgraph RHAI["RHOAI Extensions (pkg/rhai/)"]
            Progression["RHAI Progression Tracking<br/>Polls /metrics on training pods"]
            NetworkPolicyMgr["RHAI NetworkPolicy Manager<br/>Per-TrainJob pod isolation"]
        end

        Controller --> Plugins
        Controller --> RHAI
        Controller -->|validates via| Webhooks
        CertController -->|provisions certs| Webhooks
    end

    %% CRDs
    User["User / Dashboard"] -->|creates| TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    TrainJobCR -->|watched by| Controller
    Controller -->|resolves| RuntimeCR["TrainingRuntime /<br/>ClusterTrainingRuntime"]

    %% Created Resources
    Controller -->|creates| JobSet["JobSet<br/>(jobset.x-k8s.io/v1alpha2)"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy<br/>(per-TrainJob)"]
    Controller -->|creates| PodGroup["PodGroup<br/>(coscheduling / Volcano)"]
    Controller -->|creates| MPISecret["MPI SSH Secret<br/>(per MPI TrainJob)"]
    Controller -->|creates| MPIConfigMap["MPI Hostfile ConfigMap"]

    %% Training Pods
    JobSet -->|manages| TrainingPods["Training Pods<br/>(PyTorch / MPI workers)"]
    Progression -->|polls /metrics<br/>28080/TCP HTTP| TrainingPods

    %% External
    Controller -->|CRUD via| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Prometheus["OpenShift Monitoring<br/>(Prometheus)"] -->|scrapes 8443/TCP HTTPS| Controller

    %% Styles
    style Controller fill:#4a90e2,color:#fff
    style Webhooks fill:#4a90e2,color:#fff
    style CertController fill:#4a90e2,color:#fff
    style JobSetPlugin fill:#6baed6
    style TorchPlugin fill:#6baed6
    style MPIPlugin fill:#6baed6
    style CoschedulingPlugin fill:#6baed6
    style VolcanoPlugin fill:#6baed6
    style Progression fill:#e6550d,color:#fff
    style NetworkPolicyMgr fill:#e6550d,color:#fff
    style TrainJobCR fill:#f5a623
    style RuntimeCR fill:#f5a623
    style JobSet fill:#7ed321
    style NetworkPolicy fill:#7ed321
    style PodGroup fill:#7ed321
    style MPISecret fill:#7ed321
    style MPIConfigMap fill:#7ed321
    style TrainingPods fill:#9e9ac8
    style K8sAPI fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style User fill:#fff,stroke:#333
