graph LR
    WBO["workbenches-operator<br/>(Workbenches Controller)"]

    %% Internal Platform Dependencies (upstream)
    Orchestrator["Platform Orchestrator<br/>(rhods-operator /<br/>opendatahub-operator)"] -->|"creates Workbenches CR<br/>projects config"| WBO
    WBO -->|"monitors deployments<br/>(label selector)"| NotebookCtrl["Kubeflow Notebook Controller"]

    %% Infrastructure Dependencies
    WBO -->|"CRUD operations<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    WBO -->|"leader election<br/>(Lease objects)"| LeaderElection["Coordination API<br/>(coordination.k8s.io)"]

    %% Go Module Dependencies
    WBO -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    WBO -->|"API types"| APIMachinery["k8s.io/apimachinery<br/>v0.35.3"]
    WBO -->|"API client"| ClientGo["k8s.io/client-go<br/>v0.35.3"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTPS/8443"| WBO

    %% Future Dependencies (not yet active)
    WBO -.->|"planned: manage notebooks"| NotebookCRD["Notebook CRD<br/>kubeflow.org/v1"]
    WBO -.->|"planned: manage images"| ImageStream["ImageStream<br/>image.openshift.io/v1"]
    WBO -.->|"planned: GPU profiles"| HardwareProfile["HardwareProfile<br/>infrastructure.platform.<br/>opendatahub.io/v1"]

    %% Styling
    style WBO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style NotebookCtrl fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style LeaderElection fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style APIMachinery fill:#999,stroke:#333,color:#fff
    style ClientGo fill:#999,stroke:#333,color:#fff
    style NotebookCRD fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style ImageStream fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style HardwareProfile fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
