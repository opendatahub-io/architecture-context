graph TB
    subgraph NotebooksRepo["Notebooks Repository (Container Image Build System)"]
        direction TB

        subgraph BaseImages["Base Images"]
            BaseImageCPU["base-image-cpu<br/>(CentOS Stream 9)<br/>Python 3.12"]
            BaseImageCUDA13["AIPCC CUDA 13.0<br/>quay.io/aipcc/base-images/cuda-13.0"]
            BaseImageCUDA12["AIPCC CUDA 12.9<br/>quay.io/aipcc/base-images/cuda-12.9"]
            BaseImageROCm["AIPCC ROCm 7.1<br/>quay.io/aipcc/base-images/rocm-7.1"]
        end

        subgraph JupyterWorkbenches["Jupyter Workbenches (Port 8888/TCP)"]
            JupMinCPU["jupyter-minimal<br/>CPU"]
            JupMinCUDA["jupyter-minimal<br/>CUDA 13.0"]
            JupMinROCm["jupyter-minimal<br/>ROCm 7.1"]
            JupDS["jupyter-datascience<br/>CPU"]
            JupPT["jupyter-pytorch<br/>CUDA 13.0"]
            JupPTLLM["jupyter-pytorch<br/>+llmcompressor<br/>CUDA 13.0"]
            JupTF["jupyter-tensorflow<br/>CUDA 12.9"]
            JupTAI["jupyter-trustyai<br/>CPU (+ Java 17)"]
        end

        subgraph CodeServerWorkbench["Code Server Workbench (Port 8787/TCP)"]
            CS["codeserver<br/>CPU<br/>VS Code Server 4.106.3"]
            CSNginx["nginx<br/>reverse proxy<br/>Port 8080"]
            CSHttpd["httpd<br/>CGI kernel access<br/>Port 80"]
            CS --- CSNginx
            CS --- CSHttpd
        end

        subgraph PipelineRuntimes["Elyra Pipeline Runtimes (Elyra 4.3.1)"]
            RTMin["runtime-minimal<br/>CPU"]
            RTDS["runtime-datascience<br/>CPU"]
            RTPT["runtime-pytorch<br/>CUDA 13.0"]
            RTPTLLM["runtime-pytorch<br/>+llmcompressor<br/>CUDA 13.0"]
            RTTF["runtime-tensorflow<br/>CUDA 12.9"]
            RTROCmPT["runtime-rocm<br/>-pytorch<br/>ROCm 7.1"]
            RTROCmTF["runtime-rocm<br/>-tensorflow<br/>ROCm 7.1"]
        end

        subgraph Manifests["ImageStream Manifests"]
            ISRhoai["manifests/rhoai/<br/>18 ImageStreams"]
            ISOdh["manifests/odh/<br/>18 ImageStreams"]
        end
    end

    %% Base image relationships
    BaseImageCPU -->|base| JupMinCPU
    BaseImageCPU -->|base| JupDS
    BaseImageCPU -->|base| JupTAI
    BaseImageCPU -->|base| CS
    BaseImageCPU -->|base| RTMin
    BaseImageCPU -->|base| RTDS
    BaseImageCUDA13 -->|base| JupMinCUDA
    BaseImageCUDA13 -->|base| JupPT
    BaseImageCUDA13 -->|base| JupPTLLM
    BaseImageCUDA13 -->|base| RTPT
    BaseImageCUDA13 -->|base| RTPTLLM
    BaseImageCUDA12 -->|base| JupTF
    BaseImageCUDA12 -->|base| RTTF
    BaseImageROCm -->|base| JupMinROCm
    BaseImageROCm -->|base| RTROCmPT
    BaseImageROCm -->|base| RTROCmTF

    %% External consumers
    Operator["rhods-operator"] -->|reads| ISRhoai
    ODHOperator["opendatahub-operator"] -->|reads| ISOdh
    NotebookCtrl["odh-notebook-controller"] -->|deploys pods from| ISRhoai
    Dashboard["RHOAI Dashboard"] -->|reads annotations| ISRhoai
    KFP["Kubeflow Pipelines"] -->|executes| PipelineRuntimes

    %% Build system
    Konflux["Konflux Build Pipeline"] -->|builds| NotebooksRepo
    Cachi2["Cachi2 (Hermeto)"] -->|pre-fetched deps| Konflux
    Quay["quay.io/opendatahub/<br/>workbench-images"] -.->|published to| Konflux

    %% Styling
    style NotebooksRepo fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style BaseImages fill:#fff2cc,stroke:#d6b656
    style JupyterWorkbenches fill:#d5e8d4,stroke:#82b366
    style CodeServerWorkbench fill:#dae8fc,stroke:#6c8ebf
    style PipelineRuntimes fill:#e1d5e7,stroke:#9673a6
    style Manifests fill:#f8cecc,stroke:#b85450
    style Operator fill:#f5a623,stroke:#333
    style ODHOperator fill:#f5a623,stroke:#333
    style NotebookCtrl fill:#f5a623,stroke:#333
    style Dashboard fill:#f5a623,stroke:#333
    style KFP fill:#f5a623,stroke:#333
    style Konflux fill:#999,stroke:#333
    style Cachi2 fill:#999,stroke:#333
    style Quay fill:#999,stroke:#333
