graph LR
    KAP["kube-auth-proxy<br/>Go Reverse Proxy"]

    %% External Go Dependencies
    KAP -->|"OIDC discovery<br/>+ JWT verification"| GoOIDC["coreos/go-oidc/v3<br/>v3.18.0"]
    KAP -->|"JWT parsing<br/>+ validation"| GolangJWT["golang-jwt/jwt/v5<br/>v5.3.0"]
    KAP -->|"HTTP routing"| GorillaMux["gorilla/mux<br/>v1.8.1"]
    KAP -->|"metrics"| Prometheus["prometheus/client_golang<br/>v1.23.2"]
    KAP -->|"config loading"| Viper["spf13/viper<br/>v1.21.0"]

    %% Optional External Dependencies
    KAP -.->|"session store<br/>(optional)"| GoRedis["redis/go-redis/v9<br/>v9.17.0"]
    KAP -.->|"TokenReview API<br/>(optional)"| ClientGo["k8s.io/client-go<br/>v0.35.3"]

    %% Internal Platform Dependencies (Identity Providers)
    KAP -->|"OAuth2/OIDC<br/>auth code flow<br/>443/TCP HTTPS"| OIDCIdP["OIDC Identity Provider<br/>(Keycloak / DEX)"]
    KAP -->|"OAuth2 flow<br/>endpoint auto-discovery<br/>443/TCP HTTPS"| OSAuth["OpenShift OAuth Server"]

    %% Internal Platform Dependencies (K8s/OpenShift APIs)
    KAP -->|"TokenReview<br/>SA token validation<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    KAP -->|"User info enrichment<br/>/users/~<br/>443/TCP HTTPS"| OSUserAPI["OpenShift User API"]
    KAP -->|"Token deletion<br/>on sign-out<br/>443/TCP HTTPS"| OSTokenAPI["OpenShift OAuthAccessToken API"]

    %% Downstream Integrations (consume kube-auth-proxy)
    EnvoyProxy["Envoy Proxy"] -->|"ext_authz<br/>HTTP subrequest<br/>4180/TCP"| KAP
    UpstreamApp["Upstream Application"] ---|"receives authed<br/>requests via<br/>reverse proxy"| KAP

    %% Optional Runtime Dependencies
    KAP -.->|"session persistence<br/>6379/TCP<br/>optional TLS"| Redis["Redis<br/>(Standalone/Sentinel/Cluster)"]

    %% Styling
    style KAP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Go library dependencies
    style GoOIDC fill:#e8e8e8,stroke:#333
    style GolangJWT fill:#e8e8e8,stroke:#333
    style GorillaMux fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Viper fill:#e8e8e8,stroke:#333
    style GoRedis fill:#e8e8e8,stroke:#666,stroke-dasharray:5 5
    style ClientGo fill:#e8e8e8,stroke:#666,stroke-dasharray:5 5

    %% Identity providers
    style OIDCIdP fill:#ffe6cc,stroke:#d79b00
    style OSAuth fill:#ffe6cc,stroke:#d79b00

    %% K8s/OpenShift APIs
    style K8sAPI fill:#d5e8d4,stroke:#82b366
    style OSUserAPI fill:#d5e8d4,stroke:#82b366
    style OSTokenAPI fill:#d5e8d4,stroke:#82b366

    %% Downstream consumers
    style EnvoyProxy fill:#f5a623,stroke:#333
    style UpstreamApp fill:#e8d5f5,stroke:#9673a6

    %% Optional runtime
    style Redis fill:#fff2cc,stroke:#d6b656,stroke-dasharray:5 5
