graph TB
    subgraph "kube-auth-proxy"
        direction TB
        OAuthProxy["OAuthProxy Core<br/>(oauthproxy.go)"]
        SessionChain["Session Chain<br/>buildSessionChain()"]
        K8sTokenMiddleware["K8s Token Middleware<br/>TokenReview Validator"]
        BearerTokenMiddleware["Bearer Token Middleware<br/>JWT / OAuth Token"]
        StoredSessionMiddleware["Stored Session Middleware<br/>Cookie / Redis"]
        AuthDeny["Auth Deny Handler<br/>MLflow-aware errors"]
        HTTPServer["HTTP/HTTPS Server<br/>4180/TCP or 443/TCP"]
        MetricsServer["Metrics Server<br/>Prometheus /metrics"]

        HTTPServer -->|routes| OAuthProxy
        OAuthProxy -->|builds| SessionChain
        SessionChain -->|1st| K8sTokenMiddleware
        SessionChain -->|2nd| BearerTokenMiddleware
        SessionChain -->|3rd| StoredSessionMiddleware
        OAuthProxy -->|on auth failure| AuthDeny
    end

    subgraph "OAuth/OIDC Endpoints"
        direction TB
        SignIn["/oauth2/sign_in"]
        SignOut["/oauth2/sign_out"]
        Start["/oauth2/start"]
        Callback["/oauth2/callback"]
        AuthEndpoint["/oauth2/auth<br/>(ext_authz)"]
        UserInfo["/oauth2/userinfo"]
        CatchAll["/* (reverse proxy)"]
    end

    subgraph "Providers"
        OIDCProvider["OIDC Provider<br/>(providers/oidc.go)"]
        OpenShiftProvider["OpenShift Provider<br/>(providers/openshift.go)"]
    end

    Browser[Browser Client] -->|HTTPS| HTTPServer
    APIClient[API / CLI Client] -->|Bearer Token| HTTPServer
    EnvoyProxy[Envoy Proxy] -->|ext_authz subrequest| AuthEndpoint

    OAuthProxy --> SignIn
    OAuthProxy --> SignOut
    OAuthProxy --> Start
    OAuthProxy --> Callback
    OAuthProxy --> AuthEndpoint
    OAuthProxy --> UserInfo
    OAuthProxy --> CatchAll

    OIDCProvider -->|OIDC Discovery + Token Exchange| IdP["OIDC Identity Provider<br/>(Keycloak / DEX)"]
    OpenShiftProvider -->|OAuth2 + User API| OSAPI["OpenShift OAuth Server"]

    K8sTokenMiddleware -->|TokenReview| K8sAPI["Kubernetes API Server"]
    CatchAll -->|authenticated request<br/>GAP-Auth + X-Forwarded-*| Upstream["Upstream Service"]
    StoredSessionMiddleware -.->|optional| Redis["Redis Session Store"]

    style OAuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style SessionChain fill:#4a90e2,stroke:#333,color:#fff
    style K8sTokenMiddleware fill:#5b9bd5,stroke:#333,color:#fff
    style BearerTokenMiddleware fill:#5b9bd5,stroke:#333,color:#fff
    style StoredSessionMiddleware fill:#5b9bd5,stroke:#333,color:#fff
    style AuthDeny fill:#5b9bd5,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style OIDCProvider fill:#7ed321,stroke:#333
    style OpenShiftProvider fill:#7ed321,stroke:#333
    style IdP fill:#e8e8e8,stroke:#333
    style OSAPI fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Upstream fill:#f5a623,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style Browser fill:#f9f9f9,stroke:#999
    style APIClient fill:#f9f9f9,stroke:#999
    style EnvoyProxy fill:#f5a623,stroke:#333
