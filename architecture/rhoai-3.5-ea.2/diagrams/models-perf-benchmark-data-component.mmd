graph TB
    subgraph DataContainer["odh-model-performance-data (Init Container)"]
        direction TB
        DataDir["data/ Directory<br/>JSON + NDJSON files"]
        CopyCmd["CMD: copy data to<br/>shared volume"]
        DataDir --> CopyCmd
    end

    subgraph IngestionTools["Data Ingestion Tools (CI/Developer only)"]
        direction TB
        APIClient["api-client<br/>Python CLI"]
        KafkaProcessor["kafka-processor<br/>Python CLI"]
        ColdStart["cold-start-vram-data<br/>enrichment script"]
    end

    subgraph DataSchema["Data Entities"]
        direction LR
        Providers["Providers"]
        Models["Models"]
        Evaluations["Evaluations"]
        Performances["Performances"]
        Validations["Validations"]
        VariantGroups["Variant Groups"]
    end

    %% Ingestion flows
    ModelValidationAPI["model-validation API<br/>(REST v1)"] -->|GET /api/v1/*<br/>HTTPS| APIClient
    KafkaBroker["Kafka / Redpanda<br/>9092/TCP"] -->|CDC Events<br/>Kafka Protocol| KafkaProcessor

    APIClient -->|writes JSON/NDJSON| DataDir
    KafkaProcessor -->|writes JSON/NDJSON| DataDir
    ColdStart -->|enriches metadata| DataDir

    %% Data entity types
    DataDir --- Providers
    DataDir --- Models
    DataDir --- Evaluations
    DataDir --- Performances
    DataDir --- Validations
    DataDir --- VariantGroups

    %% Runtime deployment
    CopyCmd -->|copies to<br/>emptyDir volume| SharedVolume["Shared emptyDir Volume"]
    SharedVolume -->|reads at startup| ModelCatalog["model-catalog<br/>(model-registry)"]

    %% Operator management
    ModelRegistryOp["model-registry-operator"] -.->|manages Deployment<br/>referencing init container| DataContainer

    %% Build
    KonfluxBuild["Konflux Build<br/>Dockerfile.konflux"] -->|builds UBI 9 minimal<br/>data image| DataContainer

    %% Styling
    style DataContainer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style APIClient fill:#7ed321,stroke:#333
    style KafkaProcessor fill:#7ed321,stroke:#333
    style ColdStart fill:#7ed321,stroke:#333
    style ModelValidationAPI fill:#e8e8e8,stroke:#333
    style KafkaBroker fill:#e8e8e8,stroke:#333
    style ModelCatalog fill:#f5a623,stroke:#333
    style ModelRegistryOp fill:#f5a623,stroke:#333
    style SharedVolume fill:#d5e8d4,stroke:#82b366
    style KonfluxBuild fill:#e8e8e8,stroke:#333
    style DataDir fill:#4a90e2,stroke:#333,color:#fff
    style CopyCmd fill:#4a90e2,stroke:#333,color:#fff
