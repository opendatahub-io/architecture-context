graph LR
    AGPP["AI Gateway<br/>Payload Processing"]

    %% External Dependencies (Required)
    AGPP -->|"ext_proc server,<br/>plugin registry,<br/>controller runner"| LLMD["llm-d IPP Framework<br/>v0.1.0-rc.1"]
    AGPP -->|"CRD reconciliation"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    AGPP -->|"HTTPRoute types"| GatewayAPI["Gateway API<br/>v1.5.1"]
    AGPP -->|"SigV4 signing<br/>(Bedrock auth)"| AWSSDK["aws-sdk-go-v2<br/>v1.42.0"]
    AGPP -->|"ServiceEntry,<br/>DestinationRule,<br/>EnvoyFilter"| Istio["Istio Service Mesh<br/>≥1.25"]
    AGPP -->|"HTTPRoute CRDs"| GatewayAPICRDs["Gateway API CRDs<br/>≥v1.3.0"]

    %% Internal Platform Dependencies
    AGPP -->|"HTTPRoute parentRef<br/>(traffic routing)"| PlatformGW["Platform Gateway<br/>(maas-default-gateway)"]
    AGPP -->|"ServiceEntry +<br/>DestinationRule<br/>(TLS origination)"| IstioCP["Istio Control Plane"]
    AGPP -.->|"content safety<br/>HTTP POST"| NeMo["NeMo Guardrails<br/>(optional)"]
    AGPP -.->|"backward compat<br/>CRD watch"| LegacyMaaS["Legacy MaaS Controller<br/>(maas.opendatahub.io)"]

    %% External Provider Integrations
    AGPP -->|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API<br/>api.openai.com"]
    AGPP -->|"HTTPS/443<br/>x-api-key"| Anthropic["Anthropic API<br/>api.anthropic.com"]
    AGPP -->|"HTTPS/443<br/>api-key header"| Azure["Azure OpenAI<br/>*.openai.azure.com"]
    AGPP -->|"HTTPS/443<br/>AWS SigV4"| Bedrock["AWS Bedrock<br/>bedrock-runtime.*.amazonaws.com"]
    AGPP -->|"HTTPS/443<br/>Bearer Token"| Vertex["Google Vertex AI<br/>*-aiplatform.googleapis.com"]

    %% Infrastructure
    AGPP -->|"CRD watches,<br/>resource creation<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]

