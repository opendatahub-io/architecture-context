graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        MRReconciler["ModelRegistryReconciler<br/>(Controller)"]
        MCReconciler["ModelCatalogReconciler<br/>(Controller)"]
        MigrationMgr["StorageMigrationManager<br/>(Migration System)"]
        WebhookMgr["Webhook Manager<br/>(Admission Webhooks)"]

        MRReconciler -->|"triggers on profile change"| MigrationMgr
        WebhookMgr -->|"defaults & validates"| MRReconciler
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(v1beta1)"]
    ModelRegistryCRLegacy["ModelRegistry CR<br/>(v1alpha1 - deprecated)"]

    %% Per-Instance Resources Created by ModelRegistryReconciler
    subgraph PerInstance["Per-Registry Instance Resources"]
        direction TB
        RegistryDeploy["Registry Deployment<br/>(model-registry REST + kube-rbac-proxy)"]
        RegistrySvc["Service<br/>{name}:8443/TCP"]
        PostgresDeploy["PostgreSQL Deployment<br/>(optional auto-provisioned)"]
        PostgresSvc["PostgreSQL Service<br/>{name}-postgres:5432/TCP"]
        NetPol["NetworkPolicy<br/>(restrict DB access)"]
        HTTPRouteReg["HTTPRoute<br/>(Gateway API ingress)"]
        OSRoute["OpenShift Route<br/>(reencrypt)"]
        UserGroup["OpenShift Group<br/>{name}-users"]
        RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    end

    %% Catalog Resources Created by ModelCatalogReconciler
    subgraph CatalogResources["Model Catalog Resources"]
        direction TB
        CatalogDeploy["Catalog Deployment<br/>(REST + kube-rbac-proxy + init containers)"]
        CatalogSvc["Service<br/>model-catalog:8443/TCP"]
        CatalogPostgres["Catalog PostgreSQL<br/>model-catalog-postgres:5432/TCP"]
        CatalogHTTPRoute["HTTPRoute<br/>(catalog ingress)"]
    end

    %% Flows
    ModelRegistryCRLegacy -->|"auto-converted"| ModelRegistryCR
    ModelRegistryCR -->|"watched by"| MRReconciler
    MRReconciler -->|"creates/manages"| RegistryDeploy
    MRReconciler -->|"creates"| RegistrySvc
    MRReconciler -->|"creates (if generateDeployment)"| PostgresDeploy
    MRReconciler -->|"creates"| PostgresSvc
    MRReconciler -->|"creates"| NetPol
    MRReconciler -->|"creates"| HTTPRouteReg
    MRReconciler -->|"creates"| OSRoute
    MRReconciler -->|"creates (traditional OCP)"| UserGroup
    MRReconciler -->|"creates"| RefGrant

    MCReconciler -->|"creates/manages"| CatalogDeploy
    MCReconciler -->|"creates"| CatalogSvc
    MCReconciler -->|"creates"| CatalogPostgres
    MCReconciler -->|"creates"| CatalogHTTPRoute

    %% External Dependencies
    MRReconciler -->|"HTTPRoute parentRef"| Gateway["Data Science Gateway"]
    MCReconciler -->|"HTTPRoute parentRef"| Gateway
    MCReconciler -->|"reads adminGroups"| AuthCR["services.platform.opendatahub.io/Auth"]
    MCReconciler -->|"owner reference"| ComponentCR["components.platform.opendatahub.io/ModelRegistry"]
    MCReconciler -->|"discovers sources"| CatalogCMs["ConfigMaps<br/>(opendatahub.io/catalog-source=true)"]

    MigrationMgr -->|"v1alpha1 → v1beta1"| K8sAPI["Kubernetes API"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MRReconciler fill:#357abd,stroke:#333,color:#fff
    style MCReconciler fill:#357abd,stroke:#333,color:#fff
    style MigrationMgr fill:#357abd,stroke:#333,color:#fff
    style WebhookMgr fill:#357abd,stroke:#333,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333
    style ModelRegistryCRLegacy fill:#d4890e,stroke:#333
    style PerInstance fill:#e8f4e8,stroke:#82b366,stroke-width:2px
    style CatalogResources fill:#e8f0f8,stroke:#6694c1,stroke-width:2px
    style Gateway fill:#7ed321,stroke:#333
    style AuthCR fill:#7ed321,stroke:#333
    style ComponentCR fill:#7ed321,stroke:#333
    style CatalogCMs fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
