graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Edge)"]
        RouteUI["Route: planner<br/>443/TCP → 8501/TCP<br/>TLS Edge Termination"]
        RouteAPI["Route: planner-backend<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination"]
    end

    subgraph AppTier["APPLICATION TIER (Namespace: planner)"]
        direction TB

        subgraph FrontendZone["Frontend"]
            UI["Streamlit UI<br/>Service: ui (ClusterIP)<br/>Port: 8501/TCP HTTP<br/>SA: default"]
        end

        subgraph BackendZone["Backend"]
            API["Backend API (FastAPI)<br/>Service: backend (ClusterIP)<br/>Port: 8000/TCP HTTP<br/>SA: planner-backend<br/>Admin: x-admin-password (HMAC)"]
        end

        subgraph DataZone["Data Tier"]
            PG["PostgreSQL<br/>Service: postgres (ClusterIP)<br/>Port: 5432/TCP<br/>Auth: Password"]
        end

        subgraph LLMZone["LLM Tier"]
            Ollama["Ollama LLM<br/>Service: ollama (ClusterIP)<br/>Port: 11434/TCP HTTP<br/>Model: qwen2.5:7b<br/>Auth: None"]
        end

        subgraph DevZone["Development Only"]
            Simulator["vLLM Simulator<br/>Port: 8080/TCP HTTP<br/>GPU-free benchmark replay"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>Port: 6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
        ModelCatalog["RHOAI Model Catalog<br/>Namespace: rhoai-model-registries<br/>Port: 8443/TCP HTTPS<br/>TLS (service CA)<br/>Auth: Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        OpenAI["OpenAI API (conditional)<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer API Key"]
        VertexAI["Vertex AI (conditional)<br/>googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP IAM"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS Edge"| RouteUI
    User -->|"HTTPS/443<br/>TLS Edge"| RouteAPI

    %% Ingress → App
    RouteUI -->|"HTTP/8501<br/>No encryption<br/>Cluster-internal"| UI
    RouteAPI -->|"HTTP/8000<br/>No encryption<br/>Cluster-internal"| API

    %% App internal
    UI -->|"HTTP/8000<br/>No encryption<br/>No auth"| API

    %% Backend → Data
    API -->|"TCP/5432<br/>No encryption<br/>Password auth"| PG

    %% Backend → LLM
    API -->|"HTTP/11434<br/>No encryption<br/>No auth"| Ollama

    %% Backend → Cluster Services
    API -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    API -->|"HTTPS/8443<br/>TLS (service CA)<br/>Bearer Token"| ModelCatalog

    %% Backend → External
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HuggingFace
    API -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer API Key"| OpenAI
    API -.->|"HTTPS/443<br/>TLS 1.2+<br/>GCP IAM"| VertexAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef data fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llm fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef dev fill:#f0f0f0,stroke:#aaa,stroke-width:1px,stroke-dasharray: 5

    class User external
    class RouteUI,RouteAPI ingress
    class UI,API app
    class PG data
    class Ollama llm
    class K8sAPI,ModelCatalog cluster
    class HuggingFace,OpenAI,VertexAI extsvc
    class Simulator dev
