graph TD
    subgraph "Service Account"
        SA["controller-manager<br/>(ServiceAccount)"]
    end

    subgraph "ClusterRole Bindings"
        CRB["manager-rolebinding<br/>(ClusterRoleBinding)<br/>Scope: cluster-wide"]
    end

    subgraph "Role Bindings"
        RB["leader-election-rolebinding<br/>(RoleBinding)<br/>Scope: operator namespace"]
    end

    subgraph "ClusterRole: manager-role"
        CR["manager-role"]
    end

    subgraph "Role: leader-election-role"
        LER["leader-election-role<br/>(namespace-scoped)"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB
    CRB -->|"grants"| CR
    RB -->|"grants"| LER

    subgraph "ClusterRole Permissions"
        Namespaces["core<br/>Namespaces<br/>create, get, list, patch,<br/>update, watch"]
        Deployments["apps<br/>Deployments<br/>get, list, watch"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews<br/>create"]
        Workbenches["components.platform.<br/>opendatahub.io<br/>Workbenches<br/>get, list, watch"]
        WBFinalizers["components.platform.<br/>opendatahub.io<br/>Workbenches/finalizers<br/>update"]
        WBStatus["components.platform.<br/>opendatahub.io<br/>Workbenches/status<br/>get, patch, update"]
    end

    subgraph "Leader Election Permissions"
        ConfigMaps["core<br/>ConfigMaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        Leases["coordination.k8s.io<br/>Leases<br/>get, list, watch, create,<br/>update, patch, delete"]
        Events["core<br/>Events<br/>create, patch"]
    end

    CR -->|"grants access to"| Namespaces
    CR -->|"grants access to"| Deployments
    CR -->|"grants access to"| SAR
    CR -->|"grants access to"| Workbenches
    CR -->|"grants access to"| WBFinalizers
    CR -->|"grants access to"| WBStatus

    LER -->|"grants access to"| ConfigMaps
    LER -->|"grants access to"| Leases
    LER -->|"grants access to"| Events

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#50c8e8,stroke:#333,color:#fff
    style RB fill:#50c8e8,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style LER fill:#f5a623,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style Workbenches fill:#7ed321,stroke:#333,color:#fff
    style WBFinalizers fill:#7ed321,stroke:#333,color:#fff
    style WBStatus fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#a8d98a,stroke:#333
    style Leases fill:#a8d98a,stroke:#333
    style Events fill:#a8d98a,stroke:#333
