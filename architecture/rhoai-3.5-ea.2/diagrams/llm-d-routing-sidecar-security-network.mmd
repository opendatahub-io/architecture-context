graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / EPP<br/>(llm-d-inference-scheduler)"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
    end

    subgraph ServiceLayer["SERVICE LAYER"]
        Service["ClusterIP Service<br/>8080/TCP → 8080/TCP<br/>HTTP, No Encryption"]
    end

    subgraph SidecarPod["SIDECAR POD (Decoder Pod)"]
        direction TB
        Sidecar["llm-d-routing-sidecar<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (FIPS ciphers)<br/>SSRF AllowlistValidator"]

        subgraph LocalPod["Co-located Container"]
            Decoder["Local vLLM Decoder<br/>localhost:8001/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.2+"]
        end
    end

    subgraph RemotePods["REMOTE PODS (InferencePool Members)"]
        Prefiller["Remote Prefiller vLLM<br/>variable/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.2+<br/>Must match pool selector"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        Pods["Pod Resources<br/>(matching pool labels)"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No App Auth<br/>x-prefiller-host-port header"| Route

    %% Ingress to Service
    Route -->|"HTTP/8080<br/>Post-TLS termination"| Service

    %% Service to Sidecar
    Service -->|"HTTP/8080"| Sidecar

    %% Sidecar to Local Decoder
    Sidecar -->|"HTTP(S)/8001<br/>Optional TLS 1.2+<br/>No Auth<br/>Decode + passthrough"| Decoder

    %% Sidecar to Remote Prefiller
    Sidecar -->|"HTTP(S)/variable<br/>Optional TLS 1.2+<br/>SSRF Allowlist Validated<br/>NIXL v2 kv_transfer_params"| Prefiller

    %% Sidecar to K8s API (SSRF allowlist)
    Sidecar -->|"HTTPS/443<br/>TLS<br/>SA Bearer Token<br/>Watch InferencePool + Pods"| K8sAPI

    %% K8s API resources
    K8sAPI --- InferencePool
    K8sAPI --- Pods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicelayer fill:#e6e6e6,stroke:#999,stroke-width:1px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef decoder fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class Service servicelayer
    class Sidecar sidecar
    class Decoder decoder
    class Prefiller remote
    class K8sAPI,InferencePool,Pods controlplane
