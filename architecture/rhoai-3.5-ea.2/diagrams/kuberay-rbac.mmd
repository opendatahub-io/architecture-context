graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>(ServiceAccount)"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["kuberay-operator<br/>(ClusterRoleBinding)"]
        RB["kuberay-operator-leader-election<br/>(RoleBinding, operator NS)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["kuberay-operator<br/>(ClusterRole)"]
        LER["kuberay-leader-election-role<br/>(Role)"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB
    CRB -->|"grants"| CR
    RB -->|"grants"| LER

    subgraph RayCRDs["ray.io CRDs"]
        RayClusters["ray.io<br/>RayClusters<br/>+ status + finalizers"]
        RayJobs["ray.io<br/>RayJobs<br/>+ status + finalizers"]
        RayServices["ray.io<br/>RayServices<br/>+ status + finalizers"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>Pods<br/>+ status + proxy"]
        Services["core<br/>Services<br/>+ status + proxy"]
        ConfigMaps["core<br/>ConfigMaps"]
        SvcAccounts["core<br/>ServiceAccounts"]
        Events["core<br/>Events"]
        Secrets["core<br/>Secrets"]
        Endpoints["core<br/>Endpoints"]
    end

    subgraph WorkloadResources["Workload Resources"]
        Jobs["batch<br/>Jobs"]
        Deployments["apps<br/>Deployments"]
    end

    subgraph CertManagerResources["cert-manager.io"]
        Certificates["Certificates<br/>+ status"]
        Issuers["Issuers"]
    end

    subgraph GatewayResources["gateway.networking.k8s.io"]
        Gateways["Gateways<br/>(read only)"]
        HTTPRoutes["HTTPRoutes"]
        RefGrants["ReferenceGrants"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        Ingresses["Ingresses"]
        NetPolicies["NetworkPolicies"]
        IngressClasses["IngressClasses<br/>(read only)"]
    end

    subgraph OpenShiftResources["OpenShift APIs"]
        Routes["route.openshift.io<br/>Routes"]
        AuthConfigs["config.openshift.io<br/>Authentications, OAuths<br/>(read only)"]
        KubeAPIServers["operator.openshift.io<br/>KubeAPIServers<br/>(read only)"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        Roles["Roles"]
        RoleBindings["RoleBindings"]
        CRoles["ClusterRoles<br/>(read only)"]
        CRBindings["ClusterRoleBindings<br/>(read only)"]
    end

    subgraph AuthZResources["Auth Token APIs"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews<br/>(create only)"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews<br/>(create only)"]
    end

    subgraph LeaderElection["Leader Election"]
        Leases["coordination.k8s.io<br/>Leases"]
    end

    %% Full CRUD permissions
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| RayClusters
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| RayJobs
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| RayServices
    CR -->|"full CRUD +<br/>deletecollection + proxy"| Pods
    CR -->|"full CRUD +<br/>proxy + status"| Services
    CR -->|"full CRUD"| ConfigMaps
    CR -->|"full CRUD"| SvcAccounts
    CR -->|"full CRUD"| Events
    CR -->|"get,list,watch,delete"| Secrets
    CR -->|"get,list,watch"| Endpoints
    CR -->|"full CRUD"| Jobs
    CR -->|"get,list,watch,<br/>update,patch"| Deployments
    CR -->|"full CRUD + status"| Certificates
    CR -->|"full CRUD"| Issuers
    CR -->|"get,list,watch"| Gateways
    CR -->|"full CRUD"| HTTPRoutes
    CR -->|"full CRUD"| RefGrants
    CR -->|"full CRUD"| Ingresses
    CR -->|"full CRUD"| NetPolicies
    CR -->|"get,list,watch"| IngressClasses
    CR -->|"full CRUD"| Routes
    CR -->|"get,list,watch"| AuthConfigs
    CR -->|"get,list,watch"| KubeAPIServers
    CR -->|"full CRUD"| Roles
    CR -->|"full CRUD"| RoleBindings
    CR -->|"get,list,watch"| CRoles
    CR -->|"get,list,watch"| CRBindings
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR
    LER -->|"get,list,create,update"| Leases

