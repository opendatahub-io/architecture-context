graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Gateway["Data Science Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>HTTPRoute: /model-registry/{name}/"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS reencrypt<br/>Route: {name}-rest.{domain}"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KRP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>SubjectAccessReview authZ"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph ServiceLayer["SERVICE LAYER"]
        direction TB

        subgraph NS_Registry["Namespace: {registry-namespace}"]
            RegistryPod["model-registry REST<br/>8080/TCP HTTP (loopback)<br/>SA: {name}"]
            PostgresPod["PostgreSQL<br/>5432/TCP<br/>Password auth<br/>NetworkPolicy restricted"]
        end

        subgraph NS_Apps["Namespace: redhat-ods-applications"]
            CatalogPod["model-catalog REST<br/>8080/TCP HTTP (loopback)<br/>SA: model-catalog"]
            CatalogPG["Catalog PostgreSQL<br/>5432/TCP<br/>Password auth"]
        end
    end

    subgraph OperatorNS["OPERATOR CONTROL PLANE (redhat-ods-applications)"]
        Operator["model-registry-operator<br/>SA: controller-manager"]
        Metrics["Metrics: 8443/TCP HTTPS<br/>Bearer Token auth"]
        Webhooks["Webhooks: 9443/TCP HTTPS<br/>API server TLS client cert"]
        Health["Health: 8081/TCP HTTP<br/>No auth"]
    end

    subgraph ExternalDB["EXTERNAL SERVICES (Optional)"]
        ExtPG["External PostgreSQL<br/>Configurable port<br/>Optional TLS (client certs)<br/>Password auth"]
        ExtMySQL["External MySQL<br/>Configurable port<br/>Optional TLS (client certs)<br/>Password auth"]
    end

    subgraph OpenShiftAPIs["OPENSHIFT APIs"]
        ConfigAPI["config.openshift.io<br/>443/TCP HTTPS<br/>Ingress + APIServer"]
        UserAPI["user.openshift.io<br/>443/TCP HTTPS<br/>Groups (traditional OCP only)"]
    end

    %% Client flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Router

    %% Ingress to auth
    Gateway -->|"HTTPS/8443<br/>TLS (serving cert)<br/>X-Forwarded headers"| KRP
    Router -->|"HTTPS/8443<br/>TLS reencrypt<br/>X-Forwarded headers"| KRP

    %% Auth checks
    KRP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>SubjectAccessReview"| K8sAPI

    %% Auth to service
    KRP -->|"HTTP/8080<br/>loopback<br/>pre-authorized"| RegistryPod
    KRP -->|"HTTP/8080<br/>loopback<br/>pre-authorized"| CatalogPod

    %% Service to DB
    RegistryPod -->|"PostgreSQL/5432<br/>Optional TLS<br/>Password"| PostgresPod
    RegistryPod -.->|"PostgreSQL<br/>Optional TLS<br/>Password"| ExtPG
    RegistryPod -.->|"MySQL<br/>Optional TLS<br/>Password"| ExtMySQL
    CatalogPod -->|"PostgreSQL/5432<br/>Password"| CatalogPG

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRD watches, CRUD"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| ConfigAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| UserAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef osapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway,Router ingress
    class KRP auth
    class K8sAPI k8s
    class RegistryPod,PostgresPod,CatalogPod,CatalogPG service
    class Operator,Metrics,Webhooks,Health operator
    class ExtPG,ExtMySQL extservice
    class ConfigAPI,UserAPI osapi
