graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / API Consumer"]
    end

    subgraph Ingress["INGRESS (KServe + Istio Gateway)"]
        KServeRoute["KServe InferenceService Route<br/>443/TCP → internal ports<br/>TLS 1.2+ (SIMPLE)<br/>security.opendatahub.io/enable-auth: true<br/>kube-rbac-proxy (when enabled)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS via Istio Sidecar)"]
        direction TB

        subgraph NS_Orchestrator["FMS Guardrails Orchestrator"]
            Orchestrator["Guardrails Orchestrator<br/>sidecar.istio.io/inject: true"]
        end

        subgraph NS_BuiltIn["Built-in Detector"]
            BuiltIn["odh-built-in-detector-rhel9<br/>Port: 8080/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics, /registry<br/>Self-contained (no outbound)"]
        end

        subgraph NS_HF["HuggingFace Detector"]
            HFDetector["odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics"]
        end

        subgraph NS_Judge["LLM Judge Detector"]
            JudgeDetector["LLM Judge Detector<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/api/v1/text/generation,<br/>/health, /metrics"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage (MinIO)<br/>9000/TCP HTTP<br/>No encryption<br/>AWS access key / secret key"]
        vLLM["vLLM Server<br/>8080/TCP HTTP<br/>No encryption<br/>No auth (cluster-internal)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| KServeRoute

    %% Ingress to Orchestrator
    KServeRoute -->|"mTLS (Istio)<br/>Service Identity"| Orchestrator

    %% Orchestrator to Detectors
    Orchestrator -->|"HTTP/8080<br/>mTLS (Istio sidecar)<br/>Bearer Token (KServe)"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio sidecar)<br/>Bearer Token (KServe)"| HFDetector
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio sidecar)<br/>Bearer Token (KServe)"| JudgeDetector

    %% Detector to External Services
    HFDetector -->|"HTTP/9000<br/>No encryption<br/>AWS credentials<br/>(KServe storage init)"| S3
    JudgeDetector -->|"HTTP/8080<br/>No encryption<br/>No auth"| vLLM
    HFDetector -.->|"HTTPS/443<br/>TLS 1.2+<br/>(init container)"| HFHub

    %% Monitoring
    Prometheus -.->|"HTTP/8080, 8000<br/>No auth"| BuiltIn
    Prometheus -.->|"HTTP/8080, 8000<br/>No auth"| HFDetector
    Prometheus -.->|"HTTP/8080, 8000<br/>No auth"| JudgeDetector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeRoute ingress
    class Orchestrator,BuiltIn,HFDetector,JudgeDetector servicemesh
    class S3,vLLM,HFHub,Prometheus externalservice
