graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (Gateway API Layer)"]
        direction TB
        Gateway["data-science-gateway<br/>Gateway CR (Envoy)<br/>443/TCP → component ports<br/>TLS 1.2+ Terminate<br/>Cert: Default/SelfSigned/Provided"]

        EnvoyFilter["EnvoyFilter<br/>data-science-authn-filter<br/>ext_authz + Lua filter<br/>Strips cookies, injects Bearer"]

        AuthProxy["kube-auth-proxy<br/>NS: openshift-ingress<br/>SA: kube-auth-proxy<br/>8443/TCP HTTPS (service-CA)<br/>9000/TCP HTTP (metrics)<br/>HPA: 1-3 replicas"]

        DashRedirect["Dashboard Redirect<br/>(Nginx)<br/>301: legacy URL →<br/>rh-ai.{domain}"]
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-operator"]
            Manager["manager Pod<br/>SA: opendatahub-operator-<br/>controller-manager<br/>8443/TCP (webhook)<br/>8080/TCP (metrics)<br/>8081/TCP (health)<br/>FIPS: strictfipsruntime"]
        end

        subgraph NS_Cloud["Non-OpenShift clusters only"]
            CloudMgr["cloudmanager Pod<br/>SA: cloudmanager-<br/>controller-manager<br/>8080/TCP (metrics)<br/>8081/TCP (health)"]
        end
    end

    subgraph PlatformSvcs["PLATFORM SERVICES (Internal)"]
        direction LR
        Prometheus["Prometheus<br/>MonitoringStack<br/>443→9091/TCP HTTPS<br/>kube-rbac-proxy"]
        OTelCollector["OTel Collector<br/>4317/TCP OTLP<br/>RBAC auth"]
        Tempo["Tempo<br/>Tracing"]
        Perses["Perses<br/>Dashboards"]
    end

    subgraph ManagedComponents["MANAGED COMPONENTS (16)<br/>Namespace: redhat-ods-applications"]
        direction LR
        Dashboard["Dashboard"]
        KServe["KServe"]
        Kueue["Kueue"]
        DSP["DSP"]
        Workbenches["Workbenches"]
        ModelReg["ModelRegistry"]
        Ray["Ray"]
        TrustyAI["TrustyAI"]
        MaaS["ModelsAsService"]
        Others["TrainingOp, Trainer,<br/>Feast, OGX, MLflow,<br/>Spark, ModelController"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        direction LR
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client Creds"]
        OIDCProvider["External OIDC<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client Creds"]
        OpenShiftAPI["OpenShift API<br/>6443/TCP HTTPS<br/>TLS Profile Config"]
    end

    subgraph CloudDeps["CLOUD INFRA (Helm-deployed)"]
        direction LR
        CertMgr["cert-manager"]
        SailIstio["Sail/Istio"]
        LWS["LWS Operator"]
        GatewayAPICRDs["Gateway API CRDs"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (initial)"| Gateway
    Gateway -->|"ext_authz check"| EnvoyFilter
    EnvoyFilter -->|"HTTPS/8443<br/>TLS (service-CA)<br/>Cookie/Bearer"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDCProvider
    EnvoyFilter -->|"HTTPRoute<br/>Bearer token injected"| ManagedComponents

    %% Operator → K8s API
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (RBAC)"| K8sAPI
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| OpenShiftAPI
    Manager -->|"HTTPS/443<br/>SA token"| OAuthServer
    CloudMgr -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Cloud Manager → Infra
    CloudMgr -->|"Helm deploy"| CloudDeps

    %% Monitoring
    Manager -.->|"metrics"| Prometheus
    Manager -.->|"traces"| OTelCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef components fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extdep fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef clouddep fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,EnvoyFilter,AuthProxy,DashRedirect ingress
    class Manager,CloudMgr operator
    class Prometheus,OTelCollector,Tempo,Perses platform
    class Dashboard,KServe,Kueue,DSP,Workbenches,ModelReg,Ray,TrustyAI,MaaS,Others components
    class K8sAPI,OAuthServer,OIDCProvider,OpenShiftAPI extdep
    class CertMgr,SailIstio,LWS,GatewayAPICRDs clouddep
