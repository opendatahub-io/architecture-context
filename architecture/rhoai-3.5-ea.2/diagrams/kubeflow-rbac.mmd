graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KF["notebook-controller-manager<br/>(opendatahub namespace)"]
        SA_ODH["odh-notebook-controller-manager<br/>(opendatahub namespace)"]
        SA_NB["{notebook-name}<br/>({user-namespace})"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KF["kf-notebook-controller-rolebinding"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB_AUTH["{notebook-name}-rbac-<br/>{namespace}-auth-delegator<br/>(per notebook, cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (per notebook, namespace-scoped)"]
        RB_DSPA["elyra-pipelines-{notebook-name}<br/>(user namespace)"]
        RB_MLFLOW["{notebook-name}-mlflow<br/>(user namespace, if MLflow exists)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KF["kf-notebook-controller role"]
        CR_ODH["odh-notebook-controller<br/>manager-role"]
        CR_AUTH["system:auth-delegator"]
        CR_MLFLOW["mlflow<br/>(if exists)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_DSPA["ds-pipeline-user-access-dspa<br/>(user namespace)"]
    end

    subgraph UserRoles["User-Facing Aggregated Roles"]
        CR_ADMIN["notebooks-admin<br/>(aggregates notebooks-edit)"]
        CR_EDIT["notebooks-edit"]
        CR_VIEW["notebooks-view"]
    end

    subgraph KF_Resources["KF Controller Resources"]
        KF_Pods["core: pods<br/>get, list, watch, delete"]
        KF_Events["core: events<br/>get, list, watch, create, patch"]
        KF_Services["core: services<br/>*"]
        KF_STS["apps: statefulsets<br/>*"]
        KF_NB["kubeflow.org: notebooks,<br/>notebooks/finalizers,<br/>notebooks/status<br/>*"]
        KF_VS["networking.istio.io:<br/>virtualservices<br/>*"]
    end

    subgraph ODH_Resources["ODH Controller Resources"]
        ODH_Core["core: configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch,<br/>update, watch"]
        ODH_Events["core: events<br/>create, patch"]
        ODH_AuthN["authentication.k8s.io:<br/>tokenreviews<br/>create"]
        ODH_AuthZ["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        ODH_OCP["config.openshift.io:<br/>apiservers, proxies<br/>get, list, watch"]
        ODH_DSPA["dspa.opendatahub.io:<br/>dspa, dspa/api<br/>get, list, watch, create,<br/>delete, patch, update"]
        ODH_GW["gateway.networking.k8s.io:<br/>gateways, httproutes,<br/>referencegrants<br/>full CRUD"]
        ODH_IMG["image.openshift.io:<br/>imagestreams<br/>get, list, watch"]
        ODH_NB["kubeflow.org: notebooks<br/>get, list, patch,<br/>update, watch"]
        ODH_NET["networking.k8s.io:<br/>networkpolicies<br/>full CRUD"]
        ODH_RBAC["rbac.authorization.k8s.io:<br/>clusterrolebindings,<br/>rolebindings, roles<br/>full CRUD"]
        ODH_Route["route.openshift.io: routes<br/>get, list, watch"]
        ODH_OAuth["oauth.openshift.io:<br/>oauthclients<br/>delete, get, list,<br/>patch, update, watch"]
    end

    subgraph UserResources["User-Facing Resources"]
        U_NB["kubeflow.org: notebooks,<br/>notebooks/status"]
    end

    %% KF Controller bindings
    SA_KF -->|"bound via"| CRB_KF
    CRB_KF -->|"grants"| CR_KF
    CR_KF -->|"permits"| KF_Pods
    CR_KF -->|"permits"| KF_Events
    CR_KF -->|"permits"| KF_Services
    CR_KF -->|"permits"| KF_STS
    CR_KF -->|"permits"| KF_NB
    CR_KF -->|"permits"| KF_VS

    %% ODH Controller bindings
    SA_ODH -->|"bound via"| CRB_ODH
    CRB_ODH -->|"grants"| CR_ODH
    CR_ODH -->|"permits"| ODH_Core
    CR_ODH -->|"permits"| ODH_Events
    CR_ODH -->|"permits"| ODH_AuthN
    CR_ODH -->|"permits"| ODH_AuthZ
    CR_ODH -->|"permits"| ODH_OCP
    CR_ODH -->|"permits"| ODH_DSPA
    CR_ODH -->|"permits"| ODH_GW
    CR_ODH -->|"permits"| ODH_IMG
    CR_ODH -->|"permits"| ODH_NB
    CR_ODH -->|"permits"| ODH_NET
    CR_ODH -->|"permits"| ODH_RBAC
    CR_ODH -->|"permits"| ODH_Route
    CR_ODH -->|"permits"| ODH_OAuth

    %% Per-notebook bindings
    SA_NB -->|"bound via"| CRB_AUTH
    CRB_AUTH -->|"grants"| CR_AUTH
    SA_NB -->|"bound via"| RB_DSPA
    RB_DSPA -->|"grants"| R_DSPA
    SA_NB -.->|"bound via (if MLflow)"| RB_MLFLOW
    RB_MLFLOW -.->|"grants"| CR_MLFLOW

    %% User-facing roles
    CR_ADMIN -->|"aggregates"| CR_EDIT
    CR_EDIT -->|"get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"| U_NB
    CR_VIEW -->|"get, list, watch"| U_NB

    %% Styling
    style SA_KF fill:#4a90e2,stroke:#333,color:#fff
    style SA_ODH fill:#4a90e2,stroke:#333,color:#fff
    style SA_NB fill:#4a90e2,stroke:#333,color:#fff
    style CR_KF fill:#f5a623,stroke:#333,color:#fff
    style CR_ODH fill:#f5a623,stroke:#333,color:#fff
    style CR_AUTH fill:#f5a623,stroke:#333,color:#fff
    style CR_MLFLOW fill:#f5a623,stroke:#333,color:#fff
    style R_DSPA fill:#f5a623,stroke:#333,color:#fff
    style CR_ADMIN fill:#bd10e0,stroke:#333,color:#fff
    style CR_EDIT fill:#bd10e0,stroke:#333,color:#fff
    style CR_VIEW fill:#bd10e0,stroke:#333,color:#fff
