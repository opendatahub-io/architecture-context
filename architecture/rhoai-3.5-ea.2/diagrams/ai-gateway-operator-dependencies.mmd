graph LR
    AIGW["ai-gateway-operator<br/>(Module Operator)"]

    %% Internal Platform Dependencies
    AIGW -->|"module lifecycle<br/>(creates AIGateway CR)"| RHODS["opendatahub-operator<br/>(rhods-operator)"]
    AIGW -->|"deploys sub-component<br/>(kustomize manifests)"| BatchGW["llm-d-batch-gateway-operator"]

    %% External Dependencies (Go libraries)
    AIGW -->|"controller framework<br/>v0.24.1"| CtrlRuntime["controller-runtime"]
    AIGW -->|"reconciler framework,<br/>kustomize, deploy actions<br/>v2.8.1"| ODHFramework["opendatahub-operator/v2<br/>framework"]
    AIGW -->|"manifest rendering"| ManifestKit["k8s-manifest-kit<br/>v0.2.1+"]

    %% Cluster Dependencies (CRD integrations)
    BatchGW -->|"TLS certificates"| CertManager["cert-manager<br/>v1.13+"]
    BatchGW -->|"HTTPRoute ingress"| GatewayAPI["Gateway API<br/>v1.3.0"]
    AIGW -->|"metrics scraping"| PromOp["Prometheus Operator"]
    BatchGW -->|"monitoring resources"| PromOp

    %% Infrastructure
    AIGW -->|"watch/manage resources<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    BatchGW -->|"watch/manage resources<br/>443/TCP HTTPS"| K8sAPI

    %% Build Dependencies
    AIGW -.->|"OLM version types<br/>v0.42.0"| OLMFramework["operator-framework/api"]
    AIGW -.->|"semver parsing<br/>v4.0.0"| SemVer["blang/semver"]
    AIGW -.->|"CLI framework"| Cobra["spf13/cobra v1.10.2"]
    AIGW -.->|"config loading"| Viper["spf13/viper v1.21.0"]

    %% Styling
    style AIGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RHODS fill:#9b59b6,stroke:#333,color:#fff
    style BatchGW fill:#7ed321,stroke:#333
    style CtrlRuntime fill:#e8e8e8,stroke:#333
    style ODHFramework fill:#9b59b6,stroke:#333,color:#fff
    style ManifestKit fill:#e8e8e8,stroke:#333
    style CertManager fill:#f5a623,stroke:#333
    style GatewayAPI fill:#f5a623,stroke:#333
    style PromOp fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
