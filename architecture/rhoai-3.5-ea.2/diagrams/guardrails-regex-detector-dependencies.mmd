graph LR
    RegexDetector["Guardrails Regex Detector<br/>(Rust HTTP Service)"]

    %% Internal Platform Dependencies (caller)
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP Plaintext"| RegexDetector

    %% Rust Crate Dependencies
    subgraph RustDeps["Rust Dependencies (Cargo)"]
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Regex["regex 1.11.1<br/>(pattern matching)"]
        Serde["serde 1.0.215<br/>serde_json 1.0.133<br/>(JSON ser/de)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        TowerHTTP["tower-http 0.6.2<br/>(HTTP middleware)"]
        Tracing["tracing 0.1.41<br/>tracing-subscriber 0.3.19<br/>(structured logging)"]
    end

    RegexDetector -.->|"framework"| Axum
    RegexDetector -.->|"core engine"| Regex
    RegexDetector -.->|"serialization"| Serde
    RegexDetector -.->|"runtime"| Tokio
    RegexDetector -.->|"middleware"| TowerHTTP
    RegexDetector -.->|"logging"| Tracing

    %% Container Base
    subgraph Container["Container Image"]
        UBI9["UBI 9 Minimal<br/>(runtime base)"]
        RustBuilder["rust:1.84.0<br/>(build stage)"]
        OpenSSL["compat-openssl11<br/>(installed, not used)"]
    end

    RegexDetector -.->|"runs on"| UBI9
    RegexDetector -.->|"built with"| RustBuilder

    %% No external service dependencies
    NoDeps["No External Service<br/>Dependencies<br/>(no DB, no storage,<br/>no API calls out)"]

    RegexDetector -.-|"none"| NoDeps

    %% Styling
    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#f5a623,stroke:#333,color:#fff
    style Axum fill:#e8e8e8,stroke:#333
    style Regex fill:#7ed321,stroke:#333,color:#fff
    style Serde fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style TowerHTTP fill:#e8e8e8,stroke:#333
    style Tracing fill:#e8e8e8,stroke:#333
    style UBI9 fill:#cc0000,stroke:#333,color:#fff
    style RustBuilder fill:#e8e8e8,stroke:#333
    style OpenSSL fill:#e8e8e8,stroke:#333
    style NoDeps fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
