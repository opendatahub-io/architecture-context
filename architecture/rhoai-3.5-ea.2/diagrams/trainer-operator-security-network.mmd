graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer Tokens<br/>AuthZ: RBAC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        direction TB

        subgraph TrainerPod["Trainer Operator Pod"]
            TrainerOp["trainer-operator<br/>SA: controller-manager<br/>ClusterRole: manager-role<br/>FIPS: strictfipsruntime"]
            Metrics["Metrics Endpoint<br/>/metrics<br/>8080/TCP HTTP"]
            Probes["Health Probes<br/>/healthz /readyz<br/>8081/TCP HTTP"]
        end

        MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8080/TCP<br/>HTTP, No TLS"]
    end

    subgraph ManagedNS["MANAGED RESOURCES"]
        direction TB
        TrainerCtrl["Kubeflow Trainer Controller<br/>(Managed Deployment)<br/>SA: trainer-controller-manager"]
        Runtimes["ClusterTrainingRuntimes<br/>(15 variants: CUDA/ROCm/CPU)<br/>Cluster-scoped"]
        ImgStreams["Training Hub ImageStreams<br/>(3 accelerator variants)<br/>OpenShift only"]
        ManagedWebhooks["ValidatingWebhookConfigs"]
        ManagedNetPol["NetworkPolicies"]
        ManagedPodMon["PodMonitors"]
    end

    subgraph Monitoring["MONITORING NAMESPACE"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>insecureSkipVerify: true"]
    end

    subgraph Dependencies["DEPENDENCY SERVICES"]
        JobSetOp["JobSet Operator<br/>CRD: jobsets.jobset.x-k8s.io"]
        PlatformOp["rhods-operator<br/>Creates Trainer CR"]
        OLM["OLM<br/>OperatorConditions"]
        OSAPI["OpenShift API<br/>ClusterVersions"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User Token"| K8sAPI

    %% Platform operator creates CR
    PlatformOp -->|"Creates Trainer CR<br/>(default-trainer)"| K8sAPI

    %% Operator watches and applies
    K8sAPI -->|"Watch notifications<br/>HTTPS TLS 1.2+<br/>SA Bearer Token"| TrainerOp
    TrainerOp -->|"Server-side apply<br/>HTTPS/443 TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Managed resources
    TrainerOp -.->|deploys| TrainerCtrl
    TrainerOp -.->|creates/updates| Runtimes
    TrainerOp -.->|creates/updates| ImgStreams
    TrainerOp -.->|manages| ManagedWebhooks
    TrainerOp -.->|manages| ManagedNetPol
    TrainerOp -.->|manages| ManagedPodMon

    %% Managed controller to API
    TrainerCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Dependency checks
    TrainerOp -.->|"CRD check"| JobSetOp
    TrainerOp -.->|"OLM check"| OLM
    TrainerOp -.->|"Cluster type<br/>detection"| OSAPI

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No TLS<br/>NetworkPolicy: metrics=enabled"| MetricsSvc
    MetricsSvc --> Metrics

    %% NetworkPolicy annotation
    linkStyle 12 stroke:#e67e22,stroke-width:2px

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef dependency fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef service fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI k8sapi
    class TrainerOp,Metrics,Probes operator
    class TrainerCtrl,Runtimes,ImgStreams,ManagedWebhooks,ManagedNetPol,ManagedPodMon managed
    class Prometheus monitoring
    class JobSetOp,PlatformOp,OLM,OSAPI dependency
    class MetricsSvc service
