graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["(per-component SA)<br/>e.g. dashboard-sa,<br/>model-registry-sa, etc."]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB["kube-rbac-proxy<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR["kube-rbac-proxy"]
    end

    subgraph APIResources["API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    subgraph HardcodedAccess["Hardcoded Authorization (no RBAC)"]
        PrometheusAccess["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["/metrics<br/>(GET only)"]
    end

    PrometheusAccess -->|"hardcoded Allow<br/>(bypasses SAR)"| MetricsEndpoint

    subgraph ProxiedRBAC["Per-Request Authorization (SAR)"]
        direction TB
        Format1["Format1: resourceAttributes<br/>+ rewrites (query param / header)<br/>Applied to all paths"]
        Format2["Format2: path-scoped endpoints<br/>Per HTTP method resource rules<br/>e.g. POST /api → create,<br/>GET /api → get"]
    end

    SAR -.->|"evaluates"| ProxiedRBAC

    style SA fill:#4a90e2,color:#fff
    style CRB fill:#f39c12,color:#fff
    style CR fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style PrometheusAccess fill:#e74c3c,color:#fff
    style MetricsEndpoint fill:#e74c3c,color:#fff
    style Format1 fill:#dae8fc,stroke:#6c8ebf
    style Format2 fill:#dae8fc,stroke:#6c8ebf
