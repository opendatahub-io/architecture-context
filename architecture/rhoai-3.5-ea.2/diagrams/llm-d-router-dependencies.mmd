graph LR
    LLMDRouter["llm-d Router<br/>(EPP + PD Sidecar)"]

    %% External Dependencies (Required)
    LLMDRouter -->|"gRPC ext-proc v3<br/>routing decisions"| Envoy["Envoy Proxy<br/>(ext-proc v3 compatible)"]
    LLMDRouter -->|"HTTPS/443<br/>CRD & Pod watches"| K8sAPI["Kubernetes API Server<br/>v1.35+"]
    LLMDRouter -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    LLMDRouter -->|"InferencePool CRD"| GatewayAPI["gateway-api<br/>v1.5.1"]
    LLMDRouter -->|"InferencePool types"| GatewayAPIInference["gateway-api-inference-<br/>extension v1.5.0"]
    LLMDRouter -->|"ext-proc protocol"| GoControlPlane["envoy go-control-plane<br/>v1.37.0"]
    LLMDRouter -->|"metrics exposition"| PromClient["Prometheus client<br/>v1.23.2"]

    %% External Dependencies (Optional)
    LLMDRouter -.->|"distributed tracing<br/>gRPC/4317"| OTel["OpenTelemetry SDK<br/>v1.44.0"]
    LLMDRouter -.->|"KV-Events subscription<br/>ZMQ SUB/5557"| ZeroMQ["ZeroMQ (zmq4)<br/>v0.17.0"]
    LLMDRouter -.->|"prefix cache metadata"| KVCache["llm-d-kv-cache<br/>v0.9.0-rc.1"]

    %% Internal Platform Dependencies
    LLMDRouter -->|"HTTP poll metrics<br/>+ model info"| ModelServers["Model Servers<br/>(vLLM/SGLang)"]
    LLMDRouter -->|"HTTP or UDS<br/>tokenization"| Tokenizer["Tokenizer Service"]
    LLMDRouter -.->|"HTTP<br/>latency prediction"| LatencyPredictor["Latency Predictor"]

    %% Sidecar-specific dependencies
    LLMDRouter -->|"HTTP(S)/dynamic<br/>prefill stage"| PrefillServers["Remote Prefill<br/>Servers"]
    LLMDRouter -.->|"HTTP(S)/dynamic<br/>encode stage"| EncoderServers["Remote Encoder<br/>Servers"]
    LLMDRouter -->|"HTTP(S)/8001<br/>decode stage"| LocalDecode["Local Decode<br/>vLLM Server"]
    LLMDRouter -.->|"HTTP/8998<br/>dp_rank mapping"| MooncakeBoot["Mooncake Bootstrap"]

    %% CRD dependencies (consumed)
    InferencePool["InferencePool CR<br/>(gateway-api)"] -->|"CRD Watch"| LLMDRouter
    InferenceObjective["InferenceObjective CR<br/>(llm-d.ai/v1alpha2)"] -->|"CRD Watch"| LLMDRouter
    InferenceModelRewrite["InferenceModelRewrite CR<br/>(llm-d.ai/v1alpha2)"] -->|"CRD Watch"| LLMDRouter

    %% Observability
    Prometheus["Prometheus"] -->|"HTTP/9090<br/>scrape metrics"| LLMDRouter
    OTLP["OTLP Collector"] -.->|"receives traces"| LLMDRouter

    %% Styling
    style LLMDRouter fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (required) - dark gray
    style Envoy fill:#666,stroke:#333,color:#fff
    style K8sAPI fill:#666,stroke:#333,color:#fff
    style ControllerRuntime fill:#666,stroke:#333,color:#fff
    style GatewayAPI fill:#666,stroke:#333,color:#fff
    style GatewayAPIInference fill:#666,stroke:#333,color:#fff
    style GoControlPlane fill:#666,stroke:#333,color:#fff
    style PromClient fill:#666,stroke:#333,color:#fff

    %% External dependencies (optional) - light gray
    style OTel fill:#999,stroke:#333,color:#fff
    style ZeroMQ fill:#999,stroke:#333,color:#fff
    style KVCache fill:#999,stroke:#333,color:#fff

    %% Internal platform - green
    style ModelServers fill:#7ed321,stroke:#333,color:#fff
    style Tokenizer fill:#7ed321,stroke:#333,color:#fff
    style LatencyPredictor fill:#7ed321,stroke:#333,color:#fff
    style PrefillServers fill:#7ed321,stroke:#333,color:#fff
    style EncoderServers fill:#7ed321,stroke:#333,color:#fff
    style LocalDecode fill:#7ed321,stroke:#333,color:#fff
    style MooncakeBoot fill:#7ed321,stroke:#333,color:#fff

    %% CRDs - orange
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style InferenceObjective fill:#f5a623,stroke:#333,color:#fff
    style InferenceModelRewrite fill:#f5a623,stroke:#333,color:#fff

    %% Observability - blue-gray
    style Prometheus fill:#dae8fc,stroke:#6c8ebf
    style OTLP fill:#dae8fc,stroke:#6c8ebf
