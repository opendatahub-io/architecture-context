graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (DMZ - Istio Gateway)"]
        Gateway["Kubeflow Gateway<br/>(Istio VirtualService)<br/>80/TCP HTTP<br/>ISTIO_MUTUAL"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT - Istio)"]
        direction TB

        subgraph NS_DSP["Namespace: data-science-pipelines"]
            direction TB

            UI["ml-pipeline-ui<br/>SA: ml-pipeline-ui<br/>3000/TCP HTTP<br/>Proxies API + artifacts"]

            APIServer["ml-pipeline API Server<br/>SA: ml-pipeline<br/>8888/TCP REST · 8887/TCP gRPC<br/>Auth: Bearer Token / HTTP Header<br/>TokenReview + SubjectAccessReview"]

            PersistenceAgent["ml-pipeline-persistenceagent<br/>SA: ml-pipeline-persistenceagent<br/>No exposed ports<br/>Auth: Projected SA Token (3600s)"]

            SWFController["ml-pipeline-scheduledworkflow<br/>SA: ml-pipeline-scheduledworkflow<br/>9090/TCP metrics<br/>Auth: Projected SA Token (3600s)"]

            ViewerController["ml-pipeline-viewer-crd<br/>SA: ml-pipeline-viewer-crd-service-account<br/>No exposed ports"]

            CacheServer["cache-server<br/>SA: kubeflow-pipelines-cache<br/>8443/TCP HTTPS<br/>TLS: webhook-server-tls<br/>Auth: K8s webhook mTLS"]

            MLMD["ML Metadata (MLMD)<br/>8080/TCP gRPC<br/>No auth (in-cluster)"]

            EnvoyProxy["Envoy Proxy<br/>9090/TCP gRPC-Web<br/>No auth (in-cluster)"]

            VizServer["ml-pipeline-visualizationserver<br/>8888/TCP HTTP<br/>No auth (in-cluster)"]
        end

        subgraph NS_Argo["Namespace: argo / openshift-operators"]
            ArgoController["Argo Workflows Controller<br/>Creates Driver + Launcher pods"]
        end

        subgraph NS_Pipeline["Namespace: {user-namespace}"]
            Driver["ml-pipeline-driver<br/>(ephemeral Argo task)<br/>SA: pipeline-runner"]
            Launcher["ml-pipeline-launcher<br/>(ephemeral Argo task)<br/>SA: pipeline-runner"]
        end
    end

    subgraph DataStores["DATA STORES (In-Cluster)"]
        DB["MySQL / PostgreSQL<br/>3306/TCP or 5432/TCP<br/>Auth: Username/Password<br/>No TLS (in-cluster)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ObjectStore["MinIO / SeaweedFS / S3<br/>9000/TCP HTTP/HTTPS<br/>Auth: Access Key + Secret Key<br/>TLS: Configurable"]
        MLflow["MLflow Tracking<br/>8443/TCP HTTPS<br/>Auth: TLS (CA bundle)<br/>Optional"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>Auth: ServiceAccount<br/>TLS"]
    end

    %% External to Ingress
    User -->|"HTTP/80<br/>ISTIO_MUTUAL"| Gateway

    %% Ingress to Services
    Gateway -->|"HTTP/3000<br/>mTLS STRICT<br/>AuthorizationPolicy"| UI

    %% Frontend to API
    UI -->|"HTTP/8888<br/>mTLS<br/>Proxy passthrough"| APIServer
    UI -->|"HTTP/8888<br/>mTLS"| VizServer

    %% API Server connections
    APIServer -->|"TCP/3306 or 5432<br/>No TLS<br/>Username/Password"| DB
    APIServer -->|"HTTP/9000<br/>Configurable TLS<br/>Access Key"| ObjectStore
    APIServer -->|"gRPC/8080<br/>Optional TLS<br/>No auth"| MLMD
    APIServer -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    APIServer -->|"HTTPS/8443<br/>TLS<br/>CA bundle"| MLflow

    %% Controllers to API & K8s
    PersistenceAgent -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token (projected SA)"| APIServer
    PersistenceAgent -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    SWFController -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token (projected SA)"| APIServer
    SWFController -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    ViewerController -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI

    %% Cache
    CacheServer -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI

    %% Argo to data plane
    ArgoController -->|"Creates pods<br/>ServiceAccount"| Driver
    ArgoController -->|"Creates pods<br/>ServiceAccount"| Launcher

    %% Data plane connections
    Driver -->|"gRPC/8080<br/>Optional TLS<br/>No auth"| MLMD
    Driver -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token"| APIServer
    Driver -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    Launcher -->|"gRPC/8080<br/>Optional TLS<br/>No auth"| MLMD
    Launcher -->|"HTTP/9000<br/>Configurable TLS<br/>Access Key"| ObjectStore
    Launcher -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token"| APIServer

    %% Envoy proxy
    EnvoyProxy -->|"gRPC/8080<br/>No TLS"| MLMD

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class UI,APIServer,PersistenceAgent,SWFController,ViewerController,CacheServer,MLMD,EnvoyProxy,VizServer,ArgoController,Driver,Launcher servicemesh
    class DB datastore
    class ObjectStore,MLflow externalservice
    class K8sAPI k8s
