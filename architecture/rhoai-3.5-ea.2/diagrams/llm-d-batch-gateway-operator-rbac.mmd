graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["llm-d-batch-gateway-operator<br/>(operator namespace)"]
    end

    subgraph ClusterBindings["Cluster Role Bindings"]
        CRB["llm-d-batch-gateway-operator<br/>(ClusterRoleBinding)"]
        LERB["leader-election-rolebinding<br/>(RoleBinding, operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["llm-d-batch-gateway-operator<br/>(ClusterRole)"]
        LER["leader-election-role<br/>(Role, namespaced)"]
    end

    subgraph AggregateRoles["Aggregate Cluster Roles"]
        AdminRole["llmbatchgateway-admin<br/>(aggregated to admin/edit)"]
        ViewRole["llmbatchgateway-view<br/>(aggregated to view)"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| LERB
    CRB -->|"grants"| CR
    LERB -->|"grants"| LER

    subgraph CRDResources["batch.llm-d.ai Resources"]
        LLMBatchGW["llmbatchgateways"]
        LLMBatchGWStatus["llmbatchgateways/status"]
        LLMBatchGWFinalizers["llmbatchgateways/finalizers"]
    end

    subgraph CoreResources["Core (v1) Resources"]
        Deployments["apps/deployments"]
        ConfigMaps["configmaps"]
        ServAccts["serviceaccounts"]
        Services["services"]
        Secrets["secrets"]
        Events["events"]
    end

    subgraph GatewayResources["gateway.networking.k8s.io Resources"]
        HTTPRoutes["httproutes"]
        RefGrants["referencegrants"]
    end

    subgraph CertManagerResources["cert-manager.io Resources"]
        Certificates["certificates"]
    end

    subgraph MonitoringResources["monitoring.coreos.com Resources"]
        ServiceMonitors["servicemonitors"]
        PodMonitors["podmonitors"]
        PrometheusRules["prometheusrules"]
    end

    %% ClusterRole permissions
    CR -->|"get,list,watch,<br/>update,patch"| LLMBatchGW
    CR -->|"get,update,patch"| LLMBatchGWStatus
    CR -->|"update"| LLMBatchGWFinalizers
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Deployments
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| ServAccts
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Services
    CR -->|"get,list,watch,<br/>create,patch"| Secrets
    CR -->|"create,patch"| Events
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| HTTPRoutes
    CR -->|"get,list,watch"| RefGrants
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Certificates
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| ServiceMonitors
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| PodMonitors
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| PrometheusRules

    %% Aggregate role permissions
    AdminRole -->|"get,list,watch,create,<br/>update,patch,delete"| LLMBatchGW
    AdminRole -->|"get"| LLMBatchGWStatus
    ViewRole -->|"get,list,watch"| LLMBatchGW
    ViewRole -->|"get"| LLMBatchGWStatus

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style LER fill:#f5a623,color:#fff
    style AdminRole fill:#e67e22,color:#fff
    style ViewRole fill:#e67e22,color:#fff
    style CRB fill:#9b59b6,color:#fff
    style LERB fill:#9b59b6,color:#fff
    style LLMBatchGW fill:#7ed321,color:#fff
    style LLMBatchGWStatus fill:#7ed321,color:#fff
    style LLMBatchGWFinalizers fill:#7ed321,color:#fff
    style Deployments fill:#3498db,color:#fff
    style ConfigMaps fill:#3498db,color:#fff
    style ServAccts fill:#3498db,color:#fff
    style Services fill:#3498db,color:#fff
    style Secrets fill:#e74c3c,color:#fff
    style Events fill:#3498db,color:#fff
    style HTTPRoutes fill:#1abc9c,color:#fff
    style RefGrants fill:#1abc9c,color:#fff
    style Certificates fill:#1abc9c,color:#fff
    style ServiceMonitors fill:#1abc9c,color:#fff
    style PodMonitors fill:#1abc9c,color:#fff
    style PrometheusRules fill:#1abc9c,color:#fff
