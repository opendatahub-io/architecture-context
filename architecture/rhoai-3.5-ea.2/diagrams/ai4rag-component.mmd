graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Experiment["Experiment Orchestration"]
            AI4RAGExp["AI4RAGExperiment<br/>(experiment.py)"]
            MPS["ModelsPreSelector<br/>(mps.py)"]
            Results["ExperimentResults<br/>(results.py)"]
            BenchData["BenchmarkData<br/>(benchmark_data.py)"]
        end

        subgraph HPO["Hyperparameter Optimization"]
            BaseOpt["BaseOptimizer"]
            GAMOpt["GAMOptimizer<br/>(pyGAM LinearGAM)"]
            RandomOpt["RandomOptimizer"]
            BaseOpt -.->|strategy| GAMOpt
            BaseOpt -.->|strategy| RandomOpt
        end

        subgraph RAG["RAG Pipeline"]
            SimpleRAG["SimpleRAGTemplate"]
            Retriever["Retriever"]

            subgraph VectorStores["Vector Stores"]
                BaseVS["BaseVectorStore"]
                OgxVS["OGXVectorStore"]
                ChromaVS["ChromaVectorStore"]
            end

            subgraph Embeddings["Embedding Models"]
                BaseEmb["BaseEmbeddingModel"]
                OgxEmb["OGXEmbeddingModel"]
            end

            subgraph FoundationModels["Foundation Models"]
                BaseFM["BaseFoundationModel"]
                OgxFM["OGXFoundationModel"]
            end

            subgraph Chunking["Document Chunking"]
                BaseChunk["BaseChunker"]
                LangChainChunk["LangChainChunker<br/>(RecursiveCharacterTextSplitter)"]
                DoclingChunk["DoclingChunker<br/>(HybridChunker)"]
            end
        end

        subgraph SearchSpace["Search Space"]
            SSManager["SearchSpace<br/>(search_space.py)"]
            Parameter["Parameter"]
            ConstraintRules["Constraint Rules<br/>(7 built-in rules)"]
            PrepareSSP["prepare_search_space<br/>(ogx_utils.py)"]
        end

        subgraph Evaluation["Evaluation"]
            BaseEval["BaseEvaluator"]
            UnitxtEval["UnitxtEvaluator<br/>(answer_correctness,<br/>faithfulness,<br/>context_correctness)"]
        end

        subgraph EventHandlers["Event Handlers"]
            BaseEH["BaseEventHandler"]
            LocalEH["LocalEventHandler<br/>(JSON to disk)"]
            KFPEH["KFPEventHandler<br/>(Kubeflow Pipelines)"]
        end
    end

    %% Internal flows
    AI4RAGExp -->|orchestrates| MPS
    AI4RAGExp -->|uses| GAMOpt
    AI4RAGExp -->|evaluates via| SimpleRAG
    AI4RAGExp -->|collects| Results
    AI4RAGExp -->|loads| BenchData
    AI4RAGExp -->|manages| SSManager
    AI4RAGExp -->|reports to| BaseEH
    MPS -->|pre-selects models| AI4RAGExp
    SimpleRAG -->|retrieves| Retriever
    Retriever -->|queries| BaseVS
    SimpleRAG -->|generates| BaseFM
    SSManager -->|contains| Parameter
    SSManager -->|applies| ConstraintRules
    PrepareSSP -->|discovers models| SSManager

    %% External connections
    OgxVS -->|REST API| OGXServer["OGX Server<br/>(Milvus/Qdrant backends)"]
    OgxEmb -->|REST API| OGXServer
    OgxFM -->|REST API| OGXServer
    PrepareSSP -->|models.list| OGXServer
    ChromaVS -->|in-process| ChromaDB["ChromaDB<br/>(in-memory)"]
    UnitxtEval -->|in-process| Unitxt["Unitxt Framework"]
    LangChainChunk -->|in-process| LangChain["LangChain"]
    DoclingChunk -->|in-process| Docling["Docling"]

    %% Consumer integration
    Consumer["Consuming Service<br/>(KFP Component / CLI / Notebook)"] -->|imports| AI4RAGExp

    %% Styling
    style ai4rag fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style OGXServer fill:#f5a623,stroke:#333
    style ChromaDB fill:#e8e8e8,stroke:#333
    style Unitxt fill:#e8e8e8,stroke:#333
    style LangChain fill:#e8e8e8,stroke:#333
    style Docling fill:#e8e8e8,stroke:#333
    style Consumer fill:#7ed321,stroke:#333
    style AI4RAGExp fill:#4a90e2,color:#fff
    style GAMOpt fill:#4a90e2,color:#fff
    style SimpleRAG fill:#4a90e2,color:#fff
    style UnitxtEval fill:#4a90e2,color:#fff
    style MPS fill:#4a90e2,color:#fff
