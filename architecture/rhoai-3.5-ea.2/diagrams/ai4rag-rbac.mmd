graph TD
    subgraph Notice["ai4rag RBAC"]
        direction TB
        Note["ai4rag is a Python library<br/>and does not define any<br/>Kubernetes RBAC resources"]
    end

    subgraph SecurityContext["Security Context (Library)"]
        direction TB

        subgraph Secrets["Secrets Required"]
            OGXKey["OGX API Key<br/>Type: Opaque<br/>Provisioned: Manual / env var<br/>Auto-Rotate: No"]
        end

        subgraph AuthMechanisms["Authentication Mechanisms"]
            APIKeyAuth["API Key (Bearer Token)<br/>Endpoint: OGX Server<br/>Methods: POST (chat, embeddings,<br/>vector_io, vector_stores)<br/>Enforcement: OGX Server"]
        end

        subgraph ConsumerResponsibility["Consumer Responsibility"]
            ConsumerRBAC["Consuming service must provide:<br/>- ServiceAccount with appropriate roles<br/>- Access to OGX API Key secret<br/>- Network egress to OGX Server<br/>- Pod security context"]
        end
    end

    OGXKey -->|"passed via api_key param"| APIKeyAuth
    APIKeyAuth -->|"consumer must manage"| ConsumerRBAC

    %% Styling
    style Notice fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Note fill:#fff3cd,stroke:#856404
    style OGXKey fill:#f8d7da,stroke:#721c24
    style APIKeyAuth fill:#d4edda,stroke:#155724
    style ConsumerRBAC fill:#cce5ff,stroke:#004085
