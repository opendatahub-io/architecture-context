graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Platform Managed"]
        Gateway["Platform Ingress<br/>(Gateway/Route)<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token / OAuth"]
        KRBACProxy["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS<br/>SubjectAccessReview"]
    end

    subgraph Pod["POD NETWORK (KServe-managed)"]
        direction TB

        subgraph APIs["MLServer APIs"]
            REST["REST API (FastAPI/Uvicorn)<br/>8080/TCP HTTP<br/>V2 Dataplane API<br/>No encryption (delegated)"]
            GRPC["gRPC API (grpcio)<br/>8081/TCP gRPC/HTTP2<br/>V2 Dataplane API<br/>No encryption (delegated)"]
            Metrics["Metrics Endpoint<br/>8082/TCP HTTP<br/>Prometheus /metrics<br/>Pod network only"]
        end

        subgraph SecurityLayer["Security Controls"]
            Allowlist["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>Read-only (baked in image)<br/>Dual validation: parse + access"]
        end

        subgraph ModelVolume["Model Storage"]
            Models["/mnt/models<br/>PVC / Init Container<br/>POSIX permissions<br/>UID 1000 (non-root)"]
        end
    end

    subgraph EgressServices["EGRESS (Optional)"]
        Kafka["Kafka Broker<br/>9092/TCP<br/>Kafka protocol<br/>Encryption: Configurable"]
        OTel["OpenTelemetry Collector<br/>Configurable port<br/>gRPC (OTLP)<br/>Encryption: Configurable"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>8082/TCP HTTP"]
        Kubelet["Kubernetes Kubelet<br/>Health probes<br/>8080/TCP HTTP"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SA Token"| KRBACProxy
    KRBACProxy -->|"HTTP/8080<br/>No encryption<br/>Pod-internal"| REST

    %% Direct gRPC path
    Gateway -->|"gRPC/8081<br/>Pod network"| GRPC

    %% Internal flows
    REST -.->|validates| Allowlist
    GRPC -.->|validates| Allowlist
    REST -.->|loads models| Models
    GRPC -.->|loads models| Models

    %% Egress
    REST -.->|"Kafka/9092<br/>Configurable"| Kafka
    REST -.->|"gRPC OTLP<br/>Configurable"| OTel

    %% Platform
    Prometheus -->|"HTTP/8082<br/>Scrape"| Metrics
    Kubelet -->|"HTTP/8080<br/>/v2/health/live<br/>/v2/health/ready"| REST

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway,KRBACProxy ingress
    class REST,GRPC,Metrics pod
    class Allowlist,Models security
    class Kafka,OTel egress
    class Prometheus,Kubelet platform
