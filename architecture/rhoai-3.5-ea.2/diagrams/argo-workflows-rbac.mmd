graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(argo-server)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>(ClusterRoleBinding)"]
        CRB_Server["argo-server-binding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Argo["argo-role<br/>(RoleBinding, namespace-scoped)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role"]
        CR_View["argo-aggregate-to-view"]
        CR_Edit["argo-aggregate-to-edit"]
        CR_Admin["argo-aggregate-to-admin"]
    end

    subgraph Roles["Roles"]
        R_Argo["argo-role<br/>(namespace-scoped)"]
    end

    subgraph ArgoResources["Argo CRD Resources (argoproj.io)"]
        Workflows["workflows<br/>+ finalizers"]
        WFTemplates["workflowtemplates<br/>+ finalizers"]
        ClusterWFTemplates["clusterworkflowtemplates<br/>+ finalizers"]
        CronWorkflows["cronworkflows<br/>+ finalizers"]
        TaskSets["workflowtasksets<br/>+ finalizers"]
        TaskResults["workflowtaskresults"]
        ArtifactGC["workflowartifactgctasks"]
        EventBindings["workfloweventbindings"]
        EventSources["eventsources"]
        Sensors["sensors"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        Pods["pods, pods/exec"]
        PodsLog["pods/log"]
        ConfigMaps["configmaps"]
        Secrets["secrets"]
        PVCs["persistentvolumeclaims<br/>+ finalizers"]
        SAs["serviceaccounts"]
        Events["events"]
        PDBs["poddisruptionbudgets"]
    end

    %% Controller bindings
    SA_Argo -->|bound via| CRB_Argo
    SA_Argo -->|bound via| RB_Argo
    CRB_Argo -->|grants| CR_Argo
    RB_Argo -->|grants| R_Argo

    %% Server bindings
    SA_Server -->|bound via| CRB_Server
    CRB_Server -->|grants| CR_Server

    %% Controller permissions on Argo resources
    CR_Argo -->|"get,list,watch,create,<br/>update,patch,delete"| Workflows
    CR_Argo -->|"get,list,watch"| WFTemplates
    CR_Argo -->|"get,list,watch"| ClusterWFTemplates
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete"| CronWorkflows
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| TaskSets
    CR_Argo -->|"list,watch,<br/>deletecollection"| TaskResults
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| ArtifactGC

    %% Controller permissions on core resources
    CR_Argo -->|"create,get,list,watch,<br/>update,patch,delete"| Pods
    CR_Argo -->|"get,watch,list"| ConfigMaps
    CR_Argo -->|"get (restricted:<br/>agent-ca-certificates)"| Secrets
    CR_Argo -->|"create,update,<br/>delete,get"| PVCs
    CR_Argo -->|"get,list"| SAs
    CR_Argo -->|"create,patch"| Events
    CR_Argo -->|"create,get,delete"| PDBs

    %% Server permissions on Argo resources
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| Workflows
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| WFTemplates
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| ClusterWFTemplates
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| CronWorkflows
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| EventBindings
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| EventSources
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| Sensors

    %% Server permissions on core resources
    CR_Server -->|"get,list,watch,delete"| Pods
    CR_Server -->|"get,list,watch"| PodsLog
    CR_Server -->|"get,watch,list"| ConfigMaps
    CR_Server -->|"get,create"| Secrets
    CR_Server -->|"get,list,watch"| SAs
    CR_Server -->|"watch,create,patch"| Events

    %% Aggregate roles
    CR_View -.->|"aggregates to<br/>view role"| Workflows
    CR_Edit -.->|"aggregates to<br/>edit role"| Workflows
    CR_Admin -.->|"aggregates to<br/>admin role"| Workflows

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#4a90e2,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333
    style CR_Server fill:#f5a623,stroke:#333
    style CR_View fill:#f5d89a,stroke:#333
    style CR_Edit fill:#f5d89a,stroke:#333
    style CR_Admin fill:#f5d89a,stroke:#333
    style R_Argo fill:#f5a623,stroke:#333
    style CRB_Argo fill:#ddd,stroke:#333
    style CRB_Server fill:#ddd,stroke:#333
    style RB_Argo fill:#ddd,stroke:#333
    style Workflows fill:#7ed321,stroke:#333
    style WFTemplates fill:#7ed321,stroke:#333
    style ClusterWFTemplates fill:#7ed321,stroke:#333
    style CronWorkflows fill:#7ed321,stroke:#333
    style TaskSets fill:#7ed321,stroke:#333
    style TaskResults fill:#7ed321,stroke:#333
    style ArtifactGC fill:#7ed321,stroke:#333
    style EventBindings fill:#7ed321,stroke:#333
    style EventSources fill:#7ed321,stroke:#333
    style Sensors fill:#7ed321,stroke:#333
    style Pods fill:#d5e8d4,stroke:#333
    style PodsLog fill:#d5e8d4,stroke:#333
    style ConfigMaps fill:#d5e8d4,stroke:#333
    style Secrets fill:#d5e8d4,stroke:#333
    style PVCs fill:#d5e8d4,stroke:#333
    style SAs fill:#d5e8d4,stroke:#333
    style Events fill:#d5e8d4,stroke:#333
    style PDBs fill:#d5e8d4,stroke:#333
