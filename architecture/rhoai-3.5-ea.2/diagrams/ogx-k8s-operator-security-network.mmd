graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        OCIReg["OCI Container Registries<br/>443/TCP HTTPS<br/>Anonymous"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB

        Operator["OGX Kubernetes Operator<br/>SA: ogx-k8s-operator-controller-manager<br/>Image: rhoai/odh-ogx-operator-rhel9"]

        subgraph OperatorPorts["Operator Ports"]
            Metrics["8080/TCP HTTP<br/>Metrics (Prometheus)<br/>No auth"]
            Health["8081/TCP HTTP<br/>Health Probes<br/>No auth"]
            WebhookPort["9443/TCP HTTPS<br/>Webhook (validating)<br/>K8s API mTLS"]
        end

        subgraph OperatorSvc["Services"]
            WebhookSvc["ogx-k8s-operator-webhook-service<br/>ClusterIP 443→9443<br/>HTTPS (TLS)"]
            MetricsSvc["metrics-service<br/>ClusterIP 8443→8080<br/>HTTP"]
        end

        Operator --- OperatorPorts
        WebhookSvc -->|"routes to"| WebhookPort
        MetricsSvc -->|"routes to"| Metrics
    end

    subgraph UserNS["USER NAMESPACES (Per OGXServer Instance)"]
        direction TB

        OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid (OpenShift)"]

        subgraph InstanceSvc["Services"]
            InstanceService["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP (plaintext)<br/>No auth"]
        end

        subgraph InstanceIngress["Ingress (Optional)"]
            IngressRes["{instance}-ingress<br/>80/TCP HTTP<br/>No TLS at Ingress<br/>EXTERNAL"]
        end

        InstanceService -->|"routes to"| OGXPod
        IngressRes -->|"routes to"| InstanceService
    end

    subgraph ExternalAI["EXTERNAL AI SERVICES (OGX Server Egress)"]
        vLLM["vLLM Endpoints<br/>User-configured<br/>Bearer Token"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>API Key"]
        Azure["Azure OpenAI<br/>HTTPS<br/>API Key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>AWS IAM"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>Google Creds"]
        WatsonX["IBM watsonx.ai<br/>HTTPS<br/>API Key"]
    end

    subgraph ExternalData["EXTERNAL DATA SERVICES (OGX Server Egress)"]
        PostgreSQL["PostgreSQL (pgvector)<br/>TCP<br/>User/Password"]
        Milvus["Milvus<br/>HTTP/gRPC<br/>Token"]
        Qdrant["Qdrant<br/>HTTP/gRPC<br/>API Key"]
        Redis["Redis<br/>TCP<br/>Password"]
        S3["S3-compatible Storage<br/>HTTPS<br/>AWS IAM"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| K8sAPI

    %% Control Plane → Operator (Webhook)
    K8sAPI -->|"HTTPS/9443<br/>TLS (service-serving-cert)<br/>mTLS"| WebhookSvc

    %% Operator → Control Plane
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer token<br/>CRUD managed resources"| K8sAPI

    %% Operator → OCI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Anonymous<br/>Base config fetch"| OCIReg

    %% Operator → OGX Pods
    Operator -->|"HTTP/8321<br/>Plaintext<br/>No auth<br/>/v1/health, /v1/providers"| OGXPod

    %% OGX Server → External AI (dotted - proxied by OGX server, not operator)
    OGXPod -.->|"HTTPS"| vLLM
    OGXPod -.->|"HTTPS/443"| OpenAI
    OGXPod -.->|"HTTPS"| Azure
    OGXPod -.->|"HTTPS/443"| Bedrock
    OGXPod -.->|"HTTPS/443"| Vertex
    OGXPod -.->|"HTTPS"| WatsonX

    %% OGX Server → External Data
    OGXPod -.->|"TCP"| PostgreSQL
    OGXPod -.->|"HTTP/gRPC"| Milvus
    OGXPod -.->|"HTTP/gRPC"| Qdrant
    OGXPod -.->|"TCP"| Redis
    OGXPod -.->|"HTTPS"| S3

    %% External → Instance Ingress
    User -.->|"HTTP/80<br/>No TLS"| IngressRes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatrons fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externaldata fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User,OCIReg external
    class K8sAPI controlplane
    class Operator,Metrics,Health,WebhookPort,WebhookSvc,MetricsSvc operatrons
    class OGXPod,InstanceService,IngressRes userns
    class vLLM,OpenAI,Azure,Bedrock,Vertex,WatsonX externalservice
    class PostgreSQL,Milvus,Qdrant,Redis,S3 externaldata
