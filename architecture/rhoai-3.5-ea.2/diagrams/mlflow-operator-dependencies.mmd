graph LR
    MLflowOp["MLflow Operator<br/>(mlflow-operator)"]

    %% External Dependencies (Required)
    MLflowOp -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"chart rendering"| Helm["Helm SDK<br/>v3.19.2"]
    MLflowOp -->|"version comparison"| Semver["semver/v3<br/>v3.4.0"]
    MLflowOp -->|"env var config"| Viper["viper<br/>v1.21.0"]

    %% External Dependencies (Optional / Conditional)
    MLflowOp -.->|"HTTPRoute CRD<br/>(conditional)"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -.->|"ConsoleLink CRD<br/>(conditional)"| OpenShiftAPI["openshift/api"]
    MLflowOp -.->|"ServiceMonitor CRD<br/>(conditional)"| PromOperator["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"HTTPRoute parent ref<br/>external access at /mlflow"| DSGateway["data-science-gateway<br/>(Gateway API)"]
    MLflowOp -->|"TLS cert provisioning<br/>via Service annotation"| ServiceCA["OpenShift service-ca"]
    MLflowOp -->|"CA bundle volume mount<br/>TLS verification"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    MLflowOp -->|"ConsoleLink CR<br/>app menu entry"| Console["OpenShift Console"]
    MLflowOp -->|"ServiceMonitor CR<br/>metrics scraping"| Prometheus["Prometheus Operator"]
    MLflowOp -->|"SSAR, CR watch, SSA<br/>leader election, discovery"| K8sAPI["Kubernetes API Server"]

    %% Upstream operator
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"creates MLflow CR"| MLflowOp

    %% MLflow Server Dependencies (managed workload)
    subgraph "Managed MLflow Server Dependencies"
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        MySQL["MySQL<br/>3306/TCP"]
        S3["S3-compatible Storage<br/>443/TCP, 9000/TCP"]
    end

    MLflowOp -->|"metadata store<br/>PostgreSQL TLS"| PostgreSQL
    MLflowOp -->|"metadata store<br/>MySQL TLS (alt)"| MySQL
    MLflowOp -->|"artifact storage<br/>HTTPS, AWS IAM"| S3

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Helm fill:#999,stroke:#333,color:#fff
    style Semver fill:#999,stroke:#333,color:#fff
    style Viper fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style GatewayAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style OpenShiftAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333

    %% Internal platform deps
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
