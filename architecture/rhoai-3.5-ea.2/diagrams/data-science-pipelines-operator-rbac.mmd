    style Res_Apps fill:#7ed321,stroke:#333,color:#fff
    style Res_DSPA fill:#7ed321,stroke:#333,color:#fff
    style Res_Pipeline fill:#7ed321,stroke:#333,color:#fff
    style Res_Kubeflow fill:#7ed321,stroke:#333,color:#fff
    style Res_Webhook fill:#7ed321,stroke:#333,color:#fff
