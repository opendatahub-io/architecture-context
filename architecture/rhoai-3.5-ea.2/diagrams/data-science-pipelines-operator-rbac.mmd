graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>NS: dspa-controller"]
        SA_Pipeline["ds-pipeline-{name}<br/>NS: {dspa-namespace}"]
        SA_Envoy["ds-pipeline-metadata-envoy-{name}<br/>NS: {dspa-namespace}"]
        SA_PA["ds-pipeline-persistenceagent-{name}<br/>NS: {dspa-namespace}"]
        SA_WfCtrl["ds-pipeline-workflow-controller-{name}<br/>NS: {dspa-namespace}"]
        SA_SW["ds-pipeline-scheduledworkflow-{name}<br/>NS: {dspa-namespace}"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Argo["manager-argo-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_AuthDeleg["ds-pipeline-ui-auth-delegator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>NS: dspa-controller"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Argo["manager-argo-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_Edit["aggregate-dspa-admin-edit<br/>(aggregated to admin/edit)"]
        CR_View["aggregate-dspa-admin-view<br/>(aggregated to view)"]
        CR_ArgoEdit["argo-aggregate-to-edit<br/>(aggregated to edit)"]
        CR_ArgoView["argo-aggregate-to-view<br/>(aggregated to view)"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role<br/>NS: dspa-controller"]
    end

    subgraph ManagerResources["manager-role Resources"]
        Res_Core["Core API<br/>configmaps, secrets,<br/>serviceaccounts, pvcs,<br/>pvs, services, events,<br/>pods, pods/exec, pods/log"]
        Res_Apps["apps<br/>deployments,<br/>deployments/finalizers,<br/>replicasets"]
        Res_DSPA["dspa.opendatahub.io<br/>datasciencepipelinesapplications<br/>/api, /finalizers, /status"]
        Res_Pipeline["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>/finalizers, /status"]
        Res_Kubeflow["kubeflow.org<br/>* (all resources)"]
        Res_Webhook["admissionregistration<br/>mutatingwebhookconfigurations<br/>validatingwebhookconfigurations"]
        Res_Argo["argoproj.io<br/>workflows, workflowtaskresults,<br/>workflowartifactgctasks"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings"]
        Res_Network["networking.k8s.io<br/>networkpolicies, ingresses"]
        Res_Route["route.openshift.io<br/>routes"]
        Res_Monitoring["monitoring.coreos.com<br/>servicemonitors"]
        Res_Batch["batch<br/>jobs"]
        Res_CrossComp["Cross-Component<br/>serving.kserve.io/inferenceservices<br/>ray.io/rayclusters,rayjobs<br/>workload.codeflare.dev/appwrappers<br/>snapshot.storage.k8s.io/volumesnapshots"]
        Res_Auth["Auth APIs<br/>authentication.k8s.io/tokenreviews<br/>authorization.k8s.io/subjectaccessreviews"]
    end

    subgraph ArgoResources["manager-argo-role Resources"]
        Res_ArgoWf["argoproj.io<br/>workflows, workflowtasksets,<br/>workflowartifactgctasks,<br/>cronworkflows,<br/>workflowtemplates,<br/>workflowtaskresults"]
        Res_ArgoPods["Core API<br/>pods, pods/exec,<br/>configmaps, pvcs"]
        Res_ArgoPolicy["policy<br/>poddisruptionbudgets"]
    end

    %% Service Account → Binding → Role
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Argo
    SA_CM -->|bound via| RB_Leader

    SA_Pipeline -->|bound via| CRB_AuthDeleg
    SA_Envoy -->|bound via| CRB_AuthDeleg

    CRB_Manager -->|grants| CR_Manager
    CRB_Argo -->|grants| CR_Argo
    CRB_AuthDeleg -->|grants| CR_AuthDeleg
    RB_Leader -->|grants| R_Leader

    %% Role → Resources
    CR_Manager -->|CRUD + watch| Res_Core
    CR_Manager -->|full control| Res_Apps
    CR_Manager -->|CRUD + watch| Res_DSPA
    CR_Manager -->|CRUD + watch| Res_Pipeline
    CR_Manager -->|full control| Res_Kubeflow
    CR_Manager -->|CRUD + watch| Res_Webhook
    CR_Manager -->|full control| Res_Argo
    CR_Manager -->|CRUD + watch| Res_RBAC
    CR_Manager -->|CRUD + watch| Res_Network
    CR_Manager -->|CRUD + watch| Res_Route
    CR_Manager -->|CRUD + watch| Res_Monitoring
    CR_Manager -->|full control| Res_Batch
    CR_Manager -->|create,delete,get,list,patch| Res_CrossComp
    CR_Manager -->|create| Res_Auth

    CR_Argo -->|full control| Res_ArgoWf
    CR_Argo -->|CRUD| Res_ArgoPods
    CR_Argo -->|create,get,delete| Res_ArgoPolicy

