graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (Generation Backends)
    Orch -->|"gRPC/HTTP2<br/>Generate, Tokenize"| TGIS["TGIS<br/>Text Generation Inference"]
    Orch -->|"gRPC/HTTP2<br/>TextGeneration, Tokenize"| CaikitNLP["caikit-nlp<br/>NLP Generation"]
    Orch -->|"HTTP/HTTPS<br/>/v1/chat/completions"| vLLM["OpenAI Server (vLLM)<br/>Chat Completions"]

    %% Internal Platform Dependencies (Detection & Chunking)
    Orch -->|"HTTP/HTTPS<br/>/api/v1/text/*"| Detectors["Content Detector<br/>Services"]
    Orch -->|"gRPC/HTTP2<br/>ChunkerTokenization"| Chunkers["Chunker Services<br/>(caikit chunkers)"]

    %% External Dependencies (Key Libraries)
    Orch -->|"HTTP framework"| Axum["axum 0.8.8"]
    Orch -->|"gRPC client"| Tonic["tonic 0.14.2"]
    Orch -->|"TLS (ring backend)"| Rustls["rustls 0.23.36"]
    Orch -->|"async runtime"| Tokio["tokio 1.49.0"]
    Orch -->|"gRPC load balancing"| Ginepro["ginepro<br/>DNS-based LB"]

    %% Observability
    Orch -.->|"gRPC/HTTP OTLP"| OTLPCollector["OTLP Collector<br/>Traces + Metrics"]

    %% Optional Dependencies
    Orch -.->|"HTTP client (SSE)"| Reqwest["reqwest 0.12.28"]
    Orch -.->|"telemetry SDK"| OpenTelemetry["opentelemetry 0.31.0"]

    %% Styling
    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform services
    style TGIS fill:#7ed321,stroke:#333
    style CaikitNLP fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style Detectors fill:#7ed321,stroke:#333
    style Chunkers fill:#7ed321,stroke:#333

    %% External libraries
    style Axum fill:#999,stroke:#333,color:#fff
    style Tonic fill:#999,stroke:#333,color:#fff
    style Rustls fill:#999,stroke:#333,color:#fff
    style Tokio fill:#999,stroke:#333,color:#fff
    style Ginepro fill:#999,stroke:#333,color:#fff
    style Reqwest fill:#999,stroke:#333,color:#fff
    style OpenTelemetry fill:#999,stroke:#333,color:#fff

    %% Observability
    style OTLPCollector fill:#f5a623,stroke:#333
