graph LR
    MR["Model Registry<br/>Platform"]

    %% External Dependencies
    MR -->|"metadata storage<br/>3306/TCP"| MySQL["MySQL 8.3+"]
    MR -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"CRD watch<br/>InferenceService"| KServe["KServe v1beta1"]
    MR -->|"catalog data source<br/>443/TCP HTTPS"| HuggingFace["Hugging Face API v2"]
    MR -->|"model signing<br/>443/TCP HTTPS"| Sigstore["Sigstore<br/>(Fulcio/Rekor/TUF)"]
    MR -->|"OCI image ops<br/>443/TCP HTTPS"| Skopeo["skopeo"]
    MR -->|"mTLS, routing<br/>AuthorizationPolicy"| Istio["Istio / Service Mesh"]

    %% Internal Platform Dependencies
    KServe -->|"InferenceService CRD<br/>Controller syncs state"| MR
    K8sAPI["Kubernetes API"] -->|"Services, Namespaces,<br/>Jobs, ConfigMaps, SAR<br/>443/TCP HTTPS"| MR
    IstioGW["Istio Ingress Gateway"] -->|"VirtualService routing<br/>/api/model_registry/<br/>/model-registry/"| MR

    %% Integration Points - Inbound
    Dashboard["ODH Dashboard"] -.->|"UI integration"| MR
    DSPipelines["DS Pipelines"] -.->|"model registration"| MR

    %% External Services (Egress)
    MR -->|"model artifacts<br/>443/TCP HTTPS"| S3["S3 Storage"]
    MR -->|"model images<br/>443/TCP HTTPS"| OCIReg["OCI Registries"]
    MR -->|"resource mgmt<br/>443/TCP HTTPS"| K8sAPI

    %% Sub-component detail
    subgraph MRComponents["Model Registry Components"]
        direction TB
        Proxy["REST Proxy<br/>(Go, 8080/TCP)"]
        BFF["UI BFF<br/>(Go, 8080/TCP)"]
        Catalog["Model Catalog<br/>(Go, 8080/TCP)"]
        Controller["Controller<br/>(Go, 8081/TCP)"]
        CSI["Storage Initializer<br/>(Go CLI)"]
        AsyncJob["Async Upload<br/>(Python Job)"]
    end

