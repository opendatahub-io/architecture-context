graph TD
    subgraph ServiceAccount["Service Account"]
        SA["rhoai-mcp<br/>(deployment namespace)"]
    end

    subgraph Binding["ClusterRoleBinding"]
        CRB["rhoai-mcp"]
    end

    subgraph ClusterRole["ClusterRole: rhoai-mcp"]
        CR["rhoai-mcp"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    subgraph CoreReadResources["Core API — Read"]
        Pods["pods, pods/log"]
        Services["services"]
        Events["events"]
        Nodes["nodes"]
    end

    subgraph CoreWriteResources["Core API — Read + Write"]
        Namespaces["namespaces"]
        Secrets["secrets"]
        PVCs["persistentvolumeclaims"]
        PVs["persistentvolumes"]
        PodsCreate["pods (create only)"]
        Deployments["deployments (create only)"]
    end

    subgraph StorageResources["Storage API"]
        StorageClasses["storageclasses"]
    end

    subgraph KubeflowResources["Kubeflow API"]
        Notebooks["kubeflow.org<br/>notebooks"]
        TrainJobs["trainer.kubeflow.org<br/>trainjobs"]
        TrainingRuntimes["trainer.kubeflow.org<br/>trainingruntimes"]
        ClusterTrainingRuntimes["trainer.kubeflow.org<br/>clustertrainingruntimes"]
    end

    subgraph ODHResources["OpenDataHub API"]
        DSPA["opendatahub.io<br/>datasciencepipelinesapplications"]
    end

    subgraph KServeResources["KServe API"]
        InferenceServices["serving.kserve.io<br/>inferenceservices"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes"]
    end

    subgraph OpenShiftResources["OpenShift API (patch overlay)"]
        DSClusters["datasciencecluster.opendatahub.io<br/>datascienceclusters"]
        ModelRegistries["components.platform.opendatahub.io<br/>modelregistries"]
        Templates["template.openshift.io<br/>templates"]
        Routes["route.openshift.io<br/>routes"]
        Projects["project.openshift.io<br/>projects"]
        ImageStreams["image.openshift.io<br/>imagestreams"]
    end

    %% Core Read permissions
    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, watch"| Events
    CR -->|"get, list, watch"| Nodes

    %% Core Write permissions
    CR -->|"get, list, watch,<br/>create, patch, delete"| Namespaces
    CR -->|"get, list, watch,<br/>create, delete"| Secrets
    CR -->|"get, list, watch,<br/>create, delete"| PVCs
    CR -->|"create"| PVs
    CR -->|"create"| PodsCreate
    CR -->|"create"| Deployments

    %% Storage
    CR -->|"list"| StorageClasses

    %% Kubeflow
    CR -->|"get, list, watch,<br/>create, patch, delete"| Notebooks
    CR -->|"get, list, watch, create,<br/>update, patch, delete"| TrainJobs
    CR -->|"get, list, watch"| TrainingRuntimes
    CR -->|"get, list, watch,<br/>create, delete"| ClusterTrainingRuntimes

    %% ODH
    CR -->|"get, list, watch,<br/>create, delete"| DSPA

    %% KServe
    CR -->|"get, list, watch,<br/>create, delete"| InferenceServices
    CR -->|"get, list, watch,<br/>create"| ServingRuntimes

    %% OpenShift (read-only)
    CR -->|"get, list, watch"| DSClusters
    CR -->|"get, list, watch"| ModelRegistries
    CR -->|"get, list, watch"| Templates
    CR -->|"get, list, watch"| Routes
    CR -->|"get, list, watch, patch"| Projects
    CR -->|"list"| ImageStreams

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#e8a838,stroke:#333,stroke-width:2px,color:#fff
    classDef coreRead fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef coreWrite fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kubeflow fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef odh fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef kserve fill:#b6d7a8,stroke:#6aa84f,stroke-width:2px
    classDef openshift fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class SA sa
    class CRB binding
    class CR role
    class Pods,Services,Events,Nodes coreRead
    class Namespaces,Secrets,PVCs,PVs,PodsCreate,Deployments coreWrite
    class StorageClasses storage
    class Notebooks,TrainJobs,TrainingRuntimes,ClusterTrainingRuntimes kubeflow
    class DSPA odh
    class InferenceServices,ServingRuntimes kserve
    class DSClusters,ModelRegistries,Templates,Routes,Projects,ImageStreams openshift
