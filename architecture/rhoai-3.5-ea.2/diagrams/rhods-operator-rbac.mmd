graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["opendatahub-operator-<br/>controller-manager<br/>NS: redhat-ods-operator"]
        SA_AuthProxy["kube-auth-proxy<br/>NS: openshift-ingress"]
        SA_AdminGroups["{admin-groups}<br/>(configurable)"]
        SA_AllowedGroups["{allowed-groups}<br/>(configurable)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["opendatahub-operator-<br/>manager-rolebinding<br/>(cluster-scoped)"]
        CRB_TokenReview["kube-auth-proxy-<br/>tokenreview<br/>(cluster-scoped)"]
        CRB_AdminCluster["data-science-<br/>admingroupcluster-<br/>rolebinding<br/>(cluster-scoped)"]
        CRB_AllowedCluster["data-science-<br/>allowedgroupcluster-<br/>rolebinding<br/>(cluster-scoped)"]
        CRB_KueueAdmin["kueue-admin-<br/>rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_AdminNS["data-science-<br/>admingroup-rolebinding<br/>NS: {applications-namespace}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["opendatahub-operator-<br/>manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_AdminCluster["data-science-<br/>admingroupcluster-role"]
        CR_AllowedCluster["data-science-<br/>allowedgroupcluster-role"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_AdminNS["data-science-<br/>admingroup-role<br/>NS: {applications-namespace}"]
    end

    %% Bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_AuthProxy -->|"bound via"| CRB_TokenReview
    SA_AdminGroups -->|"bound via"| CRB_AdminCluster
    SA_AdminGroups -->|"bound via"| RB_AdminNS
    SA_AdminGroups -->|"bound via"| CRB_KueueAdmin
    SA_AllowedGroups -->|"bound via"| CRB_AllowedCluster

    CRB_Manager -->|"grants"| CR_Manager
    CRB_TokenReview -->|"grants"| CR_AuthDelegator
    CRB_AdminCluster -->|"grants"| CR_AdminCluster
    CRB_AllowedCluster -->|"grants"| CR_AllowedCluster
    RB_AdminNS -->|"grants"| R_AdminNS

    subgraph ManagerPermissions["opendatahub-operator-manager-role Permissions"]
        direction TB

        subgraph DSCResources["DataScienceCluster Resources"]
            DSC_API["datasciencecluster.opendatahub.io<br/>datascienceclusters (+status/finalizers)<br/>get,list,watch,create,update,patch,delete"]
        end

        subgraph DSCIResources["DSCInitialization Resources"]
            DSCI_API["dscinitialization.opendatahub.io<br/>dscinitializations (+status/finalizers)<br/>get,update,patch,delete"]
        end

        subgraph ServiceResources["Platform Service Resources"]
            SVC_API["services.platform.opendatahub.io<br/>gatewayconfigs, auths, monitorings<br/>(+status/finalizers)<br/>get,list,watch,create,update,patch,delete"]
        end

        subgraph NetworkResources["Network Resources"]
            GW_API["gateway.networking.k8s.io<br/>gateways, gatewayclasses, httproutes<br/>get,list,watch,create,update,patch,delete"]
            ISTIO_API["networking.istio.io<br/>envoyfilters, destinationrules<br/>get,list,watch,create,update,patch,delete"]
            ROUTE_API["route.openshift.io<br/>routes, routes/custom-host<br/>get,list,watch,create,update,patch,delete"]
        end

        subgraph AuthResources["Auth & RBAC Resources"]
            OAUTH_API["oauth.openshift.io<br/>oauthclients<br/>create,delete,list,watch,update,patch,get"]
            RBAC_API["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>* (all verbs)"]
        end

        subgraph OperatorResources["Operator Lifecycle Resources"]
            OLM_API["operators.coreos.com<br/>clusterserviceversions, crds,<br/>subscriptions<br/>get,list,watch,delete,update,create,patch"]
        end

        subgraph MonitoringResources["Monitoring Resources"]
            MON_API["monitoring.coreos.com<br/>servicemonitors, podmonitors,<br/>prometheusrules, prometheuses<br/>get,create,delete,update,watch,list,patch"]
        end

        subgraph PlatformConfigResources["Platform Config Resources"]
            CONFIG_API["config.openshift.io<br/>apiservers, authentications,<br/>infrastructures<br/>get,list,watch"]
        end

        subgraph CertResources["Certificate Resources"]
            CERT_API["cert-manager.io<br/>issuers, certificates<br/>create,patch,get,list,watch,update,delete"]
        end

        subgraph CoreResources["Core Kubernetes Resources"]
            CORE_API["core ('')<br/>namespaces, configmaps, secrets,<br/>services, serviceaccounts, pods,<br/>events, endpoints, pvs, pvcs<br/>get,list,watch,create,update,patch,delete"]
            APPS_API["apps<br/>deployments, replicasets, statefulsets<br/>get,list,watch,create,update,patch,delete"]
            ADMISSION_API["admissionregistration.k8s.io<br/>validating/mutatingwebhookconfigurations<br/>get,list,watch,create,update,delete,patch"]
        end
    end

    subgraph AdminPermissions["data-science-admingroupcluster-role Permissions"]
        ADMIN_DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get,list,watch,update,patch"]
        ADMIN_AUTH["services.platform.opendatahub.io<br/>auths, auths/status<br/>get,list,watch,update,patch"]
        ADMIN_MR["modelregistry.opendatahub.io<br/>modelregistries<br/>get,list,watch,create,update,patch,delete"]
    end

    subgraph AllowedPermissions["data-science-allowedgroupcluster-role Permissions"]
        ALLOWED_AUTH["services.platform.opendatahub.io<br/>auths, auths/status<br/>get,list,watch"]
    end

    %% Role → Resources
    CR_Manager -->|"permits"| ManagerPermissions
    CR_AdminCluster -->|"permits"| AdminPermissions
    CR_AllowedCluster -->|"permits"| AllowedPermissions

