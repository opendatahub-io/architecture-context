graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Agent["AI Agent<br/>(Claude / GPT / Llama)<br/>Bearer Token (JWT or OAuth)"]
    end

    subgraph Ingress["INGRESS (TLS Edge Termination)"]
        Route["OpenShift Route<br/>443/TCP → 8000/TCP<br/>TLS edge termination<br/>Wildcard or custom cert"]
    end

    subgraph Application["APPLICATION (RHOAI MCP Server Pod)"]
        direction TB

        subgraph Namespace["Namespace: redhat-ods-applications"]
            subgraph Pod["Pod: rhoai-mcp | SA: rhoai-mcp"]
                direction TB
                Endpoints["Endpoints:<br/>GET /health (no auth)<br/>GET /sse (OIDC Bearer)<br/>POST /messages (OIDC Bearer)<br/>GET /.well-known/oauth-protected-resource (no auth)"]
                AuthLayer["Auth Layer:<br/>OIDC Middleware (ASGI)<br/>JWT Validator (JWKS)<br/>TokenReview Validator (OCP)<br/>RBAC Filter (SubjectAccessReview)"]
                SafetyGates["Safety Gates:<br/>read_only_mode: true (RHOAI)<br/>enable_dangerous_operations: false<br/>Workflow Tokens (HMAC-SHA256)"]
                PluginLayer["Plugin Manager (pluggy):<br/>9 Domain Plugins + 4 Composite Plugins<br/>K8s Client (kubernetes-python)"]
            end
        end
    end

    subgraph K8sAPIZone["KUBERNETES API (TLS 1.2+)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>Bearer Token (SA)<br/>+ Impersonate-User/Group headers"]
        TokenReviewAPI["TokenReview API<br/>authentication.k8s.io/v1<br/>443/TCP HTTPS"]
        SARAPI["SubjectAccessReview API<br/>authorization.k8s.io/v1<br/>443/TCP HTTPS"]
        UserAPI["User API (OCP)<br/>user.openshift.io/v1<br/>443/TCP HTTPS"]
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        ModelReg["Model Registry<br/>8080/TCP HTTP (no auth)<br/>8443/TCP HTTPS (Bearer via kube-rbac-proxy)<br/>/api/model_registry/v1alpha3"]
        ModelCat["Model Catalog<br/>8080/TCP HTTP (no auth)<br/>8443/TCP HTTPS (Bearer)<br/>/api/model_catalog/v1alpha1"]
        PlannerSvc["Planner Service<br/>8000/TCP HTTP (no auth)<br/>/api/v1/extract, /api/v1/recommend"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (TLS 1.2+)"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>JWKS endpoint<br/>No auth"]
        GitHub["GitHub<br/>443/TCP HTTPS<br/>README content<br/>No auth"]
        HelmRepos["Helm Repositories<br/>443/TCP HTTPS<br/>Chart downloads<br/>No auth"]
    end

    %% Flows
    Agent -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| Route
    Route -->|"HTTP/8000<br/>plaintext in-cluster<br/>Bearer forwarded"| Endpoints

    Endpoints --> AuthLayer
    AuthLayer --> SafetyGates
    SafetyGates --> PluginLayer

    PluginLayer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token<br/>+ Impersonation"| K8sAPI
    AuthLayer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token"| TokenReviewAPI
    AuthLayer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token"| SARAPI
    AuthLayer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer SA Token"| UserAPI

    PluginLayer -->|"HTTP/8080 or HTTPS/8443<br/>None or Bearer"| ModelReg
    PluginLayer -->|"HTTP/8080 or HTTPS/8443<br/>None or Bearer"| ModelCat
    PluginLayer -->|"HTTP/8000<br/>plaintext<br/>No auth"| PlannerSvc

    AuthLayer -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS fetch"| OIDCProvider
    PluginLayer -->|"HTTPS/443<br/>TLS 1.2+"| GitHub
    PluginLayer -->|"HTTPS/443<br/>TLS 1.2+"| HelmRepos

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Agent external
    class Route ingress
    class Endpoints,AuthLayer,SafetyGates,PluginLayer application
    class K8sAPI,TokenReviewAPI,SARAPI,UserAPI k8sapi
    class ModelReg,ModelCat,PlannerSvc internal
    class OIDCProvider,GitHub,HelmRepos externalservice
