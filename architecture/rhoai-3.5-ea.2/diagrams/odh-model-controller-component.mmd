graph TB
    subgraph ODH_Model_Controller["odh-model-controller (Go Operator)"]
        direction TB

        subgraph Controllers["Reconcilers"]
            ISVC_R["InferenceService<br/>Reconciler"]
            LLM_R["LLMInferenceService<br/>Reconciler"]
            GW_R["Gateway<br/>Reconciler"]
            SR_R["ServingRuntime<br/>Reconciler"]
            IG_R["InferenceGraph<br/>Reconciler"]
            CM_R["ConfigMap<br/>Reconciler"]
            SEC_R["Secret<br/>Reconciler"]
            POD_R["Pod<br/>Reconciler"]
            NIM_R["NIM Account<br/>Reconciler"]
        end

        subgraph SubReconcilers["KServe Raw Sub-Reconcilers"]
            RouteR["Route<br/>Reconciler"]
            RBACR["RBAC<br/>Reconciler"]
            MetricsSvcR["Metrics Service<br/>Reconciler"]
            SvcMonR["ServiceMonitor<br/>Reconciler"]
            DashR["Dashboard<br/>Reconciler"]
            KEDAR["KEDA<br/>Reconciler"]
        end

        subgraph Webhooks["Admission Webhooks"]
            WH_ISVC["InferenceService<br/>Webhook"]
            WH_IG["InferenceGraph<br/>Webhook"]
            WH_POD["Pod Mutating<br/>Webhook<br/>(Ray TLS)"]
            WH_NIM["NIM Account<br/>Webhook<br/>(singleton)"]
        end

        ISVC_R --> SubReconcilers
    end

    subgraph Model_Serving_API["model-serving-api (Go HTTP Server)"]
        GW_Handler["/api/v1/gateways<br/>Gateway Discovery"]
        Health["/healthz /readyz"]
        Metrics_API["/metrics"]
        AuthMW["Auth Middleware<br/>SelfSubjectAccessReview"]
        TLS_Reload["FIPS TLS<br/>Cert Reloader"]
    end

    %% Watched CRDs
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    LLM_CR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha2)"]
    GW_CR["Gateway CR<br/>(gateway.networking.k8s.io/v1)"]
    SR_CR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    IG_CR["InferenceGraph CR<br/>(serving.kserve.io/v1alpha1)"]
    NIM_CR["Account CR<br/>(nim.opendatahub.io/v1)"]

    %% Created Resources
    Routes["OpenShift Routes"]
    NetPol["NetworkPolicies"]
    SvcMon["ServiceMonitors<br/>PodMonitors"]
    AuthPol["AuthPolicies<br/>(Kuadrant)"]
    EnvFilter["EnvoyFilters<br/>(Istio)"]
    TrigAuth["TriggerAuthentications<br/>(KEDA)"]
    RayTLS["Ray TLS Secrets<br/>(per-pod certs)"]
    NIM_Res["NIM ConfigMaps<br/>Secrets, Templates"]
    StorageCfg["storage-config<br/>Secrets"]
    CABundle["CA Bundle<br/>ConfigMaps"]

    %% Watch connections
    ISVC_CR -->|watched by| ISVC_R
    LLM_CR -->|watched by| LLM_R
    GW_CR -->|watched by| GW_R
    SR_CR -->|watched by| SR_R
    IG_CR -->|watched by| IG_R
    NIM_CR -->|watched by| NIM_R

    %% Created resource connections
    RouteR -->|creates| Routes
    RBACR -->|creates| NetPol
    SvcMonR -->|creates| SvcMon
    KEDAR -->|creates| TrigAuth
    LLM_R -->|creates| AuthPol
    GW_R -->|creates| EnvFilter
    GW_R -->|creates| AuthPol
    SR_R -->|creates| RayTLS
    POD_R -->|creates| RayTLS
    NIM_R -->|creates| NIM_Res
    SEC_R -->|creates| StorageCfg
    CM_R -->|creates| CABundle

    %% External dependencies
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    NGC["NVIDIA NGC API<br/>443/TCP"]
    Dashboard["RHOAI Dashboard"]

    ISVC_R -->|CRUD| K8sAPI
    NIM_R -->|validate keys| NGC
    Dashboard -->|GET /api/v1/gateways| GW_Handler
    GW_Handler --> AuthMW

    %% Styling
    style ODH_Model_Controller fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Model_Serving_API fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Controllers fill:#bbdefb,stroke:#1976d2
    style SubReconcilers fill:#c8e6c9,stroke:#388e3c
    style Webhooks fill:#fff3e0,stroke:#ef6c00

    style ISVC_CR fill:#f5a623,stroke:#333
    style LLM_CR fill:#f5a623,stroke:#333
    style GW_CR fill:#f5a623,stroke:#333
    style SR_CR fill:#f5a623,stroke:#333
    style IG_CR fill:#f5a623,stroke:#333
    style NIM_CR fill:#f5a623,stroke:#333

    style Routes fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style SvcMon fill:#7ed321,stroke:#333
    style AuthPol fill:#7ed321,stroke:#333
    style EnvFilter fill:#7ed321,stroke:#333
    style TrigAuth fill:#7ed321,stroke:#333
    style RayTLS fill:#7ed321,stroke:#333
    style NIM_Res fill:#7ed321,stroke:#333
    style StorageCfg fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333

    style K8sAPI fill:#e8e8e8,stroke:#333
    style NGC fill:#e8e8e8,stroke:#333
    style Dashboard fill:#e8e8e8,stroke:#333
