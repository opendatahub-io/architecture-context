    style SA_Manager fill:#4a90e2,color:#fff
    style SA_TAS fill:#4a90e2,color:#fff
    style SA_EvalHub fill:#4a90e2,color:#fff
    style SA_GORCH fill:#4a90e2,color:#fff
    style AllUsers fill:#9b59b6,color:#fff

