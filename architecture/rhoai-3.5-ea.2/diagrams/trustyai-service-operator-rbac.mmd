graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["trustyai-service-operator<br/>-controller-manager"]
        SA_TAS["<i>{tas-instance}</i>-proxy"]
        SA_EvalHub["<i>{evalhub-instance}</i>"]
        SA_GORCH["<i>{gorch-instance}</i>"]
    end

    subgraph ManagerRoles["Operator ClusterRoles"]
        direction TB
        TAS_CR["tas-manager-role"]
        LMES_CR["lmes-manager-role"]
        EH_CR["evalhub-manager-role"]
        GORCH_CR["gorch-manager-role"]
        NEMO_CR["nemo-guardrails-manager-role"]
    end

    subgraph UserRoles["User-Facing ClusterRoles"]
        direction TB
        LMEVAL_User["lmeval-user-role"]
        GORCH_Editor["guardrailsorchestrator<br/>-editor-role"]
        GORCH_Viewer["guardrailsorchestrator<br/>-viewer-role"]
        NEMO_Editor["nemoguardrail<br/>-editor-role"]
        NEMO_Viewer["nemoguardrail<br/>-viewer-role"]
    end

    subgraph AuthDelegation["Auth Delegation Bindings"]
        AuthDel_TAS["{tas-instance}-proxy<br/>→ system:auth-delegator"]
        AuthDel_EH["{evalhub-instance}<br/>→ system:auth-delegator"]
        AuthDel_GORCH["{gorch-instance}<br/>→ system:auth-delegator"]
    end

    %% Manager SA bindings
    SA_Manager -->|"bound via CRB"| TAS_CR
    SA_Manager -->|"bound via CRB"| LMES_CR
    SA_Manager -->|"bound via CRB"| EH_CR
    SA_Manager -->|"bound via CRB"| GORCH_CR
    SA_Manager -->|"bound via CRB"| NEMO_CR

    %% Auth delegation
    SA_TAS -->|"bound via CRB"| AuthDel_TAS
    SA_EvalHub -->|"bound via CRB"| AuthDel_EH
    SA_GORCH -->|"bound via CRB"| AuthDel_GORCH

    %% User role default binding
    AllUsers["system:authenticated<br/>(all authenticated users)"] -->|"default RoleBinding<br/>per namespace"| LMEVAL_User

    %% TAS Resources
    subgraph TAS_Resources["TAS Manager Resources"]
        direction LR
        TAS_R1["trustyai.opendatahub.io<br/>trustyaiservices<br/><i>full CRUD</i>"]
        TAS_R2["serving.kserve.io<br/>inferenceservices<br/><i>list,watch,get,update,<br/>patch,delete</i>"]
        TAS_R3["apps: deployments<br/>core: services, pods,<br/>configmaps, secrets, sa<br/><i>full CRUD</i>"]
        TAS_R4["route.openshift.io<br/>routes<br/><i>full CRUD</i>"]
        TAS_R5["networking.istio.io<br/>destinationrules,<br/>virtualservices<br/><i>full CRUD</i>"]
        TAS_R6["monitoring.coreos.com<br/>servicemonitors<br/><i>list,watch,create</i>"]
        TAS_R7["rbac.authorization.k8s.io<br/>clusterrolebindings<br/><i>get,list,watch,<br/>create,update,delete</i>"]
    end

    TAS_CR -->|"grants"| TAS_R1
    TAS_CR -->|"grants"| TAS_R2
    TAS_CR -->|"grants"| TAS_R3
    TAS_CR -->|"grants"| TAS_R4
    TAS_CR -->|"grants"| TAS_R5
    TAS_CR -->|"grants"| TAS_R6
    TAS_CR -->|"grants"| TAS_R7

    %% LMES Resources
    subgraph LMES_Resources["LMES Manager Resources"]
        direction LR
        LMES_R1["trustyai.opendatahub.io<br/>lmevaljobs<br/><i>full CRUD</i>"]
        LMES_R2["core: pods, pods/exec<br/><i>get,list,watch,<br/>create,delete</i>"]
        LMES_R3["core: configmaps<br/><i>get,watch,list,<br/>create,update</i>"]
        LMES_R4["core: secrets<br/><i>get,watch,list</i><br/>(read-only)"]
        LMES_R5["core: PVs, PVCs<br/><i>full CRUD</i>"]
    end

    LMES_CR -->|"grants"| LMES_R1
    LMES_CR -->|"grants"| LMES_R2
    LMES_CR -->|"grants"| LMES_R3
    LMES_CR -->|"grants"| LMES_R4
    LMES_CR -->|"grants"| LMES_R5

    %% EvalHub Resources
    subgraph EH_Resources["EvalHub Manager Resources"]
        direction LR
        EH_R1["trustyai.opendatahub.io<br/>evalhubs, evalhubs/proxy<br/><i>full CRUD</i>"]
        EH_R2["kueue.x-k8s.io<br/>workloads<br/><i>get,list,watch,patch</i>"]
        EH_R3["batch: jobs<br/><i>get,list,watch,<br/>patch,delete</i>"]
        EH_R4["infrastructure.opendatahub.io<br/>hardwareprofiles<br/><i>get,list</i><br/>(read-only)"]
        EH_R5["rbac.authorization.k8s.io<br/>roles, rolebindings<br/><i>full CRUD</i>"]
    end

    EH_CR -->|"grants"| EH_R1
    EH_CR -->|"grants"| EH_R2
    EH_CR -->|"grants"| EH_R3
    EH_CR -->|"grants"| EH_R4
    EH_CR -->|"grants"| EH_R5

    %% GORCH Resources
    subgraph GORCH_Resources["GORCH Manager Resources"]
        direction LR
        GORCH_R1["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/><i>full CRUD</i>"]
        GORCH_R2["serving.kserve.io<br/>servingruntimes<br/><i>get,list,watch</i><br/>(read-only)"]
        GORCH_R3["serving.kserve.io<br/>inferenceservices<br/><i>get,list</i><br/>(read-only)"]
    end

    GORCH_CR -->|"grants"| GORCH_R1
    GORCH_CR -->|"grants"| GORCH_R2
    GORCH_CR -->|"grants"| GORCH_R3

    %% Nemo Resources
    subgraph NEMO_Resources["NemoGuardrails Manager Resources"]
        direction LR
        NEMO_R1["trustyai.opendatahub.io<br/>nemoguardrails<br/><i>full CRUD</i>"]
        NEMO_R2["networking.istio.io<br/>envoyfilters<br/><i>full CRUD</i>"]
        NEMO_R3["mcp.kuadrant.io<br/>mcpgatewayextensions<br/><i>get,list,watch</i><br/>(read-only)"]
        NEMO_R4["gateway.networking.k8s.io<br/>gateways<br/><i>get,list,watch</i><br/>(read-only)"]
    end

    NEMO_CR -->|"grants"| NEMO_R1
    NEMO_CR -->|"grants"| NEMO_R2
    NEMO_CR -->|"grants"| NEMO_R3
    NEMO_CR -->|"grants"| NEMO_R4

    %% User Role Resources
    subgraph UserResources["User-Accessible Resources"]
        direction LR
        UR_LMEval["trustyai.opendatahub.io<br/>lmevaljobs<br/><i>full CRUD</i>"]
        UR_GORCH_E["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/><i>full CRUD</i>"]
        UR_GORCH_V["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/><i>get,list,watch</i>"]
        UR_NEMO_E["trustyai.opendatahub.io<br/>nemoguardrails<br/><i>full CRUD</i>"]
        UR_NEMO_V["trustyai.opendatahub.io<br/>nemoguardrails<br/><i>get,list,watch</i>"]
    end

    LMEVAL_User -->|"grants"| UR_LMEval
    GORCH_Editor -->|"grants"| UR_GORCH_E
    GORCH_Viewer -->|"grants"| UR_GORCH_V
    NEMO_Editor -->|"grants"| UR_NEMO_E
    NEMO_Viewer -->|"grants"| UR_NEMO_V

