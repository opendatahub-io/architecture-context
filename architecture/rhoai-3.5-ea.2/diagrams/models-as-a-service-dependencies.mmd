graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"CRD Create:<br/>AuthPolicy,<br/>TokenRateLimitPolicy"| Kuadrant["Kuadrant / RHCL<br/>1.3+ (RHOAI)"]
    MaaS -->|"AuthN callbacks<br/>HTTPS/8443"| Authorino["Authorino<br/>0.23.1+ (via Kuadrant)"]
    MaaS -->|"Token rate limiting<br/>HTTP/80"| Limitador["Limitador<br/>(via Kuadrant)"]
    MaaS -->|"CRD Create:<br/>HTTPRoute"| GatewayAPI["Gateway API<br/>v1"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>13+"]
    MaaS -->|"GatewayClass, Service CA<br/>RBAC, Routes"| OpenShift["OpenShift<br/>4.19.9+"]
    MaaS -->|"EnvoyFilter, ext_proc<br/>DestinationRule, Telemetry"| Istio["Istio /<br/>Service Mesh"]
    MaaS -->|"TLS certificates<br/>annotation-based"| CertManager["cert-manager /<br/>OpenShift Service CA"]

    %% Internal Platform Dependencies
    MaaS -->|"CRD Watch:<br/>LLMInferenceService"| KServe["KServe<br/>(LLMInferenceService)"]
    MaaS -.->|"Gateway CR,<br/>EnvoyFilter"| EnvoyGateway["Envoy Gateway<br/>(openshift-ingress)"]

    %% Integration Points (inbound)
    ODHOperator["ODH/RHOAI<br/>Operator"] -->|"Component CR:<br/>modelsAsService"| MaaS
    Prometheus["Prometheus"] -->|"PodMonitor<br/>ServiceMonitor"| MaaS

    %% External Services (outbound)
    MaaS -->|"Model inference<br/>HTTPS/443"| ExternalLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CRD CRUD, SAR,<br/>Informer watches"| K8sAPI["Kubernetes API<br/>443/TCP"]

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (grey)
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Limitador fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI dependencies (green)
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style EnvoyGateway fill:#7ed321,stroke:#333,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style ExternalLLM fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
