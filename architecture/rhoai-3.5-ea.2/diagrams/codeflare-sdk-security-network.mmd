graph TB
    subgraph Client["CLIENT (User Workstation / Jupyter Notebook)"]
        SDK["CodeFlare SDK<br/>Python Client Library<br/>Auth: kube-authkit<br/>Crypto: RSA 3072-bit, SHA-256"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer/OIDC/SA<br/>AuthZ: K8s RBAC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        KubeRay["KubeRay Operator<br/>SA: kuberay-operator<br/>Watches: RayCluster, RayJob"]
        KueueCtrl["Kueue Controller<br/>Queue admission<br/>Workload priority"]
    end

    subgraph UserNS["USER NAMESPACE (Workload Pods)"]
        direction TB

        subgraph HeadSvc["{cluster}-head-svc (ClusterIP)"]
            Port6379["6379/TCP<br/>Redis GCS<br/>mTLS"]
            Port8265["8265/TCP<br/>Ray Dashboard<br/>mTLS + Bearer"]
            Port10001["10001/TCP<br/>Ray Client<br/>mTLS"]
        end

        RayHead["Ray Head Pod<br/>Image: quay.io/modh/ray<br/>CA: odh-trusted-ca-bundle"]
        RayWorkers["Ray Worker Pods (N)<br/>GPU: nvidia/amd/intel/habana"]

        subgraph Secrets["Secrets"]
            CASecret["{cluster}-ca-secret<br/>Type: Opaque<br/>ca.crt + ca.key<br/>By: KubeRay"]
            FileSecret["{job}-files<br/>Type: Opaque<br/>entrypoint + working_dir<br/>By: SDK"]
        end
    end

    subgraph Ingress["INGRESS LAYER (Platform-Managed)"]
        HTTPRoute["HTTPRoute (RHOAI 3.x)<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE<br/>Gateway API"]
        OSRoute["OpenShift Route (2.x)<br/>443/TCP HTTPS<br/>edge/reencrypt"]
        K8sIngress["K8s Ingress (vanilla)<br/>80-443/TCP<br/>HTTP/HTTPS"]
    end

    %% Client to Control Plane
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / OIDC<br/>CR CRUD: RayCluster, RayJob,<br/>Secrets, HTTPRoutes, Routes"| K8sAPI

    %% Control Plane to Operators
    K8sAPI -->|"Watch events<br/>Service Account"| KubeRay
    K8sAPI -->|"Watch events<br/>Service Account"| KueueCtrl

    %% Operators to User Namespace
    KubeRay -->|"Creates pods,<br/>services, secrets"| RayHead
    KubeRay -->|"Creates"| RayWorkers
    KubeRay -->|"Provisions"| CASecret

    %% SDK direct connections to Ray
    SDK -->|"HTTPS/8265<br/>mTLS<br/>Bearer Token"| Port8265
    SDK -->|"TCP/10001<br/>mTLS<br/>Client cert"| Port10001

    %% SDK reads secrets
    SDK -.->|"Reads CA cert<br/>via K8s API"| CASecret
    SDK -.->|"Creates file secret<br/>via K8s API"| FileSecret

    %% Head service to pods
    Port6379 --- RayHead
    Port8265 --- RayHead
    Port10001 --- RayHead

    %% SDK discovers ingress
    SDK -.->|"URL discovery<br/>(read-only)"| HTTPRoute
    SDK -.->|"Fallback<br/>(read-only)"| OSRoute
    SDK -.->|"Fallback<br/>(read-only)"| K8sIngress

    %% Ingress to Ray
    HTTPRoute -->|"Proxy to<br/>8265/TCP"| Port8265
    OSRoute -->|"Proxy to<br/>8265/TCP"| Port8265

    %% Styling
    classDef client fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef controlplane fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef operator fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef workload fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef secret fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef ingress fill:#fff9c4,stroke:#f57f17,stroke-width:2px

    class SDK client
    class K8sAPI controlplane
    class KubeRay,KueueCtrl operator
    class RayHead,RayWorkers,Port6379,Port8265,Port10001 workload
    class CASecret,FileSecret secret
    class HTTPRoute,OSRoute,K8sIngress ingress
