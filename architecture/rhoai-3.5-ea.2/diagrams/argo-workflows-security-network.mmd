graph TB
    subgraph Internal["INTERNAL PLATFORM (Trusted - Cluster Network)"]
        direction TB

        subgraph DSPLayer["Data Science Pipelines"]
            DSP["DSP API Server<br/>Creates Workflow CRDs"]
        end

        subgraph K8sLayer["Kubernetes Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>CRD mgmt, Pod orchestration, RBAC"]
        end

        subgraph ControllerNS["Controller Namespace"]
            WFC["workflow-controller<br/>SA: argo<br/>9090/TCP metrics (HTTP, no auth)<br/>6060/TCP healthz (HTTP, no auth)<br/>Leader Election: 15s lease"]
        end

        subgraph WorkflowPod["Workflow Pod (per workflow step)"]
            direction LR
            ArgoExec["argoexec<br/>(init/wait sidecar)<br/>SA: workflow SA<br/>Emissary pattern"]
            UserContainer["User Container<br/>(workflow step)"]
            SharedVol["/var/run/argo<br/>shared volume"]
            ArgoExec ---|exit codes| SharedVol
            SharedVol ---|signals| UserContainer
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        ArtifactRepo["Artifact Repository<br/>S3 / GCS / Azure Blob<br/>443/TCP HTTPS TLS 1.2+<br/>Access Key / SA Key / Account Key"]
        SQLDb["SQL Database (optional)<br/>PostgreSQL 5432/TCP<br/>MySQL 3306/TCP<br/>TLS optional<br/>Username/Password"]
        Registry["Container Image Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Registry Credentials"]
        OIDC["OIDC Provider (optional)<br/>443/TCP HTTPS TLS 1.2+<br/>Client ID/Secret"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    %% Internal Flows
    DSP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"Watch/CRUD<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| WFC
    WFC -->|"Create Pods<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    ArgoExec -->|"WorkflowTaskResult<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Egress Flows
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>Access Key"| ArtifactRepo
    WFC -->|"TCP/5432 or 3306<br/>TLS optional<br/>User/Pass"| SQLDb
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Creds"| Registry
    WFC -.->|"HTTPS/443<br/>TLS 1.2+<br/>Client ID/Secret"| OIDC

    %% Monitoring
    Prometheus -->|"HTTP/9090<br/>No encryption<br/>No auth"| WFC

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef executor fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef user fill:#f5f5f5,stroke:#666,stroke-width:1px

    class DSP internal
    class K8sAPI k8s
    class WFC controller
    class ArgoExec executor
    class UserContainer user
    class SharedVol user
    class ArtifactRepo,SQLDb,Registry,OIDC external
    class Prometheus monitoring
