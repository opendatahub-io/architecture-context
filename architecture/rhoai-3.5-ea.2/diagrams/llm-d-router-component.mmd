graph TB
    subgraph LLMDRouter["llm-d Router"]
        subgraph EPP["Endpoint Picker (EPP)"]
            ExtProc["gRPC ext-proc Server<br/>9002/TCP TLS"]
            HealthSvc["gRPC Health Service<br/>9003/TCP"]
            Metrics["Prometheus Metrics<br/>9090/TCP HTTP"]
            ZMQSub["KV-Events ZMQ SUB<br/>5557/TCP"]

            subgraph Scheduling["Scheduling Engine"]
                Filters["Filters<br/>(ByLabel, PrefixCacheAffinity,<br/>SessionAffinity, SLOHeadroomTier)"]
                Scorers["Scorers<br/>(LoadAware, KVCacheUtil,<br/>PrecisePrefixCache, LoRAffinity,<br/>QueueDepth)"]
                Picker["Picker<br/>(MaxScore, WeightedRandom,<br/>Random)"]
                Filters --> Scorers --> Picker
            end

            subgraph FlowControl["Flow Control"]
                PriorityQueue["Priority Queuing<br/>(Global Strict, Program-Aware,<br/>Round-Robin)"]
                Admission["Admission Control<br/>(SLO-based)"]
            end

            subgraph Reconcilers["K8s Reconcilers"]
                PoolReconciler["InferencePool<br/>Reconciler"]
                PodReconciler["Pod<br/>Reconciler"]
                ObjectiveReconciler["InferenceObjective<br/>Reconciler"]
                RewriteReconciler["InferenceModelRewrite<br/>Reconciler"]
            end

            ExtProc --> Scheduling
            Scheduling --> FlowControl
        end

        subgraph Sidecar["Disaggregation Sidecar (pd-sidecar)"]
            ProxyServer["HTTP Reverse Proxy<br/>8000/TCP"]

            subgraph Connectors["KV Transfer Connectors"]
                NIXLv2["NIXLv2"]
                SharedStorage["Shared Storage"]
                SGLang["SGLang"]
                Mooncake["Mooncake"]
            end

            subgraph EncoderConnectors["Encoder Connectors"]
                ECNixl["ec-nixl"]
                ECExample["ec-example"]
            end

            ProxyServer --> Connectors
            ProxyServer --> EncoderConnectors
        end
    end

    %% External Inputs
    Client["External Client"] -->|HTTPS/443<br/>TLS 1.3| EnvoyProxy
    EnvoyProxy["Envoy Proxy"] -->|gRPC/9002<br/>TLS| ExtProc
    EnvoyProxy -->|HTTP(S)/8000| ProxyServer

    %% CRDs watched
    InferencePoolCR["InferencePool CR"] -->|watched by| PoolReconciler
    InferenceObjectiveCR["InferenceObjective CR"] -->|watched by| ObjectiveReconciler
    InferenceModelRewriteCR["InferenceModelRewrite CR"] -->|watched by| RewriteReconciler
    PodResource["Pod Resources"] -->|watched by| PodReconciler

    %% EPP External Connections
    ExtProc -->|routing decision| EnvoyProxy
    EnvoyProxy -->|routed request| ModelServer["Model Servers<br/>(vLLM/SGLang)"]
    EPP -.->|HTTP poll| ModelServer
    EPP -.->|HTTP/UDS| Tokenizer["Tokenizer Service"]
    EPP -.->|HTTP| LatencyPredictor["Latency Predictor"]
    EPP -.->|gRPC/4317| OTLP["OTLP Collector"]

    %% Sidecar External Connections
    ProxyServer -->|HTTP(S)| PrefillServer["Remote Prefill Server"]
    ProxyServer -->|HTTP(S)| EncoderServer["Remote Encoder Server"]
    ProxyServer -->|HTTP(S)/8001| LocalDecode["Local Decode vLLM"]

    %% K8s API
    Reconcilers -->|HTTPS/443| K8sAPI["Kubernetes API Server"]

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#7ed321,stroke:#333,color:#fff
    style ExtProc fill:#357abd,stroke:#333,color:#fff
    style ProxyServer fill:#5cb318,stroke:#333,color:#fff
    style EnvoyProxy fill:#f5a623,stroke:#333
    style ModelServer fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjectiveCR fill:#f5a623,stroke:#333
    style InferenceModelRewriteCR fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
