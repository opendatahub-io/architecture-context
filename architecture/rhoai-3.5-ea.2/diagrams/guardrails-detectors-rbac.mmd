graph TD
    subgraph "Note: RBAC Managed by Platform"
        direction TB
        Note["No RBAC resources defined in<br/>guardrails-detectors repository.<br/>RBAC is managed by KServe and<br/>the platform operator."]
    end

    subgraph "Example Binding (Demo Only)"
        SA["ServiceAccount<br/>user-one"]
        RB["RoleBinding<br/>user-one-view<br/>(deployment namespace)"]
        CR["ClusterRole<br/>view"]
    end

    subgraph "Platform-Managed Auth (KServe)"
        KServeAuth["KServe Auth<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
        RBAC_Proxy["kube-rbac-proxy<br/>(when auth enabled)"]
        IstioMTLS["Istio mTLS<br/>sidecar.istio.io/inject: 'true'"]
    end

    subgraph "Detector Endpoints"
        EP_Contents["/api/v1/text/contents<br/>Auth: Bearer Token<br/>(via KServe)"]
        EP_Health["/health<br/>Auth: None<br/>(health probes)"]
        EP_Metrics["/metrics<br/>Auth: None<br/>(Prometheus scraping)"]
    end

    SA -->|bound via| RB
    RB -->|grants| CR

    KServeAuth -->|enforces| RBAC_Proxy
    RBAC_Proxy -->|protects| EP_Contents
    IstioMTLS -->|mTLS envelope| EP_Contents
    IstioMTLS -->|mTLS envelope| EP_Health
    IstioMTLS -->|mTLS envelope| EP_Metrics

    subgraph "Secrets"
        S1["aws-connection-minio-...<br/>Type: Opaque (S3)<br/>Purpose: S3 credentials<br/>Auto-Rotate: No"]
        S2["git_auth_secret<br/>Type: Opaque<br/>Purpose: Git auth (Tekton)<br/>Auto-Rotate: No"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style RB fill:#e8e8e8,stroke:#333
    style KServeAuth fill:#7ed321,stroke:#333,color:#fff
    style RBAC_Proxy fill:#7ed321,stroke:#333,color:#fff
    style IstioMTLS fill:#7ed321,stroke:#333,color:#fff
    style EP_Contents fill:#d5e8d4,stroke:#82b366
    style EP_Health fill:#d5e8d4,stroke:#82b366
    style EP_Metrics fill:#d5e8d4,stroke:#82b366
    style S1 fill:#f8d7da,stroke:#dc3545
    style S2 fill:#f8d7da,stroke:#dc3545
