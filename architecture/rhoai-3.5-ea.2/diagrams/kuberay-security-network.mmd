graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer / SA Token"]

        subgraph AdmissionWebhooks["Admission Webhooks (9443/TCP HTTPS)"]
            MutWH["Mutating Webhook<br/>mraycluster.kb.io<br/>Enforces secure-trusted-network"]
            ValWH["Validating Webhook<br/>vraycluster.kb.io<br/>Name + group validation"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)<br/>9443/TCP webhooks (HTTPS/TLS)"]
    end

    subgraph GatewayZone["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP HTTPS<br/>TLS SIMPLE (Gateway-terminated)<br/>Path: /ray/{ns}/{cluster}/*"]
        HTTPRoute["HTTPRoute<br/>(platform namespace)<br/>+ ReferenceGrant"]
    end

    subgraph UserNS["USER NAMESPACE (Ray Cluster)"]
        direction TB

        subgraph HeadPodGroup["Ray Head Pod"]
            KRBP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>Auth: OIDC → TokenReview<br/>+ SubjectAccessReview"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>(localhost only)"]
            GCS["GCS Server<br/>6379/TCP TCP<br/>mTLS (when enabled)"]
            ServeProxy["Serve Proxy<br/>8000/TCP HTTP"]
            RayClient["Ray Client<br/>10001/TCP TCP<br/>mTLS (when enabled)"]
        end

        Workers["Ray Worker Pods<br/>mTLS certs mounted<br/>NetworkPolicy: intra-cluster only"]

        subgraph Services["Kubernetes Services"]
            HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>6379, 8265, 10001, 8080, 8000"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
            HeadlessSvc["Headless services<br/>(pod discovery)"]
        end

        NetPol["NetworkPolicies<br/>Head: intra-cluster + ingress NS + monitoring<br/>Worker: intra-cluster only"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        CertManager["cert-manager<br/>Issuer + Certificate CRs<br/>CA: 10yr, Leaf: 90d/renew@75d"]
        Redis["External Redis<br/>6379/TCP TCP<br/>No encryption (user-configurable)<br/>Auth: Username/Password (optional)"]
        OAuthConfig["OpenShift OAuth Config<br/>config.openshift.io<br/>6443/TCP HTTPS"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-manager)"| MutWH
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-manager)"| ValWH

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% External → Gateway → Head Pod
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Bearer Token"| Gateway
    Gateway --- HTTPRoute
    Gateway -->|"HTTPS/8443<br/>TLS<br/>OIDC Token forwarded"| KRBP
    KRBP -->|"HTTP/8265<br/>localhost<br/>Authenticated"| Dashboard

    %% KRBP auth check
    KRBP -.->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/6443"| K8sAPI

    %% Operator manages resources
    Operator -.->|"creates/manages"| HTTPRoute
    Operator -.->|"creates/manages"| NetPol
    Operator -.->|"creates"| HeadPodGroup
    Operator -.->|"creates"| Workers
    Operator -.->|"creates"| Services

    %% Head ↔ Workers (mTLS)
    GCS <-->|"TCP/6379<br/>mTLS (cert-manager)"| Workers

    %% External dependencies
    Operator -->|"CRD mgmt<br/>SA Token"| CertManager
    GCS -->|"TCP/6379<br/>No encryption<br/>Optional auth"| Redis
    Operator -->|"HTTPS/6443<br/>Read OAuth config"| OAuthConfig
    Prometheus -->|"HTTP/8080<br/>No auth"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef operator fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef gateway fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef userns fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef extservice fill:#fff8e1,stroke:#f9a825,stroke-width:2px
    classDef headpod fill:#c8e6c9,stroke:#388e3c,stroke-width:1px
    classDef netpol fill:#ffcdd2,stroke:#c62828,stroke-width:1px

    class User external
    class K8sAPI,MutWH,ValWH controlplane
    class Operator operator
    class Gateway,HTTPRoute gateway
    class KRBP,Dashboard,GCS,ServeProxy,RayClient headpod
    class Workers,HeadSvc,ServeSvc,HeadlessSvc userns
    class NetPol netpol
    class CertManager,Redis,OAuthConfig,Prometheus extservice
