graph TB
    subgraph JobPod["LM Evaluation Harness Job Pod"]
        direction TB

        subgraph Adapter["LMEval Adapter (main.py)"]
            AdapterCore["LMEvalAdapter<br/>FrameworkAdapter impl"]
            CredResolver["Credential Resolver<br/>API keys, HF tokens, CA certs"]
            OfflineDetect["Offline Mode Detector<br/>Auto-detect /test_data layout"]
            Sanitizer["Error Sanitizer<br/>Redact secrets from callbacks"]
            OCIPublisher["OCI Artifact Publisher<br/>scripts/oci.py"]
            S3Downloader["S3 Downloader<br/>scripts/s3_downloader.py"]
        end

        subgraph LMEval["lm-evaluation-harness (lm_eval/)"]
            Evaluator["Evaluator Engine<br/>lm_eval/evaluator.py"]
            TaskRegistry["Task Registry<br/>200+ benchmark tasks"]
            ModelBackends["Model Backends<br/>HF, vLLM, OpenAI, watsonx"]
            Metrics["Metrics Engine<br/>F1, accuracy, BLEU, etc."]
        end

        subgraph Tasks["Task Definitions (lm_eval/tasks/)"]
            MMLU["MMLU"]
            ARC["ARC"]
            HellaSwag["HellaSwag"]
            GPQA["GPQA"]
            IFEval["IFEval"]
            Unitxt["Unitxt Custom Tasks"]
        end
    end

    %% Input
    ConfigMap["/meta/job.json<br/>(ConfigMap mount)"] -->|job spec| AdapterCore
    Secret["Kubernetes Secret<br/>(Volume mount)"] -->|credentials| CredResolver

    %% Internal flows
    AdapterCore -->|configures| Evaluator
    CredResolver -->|API keys, CA certs| AdapterCore
    OfflineDetect -->|HF_HUB_OFFLINE flags| AdapterCore
    Evaluator -->|loads| TaskRegistry
    TaskRegistry -->|includes| Tasks
    Evaluator -->|uses| ModelBackends
    Evaluator -->|computes| Metrics
    AdapterCore -->|sanitized errors| Sanitizer

    %% External outbound connections
    ModelBackends -->|POST /v1/completions<br/>Bearer Token| ModelEndpoint["Model Inference Endpoint<br/>443/TCP HTTPS"]
    AdapterCore -->|status & results<br/>Bearer Token| EvalHub["EvalHub Service<br/>443/TCP HTTPS"]
    OCIPublisher -->|push artifacts<br/>Basic auth| OCIRegistry["OCI Registry<br/>443/TCP HTTPS"]
    AdapterCore -->|log metrics<br/>Bearer Token| MLflow["MLflow Tracking Server<br/>443/TCP HTTPS"]
    TaskRegistry -->|download datasets<br/>HF_TOKEN| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    S3Downloader -->|download files<br/>AWS IAM| S3["S3-compatible Storage<br/>443/TCP HTTPS"]

    %% Operator relationship
    TrustyAI["TrustyAI lm-eval-controller<br/>(creates Job)"] -.->|deploys| JobPod

    %% Styling
    style AdapterCore fill:#4a90e2,color:#fff
    style Evaluator fill:#4a90e2,color:#fff
    style CredResolver fill:#5b9bd5,color:#fff
    style OfflineDetect fill:#5b9bd5,color:#fff
    style Sanitizer fill:#5b9bd5,color:#fff
    style OCIPublisher fill:#5b9bd5,color:#fff
    style S3Downloader fill:#5b9bd5,color:#fff
    style TaskRegistry fill:#7fb3e0,color:#fff
    style ModelBackends fill:#7fb3e0,color:#fff
    style Metrics fill:#7fb3e0,color:#fff
    style MMLU fill:#a8d08d
    style ARC fill:#a8d08d
    style HellaSwag fill:#a8d08d
    style GPQA fill:#a8d08d
    style IFEval fill:#a8d08d
    style Unitxt fill:#a8d08d
    style ConfigMap fill:#f5a623
    style Secret fill:#f5a623
