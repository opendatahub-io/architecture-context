graph TB
    subgraph LlamaStackServer["Llama Stack Server (Port 8321)"]
        direction TB

        subgraph ProviderPlugin["llama-stack-provider-ragas Provider"]
            direction TB

            subgraph InlineMode["Inline Provider"]
                RagasInlineEval["RagasEvaluatorInline<br/>ragas_inline_eval.py"]
                InlineLLM["LlamaStackInlineLLM<br/>wrappers_inline.py"]
                InlineEmbeddings["LlamaStackInlineEmbeddings<br/>wrappers_inline.py"]
                RagasInlineEval -->|wraps via LangChain| InlineLLM
                RagasInlineEval -->|wraps via LangChain| InlineEmbeddings
            end

            subgraph RemoteMode["Remote Provider"]
                RagasRemoteEval["RagasEvaluatorRemote<br/>ragas_remote_eval.py"]
                KFPPipeline["KFP Pipeline Builder<br/>pipeline.py"]
                KFPComponents["KFP Components<br/>components.py"]
                RemoteLLM["LlamaStackRemoteLLM<br/>wrappers_remote.py"]
                RemoteEmbeddings["LlamaStackRemoteEmbeddings<br/>wrappers_remote.py"]
                RagasRemoteEval -->|constructs| KFPPipeline
                KFPPipeline -->|uses| KFPComponents
                KFPComponents -->|uses| RemoteLLM
                KFPComponents -->|uses| RemoteEmbeddings
            end

            Config["RagasConfig / KubeflowConfig<br/>config.py"]
            Compat["Compatibility Layer<br/>compat.py"]
        end

        EvalAPI["Eval API<br/>/v1alpha/eval/benchmarks"]
        InferenceAPI["Inference API"]
        DatasetIOAPI["DatasetIO API"]
        FilesAPI["Files API"]
        BenchmarksAPI["Benchmarks API"]

        EvalAPI -->|dispatches to| RagasInlineEval
        EvalAPI -->|dispatches to| RagasRemoteEval
        InlineLLM -->|in-process calls| InferenceAPI
        InlineEmbeddings -->|in-process calls| InferenceAPI
        RagasInlineEval -->|reads datasets| DatasetIOAPI
    end

    Client[External Client] -->|"POST /v1alpha/eval/benchmarks/{id}/jobs<br/>8321/TCP HTTP"| EvalAPI

    RagasRemoteEval -->|"submit pipeline<br/>443/TCP HTTPS"| KFP[Kubeflow Pipelines API]
    KFPComponents -->|"HTTP REST<br/>8321/TCP"| LlamaStackServer
    KFPComponents -->|"write results<br/>443/TCP HTTPS"| S3[S3 Storage]
    RagasRemoteEval -->|"fetch results<br/>443/TCP HTTPS"| S3
    InferenceAPI -->|"LLM + embeddings<br/>11434/TCP HTTP"| Ollama[Ollama]

    KFPComponents -->|"read ConfigMap<br/>443/TCP HTTPS"| TrustyAIOp["TrustyAI Operator<br/>ConfigMap"]

    style ProviderPlugin fill:#4a90e2,stroke:#333,color:#fff
    style InlineMode fill:#5ba3f5,stroke:#333,color:#fff
    style RemoteMode fill:#5ba3f5,stroke:#333,color:#fff
    style LlamaStackServer fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style EvalAPI fill:#f5a623,stroke:#333
    style InferenceAPI fill:#f5a623,stroke:#333
    style DatasetIOAPI fill:#f5a623,stroke:#333
    style FilesAPI fill:#f5a623,stroke:#333
    style BenchmarksAPI fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style KFP fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style Ollama fill:#999,stroke:#333
    style TrustyAIOp fill:#7ed321,stroke:#333
