graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / Client Cert Auth"]
        OpenShiftAPI["OpenShift API<br/>(config.openshift.io)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator webhook<br/>SA: spark-operator-webhook<br/>Service: spark-operator-webhook-svc<br/>443→9443/TCP HTTPS<br/>OpenShift TLS profile ciphers"]
        end

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator controller<br/>SA: spark-operator-controller<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (health)"]
        end

        SparkSubmit["spark-submit<br/>(in-process exec)<br/>SA: spark-operator-spark"]
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB
        DriverPod["Spark Driver Pod<br/>SA: configurable<br/>UI: 4040/TCP HTTP"]
        ExecutorPods["Spark Executor Pods<br/>Dynamic scaling"]
        ConnectServer["SparkConnect Server<br/>15002/TCP gRPC<br/>7078/TCP, 7079/TCP TCP<br/>4040/TCP HTTP"]
    end

    subgraph OptionalIngress["OPTIONAL EXTERNAL INGRESS"]
        Ingress["Spark UI Ingress<br/>80/TCP HTTP or 443/TCP HTTPS<br/>Optional TLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor"]
    end

    subgraph OptionalSchedulers["OPTIONAL SCHEDULERS"]
        Volcano["Volcano<br/>scheduling.volcano.sh<br/>443/TCP HTTPS"]
        YuniKorn["YuniKorn<br/>(pod annotations, no network)"]
        Kueue["Kueue<br/>(pod labels, no network)"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control Plane → Webhook (admission)
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+ (OpenShift profile)<br/>API server client cert"| Webhook

    %% Controller → Control Plane
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (GET apiservers)"| OpenShiftAPI

    %% Controller → spark-submit → Driver
    Controller -->|"Process exec"| SparkSubmit
    SparkSubmit -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (spark-operator-spark)"| K8sAPI

    %% Driver ↔ Executors
    DriverPod -->|"TCP<br/>No encryption"| ExecutorPods

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller

    %% Controller → Volcano
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>PodGroup CRUD"| Volcano

    %% SparkConnect access
    User -->|"gRPC/15002<br/>No encryption<br/>NetworkPolicy filtered"| ConnectServer
    ConnectServer -->|"TCP/7078,7079<br/>No encryption"| ExecutorPods

    %% Ingress
    Ingress -->|"HTTP/4040"| DriverPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduler fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI,OpenShiftAPI controlplane
    class Webhook,Controller,SparkSubmit operatorns
    class DriverPod,ExecutorPods,ConnectServer userns
    class Prometheus monitoring
    class Volcano,YuniKorn,Kueue scheduler
    class Ingress ingress
