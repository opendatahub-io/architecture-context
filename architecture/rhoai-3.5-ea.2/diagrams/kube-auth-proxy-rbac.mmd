graph TD
    subgraph "Consuming Deployment"
        SA["ServiceAccount<br/>(consuming deployment's SA)<br/>e.g., rhods-operator SA"]
    end

    subgraph "RBAC Bindings"
        CRB["ClusterRoleBinding<br/>(defined by consuming deployment)"]
    end

    subgraph "Required Permissions"
        CR["ClusterRole<br/>(TokenReview access)"]
    end

    subgraph "Kubernetes API Resources"
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
    end

    subgraph "Authentication Methods via kube-auth-proxy"
        direction TB
        Method1["1. Browser OAuth2/OIDC<br/>Cookie-based session<br/>after authorization code flow"]
        Method2["2. Bearer Token (CLI/API)<br/>OpenShift sha256~ tokens<br/>JWT ID tokens"]
        Method3["3. K8s SA Token Validation<br/>Via TokenReview API<br/>(requires RBAC below)"]
        Method4["4. Skip-Auth Routes<br/>Path/method regex allowlist<br/>--skip-auth-regex"]
        Method5["5. Trusted IPs<br/>IP-based bypass<br/>--trusted-ip"]
    end

    subgraph "Identity Headers (forwarded to upstream)"
        Headers["GAP-Auth<br/>X-Forwarded-User<br/>X-Forwarded-Email<br/>X-Forwarded-Groups<br/>X-Forwarded-Access-Token<br/>X-Forwarded-Preferred-Username"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReview

    Method3 -->|"uses"| TokenReview

    Method1 -->|"sets"| Headers
    Method2 -->|"sets"| Headers
    Method3 -->|"sets"| Headers

    subgraph "Secrets Required"
        S1["OAuth client secret<br/>(Opaque)<br/>client_secret for OIDC/OpenShift"]
        S2["Cookie secret<br/>(Opaque)<br/>HMAC key, 32/64 bytes"]
        S3["TLS cert/key<br/>(kubernetes.io/tls)<br/>Optional HTTPS termination"]
        S4["SA token<br/>(auto-mounted)<br/>OpenShift OAuth + TokenReview"]
        S5["Redis password<br/>(Opaque)<br/>Optional Redis auth"]
    end

    SA -->|"mounts"| S4
    SA -->|"references"| S1
    SA -->|"references"| S2

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#5b9bd5,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style TokenReview fill:#7ed321,stroke:#333
    style Method1 fill:#dbeafe,stroke:#3b82f6
    style Method2 fill:#dbeafe,stroke:#3b82f6
    style Method3 fill:#dbeafe,stroke:#3b82f6
    style Method4 fill:#fef3c7,stroke:#f59e0b
    style Method5 fill:#fef3c7,stroke:#f59e0b
    style Headers fill:#e8d5f5,stroke:#9673a6
    style S1 fill:#fecaca,stroke:#ef4444
    style S2 fill:#fecaca,stroke:#ef4444
    style S3 fill:#fecaca,stroke:#ef4444
    style S4 fill:#fecaca,stroke:#ef4444
    style S5 fill:#fecaca,stroke:#ef4444
