graph TB
    subgraph SparkOperator["Spark Operator (redhat-ods-applications)"]
        direction TB
        subgraph ControllerDeployment["Controller Deployment"]
            Controller["spark-operator controller<br/>Go Operator (controller-runtime)<br/>Port 8080 metrics, 8081 health"]
        end

        subgraph WebhookDeployment["Webhook Deployment"]
            Webhook["spark-operator webhook<br/>Go Admission Webhook<br/>Port 9443 HTTPS, 8081 health"]
        end

        subgraph SchedulerRegistry["Batch Scheduler Registry"]
            Volcano["Volcano Plugin"]
            YuniKorn["YuniKorn Plugin"]
            KubeSched["kube-scheduler Plugin"]
        end

        Controller --> SchedulerRegistry
    end

    User["User / Data Scientist"] -->|"kubectl create"| SparkAppCR["SparkApplication CR<br/>(v1beta2)"]
    User -->|"kubectl create"| ScheduledCR["ScheduledSparkApplication CR<br/>(v1beta2)"]
    User -->|"kubectl create"| ConnectCR["SparkConnect CR<br/>(v1alpha1)"]

    SparkAppCR -->|"watched by"| Controller
    ScheduledCR -->|"watched by"| Controller
    ConnectCR -->|"watched by"| Controller

    K8sAPI["Kubernetes API Server"] -->|"admission request<br/>9443/TCP HTTPS"| Webhook
    Webhook -->|"mutate/validate"| SparkAppCR
    Webhook -->|"mutate/validate"| ScheduledCR
    Webhook -->|"mutate pods"| SparkPods["Driver/Executor Pods"]

    Controller -->|"spark-submit"| SparkSubmit["spark-submit (local)"]
    SparkSubmit -->|"creates via K8s API"| DriverPod["Spark Driver Pod"]
    DriverPod -->|"manages"| ExecutorPods["Spark Executor Pods"]

    Controller -->|"creates"| UIService["Spark UI Service<br/>4040/TCP"]
    Controller -->|"creates"| UIIngress["Spark UI Ingress"]
    Controller -->|"creates"| MonitorCM["Monitoring ConfigMaps"]
    Controller -->|"creates"| ConnectSvc["SparkConnect Service<br/>15002/TCP gRPC"]

    Controller -->|"API calls<br/>443/TCP HTTPS"| K8sAPI
    Controller -->|"reads TLS profile"| OpenShiftAPI["OpenShift API<br/>(config.openshift.io)"]

    Prometheus["Prometheus"] -->|"scrape 8080/TCP"| Controller

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333
    style ScheduledCR fill:#f5a623,stroke:#333
    style ConnectCR fill:#f5a623,stroke:#333
    style DriverPod fill:#7ed321,stroke:#333
    style ExecutorPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OpenShiftAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Volcano fill:#d5e8d4,stroke:#333
    style YuniKorn fill:#d5e8d4,stroke:#333
    style KubeSched fill:#d5e8d4,stroke:#333
