graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph MainServer["Main API Server (8033/TCP)"]
            Router["axum Router<br/>HTTP/HTTPS"]
            TLS["rustls TLS Acceptor<br/>Optional TLS/mTLS"]
            Router --- TLS
        end

        subgraph Handlers["Request Handlers"]
            V1Handler["v1 Handler<br/>Classification + Generation"]
            V2DetHandler["v2 Detection Handler<br/>Content/Chat/Context/Generated"]
            V2GenDetHandler["v2 Generation-Detection Handler"]
            V2StreamHandler["v2 Stream Detection Handler<br/>ND-JSON bidi"]
            OpenAIHandler["OpenAI Compat Handler<br/>Chat Completions / Completions"]
        end

        subgraph Orchestrator["Orchestrator Engine"]
            HandleTrait["Handle&lt;Task&gt; Trait Dispatch"]
            ClientMap["ClientMap<br/>Type-safe Client Registry"]
        end

        subgraph HealthServer["Health Server (8034/TCP)"]
            HealthEP["/health endpoint"]
            InfoEP["/info endpoint<br/>Downstream health"]
        end

        Router --> V1Handler
        Router --> V2DetHandler
        Router --> V2GenDetHandler
        Router --> V2StreamHandler
        Router --> OpenAIHandler

        V1Handler --> HandleTrait
        V2DetHandler --> HandleTrait
        V2GenDetHandler --> HandleTrait
        V2StreamHandler --> HandleTrait
        OpenAIHandler --> HandleTrait
        HandleTrait --> ClientMap
        ClientMap -.->|health checks| InfoEP
    end

    Client[External Client] -->|"POST /api/v1/* or /api/v2/*<br/>8033/TCP HTTP/HTTPS"| Router

    subgraph Downstream["Downstream Services"]
        TGIS["TGIS<br/>gRPC Generation"]
        CaikitNLP["caikit-nlp<br/>gRPC Generation"]
        vLLM["OpenAI-compatible Server<br/>(vLLM) REST"]
        Detectors["Content Detector Services<br/>REST API"]
        Chunkers["Chunker Services<br/>gRPC"]
    end

    ClientMap -->|"gRPC/HTTP2<br/>Optional mTLS"| TGIS
    ClientMap -->|"gRPC/HTTP2<br/>Optional mTLS"| CaikitNLP
    ClientMap -->|"HTTP/HTTPS<br/>Optional Bearer Token"| vLLM
    ClientMap -->|"HTTP/HTTPS<br/>Optional TLS"| Detectors
    ClientMap -->|"gRPC/HTTP2<br/>Optional mTLS"| Chunkers

    OTLP["OTLP Collector"]
    Orchestrator -.->|"gRPC or HTTP<br/>Traces + Metrics"| OTLP

    style MainServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#50c878,stroke:#333,color:#fff
    style Orchestrator fill:#6a5acd,stroke:#333,color:#fff
    style Handlers fill:#4682b4,stroke:#333,color:#fff
    style Client fill:#f5f5f5,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
    style Chunkers fill:#e8e8e8,stroke:#333
    style OTLP fill:#fff2cc,stroke:#d6b656
