graph TB
    subgraph ModelRegistry["Model Registry Platform"]
        direction TB

        subgraph CoreAPI["Core REST API"]
            Proxy["model-registry<br/>(REST Proxy)<br/>Go Service<br/>Port: 8080/TCP"]
            HealthAPI["Health Endpoints<br/>/readyz/health<br/>/readyz/isDirty"]
            Proxy --- HealthAPI
        end

        subgraph UILayer["UI Layer"]
            BFF["model-registry-ui<br/>(BFF)<br/>Go Service<br/>Port: 8080/TCP"]
            Frontend["model-registry-ui<br/>(Frontend)<br/>React/TypeScript SPA"]
            BFF -->|serves static assets| Frontend
        end

        subgraph CatalogService["Catalog Service"]
            Catalog["model-catalog<br/>Go Service<br/>Port: 8080/TCP"]
            PluginArch["Plugin Architecture<br/>HuggingFace / YAML / DB"]
            MCPCatalog["MCP Server Catalog"]
            Catalog --- PluginArch
            Catalog --- MCPCatalog
        end

        subgraph K8sComponents["Kubernetes Components"]
            Controller["model-registry-controller<br/>Go Operator<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP"]
            CSI["model-registry-storage-initializer<br/>(CSI)<br/>Go CLI Tool"]
            AsyncJob["async-upload-job<br/>Python K8s Job"]
        end
    end

    %% External Users
    User["Data Scientist / MLOps"]
    Client["API Client"]

    %% Data Stores
    MySQL[("MySQL 8.3+<br/>3306/TCP")]
    PostgreSQL[("PostgreSQL 16+<br/>5432/TCP")]
    CatalogPG[("PostgreSQL 17.6<br/>(Catalog)<br/>5432/TCP")]

    %% External Services
    KServeISVC["KServe<br/>InferenceService CR"]
    S3["S3 Storage<br/>443/TCP"]
    OCIReg["OCI Registry<br/>443/TCP"]
    HuggingFace["Hugging Face API<br/>443/TCP"]
    Sigstore["Sigstore<br/>(Fulcio/Rekor)<br/>443/TCP"]
    K8sAPI["Kubernetes API<br/>443/TCP"]
    IstioGW["Istio Gateway<br/>(kubeflow-gateway)"]

    %% User flows
    User -->|browses models| Frontend
    Client -->|REST API calls| IstioGW

    %% Ingress
    IstioGW -->|/api/model_registry/| Proxy
    IstioGW -->|/model-registry/| BFF
    IstioGW -->|/api/model_catalog/| Catalog

    %% Internal flows
    BFF -->|proxies API calls| Proxy
    BFF -->|proxies catalog queries| Catalog
    BFF -->|SAR checks, job mgmt| K8sAPI

    %% Data store connections
    Proxy -->|GORM| MySQL
    Proxy -->|GORM| PostgreSQL
    Catalog -->|GORM + pglock| CatalogPG

    %% Controller flows
    Controller -->|watches| KServeISVC
    Controller -->|syncs state| Proxy
    Controller -->|list Services| K8sAPI

    %% CSI flows
    CSI -->|resolves model URIs| Proxy
    CSI -->|downloads artifacts| S3

    %% Async job flows
    AsyncJob -->|registers models| Proxy
    AsyncJob -->|upload/download| S3
    AsyncJob -->|push/pull images| OCIReg
    AsyncJob -->|signs models| Sigstore

    %% Catalog external
    Catalog -->|fetches metadata| HuggingFace

    %% KServe CSI registration
    CSI -.->|model-registry:// URI| KServeISVC

