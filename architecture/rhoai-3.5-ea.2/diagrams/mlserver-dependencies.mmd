    style OTelSDK fill:#e91e63,stroke:#333,color:#fff

    %% Data Processing
    style NumPy fill:#795548,stroke:#333,color:#fff
    style Pandas fill:#795548,stroke:#333,color:#fff
    style OrJSON fill:#795548,stroke:#333,color:#fff

    %% Async/Concurrency
    style AIOKafka fill:#9c27b0,stroke:#333,color:#fff
    style Gevent fill:#9c27b0,stroke:#333,color:#fff
    style UVLoop fill:#9c27b0,stroke:#333,color:#fff

