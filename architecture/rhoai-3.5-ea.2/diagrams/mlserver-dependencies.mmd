graph LR
    MLServer["MLServer<br/>ML Inference Server<br/>(V2 Dataplane API)"]

    %% Internal RHOAI Dependencies
    MLServer -->|"runtime container<br/>deployed by"| KServe["KServe<br/>(InferenceService lifecycle)"]
    MLServer -->|"runtime container<br/>multi-model serving"| ModelMesh["ModelMesh<br/>(ServingRuntime)"]

    %% Core Framework Dependencies
    MLServer -->|"REST API"| FastAPI["FastAPI >=0.134.0<br/>+ Uvicorn"]
    MLServer -->|"gRPC API"| GRPCIO["grpcio >=1.67.1<br/>+ protobuf"]
    MLServer -->|"data validation"| Pydantic["Pydantic ^2.7.1<br/>+ pydantic-settings"]

    %% ML Runtime Dependencies
    MLServer -->|"sklearn runtime"| ScikitLearn["scikit-learn"]
    MLServer -->|"xgboost runtime"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm runtime"| LightGBM["LightGBM"]
    MLServer -->|"onnx runtime"| ONNX["onnxruntime"]

    %% Observability Dependencies
    MLServer -->|"metrics"| PromExporter["starlette-exporter<br/>py-grpc-prometheus"]
    MLServer -->|"tracing"| OTelSDK["opentelemetry-sdk ^1.22.0<br/>+ FastAPI/gRPC instrumentation"]

    %% Data Processing Dependencies
    MLServer -->|"tensor codec"| NumPy["numpy"]
    MLServer -->|"dataframe codec"| Pandas["pandas"]
    MLServer -->|"JSON serialization"| OrJSON["orjson"]

    %% Async/Concurrency Dependencies
    MLServer -->|"async Kafka"| AIOKafka["aiokafka"]
    MLServer -->|"parallel workers"| Gevent["gevent"]
    MLServer -->|"event loop"| UVLoop["uvloop"]

    %% Platform Dependencies
    MLServer -.->|"traffic routing<br/>mTLS"| Istio["Istio / Service Mesh"]
    MLServer -.->|"auth sidecar"| KRBACProxy["kube-rbac-proxy"]

    %% Integration Points (downstream consumers)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8082/TCP"| MLServer
    OTelCollector["OpenTelemetry Collector"] -.->|"receives traces<br/>gRPC OTLP"| MLServer
    Kafka["Kafka Broker"] -.->|"async inference<br/>9092/TCP"| MLServer
    Kubernetes["Kubernetes Kubelet"] -->|"health probes<br/>8080/TCP"| MLServer

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff

    %% Core Frameworks
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style GRPCIO fill:#009688,stroke:#333,color:#fff
    style Pydantic fill:#009688,stroke:#333,color:#fff

    %% ML Runtimes
    style ScikitLearn fill:#f57c00,stroke:#333,color:#fff
    style XGBoost fill:#f57c00,stroke:#333,color:#fff
    style LightGBM fill:#f57c00,stroke:#333,color:#fff
    style ONNX fill:#f57c00,stroke:#333,color:#fff

    %% Observability
