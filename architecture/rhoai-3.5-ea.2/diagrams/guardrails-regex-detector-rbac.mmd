graph TD
    subgraph "Guardrails Regex Detector — RBAC"
        direction TB

        Note["ℹ No RBAC Defined<br/><br/>This service has no ClusterRoles,<br/>Roles, or RoleBindings defined<br/>in the repository.<br/><br/>The service does not interact<br/>with the Kubernetes API.<br/><br/>RBAC is expected to be defined<br/>by the platform operator or<br/>Guardrails Orchestrator<br/>deployment manifests."]
