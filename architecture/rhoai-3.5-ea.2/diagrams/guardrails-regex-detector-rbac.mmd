        NP["NetworkPolicy<br/>(not defined in repo)"]
        NP -->|"should restrict ingress to"| Pod
        NP -->|"allow only from"| OrchestratorSA["FMS Guardrails<br/>Orchestrator"]
    end

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Pod fill:#4a90e2,stroke:#333,color:#fff
