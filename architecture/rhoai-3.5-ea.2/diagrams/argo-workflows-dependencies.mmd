graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"CRD mgmt, pod orchestration<br/>HTTPS/443 SA Token"| K8s["Kubernetes v1.32+<br/>(Required)"]

    %% External Dependencies (Optional)
    ArgoWF -->|"artifact storage<br/>HTTPS/443 Access Key"| S3["S3-compatible Storage<br/>(Optional)"]
    ArgoWF -->|"artifact storage<br/>HTTPS/443 SA Key"| GCS["Google Cloud Storage<br/>(Optional)"]
    ArgoWF -->|"artifact storage<br/>HTTPS/443 Account Key"| Azure["Azure Blob Storage<br/>(Optional)"]
    ArgoWF -->|"workflow archiving<br/>TCP/5432 User/Pass"| PostgreSQL["PostgreSQL<br/>(Optional)"]
    ArgoWF -->|"workflow archiving<br/>TCP/3306 User/Pass"| MySQL["MySQL<br/>(Optional)"]
    ArgoWF -->|"SSO authentication<br/>HTTPS/443 Client ID"| OIDC["OIDC Provider<br/>(Optional)"]
    ArgoWF -->|"entrypoint resolution<br/>HTTPS/443"| Registry["Container Registry"]

    %% Internal Platform Dependencies
    DSPOperator["Data Science Pipelines<br/>Operator"] -->|"deploys & configures"| ArgoWF
    DSPAPIServer["Data Science Pipelines<br/>API Server"] -->|"creates Workflow CRDs<br/>HTTPS/443"| ArgoWF

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| ArgoWF
    ArgoEvents["Argo Events<br/>(Optional)"] -.->|"EventSource/Sensor<br/>CRD Watch"| ArgoWF

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8s fill:#999,stroke:#333,color:#fff

    %% Optional external
    style S3 fill:#bbb,stroke:#333
    style GCS fill:#bbb,stroke:#333
    style Azure fill:#bbb,stroke:#333
    style PostgreSQL fill:#bbb,stroke:#333
    style MySQL fill:#bbb,stroke:#333
    style OIDC fill:#bbb,stroke:#333
    style Registry fill:#bbb,stroke:#333

    %% Internal RHOAI
    style DSPOperator fill:#7ed321,stroke:#333,color:#fff
    style DSPAPIServer fill:#7ed321,stroke:#333,color:#fff

    %% Consumers
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style ArgoEvents fill:#e1d5e7,stroke:#9673a6
