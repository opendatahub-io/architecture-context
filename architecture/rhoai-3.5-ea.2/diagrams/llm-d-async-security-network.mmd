graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Producer Client<br/>(External Application)"]
    end

    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph PodBoundary["Pod: async-processor"]
            AP["Async Processor<br/>SA: async-processor<br/>Image: ghcr.io/llm-d/async-processor:0.6.0"]
            MetricsPort["Metrics Endpoint<br/>:9090/TCP HTTP<br/>Optional K8s RBAC auth"]
        end

        subgraph IGWPod["Inference Gateway"]
            IGW["Inference Gateway (IGW)<br/>:80/TCP or :443/TCP<br/>HTTP/HTTPS"]
        end

        subgraph ModelServers["Model Serving"]
            vLLM["vLLM Model Servers<br/>(PodMonitor scraped)"]
        end

        subgraph Monitoring["Monitoring"]
            Prom["Prometheus<br/>:9090/TCP HTTP"]
        end

        K8sAPI["Kubernetes API Server<br/>:443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["Redis<br/>:6379/TCP<br/>Redis Protocol<br/>Optional TLS (rediss://)"]
        GCPPubSub["GCP Pub/Sub<br/>:443/TCP<br/>HTTPS/gRPC<br/>TLS 1.2+"]
        GMP["Google Managed Prometheus<br/>:443/TCP<br/>HTTPS<br/>TLS 1.2+"]
    end

    %% Client to Redis (via Producer SDK)
    Client -->|"Redis Protocol / 6379<br/>Optional TLS<br/>Password in URL"| Redis

    %% AP to Redis
    AP -->|"Redis Protocol / 6379<br/>Optional TLS (rediss://)<br/>Password in URL<br/>SUBSCRIBE, PUBLISH, ZADD,<br/>ZPOPMIN, ZRANGEBYSCORE, LPUSH, BRPOP"| Redis

    %% AP to IGW
    AP -->|"HTTP(S) / 80 or 443<br/>Configurable TLS 1.2+<br/>Optional mTLS (client certs)<br/>x-gateway-inference-objective header"| IGW

    %% AP to GCP
    AP -->|"HTTPS+gRPC / 443<br/>TLS 1.2+<br/>OAuth2 (ADC)"| GCPPubSub

    %% AP to Prometheus
    AP -->|"HTTP / 9090<br/>Configurable encryption<br/>PromQL queries"| Prom

    %% AP to GMP
    AP -->|"HTTPS / 443<br/>TLS 1.2+<br/>OAuth2"| GMP

    %% AP metrics auth
    AP -.->|"HTTPS / 443<br/>SubjectAccessReview<br/>(metrics auth delegation)"| K8sAPI

    %% Prometheus scrape
    Prom -.->|"HTTP / metrics<br/>Scrape vLLM metrics<br/>PodMonitor relabeling"| vLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef igw fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class AP,MetricsPort pod
    class IGW igw
    class Redis,GCPPubSub,GMP externalservice
    class K8sAPI k8s
    class Prom monitoring
    class vLLM monitoring
