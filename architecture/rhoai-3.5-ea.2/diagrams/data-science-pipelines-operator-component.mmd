graph TB
    subgraph Operator["Data Science Pipelines Operator"]
        direction TB
        Controller["DSPO Controller<br/>(controller-runtime)<br/>Reconciles DSPA CRs"]
        WebhookServer["Webhook Server<br/>8443/TCP HTTPS<br/>Validates/Mutates PipelineVersion"]
        ManagedPipelines["Managed Pipelines Fetcher<br/>OCI image inspection<br/>Registry allowlist validation"]
    end

    User["User / Dashboard"] -->|creates| DSPACR["DataSciencePipelinesApplication CR<br/>(dspa.opendatahub.io/v1)"]
    DSPACR -->|watched by| Controller

    subgraph ManagedStack["Managed DSP Stack (per DSPA namespace)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["ds-pipeline-api-server<br/>REST: 8888/TCP<br/>gRPC: 8887/TCP"]
            KubeRBACProxy1["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        end

        subgraph WorkflowLayer["Workflow Execution"]
            WorkflowCtrl["Argo Workflow Controller<br/>Executes pipeline steps"]
            PersistenceAgent["Persistence Agent<br/>Syncs workflow status"]
            ScheduledWF["Scheduled Workflow<br/>Cron-based scheduling"]
        end

        subgraph MetadataLayer["ML Metadata"]
            MetadataGRPC["metadata-grpc<br/>gRPC: 8080/TCP"]
            MetadataEnvoy["metadata-envoy<br/>gRPC-Web: 9090/TCP"]
            KubeRBACProxy2["kube-rbac-proxy<br/>8443/TCP HTTPS"]
        end

        subgraph StorageLayer["Storage (Optional Managed)"]
            MariaDB["MariaDB<br/>3306/TCP MySQL"]
            MinIO["MinIO<br/>9000/TCP S3"]
        end
    end

    Controller -->|deploys via manifestival| ManagedStack

    KubeRBACProxy1 -->|proxies auth| APIServer
    KubeRBACProxy2 -->|proxies auth| MetadataEnvoy
    MetadataEnvoy -->|gRPC-Web translation| MetadataGRPC

    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| MinIO
    APIServer -->|creates| WorkflowCR["Workflow CR<br/>(argoproj.io)"]
    WorkflowCR -->|watched by| WorkflowCtrl
    PersistenceAgent -->|syncs status| APIServer
    MetadataGRPC -->|stores lineage| MariaDB

    PipelineCR["Pipeline CR<br/>(pipelines.kubeflow.org/v2beta1)"]
    PipelineVersionCR["PipelineVersion CR<br/>(pipelines.kubeflow.org/v2beta1)"]
    ScheduledWFCR["ScheduledWorkflow CR<br/>(kubeflow.org/v1beta1)"]

    PipelineVersionCR -->|validated by| WebhookServer
    ScheduledWFCR -->|watched by| ScheduledWF

    Controller -->|inspects images| ManagedPipelines

    %% External Dependencies
    Controller -->|watches| PlatformOp["rhods-operator /<br/>opendatahub-operator"]
    Controller -->|reads| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    Controller -->|reads| ServiceCA["openshift-service-ca.crt<br/>ConfigMap"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style WebhookServer fill:#4a90e2,stroke:#333,color:#fff
    style ManagedPipelines fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#5bb5e0,stroke:#333,color:#fff
    style WorkflowCtrl fill:#5bb5e0,stroke:#333,color:#fff
    style PersistenceAgent fill:#5bb5e0,stroke:#333,color:#fff
    style ScheduledWF fill:#5bb5e0,stroke:#333,color:#fff
    style MetadataGRPC fill:#5bb5e0,stroke:#333,color:#fff
    style MetadataEnvoy fill:#5bb5e0,stroke:#333,color:#fff
    style KubeRBACProxy1 fill:#e8744f,stroke:#333,color:#fff
    style KubeRBACProxy2 fill:#e8744f,stroke:#333,color:#fff
    style MariaDB fill:#9b59b6,stroke:#333,color:#fff
    style MinIO fill:#9b59b6,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333
    style WorkflowCR fill:#f5a623,stroke:#333
    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style ScheduledWFCR fill:#f5a623,stroke:#333
    style PlatformOp fill:#e8e8e8,stroke:#333
    style CABundle fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
