graph TD
    subgraph UserContext["User Authentication Context"]
        User["User / Service Account<br/>(Jupyter Notebook context)"]
        AuthMethods["Auth Methods:<br/>kube-authkit auto-detect<br/>OIDC device flow<br/>OpenShift OAuth<br/>Bearer Token<br/>kubeconfig"]
    end

    User -->|"authenticates via"| AuthMethods
    AuthMethods -->|"obtains credentials"| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]

    subgraph RequiredPerms["Required User Permissions (No ClusterRole deployed)"]
        direction TB

        subgraph RayPerms["ray.io API Group"]
            RayClusters["rayclusters<br/>get, list, create,<br/>delete, patch"]
            RayJobs["rayjobs<br/>get, list, create,<br/>delete, patch"]
        end

        subgraph CorePerms["Core API Group"]
            Secrets["secrets<br/>get, list, create,<br/>replace"]
            Namespaces["namespaces<br/>get"]
        end

        subgraph KueuePerms["kueue.x-k8s.io API Group"]
            LocalQueues["localqueues<br/>list"]
            Workloads["workloads<br/>list"]
            WPClasses["workloadpriorityclasses<br/>get"]
        end

        subgraph NetworkPerms["Network Discovery (read-only)"]
            Routes["route.openshift.io<br/>routes: list"]
            HTTPRoutes["gateway.networking.k8s.io<br/>httproutes: list, get"]
            Gateways["gateway.networking.k8s.io<br/>gateways: get"]
            GWConfigs["services.platform.opendatahub.io<br/>gatewayconfigs: get"]
            Ingresses["networking.k8s.io<br/>ingresses: list"]
        end
    end

    K8sAPI -->|"authorizes"| RequiredPerms

    subgraph Resources["Kubernetes Resources Accessed"]
        RayClusterCR["RayCluster CR<br/>ray.io/v1"]
        RayJobCR["RayJob CR<br/>ray.io/v1"]
        SecretRes["Secrets<br/>(CA certs, file uploads)"]
        LQRes["LocalQueue CRs"]
        HTTPRouteRes["HTTPRoute CRs"]
    end

    RayClusters -->|"manages"| RayClusterCR
    RayJobs -->|"manages"| RayJobCR
    Secrets -->|"reads/creates"| SecretRes
    LocalQueues -->|"discovers"| LQRes
    HTTPRoutes -->|"discovers URLs"| HTTPRouteRes

    subgraph DirectAuth["Direct Service Authentication"]
        RayDashAuth["Ray Dashboard<br/>8265/TCP<br/>Auth: Bearer Token<br/>(forwarded from K8s)<br/>Enforcement: OAuth proxy"]
        RayClientAuth["Ray Client<br/>10001/TCP<br/>Auth: mTLS client cert<br/>(SDK-generated)<br/>Enforcement: Ray head TLS"]
    end

    User -->|"connects directly"| DirectAuth

    %% Styling
    style User fill:#08427b,stroke:#333,color:#fff
    style AuthMethods fill:#e8eaf6,stroke:#283593
    style K8sAPI fill:#e0e0e0,stroke:#616161

    style RayClusters fill:#fff3e0,stroke:#e65100
    style RayJobs fill:#fff3e0,stroke:#e65100
    style Secrets fill:#fce4ec,stroke:#c62828
    style Namespaces fill:#e8f5e9,stroke:#2e7d32
    style LocalQueues fill:#f3e5f5,stroke:#6a1b9a
    style Workloads fill:#f3e5f5,stroke:#6a1b9a
    style WPClasses fill:#f3e5f5,stroke:#6a1b9a
    style Routes fill:#e0f7fa,stroke:#00695c
    style HTTPRoutes fill:#e0f7fa,stroke:#00695c
    style Gateways fill:#e0f7fa,stroke:#00695c
    style GWConfigs fill:#e0f7fa,stroke:#00695c
    style Ingresses fill:#e0f7fa,stroke:#00695c

    style RayClusterCR fill:#fff3e0,stroke:#e65100
    style RayJobCR fill:#fff3e0,stroke:#e65100
    style SecretRes fill:#fce4ec,stroke:#c62828
    style LQRes fill:#f3e5f5,stroke:#6a1b9a
    style HTTPRouteRes fill:#e0f7fa,stroke:#00695c

    style RayDashAuth fill:#f5a623,stroke:#333,color:#fff
    style RayClientAuth fill:#f5a623,stroke:#333,color:#fff
