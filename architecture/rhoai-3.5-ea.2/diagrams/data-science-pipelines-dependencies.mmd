graph LR
    DSP["Data Science Pipelines<br/>(KFP v2)"]

    %% External Dependencies (Required)
    DSP -->|"execution engine<br/>v3.7.14"| Argo["Argo Workflows"]
    DSP -->|"metadata persistence<br/>3306/5432 TCP"| DB["MySQL / PostgreSQL"]
    DSP -->|"artifact lineage<br/>gRPC/8080"| MLMD["ML Metadata (MLMD)<br/>v1.14.0"]
    DSP -->|"blob storage<br/>HTTP/9000"| ObjectStore["MinIO / SeaweedFS / S3"]
    DSP -->|"orchestration<br/>1.27+"| K8s["Kubernetes"]
    DSP -->|"gRPC-Web proxy<br/>9090/TCP"| Envoy["Envoy<br/>v2.16.1 (bundled)"]

    %% Optional External Dependencies
    DSP -.->|"experiment tracking<br/>HTTPS/8443 (optional)"| MLflow["MLflow Tracking"]

    %% Internal RHOAI Dependencies
    DSPO["data-science-pipelines-operator<br/>(DSPO)"] -->|"deploys via<br/>DSPA CRD"| DSP
    RHODS["rhods-operator"] -->|"platform config<br/>DSCInitialization CRD"| DSP
    Istio["Istio Service Mesh"] -->|"mTLS + AuthZ<br/>sidecar injection"| DSP
    OAuth["OpenShift OAuth"] -->|"user auth<br/>token passthrough"| DSP

    %% Integration Points (Consumers)
    Dashboard["ODH / RHOAI Dashboard"] -->|"UI management"| DSP
    Notebooks["Jupyter Notebooks"] -->|"KFP SDK<br/>submit pipelines"| DSP

