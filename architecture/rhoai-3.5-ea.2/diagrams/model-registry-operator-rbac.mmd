graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Reg["{name}<br/>(registry namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDeleg["{name}-auth-delegator<br/>(per registry instance)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Users["{name}-users<br/>(registry namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_Editor["modelregistry-editor-role<br/>(extras)"]
        CR_Viewer["modelregistry-viewer-role<br/>(extras)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Leader["leader-election-role<br/>(operator namespace)"]
        R_RegUser["registry-user-{name}<br/>(registry namespace)"]
    end

    subgraph Subjects["Subjects"]
        Group_Users["Group: {name}-users"]
    end

    %% Bindings
    SA_CM -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager

    SA_CM -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| R_Leader

    SA_Reg -->|"bound via"| CRB_AuthDeleg
    CRB_AuthDeleg -->|"grants"| CR_AuthDeleg

    Group_Users -->|"bound via"| RB_Users
    RB_Users -->|"grants"| R_RegUser

    %% Manager Role Permissions
    subgraph ManagerPermissions["manager-role Permissions"]
        direction LR
        P_Core["core API<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        P_CoreRO["core API<br/>endpoints, pods, pods/log<br/><i>get,list,watch</i>"]
        P_Events["core + events.k8s.io<br/>events<br/><i>create,patch</i>"]
        P_Apps["apps<br/>deployments<br/><i>full CRUD</i>"]
        P_CRD["apiextensions.k8s.io<br/>customresourcedefinitions<br/><i>get,list,watch</i>"]
        P_Auth["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        P_AuthZ["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
        P_MR["modelregistry.opendatahub.io<br/>modelregistries +<br/>finalizers + status<br/><i>full CRUD</i>"]
        P_GW["gateway.networking.k8s.io<br/>httproutes, referencegrants<br/><i>full CRUD</i>"]
        P_Route["route.openshift.io<br/>routes, routes/custom-host<br/><i>full CRUD</i>"]
        P_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/><i>full CRUD</i>"]
        P_NetPol["networking.k8s.io<br/>networkpolicies<br/><i>full CRUD</i>"]
        P_Migr["migration.k8s.io<br/>storageversionmigrations<br/><i>full CRUD</i>"]
        P_OCP["config.openshift.io<br/>apiservers, ingresses<br/><i>get,list,watch</i>"]
        P_User["user.openshift.io<br/>groups<br/><i>full CRUD</i>"]
        P_Platform["components/services<br/>platform.opendatahub.io<br/>modelregistries, auths<br/><i>get,list,watch</i>"]
    end

    CR_Manager -->|"includes"| ManagerPermissions

    %% Per-Instance Role Permissions
    subgraph RegUserPermissions["registry-user-{name} Permissions"]
        P_SvcGet["core API<br/>services/{name}<br/><i>get</i>"]
        P_EpGet["core API<br/>endpoints/{name}<br/><i>get</i>"]
    end

    R_RegUser -->|"includes"| RegUserPermissions

    %% Auth Delegator Permissions
    subgraph AuthDelegPermissions["system:auth-delegator Permissions"]
        P_TokenReview["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        P_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    CR_AuthDeleg -->|"includes"| AuthDelegPermissions

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Reg fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_AuthDeleg fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_RegUser fill:#f5a623,stroke:#333
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_AuthDeleg fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style RB_Users fill:#e8e8e8,stroke:#333
    style Group_Users fill:#7ed321,stroke:#333
    style P_MR fill:#d5e8d4,stroke:#82b366
    style P_GW fill:#d5e8d4,stroke:#82b366
    style P_Route fill:#d5e8d4,stroke:#82b366
    style P_Auth fill:#fff2cc,stroke:#d6b656
    style P_AuthZ fill:#fff2cc,stroke:#d6b656
    style P_TokenReview fill:#fff2cc,stroke:#d6b656
    style P_SAR fill:#fff2cc,stroke:#d6b656
