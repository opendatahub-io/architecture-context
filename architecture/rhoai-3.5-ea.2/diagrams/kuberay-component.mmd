graph TB
    subgraph KubeRayOperator["KubeRay Operator"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            RCCtrl["RayCluster Controller<br/>Reconciles RayCluster CRs"]
            RJCtrl["RayJob Controller<br/>Manages job lifecycle"]
            RSCtrl["RayService Controller<br/>Zero-downtime upgrades"]
        end

        subgraph SecurityControllers["Security Controllers (RHOAI)"]
            AuthCtrl["Authentication Controller<br/>HTTPRoute + kube-rbac-proxy"]
            MTLSCtrl["mTLS Controller<br/>cert-manager certs"]
            NPCtrl["NetworkPolicy Controller<br/>Pod network isolation"]
        end

        subgraph Webhooks["Admission Webhooks"]
            MutWebhook["Mutating Webhook<br/>9443/TCP TLS<br/>Enforces secure-trusted-network"]
            ValWebhook["Validating Webhook<br/>9443/TCP TLS<br/>Name + group validation"]
        end

        subgraph Endpoints["Operator Endpoints"]
            Metrics["Metrics<br/>8080/TCP HTTP"]
            Health["Health/Ready<br/>8081/TCP HTTP"]
        end
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    User -->|creates| RayJobCR["RayJob CR<br/>ray.io/v1"]
    User -->|creates| RayServiceCR["RayService CR<br/>ray.io/v1"]

    %% Webhook intercepts
    RayClusterCR -->|intercepted by| MutWebhook
    MutWebhook -->|sets annotation| RayClusterCR
    RayClusterCR -->|validated by| ValWebhook

    %% Controller watches
    RayClusterCR -->|watched by| RCCtrl
    RayJobCR -->|watched by| RJCtrl
    RayServiceCR -->|watched by| RSCtrl

    %% Core controller creates
    RCCtrl -->|creates| HeadPod["Head Pod<br/>6379, 8265, 10001,<br/>8080, 8000"]
    RCCtrl -->|creates| WorkerPods["Worker Pods"]
    RCCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    RCCtrl -->|creates| ServeSvc["{cluster}-serve-svc<br/>8000/TCP"]

    %% Security controllers act on annotation
    RayClusterCR -.->|annotation trigger| AuthCtrl
    RayClusterCR -.->|annotation trigger| MTLSCtrl
    RayClusterCR -.->|annotation trigger| NPCtrl

    %% Security controller creates
    AuthCtrl -->|creates| HTTPRoute["HTTPRoute<br/>in platform namespace"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant"]
    AuthCtrl -->|injects| KRBPSidecar["kube-rbac-proxy<br/>sidecar 8443/TCP"]
    MTLSCtrl -->|creates| CertIssuer["cert-manager<br/>Issuer + Certificate"]
    NPCtrl -->|creates| NetPol["NetworkPolicies<br/>head + workers"]

    %% RayJob controller
    RJCtrl -->|creates| RayClusterCR
    RJCtrl -->|creates| SubmitterJob["Submitter Job<br/>batch/v1"]
    RJCtrl -->|polls| DashboardAPI["Ray Dashboard API<br/>8265/TCP"]

    %% RayService controller
    RSCtrl -->|manages| ActiveCluster["Active RayCluster"]
    RSCtrl -->|creates| PendingCluster["Pending RayCluster"]
    RSCtrl -->|deploys serve config| DashboardAPI

    %% External dependencies
    RCCtrl -->|depends on| K8sAPI["Kubernetes API<br/>6443/TCP"]
    AuthCtrl -->|reads| OAuthConfig["OpenShift OAuth<br/>config.openshift.io"]
    HTTPRoute -->|references| Gateway["data-science-gateway<br/>Gateway CR"]
    CertIssuer -->|provisioned by| CertManager["cert-manager"]

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes| Metrics

    %% Styling
    style KubeRayOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#dbeafe,stroke:#3b82f6
    style SecurityControllers fill:#fef3c7,stroke:#f59e0b
    style Webhooks fill:#fce7f3,stroke:#ec4899
    style Endpoints fill:#d1fae5,stroke:#10b981

    style RCCtrl fill:#4a90e2,color:#fff
    style RJCtrl fill:#4a90e2,color:#fff
    style RSCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#f59e0b,color:#fff
    style MTLSCtrl fill:#f59e0b,color:#fff
    style NPCtrl fill:#f59e0b,color:#fff
    style MutWebhook fill:#ec4899,color:#fff
    style ValWebhook fill:#ec4899,color:#fff

    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333

    style Gateway fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style OAuthConfig fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
