graph TB
    subgraph PlannerSystem["llm-d-planner System"]
        direction TB

        subgraph BackendAPI["Backend API (FastAPI :8000)"]
            direction LR
            IntentRoutes["Intent Routes<br/>/api/v1/extract"]
            RecommendRoutes["Recommendation Routes<br/>/api/v1/recommend<br/>/api/v1/ranked-recommend-from-spec"]
            DeployRoutes["Deployment Routes<br/>/api/v1/deploy<br/>/api/v1/deploy-to-cluster"]
            ConfigRoutes["Config Routes<br/>/api/v1/models, /gpu-types<br/>/api/v1/use-cases"]
            DBRoutes["Database Routes<br/>/api/v1/db/*"]
            HealthRoute["Health<br/>/health"]
        end

        subgraph Orchestration["Recommendation Pipeline"]
            direction LR
            IntentExtractor["Intent Extractor"]
            SpecGenerator["Specification Generator"]
            ConfigFinder["Configuration Finder"]
            Scorer["Multi-Criteria Scorer<br/>(accuracy, cost, latency, complexity)"]
            DeployGenerator["Deployment Generator<br/>(Jinja2 Templates)"]
        end

        subgraph ClusterOps["Cluster Operations"]
            GPUDetector["GPU Detector<br/>(nvidia.com/gpu.product labels)"]
            ClusterManager["Cluster Manager<br/>(InferenceService CRUD)"]
        end

        subgraph CatalogSync["Model Catalog Sync (daemon thread)"]
            CatalogClient["Model Catalog Client"]
            SyncWorker["Sync Worker<br/>(ETL pipeline)"]
        end

        StreamlitUI["Streamlit UI (:8501)<br/>Chat Interface + Tabs<br/>(Overview, Specs, Performance, Cost, Monitoring)"]
        Simulator["vLLM Simulator (:8080)<br/>GPU-free Development"]
    end

    %% Internal connections
    StreamlitUI -->|"HTTP :8000"| BackendAPI
    IntentRoutes --> IntentExtractor
    RecommendRoutes --> IntentExtractor
    IntentExtractor --> SpecGenerator
    SpecGenerator --> ConfigFinder
    ConfigFinder --> Scorer
    Scorer --> DeployGenerator
    DeployRoutes --> DeployGenerator
    DeployRoutes --> ClusterManager
    DBRoutes --> PostgreSQL
    CatalogClient --> SyncWorker
    SyncWorker -->|"INSERT benchmarks"| PostgreSQL

    %% External data stores
    PostgreSQL[("PostgreSQL (:5432)<br/>Benchmark Database")]
    ConfigFinder -->|"SQL queries"| PostgreSQL

    %% External LLM
    Ollama["Ollama (:11434)<br/>qwen2.5:7b"]
    IntentExtractor -->|"HTTP :11434"| Ollama

    %% External services (egress)
    HuggingFace["HuggingFace Hub<br/>huggingface.co:443"]
    ModelCatalog["RHOAI Model Catalog<br/>:8443/HTTPS"]
    K8sAPI["Kubernetes API<br/>:6443/HTTPS"]

    BackendAPI -->|"HTTPS :443<br/>Bearer Token"| HuggingFace
    CatalogClient -->|"HTTPS :8443<br/>Bearer Token"| ModelCatalog
    GPUDetector -->|"HTTPS :6443<br/>SA Token"| K8sAPI
    ClusterManager -->|"HTTPS :6443<br/>SA Token"| K8sAPI

    %% User access
    User["User (Browser)"]
    User -->|"HTTPS :443<br/>via OpenShift Route"| StreamlitUI
    User -->|"HTTPS :443<br/>via OpenShift Route"| BackendAPI

    %% Generated artifacts
    KServeYAML["Generated Artifacts:<br/>InferenceService YAML<br/>HPA YAML<br/>ServiceMonitor YAML<br/>Grafana Dashboard ConfigMap"]
    DeployGenerator -->|"renders"| KServeYAML

    %% Styling
    style BackendAPI fill:#4a90e2,stroke:#333,color:#fff
    style StreamlitUI fill:#4a90e2,stroke:#333,color:#fff
    style Simulator fill:#87ceeb,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333
    style ModelCatalog fill:#7ed321,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style KServeYAML fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
    style Orchestration fill:#e8f4fd,stroke:#4a90e2
    style ClusterOps fill:#e8f4fd,stroke:#4a90e2
    style CatalogSync fill:#e8f4fd,stroke:#4a90e2
