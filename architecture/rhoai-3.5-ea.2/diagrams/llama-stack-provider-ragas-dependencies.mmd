graph LR
    RagasProvider["llama-stack-provider-ragas<br/>v0.5.1"]

    %% Core External Dependencies (always required)
    RagasProvider -->|"evaluation framework<br/>v0.3.0"| Ragas["ragas"]
    RagasProvider -->|"plugin framework<br/>>0.2.23"| LlamaStack["llama-stack"]
    RagasProvider -->|"LLM/embedding wrappers"| LangChain["langchain-core<br/>(transitive via ragas)"]
    RagasProvider -->|"DataFrame ops<br/><2.3.0"| Pandas["pandas"]
    RagasProvider -->|"Parquet/Arrow<br/>>=21.0.0"| PyArrow["pyarrow"]
    RagasProvider -->|"config validation"| Pydantic["pydantic<br/>(transitive)"]
    RagasProvider -->|"dataset loading<br/>>=2.16.0"| Datasets["datasets<br/>(HuggingFace)"]
    RagasProvider -->|"async ops<br/>==3.2.4"| Greenlet["greenlet"]

    %% Remote-only External Dependencies
    RagasProvider -.->|"pipeline SDK<br/>>=2.5.0<br/>(remote only)"| KFP["kfp"]
    RagasProvider -.->|"K8s extensions<br/>>=2.0.0<br/>(remote only)"| KFPKubernetes["kfp-kubernetes"]
    RagasProvider -.->|"K8s client<br/>>=30.0.0<br/>(remote only)"| Kubernetes["kubernetes"]
    RagasProvider -.->|"S3 filesystem<br/>>=2024.12.0<br/>(remote only)"| S3FS["s3fs"]
    RagasProvider -.->|"HTTP requests<br/>>=2.32.5"| Requests["requests"]

    %% Internal Platform Dependencies
    RagasProvider ==>|"plugin host"| LlamaStackServer["Llama Stack Server"]
    RagasProvider ==>|"LLM + embeddings"| InferenceAPI["Llama Stack<br/>Inference API"]
    RagasProvider ==>|"dataset retrieval"| DatasetIOAPI["Llama Stack<br/>DatasetIO API"]
    RagasProvider ==>|"file storage"| FilesAPI["Llama Stack<br/>Files API"]
    RagasProvider ==>|"benchmark mgmt"| BenchmarksAPI["Llama Stack<br/>Benchmarks API"]

    %% Integration Points
    RagasProvider -.->|"pipeline execution<br/>HTTPS/443"| KubeflowPipelines["Kubeflow Pipelines<br/>(Data Science Pipelines)"]
    RagasProvider -.->|"base image config<br/>ConfigMap read"| TrustyAI["TrustyAI Service<br/>Operator"]
    RagasProvider -.->|"result storage<br/>HTTPS/443"| S3Storage["S3-Compatible<br/>Storage"]
    RagasProvider -->|"default inference<br/>HTTP/11434"| Ollama["Ollama"]

    %% Consumers
    LlamaStackServer -->|"hosts"| RagasProvider

    %% Styling
    style RagasProvider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

