    style Pandas fill:#e8e8e8,stroke:#333
    style PyArrow fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333
    style Datasets fill:#e8e8e8,stroke:#333
    style Greenlet fill:#e8e8e8,stroke:#333
    style Requests fill:#e8e8e8,stroke:#333

    %% Remote-only dependencies
    style KFP fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style KFPKubernetes fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style Kubernetes fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style S3FS fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5

    %% Internal platform
    style LlamaStackServer fill:#7ed321,stroke:#333,color:#fff
    style InferenceAPI fill:#7ed321,stroke:#333,color:#fff
    style DatasetIOAPI fill:#7ed321,stroke:#333,color:#fff
    style FilesAPI fill:#7ed321,stroke:#333,color:#fff
    style BenchmarksAPI fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff

