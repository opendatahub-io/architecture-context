graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AgentPodZone["AGENT POD (User Namespace)"]
        direction TB
        AuthBridgeRev["AuthBridge Reverse Proxy<br/>8080/TCP HTTP<br/>JWT + OPA + Protocol Parsing"]
        AuthBridgeFwd["AuthBridge Forward Proxy<br/>8081/TCP HTTP<br/>Token Exchange + mTLS"]
        AgentApp["Agent Application<br/>Container"]
        AuthBridgeRev -->|"localhost<br/>Plaintext<br/>No Auth"| AgentApp
        AgentApp -->|"HTTP_PROXY<br/>Plaintext<br/>No Auth"| AuthBridgeFwd
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (kagenti-system)"]
        direction TB
        Operator["kagenti-operator<br/>SA: controller-manager<br/>FIPS: strictfipsruntime"]
        WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS 1.2+ (cert-manager)"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>TLS 1.2+"]
        BundleSvc["bundle-service<br/>8080/TCP HTTP<br/>NetworkPolicy restricted"]
        Operator --- WebhookSvc
        Operator --- MetricsSvc
    end

    subgraph PlatformSvcs["PLATFORM SERVICES (Cluster Internal)"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        KeycloakSvc["Keycloak<br/>8080/TCP HTTP (internal)<br/>443/TCP HTTPS (Route)<br/>Admin Secret Auth"]
        SPIRESvc["SPIRE Workload API<br/>Unix Socket gRPC<br/>mTLS<br/>SPIFFE SVID"]
        CertMgrSvc["cert-manager<br/>CRD-based<br/>Certificate/Issuer"]
        IstioSvc["Istio<br/>Namespace Labels<br/>Ambient Mesh"]
        MLflowSvc["MLflow<br/>HTTPS<br/>TLS (service-CA)<br/>Bearer Token"]
    end

    subgraph ExternalSvcs["EXTERNAL SERVICES"]
        Sigstore["Sigstore (Rekor/Fulcio)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Phoenix["Phoenix<br/>4317/TCP gRPC<br/>No Encryption"]
    end

    %% External client to AuthBridge
    Client -->|"HTTP 8080/TCP<br/>Optional mTLS (SPIFFE)<br/>Bearer JWT (Keycloak)"| AuthBridgeRev

    %% AuthBridge outbound
    AuthBridgeFwd -->|"HTTPS/varies<br/>mTLS (SPIFFE X.509-SVID)<br/>OAuth2 Token Exchange"| KeycloakSvc
    AuthBridgeFwd -->|"HTTP/HTTPS<br/>Bearer Token / mTLS"| ExternalSvcs

    %% AuthBridge to bundle-service
    AuthBridgeRev -->|"HTTP/8080<br/>No Encryption<br/>NetworkPolicy: authbridge=true"| BundleSvc

    %% AuthBridge to SPIRE
    AuthBridgeRev -->|"Unix Socket<br/>gRPC mTLS<br/>SPIFFE SVID"| SPIRESvc

    %% AuthBridge to Keycloak (JWT validation)
    AuthBridgeRev -->|"HTTP/8080<br/>JWKS Fetch<br/>OAuth2"| KeycloakSvc

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTP/8080<br/>Admin Secret<br/>Client Registration"| KeycloakSvc
    Operator -->|"Unix Socket<br/>gRPC mTLS<br/>Verified Fetch"| SPIRESvc
    Operator -->|"CRD Watch<br/>Certificate/Issuer"| CertMgrSvc
    Operator -->|"Namespace Labels<br/>Deployment Restart"| IstioSvc
    Operator -->|"HTTPS/varies<br/>TLS (service-CA)<br/>Bearer Token"| MLflowSvc
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Sigstore Verify"| Sigstore

    %% Webhook from K8s API
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>API Server Cert"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef agentpod fill:#dcedc8,stroke:#689f38,stroke-width:2px
    classDef operatorns fill:#bbdefb,stroke:#1976d2,stroke-width:2px
    classDef platform fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef externalsvc fill:#ffccbc,stroke:#e64a19,stroke-width:2px

    class Client external
    class AuthBridgeRev,AuthBridgeFwd,AgentApp agentpod
    class Operator,WebhookSvc,MetricsSvc,BundleSvc operatorns
    class K8sAPI,KeycloakSvc,SPIRESvc,CertMgrSvc,IstioSvc,MLflowSvc platform
    class Sigstore,Phoenix externalsvc
