graph TB
    subgraph BatchJob["BATCH JOB (K8s Job - No Inbound Traffic)"]
        direction TB

        subgraph NS_Apps["Namespace: redhat-ods-applications"]
            Adapter["Garak Adapter Pod<br/>SA: Job SA (eval-hub provisioned)<br/>Image: quay.io/aipcc/...:3.5.0-ea.2<br/>Mounts: model-auth, Data Connection"]
        end
    end

    subgraph LLM_Endpoints["LLM MODEL ENDPOINTS"]
        TargetLLM["Target LLM<br/>/v1/chat/completions<br/>443/TCP HTTPS"]
        SDGModel["SDG Model<br/>/v1/chat/completions<br/>443/TCP HTTPS"]
        JudgeModel["Judge Model<br/>/v1/chat/completions<br/>443/TCP HTTPS"]
        AttackerModel["Attacker Model<br/>/v1/chat/completions<br/>443/TCP HTTPS"]
        EvaluatorModel["Evaluator Model<br/>/v1/chat/completions<br/>443/TCP HTTPS"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        KFP["Kubeflow Pipelines API<br/>443/TCP HTTPS"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
        MLflow["MLflow Tracking<br/>HTTP/HTTPS"]
        OCI["OCI Registry<br/>443/TCP HTTPS"]
        EvalHubCB["eval-hub Callbacks<br/>443/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS"]
        GoogleTranslate["Google Translate API<br/>translate.googleapis.com<br/>443/TCP HTTPS"]
    end

    subgraph K8sAPI["K8s API ACCESS"]
        Secrets["K8s Secrets<br/>model-auth, Data Connection"]
        ConfigMap["trustyai-service-operator-config<br/>ConfigMap"]
    end

    %% Egress flows - LLM endpoints
    Adapter -->|"HTTPS/443<br/>TLS<br/>API Key (Bearer)"| TargetLLM
    Adapter -->|"HTTPS/443<br/>TLS<br/>SDG_API_KEY"| SDGModel
    Adapter -->|"HTTPS/443<br/>TLS<br/>JUDGE_API_KEY"| JudgeModel
    Adapter -->|"HTTPS/443<br/>TLS<br/>ATTACKER_API_KEY"| AttackerModel
    Adapter -->|"HTTPS/443<br/>TLS<br/>EVALUATOR_API_KEY"| EvaluatorModel

    %% Egress flows - Platform
    Adapter -->|"HTTPS/443<br/>TLS (KFP_VERIFY_SSL)<br/>SA Token"| KFP
    Adapter -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    Adapter -.->|"HTTP/HTTPS<br/>Configurable<br/>Token (optional)"| MLflow
    Adapter -->|"HTTPS/443<br/>TLS<br/>Registry creds"| OCI
    Adapter -->|"HTTPS/443<br/>TLS<br/>Callback token"| EvalHubCB

    %% Egress flows - External
    Adapter -.->|"HTTPS/443<br/>TLS<br/>HF Token (optional)"| HFHub
    Adapter -.->|"HTTPS/443<br/>TLS<br/>Google API creds"| GoogleTranslate

    %% K8s API access
    Adapter -->|"In-cluster HTTPS<br/>SA Token"| Secrets
    Adapter -->|"In-cluster HTTPS<br/>SA Token"| ConfigMap

    %% Styling
    classDef batchjob fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef llmendpoint fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8sapi fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Adapter batchjob
    class TargetLLM,SDGModel,JudgeModel,AttackerModel,EvaluatorModel llmendpoint
    class KFP,S3,MLflow,OCI,EvalHubCB platform
    class HFHub,GoogleTranslate external
    class Secrets,ConfigMap k8sapi
