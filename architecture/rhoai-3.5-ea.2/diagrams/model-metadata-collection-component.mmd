graph TB
    subgraph BuildTime["Build-Time Pipeline (CI/CD)"]
        direction TB
        Extractor["model-extractor<br/>(Go CLI)<br/>Main extraction &amp; catalog pipeline"]
        Report["metadata-report<br/>(Go CLI)<br/>Completeness &amp; provenance analysis"]

        subgraph ExtractorInternals["model-extractor Internals"]
            direction LR
            HFClient["HuggingFace Client<br/>collections, models, README"]
            Registry["Registry Client<br/>OCI manifests, layers, configs"]
            Enrichment["Enrichment Engine<br/>Multi-source priority hierarchy"]
            CatalogGen["Catalog Generator<br/>models &amp; MCP catalogs"]
            FamilyMatch["Model Family Matcher<br/>Cross-family prevention"]
        end

        Extractor --> HFClient
        Extractor --> Registry
        Extractor --> Enrichment
        Extractor --> CatalogGen
        Extractor --> FamilyMatch
        HFClient --> Enrichment
        Registry --> Enrichment
        Enrichment --> CatalogGen
    end

    subgraph ExternalAPIs["External APIs (Build-Time)"]
        HuggingFace["HuggingFace API<br/>huggingface.co:443<br/>HTTPS / TLS 1.2+"]
        RedHatRegistry["Red Hat Container Registry<br/>registry.redhat.io:443<br/>HTTPS / TLS 1.2+"]
    end

    subgraph DataFiles["Generated Artifacts"]
        ModelsIndex["data/models-index.yaml"]
        ModelsCatalog["data/models-catalog.yaml"]
        MCPCatalog["data/*-mcp-servers-catalog.yaml"]
        MCPIndex["data/*-mcp-servers-index.yaml"]
    end

    subgraph Production["Production Container (Runtime)"]
        DataContainer["odh-model-metadata-collection<br/>(ubi9-minimal)<br/>CMD: sleep infinity<br/>VOLUME: /app/data"]
    end

    subgraph Consumers["Runtime Consumers"]
        Dashboard["RHOAI Dashboard<br/>Volume mount consumer"]
        Operator["rhods-operator<br/>Deployment orchestrator"]
    end

    %% Build-time flows
    HFClient -->|"HTTPS/443<br/>Bearer Token (optional)"| HuggingFace
    Registry -->|"HTTPS/443<br/>Anonymous"| RedHatRegistry
    ModelsIndex -->|input| Extractor
    MCPIndex -->|input| Extractor
    CatalogGen -->|output| ModelsCatalog
    CatalogGen -->|output| MCPCatalog
    Report -->|reads| ModelsCatalog

    %% Build to production
    ModelsCatalog -->|"COPY into image"| DataContainer
    MCPCatalog -->|"COPY into image"| DataContainer

    %% Runtime flows
    Operator -->|"deploys as<br/>init container/sidecar"| DataContainer
    DataContainer -->|"volume mount<br/>/app/data/*.yaml"| Dashboard

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Report fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#f5a623,stroke:#333,color:#fff
    style Operator fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style RedHatRegistry fill:#999,stroke:#333,color:#fff
    style ModelsCatalog fill:#e8e8e8,stroke:#333
    style MCPCatalog fill:#e8e8e8,stroke:#333
    style ModelsIndex fill:#e8e8e8,stroke:#333
    style MCPIndex fill:#e8e8e8,stroke:#333
