graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Inference Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Managed by KServe"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ (SIMPLE)<br/>RequestAuthentication"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph PodBoundary["Pod: AutoGluon Server"]
            Sidecar["Istio Sidecar Proxy<br/>15006/TCP inbound<br/>HTTP/2 mTLS"]
            AGServer["AutoGluon Server<br/>8080/TCP REST (v1+v2)<br/>8081/TCP gRPC<br/>Image: odh-kserve-autogluon-server-rhel9"]
            Sidecar -->|localhost<br/>no encryption| AGServer
        end

        subgraph Monitoring["Monitoring"]
            Prometheus["Prometheus<br/>Scrapes :8080/metrics"]
        end

        Prometheus -->|HTTP/8080<br/>in-mesh| AGServer
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Azure AD"]
        HF["Hugging Face Hub<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / mTLS"| Gateway
    Gateway -->|"HTTP/8080<br/>mTLS STRICT<br/>PeerAuthentication"| Sidecar

    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA credentials"| GCS
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AD credentials"| Azure
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class Sidecar,AGServer pod
    class S3,GCS,Azure,HF externalservice
    class Prometheus monitoring
