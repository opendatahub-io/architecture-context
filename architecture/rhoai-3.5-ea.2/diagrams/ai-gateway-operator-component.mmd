graph TB
    subgraph PlatformOperator["Platform Operator (opendatahub-operator / rhods-operator)"]
        RHODS[rhods-operator<br/>Module Handler]
    end

    subgraph AIGatewayOperator["AI Gateway Operator"]
        Controller[ai-gateway-operator<br/>Controller Manager]
        InitContainer[copy-manifests<br/>Init Container]
        ManifestVolume["/opt/manifests<br/>(emptyDir)"]
        KustomizeEngine[Kustomize Rendering<br/>Engine]

        InitContainer -->|copies embedded<br/>manifests| ManifestVolume
        Controller -->|reads| ManifestVolume
        Controller -->|renders via| KustomizeEngine
    end

    subgraph SubComponents["Sub-Components (deployed by ai-gateway-operator)"]
        BatchGW[batch-gateway-operator<br/>llm-d-batch-gateway-operator]
        subgraph BatchWorkloads["Batch Gateway Workloads"]
            APIServer[Batch API Server]
            Processor[Batch Processor]
            GC[Garbage Collector]
        end
        BatchGW -->|deploys| APIServer
        BatchGW -->|deploys| Processor
        BatchGW -->|deploys| GC
    end

    %% CRDs
    AIGatewayCR["AIGateway CR<br/>(Cluster-scoped)<br/>components.platform.opendatahub.io/v1alpha1"]
    LLMBatchGatewayCR["LLMBatchGateway CR<br/>(Namespaced)<br/>batch.llm-d.ai/v1alpha1"]

    %% Flows
    RHODS -->|creates| AIGatewayCR
    AIGatewayCR -->|watched by| Controller
    Controller -->|deploys when<br/>managementState=Managed| BatchGW
    LLMBatchGatewayCR -->|watched by| BatchGW

    %% External Dependencies
    K8sAPI[Kubernetes API Server]
    CertManager[cert-manager]
    PrometheusOp[Prometheus Operator]
    GatewayAPI[Gateway API]

    Controller -->|watches/manages resources| K8sAPI
    BatchGW -->|creates Certificates| CertManager
    BatchGW -->|creates HTTPRoutes| GatewayAPI
    Controller -->|creates ServiceMonitor| PrometheusOp
    BatchGW -->|creates ServiceMonitor,<br/>PodMonitor, PrometheusRule| PrometheusOp

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style KustomizeEngine fill:#4a90e2,stroke:#333,color:#fff
    style ManifestVolume fill:#b8d4f0,stroke:#333
    style BatchGW fill:#7ed321,stroke:#333
    style APIServer fill:#a8e063,stroke:#333
    style Processor fill:#a8e063,stroke:#333
    style GC fill:#a8e063,stroke:#333
    style RHODS fill:#9b59b6,stroke:#333,color:#fff
    style AIGatewayCR fill:#f5a623,stroke:#333
    style LLMBatchGatewayCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style PrometheusOp fill:#e8e8e8,stroke:#333
    style GatewayAPI fill:#e8e8e8,stroke:#333
