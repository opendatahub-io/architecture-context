graph TB
    subgraph KubeflowNotebook["Kubeflow Notebook Controller System"]
        direction TB

        subgraph UpstreamCtrl["odh-kf-notebook-controller"]
            KFController["KF Notebook Controller<br/>(controller-runtime)<br/>8080/TCP metrics<br/>8081/TCP health"]
            CullingCtrl["Culling Controller<br/>Polls Jupyter API<br/>for idle detection"]
            KFController --- CullingCtrl
        end

        subgraph ODHCtrl["odh-notebook-controller"]
            ODHController["ODH Notebook Controller<br/>(controller-runtime)<br/>8080/TCP metrics<br/>8081/TCP health"]
            MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>8443/TCP HTTPS"]
            ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>8443/TCP HTTPS"]
            ODHController --- MutatingWH
            ODHController --- ValidatingWH
        end
    end

    %% User interaction
    User["User<br/>(Dashboard / CLI)"] -->|"creates/updates"| NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]

    %% Webhook intercepts
    NotebookCR -->|"admission"| MutatingWH
    NotebookCR -->|"admission"| ValidatingWH

    %% KF Controller reconciliation outputs
    NotebookCR -->|"watched by"| KFController
    KFController -->|"creates"| StatefulSet["StatefulSet<br/>(Jupyter pod)"]
    KFController -->|"creates"| JupyterSvc["Service<br/>80/TCP → 8888"]

    %% Culling flow
    CullingCtrl -->|"polls /api/kernels<br/>/api/terminals<br/>8888/TCP HTTP"| StatefulSet
    CullingCtrl -->|"scales to 0<br/>when idle"| StatefulSet

    %% ODH Controller reconciliation outputs
    NotebookCR -->|"watched by"| ODHController
    ODHController -->|"creates"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    ODHController -->|"creates"| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    ODHController -->|"creates"| NetPol["NetworkPolicies"]
    ODHController -->|"creates"| KRBPSvc["kube-rbac-proxy<br/>Service 8443/TCP"]
    ODHController -->|"creates"| DSPASecret["DSPA/Elyra<br/>Pipeline Secrets"]
    ODHController -->|"creates"| CABundle["workbench-trusted-<br/>ca-bundle ConfigMap"]

    %% Webhook injection
    MutatingWH -->|"injects"| KRBPSidecar["kube-rbac-proxy<br/>sidecar container"]
    MutatingWH -->|"injects"| ProxyEnv["Proxy env vars"]
    MutatingWH -->|"resolves"| ImageStream["ImageStream<br/>image tags"]

    %% External dependencies
    HTTPRoute -->|"parent ref"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    KRBPSidecar -->|"TokenReview +<br/>SubjectAccessReview"| K8sAPI["Kubernetes API<br/>443/TCP"]

    %% Styling
    style KFController fill:#4a90e2,stroke:#333,color:#fff
    style CullingCtrl fill:#4a90e2,stroke:#333,color:#fff
    style ODHController fill:#4a90e2,stroke:#333,color:#fff
    style MutatingWH fill:#e8744f,stroke:#333,color:#fff
    style ValidatingWH fill:#e8744f,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style StatefulSet fill:#7ed321,stroke:#333,color:#fff
    style JupyterSvc fill:#7ed321,stroke:#333,color:#fff
    style HTTPRoute fill:#7ed321,stroke:#333,color:#fff
    style RefGrant fill:#7ed321,stroke:#333,color:#fff
    style NetPol fill:#7ed321,stroke:#333,color:#fff
    style KRBPSvc fill:#7ed321,stroke:#333,color:#fff
    style DSPASecret fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style KRBPSidecar fill:#bd10e0,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ImageStream fill:#e8e8e8,stroke:#333
