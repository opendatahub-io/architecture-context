graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
        SA_LeaderElect["controller-manager<br/>(namespace: system)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-<br/>manager-rolebinding"]
        CRB_SvcReader["model-registry-ui-<br/>services-reader-binding"]
        CRB_CRBReader["model-registry-retrieve-<br/>clusterrolebindings-binding"]
        CRB_SAR["model-registry-<br/>create-sars-binding"]
        CRB_NSReader["model-registry-ui-<br/>namespaces-reader-binding"]
    end

    subgraph RoleBindings["Role Bindings (namespace: system)"]
        RB_LeaderElect["controller-manager-<br/>leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-<br/>manager-role"]
        CR_SvcReader["model-registry-ui-<br/>services-reader"]
        CR_CRBReader["model-registry-retrieve-<br/>clusterrolebindings"]
        CR_SAR["model-registry-<br/>create-sars"]
        CR_NSReader["model-registry-ui-<br/>namespaces-reader"]
    end

    subgraph Roles["Roles"]
        R_LeaderElect["leader-election-role"]
    end

    subgraph APIResources["API Resources"]
        subgraph KServeAPIs["serving.kserve.io"]
            ISVC["inferenceservices"]
            ISVCFin["inferenceservices/<br/>finalizers"]
        end

        subgraph CoreAPIs["core ('')"]
            Services["services"]
            Namespaces["namespaces"]
        end

        subgraph RBACAPIs["rbac.authorization.k8s.io"]
            CRBindings["clusterrolebindings"]
        end

        subgraph AuthzAPIs["authorization.k8s.io"]
            SAR["subjectaccessreviews"]
        end

        subgraph CoordAPIs["coordination.k8s.io"]
            Leases["leases"]
        end
    end

    %% Controller SA bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|"get, list, watch,<br/>update, patch"| ISVC
    CR_Manager -->|"get, list, watch, update,<br/>create, patch, delete"| ISVCFin
    CR_Manager -->|"get, list, watch"| Services

    %% UI SA bindings
    SA_UI -->|bound via| CRB_SvcReader
    CRB_SvcReader -->|grants| CR_SvcReader
    CR_SvcReader -->|"get, list, watch"| Services

    SA_UI -->|bound via| CRB_CRBReader
    CRB_CRBReader -->|grants| CR_CRBReader
    CR_CRBReader -->|"get, list, watch"| CRBindings

    SA_UI -->|bound via| CRB_SAR
    CRB_SAR -->|grants| CR_SAR
    CR_SAR -->|"create"| SAR

    SA_UI -->|bound via| CRB_NSReader
    CRB_NSReader -->|grants| CR_NSReader
    CR_NSReader -->|"get, list, watch"| Namespaces

    %% Leader election
    SA_LeaderElect -->|bound via| RB_LeaderElect
    RB_LeaderElect -->|grants| R_LeaderElect
    R_LeaderElect -->|"get, list, watch,<br/>create, update, patch,<br/>delete"| Leases

    %% Styles
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff
    style SA_LeaderElect fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_SvcReader fill:#f5a623,stroke:#333,color:#fff
    style CR_CRBReader fill:#f5a623,stroke:#333,color:#fff
    style CR_SAR fill:#f5a623,stroke:#333,color:#fff
    style CR_NSReader fill:#f5a623,stroke:#333,color:#fff
    style R_LeaderElect fill:#f5a623,stroke:#333,color:#fff
    style ISVC fill:#7ed321,stroke:#333,color:#fff
    style ISVCFin fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style CRBindings fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style Leases fill:#7ed321,stroke:#333,color:#fff
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_SvcReader fill:#e8e8e8,stroke:#333
    style CRB_CRBReader fill:#e8e8e8,stroke:#333
    style CRB_SAR fill:#e8e8e8,stroke:#333
    style CRB_NSReader fill:#e8e8e8,stroke:#333
    style RB_LeaderElect fill:#e8e8e8,stroke:#333
