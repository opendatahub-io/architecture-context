graph TD
    subgraph Note["RBAC Overview"]
        direction TB
        Info["This component does NOT define its own RBAC resources.<br/>It runs as a user-space model server pod.<br/>All RBAC is managed by the KServe operator."]
    end

    subgraph KServeOperatorRBAC["KServe Operator RBAC (manages this component)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            SA_Controller["kserve-controller-manager<br/>(KServe Controller)"]
            SA_Pod["default / auto-generated<br/>(AutoGluon Server Pod)"]
        end

        subgraph ClusterRoles["ClusterRoles (KServe Operator)"]
            CR_Manager["kserve-manager-role"]
        end

        subgraph Resources["API Resources Managed"]
            ISVC["serving.kserve.io<br/>InferenceService"]
            CSR["serving.kserve.io<br/>ClusterServingRuntime"]
            SR["serving.kserve.io<br/>ServingRuntime"]
            Pods["core<br/>Pods"]
            Services["core<br/>Services"]
            Deployments["apps<br/>Deployments"]
        end
    end

    subgraph SecretsAccess["Secrets (Pod-level Access)"]
        StorageCreds["storage-credentials<br/>Type: Opaque<br/>Purpose: S3/GCS/Azure creds<br/>Provisioned by: User/Operator<br/>Auto-Rotate: No"]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB
        mTLS["mTLS (Istio Sidecar)<br/>PeerAuthentication: STRICT"]
        IstioGW["Istio Gateway<br/>RequestAuthentication<br/>(validates JWT if present)"]
    end

    %% Relationships
    SA_Controller -->|bound via<br/>ClusterRoleBinding| CR_Manager
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| ISVC
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| CSR
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| SR
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| Pods
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| Services
    CR_Manager -->|get,list,watch<br/>create,update,patch,delete| Deployments

    SA_Pod -->|mounts| StorageCreds
    SA_Pod -->|identity verified by| mTLS

    IstioGW -->|protects ingress to| SA_Pod

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,stroke-width:2px
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pod fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style CSR fill:#7ed321,stroke:#333
    style SR fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style StorageCreds fill:#e74c3c,stroke:#333,color:#fff
    style mTLS fill:#9b59b6,stroke:#333,color:#fff
    style IstioGW fill:#9b59b6,stroke:#333,color:#fff
