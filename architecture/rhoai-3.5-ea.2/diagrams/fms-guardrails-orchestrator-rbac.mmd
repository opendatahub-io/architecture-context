graph TD
    subgraph ServiceIdentity["Service Identity"]
        Binary["fms-guardrails-orchestr8<br/>(Standalone Rust Service)"]
    end

    subgraph TLSAuth["TLS Authentication"]
        direction TB
        ServerTLS["Server TLS (Inbound)<br/>rustls with ring backend"]
        ClientTLS["Client TLS (Outbound)<br/>Per-service TLS configs"]
        mTLSInbound["mTLS Inbound<br/>Optional client CA verification"]
        mTLSOutbound["mTLS Outbound<br/>Client certs per service"]
    end

    subgraph HeaderAuth["Header-based Auth"]
        direction TB
        Passthrough["Passthrough Headers<br/>Configurable header list"]
        ForwardedToken["X-Forwarded-Access-Token<br/>→ Authorization: Bearer<br/>(rewrite middleware)"]
        APIToken["api_token Config<br/>Bearer token from env var<br/>for OpenAI-compatible servers"]
    end

    subgraph Secrets["Secrets & Credentials"]
        TLSServerCert["TLS Server Cert/Key<br/>Type: PEM files<br/>Provisioned: External mount<br/>Rotation: Manual"]
        TLSClientCA["TLS Client CA Cert<br/>Type: PEM file<br/>Provisioned: External mount<br/>Rotation: Manual"]
        PerServiceCerts["Per-Service TLS Certs<br/>Type: PEM files<br/>Provisioned: External mount<br/>Referenced by name in config.yaml"]
        APITokenSecret["API Tokens<br/>Type: Environment variable<br/>Provisioned: External<br/>Referenced via from_env deserializer"]
    end

    Binary -->|"serves on 8033/TCP"| ServerTLS
    Binary -->|"connects to downstream"| ClientTLS
    ServerTLS -->|"optional"| mTLSInbound
    ClientTLS -->|"optional"| mTLSOutbound

    Binary -->|"forwards to downstream"| Passthrough
    Binary -->|"rewrites headers"| ForwardedToken
    Binary -->|"authenticates to vLLM"| APIToken

    ServerTLS -->|"loads"| TLSServerCert
    mTLSInbound -->|"verifies against"| TLSClientCA
    ClientTLS -->|"loads per-service"| PerServiceCerts
    APIToken -->|"resolves from"| APITokenSecret

    subgraph FIPSWarning["⚠ FIPS Compliance Gap"]
        Warning["rustls + ring = NOT FIPS-validated<br/>OpenSSL in container but unused by binary<br/>NoVerifier mode bypasses ALL cert checks"]
    end

    ServerTLS -.->|"uses non-FIPS crypto"| Warning

    %% Styling
    style Binary fill:#4a90e2,stroke:#333,color:#fff
    style ServerTLS fill:#f5a623,stroke:#333
    style ClientTLS fill:#f5a623,stroke:#333
    style mTLSInbound fill:#f5a623,stroke:#333
    style mTLSOutbound fill:#f5a623,stroke:#333
    style Passthrough fill:#7ed321,stroke:#333
    style ForwardedToken fill:#7ed321,stroke:#333
    style APIToken fill:#7ed321,stroke:#333
    style TLSServerCert fill:#e8e8e8,stroke:#333
    style TLSClientCA fill:#e8e8e8,stroke:#333
    style PerServiceCerts fill:#e8e8e8,stroke:#333
    style APITokenSecret fill:#e8e8e8,stroke:#333
    style Warning fill:#ff6b6b,stroke:#333,color:#fff
