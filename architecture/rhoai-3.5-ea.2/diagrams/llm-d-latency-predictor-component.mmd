graph TB
    subgraph LLP["llm-d-latency-predictor"]
        direction TB

        subgraph TrainingServer["Training Server (8000/TCP)"]
            TrainAPI["FastAPI + Uvicorn"]
            TrainLoop["Background Training Loop<br/>XGBoost / LightGBM / BayesianRidge"]
            ModelStore["Model Storage<br/>/models/*.joblib<br/>(PVC)"]
            TrainAPI -->|triggers| TrainLoop
            TrainLoop -->|serializes via joblib| ModelStore
        end

        subgraph PredictionServer["Prediction Server (8001/TCP)"]
            PredAPI["FastAPI + Uvicorn<br/>(8 workers)"]
            ModelSyncer["ModelSyncer<br/>(HTTP polling thread)"]
            LocalCache["Local Model Cache<br/>/local_models/*.joblib<br/>(emptyDir)"]
            InferEngine["Inference Engine<br/>QueueGatedModel Ensemble"]
            ModelSyncer -->|atomic os.replace| LocalCache
            LocalCache -->|loaded into| InferEngine
            PredAPI -->|invokes| InferEngine
        end

        subgraph TestRunner["Test Runner (Job)"]
            Tests["pytest + httpx + aiohttp<br/>Integration & Load Tests"]
        end
    end

    %% External callers
    GatewayComponents["llm-d Gateway<br/>Components"]
    GatewayRouter["llm-d Gateway<br/>Router"]
    Prometheus["Prometheus"]

    %% Data flows
    GatewayComponents -->|"POST /add_training_data_bulk<br/>HTTP 8000/TCP"| TrainAPI
    GatewayRouter -->|"POST /predict or /predict/bulk/strict<br/>HTTP 8001/TCP"| PredAPI
    ModelSyncer -->|"GET /model/{name}/download<br/>HTTP 8000/TCP"| TrainAPI
    Prometheus -->|"GET /metrics<br/>HTTP 8000/TCP"| TrainAPI

    %% Test flows
    Tests -.->|"HTTP 8000/TCP"| TrainAPI
    Tests -.->|"HTTP 8001/TCP"| PredAPI

    %% Styling
    style TrainingServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PredictionServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style TestRunner fill:#b0b0b0,stroke:#333,stroke-width:1px,stroke-dasharray:5 5
    style GatewayComponents fill:#7ed321,stroke:#333,stroke-width:2px
    style GatewayRouter fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#333,stroke-width:2px
    style TrainAPI fill:#357abd,stroke:#333,color:#fff
    style TrainLoop fill:#357abd,stroke:#333,color:#fff
    style ModelStore fill:#f5a623,stroke:#333
    style PredAPI fill:#357abd,stroke:#333,color:#fff
    style ModelSyncer fill:#357abd,stroke:#333,color:#fff
    style LocalCache fill:#f5a623,stroke:#333
    style InferEngine fill:#357abd,stroke:#333,color:#fff
    style Tests fill:#999,stroke:#333,color:#fff
