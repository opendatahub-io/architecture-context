graph TB
    subgraph OVMS["OpenVINO Model Server"]
        direction TB

        subgraph Frontends["API Frontends"]
            TFSFrontend["TFS Frontend<br/>gRPC/REST<br/>predict, classify, regress"]
            KServeFrontend["KServe Frontend<br/>gRPC (v2 Protocol)<br/>ModelInfer, ModelStreamInfer"]
            HTTPHandler["HTTP REST Handler<br/>Drogon Framework<br/>OpenAI-compatible API"]
        end

        subgraph AIModules["AI Inference Modules"]
            LLM["LLM Engine<br/>Continuous Batching<br/>Speculative Decoding"]
            VLM["VLM Engine<br/>Vision + Language"]
            Embeddings["Embeddings Module<br/>OpenAI-compatible"]
            Rerank["Rerank Module<br/>Cohere-compatible"]
            STT["Audio STT<br/>WhisperPipeline"]
            TTS["Audio TTS<br/>Text2SpeechPipeline"]
            ImageGen["Image Generation<br/>Diffusion Models"]
        end

        subgraph Pipelines["Pipeline Engines"]
            MediaPipe["MediaPipe Graph Executor<br/>CalculatorGraph"]
            DAG["DAG Pipeline Scheduler<br/>Multi-model chaining"]
        end

        subgraph Core["Core Services"]
            ModelManager["Model Manager<br/>Versioning, Hot-reload"]
            HFPull["HuggingFace Pull<br/>GGUF Support"]
            Metrics["Metrics Module<br/>Prometheus"]
            CAPI["C API<br/>libovms_shared.so"]
        end
    end

    %% External inference engine
    OpenVINO["OpenVINO Runtime<br/>Neural Network Inference"]
    GenAI["OpenVINO GenAI<br/>LLM/VLM/STT/TTS Pipelines"]

    %% Clients
    Client["External Client"]
    KServe["KServe / ModelMesh<br/>Container Runtime"]

    %% Storage backends
    S3["S3 / MinIO / Ceph<br/>443/TCP HTTPS"]
    Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
    GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]

    %% Platform
    Prometheus["Prometheus<br/>Metrics Scrape"]

    %% Client flows
    Client -->|"REST/gRPC"| Frontends
    KServe -->|"Container Runtime"| OVMS

    %% Frontend to modules
    HTTPHandler -->|"chat/completions"| LLM
    HTTPHandler -->|"embeddings"| Embeddings
    HTTPHandler -->|"rerank"| Rerank
    HTTPHandler -->|"audio/transcriptions"| STT
    HTTPHandler -->|"audio/speech"| TTS
    HTTPHandler -->|"images/generations"| ImageGen
    HTTPHandler -->|"VLM inference"| VLM

    %% Modules use pipelines
    LLM -->|"graph execution"| MediaPipe
    VLM -->|"graph execution"| MediaPipe
    Embeddings -->|"graph execution"| MediaPipe
    Rerank -->|"graph execution"| MediaPipe
    STT -->|"graph execution"| MediaPipe
    TTS -->|"graph execution"| MediaPipe
    ImageGen -->|"graph execution"| MediaPipe

    %% Core connections
    ModelManager -->|"model loading"| S3
    ModelManager -->|"model loading"| Azure
    ModelManager -->|"model loading"| GCS
    HFPull -->|"model download"| HFHub
    Metrics -->|"/metrics"| Prometheus

    %% Inference engine
    MediaPipe -->|"inference"| OpenVINO
    DAG -->|"inference"| OpenVINO
    LLM -->|"continuous batching"| GenAI
    VLM -->|"VLM pipeline"| GenAI
    STT -->|"WhisperPipeline"| GenAI
    TTS -->|"Text2Speech"| GenAI
    ImageGen -->|"diffusion"| GenAI

    %% Styling
    style OVMS fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style TFSFrontend fill:#4a90e2,color:#fff
    style KServeFrontend fill:#4a90e2,color:#fff
    style HTTPHandler fill:#4a90e2,color:#fff
    style LLM fill:#7ed321,color:#fff
    style VLM fill:#7ed321,color:#fff
    style Embeddings fill:#7ed321,color:#fff
    style Rerank fill:#7ed321,color:#fff
    style STT fill:#7ed321,color:#fff
    style TTS fill:#7ed321,color:#fff
    style ImageGen fill:#7ed321,color:#fff
    style MediaPipe fill:#f5a623,color:#fff
    style DAG fill:#f5a623,color:#fff
    style ModelManager fill:#9b59b6,color:#fff
    style HFPull fill:#9b59b6,color:#fff
    style Metrics fill:#9b59b6,color:#fff
    style CAPI fill:#9b59b6,color:#fff
    style OpenVINO fill:#e74c3c,color:#fff
    style GenAI fill:#e74c3c,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style KServe fill:#f9f9f9,stroke:#999
    style S3 fill:#fff2cc,stroke:#d6b656
    style Azure fill:#fff2cc,stroke:#d6b656
