graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway<br/>(Istio Envoy)<br/>443/TCP → HTTPRoute routing<br/>TLS 1.2+<br/>Platform Auth"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_Deploy["Namespace: deployment namespace"]
            direction TB
            AGPP["AI Gateway Payload Processing<br/>SA: payload-processing-{release}<br/>Image: odh-ai-gateway-payload-processing-rhel9<br/>FIPS: strictfipsruntime + CGO_ENABLED=1"]

            subgraph PluginPipeline["Plugin Pipeline (in-process)"]
                direction LR
                MPR["model-provider-<br/>resolver"]
                APITrans["api-translation"]
                APIKeyInj["apikey-injection"]
            end

            subgraph Guards["Content Safety (optional)"]
                NemoReq["nemo-request-guard"]
                NemoResp["nemo-response-guard"]
            end

            subgraph Ctrl["Embedded Controllers"]
                EPCtrl["external-provider-ctrl"]
                EMCtrl["external-model-ctrl"]
                LegCtrl["legacy-migration-ctrl"]
            end
        end

        NeMoSvc["NeMo Guardrails Service<br/>/v1/guardrail/checks<br/>HTTP, Configurable<br/>Auth: None"]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ExternalProviders["EXTERNAL LLM PROVIDERS (via Istio ServiceEntry)"]
        OpenAI["api.openai.com<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Auth: Bearer Token"]
        Anthropic["api.anthropic.com<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Auth: x-api-key"]
        Azure["*.openai.azure.com<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Auth: api-key header"]
        Bedrock["bedrock-runtime.*.amazonaws.com<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Auth: AWS SigV4"]
        Vertex["*-aiplatform.googleapis.com<br/>443/TCP HTTPS<br/>TLS SIMPLE<br/>Auth: Bearer Token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"gRPC/9004<br/>Istio mTLS STRICT<br/>PeerAuthentication"| AGPP
    Guards -->|"HTTP POST<br/>Configurable<br/>No Auth"| NeMoSvc
    Ctrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    MPR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>(CRD watch)"| K8sAPI

    %% Provider egress (via Gateway + ServiceEntry)
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>Bearer Token"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>x-api-key"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>api-key header"| Azure
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>AWS SigV4"| Bedrock
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>Bearer Token"| Vertex

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef provider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef plugin fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef guard fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Client external
    class Gateway ingress
    class AGPP,NeMoSvc servicemesh
    class MPR,APITrans,APIKeyInj plugin
    class NemoReq,NemoResp guard
    class EPCtrl,EMCtrl,LegCtrl servicemesh
    class K8sAPI k8s
    class OpenAI,Anthropic,Azure,Bedrock,Vertex provider
