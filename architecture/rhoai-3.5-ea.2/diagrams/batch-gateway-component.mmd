graph TB
    subgraph External["External Clients"]
        User["User / Client<br/>(OpenAI-compatible)"]
    end

    subgraph Gateway["Gateway Layer (Kuadrant/Authorino)"]
        AuthGW["API Gateway<br/>Auth: API Key / SA Token / OpenShift Token"]
    end

    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph APIServer["batch-gateway-apiserver"]
            direction TB
            APIMain["REST API Server<br/>Port: 8000/TCP"]
            APIObserv["Observability Server<br/>Port: 8081/TCP"]
            BatchHandler["Batch Handler<br/>/v1/batches"]
            FileHandler["File Handler<br/>/v1/files"]
            Middleware["Middleware Stack<br/>Recovery | Request Tracking<br/>Security Headers"]
            APIMain --> BatchHandler
            APIMain --> FileHandler
            APIMain --> Middleware
        end

        subgraph Processor["batch-gateway-processor"]
            direction TB
            Poller["Queue Poller<br/>poll_interval: 5s"]
            Preprocessor["Preprocessor<br/>Input file → Execution Plans"]
            Executor["Executor<br/>AIMD Adaptive Concurrency"]
            Finalizer["Finalizer<br/>Result Upload & Status Update"]
            Recovery["Startup Recovery<br/>Work Dir Scanner"]
            ProcObserv["Observability Server<br/>Port: 9090/TCP"]
            Poller --> Preprocessor
            Preprocessor --> Executor
            Executor --> Finalizer
        end

        subgraph GC["batch-gateway-gc"]
            direction TB
            Collector["Collector<br/>TTL-based Cleanup<br/>interval: 30m"]
            Reconciler["Reconciler<br/>Orphan Detection<br/>interval: 60m"]
            GCMetrics["Metrics Server<br/>Port: 9091/TCP"]
        end
    end

    subgraph DataLayer["Data Layer"]
        PostgreSQL["PostgreSQL 12+<br/>5432/TCP<br/>Batch & File Metadata"]
        Redis["Redis/Valkey<br/>6379/TCP<br/>Priority Queue | Events<br/>Status Cache | In-Flight"]
        S3["S3-Compatible Storage<br/>443/TCP<br/>File Blob Storage"]
    end

    subgraph Inference["Inference Layer"]
        LLMd["llm-d Inference Endpoint<br/>HTTP/HTTPS<br/>LLM Model Serving"]
    end

    subgraph Observability["Observability"]
        Prometheus["Prometheus<br/>ServiceMonitor / PodMonitor"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC"]
        Grafana["Grafana<br/>Dashboard Sidecar"]
    end

    %% External flows
    User -->|"POST /v1/batches<br/>POST /v1/files"| AuthGW
    AuthGW -->|"Authenticated Request"| APIMain

    %% API Server to Data Layer
    BatchHandler -->|"pgx"| PostgreSQL
    BatchHandler -->|"RESP"| Redis
    FileHandler -->|"pgx"| PostgreSQL
    FileHandler -->|"HTTPS"| S3

    %% Processor to Data Layer
    Poller -->|"Dequeue (sorted set)"| Redis
    Preprocessor -->|"Download input"| S3
    Executor -->|"Inference requests<br/>AIMD concurrency"| LLMd
    Finalizer -->|"Upload output"| S3
    Finalizer -->|"Status update"| PostgreSQL
    Poller -->|"Job metadata"| PostgreSQL

    %% GC to Data Layer
    Collector -->|"Query & delete expired"| PostgreSQL
    Collector -->|"Delete blobs"| S3
    Reconciler -->|"Orphan scan"| Redis
    Reconciler -->|"CAS status update"| PostgreSQL

    %% Observability
    APIObserv -.->|"scrape"| Prometheus
    ProcObserv -.->|"scrape"| Prometheus
    GCMetrics -.->|"scrape"| Prometheus
    Middleware -.->|"traces"| OTel

    %% Styles
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style Processor fill:#4a90e2,stroke:#333,color:#fff
    style GC fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#000
    style LLMd fill:#7ed321,stroke:#333,color:#000
    style AuthGW fill:#e8e8e8,stroke:#333,color:#000
    style User fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style OTel fill:#425cc7,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
