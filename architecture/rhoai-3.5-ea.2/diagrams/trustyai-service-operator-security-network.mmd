graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes — reencrypt TLS)"]
        direction LR
        TASRoute["TAS Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        EHRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        EHMCPRoute["EvalHub MCP Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        GORCHRoute["GORCH Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        NemoRoute["NemoGuardrails Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER (kube-rbac-proxy sidecars)"]
        direction LR
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token → SubjectAccessReview"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        direction TB
        Operator["trustyai-service-operator<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health<br/>9443/TCP webhook"]
    end

    subgraph UserNS["USER NAMESPACES (managed services)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            TAS_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            TAS_Svc["trustyai-service<br/>8080/TCP HTTP"]
        end

        subgraph EHPod["EvalHub Pod"]
            EH_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            EH_Svc["evalhub<br/>8080/TCP HTTP<br/>8081/TCP metrics"]
        end

        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            GORCH_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            GORCH_Svc["orchestrator<br/>8033/TCP HTTP"]
            GORCH_GW["gateway sidecar"]
            GORCH_Det["built-in detectors"]
        end

        subgraph NemoPod["NemoGuardrails Pod"]
            Nemo_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            Nemo_Svc["nemo-guardrails-server<br/>CA bundle mounted"]
        end

        subgraph LMESPod["LMEvalJob Pod (ephemeral)"]
            LMES_Init["init: ta-lmes-driver<br/>copies binary"]
            LMES_Main["main: ta-lmes-job<br/>8082/TCP driver comm"]
        end
    end

    subgraph Platform["INTERNAL PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS"]
        KServe["KServe InferenceService<br/>gRPC/HTTP TLS"]
        ModelMesh["ModelMesh Deployments"]
        Kueue["Kueue<br/>Workload API"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        MCPGateway["MCPGatewayExtension<br/>(Kuadrant)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>Username/Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>DB creds (Secret)"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>HF Token"]
        OTLP["OTLP Endpoint<br/>gRPC/HTTP<br/>TLS optional"]
        GitRepo["Git Repository<br/>443/TCP HTTPS"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| TASRoute
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| EHRoute
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| GORCHRoute
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| NemoRoute

    %% Ingress → Auth Layer → Services
    TASRoute -->|"HTTPS/8443<br/>TLS reencrypt"| TAS_KRBP
    EHRoute -->|"HTTPS/8443<br/>TLS reencrypt"| EH_KRBP
    GORCHRoute -->|"HTTPS/8443<br/>TLS reencrypt"| GORCH_KRBP
    NemoRoute -->|"HTTPS/8443<br/>TLS reencrypt"| Nemo_KRBP

    TAS_KRBP -->|"HTTP/8080<br/>localhost"| TAS_Svc
    EH_KRBP -->|"HTTP/8080<br/>localhost"| EH_Svc
    GORCH_KRBP -->|"HTTP/8033<br/>localhost"| GORCH_Svc
    Nemo_KRBP -->|"HTTP<br/>localhost"| Nemo_Svc

    %% Auth → K8s API for SAR
    TAS_KRBP -.->|"SubjectAccessReview"| K8sAPI
    EH_KRBP -.->|"SubjectAccessReview"| K8sAPI
    GORCH_KRBP -.->|"SubjectAccessReview"| K8sAPI
    Nemo_KRBP -.->|"SubjectAccessReview"| K8sAPI

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Operator → Managed Resources
    Operator -.->|"reconciles"| TASPod
    Operator -.->|"reconciles"| EHPod
    Operator -.->|"reconciles"| GORCHPod
    Operator -.->|"reconciles"| NemoPod
    Operator -.->|"creates + exec"| LMESPod

    %% GORCH → KServe
    GORCH_Svc -->|"gRPC/HTTP<br/>TLS / mTLS"| KServe

    %% LMES → External
    LMES_Main -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    LMES_Main -->|"HTTPS/443<br/>TLS<br/>User/Pass"| OCI
    LMES_Main -->|"HTTPS/443<br/>TLS<br/>HF Token"| HuggingFace
    LMES_Main -->|"HTTPS/443<br/>TLS"| GitRepo

    %% EvalHub → External
    EH_Svc -->|"TCP/5432<br/>TLS optional<br/>DB creds"| PostgreSQL
    EH_Svc -->|"gRPC/HTTP<br/>TLS optional"| OTLP

    %% GORCH → External
    GORCH_Svc -->|"gRPC/HTTP<br/>TLS optional"| OTLP

    %% Operator → Platform integrations
    Operator -.->|"patches"| KServe
    Operator -.->|"patches"| ModelMesh
    Operator -.->|"watches"| Kueue
    Operator -.->|"creates"| Prometheus
    Operator -.->|"watches"| MCPGateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class TASRoute,EHRoute,EHMCPRoute,GORCHRoute,GORCHGWRoute,NemoRoute ingress
    class KRBP,TAS_KRBP,EH_KRBP,GORCH_KRBP,Nemo_KRBP auth
    class Operator operator
    class TAS_Svc,EH_Svc,GORCH_Svc,GORCH_GW,GORCH_Det,Nemo_Svc,LMES_Init,LMES_Main managed
    class K8sAPI,KServe,ModelMesh,Kueue,Prometheus,MCPGateway platform
    class S3,OCI,PostgreSQL,HuggingFace,OTLP,GitRepo externalsvc
