graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust/Axum Service)"]

    %% Internal Platform Dependencies (direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>8085/TCP, optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (indirect, via orchestrator)
    Orchestrator -.->|"content filtering"| Detectors["Guardrails Detectors<br/>(e.g., regex-language)"]
    Orchestrator -.->|"chat completion"| LLM["vLLM / LLM<br/>Inference Service"]

    %% Platform Infrastructure Dependencies
    Gateway -->|"CA cert mount<br/>/etc/tls/ca/service-ca.crt"| K8sServiceCA["Kubernetes<br/>Service CA"]
    Gateway -->|"client cert mount<br/>/etc/tls/private/"| CertProvisioner["cert-manager /<br/>service-serving-cert-signer"]
    Gateway -->|"config mount<br/>/app/config/config.yaml"| ConfigMap["Kubernetes ConfigMap<br/>(GATEWAY_CONFIG)"]

    %% Rust Crate Dependencies (key ones)
    subgraph "Key Runtime Dependencies (Rust Crates)"
        direction TB
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        OpenSSL["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        NativeTLS["native-tls 0.2.12<br/>(platform TLS)"]
        Serde["serde 1.0.215<br/>(serialization)"]
        SerdeYml["serde_yml 0.0.12<br/>(YAML config)"]
        TowerHTTP["tower-http 0.6.2<br/>(HTTP tracing)"]
    end

    Gateway ---|"web framework"| Axum
    Gateway ---|"async runtime"| Tokio
    Gateway ---|"upstream HTTP"| Reqwest
    Gateway ---|"TLS certs"| OpenSSL
    Gateway ---|"TLS identity"| NativeTLS
    Gateway ---|"JSON payloads"| Serde
    Gateway ---|"config parsing"| SerdeYml
    Gateway ---|"request tracing"| TowerHTTP

    %% External auth dependency
    Gateway -.->|"auth enforcement<br/>(recommended sidecar)"| KubeRBACProxy["kube-rbac-proxy<br/>(external sidecar)"]

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style LLM fill:#7ed321,stroke:#333,color:#fff
    style K8sServiceCA fill:#999,stroke:#333,color:#fff
    style CertProvisioner fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#999,stroke:#333,color:#fff
    style KubeRBACProxy fill:#999,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Axum fill:#f5a623,stroke:#333,color:#fff
    style Tokio fill:#f5a623,stroke:#333,color:#fff
    style Reqwest fill:#f5a623,stroke:#333,color:#fff
    style OpenSSL fill:#f5a623,stroke:#333,color:#fff
    style NativeTLS fill:#f5a623,stroke:#333,color:#fff
    style Serde fill:#f5a623,stroke:#333,color:#fff
    style SerdeYml fill:#f5a623,stroke:#333,color:#fff
    style TowerHTTP fill:#f5a623,stroke:#333,color:#fff
