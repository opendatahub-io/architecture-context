graph LR
    AP["llm-d-async<br/>(Async Processor)"]

    %% External Dependencies
    AP -->|"message queue<br/>6379/TCP<br/>Redis protocol"| Redis["Redis 6+<br/>(Conditional)"]
    AP -->|"message queue<br/>443/TCP<br/>gRPC/HTTPS"| GCPPubSub["GCP Pub/Sub v2<br/>(Conditional)"]
    AP -->|"flow control metrics<br/>9090/TCP<br/>PromQL"| Prometheus["Prometheus v2+<br/>(Optional)"]
    AP -->|"flow control metrics<br/>443/TCP<br/>HTTPS"| GMP["Google Managed<br/>Prometheus<br/>(Optional)"]

    %% Internal llm-d Dependencies
    AP -->|"HTTP POST<br/>80/443 TCP<br/>inference dispatch"| IGW["Inference Gateway<br/>(IGW)"]
    AP -->|"Go module<br/>EPP logging"| GAIE["gateway-api-inference<br/>-extension (GAIE)"]
    AP -->|"Go module<br/>metrics server, logging"| ControllerRuntime["controller-runtime"]

    %% Platform Dependencies
