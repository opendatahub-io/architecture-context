graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph JobPod["Job Pod: LMEval Job (odh-ta-lmes-job)<br/>Namespace: {user-namespace}<br/>SA: managed by LMEval operator<br/>CPU only (remote inference)"]
            Adapter["EvalHub Adapter<br/>main.py"]
            LMEval["lm_eval<br/>simple_evaluate()"]
            Sanitizer["Error Sanitizer<br/>Credential redaction"]
            PathGuard["Path Validator<br/>CWE-22 protection"]
        end

        subgraph VolumeMounts["Volume Mounts"]
            ConfigMap["/meta/job.json<br/>(ConfigMap)"]
            ModelSecret["Model Auth Secret<br/>(API key, HF token, CA cert)"]
            TestData["/test_data<br/>(optional, offline mode)"]
        end

        ConfigMap -->|"Filesystem<br/>read-only"| Adapter
        ModelSecret -->|"Filesystem<br/>read-only"| Adapter
        TestData -.->|"Filesystem<br/>offline datasets"| LMEval
    end

    subgraph PlatformServices["PLATFORM SERVICES (Internal)"]
        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Operator["TrustyAI LMEval Operator<br/>(creates K8s Job)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelEndpoint["Model Serving Endpoint<br/>(vLLM, TGI, etc.)<br/>443/TCP HTTPS<br/>TLS 1.2+ (configurable CA)<br/>Bearer Token (OPENAI_API_KEY)<br/>Concurrency: max 128"]
        OCIRegistry["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry credentials"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM (boto3)"]
        MLflow["MLflow Tracking Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    %% Operator creates the job
    Operator -->|"Creates K8s Job<br/>configures SA, volumes"| JobPod

    %% Egress flows (all outbound, no inbound)
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Status callbacks + results"| EvalHub
    LMEval -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>POST /v1/completions"| ModelEndpoint
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds<br/>OCI artifact push"| OCIRegistry
    LMEval -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN<br/>Datasets (disabled offline)"| HFHub
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>Model artifacts"| S3
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Metrics logging"| MLflow

    %% Styling
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef volumes fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Adapter,LMEval,Sanitizer,PathGuard jobpod
    class ConfigMap,ModelSecret,TestData volumes
    class EvalHub,Operator platform
    class ModelEndpoint,OCIRegistry,HFHub,S3,MLflow external
