graph TB
    subgraph OGX["OGX Distribution (odh-ogx-core)"]
        direction TB
        Server["OGX Server<br/>Python 3.12<br/>Port 8321/TCP"]
        AuthMW["Auth Middleware<br/>OAuth2/OIDC JWT via JWKS"]
        InferenceAPI["Inference APIs<br/>/v1/chat/completions<br/>/v1/messages<br/>/v1/completions"]
        VectorAPI["Vector I/O APIs<br/>/v1/vector-io/insert<br/>/v1/vector-io/query"]
        ResponsesAPI["Responses API<br/>/v1/responses<br/>(agentic, tool-calling)"]
        FileAPI["File Processing API<br/>/v1alpha/file-processors/process"]
        BatchAPI["Batch API<br/>/v1/batches"]
        EmbeddingAPI["Embeddings API<br/>/v1/embeddings"]

        Server --> AuthMW
        AuthMW --> InferenceAPI
        AuthMW --> VectorAPI
        AuthMW --> ResponsesAPI
        AuthMW --> FileAPI
        AuthMW --> BatchAPI
        AuthMW --> EmbeddingAPI
    end

    subgraph Providers["Provider System (env-var activated)"]
        direction TB
        subgraph InferenceProviders["Inference Providers"]
            vLLMProv["vllm-inference<br/>(VLLM_URL)"]
            BedrockProv["bedrock<br/>(ENABLE_BEDROCK)"]
            WatsonXProv["watsonx<br/>(WATSONX_API_KEY)"]
            AzureProv["azure<br/>(AZURE_API_KEY)"]
            VertexProv["vertex-ai<br/>(VERTEX_AI_PROJECT)"]
            OpenAIProv["openai<br/>(OPENAI_API_KEY)"]
            GeminiProv["gemini<br/>(ENABLE_GEMINI)"]
            AnthropicProv["anthropic<br/>(ANTHROPIC_API_KEY)"]
        end

        subgraph VectorProviders["Vector Providers"]
            MilvusProv["milvus<br/>(MILVUS_ENDPOINT)"]
            PgvectorProv["pgvector<br/>(ENABLE_PGVECTOR)"]
            QdrantProv["qdrant<br/>(ENABLE_QDRANT)"]
            FAISSProv["faiss<br/>(inline)"]
        end

        subgraph FileProviders["File Processors"]
            DoclingProv["docling<br/>(inline)"]
            MarkItDownProv["markitdown<br/>(inline)"]
            PyPDFProv["pypdf<br/>(inline)"]
        end

        subgraph ToolProviders["Tool Runtimes"]
            BraveProv["brave-search<br/>(BRAVE_SEARCH_API_KEY)"]
            TavilyProv["tavily-search<br/>(TAVILY_SEARCH_API_KEY)"]
            MCPProv["mcp<br/>(configurable)"]
        end
    end

    Client[Client] -->|HTTP 8321/TCP<br/>OAuth2 Bearer Token| Server

    InferenceAPI --> InferenceProviders
    VectorAPI --> VectorProviders
    FileAPI --> FileProviders
    ResponsesAPI --> ToolProviders
    EmbeddingAPI -->|vLLM Embedding| vLLMProv

    subgraph Storage["State Persistence"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>KV Store, SQL Tables"]
    end

    Server -->|asyncpg<br/>5432/TCP| PostgreSQL

    subgraph Platform["RHOAI Platform"]
        Operator["rhods-operator<br/>Manages Deployment"]
        Gateway["Gateway API<br/>TLS Termination"]
    end

    Gateway -->|TLS terminated| Server
    Operator -.->|manages lifecycle| OGX

    subgraph OIDC["Auth Provider"]
        JWKSEndpoint["OIDC/OAuth2 Issuer<br/>JWKS Endpoint<br/>443/TCP HTTPS"]
    end

    AuthMW -->|validates JWT| JWKSEndpoint

