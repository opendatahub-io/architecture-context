graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP external<br/>TLS 1.3<br/>OpenShift OAuth"]
    end

    subgraph AuthSidecar["AUTH SIDECAR (Injected by controller)"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS TLS 1.3<br/>SubjectAccessReview<br/>SA: per-workbench"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace, UID 1001)"]
        direction TB

        subgraph JupyterOption["Option A: JupyterLab"]
            Jupyter["JupyterLab 4.5<br/>8888/TCP HTTP<br/>Plaintext (no TLS)<br/>Auth: none (delegated)"]
        end

        subgraph CodeServerOption["Option B: code-server"]
            CodeServer["code-server 4.106.3<br/>8787/TCP HTTP<br/>--auth none<br/>Plaintext"]
            Nginx["nginx<br/>8080/TCP HTTP<br/>Reverse proxy"]
            Httpd["httpd<br/>80/TCP HTTP<br/>CGI kernel access"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        KFP["Kubeflow Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph BuildTimeSvcs["BUILD-TIME SERVICES (Konflux)"]
        Konflux["Konflux Pipeline<br/>Hermetic builds"]
        Cachi2["Cachi2 Prefetch<br/>--no-index enforcement"]
        PyPI["AIPCC PyPI Index<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Quay["Quay.io Registry<br/>443/TCP HTTPS<br/>TLS 1.3<br/>Registry token"]
    end

    %% Runtime flows
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OpenShift OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.3<br/>Bearer Token"| KRBAC
    KRBAC -->|"HTTP/8888<br/>Plaintext (localhost)<br/>No auth"| Jupyter
    KRBAC -->|"HTTP/8787<br/>Plaintext (localhost)<br/>No auth"| CodeServer

    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    CodeServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Pipeline runtime egress
    Jupyter -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>(runtime images only)"| KFP

    %% Build-time flows
    Konflux -->|"HTTPS/443 TLS 1.3"| Cachi2
    Cachi2 -->|"HTTPS/443 TLS 1.2+"| PyPI
    Konflux -->|"HTTPS/443 TLS 1.3<br/>Registry token"| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authsidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#e8e8e8,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Gateway ingress
    class KRBAC authsidecar
    class Jupyter,CodeServer,Nginx,Httpd workbench
    class S3,KFP externalservice
    class Konflux,Cachi2,PyPI,Quay buildtime
