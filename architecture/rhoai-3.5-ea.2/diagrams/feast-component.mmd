graph TB
    subgraph FeastOperator["Feast Operator (Go/kubebuilder)"]
        Controller["FeatureStore Controller<br/>Reconciles FeatureStore CRs"]
        NotebookCtrl["Notebook ConfigMap Controller<br/>Watches kubeflow.org Notebooks"]
        AccessCtrl["Access Controller<br/>RBAC management"]
        AuthzCtrl["AuthZ Controller<br/>OIDC/K8s auth config"]
        TLSMgr["TLS Manager<br/>OpenShift serving cert integration"]
        ScalingMgr["Scaling Manager<br/>HPA + PDB creation"]
    end

    subgraph FeastDeployment["Feast Deployment (Multi-Container Pod)"]
        OnlineServer["Online Server<br/>Python/FastAPI<br/>Port: 6566/6567"]
        OfflineServer["Offline Server<br/>Python/FastAPI<br/>Port: 8815/8816"]
        RegistryServer["Registry Server<br/>Python gRPC+REST<br/>Port: 6570/6572"]
        UIServer["UI Server<br/>TypeScript/React<br/>Port: 8888/8443"]
    end

    subgraph GoServer["Go Feature Server (Alternative)"]
        GoHTTP["HTTP Server<br/>Port: 6566"]
        GoGRPC["gRPC Server<br/>Port: 6566"]
    end

    User["Data Scientist / Client"] -->|"creates"| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|"watched by"| Controller

    Controller -->|"creates/manages"| FeastDeployment
    Controller -->|"creates"| Services["ClusterIP Services<br/>online/offline/registry/ui"]
    Controller -->|"creates"| Routes["OpenShift Routes<br/>TLS ReEncrypt"]
    Controller -->|"creates"| CronJobs["CronJob<br/>Materialization"]
    Controller -->|"creates"| HPA["HorizontalPodAutoscaler"]
    Controller -->|"creates"| ServiceMonitor["ServiceMonitor<br/>Prometheus"]

    TLSMgr -->|"annotates Services"| ServingCert["OpenShift Serving<br/>Cert Controller"]
    ServingCert -->|"provisions"| TLSSecrets["TLS Secrets<br/>(auto-rotated)"]

    NotebookCtrl -->|"watches"| Notebooks["Notebooks<br/>(kubeflow.org/v1)"]
    NotebookCtrl -->|"injects"| FeastConfig["feast-config ConfigMap"]

    OnlineServer -->|"reads/writes"| OnlineStore["Online Store<br/>(Redis/PostgreSQL/DynamoDB)"]
    OfflineServer -->|"reads"| OfflineStore["Offline Store<br/>(PostgreSQL/BigQuery/Snowflake)"]
    RegistryServer -->|"persists"| RegistryBackend["Registry Backend<br/>(SQL/S3/GCS/File)"]

    AuthzCtrl -->|"validates tokens"| OIDCProvider["OIDC Provider<br/>(Keycloak/Azure AD)"]

    style FeastOperator fill:#4a90e2,stroke:#333,color:#fff
    style FeastDeployment fill:#50c878,stroke:#333,color:#fff
    style GoServer fill:#50c878,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#fff
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style RegistryBackend fill:#e8e8e8,stroke:#333
    style OIDCProvider fill:#e8e8e8,stroke:#333
    style ServingCert fill:#e8e8e8,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333,color:#fff
