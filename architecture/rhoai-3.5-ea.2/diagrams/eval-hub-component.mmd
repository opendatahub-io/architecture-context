graph TB
    subgraph EvalHub["Eval Hub Service (Single Image, Multi-Binary)"]
        direction TB

        subgraph MainPod["eval-hub Pod"]
            KRBP["kube-rbac-proxy<br/>AuthN Sidecar"]
            API["eval-hub<br/>REST API Server<br/>8080/TCP"]
            Metrics["Metrics Server<br/>8081/TCP"]
            MCP["evalhub-mcp<br/>MCP Server<br/>3001/TCP or stdio"]

            KRBP -->|"X-Tenant + X-User<br/>headers injected"| API
        end

        subgraph EvalJobPod["Evaluation Job Pod (K8s Job)"]
            InitContainer["eval-runtime-init<br/>Init Container"]
            Sidecar["eval-runtime-sidecar<br/>Reverse Proxy<br/>8080/TCP"]
            Runtime["Evaluation Runtime<br/>(LM Eval Harness /<br/>Lighteval / Garak /<br/>GuiDeLLM / IBM CLEAR)"]

            InitContainer -.->|"runs before"| Runtime
            Runtime -->|"API calls via<br/>localhost:8080"| Sidecar
        end
    end

    Client["Client<br/>(Dashboard / CLI / SDK)"] -->|"HTTPS/443<br/>Bearer Token"| KRBP
    IDE["IDE<br/>(Cursor / VS Code /<br/>Claude Code)"] -->|"stdio or HTTP/3001"| MCP

    API -->|"creates"| EvalJobPod
    MCP -->|"delegates to"| API

    Sidecar -->|"status updates<br/>HTTPS + SA token"| API
    Sidecar -->|"metrics logging<br/>HTTPS + bearer"| MLflow["MLflow Tracking<br/>Server"]
    Sidecar -->|"artifact access<br/>HTTPS + docker config"| OCI["OCI Registry"]
    InitContainer -->|"downloads test data<br/>HTTPS + AWS IAM"| S3["S3-compatible<br/>Storage"]

    API -->|"Job/ConfigMap CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API"]
    API -->|"state persistence<br/>TCP/5432"| PostgreSQL["PostgreSQL"]
    API -->|"experiment tracking<br/>HTTP/HTTPS"| MLflow
    API -->|"trace export<br/>gRPC/4317"| OTEL["OTEL Collector"]
    Metrics -->|"scrape /metrics"| Prometheus["Prometheus"]

    style API fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style MCP fill:#4a90e2,stroke:#333,color:#fff
    style KRBP fill:#9b59b6,stroke:#333,color:#fff
    style Runtime fill:#e67e22,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OCI fill:#f5a623,stroke:#333
    style OTEL fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style IDE fill:#f9f9f9,stroke:#999
