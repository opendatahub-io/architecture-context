graph LR
    Dashboard["odh-dashboard<br/>Frontend + BFF Monorepo"]

    %% External Framework Dependencies
    subgraph Frameworks["Frameworks & Runtime"]
        NodeJS["Node.js 22+"]
        Go["Go 1.25+"]
        React["React 18.3.1"]
        PatternFly["PatternFly 6.4.x"]
        Fastify["Fastify 4.29.1"]
        CtrlRuntime["controller-runtime 0.23.3"]
        ModFed["@module-federation/runtime 0.15.0"]
        DynPlugin["@openshift/dynamic-plugin-sdk 5.0.1"]
    end

    Dashboard -->|"backend runtime"| NodeJS
    Dashboard -->|"BFF + operator runtime"| Go
    Dashboard -->|"frontend framework"| React
    Dashboard -->|"UI components"| PatternFly
    Dashboard -->|"HTTP server"| Fastify
    Dashboard -->|"operator framework"| CtrlRuntime
    Dashboard -->|"micro-frontend composition"| ModFed
    Dashboard -->|"plugin extension points"| DynPlugin

    %% Internal RHOAI Dependencies (CRD-based)
    subgraph InternalCRD["Internal Platform (CRD Interactions)"]
        RhodsOp["rhods-operator<br/>(Dashboard CR)"]
        DSC["DataScienceCluster<br/>(component availability)"]
        DSCI["DSCInitialization<br/>(platform init state)"]
        NotebooksCtrl["Notebooks Controller<br/>(kubeflow.org)"]
        KServe["KServe<br/>(serving.kserve.io)"]
        ModelRegOp["Model Registry Operator<br/>(modelregistry.opendatahub.io)"]
        MLflowOp["MLflow Operator<br/>(mlflow.opendatahub.io)"]
        Feast["FeatureStore<br/>(feast.dev)"]
        OGXServer["OGXServer<br/>(ogx.io)"]
        AgentRuntime["AgentRuntime<br/>(agent.kagenti.dev)"]
        MCPServer["MCPServerRegistration<br/>(mcp.kuadrant.io)"]
        NIMAccount["NIMAccount<br/>(nim.opendatahub.io)"]
        Guardrails["GuardrailsOrchestrator<br/>(trustyai.opendatahub.io)"]
        EvalHubCRD["EvalHub<br/>(trustyai.opendatahub.io)"]
    end

    RhodsOp -->|"creates Dashboard CR"| Dashboard
    Dashboard -->|"watches"| DSC
    Dashboard -->|"watches"| DSCI
    Dashboard -->|"CRUD"| NotebooksCtrl
    Dashboard -->|"watch + proxy"| KServe
    Dashboard -->|"CRUD"| ModelRegOp
    Dashboard -->|"watches"| MLflowOp
    Dashboard -->|"watches"| Feast
    Dashboard -->|"watches"| OGXServer
    Dashboard -->|"watches"| AgentRuntime
    Dashboard -->|"watches"| MCPServer
    Dashboard -->|"CRUD"| NIMAccount
    Dashboard -->|"watches"| Guardrails
    Dashboard -->|"watches"| EvalHubCRD

    %% Internal RHOAI Dependencies (REST Proxy)
    subgraph InternalREST["Internal Platform (REST Proxy)"]
        ModelRegSvc["Model Registry Service<br/>8080/TCP"]
        DSPAPISvc["DSP API Server<br/>HTTPS"]
        TrustyAISvc["TrustyAI Service<br/>443/TCP"]
        MLflowSvc["MLflow Service<br/>8443/TCP"]
        OGXAPISvc["OGX API<br/>HTTPS"]
        LlamaStackSvc["LlamaStack<br/>8321/TCP"]
        MaaSCtrlSvc["MaaS Controller<br/>HTTPS"]
        EvalHubAPISvc["EvalHub REST API<br/>HTTPS"]
        PipelineSvrSvc["Pipeline Server<br/>HTTPS"]
        PersesProxy["Perses<br/>8080/TCP"]
    end

    Dashboard -->|"model-registry BFF"| ModelRegSvc
    Dashboard -->|"backend proxy"| DSPAPISvc
    Dashboard -->|"backend proxy"| TrustyAISvc
    Dashboard -->|"gen-ai + mlflow BFF"| MLflowSvc
    Dashboard -->|"gen-ai + autorag BFF"| OGXAPISvc
    Dashboard -->|"gen-ai BFF"| LlamaStackSvc
    Dashboard -->|"maas BFF"| MaaSCtrlSvc
    Dashboard -->|"eval-hub BFF"| EvalHubAPISvc
    Dashboard -->|"automl + autorag BFF"| PipelineSvrSvc
    Dashboard -.->|"optional"| PersesProxy

    %% External Dependencies
    subgraph ExternalDeps["External Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        GatewayAPI["Gateway API<br/>(HTTPRoute)"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP"]
        CertManager["service-serving-cert<br/>(TLS provisioning)"]
        OSConsole["OpenShift Console<br/>(ConsoleLink)"]
        S3["S3-compatible Storage<br/>443/TCP"]
        Segment["Segment Analytics<br/>443/TCP"]
    end

    Dashboard -->|"all K8s operations"| K8sAPI
    Dashboard -->|"ingress routing"| GatewayAPI
    Dashboard -->|"auth enforcement"| KubeRBACProxy
    Dashboard -->|"TLS certs"| CertManager
    Dashboard -->|"app launcher"| OSConsole
    Dashboard -->|"automl + autorag data"| S3
    Dashboard -.->|"telemetry (optional)"| Segment

