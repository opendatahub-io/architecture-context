graph LR
    LMEval["LMEval Job<br/>(odh-ta-lmes-job)"]

    %% Core Framework Dependencies
    subgraph CoreFramework["Core Framework"]
        LMEvalHarness["lm-evaluation-harness<br/>0.4.8"]
        EvalHubSDK["eval-hub-sdk<br/>0.1.7"]
    end

    LMEval -->|"evaluation engine"| LMEvalHarness
    LMEval -->|"job lifecycle adapter"| EvalHubSDK

    %% ML / AI Dependencies
    subgraph MLDeps["ML / AI Libraries"]
        PyTorch["PyTorch<br/>2.6.0"]
        Transformers["transformers<br/>4.48.0"]
        Accelerate["accelerate<br/>1.0.1"]
        Datasets["datasets<br/>3.1.0"]
        PEFT["peft<br/>0.13.2"]
        ScikitLearn["scikit-learn<br/>1.5.2"]
    end

    LMEval -->|"tensor computation"| PyTorch
    LMEval -->|"tokenizer + models"| Transformers
    LMEval -->|"distributed inference"| Accelerate
    LMEval -->|"benchmark data"| Datasets
    LMEval -->|"LoRA adapters"| PEFT
    LMEval -->|"ML metrics"| ScikitLearn

    %% Evaluation Frameworks
    subgraph EvalFrameworks["Evaluation Frameworks"]
        Unitxt["unitxt<br/>1.17.2"]
        SacreBLEU["sacrebleu<br/>2.4.3"]
        RougeScore["rouge-score<br/>0.1.2"]
        MathVerify["math-verify<br/>0.9.0"]
    end

    LMEval -->|"custom eval tasks"| Unitxt
    LMEval -->|"BLEU scores"| SacreBLEU
    LMEval -->|"ROUGE metrics"| RougeScore
    LMEval -.->|"math verification"| MathVerify

    %% Infrastructure Dependencies
    subgraph InfraDeps["Infrastructure / Cloud"]
        Boto3["boto3<br/>1.42.12"]
        Olot["olot<br/>0.1.15"]
        WatsonxAI["ibm-watsonx-ai<br/>1.4.11"]
    end

    LMEval -->|"S3 storage access"| Boto3
    LMEval -->|"OCI artifact packaging"| Olot
    LMEval -.->|"Watson model endpoints"| WatsonxAI

    %% Internal Platform Dependencies
    subgraph PlatformDeps["Internal RHOAI Platform"]
        EvalHubSvc["EvalHub Service"]
        ModelEndpoint["Model Serving Endpoint<br/>(vLLM, TGI, etc.)"]
        OCIRegistry["OCI Registry"]
        LMEvalOperator["TrustyAI LMEval Operator<br/>(lmes-controller)"]
    end

    LMEval -->|"status callbacks<br/>REST API"| EvalHubSvc
    LMEval -->|"completions requests<br/>OpenAI-compatible API"| ModelEndpoint
    LMEval -->|"artifact push<br/>OCI Push"| OCIRegistry
    LMEvalOperator -->|"creates K8s Job"| LMEval

    %% External Services
    subgraph ExternalSvcs["External Services"]
        HFHub["HuggingFace Hub<br/>huggingface.co"]
        S3["S3-compatible Storage"]
        MLflow["MLflow Tracking Server"]
    end

    LMEval -->|"datasets download<br/>HTTPS/443"| HFHub
    LMEval -->|"model artifacts<br/>HTTPS/443"| S3
    LMEval -->|"metrics logging<br/>HTTPS/443"| MLflow

