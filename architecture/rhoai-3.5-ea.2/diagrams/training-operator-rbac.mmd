graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>Namespace: opendatahub"]
        LauncherSA["{job-name}-launcher<br/>Namespace: {job-namespace}<br/>(per MPI job, dynamic)"]
    end

    subgraph ClusterBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph NSBindings["Namespace Role Bindings"]
        WebhookRB["training-operator-webhook<br/>(RoleBinding, opendatahub ns)"]
        LauncherRB["{job-name}-launcher<br/>(RoleBinding, job ns, per MPI job)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["training-operator<br/>(ClusterRole)"]
        CR_Edit["training-edit<br/>(Aggregated ClusterRole)"]
        CR_View["training-view<br/>(Aggregated ClusterRole)"]
    end

    subgraph NSRoles["Namespace Roles"]
        WebhookRole["training-operator-webhook<br/>(Role, opendatahub ns)"]
        LauncherRole["{job-name}-launcher<br/>(Role, job ns, per MPI job)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods<br/>get, list, watch,<br/>create, update, patch, delete"]
        PodsExec["core<br/>pods/exec<br/>create"]
        Services["core<br/>services<br/>get, list, watch,<br/>create, delete"]
        ServiceAccts["core<br/>serviceaccounts<br/>get, list, watch, create"]
        ConfigMaps["core<br/>configmaps<br/>list, watch, create, update"]
        Events["core<br/>events<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        PyTorchJobs["kubeflow.org<br/>pytorchjobs<br/>+ /status + /finalizers<br/>full CRUD"]
        TFJobs["kubeflow.org<br/>tfjobs<br/>+ /status + /finalizers<br/>full CRUD"]
        XGBoostJobs["kubeflow.org<br/>xgboostjobs<br/>+ /status + /finalizers<br/>full CRUD"]
        MPIJobs["kubeflow.org<br/>mpijobs<br/>+ /status + /finalizers<br/>full CRUD"]
        PaddleJobs["kubeflow.org<br/>paddlejobs<br/>+ /status + /finalizers<br/>full CRUD"]
        JAXJobs["kubeflow.org<br/>jaxjobs<br/>+ /status + /finalizers<br/>full CRUD"]
    end

    subgraph SchedulingResources["Scheduling Resources"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups<br/>full CRUD"]
        SchedPG["scheduling.x-k8s.io<br/>podgroups<br/>full CRUD"]
        HPA["autoscaling<br/>horizontalpodautoscalers<br/>full CRUD"]
    end

    subgraph RBACResources["RBAC Resources"]
        Roles["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>list, watch, create, update"]
    end

    subgraph NetworkResources["Network Resources"]
        NetPol["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
    end

    subgraph AdmissionResources["Admission Resources"]
        VWC["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get, list, watch, update"]
    end

    subgraph LauncherResources["MPI Launcher Resources (per-job)"]
        LauncherPodsExec["core<br/>pods/exec<br/>create"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via"| WebhookRB
    LauncherSA -->|"bound via"| LauncherRB

    CRB -->|"grants"| CR_Main
    WebhookRB -->|"grants"| WebhookRole
    LauncherRB -->|"grants"| LauncherRole

    %% Main ClusterRole → Resources
    CR_Main -->|"manages"| Pods
    CR_Main -->|"manages"| PodsExec
    CR_Main -->|"manages"| Services
    CR_Main -->|"manages"| ServiceAccts
    CR_Main -->|"manages"| ConfigMaps
    CR_Main -->|"manages"| Events
    CR_Main -->|"manages"| PyTorchJobs
    CR_Main -->|"manages"| TFJobs
    CR_Main -->|"manages"| XGBoostJobs
    CR_Main -->|"manages"| MPIJobs
    CR_Main -->|"manages"| PaddleJobs
    CR_Main -->|"manages"| JAXJobs
    CR_Main -->|"manages"| VolcanoPG
    CR_Main -->|"manages"| SchedPG
    CR_Main -->|"manages"| HPA
    CR_Main -->|"manages"| Roles
    CR_Main -->|"manages"| NetPol
    CR_Main -->|"manages"| VWC

    %% Launcher Role
    LauncherRole -->|"grants"| LauncherPodsExec

