graph LR
    VLLM["vLLM Gaudi<br/>(vllm-gaudi)"]

    %% Core Runtime Dependencies
    VLLM -->|"plugin interface<br/>entry_points"| VLLMCore["vLLM Core<br/>v0.16.0"]
    VLLM -->|"device API<br/>graph compilation"| SynapseAI["Intel Synapse AI<br/>1.23.0"]
    VLLM -->|"HPU integration<br/>FusedSDPA kernels"| HabanaFW["habana_frameworks<br/>1.23.0"]
    VLLM -->|"deep learning<br/>framework"| PyTorch["PyTorch<br/>2.9.0 (Habana fork)"]

    %% ML Libraries
    VLLM -->|"model loading<br/>tokenization"| Transformers["HF Transformers<br/>>=4.56.0, <5"]
    VLLM -->|"distributed<br/>orchestration"| Ray["Ray<br/>>=2.48.0"]

    %% Hardware Libraries
    VLLM -->|"RDMA support"| RDMACore["habanalabs-rdma-core<br/>1.23.0"]
    VLLM -->|"user-space driver"| Thunk["habanalabs-thunk<br/>1.23.0"]
    VLLM -->|"graph compiler"| Graph["habanalabs-graph<br/>1.23.0"]
    VLLM -->|"media loading"| MediaLoader["habana-media-loader<br/>1.23.0"]

    %% Numerical Libraries
    VLLM -->|"data processing"| Pandas["pandas<br/>>=2.2.3"]
    VLLM -->|"JIT compilation"| Numba["numba<br/>>=0.58.0"]
    VLLM -->|"numerical compute"| NumPy["numpy<br/>>=1.26.0"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe<br/>ServingRuntime"] -->|"container lifecycle<br/>scaling, routing"| VLLM
    PlatformIngress["Platform Ingress<br/>Gateway API"] -->|"external routing<br/>HTTPRoute + kube-rbac-proxy"| VLLM
    VLLM -->|"model weights<br/>volume mount / API"| ModelStorage["Model Storage<br/>PVC / S3"]

    %% Styling
    style VLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - dark blue
    style VLLMCore fill:#2c5f8a,stroke:#333,color:#fff
    style SynapseAI fill:#7b2d8e,stroke:#333,color:#fff
    style HabanaFW fill:#7b2d8e,stroke:#333,color:#fff
    style PyTorch fill:#2c5f8a,stroke:#333,color:#fff

    %% Hardware libs - purple
    style RDMACore fill:#7b2d8e,stroke:#333,color:#fff
    style Thunk fill:#7b2d8e,stroke:#333,color:#fff
    style Graph fill:#7b2d8e,stroke:#333,color:#fff
    style MediaLoader fill:#7b2d8e,stroke:#333,color:#fff

    %% ML libs - gray
    style Transformers fill:#999,stroke:#333,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff

    %% Numerical - light gray
    style Pandas fill:#bbb,stroke:#333
    style Numba fill:#bbb,stroke:#333
    style NumPy fill:#bbb,stroke:#333

    %% Internal RHOAI - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff

    %% External services - orange
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
