graph TB
    subgraph External["EXTERNAL (No External Ingress)"]
        NoIngress["No external endpoints exposed<br/>Internal control-plane only"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_RHOAI["Namespace: redhat-ods-applications"]
            AIGW["ai-gateway-operator<br/>SA: operator<br/>8443/TCP HTTPS (metrics)<br/>8081/TCP HTTP (probes)"]
            MetricsSvc["ai-gateway-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS, Bearer Token"]
            BatchGWOp["batch-gateway-operator<br/>SA: llm-d-batch-gateway-operator<br/>8443/TCP HTTPS (metrics)<br/>8081/TCP HTTP (probes)"]
        end

        subgraph PlatformOp["Platform Operator"]
            RHODS["rhods-operator<br/>Creates AIGateway CR"]
        end

        subgraph Monitoring["Monitoring"]
            Prometheus["Prometheus<br/>Scrapes metrics"]
        end
    end

    subgraph ClusterDeps["CLUSTER DEPENDENCIES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        CertMgr["cert-manager<br/>Certificate CRDs"]
        GwAPI["Gateway API<br/>HTTPRoute CRDs"]
        PromOp["Prometheus Operator<br/>ServiceMonitor CRDs"]
    end

    %% Platform operator creates AIGateway CR
    RHODS -->|"Creates AIGateway CR<br/>via K8s API/443<br/>TLS 1.2+, SA Token"| K8sAPI

    %% ai-gateway-operator watches and manages
    AIGW -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    AIGW ---|"exposes"| MetricsSvc

    %% batch-gateway-operator interactions
    BatchGWOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    BatchGWOp -->|"Creates Certificate CRs<br/>via K8s API"| CertMgr
    BatchGWOp -->|"Creates HTTPRoute CRs<br/>via K8s API"| GwAPI
    BatchGWOp -->|"Creates ServiceMonitor,<br/>PodMonitor, PrometheusRule<br/>via K8s API"| PromOp

    %% Prometheus scraping
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>(insecureSkipVerify)"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef dependency fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#b8d4f0,stroke:#6c8ebf,stroke-width:1px

    class NoIngress external
    class AIGW,BatchGWOp internal
    class MetricsSvc service
    class RHODS platform
    class K8sAPI,CertMgr,GwAPI,PromOp dependency
    class Prometheus monitoring
