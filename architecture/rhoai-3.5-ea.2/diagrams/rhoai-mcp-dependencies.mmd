graph LR
    RHOAIMCP["RHOAI MCP Server<br/>(Python FastMCP)"]

    %% External Dependencies (Python packages)
    subgraph PythonDeps["Python Dependencies"]
        MCP["mcp >=1.0.0<br/>(FastMCP framework)"]
        K8sLib["kubernetes >=28.1.0<br/>(K8s API client)"]
        Pydantic["pydantic >=2.0.0<br/>(Data models)"]
        PydanticSettings["pydantic-settings >=2.0.0<br/>(Env config)"]
        HTTPX["httpx >=0.27.0<br/>(Async HTTP)"]
        Pluggy["pluggy >=1.4.0<br/>(Plugin arch)"]
        PyJWT["PyJWT[crypto] >=2.12.0<br/>(JWT validation)"]
    end

    %% CLI Tools (in container)
    subgraph CLITools["CLI Tools (in container)"]
        Helm["helm v3.18.0<br/>(Quickstarts)"]
        OC["oc stable-4.18<br/>(Port-forward, deploy)"]
    end

    %% Internal RHOAI Dependencies (CRD-based)
    subgraph RHOAIPlatform["RHOAI Platform Components"]
        KServe["KServe<br/>(InferenceService,<br/>ServingRuntime)"]
        KFNotebooks["Kubeflow Notebooks<br/>(Notebook CRD)"]
        KFTraining["Kubeflow Training<br/>(TrainJob,<br/>ClusterTrainingRuntime)"]
        DSPipelines["DS Pipelines Operator<br/>(DSPA CRD)"]
        RHOAIOp["RHOAI Operator<br/>(DataScienceCluster,<br/>DSCInitialization)"]
    end

    %% Internal RHOAI Services (REST API-based)
    subgraph RHOAIServices["RHOAI Services"]
        ModelReg["Model Registry<br/>REST /v1alpha3<br/>8080/8443"]
        ModelCat["Model Catalog<br/>REST /v1alpha1<br/>8080/8443"]
        PlannerSvc["Planner Service<br/>REST /api/v1<br/>8000"]
    end

    %% Kubernetes / OpenShift Platform
    subgraph K8sPlatform["Kubernetes / OpenShift"]
        K8sAPI["Kubernetes API Server"]
        OCPSA["OpenShift OAuth / OIDC"]
        OCPProjects["OpenShift Projects"]
        OCPTemplates["OpenShift Templates"]
        OCPRoutes["OpenShift Routes"]
        OCPImages["OpenShift ImageStreams"]
    end

    %% External Services
    subgraph ExtServices["External Services"]
        GitHub["GitHub<br/>(Quickstart READMEs)"]
        HelmRepos["Helm Repositories<br/>(Chart downloads)"]
        OIDCProvider["OIDC Provider<br/>(JWKS keys)"]
    end

    %% Integration points (who depends on RHOAI MCP)
    subgraph Consumers["Consumers"]
        Agent["AI Agents<br/>(Claude, GPT, Llama)"]
    end

    %% Python package dependencies
    RHOAIMCP -->|"MCP protocol"| MCP
    RHOAIMCP -->|"K8s operations"| K8sLib
    RHOAIMCP -->|"config/models"| Pydantic
    RHOAIMCP -->|"env settings"| PydanticSettings
    RHOAIMCP -->|"HTTP calls"| HTTPX
    RHOAIMCP -->|"plugin system"| Pluggy
    RHOAIMCP -->|"JWT auth"| PyJWT

    %% CLI tool dependencies
    RHOAIMCP -->|"chart installs"| Helm
    RHOAIMCP -.->|"port-forward"| OC

    %% CRD interactions
    RHOAIMCP -->|"CRD CRUD"| KServe
    RHOAIMCP -->|"CRD CRUD"| KFNotebooks
    RHOAIMCP -->|"CRD CRUD"| KFTraining
    RHOAIMCP -->|"CRD CRUD"| DSPipelines
    RHOAIMCP -->|"CRD read"| RHOAIOp

    %% Service interactions
    RHOAIMCP -->|"REST API"| ModelReg
    RHOAIMCP -->|"REST API"| ModelCat
    RHOAIMCP -->|"REST API"| PlannerSvc

    %% K8s / OpenShift interactions
    RHOAIMCP -->|"all cluster ops"| K8sAPI
    RHOAIMCP -->|"auth validation"| OCPSA
    RHOAIMCP -->|"project listing"| OCPProjects
    RHOAIMCP -->|"runtime discovery"| OCPTemplates
    RHOAIMCP -->|"URL discovery"| OCPRoutes
    RHOAIMCP -.->|"image listing"| OCPImages

    %% External service dependencies
    RHOAIMCP -->|"README fetch"| GitHub
    RHOAIMCP -->|"chart downloads"| HelmRepos
    RHOAIMCP -->|"JWKS fetch"| OIDCProvider

    %% Consumers
    Agent -->|"MCP over SSE/HTTP/stdio"| RHOAIMCP

    %% Styling
    style RHOAIMCP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    classDef pythondep fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef clitool fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef rhoaicomp fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef rhoaisvc fill:#b6d7a8,stroke:#6aa84f,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef consumer fill:#f9f9f9,stroke:#999,stroke-width:2px

    class MCP,K8sLib,Pydantic,PydanticSettings,HTTPX,Pluggy,PyJWT pythondep
    class Helm,OC clitool
    class KServe,KFNotebooks,KFTraining,DSPipelines,RHOAIOp rhoaicomp
    class ModelReg,ModelCat,PlannerSvc rhoaisvc
    class K8sAPI,OCPSA,OCPProjects,OCPTemplates,OCPRoutes,OCPImages k8s
    class GitHub,HelmRepos,OIDCProvider extsvc
    class Agent consumer
