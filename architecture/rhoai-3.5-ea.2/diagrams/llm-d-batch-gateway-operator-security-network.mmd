graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        HTTPRoute["HTTPRoute → Gateway<br/>8000/TCP<br/>TLS: Gateway-dependent"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications)"]
        direction TB
        Operator["LLM-D Batch Gateway Operator<br/>SA: llm-d-batch-gateway-operator<br/>8081/TCP health, 8443/TCP metrics<br/>FIPS: strictfipsruntime + UBI9"]
    end

    subgraph ManagedNS["MANAGED WORKLOADS (CR namespace)"]
        direction TB
        APIServer["API Server<br/>8000/TCP API (HTTP/HTTPS)<br/>8081/TCP health/metrics<br/>TLS: cert-manager or manual"]
        Processor["Processor<br/>9090/TCP health/metrics<br/>AIMD concurrency control<br/>Worker (no inbound API)"]
        GColl["Garbage Collector<br/>9091/TCP health/metrics<br/>Periodic cleanup worker"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Connection URL Secret"]
        Redis["Redis/Valkey<br/>6379/TCP<br/>Optional TLS<br/>Connection URL Secret"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS<br/>S3 Access Key Secret"]
        InfGW["Inference Gateway<br/>Configurable port<br/>HTTP/HTTPS, Optional mTLS<br/>Bearer Token Secret"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>Configurable TLS"]
    end

    %% External to Ingress
    Client -->|"HTTP/HTTPS 8000/TCP<br/>Bearer Token (optional)"| HTTPRoute

    %% Ingress to API Server
    HTTPRoute -->|"HTTP/HTTPS 8000/TCP<br/>Optional TLS (cert-manager)"| APIServer

    %% Operator to K8s API
    Operator -->|"HTTPS 443/TCP<br/>TLS 1.2+, SA Token<br/>Server-Side Apply"| K8sAPI

    %% Operator manages workloads
    Operator -.->|"creates/manages<br/>(SSA + owner refs)"| APIServer
    Operator -.->|"creates/manages"| Processor
    Operator -.->|"creates/manages"| GColl

    %% Managed components to backends
    APIServer -->|"TCP 5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    APIServer -->|"HTTPS 443<br/>TLS, S3 Key"| S3
    Processor -->|"TCP 5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    Processor -->|"HTTP/HTTPS<br/>Optional TLS/mTLS<br/>Bearer Token"| InfGW
    Processor -->|"HTTPS 443<br/>TLS, S3 Key"| S3
    GColl -->|"TCP 5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    GColl -->|"HTTPS 443<br/>TLS, S3 Key"| S3

    %% Optional Redis alternative
    APIServer -.->|"TCP 6379<br/>Optional TLS<br/>(alternative)"| Redis
    Processor -.->|"TCP 6379<br/>(alternative)"| Redis
    GColl -.->|"TCP 6379<br/>(alternative)"| Redis

    %% Optional OTLP
    APIServer -.->|"gRPC 4317<br/>(optional)"| OTLP
    Processor -.->|"gRPC 4317<br/>(optional)"| OTLP
    GColl -.->|"gRPC 4317<br/>(optional)"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class Client external
    class HTTPRoute ingress
    class Operator operator
    class APIServer,Processor,GColl managed
    class K8sAPI,PostgreSQL,Redis,S3,InfGW,OTLP externalservice
