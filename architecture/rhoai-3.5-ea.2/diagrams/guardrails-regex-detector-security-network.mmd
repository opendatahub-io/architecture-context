graph TB
    subgraph Internal["CLUSTER NETWORK (Internal Only)"]
        direction TB

        subgraph CallerZone["CALLER (Internal Service)"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Namespace: platform-defined"]
        end

        subgraph ServiceZone["SERVICE (ClusterIP — No External Exposure)"]
            RegexDetector["Guardrails Regex Detector<br/>0.0.0.0:8080/TCP<br/>HTTP Plaintext<br/>No Auth<br/>Container: UBI 9 Minimal<br/>⚠ Runs as root"]

            subgraph Endpoints["Exposed Endpoints"]
                Health["GET /health<br/>No Auth"]
                Detection["POST /api/v1/text/contents<br/>No Auth"]
            end

            RegexDetector --- Health
            RegexDetector --- Detection
        end
    end

    subgraph SecurityNotes["SECURITY NOTES"]
        direction TB
        Note1["⚠ No TLS — plaintext HTTP only"]
        Note2["⚠ No authentication at service level"]
        Note3["⚠ Container runs as root"]
        Note4["✅ No egress — no outbound connections"]
        Note5["✅ No secrets consumed"]
        Note6["✅ ReDoS-safe regex engine"]
        Note7["ℹ Relies on service mesh mTLS + NetworkPolicy"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>Plaintext<br/>No Auth<br/>POST /api/v1/text/contents"| RegexDetector

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef caller fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef ok fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    classDef info fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef endpoint fill:#f5f5f5,stroke:#666,stroke-width:1px

    class Orchestrator caller
    class RegexDetector service
    class Health,Detection endpoint
    class Note1,Note2,Note3 warning
    class Note4,Note5,Note6 ok
    class Note7 info
