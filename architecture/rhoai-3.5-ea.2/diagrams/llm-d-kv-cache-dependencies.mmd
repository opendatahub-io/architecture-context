graph LR
    KVCache["llm-d-kv-cache<br/>KV Cache System"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>event transport"| ZeroMQ["ZeroMQ (libzmq) 4.x<br/>✅ Required"]
    KVCache -->|"inference engine<br/>plugin interface"| vLLM["vLLM 0.18.0+rhaiv.4<br/>✅ Required (tokenizer)"]

    %% External Dependencies (Optional)
    KVCache -.->|"distributed index<br/>6379/TCP"| Redis["Redis / Valkey<br/>⚪ Optional backend"]
    KVCache -.->|"GPU↔Storage transfers<br/>CUDA API"| CUDA["CUDA Toolkit 12.x+<br/>⚪ Optional (fs_backend)"]
    KVCache -.->|"zero-copy I/O"| GDS["NVIDIA GDS<br/>⚪ Optional"]
    KVCache -.->|"S3 object storage<br/>abstraction"| NIXL["NIXL<br/>⚪ Optional"]
    KVCache -.->|"tokenizer models<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub<br/>⚪ Optional (tokenizer)"]

    %% Internal Platform Dependencies
    Gateway["llm-d-inference-scheduler<br/>(Gateway)"] -->|"Go library import<br/>(in-process)"| KVCache
    KVCache -->|"ZMQ SUB 5557/TCP<br/>block lifecycle events"| vLLMPods["vLLM Inference Pods"]
    KVCache -->|"POSIX filesystem I/O<br/>ReadWriteMany"| SharedPVC["Shared PVC"]

    %% Integration Points - Consumers
    KVCache -->|"gRPC 4317/TCP<br/>insecure"| OTLP["OTLP Collector"]
    Prometheus["Prometheus"] -->|"HTTP 8080/TCP<br/>scrape /metrics"| KVCache
    KVCache -->|"HTTPS 443/TCP<br/>SA token"| K8sAPI["Kubernetes API"]
    KVCache -.->|"HTTP(S) 9000/TCP<br/>AWS IAM"| S3["S3 / MinIO"]

    %% Styling
    style KVCache fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

