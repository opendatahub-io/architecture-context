    style CUDA fill:#999,stroke:#333,color:#fff
    style GDS fill:#999,stroke:#333,color:#fff
    style NIXL fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style vLLMPods fill:#7ed321,stroke:#333,color:#fff
    style SharedPVC fill:#f5a623,stroke:#333

