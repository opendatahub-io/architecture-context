graph LR
    KubeRbacProxy["kube-rbac-proxy<br/>Sidecar Proxy"]

    %% External Dependencies (Required)
    KubeRbacProxy -->|"TokenReview (authn)<br/>HTTPS/443"| K8sAPI["Kubernetes API Server<br/>v1.35+"]
    KubeRbacProxy -->|"SubjectAccessReview (authz)<br/>HTTPS/443"| K8sAPI

    %% External Dependencies (Optional)
    KubeRbacProxy -.->|"JWKS / Discovery<br/>HTTPS/443"| OIDC["OIDC Provider<br/>(optional)"]

    %% Internal RHOAI Dependencies
    RhodsOperator["rhods-operator"] -->|"sidecar injection<br/>creates container spec"| KubeRbacProxy
    CertManager["cert-manager"] -->|"provisions TLS certs<br/>auto-rotation"| KubeRbacProxy

    %% Upstream (loopback)
    KubeRbacProxy -->|"reverse proxy<br/>HTTP/8081 localhost"| UpstreamApp["Upstream Application<br/>(localhost only)"]

    %% Integration Points - Consumers
    Prometheus["OpenShift Monitoring<br/>(prometheus-k8s)"] -->|"metrics scrape<br/>HTTPS/8443 GET /metrics"| KubeRbacProxy

    %% RHOAI Components that use kube-rbac-proxy as sidecar
    subgraph RHOAI_Components["RHOAI Components (consumers)"]
        Dashboard["RHOAI Dashboard"]
        ModelRegistry["Model Registry"]
        TrustyAI["TrustyAI"]
        Notebooks["Notebook Controller"]
    end

    RHOAI_Components -.->|"runs as sidecar in"| KubeRbacProxy

    %% Platform Infrastructure
    KubeRbacProxy -.->|"reads cert/key files<br/>hot-reload (1min)"| TLSInfra["Platform TLS<br/>Infrastructure"]

    style KubeRbacProxy fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OIDC fill:#999,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style UpstreamApp fill:#9b59b6,stroke:#333,color:#fff
    style Prometheus fill:#e74c3c,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style Notebooks fill:#7ed321,stroke:#333,color:#fff
    style TLSInfra fill:#f5a623,stroke:#333,color:#fff
