graph TD
    subgraph "MLServer Security Model"
        direction TB

        subgraph "Container Identity"
            UID["Non-root User<br/>UID 1000"]
            SA["KServe Service Account<br/>(managed by KServe)"]
        end

        subgraph "No Direct RBAC"
            Note["MLServer does not define<br/>RBAC resources.<br/>Pod RBAC is managed by<br/>KServe's service account."]
        end

        subgraph "Runtime Security (Defense-in-Depth)"
            ProdMode{"Production Mode?<br/>/etc/mlserver/trusted-runtimes.json<br/>exists?"}

            subgraph Allowed["Production Mode (Allowlist Present)"]
                AllowlistCheck["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
                ParseValidation["Validation 1: Settings Parse Time<br/>(early rejection)"]
                AccessValidation["Validation 2: Property Access Time<br/>(defense-in-depth)"]
                ImportRegex["Import Path Regex<br/>(dotted paths, uppercase class names)"]
            end

            subgraph Blocked["Blocked in Production Mode"]
                CustomEnv["Custom Environments<br/>BLOCKED"]
                EnvTarball["Environment Tarballs<br/>BLOCKED"]
                SysPath["sys.path Injection<br/>BLOCKED"]
                WildcardCORS["Wildcard CORS<br/>BLOCKED"]
            end

            subgraph DevMode["Development Mode (No Allowlist)"]
                AnyRuntime["Any Python class<br/>can be loaded"]
                DynImport["Dynamic imports<br/>permitted"]
            end
        end

        subgraph "Network Security (Delegated)"
            IngressTLS["TLS Termination<br/>Platform Ingress / Istio"]
            RBACProxy["kube-rbac-proxy Sidecar<br/>SubjectAccessReview"]
            PodNetwork["Pod Network Isolation<br/>Metrics (8082) internal only"]
        end
    end

    UID -->|"runs as"| SA
    SA -->|"RBAC managed by"| Note

    ProdMode -->|"Yes"| AllowlistCheck
    ProdMode -->|"No"| AnyRuntime

    AllowlistCheck --> ParseValidation
    AllowlistCheck --> AccessValidation
    AllowlistCheck --> ImportRegex

    AllowlistCheck -->|"blocks"| CustomEnv
    AllowlistCheck -->|"blocks"| EnvTarball
    AllowlistCheck -->|"blocks"| SysPath
    AllowlistCheck -->|"blocks"| WildcardCORS

    AnyRuntime --> DynImport

    IngressTLS --> RBACProxy
    RBACProxy --> PodNetwork

    %% Styling
    style UID fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Note fill:#f9f9f9,stroke:#999
    style ProdMode fill:#f5a623,stroke:#333,color:#fff
    style AllowlistCheck fill:#e74c3c,stroke:#333,color:#fff
    style ParseValidation fill:#7ed321,stroke:#333,color:#fff
    style AccessValidation fill:#7ed321,stroke:#333,color:#fff
    style ImportRegex fill:#7ed321,stroke:#333,color:#fff
    style CustomEnv fill:#c0392b,stroke:#333,color:#fff
    style EnvTarball fill:#c0392b,stroke:#333,color:#fff
    style SysPath fill:#c0392b,stroke:#333,color:#fff
    style WildcardCORS fill:#c0392b,stroke:#333,color:#fff
    style AnyRuntime fill:#f39c12,stroke:#333,color:#fff
    style DynImport fill:#f39c12,stroke:#333,color:#fff
    style IngressTLS fill:#3498db,stroke:#333,color:#fff
    style RBACProxy fill:#3498db,stroke:#333,color:#fff
    style PodNetwork fill:#3498db,stroke:#333,color:#fff
