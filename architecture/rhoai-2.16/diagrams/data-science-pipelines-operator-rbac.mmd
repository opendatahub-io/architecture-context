graph TD
    subgraph "Operator Control Plane"
        SA_Controller[ServiceAccount<br/>controller-manager<br/>datasciencepipelinesapplications-controller]
    end

    subgraph "Cluster-Wide Permissions"
        CRB_Manager[ClusterRoleBinding<br/>manager-rolebinding]
        CR_Manager[ClusterRole<br/>manager-role]

        CR_ArgoAdmin[ClusterRole<br/>argo-aggregate-to-admin]
        CR_ArgoEdit[ClusterRole<br/>argo-aggregate-to-edit]
        CR_ArgoView[ClusterRole<br/>argo-aggregate-to-view]
    end

    subgraph "Per-Namespace DSP Stack Resources"
        SA_Pipeline["ServiceAccount<br/>ds-pipeline-NAME"]
        SA_Runner["ServiceAccount<br/>pipeline-runner-NAME"]
        SA_Argo["ServiceAccount<br/>argo"]
        SA_PA["ServiceAccount<br/>ds-pipeline-persistenceagent-NAME"]
        SA_SWF["ServiceAccount<br/>ds-pipeline-scheduledworkflow-NAME"]

        RB_Pipeline["RoleBinding<br/>ds-pipeline-NAME"]
        RB_Runner["RoleBinding<br/>pipeline-runner-NAME"]
        CRB_Argo["ClusterRoleBinding<br/>argo-binding"]

        R_Pipeline["Role<br/>ds-pipeline-NAME"]
        R_Runner["Role<br/>pipeline-runner-NAME"]
        CR_Argo["ClusterRole<br/>argo-cluster-role"]
    end

    subgraph "API Resources - DSPA CRDs"
        DSPACR[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
        DSPAStatus[datasciencepipelinesapplications/status]
        DSPAFinalizers[datasciencepipelinesapplications/finalizers]
    end

    subgraph "API Resources - Core & Apps"
        Deployments[apps/Deployments]
        Services[core/Services]
        ConfigMaps[core/ConfigMaps]
        Secrets[core/Secrets]
        ServiceAccounts[core/ServiceAccounts]
        PVCs[core/PersistentVolumeClaims]
        PVs[core/PersistentVolumes]
        Pods[core/Pods]
        Events[core/Events]
    end

    subgraph "API Resources - RBAC"
        Roles[rbac.authorization.k8s.io/Roles]
        RoleBindings[rbac.authorization.k8s.io/RoleBindings]
        ClusterRoles[rbac.authorization.k8s.io/ClusterRoles]
        ClusterRoleBindings[rbac.authorization.k8s.io/ClusterRoleBindings]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io/Routes]
        ImageStreamTags[image.openshift.io/ImageStreamTags]
    end

    subgraph "API Resources - Networking & Monitoring"
        NetworkPolicies[networking.k8s.io/NetworkPolicies]
        Ingresses[networking.k8s.io/Ingresses]
        ServiceMonitors[monitoring.coreos.com/ServiceMonitors]
    end

    subgraph "API Resources - Argo & Workflows"
        Workflows[argoproj.io/Workflows]
        WorkflowTaskResults[argoproj.io/WorkflowTaskResults]
        WorkflowTemplates[argoproj.io/WorkflowTemplates]
        CronWorkflows[argoproj.io/CronWorkflows]
        ClusterWorkflowTemplates[argoproj.io/ClusterWorkflowTemplates]
    end

    subgraph "API Resources - ML Workloads"
        Jobs[batch/Jobs]
        KubeflowAll[kubeflow.org/*]
        RayClusters[ray.io/RayClusters]
        AppWrappers[workload.codeflare.dev/AppWrappers]
        SeldonDeployments[machinelearning.seldon.io/SeldonDeployments]
    end

    subgraph "API Resources - Storage"
        VolumeSnapshots[snapshot.storage.k8s.io/VolumeSnapshots]
    end

    subgraph "API Resources - Auth"
        TokenReviews[authentication.k8s.io/TokenReviews]
        SubjectAccessReviews[authorization.k8s.io/SubjectAccessReviews]
    end

    %% Operator RBAC bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    %% Operator permissions (extensive)
    CR_Manager -->|get, list, watch, create, update, patch, delete| DSPACR
    CR_Manager -->|get, list, watch, create, update, patch, delete| DSPAStatus
    CR_Manager -->|get, list, watch, create, update, patch, delete| DSPAFinalizers
    CR_Manager -->|create, delete, get, list, patch, update, watch| Deployments
    CR_Manager -->|create, delete, get, list, patch, update, watch| Services
    CR_Manager -->|create, delete, get, list, patch, update, watch| ConfigMaps
    CR_Manager -->|create, delete, get, list, patch, update, watch| Secrets
    CR_Manager -->|create, delete, get, list, patch, update, watch| ServiceAccounts
    CR_Manager -->|create, delete, get, list, patch, update, watch| PVCs
    CR_Manager -->|create, delete, get, list, patch, update, watch| PVs
    CR_Manager -->|*| Pods
    CR_Manager -->|create, list, patch| Events
    CR_Manager -->|create, delete, get, list, patch, update, watch| Roles
    CR_Manager -->|create, delete, get, list, patch, update, watch| RoleBindings
    CR_Manager -->|create, delete, get, list, patch, update, watch| ClusterRoles
    CR_Manager -->|create, delete, get, list, patch, update, watch| ClusterRoleBindings
    CR_Manager -->|create, delete, get, list, patch, update, watch| Routes
    CR_Manager -->|create, delete, get, list, patch, update, watch| NetworkPolicies
    CR_Manager -->|get, list| Ingresses
    CR_Manager -->|create, delete, get, list, patch, update, watch| ServiceMonitors
    CR_Manager -->|*, create, patch| Workflows
    CR_Manager -->|*, create, patch| WorkflowTaskResults
    CR_Manager -->|*| Jobs
    CR_Manager -->|*| KubeflowAll
    CR_Manager -->|get| ImageStreamTags
    CR_Manager -->|create| TokenReviews
    CR_Manager -->|create| SubjectAccessReviews
    CR_Manager -->|create, delete, get| VolumeSnapshots
    CR_Manager -->|create, delete, get, list, patch| RayClusters
    CR_Manager -->|create, delete, deletecollection, get, list, patch, update, watch| AppWrappers
    CR_Manager -->|*| SeldonDeployments

    %% DSP component permissions
    SA_Pipeline -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| R_Pipeline
    R_Pipeline -->|get, list, watch| Secrets
    R_Pipeline -->|get, list, watch| ConfigMaps
    R_Pipeline -->|get, list, watch, create, update, patch, delete| Workflows

    %% Pipeline runner permissions
    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -->|get, list, watch, create, update, patch, delete| Workflows
    R_Runner -->|get, list, watch| Pods

    %% Argo workflow controller permissions
    SA_Argo -->|bound via| CRB_Argo
    CRB_Argo -->|grants| CR_Argo
    CR_Argo -->|manages| Workflows
    CR_Argo -->|manages| WorkflowTemplates

    %% Argo aggregate roles (for cluster users)
    CR_ArgoAdmin -->|create, delete, deletecollection, get, list, patch, update, watch| Workflows
    CR_ArgoAdmin -->|create, delete, deletecollection, get, list, patch, update, watch| WorkflowTemplates
    CR_ArgoAdmin -->|create, delete, deletecollection, get, list, patch, update, watch| CronWorkflows
    CR_ArgoAdmin -->|create, delete, deletecollection, get, list, patch, update, watch| ClusterWorkflowTemplates

    CR_ArgoEdit -->|create, delete, deletecollection, get, list, patch, update, watch| Workflows
    CR_ArgoEdit -->|create, delete, deletecollection, get, list, patch, update, watch| WorkflowTemplates
    CR_ArgoEdit -->|create, delete, deletecollection, get, list, patch, update, watch| CronWorkflows

    CR_ArgoView -->|get, list, watch| Workflows
    CR_ArgoView -->|get, list, watch| WorkflowTemplates
    CR_ArgoView -->|get, list, watch| CronWorkflows
    CR_ArgoView -->|get, list, watch| ClusterWorkflowTemplates

