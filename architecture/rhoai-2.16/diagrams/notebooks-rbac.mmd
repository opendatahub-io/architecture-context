graph TD
    subgraph "RBAC Model (Managed by Notebook Controller)"
        direction TB

        subgraph "User Access Control"
            User[Data Scientist]
            OAuth[OAuth Proxy]
            Policy[Access Policy:<br/>User must be notebook owner<br/>OR have namespace access]
        end

        subgraph "Service Account"
            SA["{notebook-name}-sa<br/>(Created per workbench)"]
        end

        subgraph "Role Bindings (Created by Notebook Controller)"
            RB[RoleBinding<br/>Grants namespace resource access]
        end

        subgraph "Namespace Resources"
            Pods[Pods]
            Services[Services]
            ConfigMaps[ConfigMaps]
            Secrets[Secrets]
            PVCs[PersistentVolumeClaims]
        end

        subgraph "External API Access"
            K8sAPI[Kubernetes API Server<br/>Service Account Token Auth]
            DSP[Data Science Pipeline API<br/>Service Account Token Auth]
            ModelReg[Model Registry<br/>Service Account Token Auth]
            KServeAPI[KServe API<br/>Service Account Token Auth]
        end

        subgraph "Mounted Secrets"
            AWSSecret[aws-connection-*<br/>S3 credentials]
            GitSecret[git-credentials<br/>SSH keys]
            DBSecret[database-credentials<br/>DB credentials]
        end
    end

    subgraph "Notebooks Repository"
        NoRBAC["❌ No ClusterRoles defined<br/>❌ No RoleBindings defined<br/>✅ RBAC managed by Notebook Controller"]
    end

    %% User access flow
    User -->|authenticates via| OAuth
    OAuth -->|enforces| Policy
    Policy -->|allows access to| JupyterContainer[JupyterLab Container]

    %% Service account usage
    JupyterContainer -->|runs as| SA
    SA -->|bound via| RB
    RB -->|grants permissions to| Pods
    RB -->|grants permissions to| Services
    RB -->|grants permissions to| ConfigMaps
    RB -->|grants permissions to| Secrets
    RB -->|grants permissions to| PVCs

    %% External API access
    SA -->|authenticates to| K8sAPI
    SA -->|authenticates to| DSP
    SA -->|authenticates to| ModelReg
    SA -->|authenticates to| KServeAPI

    %% Secret access
    SA -->|reads| AWSSecret
    SA -->|reads| GitSecret
    SA -->|reads| DBSecret

    %% Repository relationship
    NoRBAC -.->|RBAC created at runtime by| NotebookController[Notebook Controller]
    NotebookController -.->|creates| SA
    NotebookController -.->|creates| RB

    %% Styling
    style User fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style OAuth fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Policy fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style JupyterContainer fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style NotebookController fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style NoRBAC fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000

    style Pods fill:#e1f5ff,stroke:#0288d1,stroke-width:1px
    style Services fill:#e1f5ff,stroke:#0288d1,stroke-width:1px
    style ConfigMaps fill:#e1f5ff,stroke:#0288d1,stroke-width:1px
    style Secrets fill:#e1f5ff,stroke:#0288d1,stroke-width:1px
    style PVCs fill:#e1f5ff,stroke:#0288d1,stroke-width:1px

    style K8sAPI fill:#ff9800,stroke:#333,stroke-width:1px,color:#fff
    style DSP fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style ModelReg fill:#7ed321,stroke:#333,stroke-width:1px,color:#000
    style KServeAPI fill:#7ed321,stroke:#333,stroke-width:1px,color:#000

    style AWSSecret fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style GitSecret fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style DBSecret fill:#fff2cc,stroke:#d6b656,stroke-width:1px
