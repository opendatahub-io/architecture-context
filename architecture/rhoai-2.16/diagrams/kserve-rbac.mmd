graph TB
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kserve-manager-rolebinding<br/>Scope: cluster-wide]
        CRB2[kserve-leader-election-rolebinding<br/>Scope: kserve namespace]
        CRB3[kserve-auth-proxy-rolebinding<br/>Scope: kserve namespace]
    end

    subgraph "ClusterRole Permissions"
        CR1[kserve-manager-role<br/>ClusterRole]
        CR2[kserve-leader-election-role<br/>Role]
        CR3[kserve-auth-proxy-role<br/>Role]
    end

    subgraph "API Resources - serving.kserve.io"
        InferenceService[InferenceService<br/>v1beta1]
        ServingRuntime[ServingRuntime<br/>v1alpha1]
        ClusterServingRuntime[ClusterServingRuntime<br/>v1alpha1]
        TrainedModel[TrainedModel<br/>v1alpha1]
        InferenceGraph[InferenceGraph<br/>v1alpha1]
        ClusterStorageContainer[ClusterStorageContainer<br/>v1alpha1]
    end

    subgraph "API Resources - serving.knative.dev"
        KnativeService[Service<br/>Knative Services]
    end

    subgraph "API Resources - networking.istio.io"
        VirtualService[VirtualService<br/>Istio Traffic Routing]
    end

    subgraph "API Resources - apps"
        Deployment[Deployment<br/>Kubernetes Deployments]
    end

    subgraph "API Resources - networking.k8s.io"
        Ingress[Ingress<br/>Kubernetes Ingress]
    end

    subgraph "API Resources - autoscaling"
        HPA[HorizontalPodAutoscaler<br/>HPA for scaling]
    end

    subgraph "API Resources - core"
        Services[Services<br/>Kubernetes Services]
        ConfigMaps[ConfigMaps<br/>Configuration]
        Events[Events<br/>Audit trail]
        Secrets[Secrets<br/>Read-only]
        Namespaces[Namespaces<br/>Read-only]
        Pods[Pods<br/>Read-only]
    end

    subgraph "API Resources - admissionregistration.k8s.io"
        MutatingWebhook[MutatingWebhookConfiguration<br/>Webhook registration]
        ValidatingWebhook[ValidatingWebhookConfiguration<br/>Webhook registration]
    end

    subgraph "API Resources - coordination.k8s.io"
        Leases[Leases<br/>Leader election]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% ClusterRole to Resources - kserve-manager-role
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| InferenceService
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| ServingRuntime
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| ClusterServingRuntime
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| TrainedModel
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| InferenceGraph
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| ClusterStorageContainer
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| KnativeService
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| VirtualService
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| Deployment
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| Ingress
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| HPA
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| Services
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| ConfigMaps
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| Events
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| MutatingWebhook
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| ValidatingWebhook
    CR1 -->|"get, list, watch"| Namespaces
    CR1 -->|"get, list, watch"| Pods
    CR1 -->|"get"| Secrets

    %% Leader election role
    CR2 -->|"get, list, watch,<br/>create, update, patch, delete"| Leases
    CR2 -->|"get, update, patch"| ConfigMaps

