graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        RouteDashboard["OpenShift Route<br/>{cluster}-dashboard<br/>443/TCP → 8265/TCP<br/>TLS 1.2+ termination"]
        RouteServe["OpenShift Route<br/>{cluster}-serve<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ termination"]
    end

    subgraph Internal["INTERNAL SERVICES (Trusted - No Service Mesh)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            direction TB
            RayHead["Ray Head Pod<br/>SA: default/custom<br/>User: 1000 (ray)<br/>Ports: 6379,8265,10001,8080,8000"]
            RayWorkers["Ray Worker Pods<br/>SA: default/custom<br/>User: 1000 (ray)<br/>Autoscaling enabled"]

            HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>6379,8265,10001,8080,8000"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP<br/>8000"]
        end

        RayWorkers -->|TCP/6379<br/>Plaintext<br/>No auth| HeadSvc
        RayWorkers -->|HTTP/8265<br/>Plaintext<br/>No auth| HeadSvc
        HeadSvc --> RayHead
        ServeSvc --> RayHead
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: opendatahub)"]
        direction TB
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>User: 65532<br/>Replicas: 1"]
        OpMetrics["Metrics<br/>:8080/metrics"]
        OpHealth["Health<br/>:8081/healthz,readyz"]

        Operator --- OpMetrics
        Operator --- OpHealth
    end

    subgraph K8s["Kubernetes Control Plane"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        Prometheus["Prometheus<br/>Monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional - Fault Tolerance)"]
        Redis["External Redis<br/>6379/TCP<br/>TLS optional<br/>Redis credentials"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>S3 credentials"]
    end

    subgraph OptionalComponents["OPTIONAL COMPONENTS (Community)"]
        APIServer["APIServer<br/>HTTP:8888 gRPC:8887<br/>TLS/mTLS optional"]
        Volcano["Volcano Scheduler<br/>Gang scheduling"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token optional| RouteDashboard
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token optional| RouteServe

    %% Ingress to Internal
    RouteDashboard -->|HTTP/8265<br/>Plaintext<br/>No auth| HeadSvc
    RouteServe -->|HTTP/8000<br/>Plaintext<br/>No auth| ServeSvc

    %% Operator to K8s API
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Plaintext<br/>No auth| OpMetrics

    %% Optional external services
    RayHead -.->|TCP/6379<br/>TLS optional<br/>Redis auth| Redis
    RayHead -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 credentials| S3

    %% Optional components
    APIServer -.->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount| K8sAPI
    Operator -.->|Annotations<br/>via K8s API| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class RouteDashboard,RouteServe ingress
    class RayHead,RayWorkers,HeadSvc,ServeSvc internal
    class Operator,OpMetrics,OpHealth controlplane
    class K8sAPI,Prometheus k8s
    class Redis,S3 externalservice
    class APIServer,Volcano optional
