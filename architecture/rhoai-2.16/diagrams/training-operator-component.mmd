graph TB
    subgraph "Training Operator Component"
        Manager[Training Operator Manager]

        subgraph "Framework Controllers"
            PyTorchCtrl[PyTorchJob Controller]
            TFCtrl[TFJob Controller]
            MPICtrl[MPIJob Controller]
            XGBoostCtrl[XGBoostJob Controller]
            MXNetCtrl[MXNetJob Controller]
            PaddleCtrl[PaddleJob Controller]
        end

        subgraph "Resource Controllers"
            PodCtrl[PodControl]
            SvcCtrl[ServiceControl]
        end

        subgraph "Servers"
            MetricsServer[Metrics Server<br/>:8080/TCP HTTP]
            HealthServer[Health Probes<br/>:8081/TCP HTTP]
        end

        Manager --> PyTorchCtrl
        Manager --> TFCtrl
        Manager --> MPICtrl
        Manager --> XGBoostCtrl
        Manager --> MXNetCtrl
        Manager --> PaddleCtrl

        PyTorchCtrl --> PodCtrl
        PyTorchCtrl --> SvcCtrl
        TFCtrl --> PodCtrl
        TFCtrl --> SvcCtrl
        MPICtrl --> PodCtrl
        MPICtrl --> SvcCtrl
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        MXJobCR[MXJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Training Pods]
        Services[Headless Services<br/>DNS-based discovery]
        ConfigMaps[ConfigMaps]
        PodGroups[PodGroups<br/>Gang Scheduling]
    end

    User[User/Data Scientist] -->|creates| PyTorchJobCR
    User -->|creates| TFJobCR
    User -->|creates| MPIJobCR

    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MXJobCR -->|watched by| MXNetCtrl
    PaddleJobCR -->|watched by| PaddleCtrl

    PodCtrl -->|creates| Pods
    SvcCtrl -->|creates| Services
    PyTorchCtrl -->|creates| ConfigMaps
    PyTorchCtrl -.->|optional| PodGroups

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        Prometheus[Prometheus<br/>User Workload Monitoring]
        Volcano[Volcano<br/>Gang Scheduler]
        Registry[Container Registry<br/>443/TCP HTTPS]
    end

    Manager -->|API calls| K8sAPI
    Prometheus -->|scrapes| MetricsServer
    Manager -.->|optional| Volcano
    Pods -->|pulls from| Registry

    style Manager fill:#4a90e2
    style PyTorchCtrl fill:#4a90e2
    style TFCtrl fill:#4a90e2
    style MPICtrl fill:#4a90e2
    style MetricsServer fill:#4a90e2
    style HealthServer fill:#4a90e2
    style PyTorchJobCR fill:#f5a623
    style TFJobCR fill:#f5a623
    style MPIJobCR fill:#f5a623
    style XGBoostJobCR fill:#f5a623
    style MXJobCR fill:#f5a623
    style PaddleJobCR fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style Prometheus fill:#7ed321
    style Volcano fill:#e8e8e8
    style Registry fill:#e8e8e8
