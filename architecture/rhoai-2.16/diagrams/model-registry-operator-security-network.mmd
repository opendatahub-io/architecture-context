graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP HTTPS<br/>Edge TLS<br/>(registry-name)-rest.domain"]
        Gateway["Istio Ingress Gateway<br/>443/TCP HTTPS<br/>TLS Mode: SIMPLE/MUTUAL<br/>Gateway: (registry-name)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS ISTIO_MUTUAL)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            Envoy["Envoy Sidecar<br/>SA: registry-name<br/>mTLS workload identity"]
            REST["Model Registry REST<br/>8080/TCP HTTP plaintext<br/>quay.io/opendatahub/model-registry"]
            gRPC["Model Registry gRPC<br/>9090/TCP gRPC<br/>quay.io/opendatahub/mlmd-grpc-server"]
        end

        subgraph NS_Auth["Namespace: auth-namespace"]
            Authorino["Authorino<br/>50051/TCP gRPC mTLS<br/>JWT validation + RBAC check"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Controller["Controller Manager<br/>SA: controller-manager"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>webhook-server-cert"]
        Proxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>ServiceAccount Token"]
        Database["PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS1.2+ optional<br/>Password from db-secret"]
    end

    %% Flows - User Access Path (Istio Mode)
    Client -->|HTTPS/443<br/>TLS 1.3| Route
    Route -->|HTTPS/443<br/>TLS 1.3<br/>MUTUAL/SIMPLE| Gateway
    Gateway -->|HTTP/8080<br/>mTLS ISTIO_MUTUAL<br/>Workload Identity| Envoy
    Envoy -->|gRPC/50051<br/>mTLS<br/>Service Identity| Authorino
    Authorino -->|HTTPS/6443<br/>TLS 1.3<br/>SubjectAccessReview| K8sAPI
    Envoy -->|HTTP/8080<br/>plaintext localhost<br/>Auth validated by Authorino| REST
    Envoy -->|HTTP/9090<br/>plaintext localhost| gRPC

    %% Flows - Database Access
    REST -->|PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS1.2+ optional<br/>Password| Database
    gRPC -->|PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS1.2+ optional<br/>Password| Database

    %% Flows - Operator Control Plane
    Controller -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s API mTLS| Webhook
    Proxy -->|HTTP/8080<br/>localhost| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,Gateway ingress
    class Envoy,REST,gRPC,Authorino servicemesh
    class Controller,Webhook,Proxy operator
    class K8sAPI,Database externalservice
