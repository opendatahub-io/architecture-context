graph TD
    subgraph "Service Accounts"
        SA1[codeflare-operator-controller-manager<br/>Namespace: opendatahub]
        SA2["{cluster}-oauth-proxy<br/>Namespace: {user-namespace}<br/>Per RayCluster"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[codeflare-operator-manager-rolebinding]
        CRB2[codeflare-operator-leader-election-rolebinding]
        CRB3["{cluster}-{namespace}-auth<br/>Per RayCluster"]
    end

    subgraph "ClusterRoles"
        CR1[codeflare-operator-manager-role]
        CR2[codeflare-operator-leader-election-role]
        CR3["system:auth-delegator<br/>(built-in)"]
    end

    subgraph "API Resources - Core"
        direction TB
        R1["Core API:<br/>- events (create, patch, update, watch)<br/>- nodes (get, list, watch)<br/>- pods, services (full CRUD)<br/>- secrets (full CRUD)<br/>- serviceaccounts (full CRUD)"]
    end

    subgraph "API Resources - Apps & Batch"
        direction TB
        R2["apps:<br/>- deployments, statefulsets (full CRUD)<br/><br/>batch:<br/>- jobs (full CRUD)"]
    end

    subgraph "API Resources - Networking"
        direction TB
        R3["networking.k8s.io:<br/>- ingresses, networkpolicies (full CRUD)<br/><br/>route.openshift.io:<br/>- routes, routes/custom-host (full CRUD)"]
    end

    subgraph "API Resources - Ray & AppWrapper"
        direction TB
        R4["ray.io:<br/>- rayclusters, rayclusters/* (full CRUD)<br/>- rayjobs (full CRUD)<br/><br/>workload.codeflare.dev:<br/>- appwrappers, appwrappers/* (full CRUD)"]
    end

    subgraph "API Resources - Kueue & Scheduling"
        direction TB
        R5["kueue.x-k8s.io:<br/>- clusterqueues (get, list, patch, update, watch)<br/>- resourceflavors, workloadpriorityclasses (get, list, watch)<br/>- workloads, workloads/* (full CRUD)<br/><br/>scheduling.k8s.io:<br/>- priorityclasses (get, list, watch)<br/><br/>scheduling.sigs.k8s.io, scheduling.x-k8s.io:<br/>- podgroups (full CRUD)"]
    end

    subgraph "API Resources - Webhooks & CRDs"
        direction TB
        R6["admissionregistration.k8s.io:<br/>- mutatingwebhookconfigurations (get, list, update, watch)<br/>- validatingwebhookconfigurations (get, list, update, watch)<br/><br/>apiextensions.k8s.io:<br/>- customresourcedefinitions (get, list, watch)"]
    end

    subgraph "API Resources - Auth & RBAC"
        direction TB
        R7["authentication.k8s.io:<br/>- tokenreviews (create)<br/><br/>authorization.k8s.io:<br/>- subjectaccessreviews (create)<br/><br/>rbac.authorization.k8s.io:<br/>- clusterrolebindings (full CRUD)"]
    end

    subgraph "API Resources - ODH & OpenShift"
        direction TB
        R8["dscinitialization.opendatahub.io:<br/>- dscinitializations (get, list, watch)<br/><br/>config.openshift.io:<br/>- ingresses (get)<br/><br/>kubeflow.org:<br/>- pytorchjobs (full CRUD)"]
    end

    subgraph "Leader Election Resources"
        direction TB
        R9["Core API:<br/>- configmaps (full CRUD)<br/>- events (create, patch)<br/><br/>coordination.k8s.io:<br/>- leases (full CRUD)"]
    end

    subgraph "OAuth Delegation (per RayCluster)"
        direction TB
        R10["Delegated Authentication:<br/>- Allows OAuth proxy to validate tokens<br/>- ClusterRole: system:auth-delegator"]
    end

