graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: dashboard-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB[odh-dashboard<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB[odh-dashboard<br/>RoleBinding<br/>Namespace: dashboard-namespace]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]

        CR_Storage[storage.k8s.io/storageclasses<br/>update, patch]
        CR_Nodes[core/nodes<br/>get, list]
        CR_Machine[machine.openshift.io<br/>machineautoscalers, machinesets<br/>get, list]
        CR_ClusterVersions[config.openshift.io/clusterversions<br/>get, watch, list]
        CR_CSV[operators.coreos.com<br/>clusterserviceversions, subscriptions<br/>get, list, watch]
        CR_ImageStreams[image.openshift.io/imagestreams/layers<br/>get]
        CR_Core[core/configmaps, pvcs, secrets<br/>create, delete, get, list, patch, update, watch]
        CR_Routes[route.openshift.io/routes<br/>get, list, watch]
        CR_Console[console.openshift.io/consolelinks<br/>get, list, watch]
        CR_Users[user.openshift.io/groups, users<br/>get, list, watch]
        CR_Pods[core/pods, serviceaccounts, services<br/>get, list, watch]
        CR_Namespaces[core/namespaces<br/>get, list, watch, create, update, patch, delete]
        CR_RBAC[rbac.authorization.k8s.io<br/>rolebindings, clusterrolebindings, roles<br/>get, list, watch, create, update, patch, delete]
        CR_Events[events.k8s.io/events<br/>get, list, watch]
        CR_Notebooks[kubeflow.org/notebooks<br/>get, list, watch, create, update, patch, delete]
        CR_DSC[datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>list, watch, get]
        CR_DSCI[dscinitialization.opendatahub.io<br/>dscinitializations<br/>list, watch, get]
        CR_InferenceServices[serving.kserve.io/inferenceservices<br/>get, list, watch]
        CR_ModelRegistries[modelregistry.opendatahub.io<br/>modelregistries<br/>get, list, watch, create, update, patch, delete]
        CR_NIM[nim.opendatahub.io/accounts<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "Namespaced Role Permissions"
        R[odh-dashboard<br/>Role<br/>Namespace: dashboard-namespace]

        R_AcceleratorProfiles[dashboard.opendatahub.io<br/>acceleratorprofiles<br/>create, get, list, update, patch, delete]
        R_Routes[route.openshift.io/routes<br/>get, list, watch]
        R_Jobs[batch/cronjobs, jobs<br/>create, delete, get, list, patch, update, watch]
        R_ImageStreams[image.openshift.io/imagestreams<br/>create, get, list, update, patch, delete]
        R_Builds[build.openshift.io/builds, buildconfigs<br/>get, list, watch, create, patch, delete]
        R_Deployments[apps/deployments<br/>patch, update]
        R_DeploymentConfigs[apps.openshift.io/deploymentconfigs<br/>get, list, watch, create, update, patch, delete]
        R_DashboardConfigs[opendatahub.io/odhdashboardconfigs<br/>get, list, watch, create, update, patch, delete]
        R_Notebooks[kubeflow.org/notebooks<br/>get, list, watch, create, update, patch, delete]
        R_OdhApps[dashboard.opendatahub.io<br/>odhapplications, odhdocuments<br/>get, list]
        R_QuickStarts[console.openshift.io/odhquickstarts<br/>get, list]
        R_Templates[template.openshift.io/templates<br/>*]
        R_ServingRuntimes[serving.kserve.io/servingruntimes<br/>*]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% Role Bindings to Roles
    CRB -->|grants| CR
    RB -->|grants| R

    %% ClusterRole to Resources
    CR --> CR_Storage
    CR --> CR_Nodes
    CR --> CR_Machine
    CR --> CR_ClusterVersions
    CR --> CR_CSV
    CR --> CR_ImageStreams
    CR --> CR_Core
    CR --> CR_Routes
    CR --> CR_Console
    CR --> CR_Users
    CR --> CR_Pods
    CR --> CR_Namespaces
    CR --> CR_RBAC
    CR --> CR_Events
    CR --> CR_Notebooks
    CR --> CR_DSC
    CR --> CR_DSCI
    CR --> CR_InferenceServices
    CR --> CR_ModelRegistries
    CR --> CR_NIM

    %% Namespaced Role to Resources
    R --> R_AcceleratorProfiles
    R --> R_Routes
    R --> R_Jobs
    R --> R_ImageStreams
    R --> R_Builds
    R --> R_Deployments
    R --> R_DeploymentConfigs
    R --> R_DashboardConfigs
    R --> R_Notebooks
    R --> R_OdhApps
    R --> R_QuickStarts
    R --> R_Templates
    R --> R_ServingRuntimes

