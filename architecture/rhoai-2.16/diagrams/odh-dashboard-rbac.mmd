    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333
    style RB fill:#f5a623,stroke:#333
    style CR fill:#7ed321,stroke:#333
    style R fill:#7ed321,stroke:#333

