graph TD
    subgraph "Service Accounts"
        SA1[redhat-ods-operator:<br/>redhat-ods-operator-controller-manager]
        SA2[redhat-ods-monitoring:<br/>prometheus]
    end

    subgraph "ClusterRole Bindings"
        CRB1[rhods-operator-role-binding]
        CRB2[prometheus-monitoring]
        CRB3[dedicated-admins-mgmt-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[rhods-operator-role]
        CR2[cluster-monitoring-view]
    end

    subgraph "Role Bindings"
        RB1[rhods-prometheus-rolebinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "Roles"
        R1[rhods-prometheus-role]
    end

    subgraph "User/Admin ClusterRoles"
        CR3[datasciencecluster-editor]
        CR4[datasciencecluster-viewer]
        CR5[dscinitialization-editor]
        CR6[dscinitialization-viewer]
    end

    subgraph "API Resources - RHODS Operator CRDs"
        direction LR
        DSC["datasciencecluster.opendatahub.io<br/>DataScienceCluster"]
        DSCI["dscinitialization.opendatahub.io<br/>DSCInitialization"]
        FT["features.opendatahub.io<br/>FeatureTracker"]
    end

    subgraph "API Resources - Core & Apps"
        direction LR
        ConfigMaps["core<br/>ConfigMaps"]
        Secrets["core<br/>Secrets"]
        ServiceAccounts["core<br/>ServiceAccounts"]
        Services["core<br/>Services"]
        Namespaces["core<br/>Namespaces"]
        Deployments["apps<br/>Deployments"]
        ReplicaSets["apps<br/>ReplicaSets"]
        StatefulSets["apps<br/>StatefulSets"]
    end

    subgraph "API Resources - RBAC"
        direction LR
        ClusterRoles["rbac.authorization.k8s.io<br/>ClusterRoles"]
        ClusterRoleBindings["rbac.authorization.k8s.io<br/>ClusterRoleBindings"]
        Roles["rbac.authorization.k8s.io<br/>Roles"]
        RoleBindings["rbac.authorization.k8s.io<br/>RoleBindings"]
    end

    subgraph "API Resources - OpenShift & Monitoring"
        direction LR
        Routes["route.openshift.io<br/>Routes"]
        NetworkPolicies["networking.k8s.io<br/>NetworkPolicies"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors"]
        PrometheusRules["monitoring.coreos.com<br/>PrometheusRules"]
    end

    subgraph "API Resources - Service Mesh & Serving"
        direction LR
        InferenceServices["serving.kserve.io<br/>InferenceServices"]
        ServingRuntimes["serving.kserve.io<br/>ServingRuntimes"]
        KnativeServices["serving.knative.dev<br/>Services"]
        SMCP["maistra.io<br/>ServiceMeshControlPlanes"]
        SMM["maistra.io<br/>ServiceMeshMembers"]
        AuthConfigs["authorino.kuadrant.io<br/>AuthConfigs"]
    end

    subgraph "API Resources - Admission & Extensions"
        direction LR
        ValidatingWebhooks["admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations"]
        MutatingWebhooks["admissionregistration.k8s.io<br/>MutatingWebhookConfigurations"]
        CRDs["apiextensions.k8s.io<br/>CustomResourceDefinitions"]
    end

    %% Service Account to ClusterRoleBinding
    SA1 -->|bound via| CRB1
    SA2 -->|bound via| CRB2
    SA2 -->|bound via| RB1

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1
