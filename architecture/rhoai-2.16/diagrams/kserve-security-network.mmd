graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.3 Termination<br/>RequestAuthentication (JWT)"]
        VS["Istio VirtualService<br/>{isvc-name}-{namespace}.{domain}<br/>Traffic Routing & Policies"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Port: 8012/TCP<br/>Autoscaling Controller"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            KnativeSvc["Knative Service<br/>{isvc-name}-predictor-default<br/>Port: 80/TCP"]

            subgraph PredictorPod["Predictor Pod"]
                Agent["Agent Sidecar<br/>8080/TCP<br/>Batching/Logging"]
                InferenceServer["Inference Server<br/>kserve-sklearnserver<br/>kserve-torchserve<br/>kserve-huggingfaceserver<br/>Port: 8080/TCP (HTTP)<br/>Port: 8081/TCP (gRPC)"]
                StorageInit["Init Container:<br/>storage-initializer<br/>Downloads model artifacts"]
            end

            Agent -->|localhost| InferenceServer
            StorageInit -.->|initializes before| InferenceServer
        end

        subgraph NS_KServe["Namespace: kserve"]
            Controller["KServe Controller Manager<br/>SA: kserve-controller-manager<br/>Ports: 8081/TCP (health), 8443/TCP (metrics)"]
            Webhook["KServe Webhook Server<br/>Port: 9443/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Cert: kserve-webhook-server-cert"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM/Access Keys"]
        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP Service Account"]
        Azure["Azure Blob Storage<br/>{account}.blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Azure Credentials"]
        Logger["Logger Endpoint<br/>80/443 TCP HTTP/HTTPS<br/>Auth: Bearer Token (optional)"]
    end

    %% Request Flow
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token (optional)| Gateway
    Gateway -->|Route| VS
    VS -->|HTTP/80<br/>mTLS STRICT| KnativeSvc
    KnativeSvc -->|HTTP/8012<br/>mTLS<br/>Service Identity| Activator
    Activator -->|HTTP/8080<br/>mTLS| Agent
    Agent -->|HTTP/8080<br/>localhost| InferenceServer

    %% Model Download Flow
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Keys| S3
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>GCP SA JSON| GCS
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>Azure Creds| Azure

    %% Logging Flow
    Agent -.->|HTTP/HTTPS 80/443<br/>Bearer Token| Logger

    %% Control Plane Flow
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Webhook -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS| Webhook
    Controller -.->|Creates/Manages| KnativeSvc
    Controller -.->|Creates| VS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,VS ingress
    class Activator,KnativeSvc,Agent,InferenceServer,StorageInit,Controller,Webhook servicemesh
    class K8sAPI controlplane
    class S3,GCS,Azure,Logger externalservice
