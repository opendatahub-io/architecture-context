graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Termination<br/>Route: {cluster-apps-domain}/notebook/{ns}/{user}"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB

        subgraph Containers["Pod Containers"]
            OAuth["OAuth Proxy Sidecar<br/>Port: 8443/TCP<br/>Auth: OAuth2 OpenShift<br/>UID: 1001 (non-root)<br/>SELinux: Enforced"]
            Jupyter["JupyterLab Container<br/>Port: 8888/TCP (internal)<br/>Image: jupyter-datascience-notebook<br/>UID: 1001 (non-root)<br/>SA: {notebook-name}-sa<br/>Working Dir: /opt/app-root/src (PVC)"]
        end

        Service["Service: notebook<br/>ClusterIP 8888/TCP"]
    end

    subgraph InternalRHOAI["INTERNAL RHOAI SERVICES (Service Mesh)"]
        direction TB

        subgraph NS_DSP["Namespace: {dsp-namespace}"]
            DSP["Data Science Pipeline API<br/>8888/TCP HTTP<br/>mTLS<br/>Service Account Token"]
        end

        subgraph NS_ODH["Namespace: odh"]
            ModelReg["Model Registry API<br/>8080/TCP HTTP<br/>mTLS<br/>Service Account Token"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            KServe["KServe Inference<br/>8080/8443/TCP HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>Service Account Token"]
        end
    end

    subgraph Platform["OPENSHIFT PLATFORM SERVICES"]
        K8sAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Token"]
        OAuthServer["OpenShift OAuth Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Flow"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature v4"]
        PyPI["PyPI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SSH Keys/Tokens"]
        Databases["External Databases<br/>5432/3306/27017 TCP<br/>TLS (varies)<br/>User Credentials"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
    end

    %% Network flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>Forwarded| OAuth
    OAuth -->|HTTP/8888<br/>Localhost<br/>User Headers| Jupyter
    Service -.->|Exposes| Jupyter

    %% Egress from JupyterLab
    Jupyter -->|HTTP/8888<br/>mTLS<br/>SA Token| DSP
    Jupyter -->|HTTP/8080<br/>mTLS<br/>SA Token| ModelReg
    Jupyter -->|HTTP/HTTPS<br/>8080/8443<br/>TLS 1.2+<br/>SA Token| KServe
    Jupyter -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    OAuth -.->|OAuth2 Flow| OAuthServer

    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4| S3
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>Public| PyPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>SSH/Token| Git
    Jupyter -->|TCP<br/>TLS varies<br/>Credentials| Databases
    Registry -.->|Build-time<br/>Pull Images| Jupyter

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef internalService fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class OAuth,Jupyter,Service workbench
    class DSP,ModelReg,KServe internalService
    class K8sAPI,OAuthServer platform
    class S3,PyPI,Git,Databases,Registry externalService
