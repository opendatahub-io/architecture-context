graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[auth-proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB1[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "Cluster Roles"
        CR[manager-role<br/>ClusterRole]
        CR_Auth[auth-proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        R[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Core1[ConfigMaps, PVCs, Pods,<br/>Secrets, Services]
        Core2[Events]
        Core3[PersistentVolumes]
        Core4[Pods/exec]
        Core5[ServiceAccounts]
    end

    subgraph "Apps API Resources"
        Apps1[Deployments<br/>Deployments/finalizers<br/>Deployments/status]
    end

    subgraph "TrustyAI CRDs"
        TrustyAI1[TrustyAIServices<br/>LMEvalJobs]
        TrustyAI2[TrustyAIServices/finalizers<br/>LMEvalJobs/finalizers]
        TrustyAI3[TrustyAIServices/status<br/>LMEvalJobs/status]
    end

    subgraph "KServe API Resources"
        KServe1[InferenceServices<br/>InferenceServices/finalizers<br/>ServingRuntimes]
    end

    subgraph "Monitoring Resources"
        Mon1[ServiceMonitors<br/>monitoring.coreos.com]
    end

    subgraph "Istio Resources"
        Istio1[DestinationRules<br/>VirtualServices<br/>networking.istio.io]
    end

    subgraph "OpenShift Resources"
        OS1[Routes<br/>route.openshift.io]
    end

    subgraph "Kueue Resources"
        Kueue1[Workloads<br/>Workloads/finalizers<br/>Workloads/status]
        Kueue2[ResourceFlavors<br/>WorkloadPriorityClasses]
    end

    subgraph "Coordination Resources"
        Coord1[Leases<br/>coordination.k8s.io]
    end

    subgraph "RBAC Resources"
        RBAC1[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Extensions"
        API1[CustomResourceDefinitions<br/>apiextensions.k8s.io]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| CR_Auth
    RB1 -->|grants| R

    %% ClusterRole Permissions
    CR -->|create, delete, get, list,<br/>patch, update, watch| Core1
    CR -->|create, patch, update, watch| Core2
    CR -->|get, list, watch| Core3
    CR -->|create, delete, get,<br/>list, watch| Core4
    CR -->|create, delete, get,<br/>list, update, watch| Core5

    CR -->|create, delete, get, list,<br/>patch, update, watch| Apps1

    CR -->|create, delete, get, list,<br/>patch, update, watch| TrustyAI1
    CR -->|update| TrustyAI2
    CR -->|get, patch, update| TrustyAI3

    CR -->|create, delete, get, list,<br/>patch, update, watch| KServe1

    CR -->|create, list, watch| Mon1

    CR -->|create, delete, get, list,<br/>patch, update, watch| Istio1

    CR -->|create, delete, get, list,<br/>patch, update, watch| OS1

    CR -->|create, delete, get, list,<br/>patch, update, watch| Kueue1
    CR -->|get, list, watch| Kueue2

    CR -->|create, get, update| Coord1

    CR -->|create, delete, get,<br/>list, update, watch| RBAC1

    CR -->|get, list, watch| API1

    %% Leader Election Role Permissions
    R -->|get, list, watch, create,<br/>update, patch, delete| Coord1
    R -->|create, patch| Core2

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style CR_Auth fill:#f5a623,stroke:#333
    style R fill:#f5a623,stroke:#333
    style CRB1 fill:#7ed321,stroke:#333
    style CRB2 fill:#7ed321,stroke:#333
    style RB1 fill:#7ed321,stroke:#333
    style TrustyAI1 fill:#e74c3c,stroke:#333,color:#fff
    style TrustyAI2 fill:#e74c3c,stroke:#333,color:#fff
    style TrustyAI3 fill:#e74c3c,stroke:#333,color:#fff
