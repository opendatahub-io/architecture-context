graph LR
    ModelMesh["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    ModelMesh -->|coordination<br/>state mgmt| etcd["etcd 3.x<br/>(Required)<br/>:2379/TCP"]
    ModelMesh -->|platform| K8s["Kubernetes 1.23+<br/>(Required)<br/>:6443/TCP"]

    %% External Dependencies (Optional)
    ModelMesh -.->|TLS certs| CertManager["cert-manager v1.0+<br/>(Optional)<br/>Certificate CRs"]
    ModelMesh -.->|metrics CRD| PromOperator["Prometheus Operator v0.50+<br/>(Optional)<br/>ServiceMonitor"]

    %% Container Images (Internal ODH Dependencies)
    ModelMesh -->|runtime image| ModelMeshImage["kserve/modelmesh<br/>Container Image<br/>Java Service"]
    ModelMesh -->|proxy image| RESTProxyImage["kserve/rest-proxy<br/>Container Image<br/>Go Service"]
    ModelMesh -->|adapter image| AdapterImage["kserve/modelmesh-runtime-adapter<br/>Container Image<br/>Go Service"]

    %% Runtime Framework Images
    ModelMesh -->|optional runtime| TritonImage["tritonserver<br/>Container Image<br/>NVIDIA Triton"]
    ModelMesh -.->|optional runtime| MLServerImage["mlserver<br/>Container Image<br/>Seldon MLServer"]
    ModelMesh -.->|optional runtime| OpenVINOImage["openvino_model_server<br/>Container Image<br/>Intel OpenVINO"]
    ModelMesh -.->|optional runtime| TorchServeImage["torchserve<br/>Container Image<br/>PyTorch Serving"]

    %% Service Mesh (Optional but Recommended)
    ModelMesh -.->|traffic mgmt<br/>mTLS<br/>authz| Istio["Istio / Service Mesh<br/>(Optional)<br/>Sidecar Proxy"]

    %% External Services (Runtime)
    ModelMesh -->|model storage| S3["S3-Compatible Storage<br/>(Required for models)<br/>:443/TCP HTTPS"]

    %% Internal ODH Integration Points
    Dashboard["ODH Dashboard<br/>(Internal ODH)"] -->|UI management<br/>CR creation| ModelMesh
    Pipelines["Data Science Pipelines<br/>(Internal ODH)"] -.->|auto-deploy models<br/>post-training| ModelMesh

    %% Monitoring
    Prometheus["Prometheus<br/>(Monitoring)"] -->|scrapes metrics<br/>:8443, :2112| ModelMesh

    %% API Server (for webhook validation)
    K8s -->|webhook calls<br/>:9443/TCP| ModelMesh

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style etcd fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style K8s fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style CertManager fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style PromOperator fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style S3 fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff

    %% Container Images
    style ModelMeshImage fill:#7ed321,stroke:#333,stroke-width:2px
    style RESTProxyImage fill:#7ed321,stroke:#333,stroke-width:2px
    style AdapterImage fill:#7ed321,stroke:#333,stroke-width:2px
    style TritonImage fill:#50e3c2,stroke:#333,stroke-width:2px
    style MLServerImage fill:#50e3c2,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style OpenVINOImage fill:#50e3c2,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style TorchServeImage fill:#50e3c2,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    %% Service Mesh
    style Istio fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5

    %% Internal ODH
    style Dashboard fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style Pipelines fill:#9013fe,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    %% Monitoring
    style Prometheus fill:#f5a623,stroke:#333,stroke-width:2px
