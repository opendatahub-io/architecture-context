graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>(Go Operator)"]
        Webhook["Validating Webhook<br/>:9443/TCP HTTPS"]

        Controller -->|validates| Webhook
    end

    subgraph "Serving Runtime Pods"
        direction LR
        ModelMesh["ModelMesh<br/>(Java Service)<br/>Model Router"]
        RESTProxy["REST Proxy<br/>(Go Service)<br/>REST→gRPC"]
        RuntimeAdapter["Runtime Adapter/Puller<br/>(Go Service)<br/>Model Loader"]
        ModelServer["ML Framework<br/>(Triton/MLServer/<br/>OpenVINO/TorchServe)"]

        RESTProxy -->|:8033 gRPC| ModelMesh
        ModelMesh -->|UDS/8080 gRPC| RuntimeAdapter
        RuntimeAdapter -->|UDS/framework| ModelServer
    end

    subgraph "Custom Resources"
        PredictorCR["Predictor CR<br/>(serving.kserve.io/v1alpha1)"]
        ServingRuntimeCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
        ClusterServingRuntimeCR["ClusterServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
        InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)<br/>Optional"]
    end

    subgraph "External Dependencies"
        etcd["etcd Cluster<br/>:2379/TCP<br/>State & Coordination"]
        S3["S3 Storage<br/>:443/TCP HTTPS<br/>Model Artifacts"]
        K8sAPI["Kubernetes API<br/>:6443/TCP HTTPS"]
        Prometheus["Prometheus<br/>Metrics Collector"]
    end

    subgraph "Network Services"
        InferenceGRPC["gRPC Service<br/>:8033/TCP<br/>Optional mTLS"]
        InferenceREST["REST Service<br/>:8008/TCP<br/>Optional TLS"]
        MetricsService["Metrics Service<br/>:8443/TCP HTTPS<br/>OAuth Protected"]
    end

    %% User interactions
    User[User/CI Pipeline] -->|kubectl create| PredictorCR
    User -->|kubectl create| ServingRuntimeCR
    Admin[Administrator] -->|kubectl create| ClusterServingRuntimeCR
    User -->|kubectl create<br/>Optional| InferenceServiceCR

    %% Controller watches CRs
    PredictorCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    ClusterServingRuntimeCR -->|watched by| Controller
    InferenceServiceCR -.->|watched by<br/>if enabled| Controller

    %% Controller creates resources
    Controller -->|creates Deployment| ModelMesh
    Controller -->|creates Service| InferenceGRPC
    Controller -->|creates Service| InferenceREST
    Controller -->|creates Service| MetricsService

    %% External dependencies
    Controller -->|reconciles via| K8sAPI
    Controller -->|registers models| etcd
    ModelMesh -->|coordination| etcd
    RuntimeAdapter -->|downloads models| S3
    Prometheus -->|scrapes :8443| MetricsService
    Prometheus -->|scrapes :2112| ModelMesh

    %% Inference paths
    Client[External Client] -->|REST /v2/models/*/infer| InferenceREST
    Client -->|gRPC inference| InferenceGRPC
    InferenceREST -->|routes to| RESTProxy
    InferenceGRPC -->|routes to| ModelMesh

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style RESTProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimeAdapter fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelServer fill:#7ed321,stroke:#333,stroke-width:2px
    style PredictorCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style etcd fill:#e8e8e8,stroke:#666,stroke-width:2px
    style S3 fill:#e8e8e8,stroke:#666,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#666,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#666,stroke-width:2px
    style InferenceGRPC fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style InferenceREST fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style MetricsService fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
