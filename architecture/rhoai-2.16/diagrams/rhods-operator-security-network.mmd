graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Admin/User]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Routes)"]
        PrometheusRoute["Prometheus Route<br/>prometheus-{ns}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS Reencrypt<br/>OpenShift OAuth"]
        AlertmanagerRoute["Alertmanager Route<br/>alertmanager-{ns}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS Reencrypt<br/>OpenShift OAuth"]
    end

    subgraph K8sAPI["KUBERNETES API SERVER (Trust Boundary)"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB

        subgraph OperatorPod["RHODS Operator Pod<br/>SA: redhat-ods-operator-controller-manager"]
            DSCController[DSC Controller]
            DSCIController[DSCI Controller]
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>mTLS"]
            HealthEndpoints["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz /readyz"]
            MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>kube-rbac-proxy<br/>Bearer Token + SAR"]
        end
    end

    subgraph ManagedNS["MANAGED NAMESPACES"]
        direction TB

        subgraph AppsNS["redhat-ods-applications"]
            Dashboard[ODH Dashboard]
            Workbenches[Workbenches/Notebooks]
            DSP[Data Science Pipelines]
            KServe[KServe]
            ModelMesh[ModelMesh]
        end

        subgraph MonitoringNS["redhat-ods-monitoring"]
            Prometheus["Prometheus<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>SA: prometheus<br/>ClusterRole: cluster-monitoring-view"]
            Alertmanager["Alertmanager<br/>9093/TCP HTTP"]
            BlackboxExporter["Blackbox Exporter<br/>9115/TCP HTTP"]
        end

        subgraph IstioNS["istio-system"]
            SMCP[ServiceMeshControlPlane]
            SMM[ServiceMeshMember]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitRepos["Component Git Repositories<br/>github.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Registries["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2"]
    end

    %% External to API Server
    User -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"| APIServer

    %% Routes to Monitoring
    PrometheusRoute -->|"9091/TCP HTTPS<br/>TLS 1.2+"| Prometheus
    AlertmanagerRoute -->|"9093/TCP HTTP"| Alertmanager

    %% API Server to Webhook
    APIServer -->|"Admission Control<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>mTLS (API Server cert)"| WebhookServer

    %% Operator to API Server
    DSCController -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"| APIServer
    DSCIController -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"| APIServer
    WebhookServer -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"| APIServer

    %% API Server deploys components
    APIServer -.->|"Deploy/Manage"| Dashboard
    APIServer -.->|"Deploy/Manage"| Workbenches
    APIServer -.->|"Deploy/Manage"| DSP
    APIServer -.->|"Deploy/Manage"| KServe
    APIServer -.->|"Deploy/Manage"| ModelMesh
    APIServer -.->|"Deploy/Manage"| Prometheus
    APIServer -.->|"Deploy/Manage"| SMCP

    %% Prometheus to metrics
    Prometheus -->|"8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (Prometheus SA)"| MetricsEndpoint
    Prometheus -->|"HTTPS<br/>Bearer Token"| Dashboard
    Prometheus -->|"HTTPS<br/>Bearer Token"| KServe

    %% Operator to external services
    DSCController -.->|"443/TCP HTTPS<br/>TLS 1.2+<br/>Optional (devFlags)"| GitRepos
    OperatorPod -.->|"443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"| Registries

    %% OAuth integration
    PrometheusRoute -.->|"OAuth2<br/>443/TCP HTTPS"| OAuthServer
    AlertmanagerRoute -.->|"OAuth2<br/>443/TCP HTTPS"| OAuthServer

    %% Service Mesh
    DSCIController -->|"Creates"| SMCP
    DSCIController -->|"Creates"| SMM
    SMCP -.->|"mTLS STRICT"| KServe

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef managed fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class PrometheusRoute,AlertmanagerRoute ingress
    class APIServer k8sapi
    class OperatorPod,DSCController,DSCIController,WebhookServer,HealthEndpoints,MetricsEndpoint operator
    class Dashboard,Workbenches,DSP,KServe,ModelMesh,Prometheus,Alertmanager,BlackboxExporter,SMCP,SMM managed
    class GitRepos,Registries,OAuthServer externalservice
