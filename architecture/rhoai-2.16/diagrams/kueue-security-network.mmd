graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI System]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>User Credentials + SA Tokens"]
    end

    subgraph OpendatahubNS["NAMESPACE: opendatahub"]
        direction TB

        subgraph Controller["kueue-controller-manager Deployment"]
            direction TB
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>mTLS (K8s API Server)"]
            VisibilityServer["Visibility API Server<br/>8082/TCP HTTPS<br/>TLS 1.2+<br/>mTLS (APIService)"]
            MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA JWT)"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>No auth (kubelet)"]
        end

        WebhookSvc["Service: kueue-webhook-service<br/>ClusterIP 443→9443"]
        VisibilitySvc["Service: kueue-visibility-server<br/>ClusterIP 443→8082"]
        MetricsSvc["Service: kueue-metrics-service<br/>ClusterIP 8443→8443"]

        WebhookSvc -->|routes to| WebhookServer
        VisibilitySvc -->|routes to| VisibilityServer
        MetricsSvc -->|routes to| MetricsEndpoint

        Secrets["Secrets:<br/>kueue-webhook-server-cert (TLS)<br/>kueue-visibility-server-cert (TLS)"]
        Secrets -.->|provisions certs| WebhookServer
        Secrets -.->|provisions certs| VisibilityServer

        NetworkPolicy["NetworkPolicy: kueue-webhook-server<br/>Allow TCP/9443 from any"]
        NetworkPolicy -.->|protects| Controller
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        Autoscaler["cluster-autoscaler<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        Prometheus["Prometheus<br/>Metrics Collection<br/>Bearer Token"]
        CertManager["cert-manager (Optional)<br/>Certificate Provisioning"]
    end

    subgraph WatchedResources["WATCHED RESOURCES (via K8s API)"]
        direction LR
        BatchJobs["Batch Jobs"]
        KubeflowJobs["Kubeflow Jobs<br/>(PyTorch, TF, MPI, etc.)"]
        RayWorkloads["Ray Workloads<br/>(RayJob, RayCluster)"]
        JobSets["JobSets"]
        Pods["Pods"]
        KueueCRDs["Kueue CRDs<br/>(ClusterQueue, LocalQueue,<br/>Workload, etc.)"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User Credentials| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>mTLS<br/>Webhook Calls| WebhookSvc
    K8sAPI -->|HTTPS/8082<br/>mTLS<br/>APIService Aggregation| VisibilitySvc

    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch/Reconcile| K8sAPI
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>ProvisioningRequests| Autoscaler

    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MetricsSvc

    CertManager -.->|provisions| Secrets

    K8sAPI -.->|stores/watches| BatchJobs
    K8sAPI -.->|stores/watches| KubeflowJobs
    K8sAPI -.->|stores/watches| RayWorkloads
    K8sAPI -.->|stores/watches| JobSets
    K8sAPI -.->|stores/watches| Pods
    K8sAPI -.->|stores/watches| KueueCRDs

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef opendatahub fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef resources fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookServer,VisibilityServer,MetricsEndpoint,HealthProbes,WebhookSvc,VisibilitySvc,MetricsSvc,Secrets,NetworkPolicy opendatahub
    class Autoscaler,Prometheus,CertManager externalservice
    class BatchJobs,KubeflowJobs,RayWorkloads,JobSets,Pods,KueueCRDs resources
