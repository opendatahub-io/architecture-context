graph TD
    subgraph "Service Account"
        SA[kubeflow-training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kubeflow-training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kubeflow-training-operator<br/>ClusterRole]
    end

    subgraph "Aggregated User Roles"
        EditRole[kubeflow-training-edit<br/>Aggregates to: admin, edit]
        ViewRole[kubeflow-training-view<br/>Aggregates to: view]
    end

    subgraph "Core API Resources"
        Pods[core/pods<br/>+ pods/exec]
        Services[core/services]
        ConfigMaps[core/configmaps]
        Events[core/events]
        SAs[core/serviceaccounts]
    end

    subgraph "Training Job CRDs"
        PyTorch[kubeflow.org/pytorchjobs<br/>+ /status + /finalizers]
        TF[kubeflow.org/tfjobs<br/>+ /status + /finalizers]
        MPI[kubeflow.org/mpijobs<br/>+ /status + /finalizers]
        XGBoost[kubeflow.org/xgboostjobs<br/>+ /status + /finalizers]
        MXNet[kubeflow.org/mxjobs<br/>+ /status + /finalizers]
        Paddle[kubeflow.org/paddlejobs<br/>+ /status + /finalizers]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPG[scheduling.volcano.sh/podgroups]
        K8sPG[scheduling.x-k8s.io/podgroups]
    end

    subgraph "Autoscaling Resources"
        HPA[autoscaling/horizontalpodautoscalers]
    end

    subgraph "RBAC Resources"
        Roles[rbac.authorization.k8s.io/roles]
        RoleBindings[rbac.authorization.k8s.io/rolebindings]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR

    CR -->|create, delete, get, list, patch, update, watch| Pods
    CR -->|create| Pods
    CR -->|create, delete, get, list, watch| Services
    CR -->|create, list, update, watch| ConfigMaps
    CR -->|create, delete, get, list, patch, update, watch| Events
    CR -->|create, get, list, watch| SAs

    CR -->|create, delete, get, list, patch, update, watch| PyTorch
    CR -->|create, delete, get, list, patch, update, watch| TF
    CR -->|create, delete, get, list, patch, update, watch| MPI
    CR -->|create, delete, get, list, patch, update, watch| XGBoost
    CR -->|create, delete, get, list, patch, update, watch| MXNet
    CR -->|create, delete, get, list, patch, update, watch| Paddle

    CR -.->|create, delete, get, list, patch, update, watch<br/>Optional| VolcanoPG
    CR -.->|create, delete, get, list, patch, update, watch<br/>Optional| K8sPG

    CR -->|create, delete, get, list, patch, update, watch| HPA

    CR -->|create, list, update, watch| Roles
    CR -->|create, list, update, watch| RoleBindings

    EditRole -.->|Grants users full access| PyTorch
    EditRole -.->|Grants users full access| TF
    EditRole -.->|Grants users full access| MPI
    EditRole -.->|Grants users full access| XGBoost
    EditRole -.->|Grants users full access| MXNet
    EditRole -.->|Grants users full access| Paddle

    ViewRole -.->|Grants users read access| PyTorch
    ViewRole -.->|Grants users read access| TF
    ViewRole -.->|Grants users read access| MPI
    ViewRole -.->|Grants users read access| XGBoost
    ViewRole -.->|Grants users read access| MXNet
    ViewRole -.->|Grants users read access| Paddle

    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style EditRole fill:#7ed321,stroke:#333,stroke-width:2px
    style ViewRole fill:#7ed321,stroke:#333,stroke-width:2px

    style Pods fill:#85bbf0,stroke:#333
    style Services fill:#85bbf0,stroke:#333
    style ConfigMaps fill:#85bbf0,stroke:#333
    style Events fill:#85bbf0,stroke:#333
    style SAs fill:#85bbf0,stroke:#333

    style PyTorch fill:#ff9800,stroke:#333
    style TF fill:#ff9800,stroke:#333
    style MPI fill:#ff9800,stroke:#333
    style XGBoost fill:#ff9800,stroke:#333
    style MXNet fill:#ff9800,stroke:#333
    style Paddle fill:#ff9800,stroke:#333

    style VolcanoPG fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style K8sPG fill:#ccc,stroke:#333,stroke-dasharray: 5 5

    style HPA fill:#e1bee7,stroke:#333
    style Roles fill:#c5e1a5,stroke:#333
    style RoleBindings fill:#c5e1a5,stroke:#333
