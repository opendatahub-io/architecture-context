graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[webhook-service<br/>Service]
        Visibility[visibility-server<br/>APIService]
        Metrics[metrics-service<br/>Service]

        Controller -->|serves| Webhook
        Controller -->|serves| Visibility
        Controller -->|exposes| Metrics
    end

    subgraph "Custom Resources (CRDs)"
        ClusterQueue[ClusterQueue<br/>Cluster-wide queue]
        LocalQueue[LocalQueue<br/>Namespace queue]
        Workload[Workload<br/>Job abstraction]
        ResourceFlavor[ResourceFlavor<br/>Resource variants]
        WorkloadPriorityClass[WorkloadPriorityClass<br/>Priority levels]
        AdmissionCheck[AdmissionCheck<br/>Pre-admission checks]
        ProvisioningConfig[ProvisioningRequestConfig<br/>Autoscaler config]
        MultiKueueCluster[MultiKueueCluster<br/>Remote clusters]
        MultiKueueConfig[MultiKueueConfig<br/>Multi-cluster config]
    end

    subgraph "Watched Job Resources"
        BatchJob[Batch Job]
        PyTorchJob[PyTorchJob]
        TFJob[TFJob]
        MPIJob[MPIJob]
        RayJob[RayJob]
        RayCluster[RayCluster]
        JobSet[JobSet]
        Pod[Pod]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ClusterAutoscaler[cluster-autoscaler<br/>443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus<br/>Metrics collection]
    end

    subgraph "Internal ODH Integrations"
        TrainingOp[Kubeflow Training Operator]
        RayOp[Ray Operator]
        JobSetOp[JobSet Controller]
    end

    %% User interactions
    User[User/CI] -->|creates jobs| BatchJob
    User -->|creates| PyTorchJob
    User -->|creates| RayJob
    User -->|creates| JobSet

    %% Job watching
    BatchJob -->|watched by| Controller
    PyTorchJob -->|watched by| Controller
    TFJob -->|watched by| Controller
    MPIJob -->|watched by| Controller
    RayJob -->|watched by| Controller
    RayCluster -->|watched by| Controller
    JobSet -->|watched by| Controller
    Pod -->|watched by| Controller

    %% Webhook flow
    K8sAPI -->|calls| Webhook
    Webhook -->|validates/mutates| BatchJob
    Webhook -->|validates/mutates| PyTorchJob

    %% CRD management
    Controller -->|reconciles| ClusterQueue
    Controller -->|reconciles| LocalQueue
    Controller -->|manages| Workload
    Controller -->|uses| ResourceFlavor
    Controller -->|uses| WorkloadPriorityClass
    Controller -->|executes| AdmissionCheck

    %% External dependencies
    Controller -->|API calls| K8sAPI
    Controller -->|creates ProvisioningRequests| ClusterAutoscaler
    CertManager -.->|provisions certs| Webhook
    Prometheus -->|scrapes| Metrics

    %% Internal integrations
    TrainingOp -->|provides| PyTorchJob
    TrainingOp -->|provides| TFJob
    TrainingOp -->|provides| MPIJob
    RayOp -->|provides| RayJob
    RayOp -->|provides| RayCluster
    JobSetOp -->|provides| JobSet

    %% Multi-cluster
    Controller -->|uses| MultiKueueCluster
    Controller -->|uses| MultiKueueConfig

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333
    style Visibility fill:#4a90e2,stroke:#333
    style Metrics fill:#4a90e2,stroke:#333
    style ClusterQueue fill:#f5a623,stroke:#333
    style LocalQueue fill:#f5a623,stroke:#333
    style Workload fill:#f5a623,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style ClusterAutoscaler fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style TrainingOp fill:#7ed321,stroke:#333
    style RayOp fill:#7ed321,stroke:#333
    style JobSetOp fill:#7ed321,stroke:#333
