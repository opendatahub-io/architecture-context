graph TB
    subgraph "Service Accounts"
        SA1[odh-model-controller<br/>Namespace: opendatahub]
        SA2[prometheus-custom<br/>Namespace: openshift-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-role-binding<br/>ClusterRoleBinding]
        CRB2[auth-delegator<br/>RoleBinding]
    end

    subgraph "Namespace Role Bindings"
        RB1[odh-model-controller-leader-election-rolebinding<br/>RoleBinding - opendatahub]
        RB2[prometheus-ns-access<br/>RoleBinding - per InferenceService NS]
    end

    subgraph "ClusterRoles"
        CR1[odh-model-controller-role]
        CR2[odh-model-controller-leader-election-role]
        CR3[prometheus-ns-access]
        CR4[system:auth-delegator]
    end

    subgraph "API Resources - Core"
        R1[configmaps<br/>secrets<br/>serviceaccounts<br/>namespaces<br/>pods<br/>endpoints<br/>services]
    end

    subgraph "API Resources - KServe"
        R2[inferenceservices<br/>inferenceservices/finalizers<br/>servingruntimes<br/>servingruntimes/finalizers<br/>serving.kserve.io]
    end

    subgraph "API Resources - Istio"
        R3[virtualservices<br/>virtualservices/finalizers<br/>gateways<br/>networking.istio.io]
        R4[peerauthentications<br/>authorizationpolicies<br/>security.istio.io]
        R5[telemetries<br/>telemetry.istio.io]
    end

    subgraph "API Resources - Service Mesh"
        R6[servicemeshmembers<br/>servicemeshmemberrolls<br/>servicemeshcontrolplanes<br/>maistra.io]
    end

    subgraph "API Resources - OpenShift"
        R7[routes<br/>routes/custom-host<br/>route.openshift.io]
        R8[templates<br/>template.openshift.io]
    end

    subgraph "API Resources - Networking"
        R9[networkpolicies<br/>ingresses<br/>networking.k8s.io]
    end

    subgraph "API Resources - RBAC"
        R10[clusterrolebindings<br/>rolebindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - Monitoring"
        R11[servicemonitors<br/>podmonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - Authorino"
        R12[authconfigs<br/>authorino.kuadrant.io]
    end

    subgraph "API Resources - ODH"
        R13[datascienceclusters<br/>datasciencecluster.opendatahub.io]
        R14[dscinitializations<br/>dscinitialization.opendatahub.io]
        R15[accounts<br/>accounts/status<br/>accounts/finalizers<br/>nim.opendatahub.io]
    end

    subgraph "API Resources - Leader Election"
        R16[leases<br/>coordination.k8s.io]
        R17[events<br/>core]
    end

    subgraph "API Resources - Prometheus"
        R18[services<br/>endpoints<br/>pods<br/>core - read only]
    end

    %% Service Account to Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| RB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    RB1 -->|grants| CR2
    RB2 -->|grants| CR3
    CRB2 -->|grants| CR4

    %% Roles to Resources (Main Controller)
    CR1 -->|create,delete,get,list,patch,update,watch| R1
    CR1 -->|get,list,update,watch| R2
    CR1 -->|create,delete,get,list,patch,update,watch| R3
    CR1 -->|create,delete,get,list,patch,update,watch| R4
    CR1 -->|create,delete,get,list,patch,update,watch| R5
    CR1 -->|create,delete,get,list,patch,update,watch,use| R6
    CR1 -->|create,delete,get,list,patch,update,watch| R7
    CR1 -->|create,delete,get,list,update,watch| R8
    CR1 -->|create,delete,get,list,patch,update,watch| R9
    CR1 -->|create,delete,get,list,patch,update,watch| R10
    CR1 -->|create,delete,get,list,patch,update,watch| R11
    CR1 -->|create,delete,get,list,patch,update,watch| R12
    CR1 -->|get,list,watch| R13
    CR1 -->|get,list,watch| R14
    CR1 -->|get,list,update,watch| R15

    %% Leader Election Role
    CR2 -->|get,list,watch,create,update,patch,delete| R16
    CR2 -->|create,patch| R17
    CR2 -->|get,list,watch,create,update,patch,delete| R1

    %% Prometheus Role
    CR3 -->|get,list,watch| R18

