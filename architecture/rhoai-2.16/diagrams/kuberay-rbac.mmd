graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
        LeaderElection[leader-election-role-binding<br/>RoleBinding]
    end

    subgraph "Roles"
        CR[kuberay-operator<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "API Resources - ray.io"
        RayClusterRes[RayCluster<br/>rayclusters]
        RayJobRes[RayJob<br/>rayjobs]
        RayServiceRes[RayService<br/>rayservices]
        RayClusterFinalizers[rayclusters/finalizers]
        RayJobFinalizers[rayjobs/finalizers]
        RayServiceFinalizers[rayservices/finalizers]
        RayClusterStatus[rayclusters/status]
        RayJobStatus[rayjobs/status]
        RayServiceStatus[rayservices/status]
    end

    subgraph "API Resources - Core (v1)"
        Pods[Pods]
        Services[Services]
        ServiceAccounts[ServiceAccounts]
        Events[Events]
        PodStatus[pods/status]
        Endpoints[Endpoints]
    end

    subgraph "API Resources - Batch"
        Jobs[Jobs<br/>batch/v1]
    end

    subgraph "API Resources - Networking"
        Ingresses[Ingresses<br/>networking.k8s.io]
        IngressClasses[IngressClasses<br/>networking.k8s.io]
    end

    subgraph "API Resources - RBAC"
        Roles[Roles<br/>rbac.authorization.k8s.io]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - Coordination"
        Leases[Leases<br/>coordination.k8s.io]
    end

    subgraph "API Resources - OpenShift"
        Routes[Routes<br/>route.openshift.io]
    end

    subgraph "SecurityContextConstraints"
        SCC[run-as-ray-user<br/>RunAsUser: 1000<br/>Privileged: No<br/>Capabilities: DROP ALL]
    end

    %% Service Account bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderElection
    CRB -->|grants| CR
    LeaderElection -->|grants| LeaderRole

    %% ClusterRole permissions - ray.io
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayClusterRes
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayJobRes
    CR -->|create, delete, get, list,<br/>patch, update, watch| RayServiceRes
    CR -->|update| RayClusterFinalizers
    CR -->|update| RayJobFinalizers
    CR -->|update| RayServiceFinalizers
    CR -->|get, patch, update| RayClusterStatus
    CR -->|get, patch, update| RayJobStatus
    CR -->|get, patch, update| RayServiceStatus

    %% ClusterRole permissions - core
    CR -->|create, delete, get, list,<br/>patch, update, watch| Pods
    CR -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts
    CR -->|create, delete, get, list,<br/>patch, update, watch| Events
    CR -->|create, delete, get, list,<br/>patch, update, watch| PodStatus
    CR -->|get, list| Endpoints

    %% ClusterRole permissions - batch
    CR -->|create, delete, get, list,<br/>patch, update, watch| Jobs

    %% ClusterRole permissions - networking
    CR -->|create, delete, get, list,<br/>patch, update, watch| Ingresses
    CR -->|get, list, watch| IngressClasses

    %% ClusterRole permissions - RBAC
    CR -->|create, delete, get, list,<br/>update, watch| Roles
    CR -->|create, delete, get, list,<br/>update, watch| RoleBindings

    %% ClusterRole permissions - coordination
    LeaderRole -->|create, get, list, update| Leases

    %% ClusterRole permissions - OpenShift
    CR -->|create, delete, get, list,<br/>patch, update, watch| Routes

    %% SCC assignment
    SCC -.->|applies to| SA

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB fill:#e8e8e8,stroke:#333,stroke-width:1px
    style LeaderElection fill:#e8e8e8,stroke:#333,stroke-width:1px

    style RayClusterRes fill:#7ed321,stroke:#333,color:#000
    style RayJobRes fill:#7ed321,stroke:#333,color:#000
    style RayServiceRes fill:#7ed321,stroke:#333,color:#000
    style RayClusterFinalizers fill:#b8e986,stroke:#333,color:#000
    style RayJobFinalizers fill:#b8e986,stroke:#333,color:#000
    style RayServiceFinalizers fill:#b8e986,stroke:#333,color:#000
    style RayClusterStatus fill:#b8e986,stroke:#333,color:#000
    style RayJobStatus fill:#b8e986,stroke:#333,color:#000
    style RayServiceStatus fill:#b8e986,stroke:#333,color:#000

    style Pods fill:#7ed321,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style ServiceAccounts fill:#7ed321,stroke:#333,color:#000
    style Events fill:#7ed321,stroke:#333,color:#000
    style PodStatus fill:#b8e986,stroke:#333,color:#000
    style Endpoints fill:#b8e986,stroke:#333,color:#000

    style Jobs fill:#7ed321,stroke:#333,color:#000
    style Ingresses fill:#7ed321,stroke:#333,color:#000
    style IngressClasses fill:#b8e986,stroke:#333,color:#000
    style Roles fill:#7ed321,stroke:#333,color:#000
    style RoleBindings fill:#7ed321,stroke:#333,color:#000
    style Leases fill:#7ed321,stroke:#333,color:#000
    style Routes fill:#ee0000,stroke:#333,color:#fff

    style SCC fill:#d73a49,stroke:#333,stroke-width:2px,color:#fff
