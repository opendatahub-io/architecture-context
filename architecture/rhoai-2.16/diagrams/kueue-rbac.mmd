graph TD
    subgraph "Service Account"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kueue-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kueue-metrics-auth-rolebinding<br/>RoleBinding]
        CRB3[kueue-leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole: kueue-manager-role"
        direction TB
        CR[kueue-manager-role]

        subgraph "Core Resources"
            Events[events<br/>create, patch, update, watch]
            Pods[pods, pods/finalizers, pods/status<br/>delete, get, list, patch, update, watch]
            Secrets[secrets<br/>get, list, update, watch]
            Namespaces[limitranges, namespaces<br/>get, list, watch]
        end

        subgraph "Batch Jobs"
            Jobs[jobs, jobs/finalizers, jobs/status<br/>get, list, patch, update, watch]
        end

        subgraph "Kueue CRDs"
            ClusterQueue[clusterqueues, clusterqueues/status<br/>create, delete, get, list, patch, update, watch]
            LocalQueue[localqueues, localqueues/status<br/>create, delete, get, list, patch, update, watch]
            Workload[workloads, workloads/status<br/>create, delete, get, list, patch, update, watch]
            AdmissionCheck[admissionchecks, admissionchecks/status<br/>create, delete, get, list, patch, update, watch]
            ResourceFlavor[resourceflavors<br/>delete, get, list, update, watch]
            PriorityClass[workloadpriorityclasses<br/>get, list, watch]
            ProvisioningConfig[provisioningrequestconfigs<br/>get, list, watch]
            MultiKueue[multikueueclusters, multikueueconfigs<br/>get, list, watch]
        end

        subgraph "Kubeflow Training Jobs"
            KubeflowJobs[mpijobs, pytorchjobs, tfjobs,<br/>xgboostjobs, mxjobs, paddlejobs<br/>+finalizers +status<br/>get, list, patch, update, watch]
        end

        subgraph "Ray Workloads"
            RayJobs[rayjobs, rayclusters<br/>+finalizers +status<br/>get, list, patch, update, watch]
        end

        subgraph "JobSet"
            JobSets[jobsets, jobsets/finalizers, jobsets/status<br/>get, list, patch, update, watch]
        end

        subgraph "Autoscaling"
            ProvisioningRequests[provisioningrequests<br/>provisioningrequests/status<br/>create, delete, get, list, patch, update, watch]
        end

        subgraph "Admission & Scheduling"
            Webhooks[mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>get, list, update, watch]
            Scheduling[priorityclasses, runtimeclasses<br/>get, list, watch]
            FlowControl[flowschemas, prioritylevelconfigurations<br/>flowschemas/status<br/>list, watch, patch]
        end

        CR -.-> Events
        CR -.-> Pods
        CR -.-> Secrets
        CR -.-> Namespaces
        CR -.-> Jobs
        CR -.-> ClusterQueue
        CR -.-> LocalQueue
        CR -.-> Workload
        CR -.-> AdmissionCheck
        CR -.-> ResourceFlavor
        CR -.-> PriorityClass
        CR -.-> ProvisioningConfig
        CR -.-> MultiKueue
        CR -.-> KubeflowJobs
        CR -.-> RayJobs
        CR -.-> JobSets
        CR -.-> ProvisioningRequests
        CR -.-> Webhooks
        CR -.-> Scheduling
        CR -.-> FlowControl
    end

    subgraph "User-Facing Roles (for namespace admins)"
        direction TB
        BatchAdmin[kueue-batch-admin-role<br/>ClusterRole]
        BatchUser[kueue-batch-user-role<br/>ClusterRole]
        CQEditor[kueue-clusterqueue-editor-role<br/>ClusterRole]
        CQViewer[kueue-clusterqueue-viewer-role<br/>ClusterRole]
        LQEditor[kueue-localqueue-editor-role<br/>ClusterRole]
        LQViewer[kueue-localqueue-viewer-role<br/>ClusterRole]
        WLEditor[kueue-workload-editor-role<br/>ClusterRole]
        WLViewer[kueue-workload-viewer-role<br/>ClusterRole]
        MetricsReader[kueue-metrics-reader-role<br/>ClusterRole]
    end

    subgraph "API Resources"
        direction LR
        KueueAPIs[Kueue APIs<br/>kueue.x-k8s.io]
        BatchAPIs[Batch APIs<br/>batch/v1]
        CoreAPIs[Core APIs<br/>v1]
        KubeflowAPIs[Kubeflow APIs<br/>kubeflow.org]
        RayAPIs[Ray APIs<br/>ray.io]
        JobSetAPIs[JobSet APIs<br/>jobset.x-k8s.io]
        AutoscalingAPIs[Autoscaling APIs<br/>autoscaling.x-k8s.io]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    CRB1 -->|grants| CR
    CRB2 -.->|grants metrics access| MetricsReader
    CRB3 -.->|grants leader election| SA

    %% Permissions
    CR -->|full CRUD| KueueAPIs
    CR -->|watch/patch| BatchAPIs
    CR -->|watch/manage| CoreAPIs
    CR -->|watch/patch| KubeflowAPIs
    CR -->|watch/patch| RayAPIs
    CR -->|watch/patch| JobSetAPIs
    CR -->|create/manage| AutoscalingAPIs

    %% User roles
    BatchAdmin -.->|manage| BatchAPIs
    BatchUser -.->|create/view| BatchAPIs
    CQEditor -.->|manage| KueueAPIs
    CQViewer -.->|view| KueueAPIs
    LQEditor -.->|manage namespace queues| KueueAPIs
    LQViewer -.->|view namespace queues| KueueAPIs
    WLEditor -.->|manage workloads| KueueAPIs
    WLViewer -.->|view workloads| KueueAPIs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#7ed321,stroke:#333
    style CRB2 fill:#7ed321,stroke:#333
    style CRB3 fill:#7ed321,stroke:#333
    style Events fill:#dae8fc,stroke:#6c8ebf
    style Pods fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#dae8fc,stroke:#6c8ebf
    style Jobs fill:#dae8fc,stroke:#6c8ebf
    style ClusterQueue fill:#dae8fc,stroke:#6c8ebf
    style LocalQueue fill:#dae8fc,stroke:#6c8ebf
    style Workload fill:#dae8fc,stroke:#6c8ebf
    style KubeflowJobs fill:#dae8fc,stroke:#6c8ebf
    style RayJobs fill:#dae8fc,stroke:#6c8ebf
    style JobSets fill:#dae8fc,stroke:#6c8ebf
    style ProvisioningRequests fill:#dae8fc,stroke:#6c8ebf
    style KueueAPIs fill:#fff2cc,stroke:#d6b656
    style BatchAPIs fill:#fff2cc,stroke:#d6b656
    style CoreAPIs fill:#fff2cc,stroke:#d6b656
    style KubeflowAPIs fill:#fff2cc,stroke:#d6b656
    style RayAPIs fill:#fff2cc,stroke:#d6b656
    style JobSetAPIs fill:#fff2cc,stroke:#d6b656
    style AutoscalingAPIs fill:#fff2cc,stroke:#d6b656
