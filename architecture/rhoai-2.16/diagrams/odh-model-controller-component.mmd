graph TB
    subgraph "ODH Model Controller"
        MainController[InferenceService Controller]

        subgraph "Mode-Specific Reconcilers"
            MMReconciler[ModelMesh Reconciler]
            KSServerless[KServe Serverless Reconciler]
            KSRaw[KServe Raw Reconciler]
        end

        subgraph "Supporting Controllers"
            NIMController[NIM Account Controller]
            StorageController[Storage Secret Controller]
            CAController[Custom CA Cert Controller]
            MonitoringController[Monitoring Controller]
            MRController[Model Registry Controller]
        end

        subgraph "Webhooks"
            KnativeWebhook[Knative Service Webhook<br/>9443/TCP HTTPS]
            NIMWebhook[NIM Account Webhook<br/>9443/TCP HTTPS]
        end

        subgraph "Observability"
            Metrics[Metrics Endpoint<br/>8080/TCP HTTP]
            Health[Health Probes<br/>8081/TCP HTTP]
        end
    end

    subgraph "Custom Resources (Watched)"
        ISCR[InferenceService CR<br/>serving.kserve.io]
        NIMCR[NIM Account CR<br/>nim.opendatahub.io]
        DSCR[DataScienceCluster CR]
        DSCICR[DSCInitialization CR]
    end

    subgraph "Resources Created"
        Routes[OpenShift Routes]
        Gateway[Istio Gateways]
        VirtualService[Istio VirtualServices]
        AuthConfig[Authorino AuthConfigs]
        NetworkPolicy[NetworkPolicies]
        PeerAuth[PeerAuthentications]
        SMMember[ServiceMeshMembers]
        Templates[NIM Templates]
        Secrets[Secrets & ConfigMaps]
        RoleBindings[RoleBindings for Prometheus]
    end

    subgraph "External Dependencies"
        KServe[KServe 0.12.1]
        Istio[Istio 1.21.5]
        Knative[Knative Serving 0.39.3]
        Authorino[Authorino 0.15.0]
        ModelMesh[ModelMesh]
        NGCAPI[NGC API<br/>nvcr.io]
    end

    %% Main Controller Flow
    ISCR -->|watched by| MainController
    MainController -->|delegates| MMReconciler
    MainController -->|delegates| KSServerless
    MainController -->|delegates| KSRaw

    %% Mode-Specific Actions
    MMReconciler -->|creates| Routes
    KSServerless -->|creates| Gateway
    KSServerless -->|creates| VirtualService
    KSServerless -->|creates| AuthConfig
    KSServerless -->|creates| NetworkPolicy
    KSServerless -->|creates| PeerAuth
    KSRaw -->|creates| Routes

    %% Supporting Controllers
    NIMCR -->|watched by| NIMController
    NIMController -->|creates| Templates
    NIMController -->|creates| Secrets
    NIMController -->|validates with| NGCAPI
    StorageController -->|aggregates| Secrets
    MonitoringController -->|creates| RoleBindings

    %% Service Mesh
    KSServerless -->|creates| SMMember
    DSCR -->|config read by| MainController
    DSCICR -->|config read by| MainController

    %% Webhooks
    KnativeWebhook -.->|validates| Knative
    NIMWebhook -.->|validates| NIMCR

    %% External Integration
    MainController -->|depends on| KServe
    KSServerless -->|depends on| Istio
    KSServerless -->|depends on| Knative
    KSServerless -->|depends on| Authorino
    MMReconciler -->|depends on| ModelMesh

    style MainController fill:#4a90e2,stroke:#333,stroke-width:3px
    style ISCR fill:#f5a623,stroke:#333
    style NIMCR fill:#f5a623,stroke:#333
    style KServe fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style Knative fill:#999,stroke:#333
    style Authorino fill:#999,stroke:#333
    style NGCAPI fill:#e74c3c,stroke:#333
