graph TD
    subgraph "Service Account"
        SA[notebook-controller-service-account<br/>Namespace: notebook-controller-system]
    end

    subgraph "Cluster-wide Permissions"
        CRB1[ClusterRoleBinding:<br/>notebook-controller-role-binding]
        CR1[ClusterRole:<br/>notebook-controller-role]
    end

    subgraph "Namespace-scoped Permissions"
        RB1[RoleBinding:<br/>notebook-controller-leader-election-role-binding<br/>Namespace: notebook-controller-system]
        R1[Role:<br/>notebook-controller-leader-election-role]
    end

    subgraph "User-facing Aggregated Roles"
        CR_Edit[ClusterRole:<br/>kubeflow-notebooks-edit]
        CR_View[ClusterRole:<br/>kubeflow-notebooks-view]
        CR_Admin[ClusterRole:<br/>kubeflow-notebooks-admin<br/>aggregates edit]
    end

    subgraph "API Resources - Core"
        Events[core/events<br/>create, get, list, patch, watch]
        Pods[core/pods<br/>delete, get, list, watch]
        Services[core/services<br/>* all verbs]
        ConfigMaps[core/configmaps<br/>get, list, watch, create, update, patch, delete]
    end

    subgraph "API Resources - Apps"
        StatefulSets[apps/statefulsets<br/>* all verbs]
    end

    subgraph "API Resources - Kubeflow"
        Notebooks[kubeflow.org/notebooks<br/>* all verbs]
        NotebooksFinalizers[kubeflow.org/notebooks/finalizers<br/>* all verbs]
        NotebooksStatus[kubeflow.org/notebooks/status<br/>* all verbs]
    end

    subgraph "API Resources - Istio"
        VirtualServices[networking.istio.io/virtualservices<br/>* all verbs]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| RB1

    %% ClusterRole bindings
    CRB1 -->|grants| CR1
    RB1 -->|grants| R1

    %% ClusterRole permissions
    CR1 -->|permissions| Events
    CR1 -->|permissions| Pods
    CR1 -->|permissions| Services
    CR1 -->|permissions| StatefulSets
    CR1 -->|permissions| Notebooks
    CR1 -->|permissions| NotebooksFinalizers
    CR1 -->|permissions| NotebooksStatus
    CR1 -->|permissions| VirtualServices

    %% Leader election role permissions
    R1 -->|permissions| ConfigMaps
    R1 -->|permissions| Events

    %% User-facing role permissions
    CR_Edit -->|get, list, watch,<br/>create, delete,<br/>deletecollection,<br/>patch, update| Notebooks
    CR_Edit -->|get, list, watch,<br/>create, delete,<br/>deletecollection,<br/>patch, update| NotebooksStatus
    CR_View -->|get, list, watch| Notebooks
    CR_View -->|get, list, watch| NotebooksStatus
    CR_Admin -.->|aggregates| CR_Edit

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#d0d0d0,stroke:#333,stroke-width:2px
    style RB1 fill:#d0d0d0,stroke:#333,stroke-width:2px
    style CR_Edit fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_View fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_Admin fill:#7ed321,stroke:#333,stroke-width:2px
    style Events fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Pods fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Services fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ConfigMaps fill:#e8e8e8,stroke:#333,stroke-width:1px
    style StatefulSets fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Notebooks fill:#e8e8e8,stroke:#333,stroke-width:1px
    style NotebooksFinalizers fill:#e8e8e8,stroke:#333,stroke-width:1px
    style NotebooksStatus fill:#e8e8e8,stroke:#333,stroke-width:1px
    style VirtualServices fill:#e8e8e8,stroke:#333,stroke-width:1px
