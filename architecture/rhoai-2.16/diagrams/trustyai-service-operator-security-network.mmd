graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS - DMZ - OpenShift Only"]
        Route["OpenShift Route<br/>{instance-name}<br/>443 TCP to 8443 TCP<br/>TLS 1.2+ edge re-encrypt"]
    end

    subgraph ServiceMesh["SERVICE MESH - INTERNAL SERVICES"]
        direction TB

        subgraph NS_TrustyAI["Namespace: trustyai-namespace"]
            OAuthProxy["OAuth Proxy Sidecar<br/>SA: instance-name-sa<br/>8443 TCP HTTPS<br/>Secret: instance-name-tls"]
            TrustyAI["TrustyAI Service<br/>Quarkus Application<br/>SA: instance-name-sa<br/>8080 TCP HTTP<br/>80 TCP metrics"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            ModelMesh["ModelMesh Deployment<br/>Patched by TrustyAI Operator<br/>Sends inference payloads"]
        end

        subgraph Storage["Storage Options"]
            Database["Database<br/>PostgreSQL or MySQL<br/>Variable TCP JDBC<br/>TLS 1.2+ optional<br/>User and Password"]
            PVC["PersistentVolumeClaim<br/>File Storage<br/>CSV or structured files"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: operator-namespace"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>8081 TCP HTTP<br/>ClusterRole: manager-role"]
        K8sAPI["Kubernetes API Server<br/>6443 TCP HTTPS<br/>ServiceAccount Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
        ServiceMonitor["ServiceMonitor<br/>Auto-created by operator"]
    end

    subgraph LMEval["LMEVAL JOB EXECUTION"]
        direction TB
        LMEvalPod["LMEvalJob Pod<br/>Namespace: job-namespace<br/>SA: job-sa<br/>Init: Driver<br/>Main: Evaluation"]
        LMEvalPVC["PVC Storage<br/>Results"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["Hugging Face Hub<br/>huggingface.co<br/>443 TCP HTTPS TLS1.2+<br/>API Token optional"]
    end

    %% Flows
    Client -->|"HTTPS 443<br/>TLS 1.2+<br/>No Auth"| Route
    Route -->|"HTTPS 8443<br/>TLS 1.2+ re-encrypt<br/>OAuth Bearer Token"| OAuthProxy
    OAuthProxy -->|"HTTP 8080<br/>No encryption<br/>Validated OAuth"| TrustyAI
    TrustyAI -->|"JDBC or File Storage<br/>TLS 1.2+ for DB<br/>Username and Password"| Database
    TrustyAI -.->|"Alternative"| PVC

    ModelMesh -->|"HTTPS 443<br/>mTLS service mesh<br/>Service Identity"| TrustyAI

    Prometheus -->|"HTTP 80<br/>No encryption<br/>No auth"| TrustyAI
    ServiceMonitor -.->|"configures"| Prometheus

    Operator -->|"HTTPS 6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Operator -.->|"creates and manages"| TrustyAI
    Operator -.->|"creates"| OAuthProxy
    Operator -.->|"patches"| ModelMesh
    Operator -.->|"creates"| ServiceMonitor
    Operator -.->|"creates"| LMEvalPod

    LMEvalPod -->|"HTTPS 443<br/>TLS 1.2+<br/>API Token"| HuggingFace
    LMEvalPod -->|"File Storage"| LMEvalPVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class OAuthProxy,TrustyAI,ModelMesh,Database,PVC servicemesh
    class Operator,K8sAPI operator
    class Prometheus,ServiceMonitor monitoring
    class LMEvalPod,LMEvalPVC operator
    class HuggingFace externalservice
