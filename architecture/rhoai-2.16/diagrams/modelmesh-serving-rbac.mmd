graph TD
    subgraph "Service Accounts"
        SA_Controller["ServiceAccount:<br/>modelmesh-controller<br/>(controller namespace)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller["ClusterRoleBinding:<br/>modelmesh-controller-rolebinding"]
        CRB_LeaderElection["RoleBinding:<br/>leader-election-rolebinding<br/>(controller namespace)"]
    end

    subgraph "ClusterRoles"
        CR_Controller["ClusterRole:<br/>modelmesh-controller-role"]
        CR_LeaderElection["Role:<br/>leader-election-role"]
        CR_PredictorEditor["ClusterRole:<br/>predictor-editor-role"]
        CR_PredictorViewer["ClusterRole:<br/>predictor-viewer-role"]
        CR_RuntimeEditor["ClusterRole:<br/>servingruntime-editor-role"]
        CR_RuntimeViewer["ClusterRole:<br/>servingruntime-viewer-role"]
    end

    subgraph "API Resources - Core"
        R_ConfigMaps["Resource: configmaps<br/>API: core/v1"]
        R_Secrets["Resource: secrets<br/>API: core/v1"]
        R_Services["Resource: services<br/>API: core/v1"]
        R_Namespaces["Resource: namespaces<br/>API: core/v1"]
        R_Endpoints["Resource: endpoints<br/>API: core/v1"]
        R_PVCs["Resource: persistentvolumeclaims<br/>API: core/v1"]
    end

    subgraph "API Resources - Apps"
        R_Deployments["Resource: deployments<br/>API: apps/v1"]
    end

    subgraph "API Resources - Serving"
        R_Predictors["Resource: predictors<br/>API: serving.kserve.io/v1alpha1"]
        R_PredictorsStatus["Resource: predictors/status<br/>API: serving.kserve.io/v1alpha1"]
        R_PredictorsFinalizers["Resource: predictors/finalizers<br/>API: serving.kserve.io/v1alpha1"]

        R_ServingRuntimes["Resource: servingruntimes<br/>API: serving.kserve.io/v1alpha1"]
        R_ServingRuntimesStatus["Resource: servingruntimes/status<br/>API: serving.kserve.io/v1alpha1"]
        R_ServingRuntimesFinalizers["Resource: servingruntimes/finalizers<br/>API: serving.kserve.io/v1alpha1"]

        R_ClusterServingRuntimes["Resource: clusterservingruntimes<br/>API: serving.kserve.io/v1alpha1"]
        R_ClusterServingRuntimesStatus["Resource: clusterservingruntimes/status<br/>API: serving.kserve.io/v1alpha1"]
        R_ClusterServingRuntimesFinalizers["Resource: clusterservingruntimes/finalizers<br/>API: serving.kserve.io/v1alpha1"]

        R_InferenceServices["Resource: inferenceservices<br/>API: serving.kserve.io/v1beta1"]
        R_InferenceServicesStatus["Resource: inferenceservices/status<br/>API: serving.kserve.io/v1beta1"]
        R_InferenceServicesFinalizers["Resource: inferenceservices/finalizers<br/>API: serving.kserve.io/v1beta1"]
    end

    subgraph "API Resources - Autoscaling"
        R_HPAs["Resource: horizontalpodautoscalers<br/>API: autoscaling/v2"]
    end

    subgraph "API Resources - Monitoring"
        R_ServiceMonitors["Resource: servicemonitors<br/>API: monitoring.coreos.com/v1"]
    end

    subgraph "API Resources - Coordination"
        R_Leases["Resource: leases<br/>API: coordination.k8s.io/v1"]
    end

    %% Service Account to ClusterRoleBindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection

    %% ClusterRoleBindings to ClusterRoles
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection

    %% modelmesh-controller-role permissions - Core
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_ConfigMaps
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_Secrets
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_Services
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_Namespaces
    CR_Controller -->|get, list, watch| R_Endpoints
    CR_Controller -->|get, list, watch| R_PVCs

    %% modelmesh-controller-role permissions - Apps
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_Deployments

    %% modelmesh-controller-role permissions - Serving
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_Predictors
    CR_Controller -->|get, patch, update| R_PredictorsStatus
    CR_Controller -->|get, patch, update| R_PredictorsFinalizers

    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_ServingRuntimes
    CR_Controller -->|get, patch, update| R_ServingRuntimesStatus
    CR_Controller -->|get, patch, update| R_ServingRuntimesFinalizers

    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_ClusterServingRuntimes
    CR_Controller -->|get, patch, update| R_ClusterServingRuntimesStatus
    CR_Controller -->|get, patch, update| R_ClusterServingRuntimesFinalizers

    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_InferenceServices
    CR_Controller -->|get, patch, update| R_InferenceServicesStatus
    CR_Controller -->|get, patch, update| R_InferenceServicesFinalizers

    %% modelmesh-controller-role permissions - Autoscaling
    CR_Controller -->|create, delete, get,<br/>list, watch, update| R_HPAs

    %% modelmesh-controller-role permissions - Monitoring
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| R_ServiceMonitors

    %% leader-election-role permissions
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| R_ConfigMaps
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| R_Leases

    %% User-facing editor/viewer roles
    CR_PredictorEditor -->|create, delete, get,<br/>list, patch, update, watch| R_Predictors
    CR_PredictorViewer -->|get, list, watch| R_Predictors

    CR_RuntimeEditor -->|create, delete, get,<br/>list, patch, update, watch| R_ServingRuntimes
    CR_RuntimeViewer -->|get, list, watch| R_ServingRuntimes

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style CRB_Controller fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px

    style CR_Controller fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_PredictorEditor fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style CR_PredictorViewer fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style CR_RuntimeEditor fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style CR_RuntimeViewer fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    style R_ConfigMaps fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_Secrets fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_Services fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_Namespaces fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_Endpoints fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_PVCs fill:#e8e8e8,stroke:#666,stroke-width:1px
    style R_Deployments fill:#e8e8e8,stroke:#666,stroke-width:1px

    style R_Predictors fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style R_PredictorsStatus fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_PredictorsFinalizers fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_ServingRuntimes fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style R_ServingRuntimesStatus fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_ServingRuntimesFinalizers fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_ClusterServingRuntimes fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style R_ClusterServingRuntimesStatus fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_ClusterServingRuntimesFinalizers fill:#bd10e0,stroke:#333,stroke-width:1px,color:#fff
    style R_InferenceServices fill:#bd10e0,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style R_InferenceServicesStatus fill:#bd10e0,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style R_InferenceServicesFinalizers fill:#bd10e0,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    style R_HPAs fill:#50e3c2,stroke:#333,stroke-width:1px
    style R_ServiceMonitors fill:#50e3c2,stroke:#333,stroke-width:1px
    style R_Leases fill:#50e3c2,stroke:#333,stroke-width:1px
