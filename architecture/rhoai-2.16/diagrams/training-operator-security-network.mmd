graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User/Data Scientist"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>User + SA Token Auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Operator["Training Operator<br/>SA: kubeflow-training-operator<br/>UID: 65532 (non-root)<br/>allowPrivilegeEscalation: false"]

        OpMetrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth"]
        OpHealth["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]

        Operator --- OpMetrics
        Operator --- OpHealth
    end

    subgraph UserNS["USER NAMESPACE (Training Jobs)"]
        direction TB

        subgraph CRs["Custom Resources"]
            PyTorchJobCR["PyTorchJob CR<br/>kubeflow.org/v1"]
            TFJobCR["TFJob CR<br/>kubeflow.org/v1"]
            MPIJobCR["MPIJob CR<br/>kubeflow.org/v1"]
        end

        subgraph TrainingResources["Training Resources"]
            HeadlessSvc["Headless Services<br/>ClusterIP: None<br/>DNS Discovery"]
            MasterPod["Master Pod<br/>23456/TCP (PyTorch)<br/>2222/TCP (TF)<br/>Plaintext<br/>No Auth"]
            WorkerPod1["Worker Pod 1<br/>23456/TCP<br/>Plaintext"]
            WorkerPod2["Worker Pod 2<br/>23456/TCP<br/>Plaintext"]
        end
    end

    subgraph Monitoring["MONITORING (openshift-user-workload-monitoring)"]
        Prometheus["Prometheus<br/>PodMonitor"]
    end

    subgraph Optional["OPTIONAL (Gang Scheduling)"]
        Volcano["Volcano Scheduler<br/>PodGroup CRD<br/>scheduling.volcano.sh"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User Token| K8sAPI
    K8sAPI -->|Watch API<br/>TLS 1.2+<br/>SA Token| Operator
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Create/Update| K8sAPI

    K8sAPI -.->|Create CRs| PyTorchJobCR
    K8sAPI -.->|Create CRs| TFJobCR
    K8sAPI -.->|Create CRs| MPIJobCR

    Operator -->|Reconcile<br/>Watch| PyTorchJobCR
    Operator -->|Reconcile<br/>Watch| TFJobCR
    Operator -->|Reconcile<br/>Watch| MPIJobCR

    Operator -->|Create via K8s API| HeadlessSvc
    Operator -->|Create via K8s API| MasterPod
    Operator -->|Create via K8s API| WorkerPod1
    Operator -->|Create via K8s API| WorkerPod2

    MasterPod -.->|DNS lookup<br/>53/UDP| HeadlessSvc
    WorkerPod1 -.->|DNS lookup<br/>53/UDP| HeadlessSvc
    WorkerPod2 -.->|DNS lookup<br/>53/UDP| HeadlessSvc

    MasterPod <-->|TCP/23456<br/>Plaintext<br/>No Auth<br/>Training Data| WorkerPod1
    MasterPod <-->|TCP/23456<br/>Plaintext<br/>Training Data| WorkerPod2
    WorkerPod1 <-->|TCP/23456<br/>Plaintext| WorkerPod2

    Prometheus -->|HTTP/8080<br/>Scrape /metrics<br/>No Auth| OpMetrics

    Operator -.->|Optional<br/>HTTPS/6443<br/>Create PodGroup| Volcano
    Volcano -.->|Atomic Scheduling| K8sAPI

    MasterPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry
    WorkerPod1 -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry
    WorkerPod2 -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef monitoring fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef optional fill:#e0e0e0,stroke:#757575,stroke-width:2px,stroke-dasharray: 5 5
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,OpMetrics,OpHealth operatorns
    class PyTorchJobCR,TFJobCR,MPIJobCR,HeadlessSvc,MasterPod,WorkerPod1,WorkerPod2 userns
    class Prometheus monitoring
    class Volcano optional
    class Registry externalservice
