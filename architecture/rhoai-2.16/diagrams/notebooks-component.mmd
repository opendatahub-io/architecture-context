graph TB
    subgraph "Notebooks (Workbench Images)"
        direction TB

        subgraph "Base Images"
            BaseUBI9["Base UBI9<br/>Python 3.9/3.11"]
            BaseRHEL9["Base RHEL9<br/>Python 3.9/3.11"]
            BaseCentOS9["Base CentOS Stream 9<br/>Python 3.9/3.11"]
            BaseCUDA["Base CUDA<br/>NVIDIA GPU Support"]
            BaseROCm["Base ROCm<br/>AMD GPU Support"]
            BaseIntel["Base Intel<br/>oneAPI XPU"]
        end

        subgraph "Jupyter Images"
            JupyterMinimal["Jupyter Minimal<br/>JupyterLab 4.2<br/>Python Kernel"]
            JupyterDS["Jupyter Data Science<br/>Elyra + pandas + scikit-learn"]
            JupyterPyTorch["Jupyter PyTorch<br/>PyTorch 2.x + GPU"]
            JupyterTF["Jupyter TensorFlow<br/>TensorFlow 2.x + GPU"]
            JupyterTrustAI["Jupyter TrustAI<br/>Explainable AI Libraries"]
            JupyterCUDA["Jupyter CUDA<br/>GPU-accelerated ML"]
            JupyterROCm["Jupyter ROCm<br/>AMD GPU ML"]
            JupyterIntel["Jupyter Intel<br/>Intel XPU Optimized"]
        end

        subgraph "Alternative IDEs"
            CodeServer["Code Server<br/>VS Code in Browser"]
            RStudio["RStudio Server<br/>R Language IDE"]
        end

        subgraph "Runtime Images"
            RuntimeLight["Lightweight Runtime<br/>Pipeline Execution Only"]
        end

        subgraph "Manifests"
            ImageStreams["ImageStream Manifests<br/>N, N-1, N-2, N-3, N-4 versions"]
            BuildConfigs["BuildConfig<br/>RStudio in-cluster builds"]
        end
    end

    subgraph "External Components"
        User["Data Scientist"]
        Dashboard["ODH Dashboard"]
        NotebookCtrl["Notebook Controller"]
    end

    subgraph "Deployed Workbench Instance"
        StatefulSet["StatefulSet<br/>Workbench Pod"]
        OAuthProxy["OAuth Proxy Sidecar<br/>Port 8443"]
        JupyterContainer["JupyterLab Container<br/>Port 8888"]
        Service["Service<br/>notebook"]
        Route["OpenShift Route<br/>443/TCP HTTPS"]
    end

    subgraph "Integrated Services"
        DSP["Data Science Pipelines<br/>8888/TCP"]
        ModelRegistry["Model Registry<br/>8080/TCP"]
        KServe["KServe Inference<br/>8080/8443/TCP"]
        S3["S3 Storage<br/>443/TCP"]
        PyPI["PyPI/pip<br/>443/TCP"]
    end

    %% Image layering
    BaseUBI9 --> JupyterMinimal
    JupyterMinimal --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTF
    JupyterDS --> JupyterTrustAI
    BaseCUDA --> JupyterCUDA
    BaseROCm --> JupyterROCm
    BaseIntel --> JupyterIntel
    BaseUBI9 --> CodeServer
    BaseRHEL9 --> RStudio

    %% Manifest management
    ImageStreams -.->|references| JupyterMinimal
    ImageStreams -.->|references| JupyterDS
    ImageStreams -.->|references| JupyterPyTorch
    ImageStreams -.->|references| JupyterTF
    ImageStreams -.->|references| JupyterTrustAI
    ImageStreams -.->|references| CodeServer
    BuildConfigs -.->|builds| RStudio

    %% User interaction
    User -->|selects workbench| Dashboard
    Dashboard -->|reads ImageStream metadata| ImageStreams
    Dashboard -->|requests workbench| NotebookCtrl

    %% Deployment flow
    NotebookCtrl -->|creates StatefulSet from| JupyterDS
    NotebookCtrl -->|creates| StatefulSet
    StatefulSet -->|contains| OAuthProxy
    StatefulSet -->|contains| JupyterContainer
    NotebookCtrl -->|creates| Service
    NotebookCtrl -->|creates| Route

    %% Network flow
    Route -->|TLS 1.2+| OAuthProxy
    OAuthProxy -->|HTTP/8888| JupyterContainer
    Service -.->|exposes| JupyterContainer

    %% Integration points
    JupyterContainer -->|Elyra submits runs| DSP
    JupyterContainer -->|registers models| ModelRegistry
    JupyterContainer -->|deploys models| KServe
    JupyterContainer -->|stores data| S3
    JupyterContainer -->|pip install| PyPI

    %% Pipeline runtime
    DSP -.->|executes with| RuntimeLight

    %% Styling
    style JupyterMinimal fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterDS fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterPyTorch fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterTF fill:#4a90e2,stroke:#333,stroke-width:2px
    style ImageStreams fill:#f5a623,stroke:#333,stroke-width:2px
    style NotebookCtrl fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style DSP fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style User fill:#bd10e0,stroke:#333,stroke-width:2px
    style S3 fill:#999,stroke:#333,stroke-width:2px
    style PyPI fill:#999,stroke:#333,stroke-width:2px
