graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser[User Browser]
        UserAdmin[User/Admin<br/>kubectl CLI]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.3<br/>OAuth2/OIDC"]
        VirtualSvc["Istio VirtualService<br/>networking.istio.io/v1alpha3<br/>Gateway: kubeflow/kubeflow-gateway<br/>Route: /notebook/{ns}/{name}"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Controller["Namespace: notebook-controller-system"]
            Controller["NotebookReconciler<br/>SA: notebook-controller-service-account<br/>Watches: Notebook CRs"]
            Culler["CullingReconciler<br/>SA: notebook-controller-service-account<br/>Activity Monitor"]
            ControllerSvc["notebook-controller-service<br/>ClusterIP 8080/TCP<br/>Metrics endpoint"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            NotebookSvc["Notebook Service<br/>ClusterIP<br/>Name: {notebook-name}<br/>Port: 80/TCP → 8888/TCP"]
            NotebookPod["Notebook Pod<br/>StatefulSet-managed<br/>Image: {user-specified}<br/>Port: 8888/TCP Jupyter"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount JWT + User OIDC"]
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>No Auth"]
    end

    %% External flows
    Browser -->|HTTPS/443<br/>TLS 1.3<br/>OAuth2/OIDC| Gateway
    UserAdmin -->|HTTPS/6443<br/>kubectl create notebook<br/>OIDC/cert| K8sAPI

    %% Ingress flows
    Gateway -->|HTTP/80<br/>mTLS STRICT<br/>Service Identity| VirtualSvc
    VirtualSvc -->|HTTP/80<br/>mTLS<br/>Service Identity| NotebookSvc

    %% Service mesh flows
    NotebookSvc -->|HTTP/8888<br/>Plaintext<br/>No Auth| NotebookPod

    %% Controller flows
    K8sAPI -->|Watch event<br/>Notebook CR| Controller
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount JWT| K8sAPI
    Controller -->|Creates<br/>StatefulSet, Service, VirtualService| K8sAPI

    %% Culling flows
    Culler -->|HTTP/80<br/>mTLS<br/>GET /api/kernels| NotebookSvc
    Culler -->|HTTPS/6443<br/>Update annotations<br/>ServiceAccount JWT| K8sAPI

    %% Monitoring flows
    Prometheus -->|HTTP/8080<br/>GET /metrics<br/>No Auth| ControllerSvc
    ControllerSvc -->|HTTPS/6443<br/>List StatefulSets<br/>ServiceAccount JWT| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser,UserAdmin external
    class Gateway,VirtualSvc ingress
    class Controller,Culler,ControllerSvc,NotebookSvc,NotebookPod servicemesh
    class K8sAPI controlplane
    class Prometheus monitoring
