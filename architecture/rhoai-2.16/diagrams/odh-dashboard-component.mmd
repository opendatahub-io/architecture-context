graph TB
    subgraph "ODH Dashboard Pod"
        Frontend[React/TypeScript SPA<br/>Frontend UI]
        Backend[Fastify REST API<br/>Node.js Backend<br/>8080/TCP HTTP]
        OAuthProxy[OAuth Proxy<br/>Sidecar Container<br/>8443/TCP HTTPS]

        Frontend -->|serves| Backend
        OAuthProxy -->|proxies to| Backend
    end

    subgraph "Custom Resource Definitions"
        OdhDashboardConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhApplication[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhDocument[OdhDocument<br/>dashboard.opendatahub.io/v1]
        AcceleratorProfile[AcceleratorProfile<br/>dashboard.opendatahub.io/v1]
        OdhQuickStart[OdhQuickStart<br/>console.openshift.io/v1]
    end

    subgraph "External Components"
        User[User Browser]
        Route[OpenShift Route<br/>443/TCP HTTPS]
        OAuthServer[OpenShift OAuth Server]
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ThanosQuerier[Thanos Querier<br/>9092/TCP HTTPS]
        ImageStreamAPI[ImageStream API<br/>6443/TCP HTTPS]
    end

    subgraph "ODH/RHOAI Components"
        Notebooks[Kubeflow Notebooks<br/>kubeflow.org/notebooks]
        KServe[KServe<br/>serving.kserve.io]
        ModelMesh[ModelMesh<br/>serving.kserve.io]
        ModelRegistry[Model Registry<br/>modelregistry.opendatahub.io]
        Pipelines[Data Science Pipelines]
        NIMServing[NIM Serving<br/>nim.opendatahub.io/accounts]
    end

    %% User flows
    User -->|HTTPS/443<br/>OAuth Bearer Token| Route
    Route -->|HTTPS/8443<br/>TLS reencrypt| OAuthProxy

    %% Authentication
    OAuthProxy -->|OAuth flow| OAuthServer

    %% Backend interactions
    Backend -->|ServiceAccount Token| K8sAPI
    Backend -->|ServiceAccount Token| ThanosQuerier
    Backend -->|ServiceAccount Token| ImageStreamAPI

    %% CRD management
    Backend -->|manages| OdhDashboardConfig
    Backend -->|reads| OdhApplication
    Backend -->|reads| OdhDocument
    Backend -->|manages| AcceleratorProfile
    Backend -->|reads| OdhQuickStart

    %% Component integration
    Backend -->|creates/manages| Notebooks
    Backend -->|manages| KServe
    Backend -->|manages| ModelMesh
    Backend -->|manages| ModelRegistry
    Backend -->|integrates| Pipelines
    Backend -->|manages| NIMServing

    %% Styling
    style Frontend fill:#4a90e2,stroke:#333,stroke-width:2px
    style Backend fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#4a90e2,stroke:#333,stroke-width:2px
    style OdhDashboardConfig fill:#f5a623,stroke:#333
    style OdhApplication fill:#f5a623,stroke:#333
    style OdhDocument fill:#f5a623,stroke:#333
    style AcceleratorProfile fill:#f5a623,stroke:#333
    style OdhQuickStart fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style ThanosQuerier fill:#e8e8e8,stroke:#333
    style ImageStreamAPI fill:#e8e8e8,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style NIMServing fill:#7ed321,stroke:#333
