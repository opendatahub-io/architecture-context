graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (reencrypt)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Dashboard Namespace)"]
        direction TB

        subgraph Pod["ODH Dashboard Pod"]
            OAuthProxy["OAuth Proxy Container<br/>SA: odh-dashboard<br/>8443/TCP HTTPS<br/>Validates JWT tokens"]
            Backend["Dashboard Backend<br/>Fastify/Node.js<br/>SA: odh-dashboard<br/>8080/TCP HTTP<br/>Image: ubi8/nodejs-20"]
        end

        Service["Service: odh-dashboard<br/>ClusterIP<br/>8443/TCP HTTPS"]

        Service -.->|routes to| OAuthProxy
        OAuthProxy -->|HTTP/8080<br/>localhost<br/>Bearer Token| Backend
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS1.2+<br/>OAuth 2.0"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
        Thanos["Thanos Querier<br/>openshift-monitoring<br/>9092/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
        ImageAPI["ImageStream API<br/>443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
    end

    subgraph Secrets["Secrets"]
        ProxyTLS["dashboard-proxy-tls<br/>kubernetes.io/tls<br/>Auto-rotate: Yes"]
        OAuthConfig["dashboard-oauth-config-generated<br/>Opaque<br/>Cookie secret"]
        OAuthClient["dashboard-oauth-client-generated<br/>Opaque<br/>OAuth credentials"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Route
    Route -->|HTTPS/8443<br/>TLS reencrypt| Service

    OAuthProxy -->|OAuth 2.0<br/>HTTPS/443<br/>Client Credentials| OAuthServer
    Backend -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Backend -->|HTTPS/9092<br/>TLS 1.2+<br/>ServiceAccount Token| Thanos
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| ImageAPI

    %% Secrets mounting
    ProxyTLS -.->|mounts to| OAuthProxy
    OAuthConfig -.->|mounts to| OAuthProxy
    OAuthClient -.->|mounts to| OAuthProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class OAuthProxy,Backend,Service,Pod app
    class OAuthServer,K8sAPI,Thanos,ImageAPI externalservice
    class ProxyTLS,OAuthConfig,OAuthClient secret
