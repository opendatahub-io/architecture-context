graph TB
    subgraph "RHODS Operator"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        CertController[CertConfigMapGenerator Controller]
        SecretController[SecretGenerator Controller]
        Webhook[Webhook Server<br/>9443/TCP HTTPS]
        StatusReporter[Status Reporter]
        FeatureTracker[Feature Tracker]

        DSCController -->|manages| StatusReporter
        DSCIController -->|initializes| CertController
        DSCIController -->|initializes| SecretController
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FT[FeatureTracker CR<br/>features.opendatahub.io/v1]
    end

    subgraph "Component Reconcilers"
        Dashboard[Dashboard Reconciler]
        Workbenches[Workbenches Reconciler]
        Pipelines[Data Science Pipelines Reconciler]
        KServe[KServe Reconciler]
        ModelMesh[ModelMesh Reconciler]
        CodeFlare[CodeFlare Reconciler]
        Ray[Ray Reconciler]
        TrustyAI[TrustyAI Reconciler]
        ModelRegistry[Model Registry Reconciler]
        Kueue[Kueue Reconciler]
        TrainingOp[Training Operator Reconciler]
    end

    subgraph "Platform Infrastructure"
        ServiceMesh[Service Mesh<br/>Istio SMCP/SMM]
        Knative[Knative Serving]
        Authorino[Authorino]
        Monitoring[Prometheus/Alertmanager]
    end

    subgraph "Managed Components"
        DashboardComp[ODH Dashboard]
        NotebooksComp[Notebooks/Workbenches]
        DSPComp[Data Science Pipelines]
        KServeComp[KServe]
        ModelMeshComp[ModelMesh]
    end

    User[Admin/User] -->|creates| DSC
    User -->|creates| DSCI

    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController
    FT -->|watched by| FeatureTracker

    Webhook -->|validates/mutates| DSC
    Webhook -->|validates/mutates| DSCI

    DSCController -->|invokes| Dashboard
    DSCController -->|invokes| Workbenches
    DSCController -->|invokes| Pipelines
    DSCController -->|invokes| KServe
    DSCController -->|invokes| ModelMesh
    DSCController -->|invokes| CodeFlare
    DSCController -->|invokes| Ray
    DSCController -->|invokes| TrustyAI
    DSCController -->|invokes| ModelRegistry
    DSCController -->|invokes| Kueue
    DSCController -->|invokes| TrainingOp

    Dashboard -->|deploys| DashboardComp
    Workbenches -->|deploys| NotebooksComp
    Pipelines -->|deploys| DSPComp
    KServe -->|deploys| KServeComp
    ModelMesh -->|deploys| ModelMeshComp

    DSCIController -->|creates| ServiceMesh
    DSCIController -->|creates| Monitoring
    KServe -->|requires| ServiceMesh
    KServe -->|requires| Knative
    KServe -->|requires| Authorino

    style DSCController fill:#4a90e2
    style DSCIController fill:#4a90e2
    style Webhook fill:#4a90e2
    style DSC fill:#f5a623
    style DSCI fill:#f5a623
    style ServiceMesh fill:#e8e8e8
    style Knative fill:#e8e8e8
    style Authorino fill:#e8e8e8
    style DashboardComp fill:#7ed321
    style NotebooksComp fill:#7ed321
    style DSPComp fill:#7ed321
    style KServeComp fill:#7ed321
    style ModelMeshComp fill:#7ed321
