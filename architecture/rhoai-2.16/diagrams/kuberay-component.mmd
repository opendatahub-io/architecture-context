graph TB
    subgraph "KubeRay Operator"
        Controller[KubeRay Operator<br/>Go Controller]
        RayClusterCtrl[RayCluster Controller<br/>Reconciler]
        RayJobCtrl[RayJob Controller<br/>Reconciler]
        RayServiceCtrl[RayService Controller<br/>Reconciler]
        Webhook[Webhook Server<br/>Validation]
        Metrics[Metrics Exporter<br/>:8080/metrics]

        Controller --> RayClusterCtrl
        Controller --> RayJobCtrl
        Controller --> RayServiceCtrl
        Controller --> Webhook
        Controller --> Metrics
    end

    subgraph "Optional Components"
        APIServer[APIServer<br/>gRPC:8887 HTTP:8888]
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Resources"
        HeadPod[Ray Head Pod<br/>GCS + Dashboard]
        WorkerPods[Ray Worker Pods<br/>Raylets]
        HeadSvc["cluster-head-svc<br/>6379,8265,10001,8080,8000"]
        ServeSvc["cluster-serve-svc<br/>8000"]
    end

    User[User/Dashboard] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadSvc
    RayServiceCtrl -->|creates| ServeSvc

    WorkerPods -->|connects to| HeadSvc

    APIServer -.->|optional mgmt| RayClusterCR
    APIServer -.->|optional mgmt| RayJobCR
    APIServer -.->|optional mgmt| RayServiceCR

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API]
        Prometheus[Prometheus]
        Volcano[Volcano Scheduler<br/>Optional]
        Redis[External Redis<br/>Optional GCS FT]
    end

    Controller -->|REST API| K8sAPI
    Metrics -->|scraped by| Prometheus
    RayClusterCtrl -.->|gang scheduling| Volcano
    HeadPod -.->|fault tolerance| Redis

    subgraph "Internal ODH Integration"
        Dashboard[ODH Dashboard]
        MonStack[Monitoring Stack]
    end

    Dashboard -->|UI for| RayClusterCR
    MonStack -->|collects| Metrics

