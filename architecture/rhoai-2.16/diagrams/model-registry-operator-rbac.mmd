graph TD
    subgraph "Operator Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-role-binding]
        CRB_Leader[leader-election-rolebinding]
        CRB_AuthProxy[auth-proxy-role-binding]
    end

    subgraph "ClusterRole: manager-role"
        CR_Manager[manager-role]
    end

    subgraph "API Resources - ModelRegistry"
        MR_CR[modelregistry.opendatahub.io<br/>ModelRegistry CR]
        MR_Status[modelregistries/status]
        MR_Finalizers[modelregistries/finalizers]
    end

    subgraph "API Resources - Core"
        Core_Services[core/Services]
        Core_SA[core/ServiceAccounts]
        Core_Events[core/Events]
        Core_Endpoints[core/Endpoints]
        Core_Pods[core/Pods]
        Core_PodLogs[core/Pods/log]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/Deployments]
    end

    subgraph "API Resources - RBAC"
        RBAC_Roles[rbac.authorization.k8s.io/Roles]
        RBAC_RoleBindings[rbac.authorization.k8s.io/RoleBindings]
    end

    subgraph "API Resources - OpenShift"
        Route_Routes[route.openshift.io/Routes]
        Route_CustomHost[routes/custom-host]
        User_Groups[user.openshift.io/Groups]
        Config_Ingresses[config.openshift.io/Ingresses]
    end

    subgraph "API Resources - Istio"
        Istio_Gateways[networking.istio.io/Gateways]
        Istio_VS[networking.istio.io/VirtualServices]
        Istio_DR[networking.istio.io/DestinationRules]
        Istio_AuthZ[security.istio.io/AuthorizationPolicies]
    end

    subgraph "API Resources - Authorino"
        Auth_Config[authorino.kuadrant.io/AuthConfigs]
    end

    subgraph "User Roles (Created per Registry)"
        Role_User["registry-user-(registry-name)<br/>Namespace: user-namespace"]
        Resource_Service["services/(registry-name)"]
    end

    %% Operator RBAC Flow
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Leader
    SA_Controller -->|bound via| CRB_AuthProxy
    CRB_Manager -->|grants| CR_Manager

    %% Manager Role Permissions
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_CR
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_Status
    CR_Manager -->|get,list,watch,create,update,patch,delete| MR_Finalizers

    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Services
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_SA
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Events
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Endpoints
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Pods
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_PodLogs

    CR_Manager -->|get,list,watch,create,update,patch,delete| Apps_Deployments

    CR_Manager -->|get,list,watch,create,update,patch,delete| RBAC_Roles
    CR_Manager -->|get,list,watch,create,update,patch,delete| RBAC_RoleBindings

    CR_Manager -->|get,list,watch,create,update,patch,delete| Route_Routes
    CR_Manager -->|get,list,watch,create,update,patch,delete| Route_CustomHost
    CR_Manager -->|get,list,watch,create,update,patch,delete| User_Groups
    CR_Manager -->|get,list,watch| Config_Ingresses

    CR_Manager -->|get,list,watch,create,update,patch,delete| Istio_Gateways
    CR_Manager -->|get,list,watch,create,update,patch,delete| Istio_VS
    CR_Manager -->|get,list,watch,create,update,patch,delete| Istio_DR
    CR_Manager -->|get,list,watch,create,update,patch,delete| Istio_AuthZ

    CR_Manager -->|get,list,watch,create,update,patch,delete| Auth_Config

    %% User Access RBAC (Istio Mode)
    Role_User -->|get| Resource_Service

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623
    style CRB_Manager fill:#f5a623
    style CRB_Leader fill:#f5a623
    style CRB_AuthProxy fill:#f5a623

    style MR_CR fill:#7ed321
    style MR_Status fill:#7ed321
    style MR_Finalizers fill:#7ed321

    style Role_User fill:#4a90e2,color:#fff
    style Resource_Service fill:#7ed321
