graph TD
    subgraph "NOTE: Notebooks component does not define RBAC"
        Note["This component provides container images only<br/>RBAC is managed by ODH Notebook Controller"]
    end

    subgraph "Service Accounts (Created by ODH Notebook Controller)"
        SA["{notebook-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "Default Namespace Permissions"
        DefaultPerms["Default ServiceAccount Permissions<br/>- get/list pods<br/>- get/list services<br/>- mount secrets (user-provided)"]
    end

    subgraph "Authentication Flow"
        direction TB

        User[Authenticated OpenShift User]
        OAuth[OAuth Proxy Sidecar<br/>OpenShift OAuth]
        WorkbenchPod[Workbench Pod<br/>Jupyter/RStudio/VS Code]
    end

    subgraph "Access Control Enforcement"
        direction TB

        OAuthPolicy["OAuth Policy<br/>- Users can only access notebooks in authorized namespaces<br/>- Enforced by OpenShift RBAC"]
        NamespaceRBAC["OpenShift Namespace RBAC<br/>- RoleBindings control namespace access<br/>- Managed by cluster admins"]
    end

    subgraph "Container Registry Access"
        PullSecret["Pull Secret<br/>kubernetes.io/dockerconfigjson<br/>- Quay.io access<br/>- registry.redhat.io access"]
        Kubelet["Kubelet<br/>Uses pull secret to pull images"]
    end

    subgraph "User-Provided Secrets (Optional)"
        UserSecrets["User Secrets (Opaque)<br/>- S3 credentials<br/>- Database passwords<br/>- API tokens<br/>Mounted by user configuration"]
    end

    %% Relationships
    SA -->|has| DefaultPerms
    SA -->|runs| WorkbenchPod

    User -->|authenticates via| OAuth
    OAuth -->|enforces| OAuthPolicy
    OAuthPolicy -->|checks| NamespaceRBAC
    OAuth -->|forwards to| WorkbenchPod

    WorkbenchPod -->|can mount| UserSecrets
    Kubelet -->|uses| PullSecret
    Kubelet -->|pulls images for| WorkbenchPod

    %% Styling
    style Note fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style DefaultPerms fill:#7ed321,stroke:#333
    style OAuth fill:#f5a623,stroke:#333
    style OAuthPolicy fill:#e74c3c,stroke:#333,color:#fff
    style NamespaceRBAC fill:#e74c3c,stroke:#333,color:#fff
    style PullSecret fill:#9b59b6,stroke:#333,color:#fff
    style UserSecrets fill:#9b59b6,stroke:#333,color:#fff
    style WorkbenchPod fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    %% Additional note
    subgraph "Key Points"
        KP1["✓ No ClusterRoles or RoleBindings defined by Notebooks component"]
        KP2["✓ ServiceAccount created by ODH Notebook Controller per workbench"]
        KP3["✓ Authentication enforced by OAuth Proxy (OpenShift OAuth)"]
        KP4["✓ Authorization enforced by OpenShift Namespace RBAC"]
        KP5["✓ Users manage their own data access secrets"]
    end

    style KP1 fill:#d5e8d4,stroke:#82b366
    style KP2 fill:#d5e8d4,stroke:#82b366
    style KP3 fill:#d5e8d4,stroke:#82b366
    style KP4 fill:#d5e8d4,stroke:#82b366
    style KP5 fill:#d5e8d4,stroke:#82b366
