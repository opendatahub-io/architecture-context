graph TD
    subgraph "RBAC Management"
        Note1["This component does not define ClusterRoles or RoleBindings<br/>RBAC is managed by ODH Notebook Controller"]
    end

    subgraph "Service Accounts"
        SA["{notebook-name}-sa<br/>Namespace: {user-namespace}<br/>Assigned by: ODH Notebook Controller"]
    end

    subgraph "Pod Execution Context"
        JupyterPod[Jupyter Workbench Pod]
        CodePod[Code Server Pod]
        RStudioPod[RStudio Pod]
        RuntimePod[Runtime Pod<br/>Kubeflow Pipeline Task]
    end

    subgraph "Permissions"
        MinimalPerms["Minimal Permissions<br/>- No cluster-level access<br/>- No CRD manipulation<br/>- Read/write own namespace resources<br/>- Access to mounted secrets"]
    end

    subgraph "Authentication Enforcement"
        OAuthProxy["OAuth Proxy Sidecar<br/>Enforcement Point: OAuth2 Proxy Container<br/>Auth Mechanism: OpenShift OAuth<br/>Policy: Only authenticated users access their notebooks"]
    end

    subgraph "Container Registry Auth"
        PullSecret["Pull Secret<br/>Type: kubernetes.io/dockerconfigjson<br/>Purpose: Authenticate to Quay.io, registry.redhat.io<br/>Enforcement: Kubelet"]
    end

    subgraph "User-Provided Secrets"
        UserSecrets["S3 Credentials (Opaque)<br/>Cloud Credentials<br/>Mounted by users for data access<br/>Not managed by component"]
    end

    %% Relationships
    SA -->|runs as| JupyterPod
    SA -->|runs as| CodePod
    SA -->|runs as| RStudioPod
    SA -->|runs as| RuntimePod

    SA -->|has| MinimalPerms

    OAuthProxy -->|protects| JupyterPod
    OAuthProxy -->|protects| CodePod
    OAuthProxy -->|protects| RStudioPod

    SA -->|uses for image pull| PullSecret

    JupyterPod -->|accesses| UserSecrets
    CodePod -->|accesses| UserSecrets
    RStudioPod -->|accesses| UserSecrets
    RuntimePod -->|accesses| UserSecrets

    %% Styling
    style Note1 fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style JupyterPod fill:#7ed321,stroke:#333
    style CodePod fill:#7ed321,stroke:#333
    style RStudioPod fill:#7ed321,stroke:#333
    style RuntimePod fill:#7ed321,stroke:#333
    style MinimalPerms fill:#d5e8d4,stroke:#82b366
    style OAuthProxy fill:#f5a623,stroke:#333
    style PullSecret fill:#e1bee7,stroke:#8e24aa
    style UserSecrets fill:#e1bee7,stroke:#8e24aa
