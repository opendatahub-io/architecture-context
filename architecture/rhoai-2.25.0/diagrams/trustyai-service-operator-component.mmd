graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Manager<br/>Controller-Runtime]
        Webhook[Conversion Webhook<br/>v1/v1alpha1]
        LMEvalCtrl[LM Eval Job Controller]
        GuardrailsCtrl[Guardrails Controller]

        Controller -->|manages| LMEvalCtrl
        Controller -->|manages| GuardrailsCtrl
        Controller -->|serves| Webhook
    end

    subgraph "Custom Resources"
        TrustyAICR[TrustyAIService CR<br/>v1/v1alpha1]
        LMEvalCR[LMEvalJob CR<br/>v1alpha1]
        GuardrailsCR[GuardrailsOrchestrator CR<br/>v1alpha1]
    end

    subgraph "Managed Services"
        TrustyAIService[TrustyAI Service<br/>Explainability & Bias Detection]
        OAuthProxy1[OAuth Proxy Sidecar]
        LMESPod[LMES Job Pod<br/>lm-evaluation-harness]
        GuardrailsOrch[Guardrails Orchestrator<br/>Safety Detectors]
        OAuthProxy2[OAuth Proxy Sidecar]
    end

    subgraph "Platform Resources"
        Deployment1[Deployment]
        Service1[Service]
        Route1[OpenShift Route]
        VirtualService[Istio VirtualService]
        ServiceMonitor[ServiceMonitor]
        PVC[PersistentVolumeClaim]
        Secret[Secrets & ConfigMaps]
    end

    %% CR to Controller
    TrustyAICR -->|watched by| Controller
    LMEvalCR -->|watched by| LMEvalCtrl
    GuardrailsCR -->|watched by| GuardrailsCtrl

    %% Controller creates services
    Controller -->|creates| TrustyAIService
    Controller -->|creates| OAuthProxy1
    LMEvalCtrl -->|creates| LMESPod
    GuardrailsCtrl -->|creates| GuardrailsOrch
    GuardrailsCtrl -->|creates| OAuthProxy2

    %% Controller creates platform resources
    Controller -->|creates| Deployment1
    Controller -->|creates| Service1
    Controller -->|creates| Route1
    Controller -->|creates| VirtualService
    Controller -->|creates| ServiceMonitor
    Controller -->|creates| PVC
    Controller -->|creates| Secret

    subgraph "External Dependencies"
        KServe[KServe InferenceService]
        ModelMesh[ModelMesh Serving]
        Prometheus[Prometheus]
        Kueue[Kueue]
        Database[PostgreSQL/MySQL]
        S3[S3 Storage]
        HuggingFace[Hugging Face Hub]
    end

    %% Service interactions
    TrustyAIService -->|monitors| KServe
    TrustyAIService -->|injects payload processor| ModelMesh
    TrustyAIService -->|stores data| PVC
    TrustyAIService -->|stores data| Database
    Prometheus -->|scrapes metrics| TrustyAIService
    Prometheus -->|scrapes metrics| Controller

    LMESPod -->|uses| Kueue
    LMESPod -->|downloads models| HuggingFace
    LMESPod -->|evaluates| KServe
    LMESPod -->|stores results| S3

    GuardrailsOrch -->|checks with| KServe

    %% Integration points
    Controller -->|watches/patches| KServe
    Controller -->|pod exec| ModelMesh

