graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller Manager]
        TrustyAIController[TrustyAI Service Controller]
        LMEvalController[LM Eval Job Controller]
        GuardrailsController[Guardrails Orchestrator Controller]
        ConversionWebhook[CRD Conversion Webhook]

        Controller -->|reconciles| TrustyAIController
        Controller -->|reconciles| LMEvalController
        Controller -->|reconciles| GuardrailsController
        Controller -->|serves| ConversionWebhook
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>v1/v1alpha1]
        LMEvalJobCR[LMEvalJob CR<br/>v1alpha1]
        GuardrailsOrchestratorCR[GuardrailsOrchestrator CR<br/>v1alpha1]
    end

    subgraph "Managed Services"
        TrustyAIService[TrustyAI Service<br/>Explainability & Bias Detection]
        LMESPod[LMES Job Pod<br/>LM Evaluation]
        GuardrailsOrch[Guardrails Orchestrator<br/>AI Safety & Filtering]
        OAuthProxy[OAuth Proxy Sidecars<br/>Authentication]
    end

    subgraph "Storage & Monitoring"
        PVC[PVC Storage]
        Database[PostgreSQL/MySQL]
        Prometheus[Prometheus<br/>ServiceMonitors]
    end

    %% User interactions
    User[User/Dashboard] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsOrchestratorCR

    %% CR to Controllers
    TrustyAIServiceCR -->|watched by| TrustyAIController
    LMEvalJobCR -->|watched by| LMEvalController
    GuardrailsOrchestratorCR -->|watched by| GuardrailsController

    %% Controllers create managed resources
    TrustyAIController -->|creates| TrustyAIService
    TrustyAIController -->|creates| OAuthProxy
    LMEvalController -->|creates| LMESPod
    GuardrailsController -->|creates| GuardrailsOrch

    %% Storage
    TrustyAIService -->|stores data| PVC
    TrustyAIService -->|stores data| Database

    %% Monitoring
    TrustyAIService -->|exposes metrics| Prometheus
    Controller -->|exposes metrics| Prometheus

    %% External dependencies
    TrustyAIController -->|patches| KServe[KServe InferenceService]
    TrustyAIController -->|configures| ModelMesh[ModelMesh Serving]
    LMEvalController -->|integrates| Kueue[Kueue Workload]
    GuardrailsOrch -->|calls| DetectorIS[Detector InferenceService]

    %% Routes
    TrustyAIController -->|creates| Route[OpenShift Route/Istio VS]
    GuardrailsController -->|creates| GuardrailsRoute[OpenShift Route]

