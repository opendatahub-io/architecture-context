graph TD
    subgraph "Service Accounts"
        SA[notebook-controller-service-account]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding<br/>Scope: All namespaces]
        CRB2[leader-election-role-binding<br/>Scope: Controller namespace]
    end

    subgraph "ClusterRoles"
        CR1[notebook-controller-role]
        CR2[leader-election-role]
        CR3[kubeflow-notebooks-edit<br/>User role]
        CR4[kubeflow-notebooks-view<br/>User role]
    end

    subgraph "API Resources - Core"
        Events[core/events<br/>create,get,list,patch,watch]
        Pods[core/pods<br/>delete,get,list,watch]
        Services[core/services<br/>* all verbs]
        ConfigMaps[core/configmaps<br/>get,list,watch,create,update,patch,delete]
        ConfigMapsStatus[core/configmaps/status<br/>get,update,patch]
    end

    subgraph "API Resources - Apps"
        StatefulSets[apps/statefulsets<br/>* all verbs]
    end

    subgraph "API Resources - Kubeflow"
        Notebooks[kubeflow.org/notebooks<br/>* all verbs]
        NotebooksFinalizers[kubeflow.org/notebooks/finalizers<br/>* all verbs]
        NotebooksStatus[kubeflow.org/notebooks/status<br/>* all verbs]
        NotebooksEdit[kubeflow.org/notebooks<br/>get,list,watch,create,delete,<br/>deletecollection,patch,update]
        NotebooksView[kubeflow.org/notebooks<br/>get,list,watch]
    end

    subgraph "API Resources - Istio"
        VirtualServices[networking.istio.io/virtualservices<br/>* all verbs]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% ClusterRole bindings
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% notebook-controller-role permissions
    CR1 -->|permissions| Events
    CR1 -->|permissions| Pods
    CR1 -->|permissions| Services
    CR1 -->|permissions| StatefulSets
    CR1 -->|permissions| Notebooks
    CR1 -->|permissions| NotebooksFinalizers
    CR1 -->|permissions| NotebooksStatus
    CR1 -->|permissions| VirtualServices

    %% leader-election-role permissions
    CR2 -->|permissions| ConfigMaps
    CR2 -->|permissions| ConfigMapsStatus

    %% User role permissions
    CR3 -->|permissions| NotebooksEdit
    CR4 -->|permissions| NotebooksView

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR4 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#d4af37,stroke:#333,stroke-width:2px
    style CRB2 fill:#d4af37,stroke:#333,stroke-width:2px

    style Events fill:#e8f4f8,stroke:#333
    style Pods fill:#e8f4f8,stroke:#333
    style Services fill:#e8f4f8,stroke:#333
    style ConfigMaps fill:#e8f4f8,stroke:#333
    style ConfigMapsStatus fill:#e8f4f8,stroke:#333
    style StatefulSets fill:#fff4e6,stroke:#333
    style Notebooks fill:#f0f8e8,stroke:#333
    style NotebooksFinalizers fill:#f0f8e8,stroke:#333
    style NotebooksStatus fill:#f0f8e8,stroke:#333
    style NotebooksEdit fill:#f0f8e8,stroke:#333
    style NotebooksView fill:#f0f8e8,stroke:#333
    style VirtualServices fill:#f4e8f8,stroke:#333
