graph TD
    subgraph "Service Accounts"
        SA[notebook-controller-service-account<br/>Namespace: odh-notebook-controller]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding<br/>Scope: All Namespaces]
        CRB2[leader-election-role-binding<br/>Scope: Controller Namespace]
    end

    subgraph "ClusterRoles - Controller"
        CR1[notebook-controller-role]
        CR2[leader-election-role]
    end

    subgraph "ClusterRoles - End Users"
        CR3[kubeflow-notebooks-edit<br/>For notebook creators]
        CR4[kubeflow-notebooks-view<br/>For read-only access]
    end

    subgraph "Core API Resources"
        Events["events<br/>API Group: ''"]
        Pods["pods<br/>API Group: ''"]
        Services["services<br/>API Group: ''"]
        ConfigMaps["configmaps<br/>API Group: ''"]
    end

    subgraph "Apps API Resources"
        StatefulSets["statefulsets<br/>API Group: apps"]
    end

    subgraph "Kubeflow API Resources"
        Notebooks["notebooks<br/>notebooks/finalizers<br/>notebooks/status<br/>API Group: kubeflow.org"]
    end

    subgraph "Istio API Resources"
        VirtualServices["virtualservices<br/>API Group: networking.istio.io"]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% notebook-controller-role Permissions
    CR1 -->|create, get, list, patch, watch| Events
    CR1 -->|delete, get, list, watch| Pods
    CR1 -->|* all verbs| Services
    CR1 -->|* all verbs| StatefulSets
    CR1 -->|* all verbs| Notebooks
    CR1 -->|* all verbs| VirtualServices

    %% leader-election-role Permissions
    CR2 -->|get, list, watch, create, update, patch, delete| ConfigMaps

    %% End User Roles
    CR3 -->|get, list, watch, create, delete, deletecollection, patch, update| Notebooks
    CR4 -->|get, list, watch| Notebooks

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR4 fill:#7ed321,stroke:#333,stroke-width:2px
    style Events fill:#dae8fc,stroke:#333
    style Pods fill:#dae8fc,stroke:#333
    style Services fill:#dae8fc,stroke:#333
    style ConfigMaps fill:#dae8fc,stroke:#333
    style StatefulSets fill:#dae8fc,stroke:#333
    style Notebooks fill:#ffe6cc,stroke:#333,stroke-width:2px
    style VirtualServices fill:#e1d5e7,stroke:#333
