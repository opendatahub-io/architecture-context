graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: llama-stack-k8s-operator-system]
        SA_Instance["{instance-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Scope: Cluster-wide]
        CRB_AuthProxy[auth-proxy-rolebinding<br/>Scope: operator namespace]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_AuthProxy[auth-proxy-role<br/>ClusterRole]
        CR_MetricsReader[metrics-reader<br/>ClusterRole]
        CR_Editor[llsd-editor-role<br/>ClusterRole]
        CR_Viewer[llsd-viewer-role<br/>ClusterRole]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_LeaderElection[leader-election-rolebinding<br/>Namespace: operator namespace]
    end

    subgraph "Roles (Namespace-scoped)"
        R_LeaderElection[leader-election-role<br/>Role]
    end

    subgraph "API Resources - CRDs"
        CRD_LLSD[llamastack.io/v1alpha1<br/>LlamaStackDistribution]
        CRD_LLSD_Status[LlamaStackDistribution/status]
        CRD_LLSD_Finalizers[LlamaStackDistribution/finalizers]
    end

    subgraph "API Resources - Core"
        Core_Deployments[apps/v1<br/>Deployments]
        Core_Services[v1<br/>Services]
        Core_SA[v1<br/>ServiceAccounts]
        Core_PVC[v1<br/>PersistentVolumeClaims]
        Core_ConfigMaps[v1<br/>ConfigMaps]
    end

    subgraph "API Resources - Networking"
        Net_Ingress[networking.k8s.io/v1<br/>Ingresses]
        Net_NetworkPolicy[networking.k8s.io/v1<br/>NetworkPolicies]
    end

    subgraph "API Resources - RBAC"
        RBAC_ClusterRoleBindings[rbac.authorization.k8s.io/v1<br/>ClusterRoleBindings]
        RBAC_ClusterRoles[rbac.authorization.k8s.io/v1<br/>ClusterRoles]
    end

    subgraph "API Resources - Security (OpenShift)"
        Sec_SCC[security.openshift.io<br/>SecurityContextConstraints<br/>Resource: anyuid]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReview[authentication.k8s.io/v1<br/>TokenReviews]
        Auth_SAR[authorization.k8s.io/v1<br/>SubjectAccessReviews]
    end

    subgraph "API Resources - Monitoring"
        Mon_Endpoints[v1<br/>Endpoints]
        Mon_Services_Mon[v1<br/>Services]
        Mon_Pods[v1<br/>Pods]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_AuthProxy
    SA_Controller -->|bound via| RB_LeaderElection

    %% ClusterRoleBindings to ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy

    %% RoleBindings to Roles
    RB_LeaderElection -->|grants| R_LeaderElection

    %% manager-role permissions
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| CRD_LLSD
    CR_Manager -->|get, update, patch| CRD_LLSD_Status
    CR_Manager -->|update| CRD_LLSD_Finalizers
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| Core_Deployments
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| Core_Services
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| Core_SA
    CR_Manager -->|get, list, watch, create| Core_PVC
    CR_Manager -->|get, list, watch,<br/>create, update, patch| Core_ConfigMaps
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| Net_Ingress
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| Net_NetworkPolicy
    CR_Manager -->|get, list, watch,<br/>create, update, patch, delete| RBAC_ClusterRoleBindings
    CR_Manager -->|get, list, watch| RBAC_ClusterRoles
    CR_Manager -->|use| Sec_SCC

    %% auth-proxy-role permissions
    CR_AuthProxy -->|create| Auth_TokenReview
    CR_AuthProxy -->|create| Auth_SAR

    %% metrics-reader permissions
    CR_MetricsReader -->|get, list, watch| Mon_Endpoints
    CR_MetricsReader -->|get, list, watch| Mon_Services_Mon
    CR_MetricsReader -->|get, list, watch| Mon_Pods

    %% editor/viewer roles
    CR_Editor -->|get, list, watch,<br/>create, update, patch, delete| CRD_LLSD
    CR_Viewer -->|get, list, watch| CRD_LLSD

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef resource fill:#dae8fc,stroke:#333,stroke-width:1px,color:#000

    class SA_Controller,SA_Instance serviceAccount
    class CRB_Manager,CRB_AuthProxy,RB_LeaderElection binding
    class CR_Manager,CR_AuthProxy,CR_MetricsReader,CR_Editor,CR_Viewer,R_LeaderElection role
    class CRD_LLSD,CRD_LLSD_Status,CRD_LLSD_Finalizers,Core_Deployments,Core_Services,Core_SA,Core_PVC,Core_ConfigMaps,Net_Ingress,Net_NetworkPolicy,RBAC_ClusterRoleBindings,RBAC_ClusterRoles,Sec_SCC,Auth_TokenReview,Auth_SAR,Mon_Endpoints,Mon_Services_Mon,Mon_Pods resource
