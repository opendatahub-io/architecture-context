graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>namespace: llama-stack-k8s-operator-system]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>cluster-wide]
        CRB_AuthProxy[auth-proxy-rolebinding<br/>operator namespace]
        RB_LeaderElection[leader-election-rolebinding<br/>operator namespace]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_AuthProxy[auth-proxy-role]
        CR_MetricsReader[metrics-reader]
        CR_Editor[llsd-editor-role]
        CR_Viewer[llsd-viewer-role]
        R_LeaderElection[leader-election-role<br/>Role - not ClusterRole]
    end

    subgraph "API Resources - LlamaStack"
        LLSD[llamastack.io<br/>LlamaStackDistribution]
        LLSD_Status[llamastack.io<br/>LlamaStackDistribution/status]
        LLSD_Finalizers[llamastack.io<br/>LlamaStackDistribution/finalizers]
    end

    subgraph "API Resources - Core"
        Deployments[apps<br/>Deployments]
        Services[core<br/>Services]
        ServiceAccounts[core<br/>ServiceAccounts]
        PVCs[core<br/>PersistentVolumeClaims]
        ConfigMaps[core<br/>ConfigMaps]
        Endpoints[core<br/>Endpoints]
        Pods[core<br/>Pods]
    end

    subgraph "API Resources - Networking"
        Ingresses[networking.k8s.io<br/>Ingresses]
        NetworkPolicies[networking.k8s.io<br/>NetworkPolicies]
    end

    subgraph "API Resources - RBAC"
        ClusterRoleBindings[rbac.authorization.k8s.io<br/>ClusterRoleBindings]
        ClusterRoles[rbac.authorization.k8s.io<br/>ClusterRoles]
    end

    subgraph "API Resources - Auth"
        TokenReviews[authentication.k8s.io<br/>TokenReviews]
        SubjectAccessReviews[authorization.k8s.io<br/>SubjectAccessReviews]
    end

    subgraph "API Resources - Security"
        SCC[security.openshift.io<br/>SecurityContextConstraints<br/>resourceName: anyuid]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| CRB_AuthProxy
    SA -->|bound via| RB_LeaderElection

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_LeaderElection -->|grants| R_LeaderElection

    %% manager-role Permissions
    CR_Manager -->|get,list,watch,create,update,patch,delete| LLSD
    CR_Manager -->|get,update,patch| LLSD_Status
    CR_Manager -->|update| LLSD_Finalizers
    CR_Manager -->|get,list,watch,create,update,patch,delete| Deployments
    CR_Manager -->|get,list,watch,create,update,patch,delete| Services
    CR_Manager -->|get,list,watch,create,update,patch,delete| ServiceAccounts
    CR_Manager -->|get,list,watch,create| PVCs
    CR_Manager -->|get,list,watch,create,update,patch| ConfigMaps
    CR_Manager -->|get,list,watch,create,update,patch,delete| Ingresses
    CR_Manager -->|get,list,watch,create,update,patch,delete| NetworkPolicies
    CR_Manager -->|get,list,watch,create,update,patch,delete| ClusterRoleBindings
    CR_Manager -->|get,list,watch| ClusterRoles
    CR_Manager -->|use| SCC

    %% auth-proxy-role Permissions
    CR_AuthProxy -->|create| TokenReviews
    CR_AuthProxy -->|create| SubjectAccessReviews

    %% metrics-reader Permissions
    CR_MetricsReader -->|get,list,watch| Endpoints
    CR_MetricsReader -->|get,list,watch| Services
    CR_MetricsReader -->|get,list,watch| Pods

    %% User-facing Roles
    CR_Editor -->|get,list,watch,create,update,patch,delete| LLSD
    CR_Viewer -->|get,list,watch| LLSD

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_MetricsReader fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Editor fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_Viewer fill:#7ed321,stroke:#333,stroke-width:2px
    style R_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px

    style LLSD fill:#e8e8e8,stroke:#333,stroke-width:1px
    style LLSD_Status fill:#e8e8e8,stroke:#333,stroke-width:1px
    style LLSD_Finalizers fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Deployments fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Services fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ServiceAccounts fill:#e8e8e8,stroke:#333,stroke-width:1px
    style PVCs fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ConfigMaps fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Ingresses fill:#e8e8e8,stroke:#333,stroke-width:1px
    style NetworkPolicies fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ClusterRoleBindings fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ClusterRoles fill:#e8e8e8,stroke:#333,stroke-width:1px
    style TokenReviews fill:#e8e8e8,stroke:#333,stroke-width:1px
    style SubjectAccessReviews fill:#e8e8e8,stroke:#333,stroke-width:1px
    style SCC fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Endpoints fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Pods fill:#e8e8e8,stroke:#333,stroke-width:1px
