graph LR
    ModelMesh[ModelMesh Serving<br/>Operator]

    %% External Dependencies (Required)
    ModelMesh -->|"model metadata<br/>cluster coordination<br/>2379 gRPC/HTTP"| ETCD[ETCD v3.5.9<br/>REQUIRED]
    ModelMesh -->|"container orchestration<br/>6443 HTTPS"| K8s[Kubernetes 1.28+<br/>REQUIRED]

    %% External Dependencies (Optional)
    ModelMesh -.->|"webhook TLS certs<br/>auto-provisioning"| CertManager[cert-manager Latest<br/>OPTIONAL]
    ModelMesh -.->|"ServiceMonitor CRD<br/>metrics collection"| PromOperator[Prometheus Operator v0.55.0<br/>OPTIONAL]

    %% Internal ODH/RHOAI Dependencies
    ModelMesh -->|"shared CRD schema<br/>InferenceService v1beta1"| KServe[KServe<br/>CRD Schema]
    ModelMesh -->|"model artifact storage<br/>443 HTTPS<br/>AWS Signature V4"| S3[Object Storage S3<br/>Model Artifacts]
    ModelMesh -.->|"mTLS, traffic mgmt<br/>optional integration"| ServiceMesh[OpenShift Service Mesh<br/>OPTIONAL]

    %% Integration Points (consumers)
    Dashboard[ODH Dashboard] -.->|"UI for managing<br/>InferenceServices"| ModelMesh
    Pipelines[Data Science Pipelines] -.->|"automated model<br/>deployment"| ModelMesh

    %% Runtime Dependencies
    ModelMesh -->|"inference execution"| Runtimes[Model Runtimes<br/>Triton/MLServer/OpenVINO/TorchServe]
    ModelMesh -->|"metrics collection<br/>8443, 2112"| Prometheus[Prometheus<br/>Monitoring]

    %% Platform Services
    ModelMesh -->|"API calls<br/>resource mgmt"| K8sAPI[Kubernetes API Server<br/>6443 HTTPS]

