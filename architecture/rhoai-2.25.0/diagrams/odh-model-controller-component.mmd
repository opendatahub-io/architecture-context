graph TB
    subgraph "ODH Model Controller"
        direction TB

        subgraph "Reconcilers"
            ISvcCtrl[InferenceService Controller]
            IGraphCtrl[InferenceGraph Controller]
            LLMCtrl[LLMInferenceService Controller]
            NIMCtrl[NIM Account Controller]
            SRCtrl[ServingRuntime Controller]
            CMCtrl[ConfigMap Controller]
            SecCtrl[Secret Controller]
            PodCtrl[Pod Controller]
        end

        subgraph "Admission Webhooks"
            PodWebhook[Pod Mutating Webhook]
            ISvcWebhook[InferenceService Webhook]
            IGraphWebhook[InferenceGraph Webhook]
            NIMWebhook[NIM Account Webhook]
            KnativeWebhook[Knative Service Webhook]
        end

        subgraph "HTTP Endpoints"
            Metrics[Metrics Server<br/>8080/TCP HTTP]
            Health[Health Probe Server<br/>8081/TCP HTTP]
        end
    end

    subgraph "Custom Resources Created"
        NIMAccount[NIM Account CR<br/>nim.opendatahub.io/v1]
    end

    subgraph "External CRDs Watched"
        InferenceService[InferenceService<br/>serving.kserve.io/v1beta1]
        InferenceGraph[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        LLMInferenceService[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
        KnativeService[Knative Service<br/>serving.knative.dev/v1]
    end

    subgraph "Managed Resources (per InferenceService)"
        Route[OpenShift Route<br/>HTTPS/443]
        VirtualService[Istio VirtualService]
        Gateway[Istio Gateway]
        PeerAuth[Istio PeerAuthentication]
        Telemetry[Istio Telemetry]
        AuthConfig[Authorino AuthConfig]
        ServiceMonitor[Prometheus ServiceMonitor]
        NetworkPolicy[NetworkPolicy]
    end

    subgraph "External Dependencies"
        KServe[KServe Controller]
        Istio[Istio/Maistra Service Mesh]
        Authorino[Authorino]
        Prometheus[Prometheus Operator]
        KEDA[KEDA]
        NGC[NVIDIA NGC API]
    end

    subgraph "Internal ODH Dependencies"
        DSC[DataScienceCluster]
        DSCInit[DSCInitialization]
        ModelRegistry[Model Registry]
    end

    %% Reconciler watches
    InferenceService -->|watched by| ISvcCtrl
    InferenceGraph -->|watched by| IGraphCtrl
    LLMInferenceService -->|watched by| LLMCtrl
    NIMAccount -->|watched by| NIMCtrl
    ServingRuntime -->|watched by| SRCtrl

    %% Webhook validation
    InferenceService -.->|validated/mutated by| ISvcWebhook
    InferenceGraph -.->|validated/mutated by| IGraphWebhook
    NIMAccount -.->|validated by| NIMWebhook
    KnativeService -.->|validated by| KnativeWebhook

    %% Reconciler creates resources
    ISvcCtrl -->|creates| Route
    ISvcCtrl -->|creates| VirtualService
    ISvcCtrl -->|creates| AuthConfig
    ISvcCtrl -->|creates| ServiceMonitor
    ISvcCtrl -->|creates| NetworkPolicy
    ISvcCtrl -->|creates| PeerAuth
    ISvcCtrl -->|creates| Telemetry

    %% NIM Account controller
    NIMCtrl -->|creates| ServingRuntime
    NIMCtrl -->|calls| NGC

    %% External integrations
    ISvcCtrl -.->|coordinates with| KServe
    ISvcCtrl -->|uses| Istio
    ISvcCtrl -.->|creates| Authorino
    ISvcCtrl -.->|creates| Prometheus

    %% Internal ODH integrations
    ISvcCtrl -.->|reads config| DSC
    ISvcCtrl -.->|reads config| DSCInit
    ISvcCtrl -.->|registers metadata| ModelRegistry

    %% Metrics
    Metrics -.->|scraped by| Prometheus

    style ISvcCtrl fill:#4a90e2,stroke:#333,stroke-width:2px
    style ISvcWebhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style NIMCtrl fill:#4a90e2,stroke:#333,stroke-width:2px
    style NIMAccount fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceService fill:#f5a623,stroke:#333,stroke-width:2px
    style Route fill:#7ed321,stroke:#333,stroke-width:2px
    style VirtualService fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style Authorino fill:#999,stroke:#333
    style ModelRegistry fill:#50e3c2,stroke:#333
    style NGC fill:#999,stroke:#333
