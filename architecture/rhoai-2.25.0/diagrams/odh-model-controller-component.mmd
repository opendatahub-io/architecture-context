graph TB
    subgraph "ODH Model Controller"
        direction TB

        subgraph "Reconcilers"
            ISController[InferenceService Controller]
            IGController[InferenceGraph Controller]
            LLMController[LLMInferenceService Controller]
            NIMController[NIM Account Controller]
            SRController[ServingRuntime Controller]
            CMController[ConfigMap Controller]
            SecretController[Secret Controller]
            PodController[Pod Controller]
        end

        subgraph "Admission Webhooks"
            PodMutate[Pod Mutating Webhook]
            ISMutate[InferenceService Webhook<br/>Mutate/Validate]
            IGWebhook[InferenceGraph Webhook<br/>Mutate/Validate]
            NIMWebhook[NIM Account Webhook<br/>Validate]
            KnativeWebhook[Knative Service Webhook<br/>Validate]
        end

        subgraph "HTTP Endpoints"
            Metrics[Metrics Server<br/>8080/TCP HTTP]
            Health[Health Probes<br/>8081/TCP HTTP]
        end
    end

    subgraph "Watched CRDs"
        InferenceService[KServe InferenceService]
        InferenceGraph[KServe InferenceGraph]
        LLMInferenceService[KServe LLMInferenceService]
        ServingRuntime[KServe ServingRuntime]
        KnativeService[Knative Service]
    end

    subgraph "Owned CRDs"
        NIMAccount[NIM Account<br/>nim.opendatahub.io/v1]
    end

    subgraph "Created Resources"
        direction LR
        Route[OpenShift Route]
        VirtualService[Istio VirtualService]
        Gateway[Istio Gateway]
        PeerAuth[Istio PeerAuthentication]
        AuthConfig[Authorino AuthConfig]
        AuthPolicy[Kuadrant AuthPolicy]
        ServiceMonitor[Prometheus ServiceMonitor]
        PodMonitor[Prometheus PodMonitor]
        NetworkPolicy[NetworkPolicy]
        Secret[Secret - Pull/TLS/Token]
        ConfigMap[ConfigMap - NIM Models]
        Template[OpenShift Template]
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh]
        KServe[KServe Operator]
        Authorino[Authorino]
        Prometheus[Prometheus Operator]
        KEDA[KEDA]
        NGC[NVIDIA NGC API]
        ModelRegistry[Model Registry]
    end

    subgraph "OpenShift Platform"
        K8sAPI[Kubernetes API Server<br/>6443/TCP]
        RouteAPI[OpenShift Route API]
        TemplateAPI[OpenShift Template API]
    end

    %% Watched Resources
    InferenceService -->|watched by| ISController
    InferenceGraph -->|watched by| IGController
    LLMInferenceService -->|watched by| LLMController
    ServingRuntime -->|watched by| SRController
    NIMAccount -->|watched by| NIMController
    KnativeService -->|validated by| KnativeWebhook

    %% Webhooks
    K8sAPI -->|POST 443/TCP HTTPS mTLS| PodMutate
    K8sAPI -->|POST 443/TCP HTTPS mTLS| ISMutate
    K8sAPI -->|POST 443/TCP HTTPS mTLS| IGWebhook
    K8sAPI -->|POST 443/TCP HTTPS mTLS| NIMWebhook
    K8sAPI -->|POST 443/TCP HTTPS mTLS| KnativeWebhook

    %% Resource Creation
    ISController -->|creates| Route
    ISController -->|creates| VirtualService
    ISController -->|updates| Gateway
    ISController -->|creates| PeerAuth
    ISController -->|creates| AuthConfig
    ISController -->|creates| AuthPolicy
    ISController -->|creates| ServiceMonitor
    ISController -->|creates| PodMonitor
    ISController -->|creates| NetworkPolicy

    NIMController -->|creates| Secret
    NIMController -->|creates| ConfigMap
    NIMController -->|creates| Template

    %% External Integrations
    ISController -->|integrates| Istio
    ISController -->|integrates| Authorino
    ISController -->|integrates| Prometheus
    ISController -->|integrates| KEDA
    NIMController -->|API calls| NGC
    ISController -->|registers metadata| ModelRegistry

    %% Platform APIs
    ISController -->|HTTPS/6443 TLS1.3| K8sAPI
    ISController -->|uses| RouteAPI
    NIMController -->|uses| TemplateAPI

    %% Coordination
    ISController -.->|coordinates with| KServe

    %% Monitoring
    Prometheus -->|scrapes 8080/TCP HTTP| Metrics

