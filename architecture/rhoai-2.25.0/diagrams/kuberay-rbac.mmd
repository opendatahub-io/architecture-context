graph TD
    subgraph "Service Accounts"
        OpSA[kuberay-operator<br/>Namespace: opendatahub]
        HeadSA["{cluster}-ray-head<br/>Namespace: user-namespace"]
        WorkerSA["{cluster}-ray-worker<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole Bindings"
        OpCRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole: kuberay-operator"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        Pods["Pods<br/>create, delete, deletecollection,<br/>get, list, patch, update, watch"]
        PodsProxy["Pods/Proxy<br/>create, get, patch, update"]
        PodsStatus["Pods/Status<br/>create, delete, get, list,<br/>patch, update, watch"]
        Services["Services<br/>create, delete, get, list,<br/>patch, update, watch"]
        ServicesProxy["Services/Proxy<br/>create, get, patch, update"]
        ServicesStatus["Services/Status<br/>get, patch, update"]
        ServiceAccounts["ServiceAccounts<br/>create, delete, get, list, watch"]
        Events["Events<br/>create, delete, get, list,<br/>patch, update, watch"]
        Endpoints["Endpoints<br/>get, list, watch"]
    end

    subgraph "API Resources - Batch"
        Jobs["Jobs<br/>batch<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Ray CRDs"
        RayClusters["RayClusters<br/>ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayJobs["RayJobs<br/>ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayServices["RayServices<br/>ray.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayStatus["RayCluster/Job/Service<br/>Status, Finalizers<br/>get, patch, update"]
    end

    subgraph "API Resources - Networking"
        Ingresses["Ingresses<br/>networking.k8s.io<br/>create, delete, get, list,<br/>patch, update, watch"]
        IngressClasses["IngressClasses<br/>networking.k8s.io<br/>get, list, watch"]
        Routes["Routes<br/>route.openshift.io<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - RBAC"
        Roles["Roles<br/>rbac.authorization.k8s.io<br/>create, delete, get, list,<br/>update, watch"]
        RoleBindings["RoleBindings<br/>rbac.authorization.k8s.io<br/>create, delete, get, list, watch"]
    end

    subgraph "API Resources - Coordination"
        Leases["Leases<br/>coordination.k8s.io<br/>create, get, list, update"]
    end

    subgraph "Ray Head Autoscaler Permissions"
        HeadPods["Pods (same namespace)<br/>create, delete, get, list, watch"]
    end

    %% Operator RBAC Flow
    OpSA -->|bound via| OpCRB
    OpCRB -->|grants| CR

    CR -->|full CRUD| Pods
    CR -->|proxy access| PodsProxy
    CR -->|status mgmt| PodsStatus
    CR -->|full CRUD| Services
    CR -->|proxy access| ServicesProxy
    CR -->|status mgmt| ServicesStatus
    CR -->|full CRUD| ServiceAccounts
    CR -->|full CRUD| Events
    CR -->|read-only| Endpoints

    CR -->|full CRUD| Jobs

    CR -->|full CRUD| RayClusters
    CR -->|full CRUD| RayJobs
    CR -->|full CRUD| RayServices
    CR -->|status/finalizers| RayStatus

    CR -->|full CRUD| Ingresses
    CR -->|read-only| IngressClasses
    CR -->|full CRUD| Routes

    CR -->|full CRUD| Roles
    CR -->|full CRUD| RoleBindings

    CR -->|leader election| Leases

    %% Ray Head Autoscaler Flow
    HeadSA -->|limited RBAC| HeadPods

    %% Styling
    style OpSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style HeadSA fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerSA fill:#7ed321,stroke:#333,stroke-width:2px

    style OpCRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style Pods fill:#dae8fc,stroke:#333
    style PodsProxy fill:#dae8fc,stroke:#333
    style PodsStatus fill:#dae8fc,stroke:#333
    style Services fill:#dae8fc,stroke:#333
    style ServicesProxy fill:#dae8fc,stroke:#333
    style ServicesStatus fill:#dae8fc,stroke:#333
    style ServiceAccounts fill:#dae8fc,stroke:#333
    style Events fill:#dae8fc,stroke:#333
    style Endpoints fill:#dae8fc,stroke:#333

    style Jobs fill:#fff2cc,stroke:#333

    style RayClusters fill:#e1d5e7,stroke:#333
    style RayJobs fill:#e1d5e7,stroke:#333
    style RayServices fill:#e1d5e7,stroke:#333
    style RayStatus fill:#e1d5e7,stroke:#333

    style Ingresses fill:#d5e8d4,stroke:#333
    style IngressClasses fill:#d5e8d4,stroke:#333
    style Routes fill:#d5e8d4,stroke:#333

    style Roles fill:#f8cecc,stroke:#333
    style RoleBindings fill:#f8cecc,stroke:#333

    style Leases fill:#ffd966,stroke:#333

    style HeadPods fill:#7ed321,stroke:#333
