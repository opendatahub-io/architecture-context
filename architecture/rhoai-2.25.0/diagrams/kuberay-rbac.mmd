graph TD
    subgraph "Service Account"
        SA[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[kuberay-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources (api group: '')"
        Pods[Pods<br/>create, delete, deletecollection,<br/>get, list, patch, update, watch]
        PodsProxy[Pods/Proxy<br/>Services/Proxy<br/>create, get, patch, update]
        PodsStatus[Pods/Status<br/>create, delete, get, list,<br/>patch, update, watch]
        Services[Services<br/>create, delete, get, list,<br/>patch, update, watch]
        ServicesStatus[Services/Status<br/>get, patch, update]
        ServiceAccounts[ServiceAccounts<br/>create, delete, get, list, watch]
        Events[Events<br/>create, delete, get, list,<br/>patch, update, watch]
        Endpoints[Endpoints<br/>get, list, watch]
    end

    subgraph "Batch API Resources (batch)"
        Jobs[Jobs<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "Ray API Resources (ray.io)"
        RayClusters[RayClusters<br/>create, delete, get, list,<br/>patch, update, watch]
        RayJobs[RayJobs<br/>create, delete, get, list,<br/>patch, update, watch]
        RayServices[RayServices<br/>create, delete, get, list,<br/>patch, update, watch]
        RayStatus[RayClusters/Status<br/>RayJobs/Status<br/>RayServices/Status<br/>get, patch, update]
        RayFinalizers[RayClusters/Finalizers<br/>RayJobs/Finalizers<br/>RayServices/Finalizers<br/>update]
    end

    subgraph "Networking API Resources (networking.k8s.io)"
        Ingresses[Ingresses<br/>create, delete, get, list,<br/>patch, update, watch]
        IngressClasses[IngressClasses<br/>get, list, watch]
    end

    subgraph "OpenShift Route API (route.openshift.io)"
        Routes[Routes<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "RBAC API Resources (rbac.authorization.k8s.io)"
        Roles[Roles<br/>create, delete, get, list,<br/>update, watch]
        RoleBindings[RoleBindings<br/>create, delete, get, list, watch]
    end

    subgraph "Coordination API Resources (coordination.k8s.io)"
        Leases[Leases<br/>create, get, list, update]
    end

    %% Relationships
    SA -->|bound via| CRB
    CRB -->|grants permissions| CR

    CR -->|manages| Pods
    CR -->|manages| PodsProxy
    CR -->|manages| PodsStatus
    CR -->|manages| Services
    CR -->|manages| ServicesStatus
    CR -->|manages| ServiceAccounts
    CR -->|manages| Events
    CR -->|manages| Endpoints

    CR -->|manages| Jobs

    CR -->|manages| RayClusters
    CR -->|manages| RayJobs
    CR -->|manages| RayServices
    CR -->|manages| RayStatus
    CR -->|manages| RayFinalizers

    CR -->|manages| Ingresses
    CR -->|manages| IngressClasses

    CR -->|manages| Routes

    CR -->|manages| Roles
    CR -->|manages| RoleBindings

    CR -->|manages| Leases

