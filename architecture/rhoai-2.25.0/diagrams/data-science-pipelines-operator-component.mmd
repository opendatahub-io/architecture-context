graph TB
    subgraph "Data Science Pipelines Operator (DSPO)"
        Controller[DSPO Controller<br/>Kubernetes Operator]
        Webhook[Webhook Server<br/>Admission Controller]
        Controller -->|manages| Webhook
    end

    subgraph "DSPA Instance Components (per namespace)"
        APIServer[API Server<br/>HTTP/gRPC Service<br/>8888/8887/TCP]
        PersistAgent[Persistence Agent<br/>Background Service]
        ScheduledWF[Scheduled Workflow Controller<br/>Background Service]
        WorkflowCtrl[Workflow Controller<br/>Argo Controller]

        APIServer -->|status sync| PersistAgent
        APIServer -->|schedules| ScheduledWF
        WorkflowCtrl -->|executes| APIServer
    end

    subgraph "Optional Components"
        MariaDB[MariaDB<br/>3306/TCP]
        Minio[Minio<br/>9000/TCP]
        UI[ML Pipelines UI<br/>Web Frontend]
        MLMDEnvoy[MLMD Envoy<br/>Proxy 9090/TCP]
        MLMDgRPC[MLMD gRPC<br/>8080/TCP]
    end

    subgraph "Custom Resources"
        DSPA[DataSciencePipelinesApplication CR<br/>v1]
        Pipeline[Pipeline CR<br/>v1]
        PipelineVersion[PipelineVersion CR<br/>v1]
        Workflow[Workflow CR<br/>v1alpha1]
    end

    User[Data Scientist] -->|creates| DSPA
    DSPA -->|watched by| Controller
    Controller -->|reconciles| APIServer
    Controller -->|creates| PersistAgent
    Controller -->|creates| ScheduledWF
    Controller -->|creates| WorkflowCtrl
    Controller -->|optionally deploys| MariaDB
    Controller -->|optionally deploys| Minio
    Controller -->|optionally deploys| UI
    Controller -->|optionally deploys| MLMDEnvoy
    Controller -->|optionally deploys| MLMDgRPC

    User -->|creates| Pipeline
    User -->|creates| PipelineVersion
    Pipeline -->|validated by| Webhook
    PipelineVersion -->|validated by| Webhook

    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    PersistAgent -->|updates| MariaDB
    MLMDgRPC -->|stores lineage| MariaDB
    MLMDEnvoy -->|proxies to| MLMDgRPC

    WorkflowCtrl -->|creates| Workflow
    APIServer -->|manages| Workflow

    subgraph "External Dependencies"
        ArgoWF[Argo Workflows 3.5.14]
        K8sAPI[Kubernetes API Server]
        S3External[External S3 Storage]
        DBExternal[External Database]
    end

    Controller -->|uses| ArgoWF
    Controller -->|watches via| K8sAPI
    APIServer -->|alternative storage| S3External
    APIServer -->|alternative DB| DBExternal

    subgraph "Integration Points"
        KServe[KServe]
        Ray[Ray]
        ODHDashboard[ODH Dashboard]
    end

    APIServer -->|integrates| KServe
    APIServer -->|integrates| Ray
    UI -->|embedded in| ODHDashboard

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:3px
    style DSPA fill:#f5a623,stroke:#333,stroke-width:2px
    style Pipeline fill:#f5a623,stroke:#333,stroke-width:2px
    style PipelineVersion fill:#f5a623,stroke:#333,stroke-width:2px
    style Workflow fill:#f5a623,stroke:#333,stroke-width:2px
    style ArgoWF fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style S3External fill:#999,stroke:#333
    style DBExternal fill:#999,stroke:#333
    style MariaDB fill:#e8e8e8,stroke:#333
    style Minio fill:#e8e8e8,stroke:#333
    style UI fill:#e8e8e8,stroke:#333
    style MLMDEnvoy fill:#e8e8e8,stroke:#333
    style MLMDgRPC fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Ray fill:#7ed321,stroke:#333
    style ODHDashboard fill:#7ed321,stroke:#333
