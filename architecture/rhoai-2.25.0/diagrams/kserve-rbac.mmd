graph TD
    subgraph "Service Account"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB[kserve-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "API Resources - KServe CRDs"
        ISVC[serving.kserve.io<br/>InferenceService<br/>ServingRuntime<br/>TrainedModel<br/>InferenceGraph<br/>LLMInferenceService]
        ISVCStatus[serving.kserve.io<br/>*/status]
        LocalModel[serving.kserve.io<br/>LocalModelCache]
    end

    subgraph "API Resources - Knative"
        KnativeService[serving.knative.dev<br/>Service]
        KnativeStatus[serving.knative.dev<br/>Service/status]
    end

    subgraph "API Resources - Istio"
        IstioVS[networking.istio.io<br/>VirtualService<br/>DestinationRule]
    end

    subgraph "API Resources - Kubernetes Core"
        CoreApps[apps<br/>Deployment]
        CoreAutoscaling[autoscaling<br/>HorizontalPodAutoscaler]
        CoreResources["core<br/>Service<br/>Secret<br/>ServiceAccount<br/>ConfigMap<br/>Event"]
        CoreReadOnly["core<br/>Namespace<br/>Pod<br/>read-only"]
    end

    subgraph "API Resources - Networking"
        Ingress[networking.k8s.io<br/>Ingress]
        Route[route.openshift.io<br/>Route]
        Gateway[gateway.networking.k8s.io<br/>HTTPRoute<br/>Gateway]
    end

    subgraph "API Resources - Advanced"
        KEDA[keda.sh<br/>ScaledObject]
        OTel[opentelemetry.io<br/>OpenTelemetryCollector]
        Monitoring[monitoring.coreos.com<br/>ServiceMonitor<br/>PodMonitor]
        Webhooks[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration<br/>ValidatingWebhookConfiguration]
        RBAC[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>RoleBinding<br/>Role]
        SCC[security.openshift.io<br/>SecurityContextConstraints]
        LeaderWorkerSet[leaderworkerset.x-k8s.io<br/>LeaderWorkerSet]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions - KServe CRDs
    CR -->|"create, delete, get, list<br/>patch, update, watch"| ISVC
    CR -->|"get, patch, update"| ISVCStatus
    CR -->|"get, list, watch"| LocalModel

    %% Permissions - Knative
    CR -->|"create, delete, get, list<br/>patch, update, watch"| KnativeService
    CR -->|"get, patch, update"| KnativeStatus

    %% Permissions - Istio
    CR -->|"create, delete, get, list<br/>patch, update, watch"| IstioVS

    %% Permissions - Kubernetes Core
    CR -->|"create, delete, get, list<br/>patch, update, watch"| CoreApps
    CR -->|"create, delete, get, list<br/>patch, update, watch"| CoreAutoscaling
    CR -->|"create, delete, get, list<br/>patch, update, watch"| CoreResources
    CR -->|"get, list, watch"| CoreReadOnly

    %% Permissions - Networking
    CR -->|"create, delete, get, list<br/>patch, update, watch"| Ingress
    CR -->|"create, delete, get, list<br/>patch, update, watch"| Route
    CR -->|"create, delete, get, list<br/>patch, update, watch"| Gateway

    %% Permissions - Advanced
    CR -->|"create, delete, get, list<br/>patch, update, watch"| KEDA
    CR -->|"create, delete, get, list<br/>patch, update, watch"| OTel
    CR -->|"create, delete, get, list<br/>patch, update, watch"| Monitoring
    CR -->|"create, delete, get, list<br/>patch, update, watch"| Webhooks
    CR -->|"create, delete, get, list<br/>patch, update, watch"| RBAC
    CR -->|"use (openshift-ai-llminferenceservice-scc)"| SCC
    CR -->|"create, delete, get, list<br/>patch, update, watch"| LeaderWorkerSet

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style ISVC fill:#7ed321,stroke:#333,stroke-width:2px
    style ISVCStatus fill:#7ed321,stroke:#333,stroke-width:2px
    style LocalModel fill:#7ed321,stroke:#333,stroke-width:2px
    style KnativeService fill:#9b59b6,stroke:#333,stroke-width:2px
    style KnativeStatus fill:#9b59b6,stroke:#333,stroke-width:2px
    style IstioVS fill:#e74c3c,stroke:#333,stroke-width:2px
    style CoreApps fill:#3498db,stroke:#333,stroke-width:2px
    style CoreAutoscaling fill:#3498db,stroke:#333,stroke-width:2px
    style CoreResources fill:#3498db,stroke:#333,stroke-width:2px
    style CoreReadOnly fill:#95a5a6,stroke:#333,stroke-width:2px
    style Ingress fill:#16a085,stroke:#333,stroke-width:2px
    style Route fill:#16a085,stroke:#333,stroke-width:2px
    style Gateway fill:#16a085,stroke:#333,stroke-width:2px
    style KEDA fill:#e67e22,stroke:#333,stroke-width:2px
    style OTel fill:#e67e22,stroke:#333,stroke-width:2px
    style Monitoring fill:#e67e22,stroke:#333,stroke-width:2px
    style Webhooks fill:#e67e22,stroke:#333,stroke-width:2px
    style RBAC fill:#e67e22,stroke:#333,stroke-width:2px
    style SCC fill:#e67e22,stroke:#333,stroke-width:2px
    style LeaderWorkerSet fill:#e67e22,stroke:#333,stroke-width:2px
