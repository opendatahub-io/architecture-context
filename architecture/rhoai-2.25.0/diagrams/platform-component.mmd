graph TB
    subgraph "User Interface Layer"
        Dashboard["ODH Dashboard<br/>v1.21.0-18<br/>Web UI"]
    end

    subgraph "Development Environment"
        NotebookController["Kubeflow Notebook Controller<br/>v1.27.0<br/>Jupyter/VS Code/RStudio"]
        NotebookImages["Notebook Images<br/>v2.25.2<br/>JupyterLab, VS Code, RStudio"]
        NotebookController -->|deploys| NotebookImages
    end

    subgraph "Model Serving Layer"
        KServe["KServe Operator<br/>4211a5da7<br/>Serverless Inference"]
        ModelMesh["ModelMesh Serving<br/>1.27.0<br/>Multi-Model Serving"]
        ODHModelController["ODH Model Controller<br/>1.27.0<br/>Routes, Auth, Monitoring"]
        LlamaStack["Llama Stack Operator<br/>0.3.0<br/>LLM Inference"]

        KServe -->|integrates| ODHModelController
        ModelMesh -->|integrates| ODHModelController
    end

    subgraph "Training & Distributed Compute"
        TrainingOp["Training Operator<br/>1.9.0<br/>PyTorch, TF, XGBoost, MPI"]
        KubeRay["KubeRay Operator<br/>f10d68b1<br/>Ray Clusters"]
        CodeFlare["CodeFlare Operator<br/>1.15.0<br/>Distributed Workloads"]

        CodeFlare -->|manages| KubeRay
    end

    subgraph "Pipeline Orchestration"
        DSPA["Data Science Pipelines Operator<br/>rhoai-2.25<br/>Kubeflow Pipelines"]
    end

    subgraph "Resource Management"
        Kueue["Kueue<br/>7f2f72e51<br/>Job Queueing & Quotas"]

        Kueue -->|manages| TrainingOp
        Kueue -->|manages| KubeRay
        Kueue -->|manages| CodeFlare
        Kueue -->|manages| DSPA
    end

    subgraph "Model Lifecycle Management"
        ModelRegistry["Model Registry Operator<br/>0b48221<br/>Metadata & Versioning"]
        Feast["Feast Operator<br/>0.54.0<br/>Feature Store"]
    end

    subgraph "AI Governance"
        TrustyAI["TrustyAI Service Operator<br/>d113dae<br/>Explainability & Bias Detection"]

        TrustyAI -->|monitors| KServe
        TrustyAI -->|monitors| ModelMesh
    end

    subgraph "External Dependencies"
        Istio["Istio/Maistra<br/>Service Mesh"]
        Knative["Knative Serving<br/>Serverless Platform"]
        OpenShift["OpenShift Container Platform 4.11+<br/>OAuth, Routes, Monitoring"]
        S3["S3-Compatible Storage<br/>Models & Artifacts"]
        Database["PostgreSQL/MySQL<br/>Metadata Backend"]
    end

    %% Dashboard connections
    Dashboard -->|creates| NotebookController
    Dashboard -->|creates| KServe
    Dashboard -->|creates| ModelRegistry
    Dashboard -->|creates| DSPA
    Dashboard -->|creates| TrainingOp

    %% Model serving dependencies
    KServe -->|requires| Knative
    KServe -->|requires| Istio
    KServe -->|integrates| ModelRegistry
    KServe -->|loads from| S3

    ModelMesh -->|loads from| S3
    ModelMesh -->|uses| Database

    ODHModelController -->|creates| Istio
    ODHModelController -->|creates| OpenShift

    %% Pipeline dependencies
    DSPA -->|deploys to| KServe
    DSPA -->|registers| ModelRegistry
    DSPA -->|stores in| S3
    DSPA -->|uses| Database

    %% Training dependencies
    TrainingOp -->|stores in| ModelRegistry
    TrainingOp -->|stores in| S3

    %% Feature store dependencies
    Feast -->|uses| Database
    Feast -->|uses| S3
    KServe -->|fetches features| Feast

    %% LLM serving
    LlamaStack -->|uses| OpenShift

    %% Registry dependencies
    ModelRegistry -->|uses| Database
    ModelRegistry -->|uses| OpenShift

    %% Styling
    classDef uiLayer fill:#4a90e2,stroke:#2d5f8d,stroke-width:2px,color:#fff
    classDef servingLayer fill:#7ed321,stroke:#5a9b19,stroke-width:2px,color:#fff
    classDef trainingLayer fill:#f5a623,stroke:#c17d11,stroke-width:2px,color:#fff
    classDef pipelineLayer fill:#bd10e0,stroke:#8b0aa8,stroke-width:2px,color:#fff
    classDef resourceLayer fill:#50e3c2,stroke:#3ab39a,stroke-width:2px,color:#fff
    classDef mlopsLayer fill:#ff6b6b,stroke:#cc5555,stroke-width:2px,color:#fff
    classDef governanceLayer fill:#4ecdc4,stroke:#3a9d96,stroke-width:2px,color:#fff
    classDef externalDep fill:#e8e8e8,stroke:#999,stroke-width:2px,color:#333

    class Dashboard uiLayer
    class NotebookController,NotebookImages uiLayer
    class KServe,ModelMesh,ODHModelController,LlamaStack servingLayer
    class TrainingOp,KubeRay,CodeFlare trainingLayer
    class DSPA pipelineLayer
    class Kueue resourceLayer
    class ModelRegistry,Feast mlopsLayer
    class TrustyAI governanceLayer
    class Istio,Knative,OpenShift,S3,Database externalDep
