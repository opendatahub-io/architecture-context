graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Application /<br/>Training Job /<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Router)"]
        RouteOnline["OpenShift Route - Online<br/>{name}-online-{namespace}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteOffline["OpenShift Route - Offline<br/>{name}-offline-{namespace}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteRegistry["OpenShift Route - Registry<br/>{name}-registry-{namespace}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Re-encrypt"]
        RouteUI["OpenShift Route - UI<br/>{name}-ui-{namespace}.apps.{cluster}<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Re-encrypt"]
    end

    subgraph ClusterInternal["INTERNAL CLUSTER NETWORK"]
        subgraph NS_Operator["Namespace: redhat-ods-applications / opendatahub"]
            Operator["Feast Operator<br/>SA: feast-operator-controller-manager<br/>Image: odh-feast-operator-rhel9<br/>ClusterRole: feast-operator-manager-role"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token auth"]
            Health["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OnlineSvc["Online Feature Store<br/>Service: {featurestore-name}-online<br/>80/443 → 6566/6567<br/>HTTP/HTTPS or gRPC<br/>TLS 1.2+ (optional)<br/>Auth: None/RBAC/OIDC"]
            OfflineSvc["Offline Feature Store<br/>Service: {featurestore-name}-offline<br/>80/443 → 8815/8816<br/>HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>Auth: None/RBAC/OIDC"]
            RegistrySvc["Registry Server<br/>Service: {featurestore-name}-registry<br/>80/443 → 6570/6571<br/>HTTP/HTTPS or gRPC<br/>TLS 1.2+ (optional)<br/>Auth: None/RBAC/OIDC"]
            UISvc["UI Server (Optional)<br/>Service: {featurestore-name}-ui<br/>80/443 → 8888/8443<br/>HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>Auth: None/RBAC/OIDC"]
            CronJob["CronJob - Materialization<br/>Image: origin-cli:4.17<br/>SA: {featurestore-name}-sa"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Username/Password"]
        Redis["Redis<br/>6379/TCP<br/>TLS 1.2+ (optional)<br/>Password"]
        S3["S3/GCS/Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Service Account"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth/Key Pair"]
        Git["Git Repository<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token/SSH Key"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth 2.0"]
        Prometheus["Prometheus<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443, TLS 1.2+, None/OIDC Token"| RouteOnline
    Client -->|"HTTPS/443, TLS 1.2+, None/OIDC Token"| RouteOffline
    Client -->|"HTTPS/443, TLS 1.2+, None/OIDC Token"| RouteRegistry
    Client -->|"HTTPS/443, TLS 1.2+, None/OIDC Token"| RouteUI

    %% Ingress to Services
    RouteOnline -->|"HTTP/80 or HTTPS/443, TLS 1.2+ (optional)"| OnlineSvc
    RouteOffline -->|"HTTP/80 or HTTPS/443, TLS 1.2+ (optional)"| OfflineSvc
    RouteRegistry -->|"HTTP/80 or HTTPS/443, TLS 1.2+ (optional)"| RegistrySvc
    RouteUI -->|"HTTP/80 or HTTPS/443, TLS 1.2+ (optional)"| UISvc

    %% Operator Management
    Operator -->|"HTTPS/6443, TLS 1.2+, SA Token"| K8sAPI
    Operator -.->|Creates/Manages| OnlineSvc
    Operator -.->|Creates/Manages| OfflineSvc
    Operator -.->|Creates/Manages| RegistrySvc
    Operator -.->|Creates/Manages| UISvc
    Operator -.->|Creates/Manages| CronJob

    %% Service Interactions
    OnlineSvc -->|"Query metadata, HTTP/gRPC, TLS 1.2+ (optional)"| RegistrySvc
    OfflineSvc -->|"Query metadata, HTTP/gRPC, TLS 1.2+ (optional)"| RegistrySvc
    CronJob -->|"HTTP/HTTPS, SA Token"| OnlineSvc
    CronJob -->|"HTTP/HTTPS, SA Token"| OfflineSvc

    %% External Service Connections
    OnlineSvc -->|"Redis Protocol/6379, TLS 1.2+ (optional), Password"| Redis
    OnlineSvc -->|"PostgreSQL/5432, TLS 1.2+ (optional), User/Pass"| PostgreSQL
    OfflineSvc -->|"HTTPS/443, TLS 1.2+, AWS IAM"| S3
    OfflineSvc -->|"PostgreSQL/5432, TLS 1.2+ (optional), User/Pass"| PostgreSQL
    OfflineSvc -->|"HTTPS/443, TLS 1.2+, OAuth"| Snowflake
    RegistrySvc -->|"PostgreSQL/5432, TLS 1.2+ (optional), User/Pass"| PostgreSQL
    RegistrySvc -->|"HTTPS/443, TLS 1.2+, AWS IAM"| S3
    CronJob -->|"Redis Protocol/6379, TLS 1.2+ (optional), Password"| Redis
    CronJob -->|"HTTPS/443, TLS 1.2+, Token"| Git
    OnlineSvc -->|"HTTPS/443, TLS 1.2+, OAuth 2.0"| OIDC
    OfflineSvc -->|"HTTPS/443, TLS 1.2+, OAuth 2.0"| OIDC
    RegistrySvc -->|"HTTPS/443, TLS 1.2+, OAuth 2.0"| OIDC
    UISvc -->|"HTTPS/443, TLS 1.2+, OAuth 2.0"| OIDC
    Prometheus -->|"HTTPS/8443, TLS 1.2+, Bearer Token"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef service fill:#7ed321,stroke:#333,stroke-width:2px

    class Client external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class K8sAPI,Health clusterinternal
    class PostgreSQL,Redis,S3,Snowflake,Git,OIDC,Prometheus externalservice
    class Operator,MetricsSvc operator
    class OnlineSvc,OfflineSvc,RegistrySvc,UISvc,CronJob service
