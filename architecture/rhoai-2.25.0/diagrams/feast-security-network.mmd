graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Application /<br/>Training Job /<br/>User Browser]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Routes["OpenShift Routes<br/>&lt;name&gt;-online/offline/registry/ui-&lt;ns&gt;.apps.&lt;cluster&gt;<br/>443/TCP → 80/443/TCP<br/>TLS 1.2+ Edge/Re-encrypt<br/>OIDC/RBAC optional"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER - Trusted<br/>Namespace: redhat-ods-applications / opendatahub"]
        direction TB

        subgraph Operator["Feast Operator"]
            OpMgr["Operator Manager<br/>SA: feast-operator-controller-manager<br/>Image: odh-feast-operator-rhel9"]
        end

        subgraph FeatureStoreServices["Feature Store Services - per FeatureStore CR"]
            direction TB
            Online["Online Store<br/>6566-6567/TCP HTTP/gRPC<br/>TLS 1.2+ optional<br/>OIDC/RBAC optional<br/>Image: odh-feature-server-rhel9"]
            Offline["Offline Store<br/>8815-8816/TCP HTTP/HTTPS<br/>TLS 1.2+ optional<br/>OIDC/RBAC optional<br/>Image: odh-feature-server-rhel9"]
            Registry["Registry Server<br/>6570-6571/TCP gRPC/HTTP<br/>TLS 1.2+ optional<br/>OIDC/RBAC optional<br/>Image: odh-feature-server-rhel9"]
            UI["UI Server optional<br/>8888/8443/TCP HTTP/HTTPS<br/>TLS 1.2+ optional<br/>OIDC/RBAC optional<br/>Image: odh-feature-server-rhel9"]
            CronJob["Materialization CronJob<br/>SA: &lt;featurestore-name&gt;-sa<br/>Image: origin-cli:4.17"]
        end

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Token"]

        Metrics["Operator Metrics Service<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL Wire Protocol<br/>TLS 1.2+ optional<br/>Username/Password"]
        Redis["Redis<br/>6379/TCP<br/>Redis Protocol<br/>TLS 1.2+ optional<br/>Password optional"]
        S3["S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Service Account"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth / Key Pair"]
        Git["Git Repository<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token / SSH Key"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials"]
        Prometheus["Prometheus<br/>Metrics Collection"]
    end

    %% Flows
    Client -->|"HTTPS 443<br/>TLS 1.2+<br/>OIDC Token"| Routes
    Routes -->|"HTTP/HTTPS<br/>80/443 TCP<br/>TLS 1.2+ re-encrypt"| Online
    Routes -->|"HTTP/HTTPS<br/>80/443 TCP"| Offline
    Routes -->|"HTTP/HTTPS<br/>80/443 TCP"| Registry
    Routes -->|"HTTP/HTTPS<br/>80/443 TCP"| UI

    OpMgr -->|"HTTPS 6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    OpMgr -->|manages| Online
    OpMgr -->|manages| Offline
    OpMgr -->|manages| Registry
    OpMgr -->|manages| UI
    OpMgr -->|manages| CronJob

    Online -->|"Redis 6379<br/>TLS 1.2+ opt<br/>Password"| Redis
    Online -->|"PostgreSQL 5432<br/>TLS 1.2+ opt<br/>User/Pass"| PostgreSQL
    Online -->|"gRPC/HTTP<br/>6570-6571 TCP"| Registry

    Offline -->|"HTTPS 443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Offline -->|"gRPC/HTTP<br/>6570-6571 TCP"| Registry
    Offline -->|"HTTPS 443<br/>TLS 1.2+<br/>OAuth"| Snowflake

    Registry -->|"PostgreSQL 5432<br/>TLS 1.2+ opt"| PostgreSQL
    Registry -->|"HTTPS 443<br/>TLS 1.2+<br/>AWS IAM"| S3

    CronJob -->|"HTTP/HTTPS<br/>SA Token"| Online
    CronJob -->|"HTTP/HTTPS<br/>SA Token"| Offline

    Online -.->|"OIDC Auth"| OIDC
    Offline -.->|"OIDC Auth"| OIDC
    Registry -.->|"OIDC Auth"| OIDC
    UI -.->|"OIDC Auth"| OIDC

    OpMgr -.->|"HTTPS 443<br/>Token"| Git

    Prometheus -->|"HTTPS 8443<br/>TLS 1.2+<br/>Bearer Token"| Metrics
    Metrics -.->|"exposed by"| OpMgr

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8s fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef featurestore fill:#7ed321,stroke:#333,stroke-width:2px

    class Client external
    class Routes ingress
    class OpMgr operator
    class Online,Offline,Registry,UI,CronJob featurestore
    class K8sAPI,Metrics k8s
    class PostgreSQL,Redis,S3,Snowflake,Git,OIDC,Prometheus externalservice
