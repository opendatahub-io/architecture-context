graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
        User[User/System]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route / Ingress<br/>Ray Dashboard: 8265/TCP HTTP/HTTPS<br/>Ray Serve: 8000/TCP HTTP/HTTPS<br/>TLS: Edge/Passthrough"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
        WebhookSvc["Admission Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+<br/>mTLS (K8s API cert)"]

        K8sAPI -->|mTLS| WebhookSvc
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Operator["KubeRay Operator Pod<br/>SA: kuberay-operator<br/>Image: odh-kuberay-operator-controller"]

        subgraph OpComponents["Operator Components"]
            RayClusterCtrl[RayCluster Controller]
            RayJobCtrl[RayJob Controller]
            RayServiceCtrl[RayService Controller]
            Webhook["Webhook<br/>9443/TCP HTTPS"]
            Metrics["Metrics<br/>8080/TCP HTTP"]
        end

        Operator --> OpComponents
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph RayCluster["Ray Cluster"]
            HeadPod["Ray Head Pod<br/>SA: {cluster}-ray-head<br/>━━━━━━━━━━━━━━━━<br/>GCS: 6379/TCP TCP<br/>Dashboard: 8265/TCP HTTP<br/>Client: 10001/TCP TCP<br/>Metrics: 8080/TCP HTTP<br/>Agent: 52365/TCP HTTP"]

            WorkerPods["Ray Worker Pods<br/>SA: {cluster}-ray-worker<br/>Auto-scaled<br/>Connect to GCS: 6379/TCP"]

            JobPod["Submitter Job Pod<br/>(RayJob only)<br/>Submit: 8265/TCP HTTP"]

            ServeSvc["Ray Serve Service<br/>(RayService only)<br/>8000/TCP HTTP<br/>ClusterIP"]
        end

        WorkerPods -->|TCP/6379<br/>Optional Password| HeadPod
        JobPod -->|HTTP/8265<br/>Optional Token| HeadPod
        ServeSvc -->|Route to| HeadPod
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["External Redis<br/>6379/TCP TCP<br/>Optional TLS<br/>Auth: Redis Password"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secrets"]
        Storage["Ray Package / Git / S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Configurable Auth"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>No Auth"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Optional Auth| Route
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI

    %% Ingress to Services
    Route -->|HTTP/8265| HeadPod
    Route -->|HTTP/8000| ServeSvc

    %% Control Plane Flows
    K8sAPI -->|Validates| WebhookSvc
    WebhookSvc -.->|Webhook Response| K8sAPI

    %% Operator Flows
    Operator -->|HTTPS/443<br/>ServiceAccount Token| K8sAPI
    Operator -->|Manages| HeadPod
    Operator -->|Manages| WorkerPods
    Operator -->|Manages| JobPod
    Operator -->|Manages| ServeSvc

    %% Ray Head Autoscaler
    HeadPod -->|HTTPS/443<br/>Ray SA Token<br/>Create/Delete Pods| K8sAPI

    %% External Dependencies
    HeadPod -.->|TCP/6379<br/>Optional TLS<br/>Redis Password| Redis
    HeadPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry
    HeadPod -->|HTTPS/443<br/>TLS 1.2+<br/>Configurable| Storage
    Prometheus -->|HTTP/8080<br/>Scrape| Operator
    Prometheus -->|HTTP/8080<br/>Scrape| HeadPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userworkload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,User external
    class Route ingress
    class K8sAPI,WebhookSvc controlplane
    class Operator,OpComponents,RayClusterCtrl,RayJobCtrl,RayServiceCtrl,Webhook,Metrics operator
    class HeadPod,WorkerPods,JobPod,ServeSvc,RayCluster userworkload
    class Redis,Registry,Storage,Prometheus externalservice
