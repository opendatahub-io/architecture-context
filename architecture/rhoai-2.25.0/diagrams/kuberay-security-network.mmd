graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/System]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
        Route["OpenShift Route/Ingress<br/>8265/8000 HTTP/HTTPS<br/>Optional TLS<br/>Edge/Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB
        Operator["KubeRay Operator Pod<br/>SA: kuberay-operator<br/>Image: UBI9 minimal"]
        Webhook["Admission Webhook<br/>9443/TCP HTTPS<br/>mTLS (K8s API cert)<br/>Cert: webhook-server-cert"]
        MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>No auth"]
    end

    subgraph UserNS["USER NAMESPACES: {user-namespace}"]
        direction TB

        subgraph RayCluster["Ray Cluster"]
            RayHead["Ray Head Pod<br/>SA: {cluster}-sa<br/>GCS: 6379/TCP (optional password)<br/>Dashboard: 8265/TCP HTTP (optional token)<br/>Client: 10001/TCP<br/>Serve: 8000/TCP HTTP"]
            RayWorker["Ray Worker Pods<br/>SA: {cluster}-sa<br/>Auto-scaling"]
            HeadSvc["Head Service<br/>ClusterIP<br/>6379/8265/10001"]
            ServeSvc["Serve Service<br/>ClusterIP<br/>8000/TCP"]
        end

        JobPod["Submitter Job Pod<br/>Created by RayJob<br/>Submits to Dashboard"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Redis["External Redis<br/>6379/TCP<br/>Optional TLS<br/>Redis password<br/>GCS Fault Tolerance"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secrets"]
        Storage["Ray Package Index<br/>Git/S3/GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Configurable auth"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    subgraph SchedulingIntegration["SCHEDULING INTEGRATION"]
        Volcano["Volcano Scheduler<br/>Gang scheduling<br/>Pod annotations"]
        Kueue["Kueue<br/>Job queuing<br/>Pod labels/annotations"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    Client -->|HTTP/HTTPS<br/>Optional TLS| Route

    K8sAPI -->|HTTPS/9443<br/>mTLS<br/>K8s API cert| Webhook
    K8sAPI <-->|HTTPS/443<br/>TLS 1.2+<br/>SA token| Operator

    Operator -->|Creates/Manages| RayHead
    Operator -->|Creates/Manages| RayWorker
    Operator -->|Creates/Manages| HeadSvc
    Operator -->|Creates/Manages| ServeSvc
    Operator -->|Creates Job| JobPod

    RayWorker -->|TCP/6379<br/>Optional password| RayHead
    JobPod -->|HTTP/8265<br/>Optional token| RayHead

    Route -->|Routes to| HeadSvc
    Route -->|Routes to| ServeSvc

    RayHead -.->|TCP/6379<br/>Optional TLS<br/>Redis password| Redis
    RayHead -->|Autoscale API<br/>HTTPS/443<br/>SA token| K8sAPI

    Operator -->|Pull images<br/>HTTPS/443<br/>TLS 1.2+| Registry
    RayHead -->|Fetch code/data<br/>HTTPS/443<br/>TLS 1.2+| Storage

    Prometheus -->|HTTP/8080<br/>No auth| MetricsEndpoint

    RayWorker -.->|Pod annotations| Volcano
    RayWorker -.->|Pod labels| Kueue

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduling fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Client external
    class K8sAPI,Route ingress
    class Operator,Webhook,MetricsEndpoint operatorns
    class RayHead,RayWorker,HeadSvc,ServeSvc,JobPod userns
    class Redis,Registry,Storage externalservice
    class Prometheus monitoring
    class Volcano,Kueue scheduling
