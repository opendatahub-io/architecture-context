graph TD
    subgraph "Service Accounts"
        SA1["data-science-pipelines-operator-controller-manager<br/>Namespace: DSPO namespace"]
        SA2["ds-pipeline-NAME<br/>Namespace: DSPA namespace"]
        SA3["pipeline-runner-NAME<br/>Namespace: DSPA namespace"]
        SA4["ds-pipeline-workflow-controller-NAME<br/>Namespace: DSPA namespace"]
        SA5["ds-pipeline-persistenceagent-NAME<br/>Namespace: DSPA namespace"]
        SA6["ds-pipeline-scheduledworkflow-NAME<br/>Namespace: DSPA namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB1["manager-rolebinding"]
        CRB2["manager-argo-rolebinding"]
        CRB3["ds-pipeline-workflow-controller-NAME"]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[manager-argo-role]
    end

    subgraph "Role Bindings (Namespace)"
        RB1[ds-pipeline-NAME]
        RB2[pipeline-runner-NAME]
        RB3[ds-pipeline-persistenceagent-NAME]
        RB4[ds-pipeline-scheduledworkflow-NAME]
    end

    subgraph "Roles (Namespace)"
        R1[ds-pipeline-NAME]
        R2[pipeline-runner-NAME]
    end

    subgraph "API Resources - DSPO Operator"
        direction LR
        RES1["Core: configmaps, secrets,<br/>serviceaccounts, services,<br/>pvcs, pods, events"]
        RES2["Apps: deployments, replicasets"]
        RES3["DSP: datasciencepipelinesapplications<br/>(status, finalizers)"]
        RES4["Argo: workflows, workflowtemplates,<br/>cronworkflows, workflowartifactgctasks"]
        RES5["Pipelines: pipelines, pipelineversions"]
        RES6["Route: routes (OpenShift)"]
        RES7["Networking: networkpolicies"]
        RES8["RBAC: roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
        RES9["Monitoring: servicemonitors"]
        RES10["KServe: inferenceservices"]
        RES11["Ray: rayclusters, rayjobs, rayservices"]
        RES12["Admission: mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations"]
    end

    subgraph "API Resources - DSPA Instance"
        direction LR
        RES13["Argo: workflows,<br/>workflowartifactgctasks"]
        RES14["Core: pods, pods/log,<br/>configmaps, secrets,<br/>services, events"]
        RES15["KServe: inferenceservices"]
    end

    subgraph "API Resources - Pipeline Runner"
        direction LR
        RES16["Core: secrets, configmaps,<br/>serviceaccounts"]
        RES17["Argo: workflows<br/>(get, list, watch only)"]
    end

    subgraph "API Resources - Argo Controller"
        direction LR
        RES18["Argo: workflows, workflowtemplates,<br/>cronworkflows, workflowartifactgctasks"]
        RES19["Core: pods, pods/exec,<br/>configmaps, secrets,<br/>serviceaccounts, pvcs"]
        RES20["Coordination: leases"]
    end

    %% DSPO Controller Permissions
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES1
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES2
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES3
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES4
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES5
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES6
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES7
    CR1 -->|create, delete, get,<br/>list, update, watch| RES8
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES9
    CR1 -->|create, delete, get,<br/>list, patch| RES10
    CR1 -->|create, delete, get,<br/>list, patch| RES11
    CR1 -->|create, delete, get,<br/>list, patch, update, watch| RES12

    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES18
    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES19
    CR2 -->|create, get, update| RES20

    %% DSPA Instance Permissions
    SA2 -->|bound via| RB1
    RB1 -->|grants| R1
    R1 -->|create, delete,<br/>deletecollection, get,<br/>list, patch, update, watch| RES13
    R1 -->|create, delete, get,<br/>list, patch, watch| RES14
    R1 -->|create, delete, get,<br/>list, patch| RES15

    %% Pipeline Runner Permissions
    SA3 -->|bound via| RB2
    RB2 -->|grants| R2
    R2 -->|get| RES16
    R2 -->|get, list, watch| RES17

    %% Workflow Controller Permissions
    SA4 -->|bound via| CRB3
    CRB3 -->|grants| CR2

    %% Persistence Agent Permissions
    SA5 -->|bound via| RB3
    RB3 -->|grants| R1

    %% Scheduled Workflow Permissions
    SA6 -->|bound via| RB4
    RB4 -->|grants| R1

