graph TB
    subgraph "KubeRay Operator Pod"
        Operator[KubeRay Operator Controller<br/>Port: 8080/TCP HTTP metrics]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        Webhook[Admission Webhook<br/>Port: 9443/TCP HTTPS]
        Metrics[Metrics Exporter<br/>Port: 8080/TCP]

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
        Operator --> Webhook
        Operator --> Metrics
    end

    subgraph "Custom Resources (CRDs)"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Components (Managed)"
        HeadPod[Ray Head Pod<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP]
        WorkerPods[Ray Worker Pods<br/>Auto-scaling]
        HeadSvc[Head Service<br/>ClusterIP]
        ServeSvc[Serve Service<br/>Port: 8000/TCP HTTP]

        HeadPod --> WorkerPods
        HeadSvc --> HeadPod
        ServeSvc --> HeadPod
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Redis[External Redis<br/>6379/TCP<br/>GCS Fault Tolerance]
        CertManager[cert-manager<br/>Webhook TLS]
        Prometheus[Prometheus<br/>Metrics Collection]
        OSRoute[OpenShift Routes<br/>External Access]
    end

    subgraph "Optional Schedulers"
        Volcano[Volcano<br/>Gang Scheduling]
        YuniKorn[YuniKorn<br/>Batch Scheduling]
        Kueue[Kueue<br/>Job Queuing]
    end

    User[User/System] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    K8sAPI -->|validates| Webhook

    RayClusterCtrl -->|creates/manages| HeadPod
    RayClusterCtrl -->|creates/manages| WorkerPods
    RayClusterCtrl -->|creates| HeadSvc

    RayJobCtrl -->|creates| RayClusterCR
    RayJobCtrl -->|creates K8s Job| K8sAPI

    RayServiceCtrl -->|creates| RayClusterCR
    RayServiceCtrl -->|creates| ServeSvc
    RayServiceCtrl -->|zero-downtime updates| HeadPod

    Operator -->|manages resources| K8sAPI
    HeadPod -.->|optional| Redis
    Webhook -.->|TLS cert| CertManager
    Metrics -->|exposes to| Prometheus
    HeadSvc -.->|exposes via| OSRoute

    WorkerPods -.->|gang scheduling| Volcano
    WorkerPods -.->|batch scheduling| YuniKorn
    WorkerPods -.->|job queuing| Kueue

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style Webhook fill:#4a90e2,stroke:#333

    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333

    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style HeadSvc fill:#7ed321,stroke:#333
    style ServeSvc fill:#7ed321,stroke:#333

    style K8sAPI fill:#999,stroke:#333
    style Redis fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style OSRoute fill:#999,stroke:#333

    style Volcano fill:#e8e8e8,stroke:#333
    style YuniKorn fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
