graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS 1.3 Termination"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio/Maistra - mTLS STRICT)"]
        direction TB

        subgraph IstioSystem["Namespace: istio-system"]
            Gateway["Istio Ingress Gateway<br/>8080/TCP HTTP<br/>SA: istio-ingressgateway"]
        end

        subgraph AuthorinoNS["Namespace: authorino-operator"]
            Authorino["Authorino<br/>5001/TCP gRPC mTLS<br/>Bearer Token Validation"]
        end

        subgraph KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>8012/TCP HTTP<br/>SA: activator"]
        end

        subgraph UserNamespace["Namespace: {user-namespace}"]
            Pod["Inference Pod<br/>8080/TCP HTTP mTLS<br/>SA: {isvc-name}-sa<br/>Image: {runtime-image}<br/>runAsUser: 2000<br/>runAsNonRoot: true<br/>capabilities: drop ALL"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM/Access Key"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS1.3<br/>NGC API Key"]
        ModelReg["Model Registry API<br/>443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph K8sCluster["Kubernetes Cluster"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>OIDC/Bearer Token"]
        end

        subgraph ODHController["Namespace: odh-model-controller"]
            direction LR
            Webhook["Webhook Server<br/>443/TCP → 9443 HTTPS TLS1.2+<br/>mTLS K8s API client cert<br/>SA: odh-model-controller"]
            Reconciler["Reconcilers<br/>Watches: InferenceService,<br/>InferenceGraph, NIMAccount<br/>SA: odh-model-controller"]
            Metrics["Metrics Server<br/>8080/TCP HTTP<br/>Bearer Token<br/>TODO: migrate to 8443 HTTPS"]
        end

        subgraph Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>Scrapes via ServiceMonitor<br/>Interval: 30s"]
        end
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token optional| Route

    %% Ingress to Service Mesh
    Route -->|HTTP/8080<br/>Plaintext| Gateway

    %% Service Mesh Internal Flows
    Gateway -->|gRPC/5001<br/>mTLS<br/>Auth Check| Authorino
    Authorino -.->|Auth Decision| Gateway
    Gateway -->|HTTP/8012<br/>Plaintext| Activator
    Activator -->|HTTP/8080<br/>mTLS PeerAuth STRICT<br/>Service Identity| Pod

    %% Pod to External Services
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>IAM/Access Key| S3

    %% Control Plane Flows
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>mTLS| Webhook
    Reconciler -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token| K8sAPI
    Reconciler -->|HTTPS/443<br/>TLS 1.3<br/>NGC API Key| NGC
    Reconciler -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| ModelReg
    Prometheus -->|HTTP/8080<br/>Bearer Token| Metrics
    Prometheus -->|HTTP/8080<br/>mTLS<br/>Bearer Token| Pod

    %% Reconciler Creates Resources
    Reconciler -.->|Creates| Route
    Reconciler -.->|Creates| Gateway
    Reconciler -.->|Creates VirtualService,<br/>PeerAuthentication,<br/>ServiceMeshMember| ServiceMesh
    Reconciler -.->|Creates AuthConfig| Authorino

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Route ingress
    class Gateway,Authorino,Activator,Pod servicemesh
    class S3,NGC,ModelReg externalservice
    class K8sAPI,Webhook,Reconciler,Metrics,Prometheus controlplane
