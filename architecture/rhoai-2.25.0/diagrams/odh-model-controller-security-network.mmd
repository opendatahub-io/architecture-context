graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS 1.3<br/>Created by Controller"]
        IstioGW["Istio Ingress Gateway<br/>NS: istio-system<br/>SA: istio-ingressgateway"]
        Authorino["Authorino Service<br/>NS: authorino-system<br/>JWT/Bearer Validation<br/>Per-InferenceService AuthConfig"]
    end

    subgraph ServiceMesh["SERVICE MESH - Istio mTLS Optional"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Scale-from-zero"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            Predictor["Inference Pod - Predictor<br/>SA: isvc-name-sa<br/>Image: serving-runtime-image<br/>Security: runAsNonRoot=true, UID=2000<br/>Istio Sidecar: Injected"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE - Internal Kubernetes"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3"]
        Webhook["ODH Model Controller Webhook<br/>NS: odh-model-controller<br/>SA: odh-model-controller<br/>Service: 443 → 9443<br/>Cert: webhook-server-cert"]
        Controller["ODH Model Controller<br/>Reconcilers<br/>Watches: InferenceService, etc.<br/>Creates: Route, VirtualService, etc."]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>TODO: migrate to 8443 HTTPS"]
        Prometheus["Prometheus<br/>ServiceMonitor scraper"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/Object Storage<br/>s3.amazonaws.com<br/>HTTPS/443 TLS 1.2+<br/>Auth: AWS IAM/Access Keys"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>HTTPS/443 TLS 1.3<br/>Auth: NGC API Key<br/>Refresh: 24h"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token optional| Route
    Route -->|HTTP/8080<br/>No encryption| IstioGW

    %% Ingress to Auth
    IstioGW -->|gRPC/5001<br/>mTLS<br/>Auth validation| Authorino
    Authorino -.->|Auth result| IstioGW

    %% Ingress to Service Mesh
    IstioGW -->|HTTP/8012<br/>No encryption| Activator
    Activator -->|HTTP/8080<br/>mTLS if PeerAuth enabled<br/>Service Identity| Predictor

    %% Predictor to External Services
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>IAM/Access Key| S3

    %% Control Plane flows
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>mTLS| Webhook
    Webhook -.->|Webhook validation| K8sAPI
    Controller -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token| K8sAPI
    Controller -.->|Creates resources| Route
    Controller -.->|Creates resources| IstioGW
    Controller -.->|Creates resources| Authorino

    %% NIM integration
    Controller -->|HTTPS/443<br/>TLS 1.3<br/>NGC API Key| NGC

    %% Metrics
    Prometheus -->|HTTP/8080<br/>Bearer Token<br/>kube-rbac-proxy| MetricsSvc
    Prometheus -.->|HTTP/8080 mTLS<br/>Bearer Token| Predictor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,IstioGW,Authorino ingress
    class Activator,Predictor servicemesh
    class K8sAPI,Webhook,Controller,MetricsSvc,Prometheus controlplane
    class S3,NGC externalservice
