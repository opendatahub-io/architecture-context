graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[webhook-service<br/>9443/TCP]
        Metrics[metrics-service<br/>8443/TCP]
        Visibility[visibility-server<br/>In-Process API]

        subgraph "Core Reconcilers"
            WorkloadReconciler[Workload Reconciler]
            ClusterQueueReconciler[ClusterQueue Reconciler]
            LocalQueueReconciler[LocalQueue Reconciler]
        end

        subgraph "Job Integrations"
            BatchIntegration[Batch Job Integration]
            KubeflowIntegration[Kubeflow Integration<br/>TFJob/PyTorchJob/MPIJob]
            RayIntegration[Ray Integration<br/>RayJob/RayCluster]
            JobSetIntegration[JobSet Integration]
            AppWrapperIntegration[AppWrapper Integration]
        end

        subgraph "Scheduler & Cache"
            Scheduler[Scheduler Engine]
            Cache[In-Memory Cache<br/>ClusterQueues/Workloads]
        end

        Controller --> WorkloadReconciler
        Controller --> ClusterQueueReconciler
        Controller --> LocalQueueReconciler
        Controller --> Webhook
        Controller --> Metrics
        Controller --> Visibility

        WorkloadReconciler --> Scheduler
        Scheduler --> Cache
        ClusterQueueReconciler --> Cache
    end

    subgraph "Custom Resources"
        Workload[Workload<br/>kueue.x-k8s.io/v1beta1]
        ClusterQueue[ClusterQueue<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue<br/>kueue.x-k8s.io/v1beta1]
        ResourceFlavor[ResourceFlavor<br/>kueue.x-k8s.io/v1beta1]
        WorkloadPriorityClass[WorkloadPriorityClass<br/>kueue.x-k8s.io/v1beta1]
        AdmissionCheck[AdmissionCheck<br/>kueue.x-k8s.io/v1beta1]
        ProvisioningRequestConfig[ProvisioningRequestConfig<br/>kueue.x-k8s.io/v1beta1]
        MultiKueueConfig[MultiKueueConfig<br/>kueue.x-k8s.io/v1beta1]
        Cohort[Cohort<br/>kueue.x-k8s.io/v1alpha1]
        Topology[Topology<br/>kueue.x-k8s.io/v1alpha1]
    end

    subgraph "Managed Workloads"
        BatchJob[Batch Job]
        TFJob[TFJob]
        PyTorchJob[PyTorchJob]
        RayJobRes[RayJob]
        JobSetRes[JobSet]
        AppWrapperRes[AppWrapper]
        Deployment[Deployment/StatefulSet]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        CertManager[cert-manager<br/>TLS Certificates]
        Prometheus[Prometheus<br/>Metrics Scraping]
        ClusterAutoscaler[Cluster Autoscaler<br/>Node Provisioning]
    end

    %% User interactions
    User[User/kubectl] -->|creates| BatchJob
    User -->|creates| TFJob
    User -->|creates| LocalQueue
    User -->|creates| ClusterQueue

    %% Webhook intercepts
    K8sAPI -->|validates/mutates| Webhook
    BatchJob -.->|intercepted by| Webhook
    TFJob -.->|intercepted by| Webhook

    %% CRD watching
    Workload -->|watched by| WorkloadReconciler
    ClusterQueue -->|watched by| ClusterQueueReconciler
    LocalQueue -->|watched by| LocalQueueReconciler

    %% Job integrations
    BatchIntegration -->|patches| BatchJob
    KubeflowIntegration -->|patches| TFJob
    KubeflowIntegration -->|patches| PyTorchJob
    RayIntegration -->|patches| RayJobRes
    JobSetIntegration -->|patches| JobSetRes
    AppWrapperIntegration -->|patches| AppWrapperRes

    %% External integrations
    Controller -->|watches/patches| K8sAPI
    Metrics -->|scraped by| Prometheus
    Controller -->|requests certs| CertManager
    Controller -->|creates| ProvisioningRequest[ProvisioningRequest<br/>autoscaling.x-k8s.io]
    ProvisioningRequest -->|watched by| ClusterAutoscaler

    %% Visibility API
    User -->|queries| Visibility
    Visibility -->|reads from| Cache

