graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[webhook-service<br/>HTTPS 9443/TCP]
        Metrics[metrics-service<br/>HTTPS 8443/TCP]
        Visibility[kueue-visibility-server<br/>HTTP Server]

        subgraph "Core Components"
            WorkloadReconciler[workload-reconciler]
            ClusterQueueReconciler[clusterqueue-reconciler]
            LocalQueueReconciler[localqueue-reconciler]
            JobIntegrations[job-integrations]
            Scheduler[scheduler]
            Cache[cache]
        end

        Controller --> WorkloadReconciler
        Controller --> ClusterQueueReconciler
        Controller --> LocalQueueReconciler
        Controller --> JobIntegrations
        Controller --> Scheduler
        Scheduler --> Cache
    end

    subgraph "Custom Resources"
        Workload[Workload CR<br/>kueue.x-k8s.io/v1beta1]
        ClusterQueue[ClusterQueue CR<br/>kueue.x-k8s.io/v1beta1]
        LocalQueue[LocalQueue CR<br/>kueue.x-k8s.io/v1beta1]
        ResourceFlavor[ResourceFlavor CR<br/>kueue.x-k8s.io/v1beta1]
        WorkloadPriorityClass[WorkloadPriorityClass CR<br/>kueue.x-k8s.io/v1beta1]
        AdmissionCheck[AdmissionCheck CR<br/>kueue.x-k8s.io/v1beta1]
        ProvisioningRequestConfig[ProvisioningRequestConfig CR<br/>kueue.x-k8s.io/v1beta1]
        MultiKueueConfig[MultiKueueConfig CR<br/>kueue.x-k8s.io/v1beta1]
        Cohort[Cohort CR<br/>kueue.x-k8s.io/v1alpha1]
        Topology[Topology CR<br/>kueue.x-k8s.io/v1alpha1]
    end

    subgraph "External Workloads"
        BatchJob[Batch Job<br/>batch/v1]
        TFJob[TFJob<br/>kubeflow.org]
        PyTorchJob[PyTorchJob<br/>kubeflow.org]
        MPIJob[MPIJob<br/>kubeflow.org]
        RayJob[RayJob<br/>ray.io]
        JobSet[JobSet<br/>jobset.x-k8s.io]
        AppWrapper[AppWrapper<br/>workload.codeflare.dev]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
        CertManager[cert-manager<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Scraper]
        ClusterAutoscaler[Cluster Autoscaler<br/>Provisioning]
    end

    User[User] -->|kubectl create job| K8sAPI
    K8sAPI -->|admission webhook| Webhook
    Webhook -->|mutate/validate| K8sAPI

    WorkloadReconciler -->|watches| Workload
    ClusterQueueReconciler -->|watches| ClusterQueue
    LocalQueueReconciler -->|watches| LocalQueue

    JobIntegrations -->|watches/patches| BatchJob
    JobIntegrations -->|watches/patches| TFJob
    JobIntegrations -->|watches/patches| PyTorchJob
    JobIntegrations -->|watches/patches| MPIJob
    JobIntegrations -->|watches/patches| RayJob
    JobIntegrations -->|watches/patches| JobSet
    JobIntegrations -->|watches/patches| AppWrapper

    Scheduler -->|uses| ResourceFlavor
    Scheduler -->|uses| WorkloadPriorityClass
    Scheduler -->|uses| AdmissionCheck
    Scheduler -->|uses| Cohort
    Scheduler -->|uses| Topology

    Controller -->|API calls| K8sAPI
    Controller -->|requests certs| CertManager
    Metrics -->|scraped by| Prometheus

    Visibility -->|queries| Cache
    User -->|GET pendingworkloads| K8sAPI
    K8sAPI -->|aggregated API| Visibility

    Controller -->|creates| ProvisioningRequestConfig
    ClusterAutoscaler -->|watches| ProvisioningRequestConfig

    Controller -->|multi-cluster| MultiKueueConfig

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style Metrics fill:#4a90e2,stroke:#333,stroke-width:2px
    style Visibility fill:#4a90e2,stroke:#333,stroke-width:2px
    style Workload fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterQueue fill:#f5a623,stroke:#333,stroke-width:2px
    style LocalQueue fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style CertManager fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333,stroke-width:2px
