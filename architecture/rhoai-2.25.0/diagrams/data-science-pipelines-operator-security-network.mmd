graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[Data Scientist /<br/>External Client]
    end

    subgraph Ingress["INGRESS - OpenShift Routes"]
        RouteAPI["OpenShift Route: ds-pipeline-NAME<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        RouteUI["OpenShift Route: ds-pipeline-ui-NAME<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>optional"]
        RouteMLMD["OpenShift Route: ds-pipeline-md-NAME<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>optional"]
    end

    subgraph AppLayer["APPLICATION LAYER - DSPA Namespace - Network Policies"]
        direction TB

        subgraph API["API Server Pod"]
            OAuthProxyAPI["OAuth Proxy<br/>8443/TCP HTTPS<br/>SA: ds-pipeline-NAME"]
            APIServer["API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC"]
            OAuthProxyAPI -->|Bearer Token| APIServer
        end

        subgraph UI["UI Pod optional"]
            OAuthProxyUI["OAuth Proxy<br/>8443/TCP HTTPS"]
            UIContainer["ML Pipelines UI<br/>Web Frontend"]
            OAuthProxyUI --> UIContainer
        end

        subgraph MLMD["MLMD Envoy Pod optional"]
            OAuthProxyMLMD["OAuth Proxy<br/>8443/TCP HTTPS"]
            EnvoyProxy["Envoy Proxy<br/>9090/TCP HTTP2"]
            OAuthProxyMLMD --> EnvoyProxy
        end

        MariaDB["MariaDB Service<br/>3306/TCP MySQL<br/>NetworkPolicy: mariadb-NAME<br/>Allow from API MLMD DSPO"]
        MLMDgRPC["MLMD gRPC Service<br/>8080/TCP gRPC<br/>TLS 1.2+ if podToPodTLS<br/>mTLS if podToPodTLS<br/>SA: ds-pipeline-metadata-grpc-NAME<br/>NetworkPolicy: Allow pipeline pods"]
        Minio["Minio Service<br/>9000/TCP HTTP<br/>S3 Auth"]

        WFCtrl["Workflow Controller<br/>Argo<br/>SA: ds-pipeline-workflow-controller-NAME"]
        PipelinePod["Pipeline Step Pod<br/>SA: pipeline-runner-NAME<br/>User-defined image"]
        PersistAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-NAME"]
        ScheduledWF["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-NAME"]
    end

    subgraph OperatorLayer["OPERATOR LAYER - DSPO Namespace"]
        Controller["DSPO Controller Manager<br/>SA: dspo-controller-manager<br/>8080/TCP metrics<br/>8081/TCP health"]
        Webhook["Webhook Server<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Auth"]
        S3External["External S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / S3 Keys"]
        DBExternal["External Database<br/>3306/TCP MySQL<br/>TLS 1.2+ optional<br/>DB Credentials"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| RouteAPI
    Client -->|HTTPS/443<br/>OAuth| RouteUI
    Client -->|HTTPS/443<br/>OAuth| RouteMLMD

    %% Ingress to App Layer
    RouteAPI -->|HTTPS/8443<br/>TLS 1.2+<br/>Service Cert| OAuthProxyAPI
    RouteUI -->|HTTPS/8443<br/>Service Cert| OAuthProxyUI
    RouteMLMD -->|HTTPS/8443<br/>Service Cert| OAuthProxyMLMD

    %% App Layer internal flows
    APIServer -->|MySQL/3306<br/>None or TLS 1.2+<br/>DB Credentials| MariaDB
    APIServer -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account| K8sAPI
    APIServer -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS<br/>mTLS optional| MLMDgRPC
    APIServer -->|HTTP/9000<br/>S3 Auth| Minio
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3External

    EnvoyProxy -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS<br/>mTLS optional| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>DB Credentials| MariaDB

    WFCtrl -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account| K8sAPI
    PipelinePod -->|HTTP/9000 or HTTPS/443<br/>TLS 1.2+ external<br/>S3 Credentials| Minio
    PipelinePod -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3External
    PipelinePod -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS<br/>mTLS optional| MLMDgRPC

    PersistAgent -->|HTTPS/6443<br/>Service Account| K8sAPI
    PersistAgent -->|MySQL/3306<br/>DB Credentials| MariaDB

    ScheduledWF -->|HTTPS/6443<br/>Service Account| K8sAPI

    %% Operator Layer
    Controller -->|HTTPS/6443<br/>Service Account| K8sAPI
    Controller -->|Creates/Manages| APIServer
    Controller -->|Creates/Manages| MariaDB
    Controller -->|Creates/Manages| Minio
    Controller -->|Creates/Manages| MLMDgRPC
    Controller -->|Creates/Manages| WFCtrl

    Webhook -->|HTTPS/8443<br/>TLS 1.2+<br/>K8s API Server Auth| K8sAPI

    %% External services
    WFCtrl -.->|Pull images| Registry
    PipelinePod -.->|Pull images| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef applayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef database fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class RouteAPI,RouteUI,RouteMLMD ingress
    class OAuthProxyAPI,APIServer,OAuthProxyUI,UIContainer,OAuthProxyMLMD,EnvoyProxy,MLMDgRPC,WFCtrl,PipelinePod,PersistAgent,ScheduledWF applayer
    class Controller,Webhook operator
    class K8sAPI,S3External,DBExternal,Registry externalservice
    class MariaDB database
    class Minio storage
