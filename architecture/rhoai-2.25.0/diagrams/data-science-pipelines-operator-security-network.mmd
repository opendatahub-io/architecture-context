graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist /<br/>External Client]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Routes)"]
        RouteAPI["Route: ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        RouteUI["Route: ds-pipeline-ui-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt<br/>(optional)"]
        RouteMLMD["Route: ds-pipeline-md-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt<br/>(optional)"]
    end

    subgraph AppTier["APPLICATION TIER (User Namespace)"]
        direction TB

        subgraph APIServerPod["API Server Pod"]
            OAuthAPI["OAuth Proxy<br/>8443/TCP HTTPS<br/>OAuth validation"]
            APIServer["API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>SA: ds-pipeline-{name}"]
        end

        subgraph UIPod["ML Pipelines UI Pod (optional)"]
            OAuthUI["OAuth Proxy<br/>8443/TCP HTTPS"]
            UI["UI Frontend<br/>3000/TCP HTTP"]
        end

        subgraph MLMDPod["MLMD Envoy Pod (optional)"]
            OAuthMLMD["OAuth Proxy<br/>8443/TCP HTTPS"]
            EnvoyProxy["Envoy Proxy<br/>9090/TCP HTTP"]
        end

        MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC<br/>TLS 1.2+ if podToPodTLS<br/>mTLS if enabled<br/>SA: ds-pipeline-{name}"]

        MariaDB[("MariaDB<br/>3306/TCP MySQL<br/>None or TLS 1.2+<br/>Network Policy: mariadb-{name}")]

        Minio[("Minio (optional)<br/>9000/TCP HTTP<br/>S3 Auth")]

        WorkflowController["Argo Workflow Controller<br/>Namespace-scoped<br/>SA: ds-pipeline-workflow-controller-{name}"]

        PipelinePods["Pipeline Step Pods<br/>(dynamic)<br/>SA: pipeline-runner-{name}"]

        PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}"]

        ScheduledWorkflow["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-{name}"]
    end

    subgraph OperatorTier["OPERATOR TIER (DSPO Namespace)"]
        Controller["DSPO Controller<br/>8080/TCP metrics<br/>8081/TCP health<br/>SA: data-science-pipelines-operator-controller-manager"]
        Webhook["Webhook Server<br/>8443/TCP HTTPS TLS1.2+<br/>K8s API Server Auth"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Service Account Tokens"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExternalS3["External S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / S3 Keys"]
        ExternalDB[("External Database<br/>3306/TCP MySQL<br/>TLS 1.2+ (optional)<br/>DB Credentials")]
        ContainerRegistry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Registry Auth"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| RouteAPI
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| RouteUI
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| RouteMLMD

    %% Ingress to Application
    RouteAPI -->|HTTPS/8443<br/>TLS 1.2+<br/>Service Cert| OAuthAPI
    RouteUI -->|HTTPS/8443<br/>TLS 1.2+| OAuthUI
    RouteMLMD -->|HTTPS/8443<br/>TLS 1.2+| OAuthMLMD

    %% OAuth to App Containers
    OAuthAPI -->|HTTP/8888<br/>Bearer Token| APIServer
    OAuthUI -->|HTTP/3000<br/>Bearer Token| UI
    OAuthMLMD -->|HTTP/9090<br/>Bearer Token| EnvoyProxy

    %% Application Internal Flows
    APIServer -->|MySQL/3306<br/>None or TLS 1.2+<br/>DB Credentials| MariaDB
    APIServer -->|HTTP/9000 or HTTPS/443<br/>S3 Keys| Minio
    APIServer -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS<br/>mTLS if enabled| MLMDgRPC
    APIServer -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    EnvoyProxy -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>DB Credentials| MariaDB

    WorkflowController -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    WorkflowController -.->|creates| PipelinePods

    PipelinePods -->|HTTP/9000 or HTTPS/443<br/>S3 Keys| Minio
    PipelinePods -->|gRPC/8080<br/>TLS 1.2+ if podToPodTLS| MLMDgRPC
    PipelinePods -->|HTTPS/443<br/>TLS 1.2+<br/>Registry Auth| ContainerRegistry

    PersistenceAgent -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    PersistenceAgent -->|MySQL/3306<br/>DB Credentials| MariaDB

    ScheduledWorkflow -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Operator Tier
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>ClusterRole| K8sAPI
    Webhook -->|HTTPS/8443<br/>TLS 1.2+<br/>K8s Certs| K8sAPI

    %% External Services (optional)
    APIServer -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 Keys| ExternalS3
    APIServer -.->|MySQL/3306<br/>TLS 1.2+<br/>DB Credentials| ExternalDB
    PipelinePods -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 Keys| ExternalS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef oauth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class RouteAPI,RouteUI,RouteMLMD ingress
    class APIServer,MLMDgRPC,MariaDB,Minio,WorkflowController,PipelinePods,PersistenceAgent,ScheduledWorkflow,UI,EnvoyProxy application
    class OAuthAPI,OAuthUI,OAuthMLMD oauth
    class Controller,Webhook operator
    class K8sAPI controlplane
    class ExternalS3,ExternalDB,ContainerRegistry externalservice
