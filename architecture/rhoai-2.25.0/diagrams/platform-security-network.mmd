graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        Client["External Clients<br/>Data Scientists, Applications"]
    end

    subgraph Ingress["INGRESS/DMZ LAYER"]
        direction TB
        Router["OpenShift Router<br/>443/TCP → 8080/TCP<br/>TLS 1.3 Edge/Reencrypt<br/>OAuth Token Validation"]
        IstioGW["Istio Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.3 SIMPLE<br/>RequestAuthentication JWT"]
    end

    subgraph ControlPlane["PLATFORM CONTROL PLANE<br/>(redhat-ods-applications)"]
        direction TB

        Dashboard["ODH Dashboard<br/>8080/TCP<br/>SA: odh-dashboard<br/>OAuth Proxy: 8443/TCP"]

        subgraph Operators["Operators"]
            KServeOp["KServe Controller<br/>8080/TCP<br/>SA: kserve-controller-manager"]
            ODHModelOp["ODH Model Controller<br/>8080/TCP<br/>SA: odh-model-controller"]
            DSPAOp["DSPA Operator<br/>8080/TCP<br/>SA: data-science-pipelines-operator"]
            TrainingOp["Training Operator<br/>8080/TCP<br/>SA: training-operator"]
            KueueOp["Kueue Controller<br/>8080/TCP<br/>SA: kueue-controller-manager"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>RBAC + Admission Webhooks"]
    end

    subgraph UserWorkloads["USER WORKLOAD NAMESPACES<br/>(data science projects - multi-tenant)"]
        direction TB

        subgraph NS1["Namespace: user-project-1"]
            Notebook1["Jupyter Notebook<br/>8888/TCP<br/>OAuth Proxy<br/>SA: {notebook-name}"]
            Training1["Training Job Pods<br/>PyTorchJob<br/>SA: {job-name}-sa<br/>DDP: 23456/TCP"]
            Predictor1["InferenceService<br/>8080/TCP HTTP<br/>mTLS via Istio sidecar<br/>SA: {isvc}-sa"]
            Pipeline1["DSPA Instance<br/>API: 8888/TCP<br/>UI: 3000/TCP<br/>DB: PostgreSQL"]
            Registry1["Model Registry<br/>8080/TCP REST<br/>9090/TCP gRPC<br/>DB: PostgreSQL"]
        end

        subgraph NS2["Namespace: user-project-2"]
            Ray2["RayCluster<br/>Head: 10001/TCP<br/>Dashboard: 8265/TCP<br/>mTLS CA"]
            Feast2["Feast Feature Store<br/>Online: 6379/TCP Redis<br/>Offline: PostgreSQL/S3"]
            TrustyAI2["TrustyAI Service<br/>8080/TCP API<br/>9090/TCP metrics"]
        end
    end

    subgraph SharedInfra["SHARED INFRASTRUCTURE"]
        direction TB

        subgraph IstioNS["istio-system"]
            Istiod["istiod<br/>15012/TCP XDS gRPC<br/>15017/TCP webhook<br/>mTLS CA"]
        end

        subgraph KnativeNS["knative-serving"]
            Activator["Activator<br/>8012/TCP HTTP<br/>9090/TCP metrics"]
            Autoscaler["Autoscaler<br/>8080/TCP metrics"]
        end

        subgraph MonitoringNS["openshift-monitoring"]
            Prometheus["Prometheus<br/>9091/TCP federated scraping"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        S3["S3-Compatible Storage<br/>s3.amazonaws.com<br/>storage.googleapis.com<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Signature V4"]
        Registries["Container Registries<br/>quay.io, registry.redhat.io<br/>nvcr.io (NVIDIA NGC)<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secrets"]
        PyPI["Python & ML Hubs<br/>pypi.org, huggingface.co<br/>443/TCP HTTPS TLS 1.2+"]
        CloudDB["Cloud Data Warehouses<br/>Snowflake, Redshift, BigQuery<br/>443/TCP HTTPS TLS 1.2+"]
        ExtDB["External Databases<br/>PostgreSQL: 5432/TCP<br/>MySQL: 3306/TCP<br/>Redis: 6379/TCP<br/>TLS optional"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth Bearer Token"| Router
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>JWT (optional)"| IstioGW

    %% Ingress to Control Plane
    Router -->|"HTTP/8080<br/>Validated OAuth"| Dashboard
    IstioGW -->|"HTTP/8012<br/>mTLS PERMISSIVE<br/>Service Identity"| Activator

    %% Dashboard to API Server
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA JWT Token"| K8sAPI

    %% Operators to API Server
    KServeOp -->|"HTTPS/6443<br/>SA JWT Token"| K8sAPI
    ODHModelOp -->|"HTTPS/6443<br/>SA JWT Token"| K8sAPI
    DSPAOp -->|"HTTPS/6443<br/>SA JWT Token"| K8sAPI
    TrainingOp -->|"HTTPS/6443<br/>SA JWT Token"| K8sAPI
    KueueOp -->|"HTTPS/6443<br/>SA JWT Token"| K8sAPI

    %% API Server to User Workloads
    K8sAPI -->|"Reconciliation<br/>CR Watch Events"| Notebook1
    K8sAPI -->|"Reconciliation<br/>CR Watch Events"| Training1
    K8sAPI -->|"Reconciliation<br/>CR Watch Events"| Predictor1
    K8sAPI -->|"Reconciliation<br/>CR Watch Events"| Pipeline1

    %% Knative to Predictors
    Activator -->|"HTTP/8080<br/>mTLS (Istio sidecar)<br/>Service Identity"| Predictor1

    %% Istio control plane
    Istiod -->|"mTLS Certificate Issuance<br/>15012/TCP XDS"| Predictor1
    Istiod -->|"mTLS Certificate Issuance<br/>15012/TCP XDS"| Activator

    %% User workloads to external services
    Notebook1 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Notebook1 -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    Notebook1 -->|"HTTPS/443<br/>TLS 1.2+"| Registries

    Training1 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/IRSA"| S3
    Training1 -->|"HTTPS/443<br/>TLS 1.2+"| PyPI

    Predictor1 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/IRSA"| S3

    Pipeline1 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Pipeline1 -->|"PostgreSQL/5432<br/>TLS optional<br/>User/Pass"| ExtDB

    Registry1 -->|"PostgreSQL/5432<br/>TLS optional<br/>User/Pass"| ExtDB

    Feast2 -->|"Redis/6379<br/>TLS optional"| ExtDB
    Feast2 -->|"HTTPS/443<br/>TLS 1.2+"| CloudDB
    Feast2 -->|"PostgreSQL/5432<br/>TLS optional"| ExtDB

    Ray2 -->|"HTTPS/443<br/>TLS 1.2+"| PyPI

    %% Monitoring
    Prometheus -->|"Scrape /metrics<br/>HTTP/9090"| KServeOp
    Prometheus -->|"Scrape /metrics<br/>HTTP/9090"| Predictor1
    Prometheus -->|"Scrape /metrics<br/>HTTP/9090"| TrustyAI2

    %% Styling - Trust Zones
    classDef external fill:#f9f9f9,stroke:#e74c3c,stroke-width:3px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#333
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#333
    classDef userworkload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef sharedinfra fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef externalservice fill:#f5f5f5,stroke:#999,stroke-width:2px,color:#333

    class Client external
    class Router,IstioGW ingress
    class Dashboard,KServeOp,ODHModelOp,DSPAOp,TrainingOp,KueueOp,K8sAPI controlplane
    class Notebook1,Training1,Predictor1,Pipeline1,Registry1,Ray2,Feast2,TrustyAI2 userworkload
    class Istiod,Activator,Autoscaler,Prometheus sharedinfra
    class S3,Registries,PyPI,CloudDB,ExtDB externalservice
