graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB[kubeflow-training-operator<br/>ClusterRoleBinding]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR[training-operator<br/>ClusterRole]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB[kubeflow-training-operator-webhook-secret<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R[training-operator-webhook-secret<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph CoreResources["Core API Resources"]
        Pods[pods<br/>create, delete, get, list, patch, update, watch]
        PodsExec[pods/exec<br/>create]
        Services[services<br/>create, delete, get, list, watch]
        ServiceAccounts[serviceaccounts<br/>create, get, list, watch]
        ConfigMaps[configmaps<br/>create, list, update, watch]
        Events[events<br/>create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>get, create, update<br/>NAMESPACE-SCOPED ONLY]
    end

    subgraph KubeflowResources["Kubeflow Training API (kubeflow.org)"]
        PyTorchJobs[pytorchjobs<br/>create, delete, get, list, patch, update, watch]
        PyTorchJobsStatus[pytorchjobs/status<br/>get, patch, update]
        PyTorchJobsFinalizers[pytorchjobs/finalizers<br/>update]
        TFJobs[tfjobs<br/>create, delete, get, list, patch, update, watch]
        TFJobsStatus[tfjobs/status<br/>get, patch, update]
        MPIJobs[mpijobs<br/>create, delete, get, list, patch, update, watch]
        MPIJobsStatus[mpijobs/status<br/>get, patch, update]
        XGBoostJobs[xgboostjobs<br/>create, delete, get, list, patch, update, watch]
        PaddleJobs[paddlejobs<br/>create, delete, get, list, patch, update, watch]
        JAXJobs[jaxjobs<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph AutoscalingResources["Autoscaling API"]
        HPA[horizontalpodautoscalers<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph SchedulingResources["Scheduling APIs (Gang Scheduling)"]
        VolcanoPodGroups[podgroups<br/>scheduling.volcano.sh<br/>create, delete, get, list, patch, update, watch]
        SchedPluginsPodGroups[podgroups<br/>scheduling.x-k8s.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph NetworkingResources["Networking API"]
        NetworkPolicies[networkpolicies<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph RBACResources["RBAC API"]
        RolesAPI[roles<br/>create, list, update, watch]
        RoleBindingsAPI[rolebindings<br/>create, list, update, watch]
    end

    subgraph AdmissionResources["Admission Registration API"]
        ValidatingWebhooks[validatingwebhookconfigurations<br/>get, list, update, watch]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB
    CRB -->|grants| CR
    RB -->|grants| R

    %% ClusterRole permissions
    CR -->|full CRUD| Pods
    CR -->|exec| PodsExec
    CR -->|full CRUD| Services
