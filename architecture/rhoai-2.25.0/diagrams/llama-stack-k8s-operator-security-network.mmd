graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressCtl["Ingress Controller<br/>{instance-name}-ingress<br/>443/TCP or 80/TCP<br/>TLS 1.2+ - optional<br/>App-level auth - optional"]
    end

    subgraph InternalCluster["INTERNAL CLUSTER NETWORK"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            LLService["Service: {instance-name}-service<br/>ClusterIP<br/>8321/TCP"]
            LLPod["Llama Stack Pod<br/>SA: {instance-name}-sa<br/>Image: llamastack/distribution-{type}<br/>SCC: anyuid<br/>PVC: /opt/app-root/src/.llama"]
            InferenceProvider["Inference Provider<br/>Ollama 11434, vLLM 8000, TGI 8080<br/>HTTP/gRPC"]
        end

        subgraph NS_Operator["Namespace: llama-stack-k8s-operator-system"]
            OperatorMgr["Operator Controller Manager<br/>SA: controller-manager<br/>Leader election"]
            RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>TokenReview + SubjectAccessReview"]
            MetricsService["Service: controller-manager-metrics-service<br/>ClusterIP<br/>8443/TCP"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount JWT"]
        Registry["Container Registry<br/>docker.io, quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Image pull secrets"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>8443/TCP HTTPS TLS<br/>Bearer Token"]
    end

    %% External to Ingress
    Client -->|HTTPS/443 or HTTP/80<br/>TLS 1.2+ - optional<br/>App-level auth - optional| IngressCtl

    %% Ingress to Service
    IngressCtl -->|HTTP/8321<br/>No encryption<br/>No auth| LLService

    %% Service to Pod
    LLService -->|HTTP/8321<br/>Internal cluster| LLPod

    %% Pod to Inference Provider
    LLPod -->|HTTP/gRPC<br/>Varies by provider| InferenceProvider

    %% Operator flows
    OperatorMgr -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount JWT| K8sAPI
    LLPod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount JWT| K8sAPI

    %% External service connections
    LLPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image pull secrets| Registry
    LLPod -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HuggingFace

    %% Metrics flow
    Prometheus -->|HTTPS/8443<br/>TLS<br/>Bearer Token| RBACProxy
    RBACProxy -->|HTTP/8080<br/>localhost| OperatorMgr
    RBACProxy -->|HTTPS/6443<br/>TLS 1.2+| K8sAPI

    %% Network Policy (optional)
    NetworkPolicy["NetworkPolicy - optional<br/>When enableNetworkPolicy: true<br/>Allows from:<br/>- Same namespace part-of=llama-stack<br/>- Operator namespace<br/>- spec.network.allowedFrom"]
    NetworkPolicy -.->|restricts ingress to| LLPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef networkpolicy fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class IngressCtl ingress
    class LLService,LLPod,InferenceProvider internal
    class OperatorMgr,RBACProxy,MetricsService operator
    class K8sAPI,Registry,HuggingFace,Prometheus externalservice
    class NetworkPolicy networkpolicy
