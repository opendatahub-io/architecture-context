graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route1["OpenShift Route<br/>TrustyAI Service<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
        Route2["OpenShift Route<br/>Guardrails HTTPS<br/>443/TCP → 8032-8432/TCP<br/>TLS 1.2+ Reencrypt"]
        Route3["OpenShift Route<br/>Guardrails Gateway<br/>443/TCP → 8090-8490/TCP<br/>TLS 1.2+ Reencrypt"]
        Route4["OpenShift Route<br/>Guardrails Health<br/>443/TCP → 8034/TCP<br/>TLS 1.2+ Reencrypt"]
        IstioVS["Istio VirtualService<br/>{name}.{ns}.svc.cluster.local<br/>443/TCP HTTPS<br/>TLS SIMPLE"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        direction TB

        subgraph OAuthPod1["TrustyAI Service Pod"]
            OAuth1["OAuth Proxy<br/>8443/TCP HTTPS<br/>OpenShift SAR:<br/>namespace pods get"]
            TrustyAI["TrustyAI Service<br/>8080/TCP HTTP<br/>4443/TCP HTTPS<br/>service-ca cert"]
        end

        subgraph OAuthPod2["Guardrails Orchestrator Pod"]
            OAuth2["OAuth Proxy<br/>8443/TCP HTTPS<br/>Skip Auth:<br/>^/apis/v1beta1/healthz"]
            Guardrails["Guardrails Orchestrator<br/>8032-8432/TCP HTTPS<br/>8090-8490/TCP HTTP/HTTPS<br/>8034/TCP HTTP"]
        end

        OAuth1 -->|HTTP/8080<br/>localhost| TrustyAI
        OAuth2 -->|HTTP/HTTPS<br/>localhost| Guardrails
    end

    subgraph AppLayer["APPLICATION LAYER (Trusted)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            TrustyAISvc["ClusterIP Service<br/>{trustyai-service-name}<br/>80/TCP → 8080<br/>443/TCP → 4443,8443"]
            GuardrailsSvc["ClusterIP Service<br/>{orchestrator-name}<br/>8032-8432,8090-8490,8034/TCP"]
            LMESPod["LMES Job Pod<br/>SA: {lmevaljob-name}-sa<br/>ta-lmes-job image"]
        end

        subgraph Storage["STORAGE"]
            PVC["PersistentVolumeClaim<br/>{trustyai-service-name}-pvc"]
            DBSecret["Secret<br/>{trustyai-service-name}-db-credentials<br/>username, password, host"]
        end

        TrustyAI -->|filesystem| PVC
        TrustyAI -.->|optional| DBSecret
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: {operator-namespace}"]
            Operator["TrustyAI Operator<br/>SA: controller-manager<br/>odh-trustyai-service-operator"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>/metrics"]
        end

        OpSvc["ClusterIP Service<br/>controller-manager-metrics<br/>8443/TCP HTTPS"]

        Operator -->|proxied| RBACProxy
        RBACProxy -->|exposes| OpSvc
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    subgraph ExternalSvcs["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>SA Token"]
        KServe["KServe InferenceService<br/>80-443/TCP HTTP/HTTPS<br/>TLS 1.2+ (conditional)<br/>Bearer Token"]
        ModelMesh["ModelMesh Serving<br/>8033/TCP gRPC<br/>mTLS"]
        Database["PostgreSQL/MySQL<br/>5432/3306/TCP<br/>TLS 1.2+ (conditional)<br/>User/Pass"]
        Kueue["Kueue API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>SA Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        HuggingFace["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Redirect| Route1
    Client -->|HTTPS/443<br/>TLS 1.2+| Route2
    Client -->|HTTPS/443<br/>TLS 1.2+| Route3
    Client -->|HTTPS/443<br/>TLS 1.2+| Route4

    %% Ingress to Auth Layer
    Route1 -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| OAuth1
    Route2 -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| OAuth2
    Route3 -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| OAuth2
    Route4 -->|HTTPS/8443<br/>TLS 1.2+<br/>No Auth| OAuth2

    IstioVS -->|HTTPS/443<br/>TLS 1.2+| TrustyAISvc

    %% Services
    TrustyAISvc -->|routes to| OAuthPod1
    GuardrailsSvc -->|routes to| OAuthPod2

    %% Application to External Services
    TrustyAI -->|HTTP/HTTPS<br/>80-443/TCP<br/>TLS conditional| KServe
    Guardrails -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| KServe
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| KServe
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>API Token| HuggingFace
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    TrustyAI -->|PostgreSQL/MySQL<br/>5432/3306/TCP<br/>TLS conditional| Database

    %% Operator to K8s API
    Operator -->|Watch/Create<br/>HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    Operator -->|Pod Exec<br/>gRPC/8033<br/>mTLS| ModelMesh
    Operator -->|Watch/Patch<br/>HTTPS/6443<br/>TLS 1.3<br/>SA Token| KServe
    LMESPod -->|Workload<br/>HTTPS/6443<br/>TLS 1.3<br/>SA Token| Kueue

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>/q/metrics<br/>Internal| TrustyAI
    Prometheus -->|HTTPS/8443<br/>/metrics<br/>Bearer Token| OpSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route1,Route2,Route3,Route4,IstioVS ingress
    class OAuth1,OAuth2,OAuthPod1,OAuthPod2 auth
    class TrustyAI,Guardrails,TrustyAISvc,GuardrailsSvc,LMESPod,PVC,DBSecret,Storage,NS_User app
    class Operator,RBACProxy,OpSvc,NS_Operator operator
    class Prometheus monitoring
    class K8sAPI,KServe,ModelMesh,Database,Kueue,S3,HuggingFace externalservice
