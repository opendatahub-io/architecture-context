graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        TrustyRoute["OpenShift Route<br/>trustyai-service-name<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS 1.2+"]
        GuardrailsRoute["OpenShift Route<br/>orchestrator-name<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS 1.2+"]
    end

    subgraph AppLayer["APPLICATION LAYER (Trusted - Internal Network)"]
        direction TB

        subgraph TrustyAIPod["TrustyAI Service Pod<br/>Namespace: user-ns"]
            OAuthProxy1["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>OpenShift SAR: pods get"]
            TrustyAISvc["TrustyAI Service<br/>SA: trustyai-service-name<br/>8080/TCP HTTP<br/>4443/TCP HTTPS service-ca"]
        end

        subgraph GuardrailsPod["Guardrails Orchestrator Pod<br/>Namespace: user-ns"]
            OAuthProxy2["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>Skip: /healthz"]
            GuardrailsSvc["Guardrails Orchestrator<br/>SA: orchestrator-name<br/>8032/TCP HTTPS<br/>8034/TCP HTTP health"]
        end
    end

    subgraph OperatorLayer["OPERATOR LAYER"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>8081/TCP Health HTTP<br/>8443/TCP Metrics HTTPS<br/>9443/TCP Webhook HTTPS"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3"]
    end

    subgraph IntegrationLayer["INTEGRATION LAYER"]
        KServe["KServe InferenceService<br/>80-443/TCP HTTP/HTTPS<br/>TLS 1.2+ conditional<br/>Bearer Token"]
        ModelMesh["ModelMesh Serving<br/>8033/TCP gRPC mTLS<br/>Service Mesh Identity"]
        Kueue["Kueue Workload Controller<br/>6443/TCP HTTPS TLS1.3<br/>Service Account Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DB["PostgreSQL/MySQL<br/>5432/3306/TCP<br/>TLS 1.2+ conditional<br/>Username/Password"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM/Access Key"]
        HF["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS1.2+<br/>API Token optional"]
    end

    subgraph Storage["STORAGE"]
        PVC["PVC Storage<br/>RWO<br/>Filesystem"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitors<br/>HTTP/HTTPS"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token| TrustyRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token| GuardrailsRoute

    TrustyRoute -->|HTTPS/8443<br/>TLS service-ca<br/>Bearer Token| OAuthProxy1
    GuardrailsRoute -->|HTTPS/8443<br/>TLS service-ca<br/>Bearer Token| OAuthProxy2

    OAuthProxy1 -->|HTTP/8080<br/>Forwarded Bearer| TrustyAISvc
    OAuthProxy2 -->|HTTPS/8032<br/>TLS service-ca<br/>Forwarded Bearer| GuardrailsSvc

    TrustyAISvc -->|Filesystem| PVC
    TrustyAISvc -->|PostgreSQL/MySQL<br/>5432/3306/TCP<br/>TLS 1.2+<br/>DB Credentials| DB

    GuardrailsSvc -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| KServe

    Operator -->|Watch/Create/Update<br/>HTTPS/6443<br/>TLS 1.3<br/>Service Account Token| K8sAPI
    Operator -->|Patch/Update<br/>HTTPS/6443<br/>TLS 1.3| KServe
    Operator -->|Pod Exec<br/>gRPC/8033<br/>mTLS| ModelMesh
    Operator -->|Workload CRD<br/>HTTPS/6443<br/>TLS 1.3| Kueue

    TrustyAISvc -->|HTTP/8080<br/>/q/metrics| Prometheus
    Operator -->|HTTPS/8443<br/>/metrics<br/>Bearer Token| Prometheus

    KServe -->|Payload<br/>HTTP/HTTPS 80-443<br/>None| TrustyAISvc

    subgraph LMEval["LM EVAL JOB (Transient)"]
        LMESPod["LMES Pod<br/>SA: job-name<br/>Batch Job"]
    end

    Operator -->|Creates| LMESPod
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>API Token| HF
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| KServe
    LMESPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef applayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef integration fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#d4e1f5,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class TrustyRoute,GuardrailsRoute ingress
    class OAuthProxy1,TrustyAISvc,OAuthProxy2,GuardrailsSvc applayer
    class Operator,K8sAPI operator
    class KServe,ModelMesh,Kueue integration
    class DB,S3,HF externalservice
    class PVC storage
    class Prometheus monitoring
    class LMESPod applayer
