graph TB
    subgraph "ODH Dashboard Pod"
        direction TB
        Frontend[React Frontend<br/>PatternFly 6 UI<br/>Redux State Management]
        Backend[Fastify Backend<br/>Node.js 20<br/>Port 8080/TCP]
        OAuthProxy[OAuth Proxy Sidecar<br/>Port 8443/TCP HTTPS<br/>TLS 1.2+]
        K8sClient[Kubernetes Client<br/>client-node library<br/>API Client]
        WSServer[WebSocket Server<br/>Real-time Updates]

        Frontend -->|API Calls| Backend
        Backend -->|Kubernetes API| K8sClient
        Backend -->|Real-time| WSServer
        OAuthProxy -->|Proxy| Backend
    end

    subgraph "Custom Resources Watched"
        OdhApp[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhDoc[OdhDocument<br/>dashboard.opendatahub.io/v1]
        QuickStart[OdhQuickStart<br/>console.openshift.io/v1]
        AcceleratorProfile[AcceleratorProfile<br/>dashboard.opendatahub.io/v1]
        HardwareProfile[HardwareProfile<br/>infrastructure.opendatahub.io/v1]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        OAuthServer[OpenShift OAuth<br/>6443/TCP HTTPS]
        Prometheus[Prometheus/Thanos<br/>9092/TCP HTTPS]
    end

    subgraph "Internal ODH Dependencies"
        DSC[DataScienceCluster<br/>datasciencecluster.opendatahub.io]
        DSCI[DSCInitialization<br/>dscinitialization.opendatahub.io]
        Notebooks[Kubeflow Notebooks<br/>kubeflow.org]
        KServe[InferenceService<br/>serving.kserve.io]
        ModelRegistry[ModelRegistry<br/>modelregistry.opendatahub.io]
        LlamaStack[LlamaStackDistribution<br/>llamastack.io]
    end

    subgraph "Module Federation Plugins"
        GenAI[Gen AI Plugin]
        ModelReg[Model Registry Plugin]
        FeatureStore[Feature Store Plugin]
        LMEval[LM Eval Plugin]
    end

    User[Data Scientist] -->|HTTPS/443| OAuthProxy
