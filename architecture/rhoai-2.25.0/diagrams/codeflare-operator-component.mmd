graph TB
    subgraph "CodeFlare Operator Pod"
        Manager[Manager Pod<br/>Deployment]
        RayController[RayCluster Controller]
        AppController[AppWrapper Controller]
        MutatingWebhook[Mutating Webhook]
        ValidatingWebhook[Validating Webhook]
        CertController[Cert Controller]

        Manager -->|runs| RayController
        Manager -->|runs| AppController
        Manager -->|serves| MutatingWebhook
        Manager -->|serves| ValidatingWebhook
        Manager -->|manages| CertController
    end

    subgraph "Services"
        MetricsService[Metrics Service<br/>8080/TCP HTTP]
        WebhookService[Webhook Service<br/>443/TCP HTTPS TLS1.2+]
    end

    subgraph "Custom Resources"
        AppWrapperCR[AppWrapper CR<br/>workload.codeflare.dev/v1beta2]
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
    end

    subgraph "Managed Resources (per RayCluster)"
        OAuthProxy[OAuth Proxy<br/>OpenShift]
        Route[Route/Ingress<br/>Ray Dashboard]
        ClientRoute[Route/Ingress<br/>Ray Client 10001/TCP]
        NetworkPolicy[Network Policies<br/>Head & Worker Isolation]
        Secrets[Secrets<br/>CA & TLS]
    end

    subgraph "External Dependencies"
        KubeRay[KubeRay Operator<br/>v1.2.1]
        Kueue[Kueue<br/>v0.10.1+]
        K8sAPI[Kubernetes API<br/>6443/TCP]
        CertMgr[cert-controller<br/>v0.12.0]
    end

    subgraph "Internal ODH Components"
        Dashboard[ODH Dashboard<br/>User Interface]
        ODHOp[ODH Operator<br/>DSCInitialization]
    end

    %% User interactions
    User[User/Data Scientist] -->|creates| RayClusterCR
    User -->|creates| AppWrapperCR
    Dashboard -->|UI for| User

    %% CR watching
    RayClusterCR -->|watched by| RayController
    AppWrapperCR -->|watched by| AppController

    %% Webhook validation/mutation
    K8sAPI -->|validates/mutates| MutatingWebhook
    K8sAPI -->|validates| ValidatingWebhook

    %% Controllers create resources
    RayController -->|creates| OAuthProxy
    RayController -->|creates| Route
    RayController -->|creates| ClientRoute
    RayController -->|creates| NetworkPolicy
    RayController -->|creates| Secrets

    AppController -->|integrates with| Kueue
    AppController -->|creates resources via| K8sAPI

    %% Dependencies
    RayController -->|depends on| KubeRay
    RayController -->|reads config from| ODHOp
    CertController -->|uses| CertMgr

    %% Services
    Manager -.->|exposes| MetricsService
    Manager -.->|exposes| WebhookService

    %% Monitoring
    Prometheus[Prometheus] -->|scrapes| MetricsService

    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayController fill:#4a90e2,stroke:#333
    style AppController fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style AppWrapperCR fill:#f5a623,stroke:#333,stroke-width:2px
    style KubeRay fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style CertMgr fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style ODHOp fill:#7ed321,stroke:#333
