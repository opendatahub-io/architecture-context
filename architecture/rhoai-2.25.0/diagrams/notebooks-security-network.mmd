graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Mode<br/>Route: notebook-{username}"]
    end

    subgraph PodNetwork["POD NETWORK (Same Pod)"]
        direction TB

        subgraph Sidecar["OAuth Proxy Sidecar"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>OpenShift OAuth Validation<br/>SA: {notebook-name}-sa"]
        end

        subgraph WorkbenchContainer["Workbench Container"]
            Jupyter["Jupyter/RStudio/Code Server<br/>8888/8787/8080 TCP HTTP<br/>No Auth (pre-authenticated)<br/>Image: quay.io/opendatahub/workbench-images"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Credentials"]
        QuayIO["Quay.io Registry<br/>quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secret"]
        RedHatRegistry["Red Hat Registry<br/>registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secret"]
        GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS TLS 1.2+<br/>Git Token"]
        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS TLS 1.2+<br/>No Auth"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        KFP["Kubeflow Pipelines<br/>Controller<br/>SA: pipeline-runner"]
        Runtime["Runtime Container<br/>Ephemeral Pod<br/>SA: {pipeline-name}-sa<br/>No exposed ports"]
    end

    subgraph BuildTime["BUILD-TIME (Konflux)"]
        Konflux["Konflux Tekton Pipeline<br/>Multi-arch Builder"]
    end

    %% User flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+ Internal CA<br/>OAuth Required| OAuthProxy
    OAuthProxy -->|HTTP/8888<br/>No Encryption<br/>Localhost| Jupyter
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    %% Kubeflow Pipeline flows
    KFP -->|Create Pod<br/>ServiceAccount Token| Runtime
    Runtime -->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4| S3

    %% Build-time flows
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Git Token| GitHub
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| RedHatRegistry
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| PyPI
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Push Secret| QuayIO

    %% Image pulls
    QuayIO -.->|Referenced by<br/>ImageStream| Jupyter

    %% Styling
    classDef external fill:#f9f9f9,stroke:#d32f2f,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef buildtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Router ingress
    class OAuthProxy,Jupyter podnetwork
    class S3,QuayIO,RedHatRegistry,GitHub,PyPI externalservice
    class KFP,Runtime controlplane
    class Konflux buildtime
