graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>Route: notebook-user<br/>443/TCP to 8443/TCP<br/>TLS 1.2+ edge mode"]
    end

    subgraph PodNetwork["POD NETWORK - Trusted"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            direction LR
            OAuthProxy["OAuth Proxy Sidecar<br/>SA: notebook-name-sa<br/>8443/TCP HTTPS<br/>OpenShift OAuth"]
            Jupyter["Jupyter Container<br/>SA: notebook-name-sa<br/>8888/TCP HTTP<br/>Image: jupyter-minimal-cpu"]
            VSCode["Code Server Container<br/>SA: notebook-name-sa<br/>8080/TCP HTTP<br/>Image: codeserver-datascience-cpu"]
            RStudio["RStudio Container<br/>SA: notebook-name-sa<br/>8787/TCP HTTP<br/>Image: rstudio-minimal-cpu"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS SigV4 Auth"]
        KFP["Kubeflow Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph BuildDeploy["BUILD & DEPLOYMENT"]
        Konflux["Konflux CI/CD Pipeline"]
        GitHub["GitHub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Git Token"]
        UBI["UBI Registry<br/>registry.access.redhat.com<br/>443/TCP HTTPS<br/>Pull Secret"]
        Quay["Quay.io Registry<br/>quay.io/opendatahub/workbench-images<br/>443/TCP HTTPS<br/>Push/Pull Secret"]
        ImageStream["OpenShift ImageStream<br/>Image reference"]
    end

    %% User access flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Unauthenticated| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+ internal CA<br/>OpenShift OAuth| OAuthProxy
    OAuthProxy -->|HTTP/8888<br/>Localhost<br/>No encryption| Jupyter
    OAuthProxy -->|HTTP/8080<br/>Localhost<br/>No encryption| VSCode
    OAuthProxy -->|HTTP/8787<br/>Localhost<br/>No encryption| RStudio

    %% Workbench egress
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    VSCode -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3
    RStudio -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    %% Runtime image flow
    Jupyter -.->|Runtime executes in| KFP
    KFP -->|HTTPS/443<br/>TLS 1.2+<br/>S3 Credentials| S3

    %% Build flow
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Git Token| GitHub
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| UBI
    Konflux -->|HTTPS/443<br/>TLS 1.2+<br/>Push Secret| Quay
    ImageStream -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,Jupyter,VSCode,RStudio podnetwork
    class S3,KFP externalservice
    class Konflux,GitHub,UBI,Quay,ImageStream build
