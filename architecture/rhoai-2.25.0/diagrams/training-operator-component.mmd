graph TB
    subgraph "Training Operator Pod"
        Controller[Training Operator<br/>Controller Manager]

        subgraph "Framework Controllers"
            PyTorchCtrl[PyTorchJob Controller]
            TFCtrl[TFJob Controller]
            MPICtrl[MPIJob Controller]
            XGBoostCtrl[XGBoostJob Controller]
            PaddleCtrl[PaddleJob Controller]
            JAXCtrl[JAXJob Controller]
        end

        Webhook[Webhook Server<br/>9443/TCP HTTPS]
        CertMgr[Certificate Manager<br/>TLS Rotation]
        Metrics[Metrics Exporter<br/>8080/TCP HTTP]

        Controller --> PyTorchCtrl
        Controller --> TFCtrl
        Controller --> MPICtrl
        Controller --> XGBoostCtrl
        Controller --> PaddleCtrl
        Controller --> JAXCtrl
        Controller --> Webhook
        Controller --> CertMgr
        Controller --> Metrics
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
        JAXJobCR[JAXJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Training Pods<br/>Master + Workers]
        Services[Services<br/>Inter-pod communication]
        PodGroups[PodGroups<br/>Gang scheduling]
        HPA[HorizontalPodAutoscaler<br/>Elastic training]
        NetPol[NetworkPolicies<br/>Network isolation]
    end

    User[User/Data Scientist] -->|creates| PyTorchJobCR
    User -->|creates| TFJobCR
    User -->|creates| MPIJobCR

    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    PaddleJobCR -->|watched by| PaddleCtrl
    JAXJobCR -->|watched by| JAXCtrl

    PyTorchCtrl -->|creates| Pods
    PyTorchCtrl -->|creates| Services
    PyTorchCtrl -->|creates| HPA
    PyTorchCtrl -->|creates| PodGroups
    PyTorchCtrl -->|creates| NetPol

    TFCtrl -->|creates| Pods
    TFCtrl -->|creates| Services
    MPICtrl -->|creates| Pods
    MPICtrl -->|creates| Services

    K8sAPI[Kubernetes API Server] -->|validates| Webhook
    Webhook -->|validates| PyTorchJobCR
    Webhook -->|validates| TFJobCR
    Webhook -->|validates| MPIJobCR

    Prometheus[Prometheus] -->|scrapes| Metrics

    subgraph "External Dependencies"
        Volcano[Volcano Scheduler<br/>Optional]
        SchedPlugins[Scheduler Plugins<br/>Optional]
    end

    PodGroups -.->|gang scheduling| Volcano
    PodGroups -.->|gang scheduling| SchedPlugins

    subgraph "ODH Integration"
        Dashboard[ODH Dashboard]
        ModelRegistry[Model Registry]
    end

    Dashboard -->|UI management| PyTorchJobCR
    Pods -.->|store models| ModelRegistry

