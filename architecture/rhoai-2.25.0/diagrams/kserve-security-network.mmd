graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+ Termination<br/>RequestAuthentication"]
        Route["OpenShift Route<br/>443/TCP<br/>Edge TLS<br/>{isvc}-{ns}.apps.{cluster}"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Scale-from-zero"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            VS["Istio VirtualService<br/>{isvc}.{ns}.{domain}"]

            subgraph PredictorPod["Predictor Pod"]
                Agent["Agent Sidecar<br/>9081/TCP HTTP<br/>Batching/Logging"]
                ModelServer["Model Server<br/>8080/TCP HTTP<br/>MLServer/TorchServe/Triton"]
                StorageInit["storage-initializer<br/>Init Container"]
            end
        end
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: kserve)"]
        Controller["KServe Controller Manager<br/>SA: kserve-controller-manager<br/>8080/TCP (metrics)<br/>8081/TCP (health)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS cert from cert-manager"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Secret Key"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS1.2+<br/>Azure credentials"]
        EventSink["Event Sink<br/>80/443 HTTP/HTTPS<br/>CloudEvents<br/>Bearer Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway
    Client -.->|"OpenShift only"| Route

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/80<br/>mTLS STRICT<br/>Service Identity"| VS
    Route -->|"HTTP/80<br/>mTLS STRICT"| VS

    %% Service Mesh routing
    VS -->|"HTTP/80<br/>mTLS STRICT"| Activator
    Activator -->|"HTTP/9081<br/>Plaintext (localhost)"| Agent
    Agent -->|"HTTP/8080<br/>Plaintext (localhost)"| ModelServer

    %% Storage initialization
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/IRSA"| S3
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure creds"| Azure

    %% Logging
    Agent -.->|"HTTP/HTTPS<br/>80/443<br/>Bearer Token"| EventSink

    %% Control plane
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>API Server cert"| Webhook
    Controller -->|"Creates/manages"| VS
    Controller -->|"Creates/manages"| PredictorPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,Route ingress
    class Activator,VS,Agent,ModelServer,StorageInit servicemesh
    class Controller,Webhook,K8sAPI controlplane
    class S3,GCS,Azure,EventSink externalservice
