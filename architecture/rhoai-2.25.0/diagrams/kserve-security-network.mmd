graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+ Termination<br/>RequestAuthentication JWT"]
        Route["OpenShift Route<br/>443/TCP HTTPS<br/>TLS Edge Termination"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        VirtualService["Istio VirtualService<br/>Traffic Routing<br/>Canary Support"]

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: controller<br/>Auto-scaling<br/>Scale-to-zero"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            subgraph Pod["InferenceService Pod"]
                direction LR
                StorageInit["storage-initializer<br/>Init Container<br/>Downloads models"]
                Agent["agent<br/>Sidecar<br/>:9081 Proxy<br/>Batching/Logging"]
                ModelServer["model-server<br/>:8080 HTTP<br/>:9000 gRPC<br/>Framework-specific"]
                EnvoySidecar["Istio Envoy<br/>mTLS STRICT<br/>:15001/:15006"]

                StorageInit -.->|writes /mnt/models| ModelServer
                Agent -->|localhost:8080| ModelServer
                EnvoySidecar -.->|intercepts| Agent
            end
        end

        subgraph NS_EventSink["Event Sink (Optional)"]
            EventSink["Knative Broker<br/>80/443 TCP<br/>CloudEvents"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>:6443/TCP HTTPS TLS 1.2+"]

        subgraph NS_KServe["Namespace: kserve"]
            Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>:8080 Metrics<br/>:8081 Health<br/>:8443 HTTPS"]
            Webhook["kserve-webhook-server<br/>:9443/TCP HTTPS TLS 1.2+<br/>Mutating & Validating"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM (IRSA)"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Azure Credentials"]
        KnativeAPI["Knative Serving API<br/>via K8s API<br/>6443/TCP HTTPS"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Gateway
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Route

    %% Ingress to Service Mesh
    Gateway -->|HTTP/80<br/>mTLS STRICT<br/>Service Identity| VirtualService
    Route -->|HTTP/80<br/>mTLS STRICT| VirtualService

    %% Service Mesh Routing
    VirtualService -->|HTTP/80<br/>mTLS<br/>x509 cert| Activator
    Activator -->|HTTP/8012<br/>mTLS<br/>Service Identity| Agent

    %% Pod to External Storage
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Secret| S3
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>GCP SA| GCS
    StorageInit -->|HTTPS/443<br/>TLS 1.2+<br/>Azure Creds| Azure

    %% Logging
    Agent -.->|HTTP/HTTPS<br/>80/443<br/>Bearer Token<br/>CloudEvents| EventSink

    %% Control Plane
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>API Server cert| Webhook
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| KnativeAPI

    %% Controller creates resources
    Controller -.->|creates/manages| Pod
    Controller -.->|creates| VirtualService

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#d32f2f,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#000
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef controlplane fill:#dae8fc,stroke:#4a90e2,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class Client external
    class Gateway,Route ingress
    class VirtualService,Activator,Pod,StorageInit,Agent,ModelServer,EnvoySidecar,EventSink servicemesh
    class K8sAPI,Controller,Webhook controlplane
    class S3,GCS,Azure,KnativeAPI externalservice

    %% Legend
    subgraph Legend["Trust Zones"]
        L1[External - Untrusted]
        L2[Ingress - DMZ]
        L3[Service Mesh - mTLS STRICT]
        L4[Control Plane - Kubernetes]
        L5[External Services]
    end

    class L1 external
    class L2 ingress
    class L3 servicemesh
    class L4 controlplane
    class L5 externalservice
