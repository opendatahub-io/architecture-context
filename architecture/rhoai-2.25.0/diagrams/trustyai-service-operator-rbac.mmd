graph TD
    subgraph "Service Accounts"
        SA1[controller-manager<br/>Namespace: operator-ns]
        SA2[trustyai-service-name<br/>Namespace: user-ns]
        SA3[orchestrator-name<br/>Namespace: user-ns]
        SA4[default<br/>All Namespaces]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[leader-election-role]
        CR3[auth-proxy-role]
        CR4[non-admin-lmeval-role]
    end

    subgraph "Role Bindings"
        CRB1[manager-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[auth-proxy-rolebinding]
        CRB4[default-lmeval-user-rolebinding]
    end

    subgraph "API Resources - Core"
        R1[ConfigMaps<br/>Secrets<br/>Services<br/>PVCs<br/>Pods<br/>ServiceAccounts]
        R2[Events]
        R3[PersistentVolumes]
        R4[Pods/exec]
    end

    subgraph "API Resources - Apps"
        R5[Deployments<br/>Deployments/finalizers<br/>Deployments/status]
    end

    subgraph "API Resources - TrustyAI"
        R6[trustyai.opendatahub.io<br/>TrustyAIServices<br/>LMEvalJobs<br/>GuardrailsOrchestrators]
        R7[trustyai.opendatahub.io<br/>*/finalizers<br/>*/status]
    end

    subgraph "API Resources - KServe"
        R8[serving.kserve.io<br/>InferenceServices<br/>ServingRuntimes]
        R9[serving.kserve.io<br/>InferenceServices/finalizers]
    end

    subgraph "API Resources - Kueue"
        R10[kueue.x-k8s.io<br/>Workloads<br/>ResourceFlavors<br/>WorkloadPriorityClasses]
    end

    subgraph "API Resources - Networking"
        R11[route.openshift.io<br/>Routes]
        R12[networking.istio.io<br/>VirtualServices<br/>DestinationRules]
        R13[monitoring.coreos.com<br/>ServiceMonitors]
    end

    subgraph "API Resources - RBAC"
        R14[rbac.authorization.k8s.io<br/>ClusterRoleBindings]
    end

    subgraph "API Resources - Other"
        R15[coordination.k8s.io<br/>Leases]
        R16[apiextensions.k8s.io<br/>CustomResourceDefinitions]
        R17[scheduling.k8s.io<br/>PriorityClasses]
    end

    %% Service Account to Role Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA1 -->|bound via| CRB3
    SA4 -->|bound via| CRB4

    %% Role Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    CRB4 -->|grants| CR4

    %% manager-role permissions
    CR1 -->|create,delete,get,list,patch,update,watch| R1
    CR1 -->|create,patch,update,watch| R2
    CR1 -->|get,list,watch| R3
    CR1 -->|create,delete,get,list,watch| R4
    CR1 -->|create,delete,get,list,patch,update,watch| R5
    CR1 -->|create,delete,get,list,patch,update,watch| R6
    CR1 -->|update| R7
    CR1 -->|get,list,patch,update,watch| R8
    CR1 -->|delete,get,list,patch,update,watch| R9
    CR1 -->|create,delete,get,list,patch,update,watch| R10
    CR1 -->|create,delete,get,list,patch,update,watch| R11
    CR1 -->|create,delete,get,list,patch,update,watch| R12
    CR1 -->|create,list,watch| R13
    CR1 -->|create,delete,get,list,update,watch| R14
    CR1 -->|get,list,watch| R16
    CR1 -->|get,list,watch| R17

    %% leader-election-role permissions
    CR2 -->|get,list,watch,create,update,patch,delete| R1
    CR2 -->|get,list,watch,create,update,patch,delete| R15
    CR2 -->|create,patch| R2

    %% non-admin-lmeval-role permissions
    CR4 -->|create,delete,get,list,patch,update,watch| R6

