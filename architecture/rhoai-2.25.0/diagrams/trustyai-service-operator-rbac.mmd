graph TD
    subgraph "Service Accounts"
        SA1[controller-manager<br/>operator-namespace]
        SA2[default<br/>all-namespaces]
        SA3["{trustyai-service-name}-sa<br/>{user-namespace}"]
        SA4["{lmevaljob-name}-sa<br/>{user-namespace}"]
        SA5["{orchestrator-name}-sa<br/>{user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[auth-proxy-rolebinding]
        CRB4[default-lmeval-user-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[manager-role<br/>Main Operator Permissions]
        CR2[leader-election-role<br/>Leader Election]
        CR3[auth-proxy-role<br/>Metrics Proxy]
        CR4[non-admin-lmeval-role<br/>LMEvalJob Management]
    end

    subgraph "API Resources - Core"
        Core1["Core APIs<br/>configmaps, secrets, services<br/>serviceaccounts, pods, events<br/>persistentvolumeclaims, persistentvolumes"]
        Core2["Core APIs<br/>pods/exec"]
    end

    subgraph "API Resources - Apps"
        Apps1["apps<br/>deployments<br/>deployments/finalizers<br/>deployments/status"]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAI1["trustyai.opendatahub.io<br/>TrustyAIService"]
        TrustyAI2["trustyai.opendatahub.io<br/>LMEvalJob"]
        TrustyAI3["trustyai.opendatahub.io<br/>GuardrailsOrchestrator"]
    end

    subgraph "API Resources - KServe"
        KServe1["serving.kserve.io<br/>InferenceService<br/>InferenceService/finalizers"]
        KServe2["serving.kserve.io<br/>ServingRuntime"]
    end

    subgraph "API Resources - OpenShift"
        Route1["route.openshift.io<br/>Route"]
    end

    subgraph "API Resources - Istio"
        Istio1["networking.istio.io<br/>VirtualService<br/>DestinationRule"]
    end

    subgraph "API Resources - Monitoring"
        Monitor1["monitoring.coreos.com<br/>ServiceMonitor"]
    end

    subgraph "API Resources - Kueue"
        Kueue1["kueue.x-k8s.io<br/>Workload<br/>Workload/finalizers<br/>Workload/status"]
        Kueue2["kueue.x-k8s.io<br/>ResourceFlavor<br/>WorkloadPriorityClass"]
    end

    subgraph "API Resources - RBAC"
        RBAC1["rbac.authorization.k8s.io<br/>ClusterRoleBinding"]
    end

    subgraph "API Resources - Other"
        Other1["coordination.k8s.io<br/>Lease"]
        Other2["apiextensions.k8s.io<br/>CustomResourceDefinition"]
        Other3["scheduling.k8s.io<br/>PriorityClass"]
    end

    %% Service Account to ClusterRoleBinding
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA1 -->|bound via| CRB3
    SA2 -->|bound via| CRB4

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    CRB4 -->|grants| CR4

    %% manager-role permissions
    CR1 -->|create,delete,get,list,patch,update,watch| Core1
    CR1 -->|create,delete,get,list,watch| Core2
    CR1 -->|create,delete,get,list,patch,update,watch| Apps1
    CR1 -->|create,delete,get,list,patch,update,watch| TrustyAI1
    CR1 -->|create,delete,get,list,patch,update,watch| TrustyAI2
    CR1 -->|create,delete,get,list,patch,update,watch| TrustyAI3
    CR1 -->|get,list,patch,update,watch,delete| KServe1
    CR1 -->|get,list,watch| KServe2
    CR1 -->|create,delete,get,list,patch,update,watch| Route1
    CR1 -->|create,delete,get,list,patch,update,watch| Istio1
    CR1 -->|create,list,watch| Monitor1
    CR1 -->|create,delete,get,list,patch,update,watch| Kueue1
    CR1 -->|get,list,watch| Kueue2
    CR1 -->|create,delete,get,list,update,watch| RBAC1
    CR1 -->|create,get,update| Other1
    CR1 -->|get,list,watch| Other2
    CR1 -->|get,list,watch| Other3

    %% leader-election-role permissions
    CR2 -->|get,list,watch,create,update,patch,delete| Other1
    CR2 -->|create,patch| Core1

    %% non-admin-lmeval-role permissions
    CR4 -->|create,delete,get,list,patch,update,watch| TrustyAI2

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA3 fill:#7ed321,stroke:#333,stroke-width:2px
    style SA4 fill:#7ed321,stroke:#333,stroke-width:2px
    style SA5 fill:#7ed321,stroke:#333,stroke-width:2px

    style CR1 fill:#f5a623,stroke:#333,stroke-width:3px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB1 fill:#bd10e0,stroke:#333,stroke-width:2px
    style CRB2 fill:#bd10e0,stroke:#333,stroke-width:2px
    style CRB3 fill:#bd10e0,stroke:#333,stroke-width:2px
    style CRB4 fill:#bd10e0,stroke:#333,stroke-width:2px

    style TrustyAI1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style TrustyAI2 fill:#50e3c2,stroke:#333,stroke-width:2px
    style TrustyAI3 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KServe1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style KServe2 fill:#50e3c2,stroke:#333,stroke-width:2px
