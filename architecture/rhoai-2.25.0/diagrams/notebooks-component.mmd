    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style KFPipelines fill:#7ed321,stroke:#333,stroke-width:2px
    style Tekton fill:#f5a623,stroke:#333,stroke-width:2px
    style Quay fill:#999,stroke:#333,stroke-width:2px
    style UBI9 fill:#e8e8e8,stroke:#333,stroke-width:2px
