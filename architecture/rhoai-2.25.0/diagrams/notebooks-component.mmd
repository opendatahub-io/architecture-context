graph TB
    subgraph "Notebooks Component - Container Images"
        direction TB

        subgraph "Workbench Images"
            JupyterCPU[Jupyter Minimal CPU<br/>Python 3.12]
            JupyterCUDA[Jupyter Minimal CUDA<br/>NVIDIA GPU Support]
            JupyterROCm[Jupyter Minimal ROCm<br/>AMD GPU Support]
            JupyterDS[Jupyter DataScience<br/>Pandas, Scikit-learn]
            JupyterPyTorchCUDA[Jupyter PyTorch CUDA<br/>Deep Learning - NVIDIA]
            JupyterPyTorchROCm[Jupyter PyTorch ROCm<br/>Deep Learning - AMD]
            JupyterTFCUDA[Jupyter TensorFlow CUDA<br/>Deep Learning - NVIDIA]
            JupyterTFROCm[Jupyter TensorFlow ROCm<br/>Deep Learning - AMD]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainable AI]
            JupyterLLM[Jupyter LLMCompressor<br/>LLM Compression]

            CodeServerDS[Code Server DataScience<br/>VS Code IDE]

            RStudioCPU[RStudio Minimal CPU<br/>R 4.x]
            RStudioCUDA[RStudio CUDA<br/>R 4.x with GPU]
        end

        subgraph "Runtime Images - Kubeflow Pipelines"
            RuntimeCPU[Runtime Minimal CPU<br/>Lightweight Python]
            RuntimeDS[Runtime DataScience<br/>Pandas, Scikit-learn]
            RuntimePyTorchCUDA[Runtime PyTorch CUDA<br/>ML Training - NVIDIA]
            RuntimePyTorchROCm[Runtime PyTorch ROCm<br/>ML Training - AMD]
            RuntimeTFCUDA[Runtime TensorFlow CUDA<br/>TF Pipelines - NVIDIA]
            RuntimeTFROCm[Runtime TensorFlow ROCm<br/>TF Pipelines - AMD]
            RuntimeLLM[Runtime LLMCompressor<br/>LLM Pipeline Tasks]
        end

        subgraph "Base Images"
            UBI9[UBI9 Python Base<br/>registry.access.redhat.com/ubi9/python-312]
            CUDABase[CUDA Base Images<br/>quay.io/rhoai/cuda-*]
            ROCmBase[ROCm Base Images<br/>quay.io/rhoai/rocm-*]
        end

        subgraph "Build & Deploy"
            Tekton[Tekton Pipelines<br/>Konflux Multi-arch Build]
            Kustomize[Kustomize Manifests<br/>ImageStream Definitions]
            BuildScripts[Build Scripts<br/>Python/Bash Automation]
        end
    end

    subgraph "External Dependencies"
        JupyterLab[JupyterLab 4.4]
        PyTorch[PyTorch 2.x]
        TensorFlow[TensorFlow 2.x]
        TrustyAI[TrustyAI Toolkit]
        LLMComp[LLMCompressor]
        OpenShiftCLI[OpenShift Client oc]
    end

    subgraph "ODH Platform Integration"
        NotebookController[ODH Notebook Controller]
        Dashboard[ODH Dashboard]
        KFPipelines[Kubeflow Pipelines]
        ImageStreams[OpenShift ImageStreams]
    end

    subgraph "Container Registries"
        Quay[Quay.io Registry]
        RedHatRegistry[registry.redhat.io]
    end

    %% Build dependencies
    UBI9 --> JupyterCPU
    UBI9 --> CodeServerDS
    UBI9 --> RStudioCPU
    UBI9 --> RuntimeCPU
    UBI9 --> RuntimeDS

    CUDABase --> JupyterCUDA
    CUDABase --> JupyterPyTorchCUDA
    CUDABase --> JupyterTFCUDA
    CUDABase --> JupyterLLM
    CUDABase --> RStudioCUDA
    CUDABase --> RuntimePyTorchCUDA
    CUDABase --> RuntimeTFCUDA
    CUDABase --> RuntimeLLM

    ROCmBase --> JupyterROCm
    ROCmBase --> JupyterPyTorchROCm
    ROCmBase --> JupyterTFROCm
    ROCmBase --> RuntimePyTorchROCm
    ROCmBase --> RuntimeTFROCm

    %% Framework dependencies
    JupyterLab -.-> JupyterCPU
    JupyterLab -.-> JupyterCUDA
    JupyterLab -.-> JupyterDS
    JupyterLab -.-> JupyterPyTorchCUDA

    PyTorch -.-> JupyterPyTorchCUDA
    PyTorch -.-> JupyterPyTorchROCm
    PyTorch -.-> RuntimePyTorchCUDA

    TensorFlow -.-> JupyterTFCUDA
    TensorFlow -.-> JupyterTFROCm

    TrustyAI -.-> JupyterTrustyAI
    LLMComp -.-> JupyterLLM

    %% Build process
    Tekton -->|builds| JupyterCPU
    Tekton -->|builds| RuntimeCPU
    Tekton -->|pushes| Quay

    Kustomize -->|creates| ImageStreams
    BuildScripts -->|automates| Tekton

    %% Platform integration
    ImageStreams -->|references| Quay
    NotebookController -->|launches pods using| ImageStreams
    Dashboard -->|lists images from| ImageStreams
    KFPipelines -->|executes tasks in| RuntimeCPU
    KFPipelines -->|executes tasks in| RuntimePyTorchCUDA

    %% Registry connections
    Quay -.->|pulls from| RedHatRegistry

