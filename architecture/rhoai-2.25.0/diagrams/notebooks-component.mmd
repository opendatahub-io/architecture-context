graph TB
    subgraph "Notebooks Component (Container Images)"
        subgraph "Workbench Images"
            JupyterCPU[Jupyter Minimal CPU<br/>Python 3.12, JupyterLab 4.4]
            JupyterCUDA[Jupyter PyTorch CUDA<br/>PyTorch 2.x, CUDA 12.6/12.8]
            JupyterROCm[Jupyter PyTorch ROCm<br/>PyTorch 2.x, ROCm 6.2/6.4]
            JupyterTF[Jupyter TensorFlow CUDA<br/>TensorFlow 2.x, CUDA]
            JupyterTrustyAI[Jupyter TrustyAI CPU<br/>TrustyAI, Pandas]
            VSCode[Code Server CPU<br/>VS Code, Python 3.12]
            RStudio[RStudio CPU/CUDA<br/>R 4.x, Python 3.11]
        end

        subgraph "Runtime Images"
            RuntimeCPU[Runtime Minimal CPU<br/>Python 3.12]
            RuntimePyTorch[Runtime PyTorch CUDA/ROCm<br/>PyTorch 2.x]
            RuntimeTF[Runtime TensorFlow CUDA/ROCm<br/>TensorFlow 2.x]
            RuntimeLLM[Runtime LLMCompressor CUDA<br/>PyTorch, LLMCompressor]
        end

        subgraph "Build Artifacts"
            BaseUBI[UBI9 Base Image<br/>Python 3.11/3.12]
            BaseCUDA[CUDA Base Image<br/>CUDA 12.6/12.8]
            BaseROCm[ROCm Base Image<br/>ROCm 6.2/6.4]
        end

        subgraph "Deployment Config"
            Kustomize[Kustomize Manifests<br/>ImageStream definitions]
            Tekton[Tekton Pipelines<br/>Multi-arch builds]
        end
    end

    subgraph "External Dependencies"
        UBI9[UBI9 Python Base<br/>registry.access.redhat.com]
        CUDA[CUDA Base<br/>quay.io/rhoai/cuda-*]
        ROCm[ROCm Base<br/>quay.io/rhoai/rocm-*]
        JupyterLab[JupyterLab 4.4]
        PyTorch[PyTorch 2.x]
        TensorFlow[TensorFlow 2.x]
        TrustyAI[TrustyAI Toolkit]
    end

    subgraph "ODH Platform Integration"
        NotebookController[ODH Notebook Controller<br/>Launches workbench pods]
        Dashboard[ODH Dashboard<br/>Lists available images]
        Pipelines[Kubeflow Pipelines<br/>Uses runtime images]
        ImageStream[OpenShift ImageStreams<br/>Image registry]
    end

    subgraph "Build System"
        Konflux[Konflux CI/CD<br/>Multi-arch builds]
        Quay[Quay.io Registry<br/>Image storage]
    end

    %% Base image dependencies
    BaseUBI -->|extends| UBI9
    BaseCUDA -->|extends| CUDA
    BaseROCm -->|extends| ROCm

    %% Workbench builds
    JupyterCPU -->|built from| BaseUBI
    JupyterCUDA -->|built from| BaseCUDA
    JupyterROCm -->|built from| BaseROCm
    JupyterTF -->|built from| BaseCUDA
    JupyterTrustyAI -->|built from| BaseUBI
    VSCode -->|built from| BaseUBI
    RStudio -->|built from| BaseUBI

    %% Runtime builds
    RuntimeCPU -->|built from| BaseUBI
    RuntimePyTorch -->|built from| BaseCUDA
    RuntimeTF -->|built from| BaseCUDA
    RuntimeLLM -->|built from| BaseCUDA

    %% Framework dependencies
    JupyterCPU -->|includes| JupyterLab
    JupyterCUDA -->|includes| PyTorch
    JupyterROCm -->|includes| PyTorch
    JupyterTF -->|includes| TensorFlow
    JupyterTrustyAI -->|includes| TrustyAI

    %% Build and deployment
    Konflux -->|builds| JupyterCPU
    Konflux -->|builds| RuntimeCPU
    Konflux -->|pushes to| Quay
    Kustomize -->|defines| ImageStream
    ImageStream -->|pulls from| Quay

    %% Platform integration
    NotebookController -->|launches pods using| JupyterCPU
    NotebookController -->|launches pods using| VSCode
    NotebookController -->|launches pods using| RStudio
    Dashboard -->|queries| ImageStream
    Pipelines -->|executes tasks in| RuntimeCPU
    Pipelines -->|executes tasks in| RuntimePyTorch

    %% Styling
    style JupyterCPU fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterCUDA fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterROCm fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterTF fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterTrustyAI fill:#4a90e2,stroke:#333,stroke-width:2px
    style VSCode fill:#4a90e2,stroke:#333,stroke-width:2px
    style RStudio fill:#4a90e2,stroke:#333,stroke-width:2px
    style RuntimeCPU fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimePyTorch fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimeTF fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimeLLM fill:#7ed321,stroke:#333,stroke-width:2px
    style UBI9 fill:#e8e8e8,stroke:#333
    style CUDA fill:#e8e8e8,stroke:#333
    style ROCm fill:#e8e8e8,stroke:#333
    style NotebookController fill:#f5a623,stroke:#333
    style Dashboard fill:#f5a623,stroke:#333
    style Pipelines fill:#f5a623,stroke:#333
