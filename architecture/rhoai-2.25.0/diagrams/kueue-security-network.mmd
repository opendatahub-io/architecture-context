graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User kubectl"]
    end

    subgraph K8sAPIBoundary["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>Port: 443/TCP<br/>K8s RBAC enforcement"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (opendatahub)"]
        direction TB

        WebhookService["kueue-webhook-service<br/>Service: ClusterIP<br/>Port: 443 to 9443<br/>TLS 1.2+ mTLS"]

        Controller["kueue-controller-manager<br/>Deployment: 1 replica<br/>SA: kueue-controller-manager<br/>Non-root user 65532"]

        MetricsService["kueue-metrics-service<br/>Service: ClusterIP<br/>Port: 8443/TCP<br/>TLS 1.2+ Bearer Token"]

        VisibilityServer["kueue-visibility-server<br/>In-process HTTP<br/>Aggregated API<br/>K8s RBAC"]

        HealthChecks["Health Checks<br/>Port: 8081/TCP HTTP<br/>healthz and readyz<br/>No auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        CertManager["cert-manager<br/>Port: 443/TCP HTTPS<br/>TLS certificate provisioning"]
        RemoteK8s["Remote K8s API Servers<br/>Port: 443/TCP HTTPS<br/>MultiKueue feature"]
        ClusterAutoscaler["Cluster Autoscaler<br/>Port: 443/TCP HTTPS<br/>Watch ProvisioningRequest"]
        Prometheus["Prometheus<br/>Metrics Scraper<br/>Port: 8443/TCP HTTPS"]
    end

    subgraph WorkloadResources["WORKLOAD RESOURCES"]
        BatchJob["Batch Jobs<br/>batch/v1"]
        KubeflowJobs["Kubeflow Jobs<br/>TFJob PyTorchJob MPIJob"]
        RayJobs["Ray Jobs<br/>RayJob RayCluster"]
        JobSet["JobSet<br/>jobset.x-k8s.io"]
        AppWrapper["AppWrapper<br/>workload.codeflare.dev"]
    end

    subgraph KueueCRs["KUEUE CUSTOM RESOURCES"]
        Workload["Workload<br/>kueue.x-k8s.io/v1beta1"]
        ClusterQueue["ClusterQueue<br/>kueue.x-k8s.io/v1beta1"]
        LocalQueue["LocalQueue<br/>kueue.x-k8s.io/v1beta1"]
        ResourceFlavor["ResourceFlavor<br/>kueue.x-k8s.io/v1beta1"]
        ProvisioningRequestCR["ProvisioningRequest<br/>autoscaling.x-k8s.io/v1beta1"]
    end

    %% Flows
    User -->|HTTPS 443/TCP<br/>TLS 1.3<br/>Bearer Token| K8sAPI

    K8sAPI -->|HTTPS 9443/TCP<br/>TLS 1.2+ mTLS<br/>POST mutate validate| WebhookService

    K8sAPI -->|In-process HTTP<br/>Aggregated API<br/>K8s RBAC| VisibilityServer

    Controller -->|HTTPS 443/TCP<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    Controller -->|HTTPS 443/TCP<br/>Request certs| CertManager

    Controller -->|HTTPS 443/TCP<br/>TLS 1.2+<br/>Kubeconfig| RemoteK8s

    Prometheus -->|HTTPS 8443/TCP<br/>TLS 1.2+<br/>Bearer Token| MetricsService

    Controller -->|HTTPS 443/TCP<br/>Watch Patch<br/>Bearer Token| BatchJob
    Controller -->|HTTPS 443/TCP<br/>Watch Patch<br/>Bearer Token| KubeflowJobs
    Controller -->|HTTPS 443/TCP<br/>Watch Patch<br/>Bearer Token| RayJobs
    Controller -->|HTTPS 443/TCP<br/>Watch Patch<br/>Bearer Token| JobSet
    Controller -->|HTTPS 443/TCP<br/>Watch Patch<br/>Bearer Token| AppWrapper

    Controller -->|HTTPS 443/TCP<br/>Watch Reconcile| Workload
    Controller -->|HTTPS 443/TCP<br/>Watch Reconcile| ClusterQueue
    Controller -->|HTTPS 443/TCP<br/>Watch Reconcile| LocalQueue
    Controller -->|HTTPS 443/TCP<br/>Watch Reconcile| ResourceFlavor

    Controller -->|HTTPS 443/TCP<br/>Create Update<br/>Bearer Token| ProvisioningRequestCR
    ClusterAutoscaler -->|HTTPS 443/TCP<br/>Watch<br/>Bearer Token| ProvisioningRequestCR

    User -->|HTTPS 443/TCP<br/>GET pendingworkloads<br/>Bearer Token| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cr fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI k8sapi
    class WebhookService,Controller,MetricsService,VisibilityServer,HealthChecks kueuens
    class CertManager,RemoteK8s,ClusterAutoscaler,Prometheus externalservice
    class BatchJob,KubeflowJobs,RayJobs,JobSet,AppWrapper workload
    class Workload,ClusterQueue,LocalQueue,ResourceFlavor,ProvisioningRequestCR cr
