graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/kubectl]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.3<br/>Bearer Token + RBAC"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (opendatahub)"]
        direction TB

        WebhookSvc["kueue-webhook-service<br/>ClusterIP<br/>443/TCP → 9443/TCP<br/>TLS cert: cert-manager"]

        MetricsSvc["kueue-metrics-service<br/>ClusterIP<br/>8443/TCP → https-metrics<br/>TLS 1.2+"]

        Controller["kueue-controller-manager<br/>Deployment (1 replica)<br/>SA: kueue-controller-manager<br/>User: 65532:65532<br/>FIPS: Enabled"]

        WebhookSvc --> Controller
        MetricsSvc --> Controller
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>SA: prometheus-k8s"]
    end

    subgraph CertManagement["CERTIFICATE MANAGEMENT"]
        CertManager["cert-manager<br/>TLS Certificate Issuer<br/>90-day rotation"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        RemoteCluster["Remote K8s API Servers<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Kubeconfig<br/>(MultiKueue)"]
    end

    subgraph Autoscaling["CLUSTER AUTOSCALING (Internal)"]
        ClusterAutoscaler["Cluster Autoscaler<br/>openshift-machine-api<br/>Watches ProvisioningRequests"]
    end

    subgraph ManagedResources["MANAGED RESOURCES"]
        Jobs["Batch Jobs<br/>Kubeflow Jobs<br/>Ray Jobs<br/>JobSets<br/>AppWrappers"]
        CRDs["Kueue CRDs<br/>Workloads<br/>ClusterQueues<br/>LocalQueues"]
    end

    %% User flows
    User -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| K8sAPI

    %% Webhook flows
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS<br/>API Server Client Cert| WebhookSvc

    %% Controller to API Server
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Watch/Patch Resources| K8sAPI

    %% API Server to managed resources
    K8sAPI -.->|manages| Jobs
    K8sAPI -.->|manages| CRDs

    %% Controller watches managed resources
    Controller -.->|watches via API| Jobs
    Controller -.->|watches via API| CRDs

    %% Metrics flow
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token<br/>ServiceAccount| MetricsSvc

    %% Certificate management
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Request Certs| CertManager
    CertManager -.->|provisions| WebhookSvc

    %% MultiKueue (optional)
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Kubeconfig| RemoteCluster

    %% Autoscaling integration
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Create ProvisioningRequest| K8sAPI
    ClusterAutoscaler -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Watch ProvisioningRequest| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef kueuens fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef certmgmt fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f9f9f9,stroke:#999,stroke-width:2px,stroke-dasharray: 5 5
    classDef autoscaling fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef resources fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class WebhookSvc,MetricsSvc,Controller kueuens
    class Prometheus monitoring
    class CertManager certmgmt
    class RemoteCluster externalservice
    class ClusterAutoscaler autoscaling
    class Jobs,CRDs resources
