graph TD
    subgraph "Service Accounts"
        SA_Manager[kueue-controller-manager<br/>opendatahub namespace]
        SA_Metrics[kueue-controller-manager-metrics-reader<br/>opendatahub namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kueue-manager-rolebinding]
        CRB_Metrics[kueue-metrics-reader-clusterrolebinding]
    end

    subgraph "Role Bindings (opendatahub)"
        RB_LeaderElection[kueue-leader-election-rolebinding]
        RB_MetricsAuth[kueue-metrics-auth-rolebinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[kueue-manager-role]
        CR_ClusterQueueEditor[kueue-clusterqueue-editor-role]
        CR_ClusterQueueViewer[kueue-clusterqueue-viewer-role]
        CR_LocalQueueEditor[kueue-localqueue-editor-role]
        CR_LocalQueueViewer[kueue-localqueue-viewer-role]
        CR_BatchAdmin[kueue-batch-admin-role]
        CR_BatchUser[kueue-batch-user-role]
        CR_MetricsReader[kueue-metrics-reader-role]
    end

    subgraph "Roles (opendatahub)"
        R_LeaderElection[kueue-leader-election-role]
        R_MetricsAuth[kueue-metrics-auth-role]
    end

    subgraph "Kueue API Resources"
        KueueCRDs["kueue.x-k8s.io:<br/>workloads<br/>clusterqueues<br/>localqueues<br/>resourceflavors<br/>workloadpriorityclasses<br/>admissionchecks<br/>provisioningrequestconfigs<br/>multikueueconfigs<br/>multikueueclusters<br/>cohorts<br/>topologies"]
        VisibilityAPI["visibility.kueue.x-k8s.io:<br/>clusterqueues/pendingworkloads<br/>localqueues/pendingworkloads"]
    end

    subgraph "Kubernetes Core Resources"
        CoreResources["core:<br/>events<br/>pods<br/>namespaces<br/>nodes<br/>limitranges<br/>secrets<br/>podtemplates<br/>services<br/>endpoints<br/>configmaps"]
        CoordResources["coordination.k8s.io:<br/>leases"]
    end

    subgraph "Workload Resources"
        BatchResources["batch:<br/>jobs"]
        AppsResources["apps:<br/>deployments<br/>replicasets<br/>statefulsets"]
        AutoscalingResources["autoscaling.x-k8s.io:<br/>provisioningrequests"]
        JobSetResources["jobset.x-k8s.io:<br/>jobsets"]
        KubeflowResources["kubeflow.org:<br/>tfjobs<br/>pytorchjobs<br/>mpijobs<br/>xgboostjobs<br/>paddlejobs"]
        RayResources["ray.io:<br/>rayjobs<br/>rayclusters"]
        AppWrapperResources["workload.codeflare.dev:<br/>appwrappers"]
        AdmissionResources["admissionregistration.k8s.io:<br/>mutatingwebhookconfigurations<br/>validatingwebhookconfigurations"]
    end

    %% Service Account Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| RB_LeaderElection
    SA_Manager -->|bound via| RB_MetricsAuth

    SA_Metrics -->|bound via| CRB_Metrics

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsReader

    RB_LeaderElection -->|grants| R_LeaderElection
    RB_MetricsAuth -->|grants| R_MetricsAuth

    %% ClusterRole Permissions (kueue-manager-role)
    CR_Manager -->|get,list,watch,create,update,patch,delete| KueueCRDs
    CR_Manager -->|get,list,watch,create,update,patch| CoreResources
    CR_Manager -->|delete| CoreResources
    CR_Manager -->|get,list,watch,patch,update| BatchResources
    CR_Manager -->|get,list,watch| AppsResources
    CR_Manager -->|get,list,watch,create,update,patch,delete| AutoscalingResources
    CR_Manager -->|get,list,watch,patch,update| JobSetResources
    CR_Manager -->|get,list,watch,patch,update| KubeflowResources
    CR_Manager -->|get,list,watch,patch,update| RayResources
    CR_Manager -->|get,list,watch,patch,update| AppWrapperResources
    CR_Manager -->|get,list,watch,update| AdmissionResources

    %% ClusterRole Permissions (viewers)
    CR_ClusterQueueViewer -->|get,list,watch| KueueCRDs
    CR_ClusterQueueViewer -->|get| VisibilityAPI
    CR_LocalQueueViewer -->|get,list,watch| KueueCRDs

    %% ClusterRole Permissions (editors)
    CR_ClusterQueueEditor -->|get,list,watch,create,update,patch,delete| KueueCRDs
    CR_LocalQueueEditor -->|get,list,watch,create,update,patch,delete| KueueCRDs

    %% ClusterRole Permissions (batch)
    CR_BatchAdmin -->|get,list,watch,create,update,patch,delete| CoreResources
    CR_BatchUser -->|get,list,watch,create,update,patch,delete| KueueCRDs

    %% ClusterRole Permissions (metrics)
    CR_MetricsReader -->|get,list,watch| CoreResources

    %% Role Permissions (leader election)
    R_LeaderElection -->|get,list,watch,create,update,patch,delete| CoreResources
    R_LeaderElection -->|get,list,watch,create,update,patch,delete| CoordResources

    %% Role Permissions (metrics auth)
    R_MetricsAuth -->|get| CoreResources

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Metrics fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CRB_Manager fill:#f39c12,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Metrics fill:#f39c12,stroke:#333,stroke-width:2px,color:#fff
    style RB_LeaderElection fill:#f39c12,stroke:#333,stroke-width:2px,color:#fff
    style RB_MetricsAuth fill:#f39c12,stroke:#333,stroke-width:2px,color:#fff

    style CR_Manager fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style CR_ClusterQueueEditor fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_ClusterQueueViewer fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_LocalQueueEditor fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_LocalQueueViewer fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_BatchAdmin fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_BatchUser fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR_MetricsReader fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff

    style R_LeaderElection fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style R_MetricsAuth fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    style KueueCRDs fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style VisibilityAPI fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style CoreResources fill:#16a085,stroke:#333,stroke-width:2px,color:#fff
    style CoordResources fill:#16a085,stroke:#333,stroke-width:2px,color:#fff
    style BatchResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style AppsResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style AutoscalingResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style JobSetResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style KubeflowResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style RayResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style AppWrapperResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
    style AdmissionResources fill:#2980b9,stroke:#333,stroke-width:2px,color:#fff
