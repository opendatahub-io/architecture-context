graph TD
    subgraph "Service Accounts"
        SA_Controller[kueue-controller-manager<br/>Namespace: opendatahub]
        SA_MetricsReader[kueue-controller-manager-metrics-reader<br/>System ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kueue-manager-rolebinding<br/>ClusterRoleBinding]
        CRB_MetricsReader[kueue-metrics-reader-clusterrolebinding<br/>ClusterRoleBinding]
        RB_LeaderElection[kueue-leader-election-rolebinding<br/>RoleBinding - opendatahub]
        RB_MetricsAuth[kueue-metrics-auth-rolebinding<br/>RoleBinding - opendatahub]
    end

    subgraph "ClusterRoles"
        CR_Manager[kueue-manager-role<br/>ClusterRole]
        CR_MetricsReader[kueue-metrics-reader-role<br/>ClusterRole]
        CR_LeaderElection[kueue-leader-election-role<br/>Role]
        CR_MetricsAuth[kueue-metrics-auth-role<br/>Role]

        CR_BatchAdmin[kueue-batch-admin-role<br/>ClusterRole - User Role]
        CR_BatchUser[kueue-batch-user-role<br/>ClusterRole - User Role]
        CR_ClusterQueueEditor[kueue-clusterqueue-editor-role<br/>ClusterRole - User Role]
        CR_ClusterQueueViewer[kueue-clusterqueue-viewer-role<br/>ClusterRole - User Role]
        CR_LocalQueueEditor[kueue-localqueue-editor-role<br/>ClusterRole - User Role]
        CR_LocalQueueViewer[kueue-localqueue-viewer-role<br/>ClusterRole - User Role]
    end

    subgraph "Kueue API Resources"
        API_Workloads[kueue.x-k8s.io<br/>Workloads, ClusterQueues, LocalQueues<br/>ResourceFlavors, AdmissionChecks<br/>WorkloadPriorityClasses, Cohorts<br/>Topologies, ProvisioningRequestConfigs<br/>MultiKueueConfigs, MultiKueueClusters]
        API_Visibility[visibility.kueue.x-k8s.io<br/>ClusterQueues/pendingworkloads<br/>LocalQueues/pendingworkloads]
    end

    subgraph "Kubernetes Core Resources"
        Core_Resources[Core Resources<br/>Pods, Events, Namespaces<br/>Nodes, LimitRanges, Secrets<br/>ConfigMaps, Leases, PodTemplates]
        Batch_Resources[Batch Resources<br/>Jobs]
        Apps_Resources[Apps Resources<br/>Deployments, ReplicaSets<br/>StatefulSets]
        Autoscaling_Resources[Autoscaling Resources<br/>autoscaling.x-k8s.io/ProvisioningRequests]
        JobSet_Resources[JobSet Resources<br/>jobset.x-k8s.io/JobSets]
        Kubeflow_Resources[Kubeflow Resources<br/>kubeflow.org/TFJobs, PyTorchJobs<br/>MPIJobs, XGBoostJobs, PaddleJobs]
        Ray_Resources[Ray Resources<br/>ray.io/RayJobs, RayClusters]
        AppWrapper_Resources[AppWrapper Resources<br/>workload.codeflare.dev/AppWrappers]
        Admission_Resources[Admission Resources<br/>admissionregistration.k8s.io<br/>MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations]
        FlowControl_Resources[FlowControl Resources<br/>flowcontrol.apiserver.k8s.io<br/>FlowSchemas, PriorityLevelConfigurations]
    end

    %% Service Account to Role Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_LeaderElection
    SA_Controller -->|bound via| RB_MetricsAuth
    SA_MetricsReader -->|bound via| CRB_MetricsReader

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_MetricsReader -->|grants| CR_MetricsReader
    RB_LeaderElection -->|grants| CR_LeaderElection
    RB_MetricsAuth -->|grants| CR_MetricsAuth

    %% Manager Role Permissions
    CR_Manager -->|get,list,watch,create<br/>update,patch,delete| API_Workloads
    CR_Manager -->|get,list,watch,create<br/>update,patch| Core_Resources
    CR_Manager -->|delete| Core_Resources
    CR_Manager -->|get,list,watch<br/>patch,update| Batch_Resources
    CR_Manager -->|get,list,watch| Apps_Resources
    CR_Manager -->|get,list,watch,create<br/>update,patch,delete| Autoscaling_Resources
    CR_Manager -->|get,list,watch<br/>patch,update| JobSet_Resources
    CR_Manager -->|get,list,watch<br/>patch,update| Kubeflow_Resources
    CR_Manager -->|get,list,watch<br/>patch,update| Ray_Resources
    CR_Manager -->|get,list,watch<br/>patch,update| AppWrapper_Resources
    CR_Manager -->|get,list,watch,update| Admission_Resources
    CR_Manager -->|list,watch,patch| FlowControl_Resources

    %% Metrics Reader Permissions
    CR_MetricsReader -->|get,list,watch| Core_Resources

    %% Leader Election Permissions
    CR_LeaderElection -->|get,list,watch,create<br/>update,patch,delete| Core_Resources

    %% Metrics Auth Permissions
    CR_MetricsAuth -->|get| Core_Resources

    %% User Role Permissions
    CR_BatchAdmin -->|get,list,watch,create<br/>update,patch,delete| Core_Resources
    CR_BatchUser -->|get,list,watch,create<br/>update,patch,delete| API_Workloads
    CR_ClusterQueueEditor -->|get,list,watch,create<br/>update,patch,delete| API_Workloads
    CR_ClusterQueueViewer -->|get,list,watch| API_Workloads
    CR_ClusterQueueViewer -->|get| API_Visibility
    CR_LocalQueueEditor -->|get,list,watch,create<br/>update,patch,delete| API_Workloads
    CR_LocalQueueViewer -->|get,list,watch| API_Workloads

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_MetricsReader fill:#4a90e2,stroke:#333,color:#fff

    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_MetricsReader fill:#f5a623,stroke:#333
    style RB_LeaderElection fill:#f5a623,stroke:#333
    style RB_MetricsAuth fill:#f5a623,stroke:#333

    style CR_Manager fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style CR_MetricsReader fill:#e74c3c,stroke:#333,color:#fff
    style CR_LeaderElection fill:#e74c3c,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#e74c3c,stroke:#333,color:#fff

    style CR_BatchAdmin fill:#95a5a6,stroke:#333
    style CR_BatchUser fill:#95a5a6,stroke:#333
    style CR_ClusterQueueEditor fill:#95a5a6,stroke:#333
    style CR_ClusterQueueViewer fill:#95a5a6,stroke:#333
    style CR_LocalQueueEditor fill:#95a5a6,stroke:#333
    style CR_LocalQueueViewer fill:#95a5a6,stroke:#333

    style API_Workloads fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Visibility fill:#7ed321,stroke:#333
    style Core_Resources fill:#7ed321,stroke:#333
    style Batch_Resources fill:#7ed321,stroke:#333
    style Apps_Resources fill:#7ed321,stroke:#333
    style Autoscaling_Resources fill:#7ed321,stroke:#333
    style JobSet_Resources fill:#7ed321,stroke:#333
    style Kubeflow_Resources fill:#7ed321,stroke:#333
    style Ray_Resources fill:#7ed321,stroke:#333
    style AppWrapper_Resources fill:#7ed321,stroke:#333
    style Admission_Resources fill:#7ed321,stroke:#333
    style FlowControl_Resources fill:#7ed321,stroke:#333
