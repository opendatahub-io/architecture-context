graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>ServiceAccount]
        SA_Runtime["{runtime-sa}<br/>ServiceAccount<br/>(per runtime)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB_LeaderElection[modelmesh-controller-leader-election<br/>RoleBinding]
        CRB_AuthProxy[modelmesh-auth-proxy<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Controller[modelmesh-controller-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_ProxyRole[proxy-role<br/>ClusterRole]
        CR_Editor[inferenceservice-editor-role<br/>ClusterRole]
        CR_Viewer[inferenceservice-viewer-role<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[core/ConfigMaps<br/>create, delete, get, list, patch, update, watch]
        Core_Endpoints[core/Endpoints<br/>get, list, watch]
        Core_PVCs[core/PersistentVolumeClaims<br/>get, list, watch]
        Core_Namespaces[core/Namespaces<br/>get, list, patch, update, watch]
        Core_Secrets[core/Secrets<br/>create, delete, get, list, patch, update, watch]
        Core_Services[core/Services<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/Deployments<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_ServiceMonitors[monitoring.coreos.com/ServiceMonitors<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - serving.kserve.io"
        KServe_InferenceServices[serving.kserve.io/InferenceServices<br/>+ /finalizers, /status<br/>CRUD + watch]
        KServe_Predictors[serving.kserve.io/Predictors<br/>+ /finalizers, /status<br/>CRUD + watch]
        KServe_ServingRuntimes[serving.kserve.io/ServingRuntimes<br/>+ /finalizers, /status<br/>CRUD + watch]
        KServe_ClusterServingRuntimes[serving.kserve.io/ClusterServingRuntimes<br/>+ /finalizers, /status<br/>CRUD + watch]
    end

    subgraph "API Resources - Autoscaling"
        Autoscaling_HPA[autoscaling/HorizontalPodAutoscalers<br/>+ /status<br/>get, list, watch, create, delete, update]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_AuthProxy

    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_AuthProxy -->|grants| CR_ProxyRole

    %% Controller Role Permissions
    CR_Controller -->|manages| Core_ConfigMaps
    CR_Controller -->|reads| Core_Endpoints
    CR_Controller -->|reads| Core_PVCs
    CR_Controller -->|manages| Core_Namespaces
    CR_Controller -->|manages| Core_Secrets
    CR_Controller -->|manages| Core_Services
    CR_Controller -->|manages| Apps_Deployments
    CR_Controller -->|manages| Monitoring_ServiceMonitors
    CR_Controller -->|manages| KServe_InferenceServices
    CR_Controller -->|manages| KServe_Predictors
    CR_Controller -->|manages| KServe_ServingRuntimes
    CR_Controller -->|manages| KServe_ClusterServingRuntimes
    CR_Controller -->|manages| Autoscaling_HPA

    %% Editor Role (for users)
    CR_Editor -->|CRUD| KServe_InferenceServices

    %% Viewer Role (for users)
    CR_Viewer -->|read-only| KServe_InferenceServices

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f39c12,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff

    class SA_Controller,SA_Runtime serviceAccount
    class CRB_Controller,CRB_LeaderElection,CRB_AuthProxy binding
    class CR_Controller,CR_LeaderElection,CR_ProxyRole,CR_Editor,CR_Viewer role
    class Core_ConfigMaps,Core_Endpoints,Core_PVCs,Core_Namespaces,Core_Secrets,Core_Services,Apps_Deployments,Monitoring_ServiceMonitors,KServe_InferenceServices,KServe_Predictors,KServe_ServingRuntimes,KServe_ClusterServingRuntimes,Autoscaling_HPA resource
