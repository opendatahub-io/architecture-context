graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[modelmesh-auth-proxy<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_Leader[modelmesh-controller-leader-election<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Controller[modelmesh-controller-role<br/>ClusterRole]
        CR_Proxy[proxy-role<br/>ClusterRole]
        CR_ISVCEditor[inferenceservice-editor-role<br/>ClusterRole]
        CR_ISVCViewer[inferenceservice-viewer-role<br/>ClusterRole]
    end

    subgraph "Roles (Namespace-scoped)"
        R_Leader[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Core"
        RES_ConfigMaps[core/ConfigMaps]
        RES_Secrets[core/Secrets]
        RES_Services[core/Services]
        RES_Namespaces[core/Namespaces]
        RES_Endpoints[core/Endpoints]
        RES_PVCs[core/PersistentVolumeClaims]
        RES_Leases[coordination.k8s.io/Leases]
    end

    subgraph "API Resources - Apps"
        RES_Deployments[apps/Deployments]
    end

    subgraph "API Resources - Serving (KServe)"
        RES_ServingRuntimes[serving.kserve.io/ServingRuntimes]
        RES_ClusterServingRuntimes[serving.kserve.io/ClusterServingRuntimes]
        RES_InferenceServices[serving.kserve.io/InferenceServices]
        RES_Predictors[serving.kserve.io/Predictors]
    end

    subgraph "API Resources - Monitoring"
        RES_ServiceMonitors[monitoring.coreos.com/ServiceMonitors]
    end

    subgraph "API Resources - Autoscaling"
        RES_HPAs[autoscaling/HorizontalPodAutoscalers]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader

    %% Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    %% ClusterRole: modelmesh-controller-role permissions
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_ConfigMaps
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_Secrets
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_Services
    CR_Controller -->|"get, list, patch,<br/>update, watch"| RES_Namespaces
    CR_Controller -->|"get, list, watch"| RES_Endpoints
    CR_Controller -->|"get, list, watch"| RES_PVCs
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_Deployments
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_ServingRuntimes
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_ClusterServingRuntimes
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_InferenceServices
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_Predictors
    CR_Controller -->|"create, delete, get, list,<br/>patch, update, watch"| RES_ServiceMonitors
    CR_Controller -->|"create, delete, get, list,<br/>update, watch"| RES_HPAs

    %% Role: leader-election-role permissions
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| RES_ConfigMaps
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| RES_Leases

    %% Editor/Viewer roles (for users)
    CR_ISVCEditor -->|"create, delete, get, list,<br/>patch, update, watch"| RES_InferenceServices
    CR_ISVCViewer -->|"get, list, watch"| RES_InferenceServices

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_ISVCEditor fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_ISVCViewer fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f39c12,stroke:#333,stroke-width:2px
    style CRB_Controller fill:#85c1e9,stroke:#333,stroke-width:1px
    style CRB_Proxy fill:#85c1e9,stroke:#333,stroke-width:1px
    style RB_Leader fill:#aed6f1,stroke:#333,stroke-width:1px

    style RES_ServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px
    style RES_ClusterServingRuntimes fill:#7ed321,stroke:#333,stroke-width:2px
    style RES_InferenceServices fill:#7ed321,stroke:#333,stroke-width:2px
    style RES_Predictors fill:#7ed321,stroke:#333,stroke-width:2px
    style RES_ConfigMaps fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Secrets fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Services fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Namespaces fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Endpoints fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_PVCs fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Leases fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_Deployments fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_ServiceMonitors fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RES_HPAs fill:#e8e8e8,stroke:#333,stroke-width:1px
