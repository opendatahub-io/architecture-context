graph TB
    subgraph External["EXTERNAL (Users)"]
        User[Data Scientist /<br/>ODH Dashboard]
    end

    subgraph K8sControlPlane["KUBERNETES API SERVER (Control Plane)"]
        K8sAPI["Kubernetes API Server<br/>Namespace: opendatahub<br/>Manages: PyTorchJob, TFJob, MPIJob, etc."]
    end

    subgraph OperatorNamespace["OPERATOR CONTROL PLANE (Namespace: opendatahub)"]
        direction TB

        Webhook["Training Operator<br/>Webhook Server<br/>SA: training-operator<br/>Service: 443→9443/TCP"]
        Controller["Training Operator<br/>Controller Manager<br/>SA: training-operator<br/>Controllers: PyTorch, TF, MPI, XGBoost, Paddle, JAX"]
        WebhookSecret["Secret:<br/>training-operator-webhook-cert<br/>(kubernetes.io/tls)"]

        Webhook -.->|mounts| WebhookSecret
    end

    subgraph TrainingWorkload["TRAINING WORKLOAD (User Namespaces)"]
        direction TB

        subgraph UserNS["{user-namespace}"]
            Master["Training Master Pod<br/>SA: {job-name}-master-sa<br/>Service: {job-name}-master:23456<br/>Image: {training-image}"]
            Worker1["Training Worker Pod 1<br/>SA: {job-name}-worker-sa<br/>Service: {job-name}-worker-0:23456<br/>Image: {training-image}"]
            Worker2["Training Worker Pod 2<br/>SA: {job-name}-worker-sa<br/>Service: {job-name}-worker-1:23456<br/>Image: {training-image}"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secrets"]
        S3["Object Storage<br/>S3 / Azure Blob / GCS<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM / Azure / GCP SA"]
        Volcano["Volcano Scheduler<br/>(Optional)<br/>443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
        SchedPlugins["Scheduler Plugins<br/>(Optional)<br/>443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph Monitoring["MONITORING & OBSERVABILITY"]
        Prometheus["Prometheus<br/>Namespace: openshift-monitoring"]
        MetricsEndpoint["Training Operator<br/>Metrics Endpoint<br/>Service: 8080/TCP"]
    end

    %% User to K8s API
    User -->|HTTPS/443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% K8s API to Webhook
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>K8s API Server mTLS<br/>POST /validate-*| Webhook

    %% Controller to K8s API
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch CRs, create resources| K8sAPI

    %% Controller creates training pods
    Controller -.->|creates via K8s API| Master
    Controller -.->|creates via K8s API| Worker1
    Controller -.->|creates via K8s API| Worker2

    %% Kubelet pulls images
    Master -.->|pulls image| Registry
    Worker1 -.->|pulls image| Registry
    Worker2 -.->|pulls image| Registry

    %% Worker communication
    Master <-->|TCP/23456<br/>Framework-specific<br/>No encryption<br/>No auth| Worker1
    Master <-->|TCP/23456<br/>Framework-specific<br/>No encryption<br/>No auth| Worker2
    Worker1 <-->|TCP/23456<br/>Framework-specific| Worker2

    %% Training pods to S3
    Master -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Cloud creds<br/>Load datasets, save models| S3
    Worker1 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Cloud creds<br/>Load datasets| S3
    Worker2 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Cloud creds<br/>Load datasets| S3

    %% Gang scheduling (optional)
    Controller -.->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>PodGroup management| Volcano
    Controller -.->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>PodGroup management| SchedPlugins

    %% Metrics
    Prometheus -->|HTTP/8080<br/>No encryption<br/>ServiceAccount bearer token<br/>GET /metrics| MetricsEndpoint
    MetricsEndpoint -.->|part of| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Webhook,Controller,WebhookSecret operator
    class Master,Worker1,Worker2 workload
    class Registry,S3,Volcano,SchedPlugins externalservice
    class Prometheus,MetricsEndpoint monitoring
