graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist<br/>Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge"]
    end

    subgraph Pod["ODH Dashboard Pod (redhat-ods-applications)"]
        direction TB

        subgraph OAuthContainer["OAuth Proxy Container"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>SA: odh-dashboard"]
        end

        subgraph BackendContainer["Backend Container"]
            Backend["Dashboard Backend<br/>8080/TCP HTTP<br/>Node.js 20 Fastify<br/>SA: odh-dashboard"]
        end

        OAuthProxy -->|HTTP/8080<br/>Bearer Token<br/>Localhost| Backend
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Auth"]

        OAuthServer["OpenShift OAuth<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth 2.0"]

        Prometheus["Prometheus/Thanos<br/>9092/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        ModelRegistry["Model Registry<br/>8080/443 TCP<br/>HTTP/HTTPS<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Docs["External Docs<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public"]

        Segment["Segment Analytics<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    subgraph Secrets["SECRETS & CERTIFICATES"]
        ProxyTLS["dashboard-proxy-tls<br/>kubernetes.io/tls<br/>Auto-rotate: Yes"]
        OAuthCookie["dashboard-oauth-config<br/>Opaque<br/>Session Secret"]
        OAuthClient["dashboard-oauth-client<br/>Opaque<br/>Client Secret"]
        SAToken["ServiceAccount Token<br/>Auto-rotate: Yes"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+"| Router

    %% Ingress to Pod
    Router -->|"HTTPS/8443<br/>TLS 1.2+<br/>Re-encrypted"| OAuthProxy

    %% OAuth Flows
    OAuthProxy -->|"OAuth Flow<br/>HTTPS/6443<br/>TLS 1.2+"| OAuthServer

    %% Backend to Services
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Backend -->|"HTTPS/9092<br/>TLS 1.2+<br/>ServiceAccount Token"| Prometheus
    Backend -->|"HTTP/HTTPS<br/>ServiceAccount Token"| ModelRegistry
    Backend -.->|"HTTPS/443<br/>TLS 1.2+"| Docs
    Backend -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Segment

    %% Secret Usage
    OAuthProxy -.->|Uses| ProxyTLS
    OAuthProxy -.->|Uses| OAuthCookie
    OAuthProxy -.->|Uses| OAuthClient
    Backend -.->|Uses| SAToken

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,Backend pod
    class K8sAPI,OAuthServer,Prometheus,ModelRegistry clusterservice
    class Docs,Segment externalservice
    class ProxyTLS,OAuthCookie,OAuthClient,SAToken secret
