graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS Edge Termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph UserNamespace["Namespace: {user-namespace}"]
            Service["model-registry Service<br/>ClusterIP<br/>8443/TCP (OAuth)<br/>8080/TCP (non-OAuth)"]

            subgraph Deployment["Model Registry Deployment<br/>SA: {name}<br/>SCC: restricted-v2"]
                direction LR
                OAuthProxy["oauth-proxy container<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Image: origin-oauth-proxy"]
                RESTContainer["rest-container<br/>8080/TCP HTTP<br/>Image: model-registry"]

                OAuthProxy -->|"HTTP/8080<br/>localhost<br/>no auth"| RESTContainer
            end

            NetworkPolicy["NetworkPolicy<br/>{name}-https-route<br/>Allows: ingress pods"]
        end

        OAuthServer["OpenShift OAuth Server<br/>oauth-openshift ns<br/>443/TCP HTTPS<br/>TLS 1.2+"]

        Service -->|"HTTPS/8443<br/>Bearer Token"| OAuthProxy
        Service -->|"HTTP/8080<br/>no auth"| RESTContainer

        OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Account"| OAuthServer
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL Database<br/>{host}:5432<br/>TLS (optional)<br/>Username/Password"]
        MySQL["MySQL Database<br/>{host}:3306<br/>TLS (optional)<br/>Username/Password"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE: {operator-namespace}"]
        direction TB

        Controller["controller-manager<br/>Deployment<br/>SA: controller-manager<br/>Replicas: 1<br/>runAsNonRoot"]

        WebhookService["webhook-service<br/>ClusterIP<br/>443/TCP → 9443/TCP"]

        MetricsService["controller-manager-metrics-service<br/>ClusterIP<br/>8443/TCP HTTPS"]

        Controller -->|"HTTPS/443<br/>TLS<br/>Webhook Cert"| WebhookService

        Prometheus["Prometheus"] -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsService
    end

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Router

    %% Ingress to Service
    Router -->|"HTTPS/8443<br/>TLS Edge<br/>Bearer Token"| Service

    %% REST to Database
    RESTContainer -->|"PostgreSQL/5432<br/>TLS optional<br/>user/pass"| PostgreSQL
    RESTContainer -->|"MySQL/3306<br/>TLS optional<br/>user/pass"| MySQL

    %% Operator flows
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"HTTPS/443<br/>TLS<br/>Webhook Cert"| WebhookService

    %% Controller creates resources
    Controller -.->|creates| Deployment
    Controller -.->|creates| Service
    Controller -.->|creates| NetworkPolicy

    %% Network Policy enforcement
    NetworkPolicy -.->|"allows ingress<br/>to 8443/TCP"| Deployment

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class Service,Deployment,OAuthProxy,RESTContainer,NetworkPolicy,OAuthServer clusterinternal
    class Controller,WebhookService,MetricsService,Prometheus operator
    class PostgreSQL,MySQL externalservice
    class K8sAPI externalservice
