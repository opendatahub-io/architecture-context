graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Dashboard]
        ExternalUsers[External Users<br/>via Browser]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph NotebookCtrlNS["Namespace: odh-notebook-controller"]
        NotebookController["Notebook Controller<br/>SA: notebook-controller-service-account<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        CullingController["Culling Reconciler<br/>Part of Controller"]
    end

    subgraph UserNS["Namespace: {user-namespace}"]
        NotebookPod["Notebook Pod (StatefulSet)<br/>SA: default<br/>Jupyter Server<br/>8888/TCP HTTP<br/>/api/kernels"]
        NotebookService["ClusterIP Service<br/>notebook-{name}<br/>80/TCP → 8888/TCP"]
    end

    subgraph Istio["INGRESS (Optional - Istio)"]
        VirtualService["Istio VirtualService<br/>notebook-{name}-vs<br/>Host: {ISTIO_HOST}"]
        IstioGateway["Istio Gateway<br/>80/443 HTTP/HTTPS<br/>TLS varies"]
    end

    subgraph Monitoring["MONITORING (Cluster-Internal)"]
        Prometheus["Prometheus<br/>Scrape :8080/TCP"]
    end

    subgraph K8sInfra["KUBERNETES INFRASTRUCTURE"]
        Kubelet["Kubelet<br/>10250/TCP HTTPS<br/>mTLS"]
    end

    %% External to Control Plane
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User Auth| K8sAPI

    %% Control Plane to Controller
    K8sAPI -->|Watch API<br/>ServiceAccount Token| NotebookController
    NotebookController -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create/Update Resources| K8sAPI

    %% Controller to Workloads
    K8sAPI -->|Schedule Pod<br/>HTTPS/10250<br/>mTLS| Kubelet
    Kubelet -->|Manages| NotebookPod

    %% Culling Flow
    CullingController -->|HTTP/8888<br/>No Auth<br/>GET /api/kernels| NotebookPod
    CullingController -->|Add Annotation<br/>HTTPS/6443<br/>ServiceAccount Token| K8sAPI

    %% Service Routing
    NotebookPod -->|Exposed by| NotebookService

    %% Istio Routing (Conditional)
    NotebookService -.->|USE_ISTIO=true<br/>HTTP/80| VirtualService
    VirtualService -.->|Routes to| IstioGateway
    IstioGateway -.->|HTTP/HTTPS| ExternalUsers

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No Auth| NotebookController

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef istio fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef infra fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,ExternalUsers external
    class K8sAPI controlplane
    class NotebookController,CullingController controller
    class NotebookPod,NotebookService workload
    class VirtualService,IstioGateway istio
    class Prometheus monitoring
    class Kubelet infra
