graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / ODH Dashboard"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph ControllerNS["CONTROL PLANE (Controller Namespace)"]
        direction TB

        Controller["Notebook Controller<br/>SA: notebook-controller-service-account<br/>User: 1001 (non-root)<br/>FIPS: strictfipsruntime"]

        Metrics["Metrics Server<br/>8080/TCP HTTP<br/>No Auth<br/>ClusterIP Only"]

        Health["Health Probe<br/>8081/TCP HTTP<br/>No Auth<br/>ClusterIP Only"]

        CullingCtrl["Culling Controller<br/>Idle Detection"]
    end

    subgraph UserNS["DATA PLANE (User Namespace)"]
        direction TB

        StatefulSet["StatefulSet<br/>Managed by Controller"]

        NotebookPod["Jupyter Notebook Pod<br/>8888/TCP HTTP<br/>No Auth<br/>User-specified image"]

        NotebookSvc["Service: notebook-{name}<br/>ClusterIP<br/>80/TCP → 8888/TCP"]

        StatefulSet -->|manages| NotebookPod
        NotebookSvc -->|routes to| NotebookPod
    end

    subgraph IstioOptional["OPTIONAL ISTIO INTEGRATION"]
        VirtualService["VirtualService<br/>networking.istio.io<br/>Condition: USE_ISTIO=true"]
        IstioGateway["Istio Gateway<br/>443/TCP or 80/TCP<br/>Varies Encryption"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% User creates Notebook
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials<br/>POST Notebook CR"| K8sAPI

    %% API Server notifies controller
    K8sAPI -->|"Watch Event<br/>Notebook Created<br/>ServiceAccount Token"| Controller

    %% Controller creates resources
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>POST StatefulSet/Service"| K8sAPI

    %% API Server schedules pods
    K8sAPI -->|"HTTPS/10250<br/>mTLS<br/>Schedule Pod"| StatefulSet

    %% Culling flow
    CullingCtrl -->|"HTTP/8888<br/>⚠️ NO AUTH<br/>GET /api/kernels"| NotebookPod
    CullingCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>PATCH Notebook (if idle)"| K8sAPI

    %% Metrics flow
    Prometheus -->|"HTTP/8080<br/>No Auth<br/>GET /metrics"| Metrics

    %% Istio integration
    Controller -.->|"HTTPS/6443<br/>TLS 1.2+<br/>POST VirtualService<br/>(if USE_ISTIO=true)"| K8sAPI
    K8sAPI -.->|"creates"| VirtualService
    VirtualService -.->|"routes via"| IstioGateway
    IstioGateway -.->|"to"| NotebookSvc

    %% Health probes
    K8sAPI -->|"HTTP/8081<br/>Health Checks"| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#ffcccc,stroke:#cc0000,stroke-width:3px

    class User external
    class K8sAPI controlplane
    class Controller,Metrics,Health,CullingCtrl controller
    class StatefulSet,NotebookPod,NotebookSvc dataplane
    class VirtualService,IstioGateway optional
    class Prometheus monitoring
    class CullingCtrl warning
