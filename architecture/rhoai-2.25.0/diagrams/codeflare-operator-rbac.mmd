graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        RB1[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: operator ns]
    end

    subgraph "Roles"
        CR[manager-role<br/>ClusterRole]
        R[leader-election-role<br/>Role]
    end

    subgraph "Core API Permissions"
        CoreAPIs["• events (create, patch, update, watch)<br/>• nodes (get, list, watch)<br/>• pods, services (all verbs)<br/>• secrets (all verbs)<br/>• serviceaccounts (all verbs)"]
    end

    subgraph "Apps & Batch Permissions"
        AppsAPIs["• apps/deployments (all verbs)<br/>• apps/statefulsets (all verbs)<br/>• batch/jobs (all verbs)<br/>• jobset.x-k8s.io/jobsets (all verbs)"]
    end

    subgraph "Networking Permissions"
        NetAPIs["• networking.k8s.io/ingresses (all verbs)<br/>• networking.k8s.io/networkpolicies (all verbs)<br/>• route.openshift.io/routes (all verbs)<br/>• route.openshift.io/routes/custom-host (all verbs)"]
    end

    subgraph "Ray & CodeFlare CRD Permissions"
        RayAPIs["• ray.io/rayclusters (all verbs + finalizers + status)<br/>• ray.io/rayjobs (all verbs)<br/>• workload.codeflare.dev/appwrappers (all verbs + finalizers + status)"]
    end

    subgraph "Scheduling & Workload Permissions"
        SchedAPIs["• scheduling.sigs.k8s.io/podgroups (all verbs)<br/>• scheduling.x-k8s.io/podgroups (all verbs)<br/>• kubeflow.org/pytorchjobs (all verbs)"]
    end

    subgraph "Admission & Config Permissions"
        AdminAPIs["• admissionregistration.k8s.io/<br/>  mutatingwebhookconfigurations (get, list, update, watch)<br/>• admissionregistration.k8s.io/<br/>  validatingwebhookconfigurations (get, list, update, watch)<br/>• apiextensions.k8s.io/customresourcedefinitions (get, list, watch)<br/>• dscinitialization.opendatahub.io/dscinitializations (get, list, watch)<br/>• config.openshift.io/ingresses (get)"]
    end

    subgraph "RBAC & Auth Permissions"
        RBACAPIs["• rbac.authorization.k8s.io/clusterrolebindings (all verbs)<br/>• authentication.k8s.io/tokenreviews (create)<br/>• authorization.k8s.io/subjectaccessreviews (create)"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| RB1
    CRB1 -->|grants cluster-wide| CR
    RB1 -->|grants namespace-scoped| R

    %% Permissions
    CR -->|manages| CoreAPIs
    CR -->|manages| AppsAPIs
    CR -->|manages| NetAPIs
    CR -->|manages| RayAPIs
    CR -->|manages| SchedAPIs
    CR -->|manages| AdminAPIs
    CR -->|manages| RBACAPIs

    R -.->|coordinates| LeaderElection[Leader Election<br/>ConfigMaps & Leases]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style R fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#7ed321,stroke:#333
    style RB1 fill:#7ed321,stroke:#333

    style CoreAPIs fill:#e1f5e1,stroke:#82b366
    style AppsAPIs fill:#e1f5e1,stroke:#82b366
    style NetAPIs fill:#e1f5e1,stroke:#82b366
    style RayAPIs fill:#e1f5e1,stroke:#82b366
    style SchedAPIs fill:#e1f5e1,stroke:#82b366
    style AdminAPIs fill:#e1f5e1,stroke:#82b366
    style RBACAPIs fill:#e1f5e1,stroke:#82b366

    style LeaderElection fill:#dae8fc,stroke:#6c8ebf
