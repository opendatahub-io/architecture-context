graph TD
    subgraph "Service Accounts"
        SA[codeflare-operator-controller-manager<br/>Namespace: operator namespace]
    end

    subgraph "Cluster Role Bindings"
        CRB[manager-rolebinding<br/>Scope: cluster-wide]
        LeaderRB[leader-election-rolebinding<br/>Scope: operator namespace]
    end

    subgraph "Cluster Roles"
        CR[manager-role<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Events[events<br/>Verbs: create, patch, update, watch]
        Nodes[nodes<br/>Verbs: get, list, watch]
        Pods[pods<br/>Verbs: create, delete, get, list, patch, update, watch]
        Services[services<br/>Verbs: create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>Verbs: create, delete, get, list, patch, update, watch]
        ServiceAccounts[serviceaccounts<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Admission Webhook Resources"
        MutatingWebhook[mutatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>Verbs: get, list, update, watch]
        ValidatingWebhook[validatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>Verbs: get, list, update, watch]
    end

    subgraph "CRD Resources"
        CRDs[customresourcedefinitions<br/>apiextensions.k8s.io<br/>Verbs: get, list, watch]
    end

    subgraph "Workload Resources"
        Deployments[deployments<br/>apps<br/>Verbs: create, delete, get, list, patch, update, watch]
        StatefulSets[statefulsets<br/>apps<br/>Verbs: create, delete, get, list, patch, update, watch]
        Jobs[jobs<br/>batch<br/>Verbs: create, delete, get, list, patch, update, watch]
        JobSets[jobsets<br/>jobset.x-k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        PyTorchJobs[pytorchjobs<br/>kubeflow.org<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Ray Resources"
        RayClusters[rayclusters<br/>ray.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        RayClustersFinalizers[rayclusters/finalizers<br/>ray.io<br/>Verbs: update]
        RayClustersStatus[rayclusters/status<br/>ray.io<br/>Verbs: get, patch, update]
        RayJobs[rayjobs<br/>ray.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "AppWrapper Resources"
        AppWrappers[appwrappers<br/>workload.codeflare.dev<br/>Verbs: create, delete, get, list, patch, update, watch]
        AppWrappersFinalizers[appwrappers/finalizers<br/>workload.codeflare.dev<br/>Verbs: update]
        AppWrappersStatus[appwrappers/status<br/>workload.codeflare.dev<br/>Verbs: get, patch, update]
    end

    subgraph "Networking Resources"
        Ingresses[ingresses<br/>networking.k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        NetworkPolicies[networkpolicies<br/>networking.k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        Routes[routes<br/>route.openshift.io<br/>Verbs: create, delete, get, list, patch, update, watch]
        RoutesCustomHost[routes/custom-host<br/>route.openshift.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "RBAC Resources"
        ClusterRoleBindings[clusterrolebindings<br/>rbac.authorization.k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Scheduling Resources"
        PodGroups[podgroups<br/>scheduling.sigs.k8s.io, scheduling.x-k8s.io<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Auth Resources"
        TokenReviews[tokenreviews<br/>authentication.k8s.io<br/>Verbs: create]
        SubjectAccessReviews[subjectaccessreviews<br/>authorization.k8s.io<br/>Verbs: create]
    end

    subgraph "ODH Resources"
        DSCInit[dscinitializations<br/>dscinitialization.opendatahub.io<br/>Verbs: get, list, watch]
    end

    subgraph "OpenShift Config"
        IngressesConfig[ingresses<br/>config.openshift.io<br/>Verbs: get]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderRB
    CRB -->|grants| CR
    LeaderRB -->|grants| LeaderRole

    %% Permissions - Core
    CR -->|permissions| Events
    CR -->|permissions| Nodes
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| Secrets
    CR -->|permissions| ServiceAccounts

    %% Permissions - Webhooks
    CR -->|permissions| MutatingWebhook
    CR -->|permissions| ValidatingWebhook

    %% Permissions - CRDs
    CR -->|permissions| CRDs

    %% Permissions - Workloads
    CR -->|permissions| Deployments
    CR -->|permissions| StatefulSets
    CR -->|permissions| Jobs
    CR -->|permissions| JobSets
    CR -->|permissions| PyTorchJobs

    %% Permissions - Ray
    CR -->|permissions| RayClusters
    CR -->|permissions| RayClustersFinalizers
    CR -->|permissions| RayClustersStatus
    CR -->|permissions| RayJobs

    %% Permissions - AppWrapper
    CR -->|permissions| AppWrappers
    CR -->|permissions| AppWrappersFinalizers
    CR -->|permissions| AppWrappersStatus

    %% Permissions - Networking
    CR -->|permissions| Ingresses
    CR -->|permissions| NetworkPolicies
    CR -->|permissions| Routes
    CR -->|permissions| RoutesCustomHost

    %% Permissions - RBAC
    CR -->|permissions| ClusterRoleBindings

    %% Permissions - Scheduling
    CR -->|permissions| PodGroups

    %% Permissions - Auth
    CR -->|permissions| TokenReviews
    CR -->|permissions| SubjectAccessReviews

    %% Permissions - ODH
    CR -->|permissions| DSCInit

    %% Permissions - OpenShift Config
    CR -->|permissions| IngressesConfig

    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#000
    style LeaderRole fill:#f5a623,color:#000
    style CRB fill:#7ed321,color:#000
    style LeaderRB fill:#7ed321,color:#000

    style RayClusters fill:#ff9999,color:#000
    style RayClustersFinalizers fill:#ff9999,color:#000
    style RayClustersStatus fill:#ff9999,color:#000
    style RayJobs fill:#ff9999,color:#000

    style AppWrappers fill:#ffcc99,color:#000
    style AppWrappersFinalizers fill:#ffcc99,color:#000
    style AppWrappersStatus fill:#ffcc99,color:#000
