graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[odh-dashboard<br/>Namespace: redhat-ods-applications / opendatahub]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB1[odh-dashboard]
        CRB2[odh-dashboard-image-puller]
        CRB3[odh-dashboard-auth-delegator]
        CRB4[odh-dashboard-monitoring]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR1[odh-dashboard<br/>Custom ClusterRole]
        CR2[system:image-puller<br/>System ClusterRole]
        CR3[system:auth-delegator<br/>System ClusterRole]
        CR4[cluster-monitoring-view<br/>System ClusterRole]
        CR5[aggregate-hardware-profiles-permissions]
        CR6[aggregate-accelerator-profiles-permissions]
    end

    subgraph CoreResources["Core API Resources"]
        direction TB
        Nodes[nodes<br/>get, list]
        ConfigMaps[configmaps<br/>create, delete, get, list, patch, update, watch]
        Secrets[secrets<br/>create, delete, get, list, patch, update, watch]
        PVC[persistentvolumeclaims<br/>create, delete, get, list, patch, update, watch]
        Namespaces[namespaces<br/>patch]
        Pods[pods<br/>get, list, watch]
        SA2[serviceaccounts<br/>get, list, watch]
        Services[services<br/>get, list, watch]
        Endpoints[endpoints<br/>get]
        Events[events<br/>get, list, watch]
    end

    subgraph StorageResources["Storage API Resources"]
        StorageClasses[storageclasses<br/>storage.k8s.io<br/>update, patch]
    end

    subgraph OpenShiftResources["OpenShift API Resources"]
        direction TB
        ClusterVersions[clusterversions<br/>config.openshift.io<br/>get, watch, list]
        Routes[routes<br/>route.openshift.io<br/>get, list, watch]
        ConsoleLinks[consolelinks<br/>console.openshift.io<br/>get, list, watch]
        Consoles[consoles<br/>operator.openshift.io<br/>get, list, watch]
        Users[users<br/>user.openshift.io<br/>get, list, watch]
        Groups[groups<br/>user.openshift.io<br/>get, list, watch]
        MachineAutoscalers[machineautoscalers<br/>machine.openshift.io, autoscaling.openshift.io<br/>get, list]
        MachineSets[machinesets<br/>machine.openshift.io<br/>get, list]
        ImageStreams[imagestreams/layers<br/>image.openshift.io<br/>get]
    end

    subgraph OLMResources["OLM Resources"]
        CSV[clusterserviceversions<br/>operators.coreos.com<br/>get, list, watch]
        Subscriptions[subscriptions<br/>operators.coreos.com<br/>get, list, watch]
    end

    subgraph RBACResources["RBAC Resources"]
        RoleBindings[rolebindings<br/>rbac.authorization.k8s.io<br/>list, get, create, patch, delete]
        ClusterRoleBindingsRes[clusterrolebindings<br/>rbac.authorization.k8s.io<br/>list, get, create, patch, delete]
        Roles[roles<br/>rbac.authorization.k8s.io<br/>list, get, create, patch, delete]
    end

    subgraph ODHResources["ODH Custom Resources"]
        direction TB
        DSC[datascienceclusters<br/>datasciencecluster.opendatahub.io<br/>list, watch, get]
        DSCI[dscinitializations<br/>dscinitialization.opendatahub.io<br/>list, watch, get]
        NotebooksCR[notebooks<br/>kubeflow.org<br/>get, list, watch, create, update, patch, delete]
        InferenceServices[inferenceservices<br/>serving.kserve.io<br/>get, list, watch]
        ModelRegistries[modelregistries<br/>modelregistry.opendatahub.io<br/>get, list, watch, create, update, patch, delete]
        HardwareProfiles[hardwareprofiles<br/>infrastructure.opendatahub.io<br/>get, list, watch]
        AcceleratorProfiles[acceleratorprofiles<br/>dashboard.opendatahub.io<br/>get, list, watch]
        Auths[auths<br/>services.platform.opendatahub.io<br/>get]
        LlamaStack[llamastackdistributions<br/>llamastack.io<br/>get, list, watch]
    end

    subgraph OtherResources["Other Resources"]
        RHMI[rhmis<br/>integreatly.org<br/>get, watch, list]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    CRB4 -->|grants| CR4

    %% Aggregate Roles
    CR1 -.->|aggregates| CR5
    CR1 -.->|aggregates| CR6

    %% ClusterRole to Resources - Core
    CR1 -->|permissions| Nodes
    CR1 -->|permissions| ConfigMaps
    CR1 -->|permissions| Secrets
    CR1 -->|permissions| PVC
    CR1 -->|permissions| Namespaces
    CR1 -->|permissions| Pods
    CR1 -->|permissions| SA2
    CR1 -->|permissions| Services
    CR1 -->|permissions| Endpoints
    CR1 -->|permissions| Events

    %% ClusterRole to Resources - Storage
    CR1 -->|permissions| StorageClasses

    %% ClusterRole to Resources - OpenShift
    CR1 -->|permissions| ClusterVersions
    CR1 -->|permissions| Routes
    CR1 -->|permissions| ConsoleLinks
    CR1 -->|permissions| Consoles
    CR1 -->|permissions| Users
    CR1 -->|permissions| Groups
    CR1 -->|permissions| MachineAutoscalers
    CR1 -->|permissions| MachineSets
    CR1 -->|permissions| ImageStreams

    %% ClusterRole to Resources - OLM
    CR1 -->|permissions| CSV
    CR1 -->|permissions| Subscriptions

    %% ClusterRole to Resources - RBAC
    CR1 -->|permissions| RoleBindings
    CR1 -->|permissions| ClusterRoleBindingsRes
    CR1 -->|permissions| Roles

    %% ClusterRole to Resources - ODH
    CR1 -->|permissions| DSC
    CR1 -->|permissions| DSCI
    CR1 -->|permissions| NotebooksCR
    CR1 -->|permissions| InferenceServices
    CR1 -->|permissions| ModelRegistries
    CR5 -->|permissions| HardwareProfiles
    CR6 -->|permissions| AcceleratorProfiles
    CR1 -->|permissions| Auths
    CR1 -->|permissions| LlamaStack

    %% ClusterRole to Resources - Other
    CR1 -->|permissions| RHMI

    %% Image Puller
    CR2 -.->|pull images| ImageStreams

    %% Auth Delegator
    CR3 -.->|auth delegation| K8sAPI[Kubernetes API Server<br/>TokenReview, SubjectAccessReview]

    %% Monitoring View
    CR4 -.->|view metrics| PrometheusRes[Prometheus Resources<br/>ServiceMonitors, PodMonitors]

