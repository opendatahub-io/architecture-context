graph TD
    subgraph "Service Accounts"
        SA1[feast-operator-controller-manager<br/>Namespace: redhat-ods-applications / opendatahub]
        SA2["&lt;featurestore-name&gt;-sa<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[feast-operator-manager-rolebinding<br/>Scope: Cluster-wide]
        CRB2[feast-operator-metrics-auth-rolebinding<br/>Scope: Namespace]
        RB1[feast-operator-leader-election-rolebinding<br/>Scope: Namespace]
    end

    subgraph "ClusterRoles & Roles"
        CR1[feast-operator-manager-role<br/>ClusterRole]
        CR2[feast-operator-metrics-reader<br/>ClusterRole]
        CR3[feast-operator-featurestore-editor-role<br/>ClusterRole]
        CR4[feast-operator-featurestore-viewer-role<br/>ClusterRole]
        R1[leader-election-role<br/>Role]
    end

    subgraph "API Resources & Permissions"
        direction TB

        subgraph "feast.dev API Group"
            FS[FeatureStore<br/>Verbs: create, delete, get, list, patch, update, watch]
            FSStatus[FeatureStore/status<br/>Verbs: get, patch, update]
            FSFinalizer[FeatureStore/finalizers<br/>Verbs: update]
        end

        subgraph "apps API Group"
            Deployments[Deployments<br/>Verbs: create, delete, get, list, update, watch]
        end

        subgraph "batch API Group"
            CronJobs[CronJobs<br/>Verbs: create, delete, get, list, patch, update, watch]
        end

        subgraph "core API Group"
            ConfigMaps[ConfigMaps<br/>Verbs: create, delete, get, list, update, watch]
            PVCs[PersistentVolumeClaims<br/>Verbs: create, delete, get, list, update, watch]
            ServiceAccounts[ServiceAccounts<br/>Verbs: create, delete, get, list, update, watch]
            Services[Services<br/>Verbs: create, delete, get, list, update, watch]
            Pods[Pods<br/>Verbs: get, list]
            PodsExec[Pods/exec<br/>Verbs: create]
            Secrets[Secrets<br/>Verbs: get, list]
        end

        subgraph "rbac.authorization.k8s.io"
            Roles[Roles<br/>Verbs: create, delete, get, list, update, watch]
            RoleBindings[RoleBindings<br/>Verbs: create, delete, get, list, update, watch]
        end

        subgraph "route.openshift.io"
            Routes[Routes<br/>Verbs: create, delete, get, list, update, watch]
        end
    end

    %% Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA1 -->|bound via| RB1

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% Permissions from feast-operator-manager-role (CR1)
    CR1 -->|full management| FS
    CR1 -->|full management| FSStatus
    CR1 -->|full management| FSFinalizer
    CR1 -->|full management| Deployments
    CR1 -->|full management| CronJobs
    CR1 -->|full management| ConfigMaps
    CR1 -->|full management| PVCs
    CR1 -->|full management| ServiceAccounts
    CR1 -->|full management| Services
    CR1 -->|read-only| Pods
    CR1 -->|read-only| Secrets
    CR1 -->|execute| PodsExec
    CR1 -->|full management| Roles
    CR1 -->|full management| RoleBindings
    CR1 -->|full management| Routes

    %% Permissions from metrics-reader (CR2)
    CR2 -->|read-only| Pods

    %% User-facing roles
    CR3 -.->|edit permission| FS
    CR4 -.->|view permission| FS

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB1 fill:#e8e8e8,stroke:#333
    style CRB2 fill:#e8e8e8,stroke:#333
    style RB1 fill:#e8e8e8,stroke:#333

    style FS fill:#7ed321,stroke:#333
    style FSStatus fill:#7ed321,stroke:#333
    style FSFinalizer fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style CronJobs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Roles fill:#7ed321,stroke:#333
    style RoleBindings fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
