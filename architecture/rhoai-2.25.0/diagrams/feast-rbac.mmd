graph TD
    subgraph "Service Accounts"
        SA_Operator[feast-operator-controller-manager<br/>Namespace: redhat-ods-applications / opendatahub]
        SA_FeatureStore["{featurestore-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[feast-operator-manager-rolebinding<br/>Scope: cluster-wide]
        CRB_Metrics[feast-operator-metrics-auth-rolebinding<br/>Scope: namespace]
        RB_Leader[feast-operator-leader-election-rolebinding<br/>Scope: namespace]
    end

    subgraph "ClusterRoles"
        CR_Manager[feast-operator-manager-role]
        CR_Metrics[feast-operator-metrics-reader]
        CR_Editor[feast-operator-featurestore-editor-role]
        CR_Viewer[feast-operator-featurestore-viewer-role]
        CR_Leader[leader-election-role]
    end

    subgraph "API Resources - Apps"
        Deployments[apps/deployments<br/>verbs: create, delete, get, list, update, watch]
    end

    subgraph "API Resources - Batch"
        CronJobs[batch/cronjobs<br/>verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Core"
        ConfigMaps[core/configmaps<br/>verbs: create, delete, get, list, update, watch]
        PVCs[core/persistentvolumeclaims<br/>verbs: create, delete, get, list, update, watch]
        ServiceAccounts[core/serviceaccounts<br/>verbs: create, delete, get, list, update, watch]
        Services[core/services<br/>verbs: create, delete, get, list, update, watch]
        Pods[core/pods<br/>verbs: get, list]
        PodsExec[core/pods/exec<br/>verbs: create]
        Secrets[core/secrets<br/>verbs: get, list]
    end

    subgraph "API Resources - Feast"
        FeatureStores[feast.dev/featurestores<br/>verbs: create, delete, get, list, patch, update, watch]
        FeatureStoresStatus[feast.dev/featurestores/status<br/>verbs: get, patch, update]
        FeatureStoresFinalizers[feast.dev/featurestores/finalizers<br/>verbs: update]
    end

    subgraph "API Resources - RBAC"
        Roles[rbac.authorization.k8s.io/roles<br/>verbs: create, delete, get, list, update, watch]
        RoleBindings[rbac.authorization.k8s.io/rolebindings<br/>verbs: create, delete, get, list, update, watch]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io/routes<br/>verbs: create, delete, get, list, update, watch]
    end

    %% Service Account to RoleBindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Metrics
    SA_Operator -->|bound via| RB_Leader

    %% RoleBindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    RB_Leader -->|grants| CR_Leader

    %% Manager Role Permissions
    CR_Manager -->|permissions| Deployments
    CR_Manager -->|permissions| CronJobs
    CR_Manager -->|permissions| ConfigMaps
    CR_Manager -->|permissions| PVCs
    CR_Manager -->|permissions| ServiceAccounts
    CR_Manager -->|permissions| Services
    CR_Manager -->|permissions| Pods
    CR_Manager -->|permissions| PodsExec
    CR_Manager -->|permissions| Secrets
    CR_Manager -->|permissions| FeatureStores
    CR_Manager -->|permissions| FeatureStoresStatus
    CR_Manager -->|permissions| FeatureStoresFinalizers
    CR_Manager -->|permissions| Roles
    CR_Manager -->|permissions| RoleBindings
    CR_Manager -->|permissions| Routes

    %% Metrics Reader Permissions
    CR_Metrics -->|permissions| Pods

    %% Editor Role Permissions
    CR_Editor -->|permissions| FeatureStores

    %% Viewer Role Permissions
    CR_Viewer -->|get, list, watch only| FeatureStores

    %% Feature Store Service Account
    SA_FeatureStore -.->|used by| FSPods[Feature Store Pods<br/>Online, Offline, Registry, UI, CronJob]

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_FeatureStore fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Metrics fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Editor fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Viewer fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Leader fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB_Manager fill:#95a5a6,stroke:#333
    style CRB_Metrics fill:#95a5a6,stroke:#333
    style RB_Leader fill:#95a5a6,stroke:#333

    style FeatureStores fill:#7ed321,stroke:#333
    style FeatureStoresStatus fill:#7ed321,stroke:#333
    style FeatureStoresFinalizers fill:#7ed321,stroke:#333

    style Deployments fill:#d5e8d4,stroke:#82b366
    style CronJobs fill:#d5e8d4,stroke:#82b366
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style PVCs fill:#d5e8d4,stroke:#82b366
    style ServiceAccounts fill:#d5e8d4,stroke:#82b366
    style Services fill:#d5e8d4,stroke:#82b366
    style Pods fill:#d5e8d4,stroke:#82b366
    style PodsExec fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style Roles fill:#d5e8d4,stroke:#82b366
    style RoleBindings fill:#d5e8d4,stroke:#82b366
    style Routes fill:#d5e8d4,stroke:#82b366

    style FSPods fill:#e8e8e8,stroke:#333
