graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Notebook]
        RayClient[Ray Client Application]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Auth: ServiceAccount Bearer Token"]
        RayClientRoute["Route: ray-client-{'{cluster}'}<br/>10001/TCP gRPC passthrough<br/>Auth: Client Certificate"]
        RayDashboardRoute["Route: ray-dashboard-{'{cluster}'}<br/>443/TCP → 8443/TCP HTTPS edge TLS<br/>Auth: OAuth Bearer Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph OperatorPod["CodeFlare Operator Manager Pod<br/>SA: codeflare-operator-controller-manager"]
            RayController["RayCluster Controller"]
            AWController["AppWrapper Controller"]
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS TLS1.2+"]
            MetricsServer["Metrics Server<br/>8080/TCP HTTP"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP"]
        end

        MetricsService["Metrics Service<br/>ClusterIP 8080/TCP"]
        WebhookService["Webhook Service<br/>ClusterIP 443/TCP → 9443/TCP<br/>TLS1.2+ mTLS (K8s API only)"]
        WebhookSecret["Secret: webhook-server-cert<br/>kubernetes.io/tls<br/>Auto-rotate: cert-controller"]
    end

    subgraph UserNS["USER NAMESPACE (per RayCluster)"]
        direction TB

        subgraph RayHeadPod["Ray Head Pod<br/>SA: {'{cluster}'}-sa<br/>Label: ray.io/node-type=head"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS"]
            RayDashboard["Ray Dashboard<br/>8265/TCP HTTP"]
            RayHeadAPI["Ray Client API<br/>10001/TCP gRPC mTLS"]
        end

        RayWorkerPods["Ray Worker Pods<br/>SA: {'{cluster}'}-sa<br/>Label: ray.io/node-type=worker"]
        RayHeadService["Ray Head Service<br/>ClusterIP<br/>10001/TCP (client)<br/>8265/TCP (dashboard)"]

        NPHead["NetworkPolicy: {'{cluster}'}-head-*<br/>Allows: same cluster + namespace clients<br/>Ports: 10001, 8265, 8443"]
        NPWorker["NetworkPolicy: {'{cluster}'}-workers-*<br/>Allows: same cluster pods only"]

        MTLSSecret["Secret: {'{cluster}'}-ca (Opaque)<br/>CA cert + private key for mTLS"]
        OAuthSecret["Secret: {'{cluster}'}-tls (kubernetes.io/tls)<br/>OAuth proxy certificates"]
    end

    subgraph ExternalDeps["EXTERNAL DEPENDENCIES"]
        KubeRay["KubeRay Operator v1.2.1<br/>Provides: RayCluster CRD"]
        Kueue["Kueue v0.10.1+<br/>6443/TCP HTTPS TLS1.3<br/>Auth: ServiceAccount"]
        CertController["cert-controller v0.12.0<br/>In-process (embedded)"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>Auth: Bearer Token"]
    end

    %% External to Ingress
    User -->|HTTPS/6443 TLS1.3<br/>Bearer Token| K8sAPI
    User -->|HTTPS/443 edge TLS<br/>OAuth Token| RayDashboardRoute
    RayClient -->|gRPC/10001 passthrough<br/>Client Cert| RayClientRoute

    %% Ingress to Services
    K8sAPI -->|HTTPS/9443 mTLS<br/>API Server cert| WebhookService
    RayClientRoute -->|gRPC/10001 mTLS<br/>passthrough| RayHeadService
    RayDashboardRoute -->|HTTPS/8443<br/>edge TLS| RayHeadService

    %% Services to Pods
    WebhookService --> WebhookServer
    MetricsService --> MetricsServer
    RayHeadService --> OAuthProxy
    RayHeadService --> RayHeadAPI

    %% Operator internals
    RayController -->|watches/creates<br/>HTTPS/6443 TLS1.3<br/>ServiceAccount token| K8sAPI
    AWController -->|watches/creates<br/>HTTPS/6443 TLS1.3<br/>ServiceAccount token| K8sAPI

    %% OAuth proxy to dashboard
    OAuthProxy -->|HTTP/8265<br/>internal pod| RayDashboard

    %% Ray head to workers
    RayHeadAPI -->|gRPC mTLS<br/>internal cluster| RayWorkerPods

    %% Network policies
    NPHead -.->|restricts| RayHeadPod
    NPWorker -.->|restricts| RayWorkerPods

    %% Secrets
    WebhookSecret -.->|mounts| WebhookServer
    MTLSSecret -.->|used by| RayHeadAPI
    OAuthSecret -.->|mounts| OAuthProxy

    %% External dependencies
    CertController -.->|rotates| WebhookSecret
    Kueue -->|updates AppWrapper status<br/>via K8s API| K8sAPI
    KubeRay -.->|provides CRD| RayController
    Prometheus -->|scrapes<br/>HTTP/8080| MetricsService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userNS fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalDep fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,RayClient external
    class K8sAPI,RayClientRoute,RayDashboardRoute ingress
    class OperatorPod,RayController,AWController,WebhookServer,MetricsServer,HealthProbe,MetricsService,WebhookService operator
    class RayHeadPod,OAuthProxy,RayDashboard,RayHeadAPI,RayWorkerPods,RayHeadService userNS
    class KubeRay,Kueue,CertController,Prometheus externalDep
    class WebhookSecret,NPHead,NPWorker,MTLSSecret,OAuthSecret security
