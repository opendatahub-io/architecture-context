graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
        RayClient[Ray Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        DashRoute["Ray Dashboard Route<br/>ray-dashboard-{cluster}.{domain}<br/>443/TCP HTTPS TLS1.2+ edge<br/>OAuth Bearer Token"]
        ClientRoute["Ray Client Route<br/>ray-client-{cluster}.{domain}<br/>443/TCP HTTPS TLS1.2+ passthrough<br/>mTLS Client Cert"]
    end

    subgraph UserNamespace["User Namespace: {user-namespace}"]
        direction TB

        subgraph RayCluster["Ray Cluster (Network Isolated)"]
            RayDash["Ray Dashboard Pod<br/>SA: {cluster-name}-sa<br/>8265/TCP HTTP"]
            RayHead["Ray Head Pod<br/>SA: {cluster-name}-sa<br/>10001/TCP gRPC mTLS<br/>NP: {cluster}-head-*"]
            RayWorkers["Ray Worker Pods<br/>SA: {cluster-name}-sa<br/>gRPC mTLS<br/>NP: {cluster}-workers-*"]
        end
    end

    subgraph OperatorNamespace["Operator Namespace: redhat-ods-applications"]
        direction TB

        Manager["CodeFlare Operator Manager<br/>SA: controller-manager"]
        MetricsService["Metrics Service<br/>8080/TCP HTTP<br/>No Auth (internal)"]
        WebhookService["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS1.2+<br/>mTLS API Server"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>ServiceAccount tokens"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceAccount Bearer Token"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS1.2+ edge<br/>OAuth Bearer| DashRoute
    RayClient -->|HTTPS/443<br/>TLS1.2+ passthrough<br/>mTLS Client Cert| ClientRoute

    %% Ingress to Services
    DashRoute -->|HTTP/8265<br/>No encryption<br/>Internal pod| RayDash
    ClientRoute -->|gRPC/10001<br/>mTLS<br/>Client Cert| RayHead

    %% Ray Cluster Internal
    RayHead -->|gRPC mTLS<br/>Internal| RayWorkers

    %% Operator to API
    Manager -->|HTTPS/6443<br/>TLS1.3<br/>ServiceAccount| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS1.2+<br/>mTLS| WebhookService

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Bearer Token| MetricsService
    MetricsService -.->|exposes| Manager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef userworkload fill:#e1f5e1,stroke:#82b366,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,RayClient external
    class DashRoute,ClientRoute ingress
    class RayDash,RayHead,RayWorkers userworkload
    class Manager,MetricsService,WebhookService operator
    class K8sAPI controlplane
    class Prometheus monitoring
