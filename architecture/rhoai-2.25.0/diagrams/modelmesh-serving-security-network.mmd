graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>Data Scientist]
    end

    subgraph ServiceLayer["SERVICE LAYER"]
        Service["modelmesh-serving Service<br/>ClusterIP/Headless<br/>8033/TCP gRPC, 8008/TCP HTTP"]
    end

    subgraph ControlPlane["CONTROL PLANE (Operator)"]
        direction TB

        subgraph ControllerNS["Namespace: modelmesh-serving-system"]
            Controller["modelmesh-controller<br/>SA: modelmesh-controller"]

            WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API cert"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>TLS 1.2+ Bearer Token"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]

            Controller --- WebhookSvc
            Controller --- MetricsSvc
            Controller --- HealthProbes
        end
    end

    subgraph DataPlane["DATA PLANE (Runtime Pods)"]
        direction TB

        subgraph RuntimeNS["Namespace: {user-namespace}"]
            direction TB

            subgraph RuntimePod["Runtime Pod"]
                ModelMesh["ModelMesh Container<br/>8033/TCP gRPC (external)<br/>8080/TCP gRPC (internal)<br/>No encryption"]
                RESTProxy["REST Proxy<br/>8008/TCP HTTP<br/>No encryption"]
                RuntimeContainer["Model Runtime<br/>UDS or 8001/TCP gRPC<br/>Triton/MLServer/OpenVINO"]
                Puller["Storage Puller<br/>Init Container<br/>8086/TCP gRPC"]
                RuntimeMetrics["Metrics<br/>2112/TCP HTTP<br/>No auth"]

                RESTProxy -->|"HTTP→gRPC"| ModelMesh
                ModelMesh -->|gRPC| RuntimeContainer
                Puller -.->|shared volume| RuntimeContainer
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        ETCD["ETCD v3.5.9<br/>2379/TCP HTTP/gRPC<br/>Optional TLS<br/>Optional mTLS"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount tokens"]
        Prometheus["Prometheus<br/>Metrics scraping"]
    end

    %% External to Service Layer
    Client -->|"gRPC 8033/TCP<br/>HTTP 8008/TCP<br/>No encryption<br/>Optional auth"| Service

    %% Service to Data Plane
    Service -->|routes| ModelMesh

    %% Data Plane to External Services
    ModelMesh -->|"2379/TCP<br/>HTTP/gRPC<br/>Optional TLS"| ETCD
    Puller -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4"| S3

    %% Control Plane to K8s API
    Controller -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"9443/TCP HTTPS<br/>TLS 1.2+<br/>API cert"| WebhookSvc

    %% Prometheus scraping
    Prometheus -->|"8443/TCP HTTPS<br/>Bearer Token"| MetricsSvc
    Prometheus -->|"2112/TCP HTTP<br/>No auth"| RuntimeMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef serviceLayer fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef controlPlane fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef dataPlane fill:#c8e6c9,stroke:#43a047,stroke-width:2px
    classDef externalService fill:#ffccbc,stroke:#e64a19,stroke-width:2px

    class Client external
    class Service serviceLayer
    class Controller,WebhookSvc,MetricsSvc,HealthProbes controlPlane
    class ModelMesh,RESTProxy,RuntimeContainer,Puller,RuntimeMetrics dataPlane
    class ETCD,S3,K8sAPI,Prometheus externalService
