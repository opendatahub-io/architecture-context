graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ) - Optional"]
        Route["OpenShift Route /<br/>Istio VirtualService<br/>Optional TLS termination"]
    end

    subgraph ServiceLayer["SERVICE LAYER"]
        ServingService["modelmesh-serving Service<br/>ClusterIP/Headless<br/>8033/TCP gRPC<br/>8008/TCP HTTP<br/>No encryption"]
    end

    subgraph RuntimePods["RUNTIME PODS (user-namespace)"]
        direction TB

        subgraph Pod["Runtime Pod Deployment<br/>SA: modelmesh-controller/default"]
            ModelMesh["ModelMesh Container<br/>8033/TCP gRPC (external)<br/>8080/TCP gRPC (internal)<br/>No encryption"]
            RESTProxy["REST Proxy Container<br/>8008/TCP HTTP<br/>Translates HTTP→gRPC"]
            RuntimeAdapter["Runtime Adapter<br/>Sidecar"]
            ModelRuntime["Model Runtime<br/>Triton/MLServer/etc<br/>UDS or 8001/TCP gRPC<br/>No encryption"]
            StoragePuller["Storage Puller<br/>Init Container<br/>8086/TCP gRPC"]
            MetricsEndpoint["Metrics<br/>2112/TCP HTTP<br/>No encryption/auth"]
            SharedVolume["Shared Volume<br/>/models<br/>Filesystem"]
        end

        RESTProxy -->|"Forward"| ModelMesh
        ModelMesh -->|"Internal comm<br/>8080/TCP gRPC"| ModelMesh
        ModelMesh -->|"Route to"| RuntimeAdapter
        RuntimeAdapter -->|"gRPC"| ModelRuntime
        StoragePuller -->|"Write"| SharedVolume
        ModelRuntime -->|"Read"| SharedVolume
    end

    subgraph ControllerPods["CONTROLLER POD (modelmesh-controller-namespace)"]
        direction TB

        subgraph ControllerPod["modelmesh-controller Pod<br/>SA: modelmesh-controller"]
            Controller["Controller Container<br/>Reconciles CRDs"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API cert"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token auth"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz<br/>No auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        ETCD["ETCD Cluster<br/>2379/TCP gRPC/HTTP<br/>Optional TLS<br/>Optional mTLS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4 / IAM"]
        Prometheus["Prometheus<br/>Metrics scraping"]
    end

    %% External Client Flows
    Client -->|"gRPC/HTTP<br/>8033/8008<br/>No encryption<br/>Optional app auth"| Route
    Route -->|"Forward"| ServingService
    ServingService -->|"Route"| ModelMesh
    ServingService -->|"Route"| RESTProxy

    %% ModelMesh to ETCD
    ModelMesh -->|"2379/TCP<br/>gRPC/HTTP<br/>Optional TLS<br/>Optional mTLS"| ETCD

    %% Storage Puller to S3
    StoragePuller -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4"| S3

    %% Controller flows
    Controller -->|"6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI
    K8sAPI -->|"9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API cert"| Webhook

    %% Metrics flows
    Prometheus -->|"8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"| RBACProxy
    Prometheus -->|"2112/TCP HTTP<br/>No encryption/auth"| MetricsEndpoint

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#e1f5ff,stroke:#0277bd,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#2e5c8a,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class ServingService service
    class ModelMesh,RESTProxy,RuntimeAdapter,ModelRuntime,StoragePuller,MetricsEndpoint,SharedVolume runtime
    class Controller,Webhook,RBACProxy,HealthProbes controller
    class K8sAPI,ETCD,S3,Prometheus externalservice
