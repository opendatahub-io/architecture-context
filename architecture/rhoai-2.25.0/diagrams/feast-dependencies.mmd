graph LR
    Feast[Feast Operator]

    %% External Dependencies (Required)
    Feast -->|container orchestration| Kubernetes[Kubernetes 1.11.3+]

    %% External Dependencies (Optional)
    Feast -.->|persistent storage| PostgreSQL[PostgreSQL]
    Feast -.->|online store| Redis[Redis 7+]
    Feast -.->|object storage| S3[S3/GCS/Azure Blob]
    Feast -.->|data warehouse| Snowflake[Snowflake]
    Feast -.->|TLS certificates| CertManager[cert-manager]

    %% Internal ODH Dependencies
    Feast -->|metrics| Prometheus[Prometheus]
    Feast -.->|UI integration| Dashboard[ODH Dashboard]
    Feast -.->|authentication| OAuth[OpenShift OAuth]
    Feast -.->|CA certificates| TrustedCA[Trusted CA Bundle]
    Feast -.->|mTLS enforcement| ServiceMesh[Service Mesh]

    %% Integration Points
    Dashboard -->|discovers instances| Feast
    DataPipelines[Data Science Pipelines] -->|feature ingestion| Feast
    Notebooks[Jupyter Notebooks] -->|feature queries| Feast
    KServe[KServe] -->|online features| Feast
    TrainingOperator[Training Operator] -->|offline features| Feast

    %% External Services
    Feast -->|feature repo sync| Git[Git Repository]
    Feast -->|API server| K8sAPI[Kubernetes API]
    Feast -->|routing| OpenShiftRouter[OpenShift Router]

    %% Storage Architecture
    subgraph "Storage Backends"
        Redis
        PostgreSQL
        S3
        Snowflake
        SQLite[SQLite - Default]
    end

    %% Feature Services
    subgraph "Feast Services"
        OnlineStore[Online Store]
        OfflineStore[Offline Store]
        Registry[Registry]
        UI[UI Server]
        CronJob[Materialization CronJob]
    end

    Feast -.->|deploys| OnlineStore
    Feast -.->|deploys| OfflineStore
    Feast -.->|deploys| Registry
    Feast -.->|deploys| UI
    Feast -.->|deploys| CronJob

    OnlineStore --> Redis
    OnlineStore --> PostgreSQL
    OnlineStore --> SQLite
    OfflineStore --> S3
    OfflineStore --> PostgreSQL
    OfflineStore --> Snowflake
    Registry --> PostgreSQL
    Registry --> S3
    Registry --> Snowflake

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies (Required)
    style Kubernetes fill:#ff6b6b,stroke:#333,stroke-width:2px,color:#fff

    %% External Dependencies (Optional)
    style PostgreSQL fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Redis fill:#999,stroke:#333,stroke-dasharray: 5 5
    style S3 fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Snowflake fill:#999,stroke:#333,stroke-dasharray: 5 5
    style CertManager fill:#999,stroke:#333,stroke-dasharray: 5 5
    style SQLite fill:#999,stroke:#333,stroke-dasharray: 5 5

    %% Internal ODH Dependencies
    style Prometheus fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style OAuth fill:#7ed321,stroke:#333
    style TrustedCA fill:#7ed321,stroke:#333
    style ServiceMesh fill:#7ed321,stroke:#333

    %% Integration Points
    style DataPipelines fill:#d5e8d4,stroke:#82b366
    style Notebooks fill:#d5e8d4,stroke:#82b366
    style KServe fill:#d5e8d4,stroke:#82b366
    style TrainingOperator fill:#d5e8d4,stroke:#82b366

    %% External Services
    style Git fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style OpenShiftRouter fill:#f5a623,stroke:#333

    %% Feature Services
    style OnlineStore fill:#4a90e2,stroke:#333,color:#fff
    style OfflineStore fill:#4a90e2,stroke:#333,color:#fff
    style Registry fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#95a5a6,stroke:#333,color:#fff
    style CronJob fill:#4a90e2,stroke:#333,color:#fff

    linkStyle default stroke:#666,stroke-width:2px
