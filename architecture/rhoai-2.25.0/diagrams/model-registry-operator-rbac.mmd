graph TD
    subgraph "Service Accounts"
        ControllerSA[controller-manager<br/>ServiceAccount]
        RegistrySA["{name}<br/>ServiceAccount<br/>(per instance)"]
    end

    subgraph "ClusterRole Bindings"
        ManagerBinding[manager-rolebinding<br/>ClusterRoleBinding]
        ProxyBinding[proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        LeaderBinding[leader-election-rolebinding<br/>RoleBinding<br/>operator namespace]
        RegistryBinding["registry-user-{name}-binding<br/>RoleBinding<br/>user namespace"]
    end

    subgraph "ClusterRoles"
        ManagerRole[manager-role<br/>ClusterRole]
        ProxyRole[proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        LeaderRole[leader-election-role<br/>Role<br/>operator namespace]
        RegistryRole["registry-user-{name}<br/>Role<br/>user namespace"]
    end

    subgraph "API Resources - manager-role"
        direction TB
        ModelRegistryCRD["modelregistry.opendatahub.io<br/>ModelRegistry CR<br/>verbs: create,delete,get,list,patch,update,watch<br/>status,finalizers: get,patch,update"]
        Deployments["apps<br/>Deployments<br/>verbs: create,delete,get,list,patch,update,watch"]
        Services["core<br/>Services, ServiceAccounts<br/>verbs: create,delete,get,list,patch,update,watch"]
        ConfigMaps["core<br/>ConfigMaps, Secrets<br/>verbs: create,get,list,watch"]
        Routes["route.openshift.io<br/>Routes, Routes/custom-host<br/>verbs: create,delete,get,list,patch,update,watch"]
        RBAC["rbac.authorization.k8s.io<br/>Roles, RoleBindings, ClusterRoleBindings<br/>verbs: create,delete,get,list,patch,update,watch"]
        NetworkPolicies["networking.k8s.io<br/>NetworkPolicies<br/>verbs: create,delete,get,list,patch,update,watch"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews<br/>verbs: create"]
        SubjectAccessReviews["authorization.k8s.io<br/>SubjectAccessReviews<br/>verbs: create"]
        PlatformCRD["components.platform.opendatahub.io<br/>ModelRegistries<br/>verbs: get,list,watch"]
    end

    subgraph "API Resources - proxy-role"
        ProxyTokenReviews["authentication.k8s.io<br/>TokenReviews<br/>verbs: create"]
        ProxySubjectAccessReviews["authorization.k8s.io<br/>SubjectAccessReviews<br/>verbs: create"]
    end

    subgraph "API Resources - leader-election-role"
        LeaderConfigMaps["core<br/>ConfigMaps<br/>verbs: get,list,watch,create,update,patch,delete"]
        LeaderLeases["coordination.k8s.io<br/>Leases<br/>verbs: get,list,watch,create,update,patch,delete"]
        LeaderEvents["core<br/>Events<br/>verbs: create,patch"]
    end

    subgraph "API Resources - registry-user role"
        RegistryService["core<br/>Service/{name}<br/>verbs: get<br/>(OAuth authorization)"]
    end

    %% Service Account to Bindings
    ControllerSA -->|bound via| ManagerBinding
    ControllerSA -->|bound via| ProxyBinding
    ControllerSA -->|bound via| LeaderBinding

    RegistrySA -->|bound via| RegistryBinding

    %% Bindings to Roles
    ManagerBinding -->|grants| ManagerRole
    ProxyBinding -->|grants| ProxyRole
    LeaderBinding -->|grants| LeaderRole
    RegistryBinding -->|grants| RegistryRole

    %% Roles to Resources
    ManagerRole -->|permissions| ModelRegistryCRD
    ManagerRole -->|permissions| Deployments
    ManagerRole -->|permissions| Services
    ManagerRole -->|permissions| ConfigMaps
    ManagerRole -->|permissions| Routes
    ManagerRole -->|permissions| RBAC
    ManagerRole -->|permissions| NetworkPolicies
    ManagerRole -->|permissions| TokenReviews
    ManagerRole -->|permissions| SubjectAccessReviews
    ManagerRole -->|permissions| PlatformCRD

    ProxyRole -->|permissions| ProxyTokenReviews
    ProxyRole -->|permissions| ProxySubjectAccessReviews

    LeaderRole -->|permissions| LeaderConfigMaps
    LeaderRole -->|permissions| LeaderLeases
    LeaderRole -->|permissions| LeaderEvents

    RegistryRole -->|permissions| RegistryService

    %% Styling
    style ControllerSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style RegistrySA fill:#4a90e2,stroke:#333,stroke-width:2px
    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px
    style ProxyRole fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px
    style RegistryRole fill:#f5a623,stroke:#333,stroke-width:2px
    style ModelRegistryCRD fill:#7ed321,stroke:#333,stroke-width:2px
    style Deployments fill:#7ed321,stroke:#333,stroke-width:2px
    style Services fill:#7ed321,stroke:#333,stroke-width:2px
    style Routes fill:#7ed321,stroke:#333,stroke-width:2px
    style RegistryService fill:#7ed321,stroke:#333,stroke-width:2px
