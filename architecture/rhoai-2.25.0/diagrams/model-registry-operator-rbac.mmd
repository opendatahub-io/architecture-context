graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: operator-namespace]
        SA_Registry["NAME<br/>Namespace: user-namespace<br/>(per ModelRegistry CR)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: operator-namespace]
        RB_RegistryUser["registry-user-NAME-binding<br/>RoleBinding<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Proxy[proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        R_Leader[leader-election-role<br/>Role<br/>Namespace: operator-namespace]
        R_RegistryUser["registry-user-NAME<br/>Role<br/>Namespace: user-namespace"]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[core/configmaps<br/>create, get, list, watch]
        Core_Secrets[core/secrets<br/>create, get, list, watch]
        Core_Services[core/services, serviceaccounts<br/>create, delete, get, list, patch, update, watch]
        Core_Endpoints[core/endpoints, pods, pods/log<br/>get, list, watch]
        Core_Events[core/events<br/>create, patch]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/deployments<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - ModelRegistry"
        MR_CRs[modelregistry.opendatahub.io/modelregistries<br/>create, delete, get, list, patch, update, watch]
        MR_Status[modelregistry.opendatahub.io/modelregistries/status<br/>get, patch, update]
        MR_Finalizers[modelregistry.opendatahub.io/modelregistries/finalizers<br/>update]
    end

    subgraph "API Resources - OpenShift"
        Route_Routes[route.openshift.io/routes, routes/custom-host<br/>create, delete, get, list, patch, update, watch]
        User_Groups[user.openshift.io/groups<br/>create, delete, get, list, patch, update, watch]
        Config_Ingresses[config.openshift.io/ingresses<br/>get, list, watch]
    end

    subgraph "API Resources - RBAC"
        RBAC_Resources[rbac.authorization.k8s.io/<br/>roles, rolebindings, clusterrolebindings<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Networking"
        Net_Policies[networking.k8s.io/networkpolicies<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReviews[authentication.k8s.io/tokenreviews<br/>create]
        Auth_SubjectAccess[authorization.k8s.io/subjectaccessreviews<br/>create]
    end

    subgraph "API Resources - Platform"
        Platform_MR[components.platform.opendatahub.io/modelregistries<br/>get, list, watch]
    end

    subgraph "API Resources - Migration"
        Migration_SVM[migration.k8s.io/storageversionmigrations<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Extensions"
        Ext_CRDs[apiextensions.k8s.io/customresourcedefinitions<br/>get, list, watch]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[coordination.k8s.io/leases<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader

    SA_Registry -->|bound via| RB_RegistryUser

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader
    RB_RegistryUser -->|grants| R_RegistryUser

    %% manager-role Permissions
    CR_Manager -->|permissions| Core_ConfigMaps
    CR_Manager -->|permissions| Core_Secrets
    CR_Manager -->|permissions| Core_Services
    CR_Manager -->|permissions| Core_Endpoints
    CR_Manager -->|permissions| Core_Events
    CR_Manager -->|permissions| Apps_Deployments
    CR_Manager -->|permissions| MR_CRs
    CR_Manager -->|permissions| MR_Status
    CR_Manager -->|permissions| MR_Finalizers
    CR_Manager -->|permissions| Route_Routes
    CR_Manager -->|permissions| User_Groups
    CR_Manager -->|permissions| Config_Ingresses
    CR_Manager -->|permissions| RBAC_Resources
    CR_Manager -->|permissions| Net_Policies
    CR_Manager -->|permissions| Auth_TokenReviews
    CR_Manager -->|permissions| Auth_SubjectAccess
    CR_Manager -->|permissions| Platform_MR
    CR_Manager -->|permissions| Migration_SVM
    CR_Manager -->|permissions| Ext_CRDs

    %% proxy-role Permissions
    CR_Proxy -->|permissions| Auth_TokenReviews
    CR_Proxy -->|permissions| Auth_SubjectAccess

    %% leader-election-role Permissions
    R_Leader -->|permissions| Core_ConfigMaps
    R_Leader -->|permissions| Coord_Leases
    R_Leader -->|permissions| Core_Events

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Registry fill:#7ed321

    style CR_Manager fill:#f5a623
    style CR_Proxy fill:#f5a623
    style R_Leader fill:#f5a623
    style R_RegistryUser fill:#f5a623

    style CRB_Manager fill:#bd10e0,color:#fff
    style CRB_Proxy fill:#bd10e0,color:#fff
    style RB_Leader fill:#bd10e0,color:#fff
    style RB_RegistryUser fill:#bd10e0,color:#fff

    style MR_CRs fill:#50e3c2
    style MR_Status fill:#50e3c2
    style MR_Finalizers fill:#50e3c2
    style Platform_MR fill:#50e3c2
