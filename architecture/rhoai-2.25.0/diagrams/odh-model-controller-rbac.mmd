graph TD
    subgraph "Service Account"
        SA[odh-model-controller<br/>NS: odh-model-controller]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-role-binding]
        CRB2[metrics-auth-rolebinding]
        CRB3[auth-proxy-rolebinding]
    end

    subgraph "Roles"
        CR1[odh-model-controller-role<br/>ClusterRole]
        CR2[leader-election-role<br/>Role]
        CR3[metrics-auth-role<br/>ClusterRole]
        CR4[auth-proxy-role<br/>ClusterRole]
    end

    subgraph "KServe API Resources"
        ISVC[serving.kserve.io<br/>InferenceService, LLMInferenceService<br/>Verbs: get, list, patch, update, watch]
        ISVC_FIN[serving.kserve.io<br/>InferenceService/finalizers<br/>Verbs: create, delete, get, list, patch, update, watch]
        IGRAPH[serving.kserve.io<br/>InferenceGraph<br/>Verbs: get, list, watch]
        IGRAPH_FIN[serving.kserve.io<br/>InferenceGraph/finalizers<br/>Verbs: update]
        SR[serving.kserve.io<br/>ServingRuntime<br/>Verbs: create, get, list, update, watch]
    end

    subgraph "Istio/Service Mesh Resources"
        VS[networking.istio.io<br/>VirtualService<br/>Verbs: create, delete, get, list, patch, update, watch]
        GW[networking.istio.io<br/>Gateway<br/>Verbs: get, list, patch, update, watch]
        PA[security.istio.io<br/>PeerAuthentication<br/>Verbs: create, delete, get, list, patch, update, watch]
        AP[security.istio.io<br/>AuthorizationPolicy<br/>Verbs: get, list]
        TEL[telemetry.istio.io<br/>Telemetry<br/>Verbs: create, delete, get, list, patch, update, watch]
        SMM[maistra.io<br/>ServiceMeshMember<br/>Verbs: create, delete, get, list, patch, update, watch]
        SMCP[maistra.io<br/>ServiceMeshControlPlane<br/>Verbs: get, list, use, watch]
    end

    subgraph "OpenShift Resources"
        ROUTE[route.openshift.io<br/>Route<br/>Verbs: create, delete, get, list, patch, update, watch]
        ROUTE_HOST[route.openshift.io<br/>Route/custom-host<br/>Verbs: create]
        TEMPLATE[template.openshift.io<br/>Template<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Auth & Monitoring Resources"
        AUTHCONFIG[authorino.kuadrant.io<br/>AuthConfig<br/>Verbs: create, delete, get, list, patch, update, watch]
        AUTHPOLICY[kuadrant.io<br/>AuthPolicy<br/>Verbs: create, delete, get, list, patch, update, watch]
        SM[monitoring.coreos.com<br/>ServiceMonitor, PodMonitor<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Core & Networking Resources"
        CM[core<br/>ConfigMap, Secret, Service<br/>Verbs: create, delete, get, list, patch, update, watch]
        POD[core<br/>Pod<br/>Verbs: create, get, list, patch, update, watch]
        NP[networking.k8s.io<br/>NetworkPolicy<br/>Verbs: create, delete, get, list, patch, update, watch]
        RBAC[rbac.authorization.k8s.io<br/>ClusterRoleBinding, RoleBinding, Role<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "NIM & ODH Resources"
        NIM[nim.opendatahub.io<br/>Account, Account/status<br/>Verbs: get, list, patch, update, watch]
        NIM_FIN[nim.opendatahub.io<br/>Account/finalizers<br/>Verbs: update]
        DSC_RES[datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>Verbs: get, list, watch]
        DSCINIT[dscinitialization.opendatahub.io<br/>DSCInitialization<br/>Verbs: get, list, watch]
    end

    subgraph "Autoscaling Resources"
        KEDA_RES[keda.sh<br/>TriggerAuthentication<br/>Verbs: create, delete, get, list, patch, update, watch]
        METRICS[metrics.k8s.io<br/>Pod, Node<br/>Verbs: get, list, watch]
    end

    subgraph "Leader Election Resources"
        LEASE[coordination.k8s.io<br/>Lease<br/>Verbs: get, list, watch, create, update, patch, delete]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CR2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR3
    CRB3 -->|grants| CR4
    CR2 -->|grants leader election| LEASE

    %% Main Role to Resources
    CR1 -->|manage| ISVC
    CR1 -->|manage| ISVC_FIN
    CR1 -->|manage| IGRAPH
    CR1 -->|manage| IGRAPH_FIN
    CR1 -->|manage| SR

    CR1 -->|manage| VS
    CR1 -->|manage| GW
    CR1 -->|manage| PA
    CR1 -->|read-only| AP
    CR1 -->|manage| TEL
    CR1 -->|manage| SMM
    CR1 -->|read/use| SMCP

    CR1 -->|manage| ROUTE
    CR1 -->|create custom host| ROUTE_HOST
    CR1 -->|manage| TEMPLATE

    CR1 -->|manage| AUTHCONFIG
    CR1 -->|manage| AUTHPOLICY
    CR1 -->|manage| SM

    CR1 -->|manage| CM
    CR1 -->|manage| POD
    CR1 -->|manage| NP
    CR1 -->|manage| RBAC

    CR1 -->|manage| NIM
    CR1 -->|update finalizer| NIM_FIN
    CR1 -->|read-only| DSC_RES
    CR1 -->|read-only| DSCINIT

    CR1 -->|manage| KEDA_RES
    CR1 -->|read metrics| METRICS

