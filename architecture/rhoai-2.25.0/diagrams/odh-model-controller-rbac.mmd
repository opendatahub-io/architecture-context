graph TD
    subgraph "Service Accounts"
        SA[odh-model-controller<br/>Namespace: odh-model-controller]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-role-binding]
        CRB2[metrics-auth-rolebinding]
        CRB3[auth-proxy-rolebinding]
    end

    subgraph "ClusterRoles"
        CR[odh-model-controller-role]
        MetricsRole[metrics-reader]
        ProxyRole[auth-proxy-role]
    end

    subgraph "Role Bindings (Namespace-Scoped)"
        LeaderElectionRB[leader-election-rolebinding<br/>Namespace: odh-model-controller]
    end

    subgraph "Roles (Namespace-Scoped)"
        LeaderElectionRole[leader-election-role]
    end

    subgraph "KServe API Resources"
        direction LR
        InferenceService[InferenceService<br/>serving.kserve.io/v1beta1]
        InferenceGraph[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        LLMInferenceService[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Istio/Maistra API Resources"
        direction LR
        VirtualService[VirtualService<br/>networking.istio.io]
        Gateway[Gateway<br/>networking.istio.io]
        PeerAuth[PeerAuthentication<br/>security.istio.io]
        AuthzPolicy[AuthorizationPolicy<br/>security.istio.io]
        Telemetry[Telemetry<br/>telemetry.istio.io]
        ServiceMeshMember[ServiceMeshMember<br/>maistra.io]
        ServiceMeshMemberRoll[ServiceMeshMemberRoll<br/>maistra.io]
        ServiceMeshControlPlane[ServiceMeshControlPlane<br/>maistra.io]
    end

    subgraph "OpenShift API Resources"
        direction LR
        Route[Route<br/>route.openshift.io]
        RouteCustomHost[Route/custom-host<br/>route.openshift.io]
        Template[Template<br/>template.openshift.io]
    end

    subgraph "Monitoring API Resources"
        direction LR
        ServiceMonitor[ServiceMonitor<br/>monitoring.coreos.com]
        PodMonitor[PodMonitor<br/>monitoring.coreos.com]
    end

    subgraph "Auth API Resources"
        direction LR
        AuthConfig[AuthConfig<br/>authorino.kuadrant.io]
        AuthPolicy[AuthPolicy<br/>kuadrant.io]
    end

    subgraph "KEDA API Resources"
        TriggerAuth[TriggerAuthentication<br/>keda.sh]
    end

    subgraph "Network API Resources"
        NetworkPolicy[NetworkPolicy<br/>networking.k8s.io]
        Ingress[Ingress<br/>networking.k8s.io]
    end

    subgraph "RBAC API Resources"
        ClusterRoleBinding[ClusterRoleBinding<br/>rbac.authorization.k8s.io]
        RoleBinding[RoleBinding<br/>rbac.authorization.k8s.io]
        Role[Role<br/>rbac.authorization.k8s.io]
    end

    subgraph "NIM API Resources"
        NIMAccount[Account<br/>nim.opendatahub.io/v1]
    end

    subgraph "ODH API Resources"
        DataScienceCluster[DataScienceCluster<br/>datasciencecluster.opendatahub.io]
        DSCInit[DSCInitialization<br/>dscinitialization.opendatahub.io]
    end

    subgraph "Core K8s Resources"
        direction LR
        ConfigMap[ConfigMap]
        Secret[Secret]
        ServiceAccount[ServiceAccount]
        Service[Service]
        Pod[Pod]
        Namespace[Namespace]
        Endpoints[Endpoints]
        Event[Event]
    end

    subgraph "Coordination Resources"
        Lease[Lease<br/>coordination.k8s.io]
    end

    subgraph "Metrics Resources"
        MetricsPods[Pods<br/>metrics.k8s.io]
        MetricsNodes[Nodes<br/>metrics.k8s.io]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| LeaderElectionRB

    %% Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| MetricsRole
    CRB3 -->|grants| ProxyRole
    LeaderElectionRB -->|grants| LeaderElectionRole

