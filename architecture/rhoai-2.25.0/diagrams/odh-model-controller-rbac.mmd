    CR -->|get, list, watch, update, patch| NIMAccount

    CR -->|get, list, watch| DataScienceCluster
    CR -->|get, list, watch| DSCInit

    CR -->|get, list, watch, create, update, patch, delete| ConfigMap
    CR -->|get, list, watch, create, update, patch, delete| Secret
    CR -->|get, list, watch, create, update, patch, delete| ServiceAccount
    CR -->|get, list, watch, create, update, patch, delete| Service
    CR -->|get, list, watch, create, update, patch| Pod
    CR -->|get, list, watch, create, update, patch| Namespace
    CR -->|get, list, watch, create, update, patch| Endpoints
