    style PA fill:#9b59b6,stroke:#333
    style TEL fill:#9b59b6,stroke:#333
    style SMM fill:#9b59b6,stroke:#333

    style ROUTE fill:#e74c3c,stroke:#333
    style ROUTE_HOST fill:#e74c3c,stroke:#333

    style AUTHCONFIG fill:#50e3c2,stroke:#333
    style AUTHPOLICY fill:#50e3c2,stroke:#333
    style SM fill:#50e3c2,stroke:#333

