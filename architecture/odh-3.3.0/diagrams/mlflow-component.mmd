graph TB
    subgraph "MLflow Platform"
        subgraph "MLflow Server"
            API[MLflow REST API<br/>Flask/Python<br/>5000/TCP]
            UI[React Frontend<br/>TypeScript/React SPA]
            K8S_WS[Kubernetes Workspace Provider<br/>Namespace to Workspace Mapping]
            K8S_AUTH[Kubernetes Auth Plugin<br/>RBAC Enforcement]
            PROM_EXP[Prometheus Exporter<br/>Metrics]
        end

        CRD[MLflowConfig v1alpha1<br/>Namespace Artifact Override]
    end

    subgraph "Backend Stores"
        PG[PostgreSQL Database<br/>Metadata Store<br/>5432/TCP]
        S3[S3-compatible Storage<br/>Artifact Store<br/>443/TCP HTTPS]
    end

    subgraph "Kubernetes Integration"
        K8S_API[Kubernetes API<br/>6443/TCP HTTPS]
        NS[Namespaces]
        SAR[SubjectAccessReview API]
    end

    subgraph "External Access"
        GATEWAY[Istio Gateway<br/>443/TCP HTTPS<br/>TLS Termination]
        MESH[Service Mesh Istio<br/>mTLS Optional]
    end

    subgraph "Monitoring"
        PROM[Prometheus<br/>Metrics Scraping]
    end

    %% Server Components
    API -->|uses| K8S_WS
    API -->|uses| K8S_AUTH
    API -->|exposes| PROM_EXP
    UI -->|calls| API

    %% Kubernetes Workspace Provider
    K8S_WS -->|reads| CRD
    K8S_WS -->|lists/watches| NS
    K8S_WS -->|reads| K8S_API

    %% Kubernetes Auth Plugin
    K8S_AUTH -->|creates| SAR
    K8S_AUTH -->|enforces RBAC| API

    %% Backend Stores
    API -->|stores metadata| PG
    API -->|stores artifacts| S3

    %% External Access
    GATEWAY -->|routes to| API
    MESH -.->|optional mTLS| API

    %% Monitoring
    PROM_EXP -->|scrapes| PROM

    style API fill:#326CE5,stroke:#fff,color:#fff
    style UI fill:#4285F4,stroke:#fff,color:#fff
    style K8S_WS fill:#34A853,stroke:#fff,color:#fff
    style K8S_AUTH fill:#FBBC04,stroke:#000,color:#000
    style PG fill:#336791,stroke:#fff,color:#fff
    style S3 fill:#569A31,stroke:#fff,color:#fff
