graph TB
    subgraph "Service Accounts"
        SA1[notebook-controller-service-account]
        SA2[odh-notebook-controller-manager]
    end

    subgraph "Cluster Roles"
        CR1[notebook-controller-role]
        CR2[odh-notebook-controller<br/>-manager-role]
        CR3[notebook-controller<br/>-leader-election-role]
    end

    subgraph "Role Bindings"
        RB1[notebook-controller<br/>-role-binding]
        RB2[odh-notebook-controller<br/>-manager-rolebinding]
        RB3[notebook-controller<br/>-leader-election-rolebinding]
    end

    subgraph "Kubernetes Resources"
        subgraph "Core Resources"
            RES1[Notebooks<br/>Services<br/>Pods<br/>Events<br/>ConfigMaps<br/>Secrets<br/>ServiceAccounts]
        end

        subgraph "Apps"
            RES2[StatefulSets]
        end

        subgraph "Networking"
            RES3[Istio VirtualServices<br/>NetworkPolicies]
        end

        subgraph "ODH Integrations"
            RES4[DataSciencePipelinesApplications<br/>DSPA API Subresource]
        end

        subgraph "Gateway API"
            RES5[Gateways<br/>HTTPRoutes<br/>ReferenceGrants]
        end

        subgraph "OpenShift APIs"
            RES6[ImageStreams<br/>OAuth Clients<br/>Routes<br/>Proxies]
        end

        subgraph "RBAC"
            RES7[ClusterRoleBindings<br/>RoleBindings<br/>Roles]
        end

        subgraph "Auth"
            RES8[TokenReviews<br/>SubjectAccessReviews]
        end

        subgraph "Leader Election"
            RES9[ConfigMaps<br/>Leases]
        end
    end

    subgraph "Permissions"
        PERM1[All verbs: *]
        PERM2[get, list, watch,<br/>delete, create, patch]
        PERM3[get, list, watch,<br/>patch, update]
        PERM4[create, delete, get,<br/>list, patch, update, watch]
        PERM5[get, list, watch,<br/>create, update, patch]
    end

    %% Service Account to Role Bindings
    SA1 -->|bound by| RB1
    SA1 -->|bound by| RB3
    SA2 -->|bound by| RB2

    %% Role Bindings to Cluster Roles
    RB1 -->|grants| CR1
    RB2 -->|grants| CR2
    RB3 -->|grants| CR3

    %% Cluster Roles to Resources
    CR1 -->|all verbs| RES1
    CR1 -->|all verbs| RES2
    CR1 -->|all verbs| RES3

    CR2 -->|get, list, watch,<br/>patch, update| RES1
    CR2 -->|create| RES8
    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES4
    CR2 -->|get, list, watch| RES5
    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES5
    CR2 -->|get, list, watch| RES6
    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES3
    CR2 -->|create, delete, get,<br/>list, patch, update, watch| RES7

    CR3 -->|get, list, watch,<br/>create, update, patch| RES9

    %% Permissions Details
    CR1 -.->|notebooks, statefulsets,<br/>virtualservices| PERM1
    CR1 -.->|services, pods, events| PERM2

    CR2 -.->|notebooks, configmaps,<br/>secrets, serviceaccounts| PERM3
    CR2 -.->|DSPA, httproutes,<br/>networkpolicies, rbac| PERM4

    CR3 -.->|configmaps, leases| PERM5

