graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[User Browser /<br/>Notebook Pod]
    end

    subgraph Ingress["INGRESS - DMZ"]
        direction TB
        RouteHTTP["OpenShift Route<br/>modelregistry-sample-http<br/>80/TCP HTTP<br/>No TLS"]
        RouteHTTPS["OpenShift Route<br/>modelregistry-sample-https<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge Termination"]
    end

    subgraph AppTier["APPLICATION TIER - Namespace Isolation"]
        direction TB

        subgraph NSRegistry["Namespace: registry-namespace"]
            direction TB
            OAuthProxy["OAuth Proxy Sidecar<br/>SA: registry-name-sa<br/>Service: modelregistry-sample-oauth<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token JWT"]

            MRPod["Model Registry Service Pod<br/>SA: registry-name-sa<br/>Image: model-registry:latest"]

            ServiceHTTP["Service: modelregistry-sample<br/>ClusterIP 8080/TCP HTTP<br/>No Auth"]
            ServiceGRPC["Service: modelregistry-sample-grpc<br/>ClusterIP 9090/TCP gRPC<br/>mTLS optional"]
            ServiceOAuth["Service: modelregistry-sample-oauth<br/>ClusterIP 8443/TCP HTTPS<br/>Bearer Token"]
        end
    end

    subgraph DBTier["DATABASE TIER - External/In-Cluster"]
        direction TB
        PostgreSQL["PostgreSQL 13+ OR MySQL 8.0+<br/>5432/TCP PostgreSQL<br/>3306/TCP MySQL<br/>TLS 1.2+ optional<br/>Password Auth<br/>NetworkPolicy: Registry NS only"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph NSOpendatahub["Namespace: opendatahub"]
            Operator["Model Registry Operator<br/>SA: model-registry-operator"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Manages: Deployments, Services,<br/>Routes, NetworkPolicies, RBAC"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        OAuthService["OAuth Service<br/>OpenShift Authentication<br/>443/TCP HTTPS TLS1.2+<br/>Validates Bearer Tokens"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>AWS Credentials<br/>Model Artifacts - URI refs"]
        Prometheus["Prometheus<br/>8443/TCP HTTPS TLS1.2+<br/>mTLS Auth<br/>Operator Metrics"]
    end

    %% Flows - External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie /<br/>Bearer Token| RouteHTTPS
    User -.->|HTTP/80<br/>No TLS| RouteHTTP

    %% Ingress to Application
    RouteHTTPS -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token JWT| OAuthProxy
    RouteHTTP -.->|HTTP/8080| ServiceHTTP

    %% OAuth Proxy to Service
    OAuthProxy -->|HTTP/8080<br/>localhost<br/>Validated Token| MRPod

    %% Service endpoints
    ServiceOAuth -->|routes to| OAuthProxy
    ServiceHTTP -->|routes to| MRPod
    ServiceGRPC -->|routes to| MRPod

    %% Application to Database
    MRPod -->|PostgreSQL/5432 OR<br/>MySQL/3306<br/>TLS 1.2+ opt<br/>Password Auth| PostgreSQL

    %% Operator to K8s API
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Manages Resources| K8sAPI

    %% OAuth Proxy to OAuth Service
    OAuthProxy -->|HTTPS/443<br/>TLS 1.2+<br/>Validate Tokens| OAuthService

    %% Model Registry to S3
    MRPod -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials<br/>URI References| S3

    %% Prometheus to Operator
    Prometheus -.->|HTTPS/8443<br/>TLS 1.2+<br/>mTLS<br/>Scrape Metrics| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class RouteHTTP,RouteHTTPS ingress
    class OAuthProxy,MRPod,ServiceHTTP,ServiceGRPC,ServiceOAuth application
    class PostgreSQL database
    class Operator,K8sAPI controlplane
    class OAuthService,S3,Prometheus externalservice
