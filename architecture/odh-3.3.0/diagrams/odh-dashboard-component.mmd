graph TB
    subgraph "ODH Dashboard Component"
        Frontend["Frontend<br/>React/TypeScript SPA<br/>PatternFly v6"]
        Backend["Backend<br/>Node.js/Fastify API<br/>REST API Server"]
        Proxy["kube-rbac-proxy<br/>OAuth Auth<br/>TLS Termination"]

        Frontend -->|API calls| Backend
        Proxy -->|forwards authenticated| Backend
    end

    subgraph "Feature Packages (Plugins)"
        GenAI["Gen AI Module"]
        ModelReg["Model Registry Module"]
        MLflow["MLflow Module"]
        AutoML["AutoML Module"]
        AutoRAG["AutoRAG Module"]
        KServePlugin["KServe Module"]
    end

    subgraph "Custom Resources"
        OdhApp["OdhApplication CR<br/>dashboard.opendatahub.io/v1"]
        OdhConfig["OdhDashboardConfig CR<br/>opendatahub.io/v1alpha"]
        OdhDoc["OdhDocument CR<br/>dashboard.opendatahub.io/v1"]
        QuickStart["OdhQuickStart CR<br/>console.openshift.io/v1"]
    end

    subgraph "External Access"
        User["User Browser"]
        Router["OpenShift Router<br/>443/TCP HTTPS"]
    end

    subgraph "Dependencies"
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        OAuth["OpenShift OAuth<br/>443/TCP HTTPS"]
        Prometheus["Prometheus<br/>9091/TCP HTTP"]
        ModelRegSvc["Model Registry Service<br/>8080/TCP HTTP"]
    end

    subgraph "ODH Component Integration"
        ODHOp["ODH Operator<br/>DataScienceCluster CR"]
        Notebooks["Kubeflow Notebooks<br/>Notebook CR"]
        KServe["KServe<br/>InferenceService CR"]
        MROperator["Model Registry Operator<br/>ModelRegistry CR"]
        TrustyAI["TrustyAI<br/>GuardrailsOrchestrator CR"]
        Feast["Feast<br/>FeatureStore CR"]
        LlamaStack["LlamaStack<br/>LlamaStackDistribution CR"]
    end

    %% User flow
    User -->|HTTPS/443<br/>TLS 1.2+| Router
    Router -->|HTTPS/8443<br/>TLS| Proxy

    %% Feature package integration
    Backend -.->|uses| GenAI
    Backend -.->|uses| ModelReg
    Backend -.->|uses| MLflow
    Backend -.->|uses| AutoML
    Backend -.->|uses| AutoRAG
    Backend -.->|uses| KServePlugin

    %% CR management
    Backend -->|reads/creates| OdhApp
    Backend -->|reads/updates| OdhConfig
    Backend -->|reads| OdhDoc
    Backend -->|reads| QuickStart

    %% External dependencies
    Backend -->|HTTPS/6443<br/>ServiceAccount Token| K8sAPI
    Proxy -->|OAuth validation<br/>HTTPS/443| OAuth
    Backend -->|metrics query<br/>HTTP/9091| Prometheus
    Backend -->|proxy API calls<br/>HTTP/8080| ModelRegSvc

    %% ODH component interactions
    Backend -->|watches| ODHOp
    Backend -->|creates/manages| Notebooks
    Backend -->|lists/watches| KServe
    Backend -->|creates/manages| MROperator
    Backend -->|lists/watches| TrustyAI
    Backend -->|lists/watches| Feast
    Backend -->|lists/watches| LlamaStack

