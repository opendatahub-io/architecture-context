graph TD
    subgraph "Service Account"
        SA[trainer-controller-manager<br/>Namespace: kubeflow]
    end

    subgraph "Role Binding"
        RB[trainer-rolebinding<br/>Namespace: kubeflow]
    end

    subgraph "Cluster Role"
        CR[kubeflow-trainer-controller-manager<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        ConfigMaps["core/ConfigMaps<br/>Verbs: create, get, list,<br/>patch, update, watch"]
        Secrets["core/Secrets<br/>Verbs: create, get, list,<br/>patch, update, watch"]
        Events["core/Events<br/>Verbs: create, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Trainer CRDs"
        TrainJobs["trainer.kubeflow.org<br/>TrainJobs<br/>Verbs: get, list, patch,<br/>update, watch"]
        TrainJobsStatus["trainer.kubeflow.org<br/>TrainJobs/status<br/>Verbs: get, patch, update"]
        TrainJobsFinalizers["trainer.kubeflow.org<br/>TrainJobs/finalizers<br/>Verbs: get, patch, update"]
        TrainingRuntimes["trainer.kubeflow.org<br/>TrainingRuntimes<br/>Verbs: get, list, patch,<br/>update, watch"]
        ClusterTrainingRuntimes["trainer.kubeflow.org<br/>ClusterTrainingRuntimes<br/>Verbs: get, list, patch,<br/>update, watch"]
    end

    subgraph "API Resources - JobSet"
        JobSets["jobset.x-k8s.io<br/>JobSets<br/>Verbs: create, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Scheduling"
        PodGroups["scheduling.volcano.sh<br/>scheduling.x-k8s.io<br/>PodGroups<br/>Verbs: create, get, list,<br/>patch, update, watch"]
    end

    subgraph "API Resources - Admission"
        ValidatingWebhooks["admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations<br/>Verbs: get, list, update, watch"]
    end

    subgraph "API Resources - Node"
        RuntimeClasses["node.k8s.io<br/>RuntimeClasses<br/>Verbs: get, list, watch"]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies["networking.k8s.io<br/>NetworkPolicies<br/>Verbs: create, delete, get,<br/>list, patch, update, watch"]
    end

    %% Bindings
    SA -->|"bound via"| RB
    RB -->|"grants"| CR

    %% Permissions - Core
    CR -->|"permissions"| ConfigMaps
    CR -->|"permissions"| Secrets
    CR -->|"permissions"| Events

    %% Permissions - Trainer CRDs
    CR -->|"permissions"| TrainJobs
    CR -->|"permissions"| TrainJobsStatus
    CR -->|"permissions"| TrainJobsFinalizers
    CR -->|"permissions"| TrainingRuntimes
    CR -->|"permissions"| ClusterTrainingRuntimes

    %% Permissions - JobSet
    CR -->|"permissions"| JobSets

    %% Permissions - Scheduling
    CR -->|"permissions"| PodGroups

    %% Permissions - Admission
    CR -->|"permissions"| ValidatingWebhooks

    %% Permissions - Node
    CR -->|"permissions"| RuntimeClasses

    %% Permissions - Networking
    CR -->|"permissions"| NetworkPolicies

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RB fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style ConfigMaps fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333

    style TrainJobs fill:#7ed321,stroke:#333
    style TrainJobsStatus fill:#7ed321,stroke:#333
    style TrainJobsFinalizers fill:#7ed321,stroke:#333
    style TrainingRuntimes fill:#7ed321,stroke:#333
    style ClusterTrainingRuntimes fill:#7ed321,stroke:#333

    style JobSets fill:#7ed321,stroke:#333
    style PodGroups fill:#7ed321,stroke:#333
    style ValidatingWebhooks fill:#7ed321,stroke:#333
    style RuntimeClasses fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
