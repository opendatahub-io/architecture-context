graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        USER[User Browser<br/>HTTPS/443<br/>TLS 1.2+]
        REG[Container Registries<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets]
    end

    subgraph Ingress["INGRESS (Trust Boundary)"]
        ROUTER[OpenShift Router / Istio Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ edge/reencrypt]
    end

    subgraph AuthLayer["AUTH LAYER (OAuth/Service Mesh)"]
        OAUTH_PROXY[OAuth Proxy<br/>80/TCP HTTP<br/>OAuth Token Validation]
        OAUTH_SRV[OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+]
    end

    subgraph NotebookPods["NOTEBOOK PODS (Trusted)"]
        NB_SVC[Notebook Service<br/>80/TCP ClusterIP<br/>HTTP<br/>OAuth/Istio Auth]

        subgraph NotebookPod["Notebook Pod (StatefulSet)"]
            JUPYTER[Jupyter Server<br/>notebook-port HTTP]
            OAUTH_SIDE[OAuth Proxy Sidecar]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        NB_CTRL[notebook-controller<br/>8081/TCP health<br/>HTTP]
        ODH_CTRL[odh-notebook-controller<br/>8443/TCP webhook HTTPS mTLS<br/>8080/TCP metrics HTTP<br/>8081/TCP health HTTP]
        K8SAPI[Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount]
        DSPA_API[Data Science Pipelines API<br/>8888/TCP HTTP<br/>Internal]
    end

    subgraph Monitoring["MONITORING"]
        PROM[Prometheus<br/>Scrapes metrics<br/>HTTP]
    end

    subgraph Secrets["SECRETS"]
        SEC1[odh-notebook-controller<br/>-webhook-cert<br/>TLS cert<br/>Auto-rotate: Yes/No]
        SEC2[notebook-oauth-config<br/>OAuth client secret<br/>Auto-rotate: No]
        SEC3[ds-pipeline-config<br/>DSPA credentials<br/>Auto-rotate: No]
    end

    subgraph NetworkPolicies["NETWORK POLICIES"]
        NP[NetworkPolicy<br/>Per-notebook isolation]
    end

    %% External to Ingress
    USER -->|HTTPS/443<br/>TLS 1.2+| ROUTER

    %% Ingress to Auth
    ROUTER -->|HTTP/80<br/>Internal| OAUTH_PROXY

    %% Auth Layer
    OAUTH_PROXY -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Protocol| OAUTH_SRV
    OAUTH_PROXY -->|Authorized session<br/>HTTP| NB_SVC

    %% Notebook Service to Pod
    NB_SVC -->|HTTP<br/>notebook-port| JUPYTER

    %% Egress from Notebook
    JUPYTER -.->|Optional egress<br/>Cluster proxy config| External

    %% Control Plane to K8s API
    NB_CTRL -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| K8SAPI
    ODH_CTRL -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| K8SAPI

    %% Control Plane to DSPA
    ODH_CTRL -->|HTTP/8888<br/>Internal| DSPA_API

    %% K8s API to Webhook
    K8SAPI -->|HTTPS/8443<br/>TLS 1.2+<br/>mTLS| ODH_CTRL

    %% Container Image Pull
    NotebookPod -.->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| REG

    %% Monitoring
    PROM -.->|Scrape<br/>HTTP/8080| ODH_CTRL
    PROM -.->|Scrape<br/>HTTP/notebook-port| JUPYTER

    %% Secrets Usage
    ODH_CTRL -.-|Uses| SEC1
    OAUTH_PROXY -.-|Uses| SEC2
    JUPYTER -.-|Uses| SEC3

    %% Network Policies
    NP -.-|Protects| NotebookPod

    %% Styling
    classDef external fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef ingress fill:#fab005,stroke:#f59f00,color:#000
    classDef auth fill:#51cf66,stroke:#37b24d,color:#000
    classDef notebook fill:#74c0fc,stroke:#339af0,color:#000
    classDef control fill:#b197fc,stroke:#9775fa,color:#fff
    classDef monitor fill:#ffd43b,stroke:#fab005,color:#000
    classDef secrets fill:#ffc078,stroke:#ff922b,color:#000

    class USER,REG external
    class ROUTER ingress
    class OAUTH_PROXY,OAUTH_SRV auth
    class NB_SVC,JUPYTER,OAUTH_SIDE notebook
    class NB_CTRL,ODH_CTRL,K8SAPI,DSPA_API control
    class PROM monitor
    class SEC1,SEC2,SEC3 secrets
