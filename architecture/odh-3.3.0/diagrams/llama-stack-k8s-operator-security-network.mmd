graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        CLIENT[Clients<br/>HTTPS/443<br/>TLS 1.2+<br/>API Key]
        HF[Hugging Face Hub<br/>HTTPS/443<br/>TLS 1.3<br/>API Token]
        REG[Container Registry<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secret]
    end

    subgraph Ingress["INGRESS (Trust Boundary - Optional)"]
        ROUTE[OpenShift Route<br/>443/TCP HTTPS<br/>Edge Termination]
    end

    subgraph ServiceLayer["SERVICE LAYER (Internal)"]
        SVC[Llama Stack Service<br/>8000/TCP ClusterIP<br/>HTTP/HTTPS TLS 1.2+<br/>API Key Auth]
    end

    subgraph LlamaStackPod["LLAMA STACK POD (Trusted)"]
        SRV[Llama Stack Server<br/>8000/TCP<br/>/v1/chat/completions<br/>/v1/completions<br/>/health<br/>API Key Auth]

        subgraph Backends["Inference Backends"]
            OLLAMA[Ollama Backend<br/>11434/TCP HTTP<br/>Optional]
            VLLM[vLLM Backend<br/>Internal GPU<br/>Optional]
        end

        PVC[Persistent Volume<br/>Model Storage]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        OP[Llama Stack Operator<br/>8081/TCP health HTTP]
        K8SAPI[Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>ServiceAccount]
    end

    subgraph Secrets["SECRETS"]
        SEC1[hf-token-secret<br/>HF API token<br/>Auto-rotate: No]
        SEC2[llsd-api-key<br/>API key<br/>Auto-rotate: No]
    end

    subgraph NetworkPolicies["NETWORK POLICIES"]
        NP[NetworkPolicy<br/>Per-distribution isolation]
    end

    %% External to Ingress
    CLIENT -->|HTTPS/443<br/>TLS 1.2+<br/>API Key| ROUTE

    %% Ingress to Service
    ROUTE -.->|HTTP/HTTPS<br/>optional| SVC

    %% Direct Service Access (Internal)
    CLIENT -.->|Direct internal<br/>8000/TCP<br/>API Key| SVC

    %% Service to Pod
    SVC -->|Routes to| SRV

    %% Server to Backends
    SRV -.->|HTTP/11434<br/>optional| OLLAMA
    SRV -.->|Internal GPU<br/>optional| VLLM

    %% Storage
    SRV -->|Mounts| PVC

    %% Egress
    SRV -.->|HTTPS/443<br/>TLS 1.3<br/>API Token| HF
    LlamaStackPod -.->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| REG

    %% Control Plane
    OP -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount| K8SAPI
    K8SAPI -->|Creates/Manages| LlamaStackPod
    K8SAPI -->|Creates/Manages| SVC
    K8SAPI -->|Creates optional| ROUTE

    %% Secrets Usage
    SRV -.-|Uses| SEC1
    SRV -.-|Uses| SEC2

    %% Network Policies
    NP -.-|Protects| LlamaStackPod

    %% Styling
    classDef external fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef ingress fill:#fab005,stroke:#f59f00,color:#000
    classDef service fill:#51cf66,stroke:#37b24d,color:#000
    classDef pod fill:#74c0fc,stroke:#339af0,color:#000
    classDef control fill:#b197fc,stroke:#9775fa,color:#fff
    classDef secrets fill:#ffc078,stroke:#ff922b,color:#000

    class CLIENT,HF,REG external
    class ROUTE ingress
    class SVC service
    class SRV,OLLAMA,VLLM,PVC pod
    class OP,K8SAPI control
    class SEC1,SEC2 secrets
