graph TB
    subgraph "MLflow"
        MLFLOW[MLflow<br/>v3.10.1]
    end

    subgraph "External Dependencies"
        PG[PostgreSQL<br/>v12+<br/>Required<br/>Backend Store]
        S3[S3-compatible Storage<br/>Required<br/>Artifact Store]
        K8S[Kubernetes API<br/>v1.24+<br/>Required<br/>Workspace Provider]
        NODE[Node.js<br/>v20<br/>Build-time Only<br/>React Build]
    end

    subgraph "Internal ODH Dependencies"
        S3_INT[S3 Minio/Ceph<br/>Artifact Backend]
        PG_INT[PostgreSQL<br/>Metadata Storage]
        ISTIO[Istio Gateway<br/>HTTPS Exposure]
        MESH[Service Mesh Istio<br/>mTLS Optional]
    end

    subgraph "Monitoring"
        PROM[Prometheus<br/>Metrics Collection]
    end

    %% External Dependencies
    MLFLOW -->|requires| PG
    MLFLOW -->|requires| S3
    MLFLOW -->|requires| K8S
    MLFLOW -.->|build-time only| NODE

    %% Internal ODH Dependencies
    MLFLOW -->|stores artifacts| S3_INT
    MLFLOW -->|stores metadata| PG_INT
    ISTIO -->|exposes| MLFLOW
    MESH -.->|optional encryption| MLFLOW

    %% Monitoring
    MLFLOW -->|exposes metrics| PROM

    %% Styling
    style MLFLOW fill:#326CE5,stroke:#fff,color:#fff
    style PG fill:#336791,stroke:#fff,color:#fff
    style S3 fill:#569A31,stroke:#fff,color:#fff
    style K8S fill:#326CE5,stroke:#fff,color:#fff
    style NODE fill:#68A063,stroke:#fff,color:#fff
    style S3_INT fill:#569A31,stroke:#fff,color:#fff
    style PG_INT fill:#336791,stroke:#fff,color:#fff
    style ISTIO fill:#466BB0,stroke:#fff,color:#fff
    style MESH fill:#466BB0,stroke:#fff,color:#fff
    style PROM fill:#E6522C,stroke:#fff,color:#fff
