graph TB
    subgraph "Service Accounts"
        SA1[kserve-controller-manager]
        SA2[llmisvc-controller-manager]
        SA3[localmodel-controller-manager]
    end

    subgraph "Cluster Roles"
        CR1[kserve-manager-role]
        CR2[llmisvc-manager-role]
        CR3[localmodel-manager-role]
        CR4[leader-election-role]
    end

    subgraph "Role Bindings"
        RB1[kserve-manager-rolebinding<br/>Namespace: kserve]
        RB2[kserve-leader-election-rolebinding<br/>Namespace: kserve]
        RB3[llmisvc-manager-rolebinding<br/>Namespace: kserve]
        RB4[localmodel-manager-rolebinding<br/>Namespace: kserve]
    end

    subgraph "Kubernetes Resources"
        subgraph "Core Resources"
            RES1[ConfigMaps<br/>Events<br/>Services<br/>Namespaces<br/>Pods<br/>Secrets]
        end

        subgraph "Apps & Autoscaling"
            RES2[Deployments<br/>HorizontalPodAutoscalers]
        end

        subgraph "KServe CRDs"
            RES3[InferenceServices<br/>TrainedModels<br/>ServingRuntimes<br/>ClusterServingRuntimes<br/>InferenceGraphs<br/>ClusterStorageContainers]
        end

        subgraph "LLM CRDs"
            RES4[LLMInferenceServices<br/>LLMInferenceServiceConfigs]
        end

        subgraph "Local Model CRDs"
            RES5[LocalModelCaches<br/>LocalModelNodes<br/>LocalModelNodeGroups]
        end

        subgraph "Knative & Istio"
            RES6[Knative Services<br/>Knative Revisions<br/>Istio VirtualServices<br/>Istio DestinationRules<br/>Gateway HTTPRoutes]
        end

        subgraph "Admission"
            RES7[MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations]
        end
    end

    subgraph "Permissions"
        PERM1[create, delete, get,<br/>list, patch, update, watch]
        PERM2[all verbs]
        PERM3[get, list, watch]
        PERM4[get only]
    end

    %% Service Account to Role Bindings
    SA1 -->|bound by| RB1
    SA1 -->|bound by| RB2
    SA2 -->|bound by| RB3
    SA3 -->|bound by| RB4

    %% Role Bindings to Cluster Roles
    RB1 -->|grants| CR1
    RB2 -->|grants| CR4
    RB3 -->|grants| CR2
    RB4 -->|grants| CR3

    %% Cluster Roles to Resources
    CR1 -->|full control| RES1
    CR1 -->|full control| RES2
    CR1 -->|all verbs| RES3
    CR1 -->|full control| RES6
    CR1 -->|full control| RES7

    CR2 -->|all verbs| RES4
    CR3 -->|all verbs| RES5

    %% Permissions Details
    CR1 -.->|configmaps, events, services:<br/>create, delete, get, list,<br/>patch, update, watch| PERM1
    CR1 -.->|namespaces, pods:<br/>get, list, watch| PERM3
    CR1 -.->|secrets:<br/>get| PERM4
    CR1 -.->|InferenceServices, etc.:<br/>all verbs| PERM2

    CR2 -.->|LLMInferenceServices, etc.:<br/>all verbs| PERM2
    CR3 -.->|LocalModelCaches, etc.:<br/>all verbs| PERM2

    %% Styling
    style SA1 fill:#4285F4,stroke:#fff,color:#fff
    style SA2 fill:#4285F4,stroke:#fff,color:#fff
    style SA3 fill:#4285F4,stroke:#fff,color:#fff
    style CR1 fill:#EA4335,stroke:#fff,color:#fff
    style CR2 fill:#EA4335,stroke:#fff,color:#fff
    style CR3 fill:#EA4335,stroke:#fff,color:#fff
    style CR4 fill:#EA4335,stroke:#fff,color:#fff
    style RB1 fill:#FBBC04,stroke:#000,color:#000
    style RB2 fill:#FBBC04,stroke:#000,color:#000
    style RB3 fill:#FBBC04,stroke:#000,color:#000
    style RB4 fill:#FBBC04,stroke:#000,color:#000
    style RES1 fill:#34A853,stroke:#fff,color:#fff
    style RES2 fill:#34A853,stroke:#fff,color:#fff
    style RES3 fill:#34A853,stroke:#fff,color:#fff
    style RES4 fill:#34A853,stroke:#fff,color:#fff
    style RES5 fill:#34A853,stroke:#fff,color:#fff
    style RES6 fill:#34A853,stroke:#fff,color:#fff
    style RES7 fill:#34A853,stroke:#fff,color:#fff
