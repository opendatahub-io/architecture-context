graph TB
    subgraph "Service Accounts"
        SA[mlflow-server SA]
    end

    subgraph "Cluster Roles"
        CR[mlflow-k8s-workspace-provider]
    end

    subgraph "Role Bindings"
        RB[mlflow-k8s-workspace-provider<br/>Cluster-scoped]
    end

    subgraph "Kubernetes Resources"
        subgraph "Core Resources"
            RES1[Namespaces<br/>list, watch]
            RES2[Secrets mlflow-artifact-connection<br/>get]
        end

        subgraph "MLflow CRDs"
            RES3[MLflowConfigs<br/>mlflow.kubeflow.org<br/>list, watch]
        end

        subgraph "Authorization"
            RES4[SubjectAccessReviews<br/>authorization.k8s.io<br/>create]
        end
    end

    subgraph "Custom API Resources (mlflow.kubeflow.org)"
        subgraph "User-Facing Resources"
            CUST1[experiments<br/>get, list, create,<br/>update, delete]
            CUST2[datasets<br/>get, list, create,<br/>update, delete]
            CUST3[registeredmodels<br/>get, list, create,<br/>update, delete<br/>includes prompts]
        end

        subgraph "Gateway Resources"
            CUST4[gatewaysecrets<br/>get, list, create,<br/>update, delete]
            CUST5[gatewaysecrets/use<br/>create]
            CUST6[gatewayendpoints<br/>get, list, create,<br/>update, delete]
            CUST7[gatewayendpoints/use<br/>create]
            CUST8[gatewaymodeldefinitions<br/>get, list, create,<br/>update, delete]
            CUST9[gatewaymodeldefinitions/use<br/>create]
        end

        subgraph "Restricted Resources"
            CUST10[assistants<br/>get, create, update<br/>localhost only]
        end
    end

    subgraph "Permissions"
        PERM1[list, watch]
        PERM2[get]
        PERM3[create for RBAC checks]
        PERM4[get, list, create,<br/>update, delete]
    end

    %% Service Account to Role Binding
    SA -->|bound by| RB

    %% Role Binding to Cluster Role
    RB -->|grants| CR

    %% Cluster Role to Resources
    CR -->|list, watch| RES1
    CR -->|get| RES2
    CR -->|list, watch| RES3
    CR -->|create| RES4

    %% Permissions Details
    CR -.->|namespaces| PERM1
    CR -.->|secrets| PERM2
    CR -.->|mlflowconfigs| PERM1
    CR -.->|subjectaccessreviews| PERM3

    %% Custom API Resources Note
    CUST1 -.->|Users need permissions<br/>in mlflow.kubeflow.org| PERM4
    CUST2 -.->|Users need permissions<br/>in mlflow.kubeflow.org| PERM4
    CUST3 -.->|Users need permissions<br/>in mlflow.kubeflow.org| PERM4

    %% Styling
    style SA fill:#4285F4,stroke:#fff,color:#fff
    style CR fill:#EA4335,stroke:#fff,color:#fff
    style RB fill:#FBBC04,stroke:#000,color:#000
    style RES1 fill:#34A853,stroke:#fff,color:#fff
    style RES2 fill:#34A853,stroke:#fff,color:#fff
    style RES3 fill:#34A853,stroke:#fff,color:#fff
    style RES4 fill:#34A853,stroke:#fff,color:#fff
    style CUST1 fill:#74c0fc,stroke:#339af0,color:#000
    style CUST2 fill:#74c0fc,stroke:#339af0,color:#000
    style CUST3 fill:#74c0fc,stroke:#339af0,color:#000
    style CUST4 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST5 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST6 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST7 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST8 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST9 fill:#b197fc,stroke:#9775fa,color:#000
    style CUST10 fill:#ffc078,stroke:#ff922b,color:#000
