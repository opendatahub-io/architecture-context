graph TD
    subgraph "Service Accounts"
        SA_Operator[feast-operator-controller-manager<br/>Namespace: feast-operator-system]
        SA_Online["{name}-feast-online<br/>Namespace: {user-namespace}"]
        SA_Offline["{name}-feast-offline<br/>Namespace: {user-namespace}"]
        SA_Registry["{name}-feast-registry<br/>Namespace: {user-namespace}"]
        SA_Transform["{name}-feast-transformation<br/>Namespace: {user-namespace}"]
        SA_UI["{name}-feast-ui<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
        CRB_Leader[leader-election-rolebinding]
        CRB_Metrics[metrics-auth-rolebinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Editor[featurestore-editor-role]
        CR_Viewer[featurestore-viewer-role]
        CR_Metrics[metrics-reader]
        CR_Leader[leader-election-role]
        CR_MetricsAuth[metrics-auth-role]
    end

    subgraph "API Resources - feast.dev"
        API_FeatureStore[FeatureStore CR<br/>feast.dev/v1]
        API_FeatureStoreStatus[FeatureStore Status<br/>feast.dev/v1]
        API_FeatureStoreFinalizers[FeatureStore Finalizers<br/>feast.dev/v1]
    end

    subgraph "API Resources - apps"
        API_Deployments[Deployments<br/>apps/v1]
    end

    subgraph "API Resources - core"
        API_Services[Services]
        API_ConfigMaps[ConfigMaps]
        API_PVCs[PersistentVolumeClaims]
        API_ServiceAccounts[ServiceAccounts]
        API_Secrets[Secrets]
        API_Pods[Pods]
        API_PodsExec[Pods/Exec]
        API_Namespaces[Namespaces]
    end

    subgraph "API Resources - rbac"
        API_Roles[Roles]
        API_RoleBindings[RoleBindings]
        API_ClusterRoles[ClusterRoles]
        API_ClusterRoleBindings[ClusterRoleBindings]
        API_SubjectAccessReviews[SubjectAccessReviews]
    end

    subgraph "API Resources - authentication"
        API_TokenReviews[TokenReviews]
    end

    subgraph "API Resources - route"
        API_Routes[Routes<br/>route.openshift.io]
    end

    subgraph "API Resources - batch"
        API_CronJobs[CronJobs]
    end

    subgraph "API Resources - autoscaling"
        API_HPAs[HorizontalPodAutoscalers]
    end

    subgraph "API Resources - policy"
        API_PDBs[PodDisruptionBudgets]
    end

    subgraph "API Resources - apiextensions"
        API_CRDs[CustomResourceDefinitions]
    end

    %% Service Account to ClusterRoleBinding
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Leader
    SA_Operator -->|bound via| CRB_Metrics

    %% ClusterRoleBinding to ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Metrics -->|grants| CR_MetricsAuth

    %% ClusterRole to API Resources - manager-role permissions
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_FeatureStore
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_FeatureStoreStatus
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_FeatureStoreFinalizers
    CR_Manager -->|get, list, watch, create, update, delete| API_Deployments
    CR_Manager -->|get, list, watch, create, update, delete| API_Services
    CR_Manager -->|get, list, watch, create, update, delete| API_ConfigMaps
    CR_Manager -->|get, list, watch, create, update, delete| API_PVCs
    CR_Manager -->|get, list, watch, create, update, delete| API_ServiceAccounts
    CR_Manager -->|get, list, watch| API_Secrets
    CR_Manager -->|get, list, watch| API_Pods
    CR_Manager -->|create| API_PodsExec
    CR_Manager -->|get, list, watch| API_Namespaces
    CR_Manager -->|get, list, watch, create, update, delete| API_Roles
    CR_Manager -->|get, list, watch, create, update, delete| API_RoleBindings
    CR_Manager -->|get, list, watch, create, update, delete| API_ClusterRoles
    CR_Manager -->|get, list, watch, create, update, delete| API_ClusterRoleBindings
    CR_Manager -->|get, list, watch, create, update, delete| API_SubjectAccessReviews
    CR_Manager -->|create| API_TokenReviews
    CR_Manager -->|get, list, watch, create, update, delete| API_Routes
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_CronJobs
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_HPAs
    CR_Manager -->|get, list, watch, create, update, patch, delete| API_PDBs
    CR_Manager -->|get, list| API_CRDs

    %% User ClusterRoles
    CR_Editor -->|get, list, watch, create, update, patch, delete| API_FeatureStore
    CR_Editor -->|get, list, watch, create, update, patch, delete| API_FeatureStoreStatus
    CR_Viewer -->|get, list, watch| API_FeatureStore
    CR_Viewer -->|get, list, watch| API_FeatureStoreStatus

    %% Metrics Reader
    CR_Metrics -->|get, list, watch| API_Pods
    CR_Metrics -->|get, list, watch| API_Services

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Online fill:#82b366,stroke:#333,color:#fff
    style SA_Offline fill:#82b366,stroke:#333,color:#fff
    style SA_Registry fill:#82b366,stroke:#333,color:#fff
    style SA_Transform fill:#82b366,stroke:#333,color:#fff
    style SA_UI fill:#82b366,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_Editor fill:#f5a623,stroke:#333,color:#000
    style CR_Viewer fill:#f5a623,stroke:#333,color:#000
    style CR_Metrics fill:#f5a623,stroke:#333,color:#000
    style CR_Leader fill:#f5a623,stroke:#333,color:#000
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#000

    style CRB_Manager fill:#d79b00,stroke:#333,color:#000
    style CRB_Leader fill:#d79b00,stroke:#333,color:#000
    style CRB_Metrics fill:#d79b00,stroke:#333,color:#000

    style API_FeatureStore fill:#7ed321,stroke:#333,color:#000
    style API_FeatureStoreStatus fill:#7ed321,stroke:#333,color:#000
    style API_FeatureStoreFinalizers fill:#7ed321,stroke:#333,color:#000
    style API_Deployments fill:#e1d5e7,stroke:#333,color:#000
    style API_Services fill:#e1d5e7,stroke:#333,color:#000
    style API_ConfigMaps fill:#e1d5e7,stroke:#333,color:#000
    style API_PVCs fill:#e1d5e7,stroke:#333,color:#000
    style API_ServiceAccounts fill:#e1d5e7,stroke:#333,color:#000
    style API_Secrets fill:#e1d5e7,stroke:#333,color:#000
    style API_Pods fill:#e1d5e7,stroke:#333,color:#000
    style API_PodsExec fill:#e1d5e7,stroke:#333,color:#000
    style API_Namespaces fill:#e1d5e7,stroke:#333,color:#000
    style API_Roles fill:#e1d5e7,stroke:#333,color:#000
    style API_RoleBindings fill:#e1d5e7,stroke:#333,color:#000
    style API_ClusterRoles fill:#e1d5e7,stroke:#333,color:#000
    style API_ClusterRoleBindings fill:#e1d5e7,stroke:#333,color:#000
    style API_SubjectAccessReviews fill:#e1d5e7,stroke:#333,color:#000
    style API_TokenReviews fill:#e1d5e7,stroke:#333,color:#000
    style API_Routes fill:#e1d5e7,stroke:#333,color:#000
    style API_CronJobs fill:#e1d5e7,stroke:#333,color:#000
    style API_HPAs fill:#e1d5e7,stroke:#333,color:#000
    style API_PDBs fill:#e1d5e7,stroke:#333,color:#000
    style API_CRDs fill:#e1d5e7,stroke:#333,color:#000
