graph TB
    subgraph "Kubeflow Trainer v2 Component"
        Controller[Trainer Controller<br/>Go Controller]
        TrainJobCtrl[TrainJob Controller<br/>Reconciler]
        RuntimeCtrl[TrainingRuntime Controller<br/>Reconciler]
        ClusterRuntimeCtrl[ClusterTrainingRuntime Controller<br/>Reconciler]
        Webhook[Webhook Server<br/>9443/TCP HTTPS TLS 1.2+]
        SDK[Kubeflow SDK<br/>Python Client]

        Controller --> TrainJobCtrl
        Controller --> RuntimeCtrl
        Controller --> ClusterRuntimeCtrl
        Controller --> Webhook
    end

    subgraph "Custom Resources"
        TrainJobCR[TrainJob CR<br/>trainer.kubeflow.org/v1alpha1]
        RuntimeCR[TrainingRuntime CR<br/>Namespaced]
        ClusterRuntimeCR[ClusterTrainingRuntime CR<br/>Cluster-wide]
    end

    subgraph "External Dependencies"
        JobSet[JobSet 0.7+<br/>Distributed Worker Pods]
        Volcano[Volcano<br/>Gang Scheduling]
        Kueue[Kueue<br/>Job Queuing]
        PyTorch[PyTorch 1.x/2.x<br/>Training Runtime]
        JAX[JAX<br/>High-Performance Training]
        TensorFlow[TensorFlow 2.x<br/>Training Runtime]
        HuggingFace[HuggingFace Transformers 4.x<br/>LLM Fine-tuning]
        DeepSpeed[DeepSpeed<br/>Memory-Efficient Training]
        Megatron[Megatron-LM<br/>Large-Scale LLM Training]
    end

    subgraph "Internal ODH Integration"
        Notebooks[Notebooks<br/>Job Submission via SDK]
        Pipelines[Data Science Pipelines<br/>Pipeline Steps]
        ModelRegistry[Model Registry<br/>Register Fine-tuned Models]
        S3[S3 Storage<br/>Datasets & Checkpoints]
        Ray[Ray<br/>Hybrid Workloads]
    end

    %% User interactions
    User[User/Data Scientist] -->|creates via kubectl/SDK| TrainJobCR
    SDK -->|submits jobs| TrainJobCR
    Notebooks -->|SDK| SDK

    %% CR watched by controllers
    TrainJobCR -->|watched by| TrainJobCtrl
    RuntimeCR -->|watched by| RuntimeCtrl
    ClusterRuntimeCR -->|watched by| ClusterRuntimeCtrl

    %% Controller creates JobSets
    TrainJobCtrl -->|creates| JobSet
    TrainJobCtrl -->|creates| Volcano
    TrainJobCtrl -->|integrates| Kueue

    %% Training jobs use frameworks
    JobSet -.->|runtime| PyTorch
    JobSet -.->|runtime| JAX
    JobSet -.->|runtime| TensorFlow
    JobSet -.->|uses| HuggingFace
    JobSet -.->|uses| DeepSpeed
    JobSet -.->|uses| Megatron

    %% ODH integrations
    TrainJobCtrl -->|registers models| ModelRegistry
    JobSet -->|reads/writes| S3
    Pipelines -->|executes| TrainJobCR
    TrainJobCtrl -.->|hybrid| Ray

    %% Webhook validation
    TrainJobCR -->|validated by| Webhook

