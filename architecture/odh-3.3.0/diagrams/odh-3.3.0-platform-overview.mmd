graph TB
    subgraph External["Users & External Services"]
        User[Data Scientist]
        SecUser[Security Admin]
        S3[S3 Storage<br/>HTTPS/443]
        PyPI[PyPI Registry<br/>HTTPS/443]
        HF[HuggingFace Hub<br/>HTTPS/443]
        ContainerReg[Container Registry<br/>HTTPS/443]
    end

    subgraph ControlPlane["Control Plane (opendatahub namespace)"]
        ODHOp[opendatahub-operator<br/>v3.3.0<br/>Central Orchestrator]
        Dashboard[odh-dashboard<br/>v3.4.0EA1<br/>Web UI]
    end

    subgraph ModelServing["Model Serving Layer"]
        KServe[kserve<br/>v0.17.0-rc0<br/>Multi-framework Inference]
        ModelCtrl[odh-model-controller<br/>OpenShift Integrations]
        KServe -.extended by.-> ModelCtrl
    end

    subgraph ModelMgmt["Model Management"]
        ModelReg[model-registry-operator<br/>Model Versioning]
        MLflow[mlflow-operator<br/>Experiment Tracking]
    end

    subgraph Development["Development Workbenches"]
        NBController[kubeflow<br/>notebook-controller]
        NBImages[notebooks<br/>Container Images<br/>Jupyter/VSCode/RStudio]
        NBController -->|deploys| NBImages
    end

    subgraph Training["Training & Distributed Computing"]
        TrainOp[training-operator<br/>PyTorch/TF/MPI/JAX/XGBoost]
        Trainer[trainer v2<br/>LLM Fine-tuning]
        Ray[kuberay<br/>v1.4.4<br/>Distributed Computing]
        Spark[spark-operator<br/>Big Data Processing]
    end

    subgraph Workflows["ML Workflows & Data"]
        Pipelines[data-science-pipelines-operator<br/>Kubeflow Pipelines/Argo]
        Feast[feast<br/>v0.45.0<br/>Feature Store]
    end

    subgraph Governance["AI Governance"]
        TrustyAI[trustyai-service-operator<br/>v1.39.0<br/>Explainability/Fairness/LLM Eval]
    end

    subgraph LLMTools["LLM Tools"]
        LlamaStack[llama-stack-k8s-operator<br/>v0.2.24]
    end

    %% User interactions
    User -->|accesses| Dashboard
    SecUser -->|manages| ODHOp

    %% Control plane orchestration
    ODHOp -->|manages| KServe
    ODHOp -->|manages| ModelReg
    ODHOp -->|manages| MLflow
    ODHOp -->|manages| NBController
    ODHOp -->|manages| TrainOp
    ODHOp -->|manages| Trainer
    ODHOp -->|manages| Ray
    ODHOp -->|manages| Spark
    ODHOp -->|manages| Pipelines
    ODHOp -->|manages| Feast
    ODHOp -->|manages| TrustyAI
    ODHOp -->|manages| LlamaStack

    %% Dashboard integrations
    Dashboard -->|creates CRs| NBController
    Dashboard -->|creates CRs| KServe
    Dashboard -->|creates CRs| ModelReg
    Dashboard -->|creates CRs| MLflow

    %% Notebook integrations
    NBImages -->|logs to| MLflow
    NBImages -->|reads from| Feast
    NBImages -->|registers to| ModelReg
    NBImages -->|deploys to| KServe
    NBImages -->|submits to| Pipelines

    %% Model serving integrations
    KServe -->|links to| ModelReg
    KServe -->|monitored by| TrustyAI
    ModelCtrl -->|creates| KServe

    %% Pipeline integrations
    Pipelines -->|orchestrates| TrainOp
    Pipelines -->|orchestrates| Trainer
    Pipelines -->|orchestrates| KServe
    Pipelines -->|tracks in| ModelReg

    %% Training integrations
    TrainOp -->|logs to| MLflow
    Trainer -->|logs to| MLflow
    Trainer -->|registers to| ModelReg

    %% TrustyAI integrations
    TrustyAI -->|monitors| KServe
    TrustyAI -->|logs to| MLflow

    %% External dependencies
    KServe -->|artifacts| S3
    NBImages -->|artifacts| S3
    Pipelines -->|artifacts| S3
    NBImages -->|packages| PyPI
    TrainOp -->|packages| PyPI
    TrustyAI -->|models| HF
    NBImages -->|models| HF
    ODHOp -->|images| ContainerReg

    %% Styling
    classDef controlPlane fill:#4a90e2,stroke:#2e5c8a,stroke-width:3px,color:#fff
    classDef serving fill:#7ed321,stroke:#5a9c18,stroke-width:2px,color:#000
    classDef mgmt fill:#f5a623,stroke:#b87e1a,stroke-width:2px,color:#000
    classDef dev fill:#bd10e0,stroke:#8b0ca6,stroke-width:2px,color:#fff
    classDef training fill:#50e3c2,stroke:#3baa92,stroke-width:2px,color:#000
    classDef workflows fill:#b8e986,stroke:#8ab366,stroke-width:2px,color:#000
    classDef governance fill:#f8e71c,stroke:#b8ac15,stroke-width:2px,color:#000
    classDef llm fill:#ff6b6b,stroke:#cc5555,stroke-width:2px,color:#fff
    classDef external fill:#e0e0e0,stroke:#999,stroke-width:1px,color:#000

    class ODHOp,Dashboard controlPlane
    class KServe,ModelCtrl serving
    class ModelReg,MLflow mgmt
    class NBController,NBImages dev
    class TrainOp,Trainer,Ray,Spark training
    class Pipelines,Feast workflows
    class TrustyAI governance
    class LlamaStack llm
    class User,SecUser,S3,PyPI,HF,ContainerReg external
