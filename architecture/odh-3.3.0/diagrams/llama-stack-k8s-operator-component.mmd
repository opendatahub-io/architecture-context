graph TB
    subgraph "Llama Stack Operator"
        CTRL[Llama Stack Operator Controller<br/>Reconciles LlamaStackDistribution]

        CRD[LlamaStackDistribution v1alpha1<br/>Server Deployment Config]
    end

    subgraph "Llama Stack Server"
        SRV[Llama Stack Server<br/>8000/TCP HTTP<br/>TLS 1.2+ API Key Auth]

        subgraph "Inference Backends (Optional)"
            OLLAMA[Ollama Backend<br/>Lightweight Inference]
            VLLM[vLLM Backend<br/>GPU-Accelerated Inference]
        end
    end

    subgraph "Infrastructure"
        DEP[Deployment<br/>Llama Stack Pod]
        SVC[Service ClusterIP<br/>8000/TCP]
        ROUTE[OpenShift Route<br/>443/TCP HTTPS<br/>optional]
        PVC[PersistentVolumeClaim<br/>Model Storage]
        HPA[HorizontalPodAutoscaler<br/>optional]
        NP[NetworkPolicy<br/>Network Isolation]
    end

    subgraph "External Dependencies"
        K8S[Kubernetes 1.24+]
        HF[Hugging Face Hub<br/>Model Downloads]
        STORAGE[Persistent Storage<br/>PVC]
    end

    subgraph "Internal ODH Dependencies"
        ODH[ODH Operator<br/>DataScienceCluster]
        KSERVE[KServe<br/>Alternative LLM Serving]
        MR[Model Registry<br/>Model Tracking Future]
    end

    %% Controller Relationships
    CTRL -->|reconciles| CRD
    CTRL -->|creates| DEP
    CTRL -->|creates| SVC
    CTRL -->|creates optional| ROUTE
    CTRL -->|creates| PVC
    CTRL -->|creates optional| HPA
    CTRL -->|creates| NP

    %% Deployment to Server
    DEP -->|runs| SRV
    SRV -.->|uses optional| OLLAMA
    SRV -.->|uses optional| VLLM

    %% Service Routing
    SVC -->|routes to| SRV
    ROUTE -.->|exposes optional| SVC

    %% Storage
    DEP -->|mounts| PVC

    %% External Dependencies
    CTRL -->|uses| K8S
    SRV -->|downloads models| HF
    PVC -->|backed by| STORAGE

    %% Internal ODH Dependencies
    ODH -->|manages| CTRL
    KSERVE -.->|alternative to| SRV
    MR -.->|future integration| SRV

    style CTRL fill:#326CE5,stroke:#fff,color:#fff
    style SRV fill:#34A853,stroke:#fff,color:#fff
    style OLLAMA fill:#4285F4,stroke:#fff,color:#fff
    style VLLM fill:#4285F4,stroke:#fff,color:#fff
