graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["External User<br/>Browser"]
        APIClient["External Client<br/>API Requests"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → varied<br/>TLS 1.2+ Reencrypt<br/>OAuth Proxy"]
        Gateway["Istio Gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.3<br/>RequestAuthentication"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS PERMISSIVE/STRICT)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub (Control Plane)"]
            direction TB
            ODHOp["ODH Operator<br/>SA: opendatahub-operator-controller-manager<br/>Manages: DataScienceCluster"]
            Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>8080/TCP HTTP<br/>OAuth Proxy: 8443/TCP"]
            KServe["KServe Controller<br/>SA: kserve-controller-manager<br/>Webhook: 9443/TCP HTTPS"]
            ModelRegOp["Model Registry Operator<br/>SA: model-registry-operator-sa"]
            TrainingOp["Training Operator<br/>SA: training-operator<br/>Webhook: 9443/TCP HTTPS"]
            DSPOp["DSP Operator<br/>SA: data-science-pipelines-operator"]

            ODHOp -->|manages| Dashboard
            ODHOp -->|manages| KServe
            ODHOp -->|manages| ModelRegOp
            ODHOp -->|manages| TrainingOp
            ODHOp -->|manages| DSPOp
        end

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>8012/TCP HTTP<br/>mTLS sidecar"]
            Autoscaler["Knative Autoscaler<br/>SA: autoscaler<br/>Scales: 0-N predictors"]
        end

        subgraph NS_User["Namespace: {user-namespace} (Workloads)"]
            direction TB
            Notebook["Jupyter Notebook Pod<br/>SA: {notebook-name}-sa<br/>8888/TCP HTTP<br/>GPU: nvidia.com/gpu"]
            ModelReg["Model Registry Service<br/>8080/TCP REST<br/>OAuth Proxy: 8443/TCP<br/>Backend: PostgreSQL 5432/TCP"]
            MLflow["MLflow Server<br/>5000/TCP HTTP<br/>OAuth Proxy: 8443/TCP<br/>Backend: PostgreSQL 5432/TCP"]
            Feast["Feast Feature Store<br/>6566/TCP gRPC<br/>Redis: 6379/TCP"]
            Predictor["KServe Predictor Pod<br/>SA: {infer-service-name}-sa<br/>8080/TCP HTTP<br/>mTLS sidecar<br/>GPU: nvidia.com/gpu"]
            TrustyAI["TrustyAI Service<br/>8080/TCP gRPC<br/>Monitoring: Fairness/Drift"]
            TrainingPods["PyTorchJob Training Pods<br/>SA: {pytorchjob-name}-sa<br/>master + worker (N)<br/>GPU: nvidia.com/gpu<br/>NCCL: gRPC"]

            Notebook -->|REST API| ModelReg
            Notebook -->|REST API| MLflow
            Notebook -->|gRPC| Feast
            Predictor -->|gRPC metrics| TrustyAI
            Predictor -->|gRPC features| Feast
        end

        subgraph NS_Istio["Namespace: istio-system"]
            Istiod["Istiod<br/>SA: istiod<br/>15012/TCP xDS gRPC<br/>mTLS cert mgmt (SPIFFE)<br/>PeerAuthentication<br/>AuthorizationPolicy"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM (IRSA)<br/>Purpose: Models, data, artifacts"]
        PostgreSQL["PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ (sslmode=require)<br/>Auth: User/pass (Secret)<br/>Databases: model_registry, mlflow, dspa"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN<br/>Purpose: LLM downloads"]
        ContainerReg["Container Registry<br/>quay.io, gcr.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Image pull secrets<br/>Purpose: Image pulls"]
        K8sAPI["Kubernetes API<br/>api.{cluster}:6443<br/>HTTPS TLS 1.2+<br/>Auth: ServiceAccount tokens<br/>Purpose: Resource mgmt"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer| Router
    APIClient -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Gateway

    %% Ingress to Service Mesh
    Router -->|HTTPS/8080<br/>Dashboard| Dashboard
    Router -->|HTTPS/8443<br/>OAuth| ModelReg
    Router -->|HTTPS/8443<br/>OAuth| MLflow
    Gateway -->|HTTP/8012<br/>mTLS STRICT<br/>Service Identity| Activator

    %% Service Mesh Internal
    Dashboard -->|K8s API| KServe
    Dashboard -->|K8s API| ModelRegOp
    Activator -->|HTTP/8080<br/>mTLS<br/>Service Identity| Predictor
    KServe -->|Manages| Predictor

    %% External Service Access
    Notebook -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    TrainingPods -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    ModelReg -->|PostgreSQL/5432<br/>TLS 1.2+<br/>User/pass| PostgreSQL
    MLflow -->|PostgreSQL/5432<br/>TLS 1.2+<br/>User/pass| PostgreSQL
    Notebook -->|HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN| HuggingFace
    TrustyAI -->|HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN| HuggingFace
    ODHOp -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    KServe -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    TrainingOp -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Istio Service Mesh Control
    Istiod -.->|xDS config<br/>mTLS certs| Predictor
    Istiod -.->|xDS config<br/>mTLS certs| Activator
    Istiod -.->|xDS config<br/>mTLS certs| Notebook

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef controlplane fill:#cce5ff,stroke:#0066cc,stroke-width:2px,color:#333

    class User,APIClient external
    class Router,Gateway ingress
    class ODHOp,Dashboard,KServe,ModelRegOp,TrainingOp,DSPOp,Activator,Autoscaler,Notebook,ModelReg,MLflow,Feast,Predictor,TrustyAI,TrainingPods servicemesh
    class Istiod controlplane
    class S3,PostgreSQL,HuggingFace,ContainerReg,K8sAPI externalservice
