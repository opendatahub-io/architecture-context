graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        USER[Users/Clients<br/>HTTPS/443<br/>TLS 1.2+]
        S3[S3 Storage<br/>HTTPS/443<br/>TLS 1.2+<br/>AWS IAM]
        REG[Container Registry<br/>HTTPS/443<br/>TLS 1.2+<br/>Token]
        PYPI[PyPI<br/>HTTPS/443<br/>TLS 1.2+]
    end

    subgraph Ingress["INGRESS (Trust Boundary)"]
        ROUTE[OpenShift Route<br/>443/TCP HTTPS<br/>Edge Termination]
    end

    subgraph RayServices["RAY SERVICES (Internal)"]
        HEAD_SVC[ray-head-svc ClusterIP<br/>8265/TCP Dashboard<br/>6379/TCP GCS<br/>8000/TCP Serve<br/>10001/TCP gRPC<br/>TLS 1.2+ optional mTLS]
        METRICS_SVC[ray-operator-metrics<br/>8080/TCP HTTP]
    end

    subgraph RayCluster["RAY CLUSTER (Trusted - mTLS optional)"]
        subgraph HeadPod["Ray Head Pod"]
            DASHBOARD[Ray Dashboard<br/>8265/TCP HTTP<br/>TLS 1.2+ opt]
            GCS[GCS<br/>6379/TCP gRPC<br/>mTLS optional]
            SERVE[Ray Serve<br/>8000/TCP HTTP<br/>TLS 1.2+ opt]
        end

        subgraph WorkerPods["Ray Worker Pods"]
            RAYLET[Raylet<br/>6379/TCP gRPC<br/>mTLS optional]
            OBJSTORE[Object Store<br/>2384/TCP gRPC<br/>mTLS optional]
        end

        REDIS_EXT[External Redis Optional<br/>6379/TCP TCP<br/>TLS 1.2+ optional<br/>Password Auth]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        OP[KubeRay Operator<br/>8080/TCP metrics HTTP]
        K8SAPI[Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount]
    end

    subgraph Monitoring["MONITORING"]
        PROM[Prometheus<br/>Scrapes metrics<br/>HTTP]
    end

    subgraph Secrets["SECRETS"]
        SEC1[ray-mtls-ca-secret<br/>CA cert<br/>Auto-rotate: Yes]
        SEC2[ray-mtls-cert-secret<br/>mTLS certs<br/>Auto-rotate: Yes]
        SEC3[ray-redis-password<br/>Redis password<br/>Auto-rotate: No]
        SEC4[aws-s3-credentials<br/>S3 credentials<br/>Auto-rotate: No]
    end

    subgraph NetworkPolicies["NETWORK POLICIES"]
        NP[NetworkPolicy<br/>Per-cluster isolation]
    end

    %% External to Ingress
    USER -->|HTTPS/443<br/>TLS 1.2+| ROUTE

    %% Ingress to Services
    ROUTE -->|HTTP/HTTPS<br/>TLS 1.2+ opt| HEAD_SVC

    %% Services to Ray Cluster
    HEAD_SVC -->|Routes to| DASHBOARD
    HEAD_SVC -->|Routes to| GCS
    HEAD_SVC -->|Routes to| SERVE

    %% Ray Cluster Internal
    RAYLET -->|gRPC/6379<br/>mTLS optional| GCS
    RAYLET <-->|gRPC/2384<br/>mTLS optional| OBJSTORE
    GCS -.->|TCP/6379<br/>TLS 1.2+ opt<br/>Password| REDIS_EXT

    %% Egress from Workers
    RAYLET -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    HeadPod -.->|HTTPS/443<br/>TLS 1.2+<br/>Token| REG
    WorkerPods -.->|HTTPS/443<br/>TLS 1.2+<br/>Token| REG
    HeadPod -.->|HTTPS/443<br/>TLS 1.2+| PYPI

    %% Control Plane
    OP -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| K8SAPI
    K8SAPI -->|Creates/Manages| HeadPod
    K8SAPI -->|Creates/Manages| WorkerPods

    %% Monitoring
    PROM -.->|Scrape<br/>HTTP/8080| OP
    PROM -.->|Scrape<br/>HTTP/8265| DASHBOARD

    %% Secrets Usage
    OP -.-|Manages| SEC1
    OP -.-|Manages| SEC2
    GCS -.-|Uses| SEC3
    RAYLET -.-|Uses| SEC4
    HeadPod -.-|Uses| SEC1
    HeadPod -.-|Uses| SEC2
    WorkerPods -.-|Uses| SEC1
    WorkerPods -.-|Uses| SEC2

    %% Network Policies
    NP -.-|Protects| RayCluster

    %% Styling
    classDef external fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef ingress fill:#fab005,stroke:#f59f00,color:#000
    classDef service fill:#51cf66,stroke:#37b24d,color:#000
    classDef cluster fill:#74c0fc,stroke:#339af0,color:#000
    classDef control fill:#b197fc,stroke:#9775fa,color:#fff
    classDef monitor fill:#ffd43b,stroke:#fab005,color:#000
    classDef secrets fill:#ffc078,stroke:#ff922b,color:#000

    class USER,S3,REG,PYPI external
    class ROUTE ingress
    class HEAD_SVC,METRICS_SVC service
    class DASHBOARD,GCS,SERVE,RAYLET,OBJSTORE,REDIS_EXT cluster
    class OP,K8SAPI control
    class PROM monitor
    class SEC1,SEC2,SEC3,SEC4 secrets
