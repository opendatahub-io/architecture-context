graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>RoleBinding → kube-system]
        CRB3[odh-dashboard-cluster-monitoring-view<br/>RoleBinding → openshift-monitoring]
    end

    subgraph "ClusterRole"
        CR[odh-dashboard<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        ConfigMaps[core/ConfigMaps<br/>create,delete,get,list,patch,update,watch]
        PVCs[core/PersistentVolumeClaims<br/>create,delete,get,list,patch,update,watch]
        Secrets[core/Secrets<br/>create,delete,get,list,patch,update,watch]
        Pods[core/Pods<br/>get,list,watch]
        Services[core/Services<br/>get,list,watch]
        Namespaces[core/Namespaces<br/>patch]
        Nodes[core/Nodes<br/>get,list]
    end

    subgraph "API Resources - RBAC"
        RoleBindings[rbac.authorization.k8s.io/RoleBindings<br/>list,get,create,patch,delete]
        ClusterRoleBindings[rbac.authorization.k8s.io/ClusterRoleBindings<br/>list,get,create,patch,delete]
        Roles[rbac.authorization.k8s.io/Roles<br/>list,get,create,patch,delete]
    end

    subgraph "API Resources - Storage"
        StorageClasses[storage.k8s.io/StorageClasses<br/>update,patch]
    end

    subgraph "API Resources - ODH/RHOAI"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceClusters<br/>list,watch,get]
        DSCInit[dscinitialization.opendatahub.io<br/>DSCInitializations<br/>list,watch,get]
        ModelRegistries[modelregistry.opendatahub.io<br/>ModelRegistries<br/>get,list,watch,create,update,patch,delete]
        FeatureStores[feast.dev/FeatureStores<br/>get,list,watch]
        Guardrails[trustyai.opendatahub.io<br/>GuardrailsOrchestrators<br/>get,list,watch]
        LlamaStack[llamastack.io<br/>LlamaStackDistributions<br/>get,list,watch]
    end

    subgraph "API Resources - Kubeflow"
        NotebooksCR[kubeflow.org/Notebooks<br/>get,list,watch,create,update,patch,delete]
    end

    subgraph "API Resources - KServe"
        InferenceServices[serving.kserve.io<br/>InferenceServices<br/>get,list,watch]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io/Routes<br/>get,list,watch]
        ImageStreams[image.openshift.io/ImageStreams/layers<br/>get]
        ClusterVersions[config.openshift.io<br/>ClusterVersions,Ingresses<br/>get,watch,list]
        Users[user.openshift.io<br/>Groups,Users<br/>get,list,watch]
        CSVs[operators.coreos.com<br/>ClusterServiceVersions,Subscriptions<br/>get,list,watch]
    end

    subgraph "API Resources - Auth"
        TokenReviews[authentication.k8s.io/TokenReviews<br/>create]
        SubjectAccessReviews[authorization.k8s.io/SubjectAccessReviews<br/>create]
    end

    subgraph "Special Roles"
        AuthDelegator[ClusterRole: system:auth-delegator]
        MonitoringView[ClusterRole: cluster-monitoring-view]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% ClusterRole grants
    CRB1 -->|grants| CR
    CRB2 -->|grants| AuthDelegator
    CRB3 -->|grants| MonitoringView

    %% Core permissions
    CR -->|permissions| ConfigMaps
    CR -->|permissions| PVCs
    CR -->|permissions| Secrets
    CR -->|permissions| Pods
    CR -->|permissions| Services
    CR -->|permissions| Namespaces
    CR -->|permissions| Nodes

    %% RBAC permissions
    CR -->|permissions| RoleBindings
    CR -->|permissions| ClusterRoleBindings
    CR -->|permissions| Roles

    %% Storage permissions
    CR -->|permissions| StorageClasses

    %% ODH/RHOAI permissions
    CR -->|permissions| DSC
    CR -->|permissions| DSCInit
    CR -->|permissions| ModelRegistries
    CR -->|permissions| FeatureStores
    CR -->|permissions| Guardrails
    CR -->|permissions| LlamaStack

    %% Kubeflow permissions
    CR -->|permissions| NotebooksCR

    %% KServe permissions
    CR -->|permissions| InferenceServices

    %% OpenShift permissions
    CR -->|permissions| Routes
    CR -->|permissions| ImageStreams
    CR -->|permissions| ClusterVersions
    CR -->|permissions| Users
    CR -->|permissions| CSVs

    %% Auth permissions
    CR -->|permissions| TokenReviews
    CR -->|permissions| SubjectAccessReviews

