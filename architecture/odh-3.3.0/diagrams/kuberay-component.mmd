graph TB
    subgraph "KubeRay Operator"
        subgraph "Controllers"
            OP[Ray Operator<br/>Main Controller]
            RC[RayCluster Controller<br/>Cluster Lifecycle]
            RJ[RayJob Controller<br/>Batch Jobs]
            RS[RayService Controller<br/>Zero-Downtime Serving]
            AUTH[Authentication Controller<br/>ServiceAccounts & RBAC]
            NET[NetworkPolicy Controller<br/>Network Isolation]
            MTLS[mTLS Controller<br/>Certificate Management]
        end

        subgraph "CRDs"
            RC_CRD[RayCluster v1<br/>Cluster Definition]
            RJ_CRD[RayJob v1<br/>Batch Job Definition]
            RS_CRD[RayService v1<br/>Serving Definition]
        end
    end

    subgraph "Ray Cluster Infrastructure"
        subgraph "Ray Head Pod"
            HEAD[Ray Head Node<br/>GCS + Dashboard]
            DASHBOARD[Ray Dashboard<br/>8265/TCP]
            GCS[Global Control Store<br/>6379/TCP gRPC]
        end

        subgraph "Ray Worker Pods"
            WORKER1[Ray Worker 1<br/>Raylet + Object Store]
            WORKER2[Ray Worker 2<br/>Raylet + Object Store]
            WORKERX[Ray Worker N<br/>Autoscaled]
        end

        subgraph "Services"
            HEAD_SVC[ray-head-svc<br/>ClusterIP<br/>8265, 6379, 8000, 10001]
            METRICS_SVC[ray-operator-metrics<br/>ClusterIP 8080]
        end
    end

    subgraph "External Dependencies"
        RAY[Ray 2.x Runtime]
        REDIS[Redis 6.x+<br/>External GCS Optional]
        PROM[Prometheus 2.x]
        KUEUE[Kueue 0.5+<br/>Job Queuing Optional]
        VOLCANO[Volcano 1.8+<br/>Batch Scheduling Optional]
    end

    subgraph "Internal ODH Dependencies"
        DASH[ODH Dashboard<br/>UI Integration]
        NB[Notebooks<br/>Cluster Access]
        DSP[Data Science Pipelines<br/>Job Submission]
        MR[Model Registry<br/>Model Registration]
    end

    subgraph "Storage & Registry"
        S3[S3 Storage<br/>Datasets & Checkpoints]
        REGISTRY[Container Registry<br/>Ray Images]
        PYPI[PyPI<br/>Python Dependencies]
    end

    %% Controller Reconciliation
    OP -->|reconciles| RC_CRD
    OP -->|reconciles| RJ_CRD
    OP -->|reconciles| RS_CRD

    RC -->|manages| RC_CRD
    RJ -->|manages| RJ_CRD
    RS -->|manages| RS_CRD

    RC -->|creates| HEAD
    RC -->|creates| WORKER1
    RC -->|creates| WORKER2
    RC -->|autoscales| WORKERX
    RC -->|creates| HEAD_SVC

    AUTH -->|creates| HEAD
    AUTH -->|creates| WORKER1
    NET -->|creates network policies| HEAD
    MTLS -->|provisions certs| HEAD
    MTLS -->|provisions certs| WORKER1

    %% Ray Cluster Communication
    HEAD -->|contains| DASHBOARD
    HEAD -->|contains| GCS
    WORKER1 -->|connects to| GCS
    WORKER2 -->|connects to| GCS
    WORKERX -->|connects to| GCS

    HEAD_SVC -->|routes to| HEAD
    METRICS_SVC -->|exposes| OP

    %% External Dependencies
    HEAD -->|runs| RAY
    WORKER1 -->|runs| RAY
    HEAD -.->|optional persistence| REDIS
    OP -->|exposes metrics| PROM
    OP -.->|optional integration| KUEUE
    OP -.->|optional integration| VOLCANO

    %% Internal ODH Dependencies
    DASH -->|manages| RC_CRD
    NB -->|submits jobs to| DASHBOARD
    DSP -->|submits jobs to| DASHBOARD
    MR -->|registers models from| WORKER1

    %% Storage & Registry
    WORKER1 -->|reads/writes| S3
    WORKER2 -->|reads/writes| S3
    HEAD -->|pulls images from| REGISTRY
    WORKER1 -->|pulls images from| REGISTRY
    HEAD -->|installs deps from| PYPI

    style OP fill:#326CE5,stroke:#fff,color:#fff
    style RC fill:#4285F4,stroke:#fff,color:#fff
    style RJ fill:#4285F4,stroke:#fff,color:#fff
    style RS fill:#4285F4,stroke:#fff,color:#fff
    style HEAD fill:#34A853,stroke:#fff,color:#fff
    style WORKER1 fill:#34A853,stroke:#fff,color:#fff
    style WORKER2 fill:#34A853,stroke:#fff,color:#fff
