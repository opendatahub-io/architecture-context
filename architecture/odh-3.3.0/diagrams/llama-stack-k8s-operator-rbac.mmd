graph TB
    subgraph "Service Accounts"
        SA[controller-manager]
    end

    subgraph "Cluster Roles"
        CR1[manager-role]
        CR2[llsd-editor-role]
        CR3[llsd-viewer-role]
        CR4[leader-election-role]
    end

    subgraph "Role Bindings"
        RB1[manager-rolebinding<br/>Namespace: llama-stack-operator-system]
        RB2[leader-election-rolebinding<br/>Namespace: llama-stack-operator-system]
    end

    subgraph "Kubernetes Resources"
        subgraph "Core Resources"
            RES1[ConfigMaps<br/>PersistentVolumeClaims<br/>ServiceAccounts<br/>Services]
        end

        subgraph "Apps & Autoscaling"
            RES2[Deployments<br/>HorizontalPodAutoscalers]
        end

        subgraph "Llama Stack CRDs"
            RES3[LlamaStackDistributions<br/>LlamaStackDistributions/finalizers<br/>LlamaStackDistributions/status]
        end

        subgraph "Networking"
            RES4[NetworkPolicies]
        end

        subgraph "OpenShift"
            RES5[Routes]
        end

        subgraph "Leader Election"
            RES6[ConfigMaps<br/>Leases]
        end
    end

    subgraph "Permissions"
        PERM1[create, delete, get,<br/>list, patch, update, watch]
        PERM2[create, get,<br/>list, patch, update, watch]
        PERM3[create, get, list, watch]
        PERM4[get, patch, update]
        PERM5[get, list, watch]
    end

    %% Service Account to Role Bindings
    SA -->|bound by| RB1
    SA -->|bound by| RB2

    %% Role Bindings to Cluster Roles
    RB1 -->|grants| CR1
    RB2 -->|grants| CR4

    %% Cluster Roles to Resources
    CR1 -->|full control| RES1
    CR1 -->|full control| RES2
    CR1 -->|full control| RES3
    CR1 -->|full control| RES4
    CR1 -->|full control| RES5

    CR2 -->|edit access| RES3
    CR3 -->|view access| RES3

    CR4 -->|leader election| RES6

    %% Permissions Details
    CR1 -.->|configmaps, serviceaccounts,<br/>services, deployments, HPAs,<br/>networkpolicies, routes| PERM1
    CR1 -.->|PVCs| PERM3
    CR1 -.->|LlamaStackDistributions| PERM1
    CR1 -.->|LlamaStackDistributions/status| PERM4

    CR2 -.->|LlamaStackDistributions| PERM1
    CR3 -.->|LlamaStackDistributions| PERM5

    %% Styling
    style SA fill:#4285F4,stroke:#fff,color:#fff
    style CR1 fill:#EA4335,stroke:#fff,color:#fff
    style CR2 fill:#EA4335,stroke:#fff,color:#fff
    style CR3 fill:#EA4335,stroke:#fff,color:#fff
    style CR4 fill:#EA4335,stroke:#fff,color:#fff
    style RB1 fill:#FBBC04,stroke:#000,color:#000
    style RB2 fill:#FBBC04,stroke:#000,color:#000
    style RES1 fill:#34A853,stroke:#fff,color:#fff
    style RES2 fill:#34A853,stroke:#fff,color:#fff
    style RES3 fill:#34A853,stroke:#fff,color:#fff
    style RES4 fill:#34A853,stroke:#fff,color:#fff
    style RES5 fill:#34A853,stroke:#fff,color:#fff
    style RES6 fill:#34A853,stroke:#fff,color:#fff
