graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        CLIENT[Clients Users SDKs<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token]
    end

    subgraph Ingress["INGRESS (TLS Termination)"]
        GATEWAY[Istio Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional mTLS)"]
        SVC[MLflow Service<br/>5000/TCP ClusterIP<br/>HTTP<br/>Bearer Token Auth]
    end

    subgraph MLflowServer["MLFLOW SERVER (Trusted)"]
        API[MLflow REST API<br/>5000/TCP HTTP<br/>/api/2.0/mlflow/*<br/>/api/3.0/mlflow/traces/*<br/>Bearer Token or<br/>X-Forwarded-Access-Token]

        K8S_WS[K8s Workspace Provider<br/>Namespace Mapping]
        K8S_AUTH[K8s Auth Plugin<br/>RBAC via SubjectAccessReview]
        UI[React Frontend<br/>/ static assets]
    end

    subgraph BackendStores["BACKEND STORES"]
        PG[PostgreSQL Database<br/>5432/TCP PostgreSQL<br/>TLS 1.2+ optional<br/>Username/Password]
        S3[S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Keys]
    end

    subgraph KubernetesAPI["KUBERNETES API"]
        K8SAPI[Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token]
        NS[Namespaces list/watch]
        CONFIG[MLflowConfigs list/watch]
        SEC[Secrets get]
        SAR[SubjectAccessReviews create]
    end

    subgraph Secrets["SECRETS"]
        SEC1[mlflow-artifact-connection<br/>S3 credentials<br/>Auto-rotate: No]
        SEC2[mlflow-db-credentials<br/>PostgreSQL credentials<br/>Auto-rotate: No]
    end

    subgraph Monitoring["MONITORING"]
        PROM[Prometheus<br/>Metrics scraping]
    end

    %% External to Ingress
    CLIENT -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| GATEWAY

    %% Ingress to Service
    GATEWAY -->|HTTP/5000<br/>TLS terminated| SVC

    %% Service to API
    SVC -->|Routes to| API

    %% API Components
    API -->|uses| K8S_WS
    API -->|uses| K8S_AUTH
    API -->|serves| UI

    %% Workspace Provider and Auth
    K8S_WS -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| NS
    K8S_WS -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| CONFIG
    K8S_WS -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| SEC

    K8S_AUTH -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount| SAR

    %% Backend Stores
    API -->|PostgreSQL/5432<br/>TLS 1.2+ opt<br/>Username/Pass| PG
    API -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    %% Secrets Usage
    API -.-|Uses| SEC1
    API -.-|Uses| SEC2

    %% Monitoring
    API -.->|Exposes metrics| PROM

    %% Styling
    classDef external fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef ingress fill:#fab005,stroke:#f59f00,color:#000
    classDef service fill:#51cf66,stroke:#37b24d,color:#000
    classDef server fill:#74c0fc,stroke:#339af0,color:#000
    classDef backend fill:#b197fc,stroke:#9775fa,color:#fff
    classDef k8s fill:#326CE5,stroke:#fff,color:#fff
    classDef secrets fill:#ffc078,stroke:#ff922b,color:#000

    class CLIENT external
    class GATEWAY ingress
    class SVC service
    class API,K8S_WS,K8S_AUTH,UI server
    class PG,S3 backend
    class K8SAPI,NS,CONFIG,SEC,SAR k8s
    class SEC1,SEC2 secrets
