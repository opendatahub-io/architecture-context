graph LR
    subgraph "Platform Maturity - Open Data Hub 3.3.0"
        direction TB

        subgraph "Component Statistics"
            A["Total Components: 5<br/>(ODH Operator, Dashboard, Notebooks,<br/>MLflow, Feast)"]
            B["Operator-based: 5/5 = 100%<br/>All components use operator pattern"]
            C["Total CRDs: 20+<br/>DataScienceCluster, Notebook,<br/>FeatureStore, MLflowConfig, etc."]
        end

        subgraph "Security Posture"
            D["Service Mesh: Optional<br/>Istio supported (Feast, Notebooks)"]
            E["mTLS Mode: PERMISSIVE<br/>Optional per-component"]
            F["Auth Mechanisms: 6<br/>OAuth, Bearer, mTLS, OIDC,<br/>SA tokens, K8s RBAC"]
            G["Secrets Inventory: 10+<br/>TLS certs, OAuth configs,<br/>DB credentials, S3 creds"]
        end

        subgraph "Architecture Patterns"
            H["Multi-tenancy: Namespace-based<br/>User workspaces isolated"]
            I["High Availability: Supported<br/>ODH Operator 3 replicas w/ leader election"]
            J["Storage Backends: 7+<br/>PostgreSQL, Redis, MongoDB,<br/>S3, GCS, BigQuery, Snowflake"]
        end

        subgraph "Cloud Compatibility"
            K["Cloud Support: Multi-cloud<br/>AWS (S3), GCP (GCS, BigQuery),<br/>Azure (AKS), CoreWeave"]
            L["Container Platform: OpenShift 4.19+<br/>Kubernetes 1.25+"]
        end

        subgraph "API Maturity"
            M["HTTP Endpoints: 24+<br/>Dashboard, MLflow, Feast REST APIs"]
            N["gRPC Services: 3<br/>Feast ServingService, RegistryServer,<br/>TransformationService"]
            O["API Versions: v1<br/>All CRD storage versions stable"]
        end

        subgraph "Integration Points"
            P["External Platform: 4<br/>K8s API, OLM, OAuth, Istio (optional)"]
            Q["External Services: 6<br/>PostgreSQL, Redis, S3,<br/>BigQuery, Snowflake, Container Registries"]
            R["Internal Integrations: 15+<br/>Dashboard→Notebooks, Notebooks→Feast,<br/>Workbenches→MLflow, etc."]
        end
    end

