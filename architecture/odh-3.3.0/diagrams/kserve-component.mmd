graph TB
    subgraph "KServe Platform"
        subgraph "Control Plane"
            KSC[KServe Controller Manager<br/>Operator Controller]
            LLMC[LLM Inference Service Controller<br/>Operator Controller]
            LMC[Local Model Controller<br/>Operator Controller]
        end

        subgraph "Data Plane"
            subgraph "Predictor Pod"
                KSA[KServe Agent<br/>Sidecar]
                SR[Serving Runtime<br/>TensorFlow/PyTorch/Triton/vLLM]
            end

            KSR[KServe Router<br/>Traffic Router]
            LMNC[Local Model Node Controller<br/>Node Agent]
        end

        subgraph "CRDs"
            ISVC[InferenceService<br/>v1beta1]
            TM[TrainedModel<br/>v1alpha1]
            SRT[ServingRuntime<br/>v1alpha1]
            CSRT[ClusterServingRuntime<br/>v1alpha1]
            IG[InferenceGraph<br/>v1alpha1]
            CSC[ClusterStorageContainer<br/>v1alpha1]
            LLMIS[LLMInferenceService<br/>v1alpha1]
            LLMISC[LLMInferenceServiceConfig<br/>v1alpha1]
            LMCache[LocalModelCache<br/>v1alpha1]
            LMNode[LocalModelNode<br/>v1alpha1]
            LMNG[LocalModelNodeGroup<br/>v1alpha1]
        end
    end

    subgraph "External Dependencies"
        K8S[Kubernetes 1.24+]
        KNATIVE[Knative Serving 1.10+]
        ISTIO[Istio 1.17+]
        CERT[cert-manager 1.12+]
        PROM[Prometheus 2.40+]
    end

    subgraph "Internal ODH Dependencies"
        DASH[ODH Dashboard]
        MR[Model Registry]
        ODHO[ODH Operator]
        OSS[OpenShift Serverless]
        OSM[OpenShift Service Mesh]
    end

    subgraph "Storage Backend"
        S3[S3/Minio]
        GCS[Google Cloud Storage]
        AZURE[Azure Blob]
        PVC[Persistent Volumes]
        HF[Hugging Face Hub]
    end

    %% Control Plane Relationships
    KSC -->|reconciles| ISVC
    KSC -->|reconciles| TM
    KSC -->|reconciles| SRT
    KSC -->|reconciles| CSRT
    KSC -->|reconciles| IG
    KSC -->|reconciles| CSC
    LLMC -->|reconciles| LLMIS
    LLMC -->|reconciles| LLMISC
    LMC -->|reconciles| LMCache
    LMC -->|reconciles| LMNode
    LMC -->|reconciles| LMNG

    %% Data Plane Relationships
    KSC -->|creates| SR
    KSA -->|manages| SR
    KSR -->|routes to| SR
    LMNC -->|manages| LMNode

    %% External Dependencies
    KSC -->|uses| K8S
    KSC -->|uses| KNATIVE
    KSC -->|uses| ISTIO
    KSC -->|uses| CERT
    SR -->|exposes metrics| PROM

    %% Internal ODH Dependencies
    DASH -->|UI integration| ISVC
    MR -->|API| KSC
    ODHO -->|manages| KSC
    KSC -->|uses| OSS
    KSC -->|uses| OSM

    %% Storage
    KSA -->|downloads models| S3
    KSA -->|downloads models| GCS
    KSA -->|downloads models| AZURE
    KSA -->|downloads models| PVC
    KSA -->|downloads models| HF

    style KSC fill:#326CE5,stroke:#fff,color:#fff
    style LLMC fill:#326CE5,stroke:#fff,color:#fff
    style LMC fill:#326CE5,stroke:#fff,color:#fff
    style KSA fill:#4285F4,stroke:#fff,color:#fff
    style SR fill:#34A853,stroke:#fff,color:#fff
    style KSR fill:#4285F4,stroke:#fff,color:#fff
