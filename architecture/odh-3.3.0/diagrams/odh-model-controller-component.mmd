graph TB
    subgraph "ODH Model Controller"
        Controller[Model Controller<br/>Main Reconciler]
        ISController[InferenceService Controller]
        SRController[ServingRuntime Controller]
        LLMController[LLM InferenceService Controller]
        IGController[InferenceGraph Controller]
        NIMController[NIM Account Controller]
        CMWatcher[ConfigMap Watcher]
        PodWatcher[Pod Watcher]
        SecretWatcher[Secret Watcher]

        Controller --> ISController
        Controller --> SRController
        Controller --> LLMController
        Controller --> IGController
        Controller --> NIMController
        Controller --> CMWatcher
        Controller --> PodWatcher
        Controller --> SecretWatcher
    end

    subgraph "CRDs Watched"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        InferenceGraphCR[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        NIMAccountCR[Account<br/>nim.opendatahub.io/v1]
    end

    subgraph "Resources Created"
        Route[OpenShift Routes]
        HTTPRoute[Gateway HTTPRoutes]
        AuthPolicy[Istio AuthorizationPolicy]
        ConfigMap[NIM ConfigMaps]
        KEDAResources[KEDA ScaledObjects]
    end

    subgraph "External Dependencies"
        KServe[KServe Controller]
        OSRouter[OpenShift Router]
        Istio[Istio Service Mesh]
        NGC[NVIDIA NGC API]
        S3[S3 Storage]
    end

    subgraph "Internal ODH Dependencies"
        Dashboard[ODH Dashboard]
        ModelRegistry[Model Registry]
        TrustyAI[TrustyAI Sidecar]
    end

    %% Watching relationships
    InferenceServiceCR -->|watched by| ISController
    ServingRuntimeCR -->|watched by| SRController
    InferenceGraphCR -->|watched by| IGController
    NIMAccountCR -->|managed by| NIMController

    %% Creation relationships
    ISController -->|creates| Route
    ISController -->|creates| HTTPRoute
    LLMController -->|creates| AuthPolicy
    NIMController -->|creates| ConfigMap
    ISController -->|creates| KEDAResources

    %% External dependencies
    Controller -->|extends| KServe
    Route -->|uses| OSRouter
    AuthPolicy -->|uses| Istio
    NIMController -->|calls| NGC
    Controller -->|accesses| S3

    %% Internal integrations
    Dashboard -->|manages via| Controller
    Controller -->|integrates| ModelRegistry
    Controller -->|works with| TrustyAI

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:4px
    style ISController fill:#4a90e2,stroke:#333
    style SRController fill:#4a90e2,stroke:#333
    style LLMController fill:#4a90e2,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style NIMAccountCR fill:#f5a623,stroke:#333
    style KServe fill:#999,stroke:#333
    style OSRouter fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style NGC fill:#999,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style TrustyAI fill:#7ed321,stroke:#333
