graph TD
    subgraph "Service Accounts"
        SA_Operator[mlflow-operator<br/>NS: opendatahub / redhat-ods-applications]
        SA_Server[mlflow<br/>NS: deployment-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[mlflow-operator-rolebinding]
        CRB_Server[mlflow-server-rolebinding]
    end

    subgraph "ClusterRole: manager-role (Operator)"
        CR_Manager[manager-role]
    end

    subgraph "ClusterRole: mlflow (Server)"
        CR_MLflow[mlflow]
    end

    subgraph "Operator API Resources"
        MLflow_CRD["mlflow.opendatahub.io<br/>MLflow<br/>create, delete, get, list, patch, update, watch"]
        MLflowConfig_CRD["mlflow.kubeflow.org<br/>MLflowConfig<br/>get, list, watch"]
        Namespaces["core<br/>namespaces<br/>get, list, watch"]
        Secrets_Global["core<br/>secrets (mlflow-artifact-connection)<br/>get"]
        RBAC_Resources["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create, delete, get, list, patch, update, watch"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>create, delete, get, list, patch, update, watch"]
        ConsoleLinks["console.openshift.io<br/>consolelinks<br/>create, delete, get, list, patch, update, watch"]
    end

    subgraph "Server API Resources"
        Namespaces_Server["core<br/>namespaces<br/>get, list, watch"]
        Secrets_Server["core<br/>secrets (mlflow-artifact-connection)<br/>get"]
        MLflowConfig_Server["mlflow.kubeflow.org<br/>MLflowConfig<br/>get, list, watch"]
    end

    subgraph "Kubernetes Resources Created by Operator"
        Deployments[Deployments<br/>MLflow Server]
        Services[Services<br/>MLflow Service]
        PVCs[PersistentVolumeClaims<br/>SQLite storage]
        NetworkPolicies[NetworkPolicies<br/>Egress/Ingress]
        Routes[Gateway HTTPRoutes<br/>External access]
        Console[OpenShift ConsoleLinks<br/>Console integration]
    end

    %% Operator RBAC flow
    SA_Operator -->|bound via| CRB_Operator
    CRB_Operator -->|grants| CR_Manager

    CR_Manager -->|permissions| MLflow_CRD
    CR_Manager -->|permissions| MLflowConfig_CRD
    CR_Manager -->|permissions| Namespaces
    CR_Manager -->|permissions| Secrets_Global
    CR_Manager -->|permissions| RBAC_Resources
    CR_Manager -->|permissions| HTTPRoutes
    CR_Manager -->|permissions| ConsoleLinks

    %% Server RBAC flow
    SA_Server -->|bound via| CRB_Server
    CRB_Server -->|grants| CR_MLflow

    CR_MLflow -->|permissions| Namespaces_Server
    CR_MLflow -->|permissions| Secrets_Server
    CR_MLflow -->|permissions| MLflowConfig_Server

    %% Operator creates resources
    SA_Operator -.->|creates| Deployments
    SA_Operator -.->|creates| Services
    SA_Operator -.->|creates| PVCs
    SA_Operator -.->|creates| NetworkPolicies
    SA_Operator -.->|creates| Routes
    SA_Operator -.->|creates| Console

    %% Server uses created resources
    SA_Server -.->|runs in| Deployments
    SA_Server -.->|reads| Secrets_Server
    SA_Server -.->|reads| MLflowConfig_Server

    %% Styling
    style SA_Operator fill:#4a90e2
    style SA_Server fill:#4a90e2
    style CR_Manager fill:#f5a623
    style CR_MLflow fill:#f5a623
    style MLflow_CRD fill:#7ed321
    style MLflowConfig_CRD fill:#7ed321
    style MLflowConfig_Server fill:#7ed321
    style Deployments fill:#ddd
    style Services fill:#ddd
    style PVCs fill:#ddd
    style NetworkPolicies fill:#ddd
    style Routes fill:#ddd
    style Console fill:#ddd
