graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>notebook-ingress<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ Edge Termination<br/>Secret: notebook-tls-secret"]
        OAuth["OAuth Proxy<br/>Secret: notebook-oauth-secret<br/>User Auth via OpenShift"]
    end

    subgraph Internal["INTERNAL (Kubernetes Cluster)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            NotebookSS["Notebook StatefulSet<br/>SA: {notebook-controller-sa}"]
            NotebookPod["Notebook Pod<br/>Jupyter/CodeServer/RStudio<br/>Image: quay.io/opendatahub/workbench<br/>Port: 8888/TCP HTTP<br/>Auth: Jupyter Token"]
            NotebookSvc["Service: notebook<br/>ClusterIP<br/>8888/TCP → 8888"]
        end

        subgraph NS_Pipeline["Namespace: {pipeline-namespace}"]
            DSP["DSP Orchestrator"]
            RuntimePod["Runtime Pod<br/>Image: quay.io/opendatahub/runtime"]
        end

        subgraph NS_ODH["ODH Services"]
            ModelReg["Model Registry API<br/>8080/TCP HTTP<br/>Auth: Bearer Token"]
        end

        NotebookSS -->|creates| NotebookPod
        NotebookSvc -->|routes to| NotebookPod
        DSP -->|exec| RuntimePod
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Quay["quay.io<br/>443/TCP HTTPS<br/>Auth: Token"]
        PyPI["PyPI Index<br/>pypi.org<br/>443/TCP HTTPS<br/>No Auth"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS Credentials<br/>Secret: aws-credentials"]
        Git["Git Repositories<br/>github.com, gitlab.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: SSH Key/Token<br/>Secret: git-credentials"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route
    Route -->|TLS Termination| OAuth
    OAuth -->|HTTP/8888<br/>Notebook Token| NotebookSvc
    NotebookSvc -->|HTTP/8888| NotebookPod

    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| PyPI
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Creds| S3
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>SSH/Token| Git
    NotebookPod -->|HTTP/8080<br/>Bearer Token| ModelReg

    RuntimePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    RuntimePod -->|HTTP/8080<br/>Bearer Token| ModelReg

    %% Container image pulls (implicit)
    NotebookPod -.->|Pull Images<br/>HTTPS/443| Quay
    RuntimePod -.->|Pull Images<br/>HTTPS/443| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Route,OAuth ingress
    class NotebookSS,NotebookPod,NotebookSvc,DSP,RuntimePod,ModelReg internal
    class Quay,PyPI,S3,Git externalservice
