graph TB
    subgraph External["EXTERNAL ZONE (Untrusted)"]
        CLIENT[Client<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token]
        S3[S3/Minio<br/>HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4]
        GCS[GCS<br/>HTTPS/443<br/>TLS 1.3<br/>OAuth2]
        AZURE[Azure Blob<br/>HTTPS/443<br/>TLS 1.3<br/>Azure AD]
        HF[Hugging Face Hub<br/>HTTPS/443<br/>TLS 1.3<br/>API Token]
    end

    subgraph Ingress["INGRESS (Trust Boundary)"]
        IGW[Istio Ingress Gateway<br/>443/TCP HTTPS<br/>TLS Mode: SIMPLE/MUTUAL<br/>Auth: Bearer Token]
    end

    subgraph ServiceMesh["SERVICE MESH (Trusted - mTLS)"]
        ROUTER[KServe Router<br/>8080/TCP HTTP<br/>mTLS]

        subgraph PredictorPod["Predictor Pod"]
            AGENT[KServe Agent<br/>Sidecar]
            PRED[Predictor<br/>8080/TCP HTTP<br/>9000/TCP gRPC<br/>mTLS]
        end

        TRANS[Transformer<br/>8080/TCP HTTP<br/>mTLS]
        EXPL[Explainer<br/>8080/TCP HTTP<br/>mTLS]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        CTRL[KServe Controller<br/>8081/TCP health<br/>8080/TCP metrics]
        LLMCTRL[LLM Controller<br/>8080/TCP HTTP]
        LMCTRL[Local Model Controller<br/>8080/TCP HTTP]
        K8SAPI[Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>ServiceAccount]
    end

    subgraph Monitoring["MONITORING"]
        PROM[Prometheus<br/>Scrapes 8080/8082<br/>HTTP TLS 1.2+]
    end

    subgraph Secrets["SECRETS"]
        SEC1[kserve-webhook-server-cert<br/>TLS cert<br/>Auto-rotate: Yes]
        SEC2[storage-config<br/>S3/GCS/Azure creds<br/>Auto-rotate: No]
        SEC3[isvc-sa-token<br/>SA token<br/>Auto-rotate: Yes]
        SEC4[llm-api-key<br/>API keys<br/>Auto-rotate: No]
    end

    %% External to Ingress
    CLIENT -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| IGW

    %% Ingress to Service Mesh
    IGW -->|HTTP/8080<br/>mTLS| ROUTER

    %% Service Mesh Internal
    ROUTER -->|HTTP/8080<br/>mTLS| TRANS
    ROUTER -->|HTTP/8080<br/>mTLS| PRED
    TRANS -->|HTTP/8080<br/>mTLS| PRED
    PRED -->|HTTP/8080<br/>mTLS| EXPL

    %% Egress from Predictor
    AGENT -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4| S3
    AGENT -.->|HTTPS/443<br/>TLS 1.3<br/>OAuth2| GCS
    AGENT -.->|HTTPS/443<br/>TLS 1.3<br/>Azure AD| AZURE
    AGENT -.->|HTTPS/443<br/>TLS 1.3<br/>API Token| HF

    %% Control Plane
    CTRL -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount| K8SAPI
    LLMCTRL -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount| K8SAPI
    LMCTRL -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount| K8SAPI

    %% Monitoring
    PROM -.->|Scrape<br/>HTTP/8080| PRED
    PROM -.->|Scrape<br/>HTTP/8080| CTRL
    PROM -.->|Scrape<br/>HTTP/15090| IGW

    %% Secrets Usage
    CTRL -.-|Uses| SEC1
    AGENT -.-|Uses| SEC2
    PRED -.-|Uses| SEC3
    PRED -.-|Uses| SEC4

    %% Styling
    classDef external fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef ingress fill:#fab005,stroke:#f59f00,color:#000
    classDef mesh fill:#51cf66,stroke:#37b24d,color:#000
    classDef control fill:#74c0fc,stroke:#339af0,color:#000
    classDef monitor fill:#b197fc,stroke:#9775fa,color:#fff
    classDef secrets fill:#ffd43b,stroke:#fab005,color:#000

    class CLIENT,S3,GCS,AZURE,HF external
    class IGW ingress
    class ROUTER,TRANS,PRED,EXPL,AGENT mesh
    class CTRL,LLMCTRL,LMCTRL,K8SAPI control
    class PROM monitor
    class SEC1,SEC2,SEC3,SEC4 secrets
