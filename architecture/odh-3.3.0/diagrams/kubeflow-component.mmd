graph TB
    subgraph "Kubeflow Notebook Controllers"
        subgraph "notebook-controller (Upstream)"
            NB_CTRL[Notebook Controller<br/>Main Reconciler]
            NB_CULL[Culling Controller<br/>Idle Notebook Monitor]
        end

        subgraph "odh-notebook-controller (ODH/RHOAI Extensions)"
            ODH_CTRL[ODH Notebook Controller<br/>Main ODH Reconciler]
            ODH_WH[Notebook Webhook<br/>Admission Webhook]
            ODH_OAUTH[OAuth Module<br/>OpenShift Auth]
            ODH_ROUTE[Route Module<br/>OpenShift Routes]
            ODH_NET[Network Module<br/>NetworkPolicies]
            ODH_RBAC[RBAC Module<br/>Roles & Bindings]
            ODH_DSPA[DSPA Secret Module<br/>Pipeline Integration]
            ODH_FEAST[Feast Module<br/>Feature Store Config]
            ODH_RUNTIME[Runtime Module<br/>Image & Resources]
            ODH_REFGRANT[ReferenceGrant Module<br/>Gateway API]
        end

        subgraph "CRDs"
            NB_V1[Notebook v1<br/>Primary API]
            NB_V1B[Notebook v1beta1<br/>Beta API]
            NB_V1A[Notebook v1alpha1<br/>Alpha API]
        end
    end

    subgraph "External Dependencies"
        K8S[Kubernetes 0.33.7+]
        CTRL_RT[controller-runtime 0.21.0]
        ISTIO[Istio<br/>Optional]
        CERT[cert-manager<br/>Optional]
        OSCA[OpenShift Service CA<br/>Optional]
    end

    subgraph "Internal ODH Dependencies"
        DSPO[Data Science Pipelines Operator<br/>DSPA CRD]
        OAUTH[OpenShift OAuth<br/>OAuth Clients]
        ROUTES[OpenShift Routes<br/>Route CRD]
        GATEWAY[Gateway API<br/>HTTPRoute, Gateway]
        IMGSTR[OpenShift ImageStreams]
        FEAST_CFG[Feast ConfigMap]
    end

    subgraph "Notebook Infrastructure"
        STS[StatefulSet<br/>Notebook Pod]
        SVC[Service<br/>ClusterIP]
        ROUTE_RES[Route Resource]
        HTTPROUTE[HTTPRoute Resource]
        VS[VirtualService<br/>Istio]
        NP[NetworkPolicy]
        OAUTH_CLIENT[OAuth Client]
        SA[ServiceAccount]
    end

    %% Controller Reconciliation
    NB_CTRL -->|reconciles| NB_V1
    NB_CTRL -->|creates| STS
    NB_CTRL -->|creates| SVC
    NB_CTRL -->|creates optional| VS

    NB_CULL -->|monitors| STS
    NB_CULL -->|stops idle| NB_V1

    ODH_CTRL -->|orchestrates| NB_V1
    ODH_WH -->|validates/mutates| NB_V1
    ODH_OAUTH -->|creates| OAUTH_CLIENT
    ODH_ROUTE -->|creates| ROUTE_RES
    ODH_NET -->|creates| NP
    ODH_RBAC -->|creates| SA
    ODH_DSPA -->|injects config| STS
    ODH_FEAST -->|injects config| STS
    ODH_RUNTIME -->|configures| STS
    ODH_REFGRANT -->|creates| HTTPROUTE

    %% External Dependencies
    NB_CTRL -->|uses| K8S
    NB_CTRL -->|uses| CTRL_RT
    NB_CTRL -.->|optional| ISTIO
    ODH_CTRL -->|uses| K8S
    ODH_CTRL -->|uses| CTRL_RT
    ODH_WH -.->|optional| CERT
    ODH_WH -.->|optional| OSCA

    %% Internal ODH Dependencies
    ODH_DSPA -->|reads| DSPO
    ODH_OAUTH -->|creates| OAUTH
    ODH_ROUTE -->|creates| ROUTES
    ODH_REFGRANT -->|uses| GATEWAY
    ODH_RUNTIME -->|reads| IMGSTR
    ODH_FEAST -->|reads| FEAST_CFG

    %% CRD Versions
    NB_V1 -.->|converts to/from| NB_V1B
    NB_V1B -.->|converts to/from| NB_V1A

    style NB_CTRL fill:#326CE5,stroke:#fff,color:#fff
    style NB_CULL fill:#4285F4,stroke:#fff,color:#fff
    style ODH_CTRL fill:#0066CC,stroke:#fff,color:#fff
    style ODH_WH fill:#0080FF,stroke:#fff,color:#fff
    style STS fill:#34A853,stroke:#fff,color:#fff
