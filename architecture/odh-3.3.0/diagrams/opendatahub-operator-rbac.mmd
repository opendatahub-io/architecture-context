graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[controller-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[controller-manager<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        CoreNS[Namespaces]
        CoreSvc[Services]
        CoreSA[ServiceAccounts]
        CoreCM[ConfigMaps]
        CoreSecret[Secrets]
        CorePod[Pods]
    end

    subgraph "Apps API Resources"
        AppsDeploy[Deployments<br/>apps/v1]
        AppsSTS[StatefulSets<br/>apps/v1]
        AppsDS[DaemonSets<br/>apps/v1]
    end

    subgraph "RBAC API Resources"
        RBACRole[Roles<br/>rbac.authorization.k8s.io]
        RBACRoleBinding[RoleBindings<br/>rbac.authorization.k8s.io]
        RBACClusterRole[ClusterRoles<br/>rbac.authorization.k8s.io]
        RBACClusterRoleBinding[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "ODH CRDs"
        DSC[DataScienceCluster<br/>datasciencecluster.opendatahub.io]
        DSCI[DSCInitialization<br/>dscinitialization.opendatahub.io]
        CompCRDs[Component CRDs<br/>components.platform.opendatahub.io/*]
        SvcCRDs[Service CRDs<br/>services.platform.opendatahub.io]
    end

    subgraph "OLM Resources"
        OLMSub[Subscriptions<br/>operators.coreos.com]
        OLMOpGroup[OperatorGroups<br/>operators.coreos.com]
    end

    subgraph "Monitoring Resources"
        MonSM[ServiceMonitors<br/>monitoring.coreos.com]
        MonPR[PrometheusRules<br/>monitoring.coreos.com]
    end

    subgraph "OpenShift Resources"
        OSRoute[Routes<br/>route.openshift.io]
        OSClusterVersion[ClusterVersions<br/>config.openshift.io]
    end

    subgraph "Network Resources"
        NetPol[NetworkPolicies<br/>networking.k8s.io]
    end

    %% RBAC bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Core permissions
    CR -->|get,list,watch,create,update,patch,delete| CoreNS
    CR -->|get,list,watch,create,update,patch,delete| CoreSvc
    CR -->|get,list,watch,create,update,patch,delete| CoreSA
    CR -->|get,list,watch,create,update,patch,delete| CoreCM
    CR -->|get,list,watch,create,update,patch,delete| CoreSecret
    CR -->|get,list,watch,create,update,patch,delete| CorePod

    %% Apps permissions
    CR -->|get,list,watch,create,update,patch,delete| AppsDeploy
    CR -->|get,list,watch,create,update,patch,delete| AppsSTS
    CR -->|get,list,watch,create,update,patch,delete| AppsDS

    %% RBAC permissions
    CR -->|get,list,watch,create,update,patch,delete| RBACRole
    CR -->|get,list,watch,create,update,patch,delete| RBACRoleBinding
    CR -->|get,list,watch,create,update,patch,delete| RBACClusterRole
    CR -->|get,list,watch,create,update,patch,delete| RBACClusterRoleBinding

    %% ODH CRD permissions
    CR -->|get,list,watch,create,update,patch,delete| DSC
    CR -->|get,list,watch,create,update,patch,delete| DSCI
    CR -->|get,list,watch,create,update,patch,delete| CompCRDs
    CR -->|get,list,watch,create,update,patch,delete| SvcCRDs

    %% OLM permissions
    CR -->|get,list,watch,create,update,patch,delete| OLMSub
    CR -->|get,list,watch,create,update,patch,delete| OLMOpGroup

    %% Monitoring permissions
    CR -->|get,list,watch,create,update,patch,delete| MonSM
    CR -->|get,list,watch,create,update,patch,delete| MonPR

    %% OpenShift permissions
    CR -->|get,list,watch,create,update,patch,delete| OSRoute
    CR -->|get,list,watch| OSClusterVersion

    %% Network permissions
    CR -->|get,list,watch,create,update,patch,delete| NetPol

    %% Additional service account (metrics proxy)
    subgraph "Additional Service Accounts"
        SAProxy[auth-proxy-client<br/>For kube-rbac-proxy]
    end

    subgraph "Additional ClusterRoles"
        CRProxy[auth-proxy-client<br/>ClusterRole]
    end

    SAProxy -->|bound via ClusterRoleBinding| CRProxy
    CRProxy -->|get,list,watch| CorePod

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f39c12,stroke:#333,stroke-width:2px
    style DSC fill:#e74c3c,stroke:#333,color:#fff
    style DSCI fill:#e74c3c,stroke:#333,color:#fff
    style CompCRDs fill:#e74c3c,stroke:#333,color:#fff
    style SvcCRDs fill:#e74c3c,stroke:#333,color:#fff
    style CoreNS fill:#7ed321,stroke:#333
    style CoreSvc fill:#7ed321,stroke:#333
    style CoreSA fill:#7ed321,stroke:#333
    style CoreCM fill:#7ed321,stroke:#333
    style CoreSecret fill:#7ed321,stroke:#333
    style CorePod fill:#7ed321,stroke:#333
    style AppsDeploy fill:#3498db,stroke:#333,color:#fff
    style AppsSTS fill:#3498db,stroke:#333,color:#fff
    style AppsDS fill:#3498db,stroke:#333,color:#fff
    style OLMSub fill:#9b59b6,stroke:#333,color:#fff
    style OLMOpGroup fill:#9b59b6,stroke:#333,color:#fff
    style SAProxy fill:#95a5a6,stroke:#333
    style CRProxy fill:#95a5a6,stroke:#333
