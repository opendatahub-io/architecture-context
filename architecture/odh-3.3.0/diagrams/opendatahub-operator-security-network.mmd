graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / GitOps System]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>RBAC Enforcement"]

        subgraph Webhooks["Admission Webhooks"]
            WebhookSvc["Webhook Service<br/>ClusterIP 443→9443/TCP<br/>HTTPS TLS<br/>Cert: service-ca"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph ControllerPods["Controller Manager (3 replicas, leader-elected)"]
            Manager["Controller Manager Pod<br/>UID: 1001 (non-root)<br/>Seccomp: RuntimeDefault<br/>Caps: ALL dropped"]

            subgraph Sidecars["Sidecars"]
                RBACProxy["kube-rbac-proxy<br/>8443→8080/TCP<br/>Authz enforcement"]
            end
        end

        subgraph Services["Services"]
            MetricsSvc["Metrics Service<br/>ClusterIP 8443/TCP<br/>Target: kube-rbac-proxy"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        Kubelet["Kubelet<br/>Health Checks"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OLM["Operator Lifecycle Manager<br/>Subscription CRDs"]
        Registry["Quay.io / Registry<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secrets"]
    end

    subgraph DeployedComps["DEPLOYED COMPONENTS (Various Namespaces)"]
        CompOp1["KServe Operator"]
        CompOp2["Dashboard"]
        CompOp3["Data Science Pipelines"]
        CompOp4["Component Operators..."]
    end

    %% User flows
    User -->|HTTPS/443<br/>TLS1.2+<br/>User credentials| K8sAPI

    %% Webhook flow
    K8sAPI -->|HTTPS/9443<br/>TLS service-cert<br/>K8s API auth| WebhookSvc
    WebhookSvc -->|Validate/Mutate| Manager
    WebhookSvc -->|Response| K8sAPI

    %% Controller Manager flows
    K8sAPI -->|Watch events<br/>Internal cluster| Manager
    Manager -->|HTTPS/443<br/>mTLS<br/>SA token| K8sAPI

    %% OLM integration
    Manager -->|CREATE Subscription<br/>HTTPS/443 mTLS| K8sAPI
    K8sAPI -->|Informs| OLM
    OLM -->|HTTPS/443<br/>TLS1.2+<br/>Pull secrets| Registry

    %% Component deployment
    Manager -->|Deploys manifests<br/>via K8s API| CompOp1
    Manager -->|Deploys manifests<br/>via K8s API| CompOp2
    Manager -->|Deploys manifests<br/>via K8s API| CompOp3
    Manager -->|Deploys manifests<br/>via K8s API| CompOp4

    %% Monitoring flows
    Prometheus -->|HTTPS/8443<br/>SA token<br/>via kube-rbac-proxy| RBACProxy
    RBACProxy -->|HTTP/8080<br/>localhost| Manager
    Kubelet -->|HTTP/8081<br/>localhost<br/>/healthz, /readyz| Manager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef components fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class K8sAPI,WebhookSvc controlplane
    class Manager,RBACProxy,MetricsSvc operator
    class Prometheus,Kubelet monitoring
    class OLM,Registry externalservice
    class CompOp1,CompOp2,CompOp3,CompOp4 components
