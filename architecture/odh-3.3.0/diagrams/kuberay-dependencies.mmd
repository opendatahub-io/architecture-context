graph TB
    subgraph "KubeRay Operator"
        KUBERAY[KubeRay<br/>v1.4.4]
    end

    subgraph "External Dependencies"
        RAY[Ray Runtime<br/>v2.x<br/>Required]
        REDIS[Redis<br/>v6.x+<br/>Optional<br/>GCS Persistence]
        PROM[Prometheus<br/>v2.x<br/>Optional<br/>Monitoring]
        KUEUE[Kueue<br/>v0.5+<br/>Optional<br/>Job Queuing]
        VOLCANO[Volcano<br/>v1.8+<br/>Optional<br/>Batch Scheduling]
    end

    subgraph "Internal ODH Dependencies"
        DASH[ODH Dashboard<br/>UI Integration]
        NB[Notebooks<br/>Cluster Access]
        DSP[Data Science Pipelines<br/>Job Submission]
        MR[Model Registry<br/>Model Registration]
    end

    subgraph "Storage & Infrastructure"
        S3[S3 Storage<br/>Datasets & Checkpoints]
        REGISTRY[Container Registry<br/>Ray Images]
        PYPI[PyPI<br/>Python Dependencies]
        K8S[Kubernetes<br/>Orchestration]
    end

    %% External Dependencies
    KUBERAY -->|requires| RAY
    KUBERAY -.->|optional<br/>GCS persistence| REDIS
    KUBERAY -.->|optional<br/>monitoring| PROM
    KUBERAY -.->|optional<br/>job queuing| KUEUE
    KUBERAY -.->|optional<br/>batch scheduling| VOLCANO

    %% Internal ODH Dependencies
    DASH -->|manages clusters| KUBERAY
    NB -->|submits jobs| KUBERAY
    DSP -->|executes training| KUBERAY
    MR -->|registers models from| KUBERAY

    %% Storage & Infrastructure
    KUBERAY -->|reads/writes| S3
    KUBERAY -->|pulls images| REGISTRY
    KUBERAY -->|installs deps| PYPI
    KUBERAY -->|orchestrates on| K8S

    %% Styling
    style KUBERAY fill:#326CE5,stroke:#fff,color:#fff
    style RAY fill:#00D4AA,stroke:#fff,color:#000
    style REDIS fill:#DC382D,stroke:#fff,color:#fff
    style PROM fill:#E6522C,stroke:#fff,color:#fff
    style KUEUE fill:#326CE5,stroke:#fff,color:#fff
    style VOLCANO fill:#326CE5,stroke:#fff,color:#fff
    style DASH fill:#0066CC,stroke:#fff,color:#fff
    style NB fill:#0066CC,stroke:#fff,color:#fff
    style DSP fill:#0066CC,stroke:#fff,color:#fff
    style MR fill:#0066CC,stroke:#fff,color:#fff
    style S3 fill:#569A31,stroke:#fff,color:#fff
    style REGISTRY fill:#0078D7,stroke:#fff,color:#fff
    style PYPI fill:#3776AB,stroke:#fff,color:#fff
    style K8S fill:#326CE5,stroke:#fff,color:#fff
