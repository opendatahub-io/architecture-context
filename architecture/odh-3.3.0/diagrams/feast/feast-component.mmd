graph TB
    subgraph "Feast Feature Store"
        Operator[Feast Operator]
        OnlineServer[Feature Server<br/>Online]
        OfflineServer[Feature Server<br/>Offline]
        Registry[Registry Service]
        UI[UI Service]
        Transform[Transformation<br/>Service]
    end

    subgraph "Custom Resources"
        FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1]
    end

    subgraph "Storage Backends"
        OnlineDB[(Online Store<br/>Redis/PostgreSQL/DynamoDB)]
        OfflineDB[(Offline Store<br/>BigQuery/Snowflake/Spark)]
        RegistryDB[(Registry Storage<br/>PostgreSQL/S3/GCS)]
    end

    subgraph "External Integrations"
        MLApp[ML Application]
        TrainingJob[ML Training Job]
        StreamApp[Stream Processing]
    end

    User[Data Scientist] -->|creates| FeatureStoreCR
    FeatureStoreCR -->|watched by| Operator
    Operator -->|deploys| OnlineServer
    Operator -->|deploys| OfflineServer
    Operator -->|deploys| Registry
    Operator -->|deploys| UI
    Operator -->|deploys| Transform

    MLApp -->|HTTP/gRPC 80/6566| OnlineServer
    TrainingJob -->|HTTP 8815| OfflineServer
    StreamApp -->|HTTP 80| OnlineServer

    OnlineServer -->|gRPC 6570| Registry
    OfflineServer -->|gRPC 6570| Registry
    OnlineServer -->|gRPC 6569| Transform
    UI -->|HTTP/gRPC| Registry

    OnlineServer -->|6379/5432| OnlineDB
    OfflineServer -->|HTTPS 443| OfflineDB
    Registry -->|HTTPS 443/PostgreSQL| RegistryDB

    OnlineServer -->|materialization| OfflineDB
    StreamApp -->|push| OfflineDB

    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style OnlineServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style OfflineServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style Registry fill:#4a90e2,stroke:#333,stroke-width:2px
    style UI fill:#4a90e2,stroke:#333,stroke-width:2px
    style Transform fill:#4a90e2,stroke:#333,stroke-width:2px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style OnlineDB fill:#7ed321,stroke:#333,stroke-width:2px
    style OfflineDB fill:#7ed321,stroke:#333,stroke-width:2px
    style RegistryDB fill:#7ed321,stroke:#333,stroke-width:2px
    style MLApp fill:#e8e8e8,stroke:#333
    style TrainingJob fill:#e8e8e8,stroke:#333
    style StreamApp fill:#e8e8e8,stroke:#333
