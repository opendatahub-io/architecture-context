graph TD
    subgraph "Service Accounts"
        SA[feast-operator-controller-manager<br/>Namespace: feast-operator-system]
    end

    subgraph "ClusterRole Bindings"
        CRB1[manager-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[metrics-auth-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[featurestore-editor-role]
        CR3[featurestore-viewer-role]
        CR4[metrics-reader]
    end

    subgraph "Feast API Resources"
        API1[feast.dev/v1<br/>FeatureStore]
        API2[feast.dev/v1<br/>FeatureStore/status]
        API3[feast.dev/v1<br/>FeatureStore/finalizers]
    end

    subgraph "Kubernetes Core Resources"
        K8s1[apps<br/>Deployments]
        K8s2[core<br/>Services]
        K8s3[core<br/>ConfigMaps]
        K8s4[core<br/>PVCs]
        K8s5[core<br/>ServiceAccounts]
        K8s6[core<br/>Secrets<br/>read-only]
        K8s7[core<br/>Pods<br/>read-only]
        K8s8[core<br/>Pods/exec<br/>create-only]
        K8s9[core<br/>Namespaces<br/>read-only]
    end

    subgraph "RBAC Resources"
        RBAC1[rbac.authorization.k8s.io<br/>Roles, RoleBindings]
        RBAC2[rbac.authorization.k8s.io<br/>ClusterRoles, ClusterRoleBindings]
        RBAC3[rbac.authorization.k8s.io<br/>SubjectAccessReviews]
    end

    subgraph "OpenShift Resources"
        OS1[route.openshift.io<br/>Routes]
    end

    subgraph "Batch & Scaling Resources"
        Batch1[batch<br/>CronJobs]
        Scale1[autoscaling<br/>HorizontalPodAutoscalers]
        Policy1[policy<br/>PodDisruptionBudgets]
    end

    subgraph "Authentication Resources"
        Auth1[authentication.k8s.io<br/>TokenReviews<br/>create-only]
    end

    %% Service Account bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% ClusterRole bindings
    CRB1 -->|grants| CR1
    CRB2 -->|grants leader election| CR1
    CRB3 -->|grants metrics access| CR4

    %% Manager role permissions (full CRUD)
    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| API1
    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| API2
    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| API3

    CR1 -.->|get,list,watch,<br/>create,update,delete| K8s1
    CR1 -.->|get,list,watch,<br/>create,update,delete| K8s2
    CR1 -.->|get,list,watch,<br/>create,update,delete| K8s3
    CR1 -.->|get,list,watch,<br/>create,update,delete| K8s4
    CR1 -.->|get,list,watch,<br/>create,update,delete| K8s5

    CR1 -.->|get,list,watch| K8s6
    CR1 -.->|get,list,watch| K8s7
    CR1 -.->|create| K8s8
    CR1 -.->|get,list,watch| K8s9

    CR1 -.->|get,list,watch,<br/>create,update,delete| RBAC1
    CR1 -.->|get,list,watch,<br/>create,update,delete| RBAC2
    CR1 -.->|create| RBAC3

    CR1 -.->|get,list,watch,<br/>create,update,delete| OS1

    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| Batch1
    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| Scale1
    CR1 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| Policy1

    CR1 -.->|create| Auth1

    %% Editor role permissions
    CR2 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| API1
    CR2 -.->|get,list,watch,<br/>create,update,<br/>patch,delete| API2

    %% Viewer role permissions
    CR3 -.->|get,list,watch| API1
    CR3 -.->|get,list,watch| API2

    %% Metrics reader permissions
    CR4 -.->|get,list,watch| K8s7
    CR4 -.->|get,list,watch| K8s2

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB3 fill:#f5a623,stroke:#333,stroke-width:2px

    style CR1 fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style CR2 fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style CR3 fill:#95a5a6,stroke:#333,stroke-width:2px,color:#fff
    style CR4 fill:#95a5a6,stroke:#333,stroke-width:2px,color:#fff

    style API1 fill:#7ed321,stroke:#333,stroke-width:2px
    style API2 fill:#7ed321,stroke:#333,stroke-width:2px
    style API3 fill:#7ed321,stroke:#333,stroke-width:2px

    style K8s1 fill:#326ce5,stroke:#333,color:#fff
    style K8s2 fill:#326ce5,stroke:#333,color:#fff
    style K8s3 fill:#326ce5,stroke:#333,color:#fff
    style K8s4 fill:#326ce5,stroke:#333,color:#fff
    style K8s5 fill:#326ce5,stroke:#333,color:#fff
    style K8s6 fill:#9b59b6,stroke:#333,color:#fff
    style K8s7 fill:#326ce5,stroke:#333,color:#fff
    style K8s8 fill:#3498db,stroke:#333,color:#fff
    style K8s9 fill:#326ce5,stroke:#333,color:#fff

    style RBAC1 fill:#e8491d,stroke:#333,color:#fff
    style RBAC2 fill:#e8491d,stroke:#333,color:#fff
    style RBAC3 fill:#e8491d,stroke:#333,color:#fff

    style OS1 fill:#ee0000,stroke:#333,color:#fff

    style Batch1 fill:#16a085,stroke:#333,color:#fff
    style Scale1 fill:#16a085,stroke:#333,color:#fff
    style Policy1 fill:#16a085,stroke:#333,color:#fff

    style Auth1 fill:#34495e,stroke:#333,color:#fff
