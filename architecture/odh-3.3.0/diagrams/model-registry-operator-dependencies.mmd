graph LR
    MROperator[Model Registry Operator]

    %% External Dependencies - Required
    MROperator -->|metadata storage| PostgreSQL["PostgreSQL 13+<br/>Required"]
    MROperator -->|metadata storage<br/>alternative| MySQL["MySQL 8.0+<br/>Required"]

    %% External Dependencies - Optional
    MROperator -.->|authentication| OAuthProxy["OAuth Proxy<br/>Optional"]
    MROperator -.->|embedded library| MLMetadata["ML Metadata 1.x<br/>Embedded"]

    %% Platform Dependencies
    MROperator -->|resource mgmt| K8sAPI[Kubernetes API]
    MROperator -.->|route creation| OpenShift["OpenShift<br/>for Routes"]

    %% Internal ODH Dependencies - Integrations
    Dashboard[ODH Dashboard] -->|UI for models| MROperator
    Notebooks[Notebooks] -->|register models| MROperator
    DSPipelines[Data Science Pipelines] -->|track pipeline models| MROperator
    KServe[KServe] -->|link inference services| MROperator
    TrustyAI[TrustyAI] -->|model monitoring| MROperator

    %% External Services
    MROperator -.->|token validation| OAuthService[OAuth Service]
    MROperator -.->|artifact refs| S3[S3 Storage]
    Prometheus[Prometheus] -.->|metrics scraping| MROperator

    %% Styling
    style MROperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style PostgreSQL fill:#6c8ebf,stroke:#333,stroke-width:2px,color:#fff
    style MySQL fill:#6c8ebf,stroke:#333,stroke-width:2px,color:#fff
    style OAuthProxy fill:#d79b00,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style MLMetadata fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    %% Platform
    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px
    style OpenShift fill:#f5a623,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    %% Internal ODH
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Notebooks fill:#7ed321,stroke:#333,stroke-width:2px
    style DSPipelines fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAI fill:#7ed321,stroke:#333,stroke-width:2px

    %% External Services
    style OAuthService fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style S3 fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Prometheus fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
