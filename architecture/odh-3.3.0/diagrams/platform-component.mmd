graph TB
    subgraph "Platform Control Plane (opendatahub namespace)"
        ODHOperator[ODH Operator<br/>Central orchestration]
        Dashboard[ODH Dashboard<br/>React/Node.js UI]
    end

    subgraph "Model Serving Layer"
        KServe[KServe 0.17.0<br/>Multi-framework inference]
        ODHModelController[ODH Model Controller<br/>OpenShift integrations]
        KServe -->|extends| ODHModelController
    end

    subgraph "Development Workbenches"
        NotebookController[Notebook Controller<br/>Kubeflow v1.11.0]
        NotebookImages[Notebook Images<br/>Jupyter, VSCode, RStudio]
        NotebookController -->|deploys| NotebookImages
    end

    subgraph "Training & Distributed Computing"
        TrainingOperator[Training Operator<br/>PyTorch, TF, MPI, JAX]
        Trainer[Trainer v2<br/>LLM fine-tuning]
        KubeRay[KubeRay 1.4.4<br/>Ray clusters]
        SparkOperator[Spark Operator<br/>Big data processing]
    end

    subgraph "Model & Experiment Management"
        ModelRegistry[Model Registry Operator<br/>Versioning & lineage]
        MLflowOperator[MLflow Operator<br/>Experiment tracking]
    end

    subgraph "ML Workflows & Data"
        DSPOperator[Data Science Pipelines<br/>Kubeflow Pipelines]
        Feast[Feast 0.45.0<br/>Feature store]
    end

    subgraph "AI Governance & LLM Tools"
        TrustyAI[TrustyAI 1.39.0<br/>Explainability & evaluation]
        LlamaStack[Llama Stack 0.2.24<br/>LLM development]
    end

    subgraph "Infrastructure (istio-system, knative-serving)"
        Istio[Istio<br/>Service mesh]
        Knative[Knative Serving<br/>Autoscaling]
        CertManager[cert-manager<br/>Certificate management]
    end

    %% Central Operator Relationships
    ODHOperator -->|manages lifecycle| Dashboard
    ODHOperator -->|manages lifecycle| KServe
    ODHOperator -->|manages lifecycle| ModelRegistry
    ODHOperator -->|manages lifecycle| DSPOperator
    ODHOperator -->|manages lifecycle| TrainingOperator
    ODHOperator -->|manages lifecycle| NotebookController

    %% Dashboard Integrations
    Dashboard -->|creates CRs| NotebookController
    Dashboard -->|creates CRs| KServe
    Dashboard -->|creates CRs| ModelRegistry
    Dashboard -->|monitors| DSPOperator
    Dashboard -->|monitors| TrustyAI

    %% Workbench Integrations
    NotebookImages -->|logs experiments| MLflowOperator
    NotebookImages -->|registers models| ModelRegistry
    NotebookImages -->|deploys models| KServe
    NotebookImages -->|reads features| Feast

    %% Model Serving Integrations
    KServe -->|fetches metadata| ModelRegistry
    KServe -->|monitored by| TrustyAI
    KServe -->|uses| Istio
    KServe -->|autoscales with| Knative

    %% Training Integrations
    TrainingOperator -->|logs to| MLflowOperator
    Trainer -->|logs to| MLflowOperator
    Trainer -->|registers to| ModelRegistry

    %% Pipeline Integrations
    DSPOperator -->|orchestrates| TrainingOperator
    DSPOperator -->|deploys via| KServe
    DSPOperator -->|tracks in| ModelRegistry

    %% External Dependencies
    KServe -.->|TLS certs| CertManager
    ModelRegistry -.->|TLS certs| CertManager
    Dashboard -.->|TLS certs| CertManager

    style ODHOperator fill:#4a90e2,stroke:#333,stroke-width:4px
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookController fill:#f5a623,stroke:#333,stroke-width:2px
    style DSPOperator fill:#bd10e0,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style Knative fill:#999,stroke:#333,stroke-width:2px
