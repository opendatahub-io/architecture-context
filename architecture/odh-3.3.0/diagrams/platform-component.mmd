graph TB
    subgraph "Platform Control Plane - opendatahub namespace"
        ODHOp[ODH Operator<br/>opendatahub-operator<br/>v3.3.0]
        Dashboard[ODH Dashboard<br/>React/Node.js<br/>v3.4.0EA1]
    end

    subgraph "User Interface Layer"
        Dashboard
    end

    subgraph "Development Workbenches"
        NBController[Kubeflow Notebook Controller<br/>v1.11.0-alpha.0]
        NBImages[Notebook Images<br/>Jupyter/VSCode/RStudio<br/>v1.42.0-46]
        NBController -->|creates StatefulSets| NBImages
    end

    subgraph "Model Serving"
        KServe[KServe<br/>v0.17.0-rc0]
        ModelController[ODH Model Controller<br/>$TAG_NAME-45-g3902d61]
        KServe -->|extended by| ModelController
    end

    subgraph "Model Management"
        ModelRegOp[Model Registry Operator<br/>f8a6863]
        MLflowOp[MLflow Operator<br/>33c744b]
        ModelReg[Model Registry]
        MLflow[MLflow Server<br/>v2.x]
        ModelRegOp -->|deploys| ModelReg
        MLflowOp -->|deploys| MLflow
    end

    subgraph "Training & Distributed Computing"
        TrainingOp[Training Operator<br/>bfceb079]
        TrainerV2[Trainer v2<br/>6b4be8aa]
        KubeRay[KubeRay Operator<br/>v1.4.4]
        SparkOp[Spark Operator]

        TrainingOp -->|manages| PytorchJob[PyTorchJob]
        TrainingOp -->|manages| TFJob[TensorFlowJob]
        TrainingOp -->|manages| MPIJob[MPIJob/XGBoost/JAX]
        TrainerV2 -->|manages| TrainJob[TrainJob<br/>LLM fine-tuning]
        KubeRay -->|manages| RayCluster[Ray Cluster]
        SparkOp -->|manages| SparkApp[Spark Application]
    end

    subgraph "ML Workflows & Data"
        DSPOp[Data Science Pipelines Operator<br/>v0.0.1]
        FeastOp[Feast Operator<br/>v0.45.0]

        DSPOp -->|deploys| ArgoWorkflows[Argo Workflows]
        FeastOp -->|deploys| FeatureStore[Feature Store]
    end

    subgraph "AI Governance"
        TrustyAIOp[TrustyAI Operator<br/>v1.39.0]
        TrustyAIOp -->|deploys| TrustyAI[TrustyAI Service]
        TrustyAIOp -->|deploys| EvalHub[EvalHub<br/>LLM Evaluation]
    end

    subgraph "LLM Tools"
        LlamaStackOp[Llama Stack Operator<br/>v0.2.24]
    end

    subgraph "External Dependencies"
        ServiceMesh[Istio Service Mesh<br/>istio-system]
        Knative[Knative Serving<br/>knative-serving]
        CertMgr[cert-manager<br/>cert-manager]
    end

    subgraph "External Services"
        S3[S3 Storage<br/>Model artifacts, data]
        PostgreSQL[PostgreSQL/MySQL<br/>Metadata DB]
        ContainerReg[Container Registry<br/>Image pulls]
        HuggingFace[HuggingFace Hub<br/>LLM models]
    end

    %% ODH Operator manages all components
    ODHOp -->|manages| Dashboard
    ODHOp -->|manages| NBController
    ODHOp -->|manages| KServe
    ODHOp -->|manages| ModelRegOp
    ODHOp -->|manages| MLflowOp
    ODHOp -->|manages| TrainingOp
    ODHOp -->|manages| TrainerV2
    ODHOp -->|manages| KubeRay
    ODHOp -->|manages| DSPOp
    ODHOp -->|manages| FeastOp
    ODHOp -->|manages| TrustyAIOp
    ODHOp -->|manages| LlamaStackOp
    ODHOp -->|manages| SparkOp

    %% Dashboard integrations
    Dashboard -->|creates/manages| NBController
    Dashboard -->|creates/manages| KServe
    Dashboard -->|creates/manages| ModelReg
    Dashboard -->|reads status| ODHOp

    %% Notebook integrations
    NBImages -->|calls API| DSPOp
    NBImages -->|registers models| ModelReg
    NBImages -->|logs experiments| MLflow
    NBImages -->|deploys models| KServe

    %% KServe integrations
    KServe -->|fetches metadata| ModelReg
    KServe -->|monitored by| TrustyAI
    KServe -->|depends on| ServiceMesh
    KServe -->|depends on| Knative
    ModelController -->|creates Routes| KServe

    %% Training integrations
    TrainingOp -->|uses images| NBImages
    TrainerV2 -->|logs metrics| MLflow
    TrainingOp -->|logs metrics| MLflow

    %% Pipeline integrations
    DSPOp -->|orchestrates| TrainingOp
    DSPOp -->|orchestrates| KServe
    DSPOp -->|tracks models| ModelReg

    %% Data integrations
    FeastOp -->|serves features to| TrainingOp
    FeastOp -->|serves features to| KServe

    %% External service dependencies
    KServe -->|loads models| S3
    NBImages -->|reads/writes data| S3
    DSPOp -->|stores artifacts| S3
    ModelReg -->|stores metadata| PostgreSQL
    MLflow -->|stores metadata| PostgreSQL
    DSPOp -->|stores metadata| PostgreSQL
    NBImages -->|pulls from| HuggingFace
    TrustyAI -->|downloads models| HuggingFace

    %% Platform dependencies
    KServe -->|depends on| CertMgr
    ModelRegOp -->|depends on| CertMgr
    MLflowOp -->|depends on| CertMgr
    DSPOp -->|depends on| CertMgr

