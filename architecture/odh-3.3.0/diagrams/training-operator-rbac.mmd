graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: kubeflow]
    end

    subgraph "ClusterRole Binding"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR[training-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources (API Group: '')"
        Pods[Pods]
        Services[Services]
        ConfigMaps[ConfigMaps]
        ServiceAccounts[ServiceAccounts]
        Events[Events]
    end

    subgraph "Training Job CRs (API Group: kubeflow.org)"
        PyTorchJob[PyTorchJob]
        TFJob[TFJob]
        MPIJob[MPIJob]
        JAXJob[JAXJob]
        XGBoostJob[XGBoostJob]
        PaddleJob[PaddleJob]
    end

    subgraph "Training Job Status (API Group: kubeflow.org)"
        PyTorchJobStatus[PyTorchJob/status]
        TFJobStatus[TFJob/status]
        MPIJobStatus[MPIJob/status]
        JAXJobStatus[JAXJob/status]
        XGBoostJobStatus[XGBoostJob/status]
        PaddleJobStatus[PaddleJob/status]
    end

    subgraph "Batch API (API Group: batch)"
        Jobs[Jobs]
    end

    subgraph "Autoscaling API (API Group: autoscaling)"
        HPA[HorizontalPodAutoscalers]
    end

    subgraph "Admission Registration (API Group: admissionregistration.k8s.io)"
        VWC[ValidatingWebhookConfigurations]
    end

    %% RBAC Flow
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Core API permissions
    CR -->|create, delete, get, list,<br/>patch, update, watch| Pods
    CR -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR -->|create, delete, get, list,<br/>patch, update, watch| ConfigMaps
    CR -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts
    CR -->|create, delete, get, list,<br/>patch, update, watch| Events

    %% Training job CRD permissions
    CR -->|create, delete, get, list,<br/>patch, update, watch| PyTorchJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| TFJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| MPIJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| JAXJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| XGBoostJob
    CR -->|create, delete, get, list,<br/>patch, update, watch| PaddleJob

    %% Status subresource permissions
    CR -->|get, patch, update| PyTorchJobStatus
    CR -->|get, patch, update| TFJobStatus
    CR -->|get, patch, update| MPIJobStatus
    CR -->|get, patch, update| JAXJobStatus
    CR -->|get, patch, update| XGBoostJobStatus
    CR -->|get, patch, update| PaddleJobStatus

    %% Batch API permissions
    CR -->|create, delete, get, list,<br/>patch, update, watch| Jobs

    %% Autoscaling permissions
    CR -->|create, delete, get, list,<br/>patch, update, watch| HPA

    %% Webhook configuration permissions
    CR -->|get, list, update, watch| VWC

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px

    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333

    style PyTorchJob fill:#d4a5ff,stroke:#333
    style TFJob fill:#d4a5ff,stroke:#333
    style MPIJob fill:#d4a5ff,stroke:#333
    style JAXJob fill:#d4a5ff,stroke:#333
    style XGBoostJob fill:#d4a5ff,stroke:#333
    style PaddleJob fill:#d4a5ff,stroke:#333

    style PyTorchJobStatus fill:#ffcc99,stroke:#333
    style TFJobStatus fill:#ffcc99,stroke:#333
    style MPIJobStatus fill:#ffcc99,stroke:#333
    style JAXJobStatus fill:#ffcc99,stroke:#333
    style XGBoostJobStatus fill:#ffcc99,stroke:#333
    style PaddleJobStatus fill:#ffcc99,stroke:#333

    style Jobs fill:#99ccff,stroke:#333
    style HPA fill:#99ccff,stroke:#333
    style VWC fill:#99ccff,stroke:#333
