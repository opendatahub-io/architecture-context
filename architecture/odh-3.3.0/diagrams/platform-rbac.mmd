graph TD
    subgraph "Service Accounts"
        SA_ODH[opendatahub-operator-controller-manager<br/>Namespace: opendatahub]
        SA_KServe[kserve-controller-manager<br/>Namespace: opendatahub]
        SA_Notebook[notebook-controller-service-account<br/>Namespace: opendatahub]
        SA_Training[training-operator<br/>Namespace: opendatahub]
        SA_DSP[data-science-pipelines-operator-controller-manager<br/>Namespace: opendatahub]
        SA_Dashboard[odh-dashboard<br/>Namespace: opendatahub]
        SA_ModelReg[model-registry-NAME<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB_ODH[opendatahub-operator-manager-rolebinding]
        CRB_KServe[kserve-manager-rolebinding]
        CRB_Notebook[notebook-controller-rolebinding]
        CRB_Training[training-operator-rolebinding]
        CRB_DSP[data-science-pipelines-operator-rolebinding]
    end

    subgraph "ClusterRoles"
        CR_ODH[opendatahub-operator-manager-role]
        CR_KServe[kserve-manager-role]
        CR_Notebook[notebook-controller-role]
        CR_Training[training-operator]
        CR_DSP[data-science-pipelines-operator-role]
    end

    subgraph "API Resources - Platform Orchestration"
        API_DSC[opendatahub.io<br/>DataScienceCluster<br/>DSCInitialization]
        API_Components[components.platform.opendatahub.io<br/>Dashboard, Kserve, Ray<br/>Workbenches, ModelRegistry, etc.]
        API_Services[services.platform.opendatahub.io<br/>Auth, GatewayConfig, Monitoring]
    end

    subgraph "API Resources - Model Serving"
        API_KServe[serving.kserve.io<br/>InferenceService<br/>ServingRuntime<br/>InferenceGraph<br/>LLMInferenceService]
        API_NIM[nim.opendatahub.io<br/>Account]
        API_Knative[serving.knative.dev<br/>Service, Revision, Configuration]
        API_Istio[networking.istio.io<br/>VirtualService<br/>DestinationRule]
    end

    subgraph "API Resources - Development"
        API_Notebooks[kubeflow.org<br/>Notebook]
        API_StatefulSets[apps<br/>StatefulSet]
        API_ODHDocs[dashboard.opendatahub.io<br/>OdhApplication<br/>OdhDocument]
    end

    subgraph "API Resources - Training"
        API_Training[kubeflow.org<br/>PyTorchJob, TFJob<br/>MPIJob, JAXJob<br/>XGBoostJob]
        API_Trainer[trainer.kubeflow.org<br/>TrainJob<br/>TrainingRuntime]
        API_Ray[ray.io<br/>RayCluster, RayJob<br/>RayService]
        API_Spark[sparkoperator.k8s.io<br/>SparkApplication<br/>ScheduledSparkApplication]
    end

    subgraph "API Resources - Pipelines & Data"
        API_DSPA[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
        API_Argo[argoproj.io<br/>Workflow<br/>WorkflowTemplate<br/>CronWorkflow]
        API_Feast[feast.dev<br/>FeatureStore]
    end

    subgraph "API Resources - Model Management"
        API_ModelReg[modelregistry.opendatahub.io<br/>ModelRegistry]
        API_MLflow[mlflow.opendatahub.io<br/>MLflow, MLflowConfig]
    end

    subgraph "API Resources - Core K8s"
        API_Core[Core v1<br/>Pod Service Secret<br/>ConfigMap PVC]
        API_Apps[apps v1<br/>Deployment<br/>StatefulSet]
        API_RBAC[rbac.authorization.k8s.io<br/>Role RoleBinding<br/>ClusterRole ClusterRoleBinding]
    end

    %% ServiceAccount to ClusterRoleBinding
    SA_ODH -->|bound via| CRB_ODH
    SA_KServe -->|bound via| CRB_KServe
    SA_Notebook -->|bound via| CRB_Notebook
    SA_Training -->|bound via| CRB_Training
    SA_DSP -->|bound via| CRB_DSP

    %% ClusterRoleBinding to ClusterRole
    CRB_ODH -->|grants| CR_ODH
    CRB_KServe -->|grants| CR_KServe
    CRB_Notebook -->|grants| CR_Notebook
    CRB_Training -->|grants| CR_Training
    CRB_DSP -->|grants| CR_DSP

    %% ODH Operator permissions
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_DSC
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_Components
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_Services
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_Apps
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_Core
    CR_ODH -->|get,list,watch,create,update,patch,delete| API_RBAC

    %% KServe permissions
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_KServe
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_NIM
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_Knative
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_Istio
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_Core
    CR_KServe -->|get,list,watch,create,update,patch,delete| API_Apps

    %% Notebook Controller permissions
    CR_Notebook -->|get,list,watch,create,update,patch,delete| API_Notebooks
    CR_Notebook -->|get,list,watch,create,update,patch,delete| API_StatefulSets
    CR_Notebook -->|get,list,watch,create,update,patch,delete| API_Core

    %% Training Operator permissions
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Training
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Trainer
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Ray
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Spark
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Core
    CR_Training -->|get,list,watch,create,update,patch,delete| API_Apps

    %% Data Science Pipelines permissions
    CR_DSP -->|get,list,watch,create,update,patch,delete| API_DSPA
    CR_DSP -->|get,list,watch,create,update,patch,delete| API_Argo
    CR_DSP -->|get,list,watch,create,update,patch,delete| API_Core
    CR_DSP -->|get,list,watch,create,update,patch,delete| API_Apps

    %% Dashboard (read-only mostly, creates via K8s API)
    SA_Dashboard -->|read| API_DSC
    SA_Dashboard -->|read| API_Components
    SA_Dashboard -->|create| API_Notebooks
    SA_Dashboard -->|create| API_KServe
    SA_Dashboard -->|create| API_ModelReg

    %% Styling
    style SA_ODH fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_KServe fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Notebook fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Training fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_DSP fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Dashboard fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_ModelReg fill:#4a90e2,stroke:#333,stroke-width:2px
    
    style CR_ODH fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_KServe fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Notebook fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Training fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_DSP fill:#f5a623,stroke:#333,stroke-width:2px
    
    style API_DSC fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Components fill:#7ed321,stroke:#333,stroke-width:2px
    style API_KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Notebooks fill:#7ed321,stroke:#333,stroke-width:2px
    style API_Training fill:#7ed321,stroke:#333,stroke-width:2px
    style API_DSPA fill:#7ed321,stroke:#333,stroke-width:2px
    style API_ModelReg fill:#7ed321,stroke:#333,stroke-width:2px
