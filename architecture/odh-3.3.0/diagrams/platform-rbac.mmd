graph TD
    subgraph "Platform Control Plane - opendatahub namespace"
        direction TB

        subgraph "Service Accounts"
            SA_ODH[opendatahub-operator-controller-manager]
            SA_Dashboard[odh-dashboard]
            SA_KServe[kserve-controller-manager]
            SA_ModelReg[model-registry-operator-sa]
            SA_Training[training-operator]
            SA_Notebook[notebook-controller]
            SA_DSP[data-science-pipelines-operator]
        end

        subgraph "ClusterRoleBindings"
            CRB_ODH[opendatahub-operator-manager-rolebinding]
            CRB_KServe[kserve-manager-rolebinding]
            CRB_Training[training-operator-rolebinding]
            CRB_Notebook[notebook-controller-rolebinding]
            CRB_DSP[dsp-operator-rolebinding]
        end

        subgraph "ClusterRoles"
            CR_ODH[opendatahub-operator-manager-role]
            CR_KServe[kserve-manager-role]
            CR_Training[training-operator-role]
            CR_Notebook[notebook-controller-role]
            CR_DSP[dsp-operator-role]
        end
    end

    subgraph "API Resources - Platform CRDs"
        direction TB

        subgraph "Platform Orchestration"
            DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
            DSCInit[datasciencecluster.opendatahub.io<br/>DSCInitialization]
            CompDashboard[components.platform.opendatahub.io<br/>Dashboard]
            CompKServe[components.platform.opendatahub.io<br/>Kserve]
            CompRay[components.platform.opendatahub.io<br/>Ray]
        end

        subgraph "Model Serving"
            InferSvc[serving.kserve.io<br/>InferenceService]
            ServingRuntime[serving.kserve.io<br/>ServingRuntime]
            InferGraph[serving.kserve.io<br/>InferenceGraph]
            LLMInferSvc[serving.kserve.io<br/>LLMInferenceService]
        end

        subgraph "Development"
            NotebookCR[kubeflow.org<br/>Notebook]
            StatefulSet[apps<br/>StatefulSet]
            PVC[core<br/>PersistentVolumeClaim]
        end

        subgraph "Training"
            PyTorchJob[kubeflow.org<br/>PyTorchJob]
            TFJob[kubeflow.org<br/>TensorFlowJob]
            MPIJob[kubeflow.org<br/>MPIJob]
            JAXJob[kubeflow.org<br/>JAXJob]
            XGBoostJob[kubeflow.org<br/>XGBoostJob]
            TrainJob[trainer.kubeflow.org<br/>TrainJob]
        end

        subgraph "ML Workflows"
            DSPA[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
            Workflow[argoproj.io<br/>Workflow]
        end

        subgraph "Core Resources"
            Deployment[apps<br/>Deployment]
            Service[core<br/>Service]
            ConfigMap[core<br/>ConfigMap]
            Secret[core<br/>Secret]
        end
    end

    subgraph "User Workload Service Accounts - {user-namespace}"
        SA_NotebookUser[{notebook-name}-sa<br/>No special permissions<br/>Uses user's RBAC]
        SA_InferSvc[{infer-service-name}-sa<br/>AWS IRSA annotation<br/>eks.amazonaws.com/role-arn]
        SA_TrainingJob[{pytorchjob-name}-sa<br/>AWS IRSA annotation]
    end

    subgraph "Service Mesh Authorization"
        direction TB
        PeerAuth[PeerAuthentication<br/>PERMISSIVE/STRICT<br/>mTLS enforcement]
        AuthzPolicy_KServe[AuthorizationPolicy<br/>kserve-controller-access<br/>Allow controller to predictors]
        AuthzPolicy_Notebook[AuthorizationPolicy<br/>notebook-external-access<br/>Allow notebooks to APIs]
    end

    %% ODH Operator RBAC
    SA_ODH -->|bound via| CRB_ODH
    CRB_ODH -->|grants| CR_ODH
    CR_ODH -->|create, update, delete| DSC
    CR_ODH -->|create, update, delete| DSCInit
    CR_ODH -->|create, update, delete| CompDashboard
    CR_ODH -->|create, update, delete| CompKServe
    CR_ODH -->|create, update, delete| CompRay
    CR_ODH -->|create, update, delete| Deployment
    CR_ODH -->|create, update, delete| Service
    CR_ODH -->|create, update, delete| ConfigMap

    %% KServe RBAC
    SA_KServe -->|bound via| CRB_KServe
    CRB_KServe -->|grants| CR_KServe
    CR_KServe -->|get, list, watch, create, update, patch, delete| InferSvc
    CR_KServe -->|get, list, watch, create, update, patch, delete| ServingRuntime
    CR_KServe -->|get, list, watch, create, update, patch, delete| InferGraph
    CR_KServe -->|get, list, watch, create, update, patch, delete| LLMInferSvc
    CR_KServe -->|create, update, delete| Deployment
    CR_KServe -->|create, update, delete| Service

    %% Training Operator RBAC
    SA_Training -->|bound via| CRB_Training
    CRB_Training -->|grants| CR_Training
    CR_Training -->|get, list, watch, create, update, patch, delete| PyTorchJob
    CR_Training -->|get, list, watch, create, update, patch, delete| TFJob
    CR_Training -->|get, list, watch, create, update, patch, delete| MPIJob
    CR_Training -->|get, list, watch, create, update, patch, delete| JAXJob
    CR_Training -->|get, list, watch, create, update, patch, delete| XGBoostJob
    CR_Training -->|get, list, watch, create, update, patch, delete| TrainJob
    CR_Training -->|create, delete| Deployment

    %% Notebook Controller RBAC
    SA_Notebook -->|bound via| CRB_Notebook
    CRB_Notebook -->|grants| CR_Notebook
    CR_Notebook -->|get, list, watch, create, update, patch, delete| NotebookCR
    CR_Notebook -->|create, update, delete| StatefulSet
    CR_Notebook -->|create, delete| Service
    CR_Notebook -->|create, delete| PVC

    %% DSP Operator RBAC
    SA_DSP -->|bound via| CRB_DSP
    CRB_DSP -->|grants| CR_DSP
    CR_DSP -->|get, list, watch, create, update, patch, delete| DSPA
    CR_DSP -->|get, list, watch, create, update, patch, delete| Workflow
    CR_DSP -->|create, delete| Deployment
    CR_DSP -->|create, delete| Service
    CR_DSP -->|create, delete| Secret

    %% Service Mesh AuthZ
    AuthzPolicy_KServe -.->|allows| SA_KServe
    AuthzPolicy_KServe -.->|to access| InferSvc
    AuthzPolicy_Notebook -.->|allows| SA_NotebookUser
    PeerAuth -.->|enforces mTLS on| InferSvc
    PeerAuth -.->|enforces mTLS on| NotebookCR

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,color:#fff
    classDef binding fill:#f5a623,stroke:#333,color:#333
    classDef role fill:#7ed321,stroke:#333,color:#333
    classDef resource fill:#50e3c2,stroke:#333,color:#333
    classDef authz fill:#ff6b6b,stroke:#333,color:#fff

    class SA_ODH,SA_Dashboard,SA_KServe,SA_ModelReg,SA_Training,SA_Notebook,SA_DSP,SA_NotebookUser,SA_InferSvc,SA_TrainingJob serviceAccount
    class CRB_ODH,CRB_KServe,CRB_Training,CRB_Notebook,CRB_DSP binding
    class CR_ODH,CR_KServe,CR_Training,CR_Notebook,CR_DSP role
    class DSC,DSCInit,CompDashboard,CompKServe,CompRay,InferSvc,ServingRuntime,InferGraph,LLMInferSvc,NotebookCR,StatefulSet,PVC,PyTorchJob,TFJob,MPIJob,JAXJob,XGBoostJob,TrainJob,DSPA,Workflow,Deployment,Service,ConfigMap,Secret resource
    class PeerAuth,AuthzPolicy_KServe,AuthzPolicy_Notebook authz
