graph TB
    subgraph Users["User Identities"]
        PlatformAdmin[Platform Administrator<br/>OpenShift User]
        DataScientist[Data Scientist<br/>OpenShift User]
    end

    subgraph ServiceAccounts["Service Accounts"]
        ODHOpSA[opendatahub-operator<br/>ServiceAccount]
        KServeSA[kserve-controller<br/>ServiceAccount]
        NBCtrlSA[notebook-controller<br/>ServiceAccount]
        TrainOpSA[training-operator<br/>ServiceAccount]
        DSPSA[pipelines-controller<br/>ServiceAccount]
        ModelRegSA[model-registry-controller<br/>ServiceAccount]
        TrustyAISA[trustyai-controller<br/>ServiceAccount]
        UserPodSA[default/custom<br/>ServiceAccount<br/>(Notebook/Training Pods)]
    end

    subgraph ClusterRoles["Cluster Roles (Platform-wide)"]
        ODHOpCR[odh-operator-controller<br/>ClusterRole]
        KServeCR[kserve-controller<br/>ClusterRole]
        NBCtrlCR[notebook-controller<br/>ClusterRole]
        TrainOpCR[training-operator<br/>ClusterRole]
        DSPCR[pipelines-controller<br/>ClusterRole]
        ModelRegCR[modelregistry-controller<br/>ClusterRole]
        TrustyAICR[trustyai-controller<br/>ClusterRole]
    end

    subgraph Roles["Namespace Roles"]
        UserNSRole[edit/view<br/>Role<br/>(User Namespace)]
        SparkDriverRole[spark-driver<br/>Role]
    end

    subgraph Resources["Kubernetes Resources"]
        DSC[DataScienceCluster<br/>CRD]
        ComponentCRs[Component CRs<br/>(Dashboard, KServe, Ray, etc.)]
        NotebookCRs[Notebook<br/>CRDs]
        InferenceCRs[InferenceService<br/>CRDs]
        TrainingCRs[PyTorchJob/TFJob<br/>CRDs]
        DSPACRs[DSPA<br/>CRDs]
        ModelRegCRs[ModelRegistry<br/>CRDs]
        TrustyAICRs[TrustyAIService<br/>CRDs]
        Pods[Pods]
        Services[Services]
        Deployments[Deployments]
        Secrets[Secrets]
    end

    %% User bindings
    PlatformAdmin -->|cluster-admin| DSC
    PlatformAdmin -->|cluster-admin| ComponentCRs
    DataScientist -->|edit/view| UserNSRole
    UserNSRole --> NotebookCRs
    UserNSRole --> InferenceCRs
    UserNSRole --> TrainingCRs

    %% ServiceAccount to ClusterRole bindings
    ODHOpSA -->|ClusterRoleBinding| ODHOpCR
    KServeSA -->|ClusterRoleBinding| KServeCR
    NBCtrlSA -->|ClusterRoleBinding| NBCtrlCR
    TrainOpSA -->|ClusterRoleBinding| TrainOpCR
    DSPSA -->|ClusterRoleBinding| DSPCR
    ModelRegSA -->|ClusterRoleBinding| ModelRegCR
    TrustyAISA -->|ClusterRoleBinding| TrustyAICR

    %% ClusterRole permissions (create, update, delete, list, watch)
    ODHOpCR -->|manage| DSC
    ODHOpCR -->|manage| ComponentCRs
    ODHOpCR -->|manage| Deployments

    KServeCR -->|manage| InferenceCRs
    KServeCR -->|manage| Pods
    KServeCR -->|manage| Services

    NBCtrlCR -->|manage| NotebookCRs
    NBCtrlCR -->|manage| Pods
    NBCtrlCR -->|manage| Services

    TrainOpCR -->|manage| TrainingCRs
    TrainOpCR -->|manage| Pods
    TrainOpCR -->|manage| Services

    DSPCR -->|manage| DSPACRs
    DSPCR -->|manage| Deployments
    DSPCR -->|read| Secrets

    ModelRegCR -->|manage| ModelRegCRs
    ModelRegCR -->|manage| Deployments

    TrustyAICR -->|manage| TrustyAICRs
    TrustyAICR -->|watch| InferenceCRs

    %% Workload pod permissions
    UserPodSA -->|RoleBinding| SparkDriverRole
    SparkDriverRole -->|create| Pods
    SparkDriverRole -->|list| Services

    %% Styling
    classDef userStyle fill:#50e3c2,stroke:#3baa92,stroke-width:2px,color:#000
    classDef saStyle fill:#bd10e0,stroke:#8b0ca6,stroke-width:2px,color:#fff
    classDef clusterRoleStyle fill:#4a90e2,stroke:#2e5c8a,stroke-width:3px,color:#fff
    classDef roleStyle fill:#7ed321,stroke:#5a9c18,stroke-width:2px,color:#000
    classDef resourceStyle fill:#f5a623,stroke:#b87e1a,stroke-width:2px,color:#000

    class PlatformAdmin,DataScientist userStyle
    class ODHOpSA,KServeSA,NBCtrlSA,TrainOpSA,DSPSA,ModelRegSA,TrustyAISA,UserPodSA saStyle
    class ODHOpCR,KServeCR,NBCtrlCR,TrainOpCR,DSPCR,ModelRegCR,TrustyAICR clusterRoleStyle
    class UserNSRole,SparkDriverRole roleStyle
    class DSC,ComponentCRs,NotebookCRs,InferenceCRs,TrainingCRs,DSPACRs,ModelRegCRs,TrustyAICRs,Pods,Services,Deployments,Secrets resourceStyle
