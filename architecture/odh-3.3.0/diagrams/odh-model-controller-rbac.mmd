graph TD
    subgraph "Service Account"
        SA[odh-model-controller<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[odh-model-controller-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-model-controller-role<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        Services[Services<br/>core/v1]
        ConfigMaps[ConfigMaps<br/>core/v1]
        Secrets[Secrets<br/>core/v1]
        ServiceAccounts[ServiceAccounts<br/>core/v1]
        Pods[Pods<br/>core/v1]
        Namespaces[Namespaces<br/>core/v1]
        Endpoints[Endpoints<br/>core/v1]
    end

    subgraph "KServe API Resources"
        InferenceServices[InferenceServices<br/>serving.kserve.io/v1beta1]
        ServingRuntimes[ServingRuntimes<br/>serving.kserve.io/v1alpha1]
        InferenceGraphs[InferenceGraphs<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "OpenShift/K8s Networking"
        Routes[Routes<br/>route.openshift.io/v1]
        Gateways[Gateways<br/>gateway.networking.k8s.io/v1beta1]
        HTTPRoutes[HTTPRoutes<br/>gateway.networking.k8s.io/v1beta1]
        Ingresses[Ingresses<br/>networking.k8s.io/v1]
    end

    subgraph "Security Resources"
        AuthzPolicies[AuthorizationPolicies<br/>security.istio.io/v1beta1]
    end

    subgraph "NIM Resources"
        Accounts[Accounts<br/>nim.opendatahub.io/v1]
    end

    subgraph "KEDA Resources"
        TriggerAuths[TriggerAuthentications<br/>keda.sh/v1alpha1]
        ScaledObjects[ScaledObjects<br/>keda.sh/v1alpha1]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Core API permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| Services
    CR -->|create, delete, get,<br/>list, patch, update, watch| ConfigMaps
    CR -->|create, delete, get,<br/>list, patch, update, watch| Secrets
    CR -->|create, delete, get,<br/>list, patch, update, watch| ServiceAccounts
    CR -->|create, delete, get,<br/>list, patch, update, watch| Pods
    CR -->|create, delete, get,<br/>list, patch, update, watch| Namespaces
    CR -->|create, delete, get,<br/>list, patch, update, watch| Endpoints

    %% KServe permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| InferenceServices
    CR -->|create, delete, get,<br/>list, patch, update, watch| ServingRuntimes
    CR -->|create, delete, get,<br/>list, patch, update, watch| InferenceGraphs

    %% OpenShift/K8s Networking permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| Routes
    CR -->|create, delete, get,<br/>list, patch, update, watch| Gateways
    CR -->|create, delete, get,<br/>list, patch, update, watch| HTTPRoutes
    CR -->|get, list, watch| Ingresses

    %% Security permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| AuthzPolicies

    %% NIM permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| Accounts

    %% KEDA permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| TriggerAuths
    CR -->|create, delete, get,<br/>list, patch, update, watch| ScaledObjects

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#e74c3c,stroke:#333,stroke-width:3px,color:#fff

    %% Core resources
    style Services fill:#7ed321,stroke:#333,color:#000
    style ConfigMaps fill:#7ed321,stroke:#333,color:#000
    style Secrets fill:#7ed321,stroke:#333,color:#000
    style ServiceAccounts fill:#7ed321,stroke:#333,color:#000
    style Pods fill:#7ed321,stroke:#333,color:#000
    style Namespaces fill:#7ed321,stroke:#333,color:#000
    style Endpoints fill:#7ed321,stroke:#333,color:#000

    %% KServe resources
    style InferenceServices fill:#f5a623,stroke:#333,color:#000
    style ServingRuntimes fill:#f5a623,stroke:#333,color:#000
    style InferenceGraphs fill:#f5a623,stroke:#333,color:#000

    %% Networking resources
    style Routes fill:#3498db,stroke:#333,color:#fff
    style Gateways fill:#3498db,stroke:#333,color:#fff
    style HTTPRoutes fill:#3498db,stroke:#333,color:#fff
    style Ingresses fill:#3498db,stroke:#333,color:#fff

    %% Security resources
    style AuthzPolicies fill:#e67e22,stroke:#333,color:#fff

    %% NIM resources
    style Accounts fill:#16a085,stroke:#333,color:#fff

    %% KEDA resources
    style TriggerAuths fill:#8e44ad,stroke:#333,color:#fff
    style ScaledObjects fill:#8e44ad,stroke:#333,color:#fff
