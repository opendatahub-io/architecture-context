graph TB
    subgraph External["EXTERNAL (User Access)"]
        User[User / Data Scientist / Notebook]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>Namespace: kubeflow<br/>SA: training-operator"]
    end

    subgraph Operator["OPERATOR CONTROL PLANE (Namespace: kubeflow)"]
        direction TB
        Controller["Training Operator Controller<br/>SA: training-operator<br/>ClusterRole: training-operator"]

        subgraph Reconcilers["Reconcilers"]
            PyTorchCtrl["PyTorchJob Controller"]
            TFCtrl["TFJob Controller"]
            MPICtrl["MPIJob Controller"]
            JAXCtrl["JAXJob Controller"]
            XGBoostCtrl["XGBoostJob Controller"]
            PaddleCtrl["PaddleJob Controller"]
        end

        Controller --> Reconcilers
    end

    subgraph Workloads["TRAINING WORKLOADS (Namespace: {user-namespace})"]
        direction TB

        subgraph PyTorchJob["PyTorchJob"]
            Master["Master Pod<br/>Service: {job}-master-0<br/>23456/TCP TCP plaintext"]
            Workers["Worker Pods<br/>Service: {job}-worker-n<br/>23456/TCP TCP plaintext"]
            Master <-->|TCP/23456<br/>plaintext| Workers
        end

        subgraph TFJob["TFJob"]
            Chief["Chief Pod<br/>Coordinates training"]
            TFWorkers["Worker Pods<br/>Compute gradients"]
            PS["Parameter Server Pods<br/>2222/TCP gRPC plaintext"]
            Chief <-->|gRPC/2222<br/>plaintext| PS
            TFWorkers <-->|gRPC/2222<br/>plaintext| PS
        end

        subgraph MPIJob["MPIJob"]
            Launcher["Launcher Pod<br/>Initiates SSH"]
            MPIWorkers["MPI Worker Pods<br/>Execute training"]
            Launcher -->|SSH/22<br/>SSH key auth| MPIWorkers
            MPIWorkers <-->|Dynamic TCP/UDP<br/>plaintext| MPIWorkers
        end
    end

    subgraph ExternalServices["EGRESS - EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth"]
        PyPI["PyPI / pip Index<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph InternalServices["EGRESS - INTERNAL ODH SERVICES"]
        ModelReg["Model Registry API<br/>8080/TCP HTTP<br/>Bearer Token"]
        MLFlow["MLFlow Server<br/>5000/TCP HTTP<br/>No auth"]
    end

    subgraph Monitoring["METRICS & MONITORING"]
        Metrics["Training Operator Metrics<br/>Service: training-operator-metrics<br/>8080/TCP HTTP<br/>Internal only"]
    end

    %% User flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>Webhook cert mTLS| Webhook
    K8sAPI -->|Watch CRs<br/>ServiceAccount Token| Controller

    %% Operator creates resources
    Controller -->|HTTPS/6443<br/>Create Pods/Services<br/>ServiceAccount Token| K8sAPI

    %% Training job egress
    Workers -->|HTTPS/443<br/>TLS 1.2+<br/>AWS credentials| S3
    TFWorkers -->|HTTPS/443<br/>TLS 1.2+<br/>AWS credentials| S3
    MPIWorkers -->|HTTPS/443<br/>TLS 1.2+<br/>AWS credentials| S3

    Workers -->|HTTPS/443<br/>TLS 1.2+<br/>Token| Registry

    Master -->|HTTP/8080<br/>Bearer Token| ModelReg
    Workers -->|HTTP/5000<br/>No auth| MLFlow

    Workers -->|HTTPS/443<br/>TLS 1.2+| PyPI

    %% Metrics
    Controller -->|Expose| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0277bd,stroke-width:2px
    classDef operator fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    classDef workloads fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    classDef externalservice fill:#ffccbc,stroke:#d84315,stroke-width:2px
    classDef internalservice fill:#d1c4e9,stroke:#512da8,stroke-width:2px
    classDef monitoring fill:#b2dfdb,stroke:#00695c,stroke-width:2px

    class User external
    class K8sAPI,Webhook controlplane
    class Controller,Reconcilers,PyTorchCtrl,TFCtrl,MPICtrl,JAXCtrl,XGBoostCtrl,PaddleCtrl operator
    class Master,Workers,Chief,TFWorkers,PS,Launcher,MPIWorkers workloads
    class S3,Registry,PyPI externalservice
    class ModelReg,MLFlow internalservice
    class Metrics monitoring
