graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients[External Clients<br/>Web Browsers, API Clients]
    end

    subgraph Ingress["INGRESS (DMZ) - OpenShift Routes & Gateways"]
        Dashboard_GW["ODH Dashboard Route<br/>443/TCP → 8443/TCP<br/>HTTPS, TLS 1.2+ (reencrypt)<br/>Auth: OAuth"]
        Notebook_GW["Notebook Routes<br/>{notebook}-{ns}.{domain}<br/>443/TCP → notebook-port<br/>HTTPS, TLS 1.2+ (edge/reencrypt)<br/>Auth: OAuth Proxy"]
        MLflow_GW["MLflow Istio Gateway<br/>mlflow.apps.*<br/>443/TCP → 5000/TCP<br/>HTTPS, TLS 1.2+<br/>Auth: Bearer Token"]
        Feast_GW["Feast UI Route<br/>{name}-feast-ui-route<br/>443/TCP → 80/TCP<br/>HTTPS, TLS 1.2+ (edge)<br/>Auth: Optional OIDC"]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional mTLS - PERMISSIVE/STRICT)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>Ports: 8080/8443"]
        end

        subgraph NS_Apps["Namespace: redhat-ods-applications"]
            NotebookCtrl["Notebook Controller<br/>SA: notebook-controller<br/>Ports: 8080/8081"]
        end

        subgraph NS_User["Namespace: {user-namespaces}"]
            Notebooks["Notebook Pods<br/>SA: {notebook-name}<br/>Ports: configurable"]
            MLflowSvc["MLflow Service<br/>SA: mlflow<br/>Port: 5000/TCP"]
            FeastSvc["Feast Services<br/>SA: feast<br/>Ports: 80/6566/6570/6572"]
        end

        subgraph NS_Operator["Namespace: opendatahub-operator-system"]
            ODHOp["ODH Operator<br/>SA: controller-manager<br/>Ports: 8080/9443"]
        end
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>AWS IAM<br/>Purpose: Model artifacts,<br/>MLflow artifacts,<br/>Feast registry"]
        PG["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Purpose: MLflow metadata,<br/>Feast offline store"]
        RedisDB["Redis<br/>6379/TCP<br/>TLS (optional)<br/>Purpose: Feast online store"]
        BQ["BigQuery<br/>443/TCP HTTPS<br/>Purpose: Feast offline store"]
        Quay["Container Registry<br/>quay.io<br/>443/TCP HTTPS<br/>Pull secrets<br/>Purpose: Component images,<br/>notebook images"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA tokens<br/>Purpose: CR management,<br/>reconciliation"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443| Dashboard_GW
    Clients -->|HTTPS/443| Notebook_GW
    Clients -->|HTTPS/443| MLflow_GW
    Clients -->|HTTPS/443| Feast_GW

    %% Ingress to Service Mesh
    Dashboard_GW -->|HTTPS/8443<br/>OAuth proxy| Dashboard
    Notebook_GW -->|HTTP/notebook-port<br/>OAuth proxy| Notebooks
    MLflow_GW -->|HTTP/5000<br/>Bearer token| MLflowSvc
    Feast_GW -->|HTTP/80<br/>Optional OIDC| FeastSvc

    %% Dashboard Internal Communications
    Dashboard -->|REST API<br/>SA token| K8sAPI
    Dashboard -->|Creates Notebook CRs<br/>SA token| K8sAPI

    %% Notebook Controller Internal Communications
    NotebookCtrl -->|CR reconciliation<br/>SA token| K8sAPI
    NotebookCtrl -->|Creates OAuth clients<br/>SA token| K8sAPI

    %% ODH Operator Internal Communications
    ODHOp -->|Deploys components<br/>SA token| K8sAPI
    ODHOp -->|Pulls images<br/>Pull secrets| Quay

    %% MLflow External Dependencies
    MLflowSvc -->|Metadata storage<br/>TLS 1.2+| PG
    MLflowSvc -->|Artifact storage<br/>HTTPS/443<br/>AWS IAM| S3
    MLflowSvc -->|RBAC checks<br/>SA token| K8sAPI

    %% Feast External Dependencies
    FeastSvc -->|Online store<br/>TLS optional| RedisDB
    FeastSvc -->|Online store<br/>TLS 1.2+| PG
    FeastSvc -->|Offline store<br/>HTTPS/443| BQ
    FeastSvc -->|Registry backend<br/>HTTPS/443<br/>AWS IAM| S3
    FeastSvc -->|Metrics<br/>SA token| K8sAPI

    %% Notebook External Dependencies
    Notebooks -->|User-initiated<br/>HTTP/HTTPS| S3
    Notebooks -->|Image pulls<br/>HTTPS/443| Quay
    Notebooks -->|MLflow tracking<br/>HTTP/5000| MLflowSvc
    Notebooks -->|Feature retrieval<br/>gRPC/6566| FeastSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Clients external
    class Dashboard_GW,Notebook_GW,MLflow_GW,Feast_GW ingress
    class Dashboard,NotebookCtrl,Notebooks,MLflowSvc,FeastSvc,ODHOp servicemesh
    class S3,PG,RedisDB,BQ,Quay,K8sAPI egress
