graph TB
    subgraph "Open Data Hub Operator"
        Manager[Controller Manager<br/>Deployment - 3 replicas<br/>Leader Election]
        Webhook[Webhook Server<br/>Port 9443/TCP<br/>TLS cert-manager]
        ManifestEngine[Manifest Engine<br/>Kustomize + Helm]

        Manager -->|validates/mutates| Webhook
        Manager -->|renders| ManifestEngine

        subgraph "Component Controllers"
            Dashboard[Dashboard Controller]
            KServe[KServe Controller]
            DSP[Data Science Pipelines]
            Ray[Ray Controller]
            Training[Training Operator]
            ModelReg[Model Registry]
            TrustyAI[TrustyAI Controller]
            Workbenches[Workbenches Controller]
            Feast[Feast Operator]
            MLflow[MLflow Operator]
            Spark[Spark Operator]
            Trainer[Trainer Controller]
            MaaS[Models as Service]
        end

        subgraph "Service Controllers"
            Auth[Auth Service]
            Gateway[Gateway Config]
            Monitor[Monitoring Service]
        end

        Manager -->|reconciles| Dashboard
        Manager -->|reconciles| KServe
        Manager -->|reconciles| DSP
        Manager -->|reconciles| Ray
        Manager -->|reconciles| Training
        Manager -->|reconciles| ModelReg
        Manager -->|reconciles| TrustyAI
        Manager -->|reconciles| Workbenches
        Manager -->|reconciles| Feast
        Manager -->|reconciles| MLflow
        Manager -->|reconciles| Spark
        Manager -->|reconciles| Trainer
        Manager -->|reconciles| MaaS
        Manager -->|reconciles| Auth
        Manager -->|reconciles| Gateway
        Manager -->|reconciles| Monitor
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        CompCRDs[Component CRDs<br/>components.platform.opendatahub.io]
        SvcCRDs[Service CRDs<br/>services.platform.opendatahub.io]
    end

    subgraph "External Platform Dependencies"
        K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS mTLS]
        OLM[Operator Lifecycle Manager<br/>Subscription/OperatorGroup]
        CertMgr[cert-manager<br/>Certificate/Issuer CRDs]
        ServiceMesh[Service Mesh - Istio<br/>Gateway/VirtualService CRDs]
        Prometheus[Prometheus Operator<br/>ServiceMonitor CRDs]
    end

    subgraph "Deployed Components"
        DashboardOp[ODH Dashboard]
        KServeOp[KServe Operator]
        DSPOp[DS Pipelines Operator]
        RayOp[Kuberay Operator]
        TrainingOp[Training Operator]
        ModelRegOp[Model Registry Operator]
        TrustyAIOp[TrustyAI Operator]
        NotebookCtrl[Notebook Controller]
        ModelCtrl[Model Controller]
    end

    User[User/GitOps] -->|creates/updates| DSC
    User -->|creates/updates| DSCI
    DSC -->|watched by| Manager
    DSCI -->|watched by| Manager
    CompCRDs -->|watched by| Manager
    SvcCRDs -->|watched by| Manager

    Manager -->|REST API| K8sAPI
    Manager -->|creates| OLM
    Manager -->|creates| CertMgr
    Manager -->|configures| ServiceMesh
    Manager -->|configures| Prometheus

    Dashboard -->|deploys manifests| DashboardOp
    KServe -->|deploys operator| KServeOp
    DSP -->|deploys operator| DSPOp
    Ray -->|deploys operator| RayOp
    Training -->|deploys operator| TrainingOp
    ModelReg -->|deploys operator| ModelRegOp
    TrustyAI -->|deploys operator| TrustyAIOp
    Workbenches -->|deploys manifests| NotebookCtrl
    Manager -->|deploys operator| ModelCtrl

