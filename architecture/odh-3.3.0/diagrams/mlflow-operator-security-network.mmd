graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser / Notebook Pod]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Gateway HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>Bearer Token Forwarding"]
    end

    subgraph ServiceMesh["SERVICE MESH (Internal)"]
        direction TB

        subgraph NS_MLflow["Namespace: opendatahub / redhat-ods-applications"]
            MLflowService["MLflow Service<br/>ClusterIP<br/>8443/TCP HTTPS"]
            MLflowPod["MLflow Pod<br/>SA: mlflow<br/>Port: 8443/TCP<br/>TLS: service-ca cert<br/>Auth: kubernetes-auth"]
            OperatorPod["MLflow Operator Pod<br/>SA: mlflow-operator<br/>Port: 8080/TCP HTTP"]
        end

        MLflowService --> MLflowPod
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph Database["DATABASE TIER"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP<br/>TLS 1.2+ optional<br/>Password Auth"]
        MySQL["MySQL Database - Alternative<br/>3306/TCP<br/>TLS 1.2+ optional<br/>Password Auth"]
        SQLite["SQLite - Dev Mode<br/>File-based<br/>No network"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP, 9000/TCP, 8333/TCP<br/>HTTPS TLS 1.2+<br/>AWS Credentials"]
        DNS["DNS Servers<br/>53/UDP, 53/TCP<br/>No encryption"]
        ServiceCA["OpenShift service-ca<br/>Auto TLS cert provisioning"]
    end

    %% User to Gateway
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie/Bearer Token| Gateway

    %% Gateway to MLflow
    Gateway -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MLflowService

    %% MLflow to K8s API (Auth)
    MLflowPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SubjectAccessReview<br/>ServiceAccount Token| K8sAPI

    %% MLflow to Database
    MLflowPod -->|PostgreSQL/5432<br/>TLS 1.2+ optional<br/>Username/Password| PostgreSQL
    MLflowPod -.->|MySQL/3306<br/>TLS 1.2+ optional<br/>Username/Password| MySQL
    MLflowPod -.->|File I/O<br/>Local storage| SQLite

    %% MLflow to S3
    MLflowPod -->|HTTPS/443,9000,8333<br/>TLS 1.2+<br/>AWS_ACCESS_KEY_ID| S3

    %% MLflow to DNS
    MLflowPod -->|DNS/53<br/>UDP/TCP<br/>Hostname resolution| DNS

    %% Operator to K8s API
    OperatorPod -->|HTTPS/6443<br/>TLS 1.2+<br/>Watch CRs, Create Resources<br/>ServiceAccount Token| K8sAPI

    %% service-ca to TLS Secret
    ServiceCA -.->|Auto-provision TLS cert<br/>90d rotation| MLflowPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class MLflowService,MLflowPod,OperatorPod servicemesh
    class K8sAPI k8s
    class PostgreSQL,MySQL,SQLite database
    class S3,DNS,ServiceCA externalservice
