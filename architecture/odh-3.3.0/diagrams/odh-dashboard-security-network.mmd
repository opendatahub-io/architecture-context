graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>OpenShift Identity"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Proxy["kube-rbac-proxy<br/>SA: odh-dashboard<br/>8443/TCP HTTPS<br/>Cert: dashboard-proxy-tls<br/>AuthN: OAuth Bearer<br/>AuthZ: OpenShift RBAC"]
            Backend["ODH Dashboard Backend<br/>Node.js/Fastify<br/>SA: odh-dashboard<br/>8080/TCP HTTP<br/>Health: /api/health"]
        end
    end

    subgraph BackendServices["BACKEND SERVICES"]
        direction TB

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prom["Prometheus Service<br/>9091/TCP HTTP<br/>Bearer Token"]
        end

        ModelRegSvc["Model Registry Service<br/>8080/TCP HTTP<br/>Bearer Token"]
    end

    subgraph NetworkPolicy["Network Policy: odh-dashboard-allow-ports"]
        direction LR
        NPIngress["Ingress: 8443/TCP<br/>From: OpenShift ingress<br/>+ same namespace"]
        NPEgress["Egress: Not restricted"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|OAuth Challenge<br/>HTTPS/443| OAuth
    OAuth -->|Bearer Token<br/>Cookie| User
    User -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| Proxy
    Proxy -->|HTTP/8080<br/>Localhost<br/>X-Auth-Request-User| Backend
    Backend -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Backend -->|HTTP/9091<br/>Bearer Token| Prom
    Backend -->|HTTP/8080<br/>Bearer Token| ModelRegSvc

    %% Network Policy enforcement
    Proxy -.->|enforced by| NPIngress
    Backend -.->|enforced by| NPEgress

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef netpol fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5

    class User external
    class Router,OAuth ingress
    class Proxy,Backend application
    class K8sAPI,Prom,ModelRegSvc backend
    class NPIngress,NPEgress netpol
