graph TB
    subgraph "Model Registry Operator"
        Operator[Model Registry Operator<br/>Go Controller]
        Controller[ModelRegistry Controller<br/>Reconciler]
        Operator -->|reconciles| Controller
    end

    subgraph "Deployed Services"
        MRService[Model Registry Service<br/>REST API + gRPC]
        DBProxy[Database Proxy<br/>Sidecar]
        OAuthProxy[OAuth Proxy<br/>Sidecar]
        MRService -.->|optional| DBProxy
        MRService -.->|optional| OAuthProxy
    end

    subgraph "Custom Resources"
        MRCRv1alpha1[ModelRegistry CR<br/>v1alpha1 - deprecated]
        MRCRv1beta1[ModelRegistry CR<br/>v1beta1]
    end

    subgraph "Created Resources"
        Deployment[Deployment]
        ServiceHTTP[Service - HTTP/8080]
        ServiceGRPC[Service - gRPC/9090]
        ServiceOAuth[Service - OAuth/8443]
        Route[OpenShift Route]
        NetworkPolicy[NetworkPolicy]
        ServiceAccount[ServiceAccount]
        RBAC[RoleBindings]
    end

    subgraph "External Dependencies"
        PostgreSQL[(PostgreSQL 13+<br/>or MySQL 8.0+)]
        OAuthService[OAuth Service]
        K8sAPI[Kubernetes API<br/>6443/TCP]
    end

    subgraph "ODH Integrations"
        Dashboard[ODH Dashboard]
        Notebooks[Notebooks]
        DSPipelines[Data Science Pipelines]
        KServe[KServe]
        TrustyAI[TrustyAI]
    end

    %% CR Flow
    User[User] -->|creates| MRCRv1beta1
    MRCRv1alpha1 -.->|deprecated| Controller
    MRCRv1beta1 -->|watched by| Controller

    %% Resource Creation
    Controller -->|creates| Deployment
    Controller -->|creates| ServiceHTTP
    Controller -->|creates| ServiceGRPC
    Controller -->|creates| ServiceOAuth
    Controller -->|creates| Route
    Controller -->|creates| NetworkPolicy
    Controller -->|creates| ServiceAccount
    Controller -->|creates| RBAC

    %% Service to Deployment
    Deployment -->|runs| MRService

    %% External Dependencies
    MRService -->|stores metadata| PostgreSQL
    OAuthProxy -->|validates tokens| OAuthService
    Controller -->|manages resources| K8sAPI

    %% ODH Integrations
    Dashboard -->|REST API| MRService
    Notebooks -->|REST API| MRService
    DSPipelines -->|REST API| MRService
    KServe -->|REST API| MRService
    TrustyAI -->|REST API| MRService

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style MRService fill:#4a90e2,stroke:#333,stroke-width:2px
    style MRCRv1beta1 fill:#f5a623,stroke:#333,stroke-width:2px
    style MRCRv1alpha1 fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style PostgreSQL fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OAuthService fill:#e8e8e8,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Notebooks fill:#7ed321,stroke:#333,stroke-width:2px
    style DSPipelines fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAI fill:#7ed321,stroke:#333,stroke-width:2px
