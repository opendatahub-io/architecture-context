graph TD
    subgraph "Service Accounts"
        SA_Operator[trustyai-operator<br/>Namespace: opendatahub]
        SA_EvalHub[evalhub-mlflow<br/>Namespace: tenant-namespaces]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Namespace: opendatahub]
        CRB_EvalHub[evalhub-mlflow-binding<br/>Namespace: tenant-namespaces]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager[manager-role]
        CR_EvalHub[evalhub-mlflow-role]
    end

    subgraph "API Resources - Core"
        Core_Pods[core/pods]
        Core_Services[core/services]
        Core_ConfigMaps[core/configmaps]
        Core_Secrets[core/secrets]
        Core_SA[core/serviceaccounts]
        Core_PVC[core/persistentvolumeclaims]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/deployments]
    end

    subgraph "API Resources - Batch"
        Batch_Jobs[batch/jobs]
    end

    subgraph "API Resources - TrustyAI CRDs"
        CRD_TrustyAIService[trustyai.opendatahub.io<br/>TrustyAIService]
        CRD_EvalHub[trustyai.opendatahub.io<br/>EvalHub]
        CRD_LMEvalJob[trustyai.opendatahub.io<br/>LMEvalJob]
        CRD_Guardrails[trustyai.opendatahub.io<br/>GuardrailsOrchestrator]
        CRD_Nemo[trustyai.opendatahub.io<br/>NemoGuardrails]
    end

    subgraph "API Resources - KServe"
        KServe_IS[serving.kserve.io<br/>InferenceService]
    end

    subgraph "API Resources - OpenShift"
        Route[route.openshift.io<br/>routes]
    end

    %% Service Account Bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_EvalHub -->|bound via| CRB_EvalHub

    %% ClusterRole Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_EvalHub -->|grants| CR_EvalHub

    %% manager-role Permissions
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_Pods
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_Services
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_ConfigMaps
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_Secrets
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_SA
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_PVC
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Apps_Deployments
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Batch_Jobs
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CRD_TrustyAIService
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CRD_EvalHub
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CRD_LMEvalJob
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CRD_Guardrails
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CRD_Nemo
    CR_Manager -->|get, list, watch| KServe_IS
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Route

    %% evalhub-mlflow-role Permissions
    CR_EvalHub -->|create, delete, get, list,<br/>patch, update, watch| Core_Secrets
    CR_EvalHub -->|create, delete, get, list,<br/>patch, update, watch| Core_SA
    CR_EvalHub -->|create, delete, get, list,<br/>patch, update, watch| Core_ConfigMaps
    CR_EvalHub -->|create, delete, get, list,<br/>patch, update, watch| Batch_Jobs

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_EvalHub fill:#f5a623,stroke:#333
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_EvalHub fill:#e8e8e8,stroke:#333

    style Core_Pods fill:#7ed321,stroke:#333
    style Core_Services fill:#7ed321,stroke:#333
    style Core_ConfigMaps fill:#7ed321,stroke:#333
    style Core_Secrets fill:#7ed321,stroke:#333
    style Core_SA fill:#7ed321,stroke:#333
    style Core_PVC fill:#7ed321,stroke:#333
    style Apps_Deployments fill:#7ed321,stroke:#333
    style Batch_Jobs fill:#7ed321,stroke:#333

    style CRD_TrustyAIService fill:#d4a5ff,stroke:#333
    style CRD_EvalHub fill:#d4a5ff,stroke:#333
    style CRD_LMEvalJob fill:#d4a5ff,stroke:#333
    style CRD_Guardrails fill:#d4a5ff,stroke:#333
    style CRD_Nemo fill:#d4a5ff,stroke:#333

    style KServe_IS fill:#ffd4a5,stroke:#333
    style Route fill:#ffd4a5,stroke:#333
