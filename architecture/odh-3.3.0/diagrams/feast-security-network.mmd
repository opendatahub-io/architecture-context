graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Application /<br/>Training Job /<br/>Stream Processing]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route / K8s Ingress<br/>443/TCP → 80/TCP<br/>TLS 1.2+ Edge Termination<br/>Auth: Bearer/OIDC"]
    end

    subgraph ServiceMesh["SERVICE MESH (Optional mTLS)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            OnlineServer["Feature Server Online<br/>SA: {name}-feast-online<br/>80:6566/TCP HTTP/gRPC<br/>Auth: Bearer Token (Optional)"]
            OfflineServer["Feature Server Offline<br/>SA: {name}-feast-offline<br/>80:8815/TCP HTTP<br/>Auth: Bearer Token (Optional)"]
            Registry["Registry Service<br/>SA: {name}-feast-registry<br/>80:6570/TCP gRPC<br/>80:6572/TCP REST<br/>Auth: None (Internal)"]
            Transform["Transformation Service<br/>SA: {name}-feast-transformation<br/>80:6569/TCP gRPC<br/>Auth: None (Internal)"]
            UI["UI Service<br/>SA: {name}-feast-ui<br/>80:8888/TCP HTTP<br/>Auth: OIDC (Optional)"]
        end

        subgraph NS_Operator["Namespace: feast-operator-system"]
            Operator["Feast Operator<br/>SA: feast-operator-controller-manager<br/>8443/TCP HTTPS<br/>Auth: Bearer Token (SA)"]
        end
    end

    subgraph Storage["STORAGE BACKENDS (Internal/External)"]
        direction TB

        OnlineDB["Online Store<br/>Redis: 6379/TCP (TLS Optional)<br/>PostgreSQL: 5432/TCP (TLS Optional)<br/>Auth: Password/AWS IAM"]
        OfflineDB["Offline Store<br/>BigQuery/Snowflake/S3<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Cloud IAM/OAuth"]
        RegistryDB["Registry Backend<br/>PostgreSQL: 5432/TCP<br/>S3/GCS: 443/TCP HTTPS<br/>Auth: User/Password/Cloud IAM"]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph Observability["OBSERVABILITY & INTEGRATION"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
        Istio["Istio Service Mesh<br/>Optional mTLS STRICT/PERMISSIVE"]
        CertManager["cert-manager<br/>TLS Certificate Provisioning"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer/OIDC| Route

    %% Ingress to Services
    Route -->|HTTP/80<br/>mTLS Optional| OnlineServer
    Route -->|HTTP/80<br/>mTLS Optional| OfflineServer
    Route -->|HTTP/80<br/>mTLS Optional| UI

    %% Service to Service
    OnlineServer -->|gRPC/6570<br/>mTLS Optional| Registry
    OfflineServer -->|gRPC/6570<br/>mTLS Optional| Registry
    OnlineServer -->|gRPC/6569<br/>mTLS Optional| Transform
    UI -->|HTTP/6572<br/>mTLS Optional| Registry

    %% Service to Storage
    OnlineServer -->|Redis/6379 or PG/5432<br/>TLS Optional<br/>Password/AWS IAM| OnlineDB
    OfflineServer -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM/OAuth| OfflineDB
    OnlineServer -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| OfflineDB
    Registry -->|PG/5432 or HTTPS/443<br/>TLS Optional/1.2+<br/>User/Password/Cloud IAM| RegistryDB

    %% Operator to K8s
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Observability
    OnlineServer -->|Metrics<br/>HTTP/8000| Prometheus
    Operator -->|Metrics<br/>HTTPS/8443<br/>Bearer Token| Prometheus
    OnlineServer -.->|Optional| Istio
    OfflineServer -.->|Optional| Istio
    Registry -.->|Optional| Istio
    Transform -.->|Optional| Istio
    UI -.->|Optional| Istio
    CertManager -.->|Provisions TLS| OnlineServer
    CertManager -.->|Provisions TLS| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class OnlineServer,OfflineServer,Registry,Transform,UI,Operator servicemesh
    class OnlineDB,OfflineDB,RegistryDB storage
    class K8sAPI k8s
    class Prometheus,Istio,CertManager observability
