graph TD
    subgraph "Authentication Mechanisms"
        OAuth[OpenShift OAuth<br/>ODH Dashboard,<br/>Kubeflow Notebooks]
        Bearer[Bearer Tokens<br/>K8s SA JWT<br/>MLflow, Dashboard API]
        mTLS[mTLS Certificates<br/>Service Mesh<br/>Optional Istio]
        OIDC[OIDC<br/>Feast UI<br/>Optional]
        SATokens[ServiceAccount Tokens<br/>All Operators<br/>K8s API Access]
        RBAC[Kubernetes RBAC<br/>SubjectAccessReview<br/>MLflow, Dashboard]
    end

    subgraph "Key ServiceAccounts & Namespaces"
        SA1["controller-manager<br/>Namespace: opendatahub-operator-system<br/>Purpose: ODH Operator"]
        SA2["odh-dashboard<br/>Namespace: opendatahub<br/>Purpose: Dashboard"]
        SA3["notebook-controller<br/>Namespace: redhat-ods-applications<br/>Purpose: Notebook Controller"]
        SA4["mlflow<br/>Namespace: {user-namespaces}<br/>Purpose: MLflow Service"]
        SA5["feast<br/>Namespace: {user-namespaces}<br/>Purpose: Feast Services"]
        SA6["{notebook-name}<br/>Namespace: {user-namespaces}<br/>Purpose: Notebook Pods"]
    end

    subgraph "ClusterRoles (High Privilege)"
        CR1["controller-manager<br/>API: datasciencecluster.odh.io/*<br/>dscinitialization.odh.io/*<br/>components.platform.odh.io/*<br/>Resources: namespaces, deployments,<br/>roles, rolebindings, secrets"]
        CR2["odh-dashboard<br/>API: kubeflow.org/notebooks<br/>modelregistry.odh.io/*<br/>feast.dev/featurestores"]
        CR3["notebook-controller-role<br/>API: kubeflow.org/notebooks/*<br/>All verbs on Notebook CRs"]
        CR4["odh-notebook-controller-mgr<br/>API: datasciencepipelinesapp.odh<br/>oauth.openshift.io/oauthclients"]
        CR5["feast-operator-manager-role<br/>API: feast.dev/featurestores<br/>apps/deployments<br/>batch/cronjobs"]
        CR6["mlflow-k8s-workspace-provider<br/>API: mlflow.kubeflow.org/*<br/>authorization.k8s.io/sar"]
    end

    subgraph "Critical Secrets"
        Secret1["opendatahub-operator-controller-<br/>webhook-cert<br/>Type: kubernetes.io/tls<br/>Rotation: 90d (cert-manager)"]
        Secret2["dashboard-proxy-tls<br/>Type: kubernetes.io/tls<br/>Purpose: kube-rbac-proxy"]
        Secret3["odh-notebook-controller-<br/>webhook-cert<br/>Type: kubernetes.io/tls<br/>Purpose: Admission webhook"]
        Secret4["{notebook-name}-oauth-config<br/>Type: Opaque<br/>Purpose: OAuth client secret<br/>per-notebook"]
        Secret5["mlflow-artifact-connection<br/>Type: Opaque<br/>Purpose: S3 credentials<br/>per-namespace"]
        Secret6["mlflow-db-credentials<br/>Type: Opaque<br/>Purpose: PostgreSQL creds"]
        Secret7["{name}-feast-secret<br/>Type: Opaque<br/>Purpose: DB credentials,<br/>API keys"]
        Secret8["{name}-feast-registry-secret<br/>Type: Opaque<br/>Purpose: S3/GCS creds"]
    end

    subgraph "Service Mesh Policies (Optional)"
        PA["PeerAuthentication<br/>Mode: PERMISSIVE/STRICT<br/>Namespace: {user-namespaces}<br/>Components: Feast, Notebooks"]
        AP1["AuthorizationPolicy<br/>feast-feature-server-access<br/>Allow: specific SAs"]
        AP2["AuthorizationPolicy<br/>notebook-endpoint-access<br/>Allow: authenticated users"]
    end

    %% ServiceAccount to ClusterRole bindings
    SA1 -->|bound to| CR1
    SA2 -->|bound to| CR2
    SA3 -->|bound to| CR3
    SA3 -->|bound to| CR4
    SA5 -->|bound to| CR5
    SA4 -->|bound to| CR6

    %% ServiceAccount to Secret usage
    SA1 -->|uses| Secret1
    SA2 -->|uses| Secret2
    SA3 -->|uses| Secret3
    SA6 -->|uses| Secret4
    SA4 -->|uses| Secret5
    SA4 -->|uses| Secret6
    SA5 -->|uses| Secret7
    SA5 -->|uses| Secret8

    %% Authentication mechanisms to ServiceAccounts
    OAuth -->|authenticates| SA2
    OAuth -->|authenticates| SA6
    Bearer -->|authenticates| SA2
    Bearer -->|authenticates| SA4
    mTLS -->|authenticates| SA5
    mTLS -->|authenticates| SA6
    OIDC -->|authenticates| SA5
    SATokens -->|used by| SA1
    SATokens -->|used by| SA2
    SATokens -->|used by| SA3
    SATokens -->|used by| SA4
    SATokens -->|used by| SA5
    RBAC -->|enforced by| SA2
    RBAC -->|enforced by| SA4

    %% Service Mesh policies
    PA -->|enforces| mTLS
    AP1 -->|allows| SA5
    AP2 -->|allows| SA6

    %% Styling
    style CR1 fill:#ff6b6b,stroke:#333,stroke-width:2px,color:#fff
    style CR3 fill:#ff6b6b,stroke:#333,stroke-width:2px,color:#fff
    style Secret4 fill:#ffd93d,stroke:#333,stroke-width:2px
    style Secret5 fill:#ffd93d,stroke:#333,stroke-width:2px
    style Secret6 fill:#ffd93d,stroke:#333,stroke-width:2px
    style Secret7 fill:#ffd93d,stroke:#333,stroke-width:2px
    style Secret8 fill:#ffd93d,stroke:#333,stroke-width:2px
    style PA fill:#6bcf7f,stroke:#333,stroke-width:2px
    style AP1 fill:#6bcf7f,stroke:#333,stroke-width:2px
    style AP2 fill:#6bcf7f,stroke:#333,stroke-width:2px
