graph TD
    subgraph "Authentication Mechanisms"
        OAuth[OpenShift OAuth<br/>ODH Dashboard, Notebooks<br/>OIDC/OAuth 2.0]
        Bearer[Bearer Tokens<br/>K8s ServiceAccount JWT<br/>MLflow API, Dashboard API]
        mTLS[mTLS Client Certs<br/>Service Mesh<br/>Optional Istio Integration]
        AWSIAM[AWS IAM<br/>S3 Access<br/>IRSA or Static Credentials]
        SATokens[ServiceAccount Tokens<br/>K8s API Access<br/>All Operators & Services]
        OIDC[OIDC<br/>Feast UI<br/>Optional Authentication]
        SubAccessReview[SubjectAccessReview<br/>K8s RBAC Validation<br/>MLflow, Dashboard]
    end

    subgraph "Key ServiceAccounts & Roles"
        SA1[controller-manager<br/>NS: opendatahub-operator-system<br/>Role: ODH Operator]
        SA2[odh-dashboard<br/>NS: opendatahub<br/>Role: Dashboard Backend]
        SA3[notebook-controller-sa<br/>NS: redhat-ods-applications<br/>Role: Notebook Controller]
        SA4[mlflow-sa<br/>NS: user-namespaces<br/>Role: MLflow Server]
        SA5[feast-sa<br/>NS: user-namespaces<br/>Role: Feast Services]
    end

    subgraph "ClusterRoles - Highly Privileged"
        CR1[controller-manager<br/>API: datasciencecluster.opendatahub.io/*<br/>API: components.platform.opendatahub.io/*<br/>Resources: namespaces, deployments,<br/>roles, secrets, configmaps<br/>Verbs: * all]
        CR2[notebook-controller-role<br/>API: kubeflow.org/notebooks<br/>API: datasciencepipelinesapplications.opendatahub.io/*<br/>API: oauth.openshift.io/oauthclients<br/>Verbs: get, list, watch, create, delete, patch, update]
        CR3[odh-dashboard<br/>API: kubeflow.org/notebooks<br/>API: modelregistry.opendatahub.io/modelregistries<br/>API: feast.dev/featurestores<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR4[manager-role<br/>Feast Operator<br/>API: feast.dev/featurestores/*<br/>Resources: deployments, cronjobs<br/>Verbs: get, list, watch, create, update, delete]
        CR5[mlflow-k8s-workspace-provider<br/>API: core/namespaces<br/>API: mlflow.kubeflow.org/mlflowconfigs<br/>API: authorization.k8s.io/subjectaccessreviews<br/>Verbs: list, watch, create]
    end

    subgraph "Critical Secrets"
        Secret1[opendatahub-operator-controller-webhook-cert<br/>Type: kubernetes.io/tls<br/>Purpose: Webhook server TLS<br/>Rotation: cert-manager managed]
        Secret2[dashboard-proxy-tls<br/>Type: kubernetes.io/tls<br/>Purpose: kube-rbac-proxy TLS<br/>Rotation: cert-manager managed]
        Secret3[notebook-name-oauth-config<br/>Type: Opaque<br/>Purpose: OAuth client secret<br/>Sensitive: Yes]
        Secret4[mlflow-artifact-connection<br/>Type: Opaque<br/>Purpose: S3 credentials<br/>Sensitive: YES - AWS keys]
        Secret5[mlflow-db-credentials<br/>Type: Opaque<br/>Purpose: PostgreSQL password<br/>Sensitive: YES - DB password]
        Secret6[feast-secret<br/>Type: Opaque<br/>Purpose: DB + API keys<br/>Sensitive: YES - Multi-credential]
        Secret7[feast-registry-secret<br/>Type: Opaque<br/>Purpose: S3/GCS credentials<br/>Sensitive: YES - Cloud credentials]
    end

    subgraph "Service Mesh Policies - Optional"
        PA[PeerAuthentication<br/>Mode: PERMISSIVE or STRICT<br/>Scope: Namespace or Workload<br/>Components: Feast, Notebooks]
        AP1[AuthorizationPolicy<br/>feast-feature-server-access<br/>Allows: Authenticated workloads<br/>Denies: External traffic]
        AP2[AuthorizationPolicy<br/>notebook-endpoint-access<br/>Allows: User ServiceAccounts<br/>Denies: Cross-namespace access]
    end

    subgraph "Webhook Security"
        WH1[opendatahub-operator-webhook<br/>Port: 443/TCP<br/>TLS: Required<br/>Validates: DataScienceCluster, DSCInit]
        WH2[odh-notebook-controller-webhook<br/>Port: 443/TCP<br/>TLS: Required<br/>Validates: Notebook CR]
        WH3[feast-operator-webhook<br/>Port: 443/TCP<br/>TLS: Required<br/>Future use]
    end

    %% ServiceAccount to ClusterRole bindings
    SA1 -->|ClusterRoleBinding| CR1
    SA2 -->|ClusterRoleBinding| CR3
    SA3 -->|ClusterRoleBinding| CR2
    SA4 -->|RoleBinding| CR5
    SA5 -->|RoleBinding| CR4

    %% ServiceAccount uses secrets
    SA1 -->|mounts| Secret1
    SA2 -->|mounts| Secret2
    SA3 -->|creates| Secret3
    SA4 -->|uses| Secret4
    SA4 -->|uses| Secret5
    SA5 -->|uses| Secret6
    SA5 -->|uses| Secret7

    %% Authentication mechanism usage
    OAuth -->|authenticates| SA2
    OAuth -->|authenticates| SA3
    Bearer -->|validates via| SubAccessReview
    Bearer -->|used by| SA4
    AWSIAM -->|used by| SA4
    AWSIAM -->|used by| SA5
    SATokens -->|used by| SA1
    SATokens -->|used by| SA2
    SATokens -->|used by| SA3
    mTLS -->|enforced by| PA
    OIDC -->|authenticates| SA5

    %% Service Mesh policy enforcement
    PA -->|applied to| SA5
    AP1 -->|protects| SA5
    AP2 -->|protects| SA3

    %% Webhook security
    WH1 -->|uses cert| Secret1
    WH2 -->|uses cert| Secret2

    %% Styling
    style CR1 fill:#ff6b6b,stroke:#333,stroke-width:3px,color:#fff
    style CR2 fill:#ff6b6b,stroke:#333,stroke-width:2px,color:#fff
    style Secret4 fill:#ffd93d,stroke:#333,stroke-width:3px
    style Secret5 fill:#ffd93d,stroke:#333,stroke-width:3px
    style Secret6 fill:#ffd93d,stroke:#333,stroke-width:3px
    style Secret7 fill:#ffd93d,stroke:#333,stroke-width:3px
    style PA fill:#6bcf7f,stroke:#333
    style AP1 fill:#6bcf7f,stroke:#333
    style AP2 fill:#6bcf7f,stroke:#333
    style SubAccessReview fill:#4a90e2,stroke:#333
    style WH1 fill:#d3d3d3,stroke:#333
    style WH2 fill:#d3d3d3,stroke:#333
