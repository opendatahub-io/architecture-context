graph TB
    subgraph "Llama Stack Operator"
        LLAMA[Llama Stack<br/>Kubernetes Operator<br/>v0.0.1]
    end

    subgraph "External Dependencies"
        K8S[Kubernetes<br/>v1.24+<br/>Required]
        OLLAMA_DEP[Ollama<br/>latest<br/>Optional<br/>Lightweight Inference]
        VLLM_DEP[vLLM<br/>latest<br/>Optional<br/>GPU Inference]
        HF[Hugging Face Hub<br/>Optional<br/>Model Downloads]
        STORAGE[Persistent Storage<br/>Required<br/>PVC]
    end

    subgraph "Internal ODH Dependencies"
        ODH[ODH Operator<br/>DataScienceCluster<br/>CRD Management]
        KSERVE[KServe<br/>Alternative LLM Serving]
        MR[Model Registry<br/>Model Tracking<br/>Future]
    end

    %% External Dependencies
    LLAMA -->|requires| K8S
    LLAMA -.->|optional backend| OLLAMA_DEP
    LLAMA -.->|optional backend| VLLM_DEP
    LLAMA -.->|downloads models| HF
    LLAMA -->|requires| STORAGE

    %% Internal ODH Dependencies
    ODH -->|manages| LLAMA
    KSERVE -.->|alternative to| LLAMA
    MR -.->|future integration| LLAMA

    %% Styling
    style LLAMA fill:#326CE5,stroke:#fff,color:#fff
    style K8S fill:#326CE5,stroke:#fff,color:#fff
    style OLLAMA_DEP fill:#4285F4,stroke:#fff,color:#fff
    style VLLM_DEP fill:#34A853,stroke:#fff,color:#fff
    style HF fill:#FFD21E,stroke:#000,color:#000
    style STORAGE fill:#0078D7,stroke:#fff,color:#fff
    style ODH fill:#0066CC,stroke:#fff,color:#fff
    style KSERVE fill:#0066CC,stroke:#fff,color:#fff
    style MR fill:#0066CC,stroke:#fff,color:#fff
