graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist]
    end

    subgraph K8sAPI["KUBERNETES API SERVER"]
        API["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: kubeflow)"]
        direction TB

        Webhook["Trainer Webhook Server<br/>9443/TCP HTTPS TLS 1.2+<br/>SA: trainer-controller-manager<br/>Secret: trainer-webhook-cert"]

        Controller["Trainer Controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>SA: trainer-controller-manager"]

        JobSetCtrl["JobSet Controller<br/>Creates Worker Pods"]
    end

    subgraph TrainingWorkload["TRAINING WORKLOAD (Namespace: {user-namespace})"]
        direction TB

        subgraph MasterNode["Master Pod (Rank 0)"]
            Master["Master Pod<br/>SA: {trainjob-name}-sa<br/>Service: {trainjob}-node-0<br/>Port: 23456/TCP"]
        end

        subgraph WorkerNodes["Worker Pods (Rank 1-N)"]
            Workers["Worker Pods<br/>SA: {trainjob-name}-sa<br/>Service: {trainjob}-node-n<br/>Port: 23456/TCP"]
        end

        NetworkPolicy["NetworkPolicy<br/>Allow inter-worker: 23456/TCP<br/>Allow egress to external services"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]

        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+ Token"]

        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+ Token"]

        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+"]

        ModelRegistry["Model Registry<br/>8080/TCP HTTP<br/>⚠️ No encryption<br/>Bearer Token"]
    end

    %% User to API
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| API

    %% API to Webhook
    API -->|"HTTPS/9443<br/>TLS 1.2+<br/>Webhook cert (mTLS)"| Webhook

    %% API to Controller
    API <-->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| Controller

    %% Controller to JobSet
    Controller -->|Creates| JobSetCtrl

    %% JobSet creates pods
    JobSetCtrl -->|Creates| Master
    JobSetCtrl -->|Creates| Workers

    %% Inter-worker communication
    Master <-->|"TCP/23456<br/>⚠️ PLAINTEXT<br/>No auth<br/>DeepSpeed/PyTorch"| Workers

    %% NetworkPolicy enforcement
    NetworkPolicy -.->|Enforces| Master
    NetworkPolicy -.->|Enforces| Workers

    %% Worker pods to external services
    Master -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3
    Workers -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3

    Master -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HuggingFace
    Workers -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HuggingFace

    Master -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Token"| Registry
    Workers -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Token"| Registry

    Workers -->|"HTTPS/443<br/>TLS 1.2+"| PyPI

    Master -->|"HTTP/8080<br/>⚠️ No encryption<br/>Bearer Token"| ModelRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef training fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class API k8sapi
    class Webhook,Controller,JobSetCtrl controlplane
    class Master,Workers,NetworkPolicy training
    class S3,HuggingFace,Registry,PyPI externalservice
    class ModelRegistry warning
