graph TB
    subgraph Internet["External Network"]
        User[Data Scientist<br/>OAuth Bearer Token]
        Client[External Client<br/>API Requests]
        S3[S3 Storage<br/>HTTPS/443<br/>AWS IAM]
        PyPI[PyPI<br/>HTTPS/443]
        HF[HuggingFace<br/>HTTPS/443<br/>API Keys]
        Registry[Container Registry<br/>HTTPS/443<br/>Token Auth]
    end

    subgraph OpenShift["OpenShift Cluster"]
        subgraph ControlPlaneNS["opendatahub namespace<br/>(Control Plane)"]
            Dashboard[odh-dashboard<br/>OAuth Proxy<br/>kube-rbac-proxy]
            Operator[opendatahub-operator<br/>ServiceAccount RBAC]
        end

        subgraph IstioNS["istio-system namespace<br/>(Service Mesh)"]
            Istio[Istio Control Plane<br/>mTLS PERMISSIVE/STRICT<br/>AuthZ Policies]
        end

        subgraph KnativeNS["knative-serving namespace<br/>(Serverless Platform)"]
            Knative[Knative Serving<br/>Queue Proxy]
        end

        subgraph UserNS["User Namespaces<br/>(Data Science Workloads)"]
            Notebook[Notebook Pods<br/>ServiceAccount Token<br/>NetworkPolicy: Egress]
            InferenceService[KServe Predictor<br/>mTLS via Istio<br/>NetworkPolicy: Ingress/Egress]
            TrainingJob[Training Pods<br/>ServiceAccount Token<br/>NetworkPolicy: Egress]
        end

        subgraph Routes["OpenShift Router<br/>(Ingress)"]
            Route[Routes/HTTPRoutes<br/>TLS 1.2+ Reencrypt<br/>Edge Termination]
        end

        subgraph K8sAPI["Kubernetes API Server"]
            API[kube-apiserver<br/>HTTPS/6443<br/>Bearer Token Auth<br/>RBAC]
        end
    end

    %% External access
    User -->|HTTPS/443<br/>OAuth| Route
    Client -->|HTTPS/443| Route
    Route -->|TLS Reencrypt| Dashboard
    Route -->|TLS Passthrough| InferenceService

    %% Workload egress
    Notebook -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Creds| S3
    Notebook -->|HTTPS/443| PyPI
    Notebook -->|HTTPS/443<br/>API Keys| HF
    InferenceService -->|HTTPS/443<br/>AWS Creds| S3
    TrainingJob -->|HTTPS/443<br/>AWS Creds| S3
    TrainingJob -->|HTTPS/443| PyPI
    TrainingJob -->|HTTPS/443<br/>API Keys| HF

    %% Image pulls
    Operator -->|HTTPS/443<br/>Token| Registry
    Notebook -->|HTTPS/443<br/>Token| Registry

    %% Service mesh
    Istio -.->|mTLS<br/>AuthZ| InferenceService
    Istio -.->|mTLS| Notebook

    %% API access
    Dashboard -->|HTTPS/6443<br/>ServiceAccount Token<br/>RBAC| API
    Operator -->|HTTPS/6443<br/>ServiceAccount Token<br/>ClusterRole| API
    Notebook -->|HTTPS/6443<br/>ServiceAccount Token<br/>Role| API
    InferenceService -->|HTTPS/6443<br/>ServiceAccount Token| API

    %% Styling
    classDef external fill:#e0e0e0,stroke:#999,stroke-width:2px,color:#000
    classDef controlPlane fill:#4a90e2,stroke:#2e5c8a,stroke-width:3px,color:#fff
    classDef mesh fill:#9b59b6,stroke:#6c3483,stroke-width:2px,color:#fff
    classDef workload fill:#50e3c2,stroke:#3baa92,stroke-width:2px,color:#000
    classDef ingress fill:#e74c3c,stroke:#c0392b,stroke-width:2px,color:#fff
    classDef api fill:#f39c12,stroke:#d68910,stroke-width:2px,color:#000

    class User,Client,S3,PyPI,HF,Registry external
    class Dashboard,Operator controlPlane
    class Istio,Knative mesh
    class Notebook,InferenceService,TrainingJob workload
    class Route ingress
    class API api
