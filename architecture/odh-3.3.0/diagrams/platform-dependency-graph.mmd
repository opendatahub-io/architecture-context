graph TB
    subgraph "Core Platform Services"
        K8sAPI[Kubernetes API Server<br/>Resource Management]
        OCP_OAuth[OpenShift OAuth<br/>User Authentication]
        Prometheus[Prometheus<br/>Monitoring]
        OLM[Operator Lifecycle Manager<br/>Operator Installation]
    end

    subgraph "ODH Central Control Plane"
        ODHOp[OpenDataHub Operator<br/>v3.3.0<br/>Central Platform Management]
    end

    subgraph "Platform Services"
        Dashboard[ODH Dashboard<br/>v3.4.0EA1<br/>Unified Web UI]
        NotebookCtrl[Kubeflow Notebook Controllers<br/>v1.7.0-15-519<br/>Workbench Lifecycle]
    end

    subgraph "ML Lifecycle Services"
        MLflow[MLflow<br/>v3.10.1<br/>Experiment Tracking & Model Registry]
        Feast[Feast<br/>v0.61.0<br/>Feature Store]
    end

    subgraph "External Storage"
        PostgreSQL[(PostgreSQL<br/>Metadata Storage)]
        Redis[(Redis<br/>Online Store)]
        S3[S3-compatible Storage<br/>Artifacts & Models]
        BigQuery[BigQuery<br/>Offline Store]
    end

    subgraph "External Services"
        Istio[Istio Gateway<br/>Service Mesh<br/>Optional]
        Routes[OpenShift Routes<br/>Ingress]
        Registry[Container Registries<br/>quay.io]
    end

    %% Central Operator Dependencies
    ODHOp -->|deploys manifests| Dashboard
    ODHOp -->|deploys manifests| NotebookCtrl
    ODHOp -->|deploys operator| MLflow
    ODHOp -->|deploys operator| Feast
    ODHOp -->|creates Subscriptions| OLM
    ODHOp -->|pulls images| Registry
    ODHOp -->|reconciles CRs| K8sAPI

    %% Dashboard Dependencies
    Dashboard -->|CR management| K8sAPI
    Dashboard -->|creates/manages| NotebookCtrl
    Dashboard -->|user auth| OCP_OAuth
    Dashboard -->|metrics queries| Prometheus
    Dashboard -->|manages FeatureStore CRs| Feast

    %% Notebook Controller Dependencies
    NotebookCtrl -->|CR reconciliation| K8sAPI
    NotebookCtrl -->|creates OAuth clients| OCP_OAuth
    NotebookCtrl -->|external access| Routes
    NotebookCtrl -->|injects Feast config| Feast
    NotebookCtrl -->|optional routing| Istio

    %% MLflow Dependencies
    MLflow -->|metadata storage| PostgreSQL
    MLflow -->|artifact storage| S3
    MLflow -->|namespace watch & RBAC| K8sAPI
    MLflow -->|external HTTPS| Istio

    %% Feast Dependencies
    Feast -->|online/offline stores| PostgreSQL
    Feast -->|online store| Redis
    Feast -->|registry & offline| S3
    Feast -->|offline store| BigQuery
    Feast -->|optional mTLS & auth| Istio
    Feast -->|external access| Routes
    Feast -->|metrics| Prometheus

    %% Notebook to ML Services
    NotebookCtrl -.->|experiment tracking| MLflow
    NotebookCtrl -.->|feature retrieval| Feast

    %% Kubernetes API as central hub
    K8sAPI -->|serves| ODHOp
    K8sAPI -->|serves| Dashboard
    K8sAPI -->|serves| NotebookCtrl
    K8sAPI -->|serves| MLflow
    K8sAPI -->|serves| Feast

    %% Styling
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:4px
    style ODHOp fill:#ff6b6b,stroke:#333,stroke-width:4px
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:3px
    style NotebookCtrl fill:#7ed321,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style Feast fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style Redis fill:#f5a623,stroke:#333
    style BigQuery fill:#f5a623,stroke:#333
    style Istio fill:#d3d3d3,stroke:#333
    style Routes fill:#d3d3d3,stroke:#333
    style Registry fill:#d3d3d3,stroke:#333
    style OCP_OAuth fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OLM fill:#e8e8e8,stroke:#333
