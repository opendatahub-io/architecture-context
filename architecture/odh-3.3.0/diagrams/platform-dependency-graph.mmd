graph TB
    subgraph "Core Platform Services"
        K8sAPI[Kubernetes API Server<br/>Resource Management]
        OLM[Operator Lifecycle Manager<br/>Component Installation]
        OSAuth[OpenShift OAuth<br/>User Authentication]
        Istio[Istio Service Mesh<br/>Optional mTLS]
    end

    subgraph "Central Control Plane"
        ODHOperator[OpenDataHub Operator<br/>Central Component Manager]
    end

    subgraph "Platform Management"
        Dashboard[ODH Dashboard<br/>Web UI & Control Plane]
        NotebookCtrl[Kubeflow Notebook Controllers<br/>Workbench Management]
    end

    subgraph "ML Services"
        MLflow[MLflow<br/>Experiment Tracking]
        Feast[Feast<br/>Feature Store]
    end

    subgraph "External Services"
        PostgreSQL[PostgreSQL<br/>Metadata Storage]
        Redis[Redis<br/>Online Store]
        S3[S3 Storage<br/>Artifacts & Models]
        BigQuery[BigQuery<br/>Offline Store]
        Quay[Container Registry<br/>Image Pulls]
    end

    %% Central operator dependencies
    ODHOperator -->|deploys manifests| Dashboard
    ODHOperator -->|deploys manifests| NotebookCtrl
    ODHOperator -->|deploys operator| MLflow
    ODHOperator -->|deploys operator| Feast
    ODHOperator -->|creates subscriptions| OLM
    ODHOperator -->|reconciles CRs| K8sAPI

    %% Dashboard integrations
    Dashboard -->|CR management| K8sAPI
    Dashboard -->|creates Notebook CRs| NotebookCtrl
    Dashboard -->|user auth| OSAuth
    Dashboard -->|manages FeatureStore CRs| Feast
    Dashboard -->|manages ModelRegistry CRs| K8sAPI

    %% Notebook Controller integrations
    NotebookCtrl -->|CR reconciliation| K8sAPI
    NotebookCtrl -->|creates OAuth clients| OSAuth
    NotebookCtrl -->|injects Feast config| Feast
    NotebookCtrl -->|optional routing| Istio

    %% MLflow dependencies
    MLflow -->|metadata storage| PostgreSQL
    MLflow -->|artifact storage| S3
    MLflow -->|RBAC enforcement| K8sAPI
    MLflow -->|optional routing| Istio

    %% Feast dependencies
    Feast -->|online store| Redis
    Feast -->|online store| PostgreSQL
    Feast -->|offline store| BigQuery
    Feast -->|registry backend| S3
    Feast -->|optional mTLS| Istio
    Feast -->|metrics| K8sAPI

    %% External dependencies
    ODHOperator -->|component images| Quay
    NotebookCtrl -->|notebook images| Quay

    %% Styling
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OLM fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OSAuth fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Istio fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ODHOperator fill:#4a90e2,stroke:#333,stroke-width:4px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:3px
    style NotebookCtrl fill:#7ed321,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style Feast fill:#7ed321,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style Redis fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style BigQuery fill:#f5a623,stroke:#333
    style Quay fill:#f5a623,stroke:#333
