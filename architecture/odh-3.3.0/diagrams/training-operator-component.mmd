graph TB
    subgraph "Training Operator Component"
        direction TB
        Controller[Training Operator Controller<br/>Go Controller]
        PyTorchCtrl[PyTorchJob Controller<br/>Reconciler]
        TFCtrl[TFJob Controller<br/>Reconciler]
        MPICtrl[MPIJob Controller<br/>Reconciler]
        JAXCtrl[JAXJob Controller<br/>Reconciler]
        XGBoostCtrl[XGBoostJob Controller<br/>Reconciler]
        PaddleCtrl[PaddleJob Controller<br/>Reconciler]
        Webhook[Webhook Server<br/>Admission Controller<br/>9443/TCP HTTPS]
        SDK[Python SDK<br/>Client Library]

        Controller -->|manages| PyTorchCtrl
        Controller -->|manages| TFCtrl
        Controller -->|manages| MPICtrl
        Controller -->|manages| JAXCtrl
        Controller -->|manages| XGBoostCtrl
        Controller -->|manages| PaddleCtrl
        Controller -->|integrates| Webhook
    end

    subgraph "Custom Resources"
        PyTorchJobCR[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJobCR[TFJob CR<br/>kubeflow.org/v1]
        MPIJobCR[MPIJob CR<br/>kubeflow.org/v1]
        JAXJobCR[JAXJob CR<br/>kubeflow.org/v1]
        XGBoostJobCR[XGBoostJob CR<br/>kubeflow.org/v1]
        PaddleJobCR[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Master/Worker Pods]
        Services[ClusterIP Services<br/>23456/TCP]
        ConfigMaps[ConfigMaps]
        ServiceAccounts[ServiceAccounts]
    end

    subgraph "External Dependencies"
        Volcano[Volcano<br/>Gang Scheduling]
        Kueue[Kueue<br/>Job Queueing]
        S3[S3 Storage<br/>443/TCP HTTPS]
        Registry[Container Registry<br/>443/TCP HTTPS]
    end

    subgraph "Internal ODH Integrations"
        Notebooks[Notebooks<br/>Job Submission]
        Pipelines[Data Science Pipelines<br/>Pipeline Steps]
        ModelRegistry[Model Registry<br/>8080/TCP HTTP]
        Ray[Ray<br/>Hybrid Workloads]
    end

    %% User interactions
    User[User/Data Scientist] -->|creates via| SDK
    SDK -->|creates| PyTorchJobCR
    SDK -->|creates| TFJobCR
    SDK -->|creates| MPIJobCR
    Notebooks -->|submits| PyTorchJobCR
    Pipelines -->|executes| TFJobCR

    %% CR to Controller
    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    JAXJobCR -->|watched by| JAXCtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    PaddleJobCR -->|watched by| PaddleCtrl

    %% Webhook validation
    PyTorchJobCR -->|validated by| Webhook
    TFJobCR -->|validated by| Webhook
    MPIJobCR -->|validated by| Webhook

    %% Controllers create resources
    PyTorchCtrl -->|creates| Pods
    TFCtrl -->|creates| Pods
    MPICtrl -->|creates| Pods
    PyTorchCtrl -->|creates| Services
    TFCtrl -->|creates| Services
    PyTorchCtrl -->|creates| ConfigMaps
    PyTorchCtrl -->|creates| ServiceAccounts

    %% External dependencies
    Controller -.->|optional| Volcano
    Controller -.->|optional| Kueue
    Pods -->|access data| S3
    Pods -->|pull images| Registry
    Pods -->|register models| ModelRegistry

    %% Integration with Ray
    Controller -.->|coordinates| Ray

