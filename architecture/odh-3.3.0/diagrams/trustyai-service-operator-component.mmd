graph TB
    subgraph "TrustyAI Service Operator"
        Operator[TrustyAI Operator<br/>Go Controller]
        TrustyAICtrl[TrustyAIService Controller]
        EvalHubCtrl[EvalHub Controller]
        LMEvalJobCtrl[LMEvalJob Controller]
        GuardrailsCtrl[GuardrailsOrchestrator Controller]
        NemoCtrl[NemoGuardrails Controller]

        Operator -->|reconciles| TrustyAICtrl
        Operator -->|reconciles| EvalHubCtrl
        Operator -->|reconciles| LMEvalJobCtrl
        Operator -->|reconciles| GuardrailsCtrl
        Operator -->|reconciles| NemoCtrl
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1]
        EvalHubCR[EvalHub CR<br/>trustyai.opendatahub.io/v1]
        LMEvalJobCR[LMEvalJob CR<br/>trustyai.opendatahub.io/v1]
        GuardrailsCR[GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1]
        NemoCR[NemoGuardrails CR<br/>trustyai.opendatahub.io/v1]
    end

    subgraph "Deployed Services"
        TrustyAIService[TrustyAI Service<br/>8080/TCP<br/>Explainability & Fairness]
        EvalHubService[EvalHub Service<br/>8000/TCP<br/>LLM Evaluation]
        GuardrailsService[Guardrails Service<br/>8080/TCP<br/>LLM Safety]
        EvalJob[Evaluation Job Pod<br/>lm-evaluation-harness]
    end

    User[User/Dashboard] -->|creates| TrustyAIServiceCR
    User -->|creates| EvalHubCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsCR
    User -->|creates| NemoCR

    TrustyAIServiceCR -->|watched by| TrustyAICtrl
    EvalHubCR -->|watched by| EvalHubCtrl
    LMEvalJobCR -->|watched by| LMEvalJobCtrl
    GuardrailsCR -->|watched by| GuardrailsCtrl
    NemoCR -->|watched by| NemoCtrl

    TrustyAICtrl -->|creates| TrustyAIService
    EvalHubCtrl -->|creates| EvalHubService
    LMEvalJobCtrl -->|creates| EvalJob
    GuardrailsCtrl -->|creates| GuardrailsService

    subgraph "External Dependencies"
        KServe[KServe<br/>Model Serving]
        PostgreSQL[PostgreSQL 13+<br/>5432/TCP]
        MLFlow[MLFlow 2.x<br/>5000/TCP]
        HuggingFace[HuggingFace Hub<br/>443/TCP HTTPS]
        S3[S3 Storage<br/>443/TCP HTTPS]
    end

    subgraph "Internal ODH"
        ModelRegistry[Model Registry]
        Dashboard[ODH Dashboard]
        DSPipelines[Data Science Pipelines]
    end

    TrustyAIService -->|monitors| KServe
    TrustyAIService -->|persists data| PostgreSQL
    EvalHubService -->|persists data| PostgreSQL
    EvalJob -->|tracks experiments| MLFlow
    EvalJob -->|downloads models| HuggingFace
    EvalJob -->|stores datasets| S3

    TrustyAIService -->|queries metadata| ModelRegistry
    Dashboard -->|UI integration| TrustyAIService
    Dashboard -->|UI integration| EvalHubService
    DSPipelines -->|executes| EvalJob

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style TrustyAICtrl fill:#4a90e2,stroke:#333
    style EvalHubCtrl fill:#4a90e2,stroke:#333
