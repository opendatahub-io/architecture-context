graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[External Client]
        NGCAPI[NVIDIA NGC API<br/>nvcr.io]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>443/TCP to 8080/TCP<br/>TLS 1.2+ Edge Termination<br/>Optional Bearer Token"]
        GatewayAPI["Gateway HTTPRoute<br/>443/TCP TLS 1.2+"]
    end

    subgraph ServiceMesh["SERVICE MESH - mTLS STRICT"]
        direction TB

        subgraph NS_Istio["Namespace: istio-system"]
            IstioGW["Istio Gateway<br/>SA: istio-ingressgateway<br/>AuthorizationPolicy Enforcement"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            Predictor["Predictor Pod<br/>SA: inferenceservice-name-sa<br/>Image: serving-runtime-image<br/>Sidecar: Istio Envoy"]
            PredictorSvc["Service: is-predictor<br/>80/TCP to 8080/TCP HTTP<br/>81/TCP to 9000/TCP gRPC<br/>mTLS"]
        end
    end

    subgraph ControlPlane["CONTROLLER PLANE"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>Deployment: odh-model-controller-manager"]
            ControllerMetrics["Metrics Service<br/>8080/TCP HTTP<br/>Internal only"]
        end

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM Auth"]
        NGC["NVIDIA NGC API<br/>nvcr.io/api<br/>443/TCP HTTPS TLS 1.2+<br/>API Key Auth"]
        ModelReg["Model Registry API<br/>8080/TCP HTTP<br/>Bearer Token"]
    end

    %% Client flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Router
    Router -->|"HTTP/8080<br/>mTLS STRICT<br/>Service Identity"| IstioGW
    IstioGW -->|"HTTP/8080 or gRPC/9000<br/>mTLS<br/>Token + Service ID"| PredictorSvc
    PredictorSvc -->|mTLS| Predictor

    %% Alternative ingress
    Client -.->|"HTTPS/443<br/>TLS 1.2+"| GatewayAPI
    GatewayAPI -.->|mTLS| IstioGW

    %% Predictor egress
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS credentials"| S3
    Predictor -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key<br/>NIM only"| NGC

    %% Controller flows
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key<br/>NIM mgmt"| NGCAPI
    Controller -->|Integrates| ModelReg

    %% Monitoring
    Controller -->|Exposes| ControllerMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,NGCAPI external
    class Router,GatewayAPI ingress
    class IstioGW,Predictor,PredictorSvc servicemesh
    class Controller,ControllerMetrics,K8sAPI controlplane
    class S3,NGC,ModelReg externalservice
