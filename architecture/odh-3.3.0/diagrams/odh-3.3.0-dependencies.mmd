graph LR
    %% Platform Control Plane
    ODHOp[opendatahub-operator<br/>Central Control Plane]
    Dashboard[odh-dashboard<br/>Web UI]

    %% Component Operators
    KServe[kserve<br/>Model Serving]
    ModelCtrl[odh-model-controller<br/>KServe Extensions]
    ModelReg[model-registry-operator<br/>Model Versioning]
    MLflowOp[mlflow-operator<br/>Experiment Tracking]
    NBCtrl[kubeflow<br/>notebook-controller]
    NBImages[notebooks<br/>Workbench Images]
    TrainOp[training-operator<br/>Distributed Training]
    Trainer[trainer<br/>LLM Fine-tuning]
    Ray[kuberay<br/>Distributed Computing]
    Spark[spark-operator<br/>Big Data]
    Pipelines[data-science-pipelines-operator<br/>ML Workflows]
    Feast[feast<br/>Feature Store]
    TrustyAI[trustyai-service-operator<br/>AI Governance]
    LlamaStack[llama-stack-k8s-operator<br/>LLM Tools]

    %% Platform orchestration (ODH Operator manages all)
    ODHOp -->|manages lifecycle| KServe
    ODHOp -->|manages lifecycle| ModelReg
    ODHOp -->|manages lifecycle| MLflowOp
    ODHOp -->|manages lifecycle| NBCtrl
    ODHOp -->|manages lifecycle| TrainOp
    ODHOp -->|manages lifecycle| Trainer
    ODHOp -->|manages lifecycle| Ray
    ODHOp -->|manages lifecycle| Spark
    ODHOp -->|manages lifecycle| Pipelines
    ODHOp -->|manages lifecycle| Feast
    ODHOp -->|manages lifecycle| TrustyAI
    ODHOp -->|manages lifecycle| LlamaStack

    %% Dashboard integrations (creates CRs)
    Dashboard -->|creates CRs| NBCtrl
    Dashboard -->|creates CRs| KServe
    Dashboard -->|creates CRs| ModelReg
    Dashboard -->|creates CRs| MLflowOp

    %% Model serving dependencies
    ModelCtrl -->|extends| KServe
    KServe -->|links to models| ModelReg
    KServe -->|monitored by| TrustyAI

    %% Notebook integrations
    NBCtrl -->|deploys| NBImages
    NBImages -->|logs experiments| MLflowOp
    NBImages -->|reads features| Feast
    NBImages -->|registers models| ModelReg
    NBImages -->|deploys models| KServe
    NBImages -->|submits workflows| Pipelines

    %% Pipeline orchestration
    Pipelines -->|orchestrates| TrainOp
    Pipelines -->|orchestrates| Trainer
    Pipelines -->|orchestrates| KServe
    Pipelines -->|tracks models| ModelReg

    %% Training integrations
    TrainOp -->|logs metrics| MLflowOp
    Trainer -->|logs metrics| MLflowOp
    Trainer -->|registers models| ModelReg

    %% TrustyAI integrations
    TrustyAI -->|monitors| KServe
    TrustyAI -->|logs evaluations| MLflowOp

    %% LLM Stack integration
    LlamaStack -->|serves models| KServe
    LlamaStack -->|develops in| NBImages

    %% Styling
    classDef control fill:#4a90e2,stroke:#2e5c8a,stroke-width:3px,color:#fff
    classDef serving fill:#7ed321,stroke:#5a9c18,stroke-width:2px,color:#000
    classDef mgmt fill:#f5a623,stroke:#b87e1a,stroke-width:2px,color:#000
    classDef dev fill:#bd10e0,stroke:#8b0ca6,stroke-width:2px,color:#fff
    classDef training fill:#50e3c2,stroke:#3baa92,stroke-width:2px,color:#000
    classDef workflows fill:#b8e986,stroke:#8ab366,stroke-width:2px,color:#000
    classDef governance fill:#f8e71c,stroke:#b8ac15,stroke-width:2px,color:#000
    classDef llm fill:#ff6b6b,stroke:#cc5555,stroke-width:2px,color:#fff

    class ODHOp,Dashboard control
    class KServe,ModelCtrl serving
    class ModelReg,MLflowOp mgmt
    class NBCtrl,NBImages dev
    class TrainOp,Trainer,Ray,Spark training
    class Pipelines,Feast workflows
    class TrustyAI governance
    class LlamaStack llm
