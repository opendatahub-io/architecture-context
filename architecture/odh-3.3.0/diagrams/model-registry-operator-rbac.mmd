graph TD
    subgraph "Service Accounts"
        SA_Operator[model-registry-operator<br/>Namespace: opendatahub]
        SA_Registry["registry-name-sa<br/>Namespace: registry-namespace"]
        SA_User["user-serviceaccount<br/>Namespace: registry-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Namespace: opendatahub]
    end

    subgraph "Role Bindings"
        RB_Custom["custom-rolebinding<br/>Namespace: registry-namespace"]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager[manager-role]
    end

    subgraph "Role Permissions"
        R_RegistryUser["registry-user-registry-name"]
    end

    subgraph "API Resources - Core"
        Core_Services[core/services]
        Core_Secrets[core/secrets]
        Core_ConfigMaps[core/configmaps]
        Core_SA[core/serviceaccounts]
        Core_PVC[core/persistentvolumeclaims]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/deployments]
    end

    subgraph "API Resources - ModelRegistry CRDs"
        MR_CRDv1alpha1[modelregistry.opendatahub.io<br/>ModelRegistry v1alpha1]
        MR_CRDv1beta1[modelregistry.opendatahub.io<br/>ModelRegistry v1beta1]
    end

    subgraph "API Resources - OpenShift"
        Route_Routes[route.openshift.io<br/>routes]
    end

    subgraph "API Resources - Networking"
        Net_NetworkPolicies[networking.k8s.io<br/>networkpolicies]
    end

    subgraph "API Resources - Authorization"
        Auth_SAR[authorization.k8s.io<br/>subjectaccessreviews]
        Auth_TR[authorization.k8s.io<br/>tokenreviews]
    end

    %% Service Account to Bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_User -->|bound via| RB_Custom

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_Custom -->|grants| R_RegistryUser

    %% ClusterRole manager-role Permissions
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_Services
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_Secrets
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_ConfigMaps
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_SA
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Core_PVC
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Apps_Deployments
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| MR_CRDv1alpha1
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| MR_CRDv1beta1
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Route_Routes
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Net_NetworkPolicies
    CR_Manager -->|create| Auth_SAR
    CR_Manager -->|create| Auth_TR

    %% Role registry-user Permissions
    R_RegistryUser -->|get| Core_Services

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Registry fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_User fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style R_RegistryUser fill:#f5a623,stroke:#333,stroke-width:2px

    style CRB_Manager fill:#d79b00,stroke:#333,stroke-width:2px
    style RB_Custom fill:#d79b00,stroke:#333,stroke-width:2px

    style MR_CRDv1alpha1 fill:#7ed321,stroke:#333,stroke-width:2px
    style MR_CRDv1beta1 fill:#7ed321,stroke:#333,stroke-width:2px
    style Core_Services fill:#7ed321,stroke:#333,stroke-width:2px
    style Core_Secrets fill:#7ed321,stroke:#333,stroke-width:2px
    style Apps_Deployments fill:#7ed321,stroke:#333,stroke-width:2px
    style Route_Routes fill:#7ed321,stroke:#333,stroke-width:2px
    style Net_NetworkPolicies fill:#7ed321,stroke:#333,stroke-width:2px
