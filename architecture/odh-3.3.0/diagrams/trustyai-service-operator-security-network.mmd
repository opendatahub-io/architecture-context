graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External User/Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        TrustyAIRoute["OpenShift Route<br/>trustyai-route<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ Edge<br/>OAuth Proxy"]
        EvalHubRoute["OpenShift Route<br/>evalhub-route<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ Edge<br/>Bearer Token"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Operator["TrustyAI Operator<br/>SA: trustyai-operator<br/>Metrics: 8443/TCP HTTPS mTLS"]
        end

        subgraph NS_Tenant["Namespace: {tenant-namespace}"]
            direction TB

            TrustyAIService["TrustyAI Service<br/>SA: trustyai-service-sa<br/>ClusterIP: 8080/TCP<br/>HTTP, TLS 1.2+ (optional)<br/>Auth: Bearer Token"]

            EvalHubService["EvalHub Service<br/>SA: evalhub-mlflow<br/>ClusterIP: 8000/TCP<br/>HTTP, TLS 1.2+ (optional)<br/>Auth: Bearer Token + AuthZ"]

            GuardrailsService["Guardrails Service<br/>ClusterIP: 8080/TCP<br/>HTTP, TLS 1.2+ (optional)<br/>Auth: Bearer Token"]

            EvalJob["Evaluation Job Pod<br/>SA: evalhub-mlflow<br/>Type: Kubernetes Job<br/>lm-evaluation-harness"]

            PostgreSQL_TrustyAI["PostgreSQL DB<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Password Auth<br/>Purpose: Inference data"]

            PostgreSQL_EvalHub["PostgreSQL DB<br/>5432/TCP<br/>TLS 1.2+ (optional)<br/>Password Auth<br/>Purpose: Eval state"]

            KServe["KServe Model Server<br/>8080/TCP HTTP<br/>TLS 1.2+ (optional)"]
        end

        Operator -->|manages CRDs<br/>deploys services| TrustyAIService
        Operator -->|manages CRDs<br/>deploys services| EvalHubService
        Operator -->|manages CRDs<br/>creates jobs| EvalJob
        Operator -->|manages CRDs<br/>deploys services| GuardrailsService
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token Auth"]

        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]

        MLFlow["MLFlow Server<br/>5000/TCP HTTP<br/>No encryption<br/>mlflow-secret (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% Client flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token JWT| TrustyAIRoute
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token JWT| EvalHubRoute

    %% Route to services
    TrustyAIRoute -->|HTTP/8080<br/>OAuth validated| TrustyAIService
    EvalHubRoute -->|HTTP/8000<br/>Token validated| EvalHubService

    %% TrustyAI flows
    TrustyAIService -->|PostgreSQL/5432<br/>TLS 1.2+ optional<br/>Password| PostgreSQL_TrustyAI
    KServe -->|HTTP/8080<br/>TLS 1.2+ optional<br/>Bearer Token<br/>Inference data| TrustyAIService

    %% EvalHub flows
    EvalHubService -->|PostgreSQL/5432<br/>TLS 1.2+ optional<br/>Password| PostgreSQL_EvalHub

    %% Evaluation Job flows
    EvalJob -->|HTTPS/443<br/>TLS 1.2+<br/>HuggingFace Token| HuggingFace
    EvalJob -->|HTTPS/443<br/>TLS 1.2+<br/>AWS credentials| S3
    EvalJob -->|HTTP/5000<br/>No encryption| MLFlow
    EvalJob -->|HTTP/8000<br/>TLS 1.2+ optional<br/>Bearer Token| EvalHubService

    %% Monitoring
    Prometheus -->|HTTPS/8443<br/>mTLS<br/>kube-rbac-proxy| Operator
    Prometheus -->|HTTP/8080| TrustyAIService
    Prometheus -->|HTTP/8000| EvalHubService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterInternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class TrustyAIRoute,EvalHubRoute ingress
    class Operator,TrustyAIService,EvalHubService,GuardrailsService,EvalJob,PostgreSQL_TrustyAI,PostgreSQL_EvalHub,KServe clusterInternal
    class HuggingFace,S3,MLFlow externalService
    class Prometheus monitoring
