graph TB
    subgraph "Service Accounts"
        SA[kuberay-operator]
    end

    subgraph "Cluster Roles"
        CR[kuberay-operator]
    end

    subgraph "Role Bindings"
        RB[kuberay-operator<br/>Namespace: opendatahub]
    end

    subgraph "Kubernetes Resources"
        subgraph "Core Resources"
            RES1[Pods<br/>Services<br/>ConfigMaps<br/>ServiceAccounts<br/>Events<br/>Secrets]
        end

        subgraph "Apps & Batch"
            RES2[Deployments<br/>Jobs]
        end

        subgraph "Ray CRDs"
            RES3[RayClusters<br/>RayJobs<br/>RayServices]
        end

        subgraph "Networking"
            RES4[NetworkPolicies<br/>Ingresses]
        end

        subgraph "OpenShift"
            RES5[Routes]
        end
    end

    subgraph "Permissions"
        PERM1[create, delete, get,<br/>list, patch, update, watch]
        PERM2[delete, get, list, watch]
        PERM3[get, list, patch,<br/>update, watch]
    end

    %% Service Account to Role Binding
    SA -->|bound by| RB

    %% Role Binding to Cluster Role
    RB -->|grants| CR

    %% Cluster Role to Resources
    CR -->|full control| RES1
    CR -->|secrets: delete, get,<br/>list, watch| RES1
    CR -->|get, list, patch,<br/>update, watch| RES2
    CR -->|create, delete, get,<br/>list, patch, update, watch| RES2
    CR -->|create, delete, get,<br/>list, patch, update, watch| RES3
    CR -->|create, delete, get,<br/>list, patch, update, watch| RES4
    CR -->|create, delete, get,<br/>list, patch, update, watch| RES5

    %% Permissions Details
    CR -.->|pods, services, configmaps,<br/>serviceaccounts, events| PERM1
    CR -.->|secrets| PERM2
    CR -.->|deployments| PERM3
    CR -.->|jobs, rayclusters, rayjobs,<br/>rayservices, networkpolicies,<br/>ingresses, routes| PERM1

    %% Styling
    style SA fill:#4285F4,stroke:#fff,color:#fff
    style CR fill:#EA4335,stroke:#fff,color:#fff
    style RB fill:#FBBC04,stroke:#000,color:#000
    style RES1 fill:#34A853,stroke:#fff,color:#fff
    style RES2 fill:#34A853,stroke:#fff,color:#fff
    style RES3 fill:#34A853,stroke:#fff,color:#fff
    style RES4 fill:#34A853,stroke:#fff,color:#fff
    style RES5 fill:#34A853,stroke:#fff,color:#fff
