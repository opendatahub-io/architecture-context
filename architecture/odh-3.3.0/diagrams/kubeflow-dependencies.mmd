graph TB
    subgraph "Kubeflow Notebook Controllers"
        KUBEFLOW[Kubeflow<br/>Notebook Controllers<br/>v1.7.0-15-519]
    end

    subgraph "External Dependencies"
        K8S[Kubernetes<br/>v0.33.7+<br/>Required]
        CTRL_RT[controller-runtime<br/>v0.21.0<br/>Required]
        ISTIO[Istio<br/>Optional]
        CERT[cert-manager<br/>Optional]
        OSCA[OpenShift Service CA<br/>Optional]
    end

    subgraph "Internal ODH Dependencies"
        DSPO[Data Science Pipelines Operator<br/>DSPA CRD<br/>API Integration]
        OAUTH[OpenShift OAuth<br/>OAuth Client API]
        ROUTES[OpenShift Routes<br/>Route CRD]
        GATEWAY[Gateway API<br/>HTTPRoute, Gateway, ReferenceGrant]
        IMGSTR[OpenShift ImageStreams<br/>Image References]
        FEAST[Feast<br/>ConfigMap Integration]
    end

    subgraph "Monitoring"
        PROM[Prometheus<br/>Metrics Scraping]
    end

    %% External Dependencies
    KUBEFLOW -->|requires| K8S
    KUBEFLOW -->|requires| CTRL_RT
    KUBEFLOW -.->|optional<br/>VirtualService ingress| ISTIO
    KUBEFLOW -.->|optional<br/>webhook certs| CERT
    KUBEFLOW -.->|optional<br/>webhook certs| OSCA

    %% Internal ODH Dependencies
    KUBEFLOW -->|retrieves config<br/>injects secrets| DSPO
    KUBEFLOW -->|creates clients| OAUTH
    KUBEFLOW -->|creates Routes| ROUTES
    KUBEFLOW -->|creates HTTPRoutes<br/>ReferenceGrants| GATEWAY
    KUBEFLOW -->|references images| IMGSTR
    KUBEFLOW -->|injects config| FEAST

    %% Monitoring
    KUBEFLOW -->|exposes metrics| PROM

    %% Styling
    style KUBEFLOW fill:#326CE5,stroke:#fff,color:#fff
    style K8S fill:#326CE5,stroke:#fff,color:#fff
    style CTRL_RT fill:#0078D7,stroke:#fff,color:#fff
    style ISTIO fill:#466BB0,stroke:#fff,color:#fff
    style CERT fill:#FF6F00,stroke:#fff,color:#fff
    style OSCA fill:#CC0000,stroke:#fff,color:#fff
    style DSPO fill:#0066CC,stroke:#fff,color:#fff
    style OAUTH fill:#CC0000,stroke:#fff,color:#fff
    style ROUTES fill:#CC0000,stroke:#fff,color:#fff
    style GATEWAY fill:#326CE5,stroke:#fff,color:#fff
    style IMGSTR fill:#CC0000,stroke:#fff,color:#fff
    style FEAST fill:#0066CC,stroke:#fff,color:#fff
    style PROM fill:#E6522C,stroke:#fff,color:#fff
