graph TD
    subgraph "RBAC Model"
        Note1["No Custom ClusterRoles Defined<br/>in Notebooks Component"]
        Note2["RBAC Managed by<br/>ODH Notebook Controller"]
    end

    subgraph "Service Accounts"
        NotebookControllerSA["Notebook Controller SA<br/>Namespace: opendatahub"]
        WorkbenchPodSA["Workbench Pod SA<br/>Namespace: user-namespace<br/>Minimal Permissions"]
    end

    subgraph "Permissions Granted"
        direction TB

        subgraph "Notebook Controller Permissions"
            CreateSS["Create/Manage<br/>StatefulSets"]
            CreateSvc["Create/Manage<br/>Services"]
            CreateRoute["Create/Manage<br/>Routes"]
            ManagePods["Watch/Manage<br/>Pods"]
        end

        subgraph "Workbench Pod Permissions"
            ReadSecrets["Read Secrets<br/>aws-credentials<br/>git-credentials"]
            AccessAPI["Access Kubernetes API<br/>Limited Scope"]
        end
    end

    subgraph "Secrets Access Control"
        TLSSecret["notebook-tls-secret<br/>kubernetes.io/tls<br/>TLS Certificates"]
        OAuthSecret["notebook-oauth-secret<br/>Opaque<br/>OAuth Token"]
        AWSSecret["aws-credentials<br/>Opaque<br/>S3 Access Keys"]
        GitSecret["git-credentials<br/>kubernetes.io/ssh-auth<br/>SSH Keys"]
    end

    NotebookControllerSA -->|grants| CreateSS
    NotebookControllerSA -->|grants| CreateSvc
    NotebookControllerSA -->|grants| CreateRoute
    NotebookControllerSA -->|grants| ManagePods

    WorkbenchPodSA -->|grants| ReadSecrets
    WorkbenchPodSA -->|grants| AccessAPI

    WorkbenchPodSA -.->|reads| AWSSecret
    WorkbenchPodSA -.->|reads| GitSecret
    NotebookControllerSA -.->|manages| TLSSecret
    NotebookControllerSA -.->|manages| OAuthSecret

    subgraph "Authentication Flow"
        UserAuth["User Authentication<br/>OAuth Proxy"]
        NotebookAuth["Notebook Authentication<br/>Jupyter Token"]
    end

    UserAuth -->|enforced at| Route2["OpenShift Route"]
    NotebookAuth -->|enforced at| JupyterServer["Jupyter Server"]

    style NotebookControllerSA fill:#4a90e2
    style WorkbenchPodSA fill:#4a90e2
    style CreateSS fill:#7ed321
    style CreateSvc fill:#7ed321
    style CreateRoute fill:#7ed321
    style ManagePods fill:#7ed321
    style ReadSecrets fill:#7ed321
    style AccessAPI fill:#7ed321
    style TLSSecret fill:#f5a623
    style OAuthSecret fill:#f5a623
    style AWSSecret fill:#f5a623
    style GitSecret fill:#f5a623
    style Note1 fill:#ffe6cc
    style Note2 fill:#ffe6cc
