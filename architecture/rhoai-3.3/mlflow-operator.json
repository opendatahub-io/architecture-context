          "doc": "Image specifies the MLflow container image. If not specified, use the default image via the MLFLOW_IMAGE environment variable in the operator."
        },
        {
          "name": "Replicas",
          "type": "*int32",
          "json_tag": "replicas,omitempty",
          "doc": "Replicas is the number of MLflow pods to run",
          "markers": [
            "+kubebuilder:default=1",
