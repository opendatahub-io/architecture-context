%% Source: architecture/rhoai-3.3/notebooks.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Gateway (Envoy)<br/>443/TCP<br/>TLS 1.2+<br/>No gateway-level auth"]
    end

    subgraph Cluster["CLUSTER (Internal)"]
        direction TB

        subgraph WBPod["Workbench Pod (per user)"]
            KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>Auth: Bearer Token RBAC"]
            JupyterWB["JupyterLab Container<br/>8888/TCP HTTP plaintext<br/>Auth: None (disabled)"]
            CodeServerWB["Code Server Container<br/>8787/TCP HTTP plaintext<br/>Auth: None (--auth none)"]
            RStudioWB["RStudio Server Container<br/>8787/TCP HTTP plaintext<br/>Auth: None (NGINX proxy)"]
        end

        subgraph Controllers["Controller Namespace"]
            NotebookCtrl["ODH Notebook Controller<br/>Creates pods, services,<br/>HTTPRoutes from ImageStreams"]
            RhodsOp["rhods-operator<br/>Deploys ImageStream<br/>manifests via kustomize"]
        end

        subgraph DSPNamespace["Data Science Pipelines"]
            DSPCtrl["DSP Controller"]
            RuntimePod["Runtime Image Pod<br/>(headless pipeline execution)"]
        end

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Credentials"]
        ContainerReg["Container Registries<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secret"]
        PyPI["PyPI / pip Registries<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Kafka["Kafka Brokers<br/>9092/TCP<br/>TLS optional / SASL optional"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional / Credentials"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional / Credentials"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS optional / Credentials"]
    end

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KRBAC

    %% Internal workbench flows
    KRBAC -->|"HTTP/8888<br/>plaintext localhost<br/>No Auth"| JupyterWB
    KRBAC -->|"HTTP/8787<br/>plaintext localhost<br/>No Auth"| CodeServerWB
    KRBAC -->|"HTTP/8787<br/>plaintext localhost<br/>No Auth"| RStudioWB

    %% Controller flows
    NotebookCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    RhodsOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Pipeline flows
    DSPCtrl -->|"SA Token"| RuntimePod
    RuntimePod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials"| S3
    RuntimePod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Egress from workbenches
    JupyterWB -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    JupyterWB -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Creds"| S3
    JupyterWB -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    JupyterWB -->|"9092/TCP<br/>TLS/SASL opt"| Kafka
    JupyterWB -->|"27017/TCP<br/>TLS opt"| MongoDB
    JupyterWB -->|"5432/TCP<br/>TLS opt"| PostgreSQL
    JupyterWB -->|"3306/TCP<br/>TLS opt"| MySQL

    %% Image registry
    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| ContainerReg

