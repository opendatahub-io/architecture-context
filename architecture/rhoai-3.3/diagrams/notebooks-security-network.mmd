graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (edge mode)<br/>{workbench}.apps.{cluster}"]
    end

    subgraph Authentication["AUTHENTICATION LAYER"]
        OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>Secret: {workbench}-oauth-config"]
        OAuthServer["OpenShift OAuth Server<br/>6443/TCP HTTPS TLS 1.2+<br/>JWT token issuance"]
    end

    subgraph Application["APPLICATION LAYER (User Namespace)"]
        direction TB

        subgraph WorkbenchPod["Workbench Pod (StatefulSet)<br/>Namespace: {user-namespace}<br/>SA: {workbench-name}-sa<br/>UID: 1001 (non-root)<br/>SCC: restricted"]
            JupyterContainer["Jupyter Server Container<br/>Port: 8888/TCP HTTP<br/>Auth: Disabled<br/>Image: registry.redhat.io/rhoai/odh-workbench-*"]
            OAuthProxyContainer["oauth-proxy Container<br/>Port: 8443/TCP HTTPS<br/>Validates OAuth tokens"]
        end

        Service["Service: {workbench-name}-notebook<br/>Type: ClusterIP<br/>Port: 8888/TCP"]
        PVC["Persistent Volume Claim<br/>{workbench-name}-pvc<br/>User data storage"]
    end

    subgraph Internal["INTERNAL SERVICES (Cluster Network)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Service Account Token<br/>kubectl/oc commands"]
        Pipelines["Kubeflow Pipelines API<br/>8888/TCP HTTP<br/>Bearer Token<br/>Elyra execution"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        PyPI["pypi.org<br/>443/TCP HTTPS TLS 1.2+<br/>No Auth<br/>Python packages"]
        Quay["quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull secret<br/>Container images"]
        RedHat["registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+<br/>RH subscription<br/>RHEL base images"]
        S3["S3 Storage (s3.amazonaws.com)<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / Access Keys<br/>Model artifacts, datasets"]
        Git["Git Repositories<br/>443/TCP HTTPS TLS 1.2+<br/>SSH keys / PAT<br/>Code repositories"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS TLS 1.2+<br/>No Auth<br/>OpenShift CLI (oc)"]
    end

    %% Flow from user to workbench
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>OAuth redirect| OAuthProxy
    OAuthProxy <-->|HTTPS/6443<br/>TLS 1.2+<br/>OAuth token exchange| OAuthServer
    OAuthProxy -->|HTTP/8888<br/>No encryption<br/>OAuth validated| JupyterContainer

    %% Service exposure
    JupyterContainer -.->|exposes| Service
    Service -.->|backend for| Router

    %% Internal sidecar
    OAuthProxyContainer -.->|sidecar in| WorkbenchPod

    %% Storage
    WorkbenchPod -->|mounts| PVC

    %% Internal service calls
    JupyterContainer -->|HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token| K8sAPI
    JupyterContainer -->|HTTP/8888<br/>Bearer Token| Pipelines

    %% Egress
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+| PyPI
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>Pull secret| Quay
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>RH subscription| RedHat
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM credentials| S3
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+<br/>SSH/PAT| Git
    JupyterContainer -->|HTTPS/443<br/>TLS 1.2+| Mirror

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,OAuthServer,OAuthProxyContainer auth
    class JupyterContainer,WorkbenchPod,Service,PVC application
    class K8sAPI,Pipelines internal
    class PyPI,Quay,RedHat,S3,Git,Mirror externalservice
