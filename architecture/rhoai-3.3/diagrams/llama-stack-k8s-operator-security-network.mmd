graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI<br/>kubectl]
        Client[Client Application]
    end

    subgraph Ingress["INGRESS (Optional)"]
        IngressCtrl["Ingress Controller<br/>{instance-name}-ingress<br/>443/TCP → 8321/TCP<br/>Optional TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        ControllerPod["Controller Manager Pod<br/>SA: controller-manager<br/>runAsNonRoot, no privEsc<br/>SELinux: Enforcing"]

        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS TLS<br/>Bearer Token (kube-rbac-proxy)"]

        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Token"]
    end

    subgraph UserNS["USER NAMESPACE (NetworkPolicy Protected)"]
        direction TB

        LlamaStackPod["Llama Stack Pod<br/>SA: {instance-name}-sa<br/>SCC: anyuid<br/>PVC: /opt/app-root/src/.llama/"]

        LlamaStackSvc["Llama Stack Service<br/>8321/TCP HTTP/HTTPS<br/>Optional TLS 1.3"]

        NetPol["NetworkPolicy (Optional)<br/>{instance-name}-netpol<br/>Ingress: same NS + operator NS + allowed NS<br/>Egress: unrestricted"]
    end

    subgraph InferenceProviders["INFERENCE PROVIDERS"]
        direction TB

        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No encryption, No auth"]

        vLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>Optional TLS, Optional Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        HF["HuggingFace Hub<br/>443/TCP HTTPS TLS1.2+<br/>HF Token Auth"]

        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secret"]

        Prometheus["Prometheus<br/>ServiceMonitor scraping"]
    end

    %% External to Ingress
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig| K8sAPI
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>None/Custom| IngressCtrl

    %% Ingress to Service
    IngressCtrl -->|HTTP or HTTPS/8321<br/>Optional TLS 1.3<br/>None/Custom| LlamaStackSvc

    %% Operator to K8s API
    ControllerPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Service to Pod
    LlamaStackSvc -->|HTTP or HTTPS/8321| LlamaStackPod
    NetPol -.->|protects| LlamaStackPod

    %% Pod to Inference
    LlamaStackPod -->|HTTP/11434<br/>None, None| Ollama
    LlamaStackPod -->|HTTP or HTTPS/8000<br/>Optional TLS<br/>Optional Token| vLLM

    %% Inference to External
    vLLM -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HF
    LlamaStackPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry

    %% Metrics
    Prometheus -->|HTTPS/8443<br/>TLS<br/>Bearer Token| MetricsSvc
    MetricsSvc -.->|hosted by| ControllerPod

    %% Health
    HealthProbes -.->|hosted by| ControllerPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorNS fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef userNS fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inference fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User,Client external
    class IngressCtrl ingress
    class ControllerPod,MetricsSvc,HealthProbes,K8sAPI operatorNS
    class LlamaStackPod,LlamaStackSvc,NetPol userNS
    class Ollama,vLLM inference
    class HF,Registry,Prometheus externalService
