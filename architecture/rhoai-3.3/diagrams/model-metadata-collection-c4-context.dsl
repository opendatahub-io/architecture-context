/*
 * C4 Context Diagram: Model Metadata Collection
 * Generated by: Claude Opus 4.6
 *
 * Render with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace model-metadata-collection-c4-context.dsl -format png
 */

workspace {
    model {
        ciEngineer = person "CI/CD Pipeline" "Automated build pipeline (Konflux/GitHub Actions) that executes the metadata extraction"

        dataScientist = person "Data Scientist" "Browses model catalog via Dashboard to discover available AI models"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time Go tool that extracts, enriches, and catalogs AI model metadata into a static data container image" {
            modelExtractor = container "model-extractor" "Main CLI that discovers HuggingFace collections, extracts model cards from OCI containers, enriches metadata, generates catalogs" "Go CLI"
            metadataReport = container "metadata-report" "Generates completeness and data source analysis reports" "Go CLI"
            huggingfaceClient = container "HuggingFace Client" "API integration for collection discovery, model details, README fetching" "Go Package"
            registryClient = container "Registry Client" "OCI manifest metadata, layer fetching, multi-arch detection" "Go Package"
            enrichmentEngine = container "Enrichment Engine" "Similarity matching, tag parsing, priority-based data merging" "Go Package"
            catalogGenerator = container "Catalog Generator" "Deduplication, static catalog merging, model classification" "Go Package"
            dataContainer = container "Data Container Image" "Minimal UBI9 container with pre-generated YAML catalogs and benchmark data" "Container (sleep infinity)"
        }

        huggingface = softwareSystem "HuggingFace" "AI model hosting platform with public API for model metadata" "External"
        redhatRegistry = softwareSystem "Red Hat Container Registry" "registry.redhat.io - hosts ModelCar OCI images with model cards" "External"
        ubiRegistry = softwareSystem "UBI Base Image Registry" "registry.access.redhat.com - provides UBI9 base images" "External"
        quayRegistry = softwareSystem "Quay.io Registry" "Container image registry for publishing built images" "External"

        modelRegistry = softwareSystem "Model Registry" "Stores and serves model metadata to users" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for managing AI/ML workloads" "Internal RHOAI"
        konflux = softwareSystem "Konflux CI" "Tekton-based CI/CD pipeline system" "Internal"

        # Build-time relationships
        ciEngineer -> modelMetadataCollection "Triggers metadata extraction pipeline"
        modelExtractor -> huggingfaceClient "Uses for API calls"
        modelExtractor -> registryClient "Uses for OCI image access"
        modelExtractor -> enrichmentEngine "Uses for metadata enrichment"
        modelExtractor -> catalogGenerator "Uses to generate catalogs"
        catalogGenerator -> dataContainer "Catalogs packaged into"

        modelMetadataCollection -> huggingface "Fetches model collections, details, READMEs" "HTTPS/443 TLS 1.2+ No Auth"
        modelMetadataCollection -> redhatRegistry "Fetches OCI manifests, model card layers" "HTTPS/443 TLS 1.2+ Docker Auth"
        modelMetadataCollection -> ubiRegistry "Pulls base image for container build" "HTTPS/443 TLS 1.2+"
        modelMetadataCollection -> quayRegistry "Pushes built data container image" "HTTPS/443 TLS 1.2+ CI Credentials"

        konflux -> modelMetadataCollection "Builds and publishes container image"

        # Runtime relationships
        modelRegistry -> dataContainer "Mounts catalog data via volume" "Filesystem"
        dashboard -> dataContainer "Mounts catalog data via volume" "Filesystem"
        dataScientist -> dashboard "Browses model catalog"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #85bbf0
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
