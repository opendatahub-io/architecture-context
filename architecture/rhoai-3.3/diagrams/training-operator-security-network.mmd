graph TB
    subgraph External["EXTERNAL - User Workstation"]
        User[Data Scientist]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.3<br/>AuthN: User creds and SA tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE - opendatahub"]
        direction TB

        subgraph OperatorPod["training-operator Pod"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+"]
            Metrics["Metrics Exporter<br/>8080/TCP HTTP plaintext"]
            Health["Health Probes<br/>8081/TCP HTTP"]
            Controllers["6x Job Controllers<br/>PyTorch, TF, XGBoost, MPI, JAX, Paddle"]
        end

        OperatorSA["ServiceAccount:<br/>training-operator<br/>UID: 65532 non-root<br/>Istio: DISABLED"]

        Prometheus["Prometheus<br/>openshift-monitoring<br/>PodMonitor scraping"]
        Kubelet["Kubelet<br/>Health Monitoring"]
    end

    subgraph UserNS["USER NAMESPACES - user-namespace"]
        direction TB

        subgraph TrainingPods["Training Job Pods - Created by Operator"]
            Master["Master/Chief Pod<br/>SA: job-name-sa<br/>Image: user-training-image"]
            Workers["Worker Pods - N replicas<br/>Framework-specific"]
        end

        TrainingService["Kubernetes Service<br/>Pod Discovery<br/>Port: 23456/TCP PyTorch<br/>Port: 9999/TCP XGBoost"]
    end

    subgraph OptionalServices["OPTIONAL EXTERNAL SERVICES"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS<br/>Gang Scheduling"]
        SchedulerPlugins["scheduler-plugins<br/>443/TCP HTTPS<br/>Alternative Gang Scheduling"]
    end

    %% User to API Server
    User -->|kubectl apply<br/>HTTPS/443 TLS1.3<br/>User credentials| K8sAPI

    %% API Server to Webhook
    K8sAPI -->|POST /validate-*<br/>HTTPS/9443 TLS1.2+<br/>API Server mTLS| Webhook

    %% Controller to API Server
    Controllers -->|Watch CRDs, Create Pods/Services<br/>HTTPS/443 TLS1.2+<br/>SA token| K8sAPI

    %% Monitoring
    Prometheus -.->|GET /metrics<br/>HTTP/8080 plaintext<br/>No auth| Metrics
    Kubelet -.->|GET /healthz, /readyz<br/>HTTP/8081<br/>No auth| Health

    %% Training Pod Communication
    Master <-->|Distributed Training<br/>TCP: 23456 PyTorch, 9999 XGBoost<br/>PLAINTEXT - no encryption<br/>No auth| Workers
    TrainingService -.->|DNS/Service Discovery| Master
    TrainingService -.->|DNS/Service Discovery| Workers

    %% Optional Gang Scheduling
    Controllers -.->|Create PodGroups<br/>HTTPS/443 TLS1.2+<br/>SA token<br/>Optional| Volcano
    Controllers -.->|Create PodGroups<br/>HTTPS/443 TLS1.2+<br/>SA token<br/>Optional| SchedulerPlugins

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlPlane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorNS fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userNS fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlPlane
    class OperatorPod,Webhook,Metrics,Health,Controllers,OperatorSA,Prometheus,Kubelet operatorNS
    class Master,Workers,TrainingService userNS
    class Volcano,SchedulerPlugins optional
