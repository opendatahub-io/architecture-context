        OTelCollector["OTel Collector / SDK"]
    end

    subgraph Ingress["INGRESS (Authentication Proxy)"]
        Gateway["Platform Gateway<br/>443/TCP<br/>TLS 1.2+ SIMPLE<br/>HTTPRoute (Gateway API)"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP → 5000/TCP<br/>TLS 1.2+ termination<br/>Validates K8s SA tokens<br/>Injects x-remote-user headers"]
    end

    subgraph AppLayer["APPLICATION LAYER (MLflow Server Pod)"]
        direction TB
        MLflow["MLflow Tracking Server<br/>5000/TCP HTTP (plaintext)<br/>SA: mlflow-server<br/>UBI9 / Python 3.11"]
        AuthMW["K8s Auth Middleware<br/>SelfSubjectAccessReview (default)<br/>SubjectAccessReview (proxy mode)<br/>Cache TTL: 300s"]

        subgraph Endpoints["Exposed Endpoints"]
            RESTAPI["/api/2.0/mlflow/* - REST API<br/>/ajax-api/* - AJAX API<br/>/graphql - GraphQL<br/>Auth: Bearer/proxy headers"]
            OTelAPI["/v1/traces - OTLP ingest<br/>/ajax-api/3.0/jobs/* - Job API<br/>Auth: Bearer/proxy headers"]
            PublicEP["/health /version /metrics /<br/>Auth: None"]
        end

        MLflow --- AuthMW
        MLflow --- Endpoints
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token auth"]
    end

    subgraph BackendServices["BACKEND SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Username/Password"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| KubeRBACProxy
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"routes to"| KubeRBACProxy
    OTelCollector -->|"OTLP/HTTP<br/>Bearer Token"| KubeRBACProxy

    %% Proxy to app
    KubeRBACProxy -->|"HTTP/5000<br/>plaintext (pod-local)<br/>x-remote-user headers"| MLflow

    %% Auth middleware to K8s API
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReview"| K8sAPI

    %% Data flows
    MLflow -->|"PostgreSQL/5432<br/>TLS (configurable)<br/>Username/Password"| PostgreSQL
    MLflow -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Access Key"| S3

    %% Monitoring
    Prometheus -->|"HTTP/5000<br/>scrape /metrics<br/>No auth"| MLflow

