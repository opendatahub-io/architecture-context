graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: operator-namespace]
        SA_Registry[inferred from deployment<br/>Namespace: registry-namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader[leader-election-rolebinding<br/>RoleBinding]
        RB_Registry[registry-user-REGISTRY-binding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Proxy[proxy-role<br/>ClusterRole]
        CR_Admin[modelregistry-admin-role<br/>ClusterRole]
        CR_Editor[modelregistry-editor-role<br/>ClusterRole]
        CR_Viewer[modelregistry-viewer-role<br/>ClusterRole]
    end

    subgraph "Roles"
        R_Leader[leader-election-role<br/>Role]
        R_Registry[registry-user-REGISTRY<br/>Role]
    end

    subgraph "API Resources - ModelRegistry CRD"
        API_MR[modelregistry.opendatahub.io<br/>ModelRegistry v1beta1<br/>modelregistries/status<br/>modelregistries/finalizers]
    end

    subgraph "API Resources - Core"
        API_Core[Core API<br/>services<br/>serviceaccounts<br/>configmaps<br/>secrets<br/>persistentvolumeclaims<br/>endpoints<br/>pods<br/>pods/log<br/>events]
    end

    subgraph "API Resources - Apps"
        API_Apps[apps<br/>deployments]
    end

    subgraph "API Resources - Networking"
        API_Network[networking.k8s.io<br/>networkpolicies]
    end

    subgraph "API Resources - RBAC"
        API_RBAC[rbac.authorization.k8s.io<br/>roles<br/>rolebindings<br/>clusterrolebindings]
    end

    subgraph "API Resources - OpenShift"
        API_Route[route.openshift.io<br/>routes<br/>routes/custom-host]
        API_User[user.openshift.io<br/>groups]
        API_Config[config.openshift.io<br/>ingresses]
    end

    subgraph "API Resources - Auth"
        API_Auth[authentication.k8s.io<br/>tokenreviews<br/><br/>authorization.k8s.io<br/>subjectaccessreviews]
    end

    subgraph "API Resources - Platform"
        API_Platform[components.platform.opendatahub.io<br/>modelregistries<br/><br/>services.platform.opendatahub.io<br/>auths]
    end

    subgraph "API Resources - Extensions"
        API_Ext[migration.k8s.io<br/>storageversionmigrations<br/><br/>apiextensions.k8s.io<br/>customresourcedefinitions]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Controller -->|bound via| RB_Leader

    %% ClusterRoleBindings grant ClusterRoles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy

    %% RoleBindings grant Roles
    RB_Leader -->|grants| R_Leader
    RB_Registry -->|grants| R_Registry

    %% ClusterRole permissions - manager-role
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_MR
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Core
    CR_Manager -->|get,list,watch| API_Core
    CR_Manager -->|create,patch| API_Core
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Apps
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Network
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_RBAC
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Route
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_User
    CR_Manager -->|create| API_Auth
    CR_Manager -->|get,list,watch| API_Config
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_Ext
    CR_Manager -->|get,list,watch| API_Platform

    %% User-facing ClusterRoles for ModelRegistry access
    CR_Admin -->|get,list,watch,create,update,patch,delete| API_MR
    CR_Editor -->|get,list,watch,create,update,patch| API_MR
    CR_Viewer -->|get,list,watch| API_MR

    %% Role for registry user access (kube-rbac-proxy authz)
    R_Registry -->|get| API_Core

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,color:#fff
    classDef binding fill:#f5a623,stroke:#333,color:#000
    classDef role fill:#7ed321,stroke:#333,color:#000
    classDef api fill:#e8e8e8,stroke:#333,color:#000

    class SA_Controller,SA_Registry serviceaccount
    class CRB_Manager,CRB_Proxy,RB_Leader,RB_Registry binding
    class CR_Manager,CR_Proxy,CR_Admin,CR_Editor,CR_Viewer,R_Leader,R_Registry role
    class API_MR,API_Core,API_Apps,API_Network,API_RBAC,API_Route,API_User,API_Config,API_Auth,API_Platform,API_Ext api
