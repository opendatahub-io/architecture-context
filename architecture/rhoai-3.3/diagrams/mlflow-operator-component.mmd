%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["MLflowReconciler<br/>(controller-runtime)"]
        HelmRenderer["HelmRenderer<br/>(Helm v3 library)"]
        RoutingLogic["Routing Controller Logic<br/>(HTTPRoute + ConsoleLink)"]
        MetricsEndpoint["Metrics Server<br/>8443/TCP HTTPS"]
        HealthEndpoint["Health Probes<br/>8081/TCP HTTP"]

        Controller -->|renders chart| HelmRenderer
        Controller -->|creates routes| RoutingLogic
    end

    Admin[Platform Admin] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowCR -->|watched by| Controller

    subgraph ManagedResources["Managed Resources (per MLflow CR)"]
        MLflowDeploy["MLflow Server<br/>Deployment"]
        MLflowSvc["MLflow Service<br/>ClusterIP 8443/TCP"]
        MLflowSA["ServiceAccount<br/>(mlflow-sa)"]
        MLflowPVC["PVC<br/>(optional, local storage)"]
        MLflowNP["NetworkPolicy<br/>(allow 8443 ingress)"]
        MLflowTLS["TLS Secret<br/>(mlflow-tls)"]
        MLflowRBAC["ClusterRole/Binding<br/>(mlflow)"]
    end

    Controller -->|Server-Side Apply| MLflowDeploy
    Controller -->|creates| MLflowSvc
    Controller -->|creates| MLflowSA
    Controller -->|creates| MLflowPVC
    Controller -->|creates| MLflowNP
    Controller -->|creates| MLflowRBAC

    subgraph IngressResources["Ingress Resources (conditional)"]
        HTTPRoute["HTTPRoute<br/>(Gateway API v1)"]
        ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    end

    RoutingLogic -->|creates if GW API available| HTTPRoute
    RoutingLogic -->|creates if OpenShift| ConsoleLink

    HTTPRoute -->|parent ref| DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    ConsoleLink -->|adds to| OpenShiftConsole["OpenShift Console<br/>App Menu"]

    Controller -->|watches, SSA| K8sAPI["Kubernetes API<br/>443/TCP"]
    ServiceCA["OpenShift service-ca"] -->|provisions| MLflowTLS
    RhodsOperator["rhods-operator"] -->|deploys via kustomize| OperatorPod
    Prometheus["Prometheus"] -->|scrapes| MetricsEndpoint

