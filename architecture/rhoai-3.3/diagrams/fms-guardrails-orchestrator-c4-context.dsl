/*
 * FMS Guardrails Orchestrator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "API Client" "Application or service consuming AI text generation with safety guardrails"

        guardrailsOrchestrator = softwareSystem "FMS Guardrails Orchestrator" "Rust-based middleware that coordinates AI text generation with content safety guardrails" {
            guardrailsServer = container "Guardrails Server" "Main REST API server handling guardrails orchestration" "Rust/Axum 0.8.4, 8033/TCP"
            healthServer = container "Health Server" "Health check and info endpoint server" "Rust/Axum, 8034/TCP"
            tgisClient = container "TGIS Client" "gRPC client for TGIS text generation" "Tonic 0.14.2"
            nlpClient = container "NLP Client" "gRPC client for caikit-nlp text generation" "Tonic 0.14.2"
            openaiClient = container "OpenAI Client" "HTTP client for OpenAI-compatible servers" "reqwest 0.12.23"
            detectorClient = container "Detector Client" "HTTP client for content safety detectors" "reqwest 0.12.23"
            chunkerClient = container "Chunker Client" "gRPC client for text chunking services" "Tonic 0.14.2"
            tlsModule = container "TLS Module" "TLS/mTLS configuration for server and client connections" "rustls 0.23.31 (ring)"
            otelIntegration = container "OpenTelemetry Integration" "Distributed tracing and metrics export" "opentelemetry 0.30.0"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server for model serving" "Internal Backend"
        caikitNlp = softwareSystem "caikit-nlp" "Alternative text generation backend using caikit framework" "Internal Backend"
        detectors = softwareSystem "Content Safety Detectors" "HAP, PII, and other content safety detection services" "Internal Backend"
        chunkers = softwareSystem "Chunker Services" "Text tokenization and chunking services" "Internal Backend"
        vllm = softwareSystem "vLLM / OpenAI-compatible Server" "Chat and text completions generation server" "Internal Backend"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry telemetry collection and export" "Infrastructure"

        # System Context relationships
        user -> guardrailsOrchestrator "Sends text generation/detection requests" "HTTP/HTTPS 8033/TCP"
        guardrailsOrchestrator -> tgis "Text generation requests" "gRPC/HTTP2 8033/TCP, Optional TLS/mTLS"
        guardrailsOrchestrator -> caikitNlp "Alternative text generation" "gRPC/HTTP2, Optional TLS/mTLS"
        guardrailsOrchestrator -> detectors "Content safety detection" "HTTP/HTTPS 8080/TCP, Optional TLS/mTLS"
        guardrailsOrchestrator -> chunkers "Text chunking/tokenization" "gRPC/HTTP2 8085/TCP, Optional TLS/mTLS"
        guardrailsOrchestrator -> vllm "Chat/text completions" "HTTP/HTTPS 8080/TCP, Optional TLS/mTLS"
        guardrailsOrchestrator -> otlpCollector "Traces and metrics" "gRPC 4317/TCP or HTTP 4318/TCP"

        # Container relationships
        user -> guardrailsServer "POST /api/v1/*, /api/v2/*" "HTTP/HTTPS 8033/TCP"
        user -> healthServer "GET /health, /info" "HTTP 8034/TCP"
        guardrailsServer -> tgisClient "Routes generation requests"
        guardrailsServer -> nlpClient "Routes NLP generation requests"
        guardrailsServer -> openaiClient "Routes chat completion requests"
        guardrailsServer -> detectorClient "Routes detection requests"
        guardrailsServer -> chunkerClient "Routes chunking requests"
        guardrailsServer -> tlsModule "TLS/mTLS termination"
        guardrailsServer -> otelIntegration "Emits traces and metrics"
        tgisClient -> tgis "Generate, GenerateStream, Tokenize" "gRPC/HTTP2"
        nlpClient -> caikitNlp "Text generation" "gRPC/HTTP2"
        openaiClient -> vllm "/v1/chat/completions, /v1/completions" "HTTP/HTTPS"
        detectorClient -> detectors "/api/v1/text/contents" "HTTP/HTTPS"
        chunkerClient -> chunkers "ChunkerTokenizationTaskPredict" "gRPC/HTTP2"
        otelIntegration -> otlpCollector "OTLP export" "gRPC/HTTP"
        healthServer -> detectorClient "Detector health probes"
    }

    views {
        systemContext guardrailsOrchestrator "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsOrchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal Backend" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
