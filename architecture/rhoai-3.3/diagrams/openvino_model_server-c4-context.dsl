/*
 * OpenVINO Model Server (OVMS) - C4 Context Diagram
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-19
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys and serves ML models via RHOAI Dashboard"
        appDeveloper = person "Application Developer" "Sends inference requests to deployed models"

        ovms = softwareSystem "OpenVINO Model Server" "High-performance C++ inference serving runtime for AI/ML models via gRPC and REST APIs" {
            serverCore = container "OVMS Server Core" "Main server singleton managing module lifecycle" "C++ Service"
            grpcServer = container "gRPC Server" "KServe V2, TFS PredictionService, TFS ModelService" "C++ / gRPC / Port 8085"
            httpServer = container "HTTP/REST Server" "TFS, KServe V2, OpenAI v3 APIs, Prometheus metrics" "C++ / Drogon / Port 8080"
            servableManager = container "Servable Manager" "Model loading, versioning, and lifecycle management" "C++ Module"
            modelManager = container "Model Manager" "Core model management with config polling" "C++ Component"
            mediaPipeIntegration = container "MediaPipe Integration" "Graph-based pipeline execution for LLM, embeddings, rerank, image gen, audio" "C++ / MediaPipe"
            dagScheduler = container "DAG Scheduler" "Multi-model pipeline execution with custom nodes" "C++ Component"
            fsAbstraction = container "FileSystem Abstraction" "Storage backends: Local, S3, GCS, Azure" "C++ Component"
        }

        openvinoRuntime = softwareSystem "OpenVINO Runtime" "Intel AI inference engine (2025.4.1)" "External"
        openvinoGenAI = softwareSystem "OpenVINO GenAI" "Generative AI pipeline support (2025.4)" "External"
        openvinoTokenizers = softwareSystem "OpenVINO Tokenizers" "Tokenization for generative models (2025.4)" "External"

        kserve = softwareSystem "KServe Controller" "Deploys and manages OVMS pods as InferenceService runtime" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Alternative multi-model serving orchestrator" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "User interface for model serving configuration" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "Automated ML pipelines sending inference requests" "Internal RHOAI"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication/authorization sidecar" "Internal RHOAI"
        platformGateway = softwareSystem "Platform Gateway" "Envoy-based ingress with TLS termination" "Internal RHOAI"

        s3Storage = softwareSystem "S3-compatible Storage" "Model artifact storage (s3://)" "External"
        gcsStorage = softwareSystem "Google Cloud Storage" "Model artifact storage (gs://)" "External"
        azureStorage = softwareSystem "Azure Blob/File Storage" "Model artifact storage (az:// / azfs://)" "External"
        huggingFaceHub = softwareSystem "HuggingFace Hub" "Pre-trained model repository" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        # User interactions
        dataScientist -> rhoaiDashboard "Configures model serving"
        appDeveloper -> platformGateway "Sends inference requests" "HTTPS/443"

        # Ingress flow
        platformGateway -> kubeRBACProxy "Forwards authenticated requests" "HTTPS/8443"
        kubeRBACProxy -> ovms "Forwards authorized requests" "HTTP/8080"

        # Platform management
        kserve -> ovms "Deploys and manages OVMS pods" "Kubernetes API"
        modelMesh -> ovms "Alternative orchestrator" "Kubernetes API"
        rhoaiDashboard -> kserve "Creates InferenceService CRs"
        dsPipelines -> ovms "Sends inference requests" "HTTP/8080, gRPC/8085"

        # Monitoring
        prometheus -> ovms "Scrapes metrics" "HTTP/8080 /metrics"

        # External storage
        ovms -> s3Storage "Downloads model artifacts" "HTTPS/443"
        ovms -> gcsStorage "Downloads model artifacts" "HTTPS/443"
        ovms -> azureStorage "Downloads model artifacts" "HTTPS/443"
        ovms -> huggingFaceHub "Pulls models (--pull mode)" "HTTPS/443"

        # Runtime dependencies
        ovms -> openvinoRuntime "Executes model inference" "C++ API (in-process)"
        ovms -> openvinoGenAI "Generative AI pipelines" "C++ API (in-process)"
        ovms -> openvinoTokenizers "Tokenization" "C++ API (in-process)"

        # Internal container relationships
        serverCore -> grpcServer "Manages lifecycle"
        serverCore -> httpServer "Manages lifecycle"
        serverCore -> servableManager "Manages lifecycle"
        servableManager -> modelManager "Delegates model ops"
        modelManager -> fsAbstraction "Loads models from storage"
        modelManager -> mediaPipeIntegration "Executes graphs"
        modelManager -> dagScheduler "Executes pipelines"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
