%% Data Science Pipelines - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / SDK Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP -> 3000/TCP<br/>TLS edge termination"]
        IstioGW["Istio Gateway<br/>(multi-user mode)<br/>80/TCP, mTLS ISTIO_MUTUAL"]
    end

    subgraph AppLayer["APPLICATION LAYER (kubeflow namespace)"]
        direction TB

        subgraph FrontendZone["Frontend"]
            PipelineUI["ml-pipeline-ui<br/>SA: ml-pipeline-ui<br/>3000/TCP HTTP<br/>AuthzPolicy: gateway + auth header"]
        end

        subgraph APIZone["API Layer"]
            APIServer["ml-pipeline API Server<br/>SA: ml-pipeline<br/>8888/TCP REST, 8887/TCP gRPC<br/>8443/TCP Webhook HTTPS<br/>DestRule: ISTIO_MUTUAL"]
        end

        subgraph AgentsZone["Controllers & Agents"]
            PA["Persistence Agent<br/>SA: ml-pipeline-persistenceagent<br/>Watches Workflows"]
            SW["Scheduled Workflow<br/>SA: ml-pipeline-scheduledworkflow<br/>Watches ScheduledWorkflow CRs"]
            VW["Viewer CRD Controller<br/>Manages TensorBoard pods"]
            CacheSrv["cache-server<br/>SA: kubeflow-pipelines-cache<br/>443->8443/TCP HTTPS<br/>AuthzPolicy: Allow all"]
        end

        subgraph MetadataZone["Metadata Services"]
            MLMDServer["metadata-grpc-server<br/>8080/TCP gRPC plaintext"]
            Envoy["metadata-envoy<br/>9090/TCP HTTP proxy"]
            MWriter["metadata-writer<br/>SA: metadata-writer"]
        end

        subgraph VisualizationZone["Visualization"]
            VizServer["ml-pipeline-visualizationserver<br/>8888/TCP HTTP<br/>DestRule: ISTIO_MUTUAL"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DB["MySQL/PostgreSQL<br/>3306/5432/TCP<br/>plaintext (in-cluster)<br/>Auth: Username/Password"]
        S3["MinIO/S3 Storage<br/>9000/TCP HTTP<br/>Optional TLS<br/>Auth: AccessKey/SecretKey"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: SA Token (3600s expiry)"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| Route
    User -->|"HTTP/80<br/>mTLS ISTIO_MUTUAL"| IstioGW

    %% Ingress to Frontend
    Route -->|"HTTP/3000<br/>plaintext"| PipelineUI
    IstioGW -->|"HTTP/3000<br/>mTLS"| PipelineUI

    %% Frontend to API
    PipelineUI -->|"HTTP/8888<br/>mTLS ISTIO_MUTUAL<br/>Bearer Token"| APIServer

    %% API to external services
    APIServer -->|"DB protocol/3306,5432<br/>plaintext<br/>Username/Password"| DB
    APIServer -->|"HTTP/9000<br/>Optional TLS<br/>AccessKey/SecretKey"| S3
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Agents to K8s API
    PA -->|"HTTPS/443<br/>TLS<br/>SA Token 3600s"| K8sAPI
    PA -->|"HTTP/8888<br/>SA Token"| APIServer
    SW -->|"HTTPS/443<br/>TLS<br/>SA Token 3600s"| K8sAPI
    MWriter -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Metadata flows
    MWriter -->|"gRPC/8080<br/>plaintext"| MLMDServer
    Envoy -->|"gRPC/8080<br/>plaintext"| MLMDServer

    %% Cache flows
    K8sAPI -->|"HTTPS/443->8443<br/>TLS webhook cert"| CacheSrv
    CacheSrv -->|"DB protocol<br/>plaintext<br/>Username/Password"| DB

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef metadata fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Route,IstioGW ingress
    class PipelineUI,APIServer,PA,SW,VW,CacheSrv,VizServer app
    class MLMDServer,Envoy,MWriter metadata
    class DB,S3,K8sAPI extservice
