graph TD
    subgraph "Operator Service Accounts"
        OpSA[controller-manager<br/>ServiceAccount]
    end

    subgraph "MLflow Instance Service Accounts"
        MLflowSA[mlflow-sa<br/>ServiceAccount<br/>per MLflow CR]
    end

    subgraph "ClusterRole Bindings"
        OpClusterBinding[manager-role-binding<br/>ClusterRoleBinding]
        MLflowClusterBinding[mlflow<br/>ClusterRoleBinding]
    end

    subgraph "Namespace Role Bindings"
        OpNamespaceBinding[namespace-role-binding<br/>RoleBinding]
        LeaderElectionBinding[leader-election-role-binding<br/>RoleBinding]
    end

    subgraph "Operator ClusterRole Permissions"
        direction TB
        OpClusterRole[ClusterRole:<br/>manager-role]

        OpClusterPerm1["API: ''<br/>namespaces<br/>get, list, watch"]
        OpClusterPerm2["API: mlflow.opendatahub.io<br/>mlflows<br/>create, delete, get, list,<br/>patch, update, watch"]
        OpClusterPerm3["API: mlflow.opendatahub.io<br/>mlflows/status<br/>get, patch, update"]
        OpClusterPerm4["API: mlflow.opendatahub.io<br/>mlflows/finalizers<br/>update"]
        OpClusterPerm5["API: rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create, delete, get, list,<br/>patch, update, watch"]
        OpClusterPerm6["API: console.openshift.io<br/>consolelinks<br/>create, delete, get, list,<br/>patch, update, watch"]
        OpClusterPerm7["API: gateway.networking.k8s.io<br/>httproutes<br/>create, delete, get, list,<br/>patch, update, watch"]

        OpClusterRole --> OpClusterPerm1
        OpClusterRole --> OpClusterPerm2
        OpClusterRole --> OpClusterPerm3
        OpClusterRole --> OpClusterPerm4
        OpClusterRole --> OpClusterPerm5
        OpClusterRole --> OpClusterPerm6
        OpClusterRole --> OpClusterPerm7
    end

    subgraph "Operator Namespace Role Permissions"
        direction TB
        OpNamespaceRole[Role:<br/>manager-role<br/>opendatahub or<br/>redhat-ods-applications]

        OpNamespacePerm1["API: ''<br/>persistentvolumeclaims, secrets,<br/>serviceaccounts, services<br/>create, delete, get, list,<br/>patch, update, watch"]
        OpNamespacePerm2["API: apps<br/>deployments<br/>create, delete, get, list,<br/>patch, update, watch"]
        OpNamespacePerm3["API: networking.k8s.io<br/>networkpolicies<br/>create, delete, get, list,<br/>patch, update, watch"]

        OpNamespaceRole --> OpNamespacePerm1
        OpNamespaceRole --> OpNamespacePerm2
        OpNamespaceRole --> OpNamespacePerm3
    end

    subgraph "MLflow ClusterRole Permissions"
        direction TB
        MLflowClusterRole[ClusterRole:<br/>mlflow]

        MLflowPerm1["API: ''<br/>namespaces<br/>get, list, watch"]

        MLflowClusterRole --> MLflowPerm1
    end

    subgraph "Kubernetes API Resources"
        direction TB
        APIResources["Kubernetes API Server<br/>────────────────<br/>• MLflow CRs<br/>• Deployments<br/>• Services<br/>• Secrets<br/>• HTTPRoutes<br/>• ConsoleLinks<br/>• Namespaces"]
    end

    %% Bindings
    OpSA -->|bound via| OpClusterBinding
    OpClusterBinding -->|grants| OpClusterRole

    OpSA -->|bound via| OpNamespaceBinding
    OpNamespaceBinding -->|grants| OpNamespaceRole

    OpSA -->|bound via| LeaderElectionBinding

    MLflowSA -->|bound via| MLflowClusterBinding
    MLflowClusterBinding -->|grants| MLflowClusterRole

    %% Permissions to API
    OpClusterRole -.->|access| APIResources
    OpNamespaceRole -.->|access| APIResources
    MLflowClusterRole -.->|access| APIResources

    %% Styling
    style OpSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style MLflowSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style OpClusterRole fill:#f5a623,stroke:#333,stroke-width:2px
    style OpNamespaceRole fill:#f5a623,stroke:#333,stroke-width:2px
    style MLflowClusterRole fill:#f5a623,stroke:#333,stroke-width:2px
    style APIResources fill:#7ed321,stroke:#333,stroke-width:3px
    style OpClusterPerm1 fill:#e8e8e8,stroke:#666
    style OpClusterPerm2 fill:#e8e8e8,stroke:#666
    style OpClusterPerm3 fill:#e8e8e8,stroke:#666
    style OpClusterPerm4 fill:#e8e8e8,stroke:#666
    style OpClusterPerm5 fill:#e8e8e8,stroke:#666
    style OpClusterPerm6 fill:#e8e8e8,stroke:#666
    style OpClusterPerm7 fill:#e8e8e8,stroke:#666
    style OpNamespacePerm1 fill:#e8e8e8,stroke:#666
    style OpNamespacePerm2 fill:#e8e8e8,stroke:#666
    style OpNamespacePerm3 fill:#e8e8e8,stroke:#666
    style MLflowPerm1 fill:#e8e8e8,stroke:#666
