// Models as a Service - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Developer" "Discovers models, obtains tokens, and performs LLM inference"

        maas = softwareSystem "Models as a Service (MaaS) API" "OpenAI-compatible model discovery, tiered token/API key management, and policy-driven rate limiting for LLM inference" {
            maasApi = container "maas-api" "Core API server providing token management, model discovery, tier lookup, and API key management" "Go/Gin HTTP Service"
            tokenManager = container "Token Manager" "Issues Kubernetes ServiceAccount tokens scoped to user tiers; manages SA lifecycle" "Go Service Component"
            modelManager = container "Model Manager" "Lists KServe InferenceService and LLMInferenceService CRs, performs authorization loopback checks" "Go Service Component"
            tierMapper = container "Tier Mapper" "Maps user groups to subscription tiers (free/premium/enterprise) from ConfigMap" "Go Service Component"
            apiKeyService = container "API Key Service" "Manages persistent API key metadata with pluggable storage backends" "Go Service Component"
        }

        gateway = softwareSystem "maas-default-gateway" "Gateway API Gateway (openshift-default GatewayClass) for routing MaaS and model traffic" "Infrastructure"

        openshift = softwareSystem "OpenShift / Kubernetes API" "Platform with Gateway API support, TokenReview, SubjectAccessReview" "External"
        kuadrantAuthorino = softwareSystem "Kuadrant / Authorino" "Authentication and authorization policy enforcement via TokenReview and SubjectAccessReview" "External"
        kuadrantLimitador = softwareSystem "Kuadrant / Limitador" "Token-based rate limiting enforcement per user per tier" "External"
        kserve = softwareSystem "KServe" "Model serving platform providing InferenceService and LLMInferenceService CRDs" "Internal ODH"
        certManager = softwareSystem "Cert Manager" "TLS certificate provisioning for gateway and services" "External"
        postgresql = softwareSystem "PostgreSQL" "External database for API key metadata in HA mode" "External"
        serviceCa = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning for internal services" "External"
        istio = softwareSystem "Istio" "Service mesh with DestinationRule for gateway-to-backend TLS" "External"

        // User interactions
        user -> gateway "Sends requests (model discovery, token issuance, inference)" "HTTPS/443"
        gateway -> maas "Routes MaaS API requests" "HTTP/8080 or HTTPS/8443"
        gateway -> kserve "Routes inference requests to model backends" "HTTPS"

        // MaaS internal
        maasApi -> tokenManager "Delegates token operations"
        maasApi -> modelManager "Delegates model discovery"
        maasApi -> tierMapper "Resolves user tier"
        maasApi -> apiKeyService "Manages API keys"

        // External dependencies
        maas -> openshift "TokenRequest, TokenReview, CRUD Namespaces/ServiceAccounts, informer watches" "HTTPS/443"
        maas -> kserve "Watches InferenceService and LLMInferenceService CRDs via informers"
        maas -> postgresql "Stores API key metadata (HA mode)" "TCP/5432"
        maas -> gateway "Authorization loopback check on model endpoints" "HTTPS/443"

        // Gateway dependencies
        gateway -> kuadrantAuthorino "Policy evaluation (TokenReview, SubjectAccessReview, tier lookup)"
        gateway -> kuadrantLimitador "Token rate limiting (free/premium/enterprise tiers)"

        // Infrastructure
        serviceCa -> maas "Provisions TLS certificates (annotation-based)"
        certManager -> gateway "Provisions gateway TLS certificates"
        istio -> gateway "DestinationRule for gateway-to-backend TLS" "HTTPS/8443"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "Infrastructure" {
                background #f5a623
                color #000000
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
