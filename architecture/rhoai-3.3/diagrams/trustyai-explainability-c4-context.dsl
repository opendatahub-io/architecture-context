/*
 * TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/trustyai-explainability.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Requests fairness metrics, drift detection, and model explanations"

        trustyai = softwareSystem "TrustyAI Explainability" "Quarkus-based REST service providing AI fairness metrics, bias tracking, drift detection, and explainability for ML models" {
            service = container "explainability-service" "Main Quarkus REST microservice exposing APIs for metrics, explainers, data management, and inference payload consumption" "Java 17, Quarkus 3.8.5"
            core = container "explainability-core" "Core XAI library with fairness metrics (SPD, DIR), local explainers (LIME, SHAP, CF), drift detectors (KS Test, Meanshift, Fourier MMD)" "Java Library"
            connectors = container "explainability-connectors" "KServe v2 gRPC client connectors for outbound model inference" "Java Library, gRPC 1.75.0"
            arrow = container "explainability-arrow" "Apache Arrow-based data interchange for Python interoperability" "Java Library"
        }

        modelMesh = softwareSystem "ModelMesh" "Model serving platform that sends inference payloads to TrustyAI" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform; sends CloudEvents and serves models via gRPC" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Operator" "Manages TrustyAI service lifecycle, deployment, TLS, and auth configuration" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform management" "Internal RHOAI"

        mariadb = softwareSystem "MariaDB/MySQL" "Relational database for persistent inference data storage" "External"
        minio = softwareSystem "MinIO/S3" "S3-compatible object storage for inference data" "External"
        pvc = softwareSystem "PVC Storage" "Kubernetes Persistent Volume for flat file storage" "Infrastructure"

        # Relationships
        user -> trustyai "Requests fairness metrics, drift detection, explanations" "HTTP/8080"
        modelMesh -> trustyai "Sends inference payloads" "HTTP/80 POST /consumer/kserve/v2"
        kserve -> trustyai "Sends inference payloads via CloudEvents" "HTTP/80 CloudEvent"
        trustyai -> kserve "Outbound inference for explanations" "gRPC/HTTP2 KServe v2"
        trustyai -> modelMesh "Outbound inference for explanations" "gRPC/HTTP2 KServe v2"
        prometheus -> trustyai "Scrapes metrics" "HTTP/80 GET /q/metrics"
        trustyaiOperator -> trustyai "Manages deployment and configuration" "Kubernetes API"
        dashboard -> trustyai "UI-driven metric and explanation requests" "HTTP/80"

        trustyai -> mariadb "Stores inference data" "JDBC/3306"
        trustyai -> minio "Stores inference data" "HTTP/9000"
        trustyai -> pvc "Stores inference data" "Filesystem"

        # Container relationships
        service -> core "Uses fairness metrics, drift detectors, explainers" "In-process"
        service -> connectors "Uses gRPC client for model inference" "In-process"
        service -> arrow "Uses for Python data interchange" "In-process"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Infrastructure" {
                background #d79b00
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
