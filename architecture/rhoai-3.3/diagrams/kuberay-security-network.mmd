graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        UserClient[User/CI Client]
        ExternalClient[External Client<br/>Model Serving]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>Bearer Token Auth"]
        IngressGW["Ingress/Gateway/Route<br/>443/TCP HTTPS TLS1.3<br/>Optional Bearer Token"]
    end

    subgraph ControlPlane["CONTROL PLANE (Operator Namespace)"]
        direction TB

        subgraph Webhooks["Admission Webhooks"]
            MutatingWH["Mutating Webhook<br/>kuberay-webhook-service<br/>443→9443/TCP HTTPS TLS1.2+<br/>Cert: webhook-server-cert"]
            ValidatingWH["Validating Webhook<br/>kuberay-webhook-service<br/>443→9443/TCP HTTPS TLS1.2+<br/>Cert: webhook-server-cert"]
        end

        subgraph Operator["KubeRay Operator Deployment"]
            OpPod["kuberay-operator<br/>SA: kuberay-operator<br/>Security: runAsNonRoot<br/>Replicas: 1 (Recreate)"]
            Controllers["Controllers:<br/>• RayCluster Controller<br/>• RayJob Controller<br/>• RayService Controller<br/>• NetworkPolicy Controller<br/>• Authentication Controller"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No auth"]
        end
    end

    subgraph DataPlane["DATA PLANE (User Namespaces)"]
        direction TB

        subgraph RayCluster["Ray Cluster: {cluster-name}"]
            RayHead["Ray Head Pod<br/>SA: {cluster-name}-head<br/>Security: runAsUser:1000<br/>Service: {cluster-name}-head-svc"]
            RayWorkers["Ray Worker Pods<br/>SA: {cluster-name}-worker<br/>Autoscaled (min-max)<br/>Security: runAsUser:1000"]

            subgraph HeadServices["Ray Head Services"]
                GCS["GCS Server<br/>6379/TCP Redis<br/>Optional mTLS<br/>Cert: {cluster}-tls-cert"]
                Dashboard["Ray Dashboard<br/>8265/TCP HTTP/HTTPS<br/>Optional TLS/OAuth"]
                ClientServer["Ray Client<br/>10001/TCP gRPC<br/>Optional mTLS<br/>Cert: {cluster}-tls-cert"]
            end
        end

        subgraph RayService["RayService: {service-name}"]
            ServeSvc["Ray Serve Service<br/>{service-name}-serve-svc<br/>8000/TCP HTTP<br/>Optional TLS"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["External Redis<br/>6379/TCP<br/>Optional TLS<br/>Auth: Password"]
        ObjectStorage["Object Storage<br/>S3/GCS<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Cloud IAM"]
        ContainerRegistry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secrets"]
        CertManager["cert-manager<br/>443/TCP HTTPS TLS1.2+<br/>Certificate Management"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP<br/>No auth"]
    end

    %% External to Ingress
    UserClient -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    ExternalClient -->|HTTPS/443<br/>TLS 1.3<br/>Optional Bearer| IngressGW

    %% Ingress to Control Plane
    K8sAPI -->|HTTPS/443→9443<br/>TLS 1.2+<br/>Admission Control| MutatingWH
    K8sAPI -->|HTTPS/443→9443<br/>TLS 1.2+<br/>Admission Control| ValidatingWH

    %% Operator interactions
    OpPod -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    OpPod -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| CertManager

    %% Data Plane - Ray Cluster
    K8sAPI -->|Creates/Manages| RayHead
    K8sAPI -->|Creates/Manages| RayWorkers
    RayHead -->|Contains| GCS
    RayHead -->|Contains| Dashboard
    RayHead -->|Contains| ClientServer
    RayWorkers -->|Ray Protocol<br/>Dynamic Ports<br/>Optional mTLS| GCS
    OpPod -->|Submits Jobs<br/>gRPC/10001<br/>Optional mTLS| ClientServer

    %% RayService
    IngressGW -->|HTTP/8000<br/>Optional TLS| ServeSvc
    ServeSvc -->|Ray Protocol<br/>Optional mTLS| RayWorkers

    %% External Services
    GCS -->|Redis/6379<br/>Optional TLS<br/>Password Auth| Redis
    RayWorkers -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM| ObjectStorage
    K8sAPI -->|Pull Images<br/>HTTPS/443<br/>Pull Secrets| ContainerRegistry
    OpPod -->|Request Certs<br/>HTTPS/443<br/>SA Token| CertManager

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>No Auth| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#cce5ff,stroke:#004085,stroke-width:2px
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class UserClient,ExternalClient external
    class K8sAPI,IngressGW ingress
    class MutatingWH,ValidatingWH,OpPod,Controllers,Metrics controlplane
    class RayHead,RayWorkers,GCS,Dashboard,ClientServer,ServeSvc dataplane
    class Redis,ObjectStorage,ContainerRegistry,CertManager externalservice
    class Prometheus monitoring
