%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP HTTPS<br/>TLS 1.2+ termination"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["kuberay-operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP HTTP<br/>Webhooks: 9443/TCP HTTPS"]
        HTTPRoute["HTTPRoute: {ns}-{cluster}<br/>Path: /ray/{ns}/{cluster}<br/>Rewrite: /"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph HeadPodGroup["Ray Head Pod (SCC: run-as-ray-user, UID 1000)"]
            RayHead["Ray Head Container<br/>8265/TCP dashboard<br/>10001/TCP client<br/>6379/TCP GCS"]
            RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TokenReview + SAR"]
        end

        Workers["Ray Worker Pods<br/>SCC: run-as-ray-user, UID 1000<br/>NetworkPolicy: intra-cluster only"]
        HeadSvc["Head Service (ClusterIP)<br/>8265, 10001, 6379/TCP"]
        RefGrant["ReferenceGrant<br/>(cross-namespace)"]
        HeadNP["NetworkPolicy: {cluster}-head<br/>Intra-cluster + namespace + operator + gateway"]
        WorkerNP["NetworkPolicy: {cluster}-workers<br/>Intra-cluster only"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
        CertManager["cert-manager<br/>Issuer + Certificate CRs"]
        Prometheus["Prometheus<br/>8080/TCP HTTP"]
        Volcano["Volcano Scheduler<br/>(optional, PodGroup CRs)"]
    end

    %% External user flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Via HTTPRoute"| RBACProxy
    RBACProxy -->|"HTTP/8265<br/>plaintext<br/>localhost"| RayHead

    %% HTTPRoute routing
    HTTPRoute -.->|"parent ref"| Gateway
    RefGrant -.->|"allows cross-ns"| HTTPRoute

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"creates"| HTTPRoute
    Operator -->|"creates"| RefGrant
    Operator -->|"injects sidecar"| RBACProxy
    Operator -->|"creates"| HeadNP
    Operator -->|"creates"| WorkerNP

    %% Auth check
    RBACProxy -->|"HTTPS/6443<br/>TLS 1.2+<br/>TokenReview"| K8sAPI

    %% Internal Ray traffic
    RayHead -->|"gRPC/10001<br/>mTLS (if enabled)<br/>cert-manager certs"| Workers

    %% External service connections
    Operator -->|"creates Issuer +<br/>Certificate CRs"| CertManager
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>metrics scrape"| Operator

    %% Styles
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#333
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class User external
    class Gateway ingress
    class Operator,HTTPRoute operator
    class RayHead,Workers,HeadSvc,RefGrant userns
    class RBACProxy,HeadNP,WorkerNP security
    class K8sAPI,CertManager,Prometheus,Volcano extsvc
