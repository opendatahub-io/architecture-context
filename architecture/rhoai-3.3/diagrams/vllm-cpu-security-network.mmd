            Engine["AsyncLLM Engine V1<br/>ZeroMQ IPC"]
            Executor["PyTorch Model Executor<br/>CPU"]
            CppKernels["C/C++ Extensions<br/>(CPU Kernels)"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Credentials"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus Server"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SA Token"| RBACProxy
    RBACProxy -->|"HTTP/8000<br/>plaintext<br/>(pod-local)"| APIServer
    APIServer --> AuthMW
    AuthMW --> Engine
    Engine -->|"ZeroMQ IPC"| Executor
    Executor --> CppKernels

    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Creds"| S3

    Prometheus -->|"HTTP/8000<br/>plaintext<br/>/metrics"| APIServer

