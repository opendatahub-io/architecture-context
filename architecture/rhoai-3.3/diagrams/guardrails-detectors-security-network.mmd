graph TB
    subgraph External["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>(optional, dev only)"]
    end

    subgraph Cluster["CLUSTER INTERNAL"]
        subgraph Orchestrator_NS["FMS Orchestrator Pod"]
            BuiltIn["Built-in Detector<br/>Port: 8080/TCP<br/>HTTP plaintext<br/>Auth: None (co-deployed)<br/>Image: odh-built-in-detector-rhel9"]
            OrchestratorSvc["FMS Guardrails<br/>Orchestrator"]
        end

        subgraph KServe_NS["KServe Managed (model-namespace)"]
            direction TB

            subgraph HF_Pod["HuggingFace Detector Pod"]
                HFSidecar["Istio Sidecar<br/>mTLS STRICT"]
                HFDetector["HuggingFace Detector<br/>Port: 8000/TCP<br/>HTTP + mTLS<br/>Auth: KServe + Istio<br/>Image: odh-guardrails-detector-<br/>huggingface-runtime-rhel9"]
            end

            subgraph Judge_Pod["LLM Judge Detector Pod"]
                JudgeSidecar["Istio Sidecar<br/>mTLS STRICT"]
                JudgeDetector["LLM Judge Detector<br/>Port: 8000/TCP<br/>HTTP + mTLS<br/>Auth: KServe + Istio<br/>Image: guardrails-detector-llm-judge"]
            end
        end

        subgraph Storage["STORAGE"]
            S3["S3/MinIO<br/>9000/TCP HTTP<br/>Auth: AWS credentials"]
        end

        subgraph Inference["INFERENCE"]
            vLLM["External vLLM Server<br/>8080/TCP HTTP<br/>OpenAI-compatible API"]
        end

        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% Flows
    OrchestratorSvc -->|"HTTP/8080<br/>plaintext<br/>No Auth"| BuiltIn
    OrchestratorSvc -->|"HTTP/8000<br/>mTLS (Istio)<br/>KServe auth"| HFSidecar
    OrchestratorSvc -->|"HTTP/8000<br/>mTLS (Istio)<br/>KServe auth"| JudgeSidecar
    HFSidecar --> HFDetector
    JudgeSidecar --> JudgeDetector

    HFDetector -->|"S3 API/9000<br/>plaintext<br/>AWS key/secret"| S3
    JudgeDetector -->|"HTTP/8080<br/>OpenAI API<br/>No Auth (internal)"| vLLM
    HFDetector -.->|"HTTPS/443<br/>TLS 1.2+<br/>Token (optional)"| HFHub

    Prometheus -->|"HTTP/8080<br/>scrape /metrics"| BuiltIn
    Prometheus -->|"HTTP/8000<br/>scrape /metrics"| HFDetector
    Prometheus -->|"HTTP/8000<br/>scrape /metrics"| JudgeDetector

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef orchestrator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kserve fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef sidecar fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef storage fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class HFHub external
    class BuiltIn,OrchestratorSvc orchestrator
    class HFDetector,JudgeDetector kserve
    class HFSidecar,JudgeSidecar sidecar
    class S3,vLLM storage
    class Prometheus monitoring
