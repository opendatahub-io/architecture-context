%% ML Metadata - RBAC Visualization
%% Generated by: Claude Opus 4.6
%% Note: MLMD defines no RBAC roles itself. RBAC is managed by the deploying operator.

graph TD
    subgraph "ML Metadata RBAC Model"
        Note["Note: ML Metadata does not define<br/>its own RBAC roles or bindings.<br/>RBAC is managed externally by the<br/>RHOAI Operator (DS Pipelines Controller)."]
    end

    subgraph "Deploying Operator RBAC (External)"
        SA["ServiceAccount<br/>(managed by DS Pipelines Controller)"]
        CRB["ClusterRoleBinding / RoleBinding<br/>(managed by operator)"]
        CR["ClusterRole / Role<br/>(managed by operator)"]
    end

    subgraph "Authentication at Service Level"
        direction TB
        gRPCAuth["gRPC MetadataStoreService<br/>8080/TCP"]
        TLSConfig["SSLConfig<br/>Optional TLS"]
        mTLSConfig["client_verify<br/>Optional mTLS"]

        gRPCAuth -->|"configurable"| TLSConfig
        gRPCAuth -->|"configurable"| mTLSConfig
    end

    subgraph "Container Security"
        Container["odh-mlmd-grpc-server"]
        NonRoot["Non-root User<br/>UID: 65534<br/>GID: 65534"]
        BaseImage["Base Image<br/>UBI9 (ubi-minimal)"]

        Container -->|"runs as"| NonRoot
        Container -->|"built on"| BaseImage
    end

    subgraph "Secrets"
        DBCreds["Database Credentials<br/>(Opaque)<br/>host, port, user,<br/>password, database"]
        SSLCerts["SSL Certificates<br/>(kubernetes.io/tls)<br/>gRPC server & DB certs"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -.->|"manages deployment of"| Container

    Container -->|"uses"| DBCreds
    Container -->|"uses"| SSLCerts

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style CRB fill:#e8e8e8,stroke:#333
    style gRPCAuth fill:#4a90e2,stroke:#333,color:#fff
    style TLSConfig fill:#d5e8d4,stroke:#82b366
    style mTLSConfig fill:#d5e8d4,stroke:#82b366
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#e8e8e8,stroke:#333
    style DBCreds fill:#f8cecc,stroke:#b85450
    style SSLCerts fill:#f8cecc,stroke:#b85450
