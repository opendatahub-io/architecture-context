// RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // People
        developer = person "Developer" "Pushes build configuration changes to the repository"
        releaseEngineer = person "Release Engineer" "Manages operator releases and promotions"
        clusterAdmin = person "Cluster Administrator" "Installs and manages RHOAI on OpenShift"

        // Primary System
        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration repository defining OLM operator bundle, FBC catalog fragments, image references, and CI/CD pipelines for RHOAI 3.3" {
            olmBundle = container "OLM Bundle" "Packages rhods-operator CSV, 24 CRDs, RBAC, and 12 webhook definitions" "YAML Manifests"
            fbcCatalog = container "FBC Catalog Fragments" "Defines operator upgrade graph for OCP v4.19, v4.20, v4.21" "YAML Catalog"
            buildConfig = container "Build Configuration" "Maps image registries (quay.io -> registry.redhat.io), defines supported OCP versions" "YAML Config"
            tektonPipelines = container "Tekton Pipelines" "Builds operator bundle and FBC fragment container images via Konflux" "Tekton YAML"
            ghActions = container "GitHub Actions Workflows" "Automates bundle processing, FBC generation, nightly builds, stage promotion" "GitHub Actions"
            mirrorSet = container "ImageDigestMirrorSet" "Enables quay.io -> registry.redhat.io mirroring for disconnected clusters" "YAML Config"
            ecPipeline = container "Enterprise Contract Pipeline" "Validates container image signatures and compliance policies" "Tekton Task"
        }

        // External Systems
        github = softwareSystem "GitHub" "Source code hosting and CI/CD triggers" "External"
        konflux = softwareSystem "Konflux" "Tekton-based CI/CD build system" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager for operator installation" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Supply chain security verification" "External"
        quay = softwareSystem "quay.io/rhoai" "Development/staging container image registry" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Production container image registry" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target platform (v4.19, v4.20, v4.21)" "External"

        // Internal ODH Systems
        rhodsOperator = softwareSystem "rhods-operator" "Operator whose bundle/CSV is defined in this repository" "Internal ODH"
        konfluxAutomation = softwareSystem "RHOAI-Konflux-Automation" "Shared automation scripts for bundle/FBC processing" "Internal ODH"

        // Relationships - People
        developer -> rhoaiBuildConfig "Pushes configuration changes"
        releaseEngineer -> rhoaiBuildConfig "Manages releases and promotions"
        clusterAdmin -> olm "Installs RHOAI operator via OLM catalog"

        // Relationships - External
        rhoaiBuildConfig -> github "Source repository hosted on" "HTTPS/443"
        rhoaiBuildConfig -> konflux "Triggers builds via" "HTTPS/443"
        rhoaiBuildConfig -> enterpriseContract "Validates images via" "HTTPS/443"
        rhoaiBuildConfig -> quay "Pushes bundle images to" "HTTPS/443"
        rhoaiBuildConfig -> registryRedHat "Production images served from" "HTTPS/443"
        olm -> rhoaiBuildConfig "Reads FBC catalog fragments from"
        olm -> rhodsOperator "Installs and manages"
        olm -> registryRedHat "Pulls operator images from" "HTTPS/443"

        // Relationships - Internal
        rhoaiBuildConfig -> rhodsOperator "Defines bundle/CSV for"
        rhoaiBuildConfig -> konfluxAutomation "Uses shared automation from" "HTTPS/443"

        // Container relationships
        ghActions -> konfluxAutomation "Fetches automation utils" "HTTPS/443"
        tektonPipelines -> quay "Pushes built images" "HTTPS/443"
        ecPipeline -> quay "Verifies image signatures" "HTTPS/443"
        buildConfig -> olmBundle "Patches image references in"
        fbcCatalog -> olm "Provides catalog entries to"
        mirrorSet -> registryRedHat "Mirrors images to"
        mirrorSet -> quay "Mirrors images from"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
