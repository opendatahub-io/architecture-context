graph TD
    subgraph "Notebooks Component RBAC"
        direction TB
        Note["This component does not define<br/>its own RBAC resources.<br/>RBAC is managed by external components."]
    end

    subgraph "Authentication Architecture (per Workbench Pod)"
        direction TB

        subgraph "RHOAI 3.x Pattern"
            User3["User Browser"]
            Gateway3["Gateway Envoy<br/>443/TCP HTTPS"]
            KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS"]
            Workbench3["Workbench Container<br/>8888/TCP HTTP<br/>(no built-in auth)"]

            User3 -->|"HTTPS/443<br/>TLS 1.2+"| Gateway3
            Gateway3 -->|"HTTPS/8443<br/>Bearer Token"| KRBAC
            KRBAC -->|"HTTP/8888<br/>plaintext localhost"| Workbench3
        end

        subgraph "RHOAI 2.x Pattern"
            User2["User Browser"]
            Route2["OpenShift Route<br/>443/TCP HTTPS"]
            OAuth["oauth-proxy sidecar<br/>8443/TCP HTTPS TLS"]
            Workbench2["Workbench Container<br/>8888/TCP HTTP<br/>(no built-in auth)"]

            User2 -->|"HTTPS/443<br/>TLS 1.2+"| Route2
            Route2 -->|"HTTPS/8443<br/>OAuth Token"| OAuth
            OAuth -->|"HTTP/8888<br/>plaintext localhost"| Workbench2
        end
    end

    subgraph "RBAC Managed By External Components"
        direction TB

        subgraph "ODH Notebook Controller"
            SA_Ctrl["ServiceAccount<br/>notebook-controller-manager"]
            CR_Ctrl["ClusterRole<br/>notebook-controller-role"]
            SA_Ctrl -->|"bound via ClusterRoleBinding"| CR_Ctrl
            CR_Ctrl -->|"manages"| Notebooks_CR["Notebook CRs<br/>kubeflow.org/notebooks"]
            CR_Ctrl -->|"creates"| Pods["Workbench Pods"]
            CR_Ctrl -->|"creates"| Services["ClusterIP Services"]
            CR_Ctrl -->|"creates"| HTTPRoutes["HTTPRoute CRs"]
        end

        subgraph "rhods-operator"
            SA_Op["ServiceAccount<br/>rhods-operator"]
            CR_Op["ClusterRole<br/>rhods-operator-role"]
            SA_Op -->|"bound via ClusterRoleBinding"| CR_Op
            CR_Op -->|"deploys"| ImageStreams["ImageStream Resources"]
            CR_Op -->|"deploys"| ConfigMaps["ConfigMap Resources"]
        end
    end

    subgraph "Secrets"
        RHELSub["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio BuildConfig builds<br/>Provisioned: Manual/Admin<br/>Auto-Rotate: No"]
    end

