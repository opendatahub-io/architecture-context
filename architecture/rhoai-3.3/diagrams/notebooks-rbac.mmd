graph TD
    subgraph "RBAC Model (Managed by odh-notebook-controller)"
        direction TB

        subgraph "Service Accounts"
            WorkbenchSA["ServiceAccount<br/>{workbench-name}-sa<br/>Namespace: {user-namespace}"]
        end

        subgraph "Role Bindings (Namespace-scoped)"
            WorkbenchRB["RoleBinding<br/>{workbench-name}-rb<br/>Created by odh-notebook-controller"]
        end

        subgraph "Roles (Namespace-scoped)"
            WorkbenchRole["Role: {workbench-name}-role<br/>API Groups: core, apps<br/>Resources: configmaps, secrets, imagestreams<br/>Verbs: get, list, watch"]
        end

        subgraph "Kubernetes API Resources (Namespace-scoped)"
            ConfigMaps["ConfigMaps<br/>Workbench configuration"]
            Secrets["Secrets<br/>Git, S3, API credentials"]
            ImageStreams["ImageStreams<br/>Available workbench images"]
            Pods["Pods<br/>Workbench pods"]
        end

        subgraph "Cluster-scoped Resources (Limited Access)"
            Nodes["Nodes<br/>Read-only (for GPU detection)"]
        end
    end

    subgraph "User Access Control"
        User["User (Data Scientist)<br/>OpenShift user account"]
        OAuthProxy["OAuth Proxy<br/>Enforces authentication"]
        NamespaceAccess["Namespace RBAC<br/>User must have namespace access"]
    end

    subgraph "Security Context Constraints"
        SCC["SCC: restricted<br/>Non-root UID 1001<br/>No privileged operations<br/>No host access"]
    end

    subgraph "Workbench Pod"
        WorkbenchPod["Workbench Pod<br/>Runs as ServiceAccount: {workbench-name}-sa<br/>UID: 1001 (non-root)"]
    end

    %% User to workbench access
    User -->|authenticates via| OAuthProxy
    OAuthProxy -->|validates| NamespaceAccess
    NamespaceAccess -->|grants access to| WorkbenchPod

    %% RBAC flow
    WorkbenchSA -->|bound via| WorkbenchRB
    WorkbenchRB -->|grants| WorkbenchRole
    WorkbenchRole -->|allows get,list,watch| ConfigMaps
    WorkbenchRole -->|allows get,list,watch| Secrets
    WorkbenchRole -->|allows get,list| ImageStreams

    %% Pod uses ServiceAccount
    WorkbenchPod -.->|runs as| WorkbenchSA

    %% SCC enforcement
    SCC -.->|restricts| WorkbenchPod

    %% Limited cluster access
    WorkbenchSA -.->|read-only via default SA| Nodes

    %% Permissions NOT granted
    ClusterResources["❌ Cluster Resources<br/>No cross-namespace access<br/>No cluster-admin permissions"]
    WorkbenchRole -.->|NO cluster-admin| ClusterResources

    subgraph "Default Kubernetes ServiceAccount Permissions"
        DefaultSA["Default SA Token<br/>Mounted at /var/run/secrets/kubernetes.io/serviceaccount/token<br/>Allows basic API discovery<br/>Allows kubectl/oc commands within namespace"]
    end

    WorkbenchSA -.->|inherits| DefaultSA
    DefaultSA -->|allows namespace-scoped kubectl/oc| Pods

    subgraph "External Authentication (OAuth)"
        OpenShiftOAuth["OpenShift OAuth Server<br/>Issues JWT tokens<br/>Validates user identity"]
    end

    OAuthProxy <-->|validates tokens with| OpenShiftOAuth

    subgraph "Secrets Management"
        WorkbenchOAuthSecret["Secret: {workbench}-oauth-config<br/>Type: Opaque<br/>OAuth proxy configuration"]
        WorkbenchTLSSecret["Secret: {workbench}-tls<br/>Type: kubernetes.io/tls<br/>TLS certificate (90d rotation)"]
        UserSecrets["User-created Secrets<br/>Git credentials, S3 keys, API tokens"]
    end

    OAuthProxy -->|reads| WorkbenchOAuthSecret
    WorkbenchPod -->|may mount| UserSecrets
    WorkbenchPod -.->|route uses| WorkbenchTLSSecret

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px
    classDef resource fill:#7ed321,stroke:#333,stroke-width:2px
    classDef user fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef denied fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef scc fill:#3498db,stroke:#333,stroke-width:2px,color:#fff
    classDef secret fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff

    class WorkbenchSA,DefaultSA serviceaccount
    class WorkbenchRole,WorkbenchRB role
    class ConfigMaps,Secrets,ImageStreams,Pods,Nodes resource
    class User,OAuthProxy,NamespaceAccess,OpenShiftOAuth user
    class ClusterResources denied
    class SCC scc
    class WorkbenchOAuthSecret,WorkbenchTLSSecret,UserSecrets secret
    class WorkbenchPod serviceaccount
