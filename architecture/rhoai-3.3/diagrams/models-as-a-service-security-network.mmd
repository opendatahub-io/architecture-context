%% Models as a Service - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User/Client"]
    end

    subgraph Ingress["INGRESS (Gateway API Layer)"]
        direction TB
        Gateway["maas-default-gateway<br/>GatewayClass: openshift-default<br/>80/TCP HTTP, 443/TCP HTTPS<br/>TLS: Terminate"]

        subgraph Policies["Kuadrant Policy Engine"]
            GWAuth["gateway-auth-policy<br/>TokenReview + SubjectAccessReview<br/>Tier lookup callback (300s cache)"]
            MaaSAuth["maas-api-auth-policy<br/>TokenReview<br/>Sets X-MaaS-Username/Group"]
            RateLimit["token-rate-limit-policy<br/>Free: 100 tok/min<br/>Premium: 50K tok/min<br/>Enterprise: 100K tok/min"]
        end

        Gateway --- GWAuth
        Gateway --- MaaSAuth
        Gateway --- RateLimit
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph MaaSPod["maas-api Pod<br/>SA: maas-api | User: 1001<br/>runAsNonRoot | readOnlyRootFS<br/>drop ALL caps | FIPS"]
            API["maas-api Service<br/>ClusterIP 8080/TCP (HTTP)<br/>or 8443/TCP (HTTPS TLS 1.2+)"]
        end
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Connection credentials<br/>(HA mode only)"]
        KServeEndpoints["KServe Model Endpoints<br/>443/TCP HTTPS<br/>TLS (InsecureSkipVerify)<br/>Bearer Token"]
    end

    subgraph KuadrantSvc["KUADRANT SERVICES"]
        Authorino["Authorino<br/>kuadrant-system /<br/>openshift-operators"]
        Limitador["Limitador<br/>kuadrant-system"]
    end

    %% External to Gateway
    Client -->|"HTTPS/443<br/>TLS Terminate<br/>Bearer Token<br/>(OpenShift ID or SA token)"| Gateway

    %% Gateway to MaaS API
    Gateway -->|"HTTP/8080 or HTTPS/8443<br/>plaintext or TLS 1.2+<br/>X-MaaS-Username/Group headers"| API

    %% Gateway policy evaluation
    GWAuth -.->|"TokenReview +<br/>SubjectAccessReview"| K8sAPI
    GWAuth -.->|"POST /v1/tiers/lookup<br/>HTTP/8080 (internal)"| API
    MaaSAuth -.->|"TokenReview"| K8sAPI

    %% Gateway to Kuadrant
    Gateway -.-> Authorino
    Gateway -.-> Limitador

    %% MaaS API egress
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenRequest, CRUD NS/SA"| K8sAPI
    API -->|"HTTPS/443<br/>TLS (InsecureSkipVerify)<br/>Bearer Token<br/>Auth loopback check"| KServeEndpoints
    API -.->|"TCP/5432<br/>Configurable encryption<br/>Connection credentials<br/>API key metadata"| PostgreSQL

    %% Network Policy
    Authorino -.->|"NetworkPolicy:<br/>maas-authorino-allow"| API

    %% Gateway to LLM backends
    Gateway -->|"Proxied request<br/>Bearer Token"| KServeEndpoints

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef kuadrant fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef policy fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Client external
    class Gateway ingress
    class GWAuth,MaaSAuth,RateLimit policy
    class API,MaaSPod app
    class K8sAPI k8s
    class PostgreSQL,KServeEndpoints extservice
    class Authorino,Limitador kuadrant
