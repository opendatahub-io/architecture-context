%% Component Structure Diagram for vllm-gaudi
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "vllm-gaudi Plugin"
        Platform[HpuPlatform<br/>Plugin Registration]
        ModelRunner[HPUModelRunner<br/>Forward Pass Execution]
        Worker[HPUWorker<br/>Device Lifecycle]
        Attention[Attention Backends<br/>HPUAttentionV1 / UnifiedMLA]
        CustomOps[Custom Ops<br/>FP8, MoE, RoPE, LayerNorm]
        Communicator[HpuCommunicator<br/>HCCL Distributed Comm]
        NIXL[NIXL KV Connector<br/>KV-cache Transfer]
        SpecDec[Speculative Decoding<br/>EAGLE on HPU]
        Models[Model Overrides<br/>Gemma3, Qwen, DeepSeek, etc.]
        LoRA[LoRA Support<br/>PunicaWrapperHPU]
        Calibration[Calibration Tools<br/>FP8 Quantization Pipeline]
        ExtRuntime[Extension Runtime<br/>Config & Feature Flags]

        Platform -->|configures| Worker
        Platform -->|selects| Attention
        Worker -->|manages| ModelRunner
        ModelRunner -->|uses| Attention
        ModelRunner -->|uses| CustomOps
        ModelRunner -->|loads| Models
        ModelRunner -->|applies| LoRA
        Worker -->|communicates via| Communicator
        Worker -->|transfers KV via| NIXL
        ModelRunner -->|optional| SpecDec
        ExtRuntime -->|configures| Platform
    end

    subgraph "vLLM Core Engine"
        APIServer[vLLM API Server<br/>Port 8000/TCP]
        Engine[vLLM Engine<br/>v0.16.0]
    end

    subgraph "Intel Gaudi Hardware"
        HPU[Intel Gaudi HPU<br/>SynapseAI 1.23.0]
    end

    subgraph "RHOAI Platform"
        KServe[KServe<br/>ServingRuntime]
        Gateway[Gateway API / Istio<br/>TLS Termination]
        ModelCtrl[Model Controller<br/>InferenceService CR]
        ModelReg[Model Registry<br/>Optional]
    end

    subgraph "External Services"
        HFHub[HuggingFace Hub<br/>443/TCP HTTPS]
        S3[Object Storage S3<br/>443/TCP HTTPS]
    end

    Client[Client] -->|HTTPS/443| Gateway
    Gateway -->|HTTP/80| KServe
    KServe -->|HTTP/8000| APIServer
    APIServer -->|invokes| Engine
    Engine -->|delegates to| Platform
    ModelRunner -->|executes on| HPU
    Communicator -->|HCCL/RDMA| HPU

    ModelCtrl -->|manages| KServe
    KServe -.->|metadata| ModelReg

    Worker -->|downloads| S3
    Worker -->|downloads| HFHub

