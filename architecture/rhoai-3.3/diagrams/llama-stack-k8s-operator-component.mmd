graph TB
    subgraph "Llama Stack Operator (redhat-ods-applications)"
        Controller[Controller Manager<br/>Deployment]
        LlamaStackController[LlamaStackDistribution Controller]
        KustomizeEngine[Kustomize Engine<br/>In-Process]
        ConfigMapWatcher[ConfigMap Watcher]
        NetworkPolicyMgr[NetworkPolicy Manager]
        MetricsService[Metrics Service<br/>8443/TCP HTTPS]
        HealthProbes[Health Probes<br/>8081/TCP HTTP]

        Controller -->|reconciles| LlamaStackController
        Controller -->|watches| ConfigMapWatcher
        Controller -->|renders manifests| KustomizeEngine
        LlamaStackController -->|manages| NetworkPolicyMgr
        Controller -->|exposes| MetricsService
        Controller -->|provides| HealthProbes
    end

    subgraph "Custom Resources"
        LlamaStackDistCR[LlamaStackDistribution CR<br/>llamastack.io/v1alpha1]
        ConfigMapConfig[llama-stack-operator-config<br/>ConfigMap]
    end

    subgraph "Managed Resources (Created by Operator)"
        LlamaStackDeploy[Llama Stack Deployment<br/>8321/TCP]
        LlamaStackSvc[Llama Stack Service<br/>8321/TCP]
        PVC[PersistentVolumeClaim<br/>10Gi default]
        Ingress[Ingress<br/>Optional]
        NetPol[NetworkPolicy<br/>Optional]
        HPA[HorizontalPodAutoscaler<br/>Optional]
        PDB[PodDisruptionBudget<br/>Optional]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        Ollama[Ollama Server<br/>11434/TCP HTTP]
        vLLM[vLLM Server<br/>8000/TCP HTTP/HTTPS]
        HuggingFace[HuggingFace Hub<br/>443/TCP HTTPS]
        Registry[Container Registry<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>ServiceMonitor]
    end

    subgraph "User Interaction"
        User[User/CI<br/>kubectl]
    end

    %% User creates CR
    User -->|creates| LlamaStackDistCR
    User -->|updates| ConfigMapConfig

    %% CR watched by controller
    LlamaStackDistCR -->|watched by| LlamaStackController
    ConfigMapConfig -->|watched by| ConfigMapWatcher

    %% Controller manages resources
    LlamaStackController -->|creates/updates| LlamaStackDeploy
    LlamaStackController -->|creates| LlamaStackSvc
    LlamaStackController -->|creates| PVC
    LlamaStackController -->|creates| Ingress
    NetworkPolicyMgr -->|creates/deletes| NetPol
    LlamaStackController -->|creates| HPA
    LlamaStackController -->|creates| PDB

    %% Operator dependencies
    Controller -->|watches/creates/updates| K8sAPI
    LlamaStackController -->|renders templates| KustomizeEngine
    MetricsService -->|scraped by| Prometheus

    %% Llama Stack runtime dependencies
    LlamaStackDeploy -->|inference requests| Ollama
    LlamaStackDeploy -->|inference requests| vLLM
    LlamaStackDeploy -->|model downloads| HuggingFace
    LlamaStackDeploy -->|pulls images| Registry

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style LlamaStackController fill:#4a90e2,stroke:#333,stroke-width:2px
    style LlamaStackDistCR fill:#f5a623,stroke:#333,stroke-width:2px
    style LlamaStackDeploy fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Ollama fill:#e8e8e8,stroke:#333,stroke-width:2px
    style vLLM fill:#e8e8e8,stroke:#333,stroke-width:2px
