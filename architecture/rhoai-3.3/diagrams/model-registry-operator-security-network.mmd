graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.3 reencrypt<br/>{registry-name}-rest.{domain}"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER (Cluster Internal)"]
        direction TB

        subgraph NS_Registry["Namespace: {registry-namespace}"]
            direction TB

            subgraph Pod_MR["Model Registry Pod"]
                RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ (Service CA)"]
                RestAPI["Model Registry REST<br/>8080/TCP HTTP<br/>(localhost only)"]
            end

            Service["Service: {registry-name}<br/>8443/TCP (HTTPS)<br/>8080/TCP (HTTP - no proxy)"]

            subgraph DataIsolation["Network Isolated (NetworkPolicy)"]
                PostgresDB["PostgreSQL<br/>5432/TCP<br/>Password/Cert Auth<br/>Optional TLS"]
            end
        end
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: {operator-namespace}"]
            Operator["Controller Manager<br/>SA: controller-manager"]
            WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>mTLS (cert-manager)"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph ExternalDB["EXTERNAL SERVICES (Optional)"]
        ExtMySQL["MySQL Database<br/>3306/TCP<br/>Optional TLS<br/>Password/Cert Auth"]
    end

    %% External flow
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token"| Router
    Router -->|"HTTPS/8443<br/>TLS 1.2+ reencrypt<br/>Bearer Token"| Service
    Service --> RBACProxy

    %% Authentication flow
    RBACProxy -->|"SubjectAccessReview<br/>HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -.->|"Authz: true/false"| RBACProxy

    %% Authorized request flow
    RBACProxy -->|"HTTP/8080<br/>localhost<br/>No encryption"| RestAPI
    RestAPI -->|"PostgreSQL/5432<br/>Optional TLS<br/>Password/Cert"| PostgresDB

    %% Alternative DB
    RestAPI -.->|"MySQL/3306<br/>Optional TLS<br/>Password/Cert"| ExtMySQL

    %% Operator flows
    Operator -->|"Watch CRs<br/>Create Resources<br/>HTTPS/6443<br/>SA Token"| K8sAPI
    K8sAPI -->|"Admission Webhook<br/>HTTPS/9443<br/>mTLS"| WebhookSvc

    %% Internal access (no proxy)
    Client -.->|"Internal pods only<br/>HTTP/8080<br/>No auth"| Service

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef database fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router ingress
    class RBACProxy,RestAPI,Service application
    class PostgresDB database
    class Operator,WebhookSvc controlplane
    class K8sAPI cluster
    class ExtMySQL externalservice
