graph TD
    subgraph "Service Accounts"
        SA_Manager[controller-manager<br/>Namespace: trustyai-operator-system]
        SA_TrustyAI["{trustyai-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding]
        CRB_Proxy[proxy-rolebinding]
    end

    subgraph "Role Bindings"
        RB_Leader[leader-election-rolebinding<br/>Namespace: trustyai-operator-system]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Proxy[proxy-role]
    end

    subgraph "Roles"
        R_Leader[leader-election-role<br/>Namespace: trustyai-operator-system]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps[core/configmaps<br/>create, delete, get, list, patch, update, watch]
        Core_PVCs[core/persistentvolumeclaims<br/>create, delete, get, list, patch, update, watch]
        Core_Pods[core/pods<br/>create, delete, get, list, patch, update, watch]
        Core_PodExec[core/pods/exec<br/>create, delete, get, list, watch]
        Core_Secrets[core/secrets<br/>create, delete, get, list, patch, update, watch]
        Core_ServiceAccounts[core/serviceaccounts<br/>create, delete, get, list, patch, update, watch]
        Core_Services[core/services<br/>create, delete, get, list, patch, update, watch]
        Core_Events[core/events<br/>create, patch, update, watch]
        Core_PVs[core/persistentvolumes<br/>get, list, watch]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments[apps/deployments<br/>create, delete, get, list, patch, update, watch]
        Apps_DeploymentsFinalizers[apps/deployments/finalizers<br/>update]
        Apps_DeploymentsStatus[apps/deployments/status<br/>get, patch, update]
    end

    subgraph "API Resources - KServe"
        KServe_InferenceServices[serving.kserve.io/inferenceservices<br/>get, list, patch, update, watch]
        KServe_InferenceServicesFinalizers[serving.kserve.io/inferenceservices/finalizers<br/>delete, get, list, patch, update, watch]
        KServe_ServingRuntimes[serving.kserve.io/servingruntimes<br/>get, list, watch]
    end

    subgraph "API Resources - Istio"
        Istio_DestinationRules[networking.istio.io/destinationrules<br/>create, delete, get, list, patch, update, watch]
        Istio_VirtualServices[networking.istio.io/virtualservices<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - OpenShift"
        OpenShift_Routes[route.openshift.io/routes<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_ServiceMonitors[monitoring.coreos.com/servicemonitors<br/>create, list, watch]
    end

    subgraph "API Resources - Kueue"
        Kueue_Workloads[kueue.x-k8s.io/workloads<br/>create, delete, get, list, patch, update, watch]
        Kueue_WorkloadsFinalizers[kueue.x-k8s.io/workloads/finalizers<br/>update]
        Kueue_WorkloadsStatus[kueue.x-k8s.io/workloads/status<br/>get, patch, update]
        Kueue_ResourceFlavors[kueue.x-k8s.io/resourceflavors<br/>get, list, watch]
        Kueue_WorkloadPriorityClasses[kueue.x-k8s.io/workloadpriorityclasses<br/>get, list, watch]
    end

    subgraph "API Resources - TrustyAI CRDs"
        TrustyAI_TrustyAIServices[trustyai.opendatahub.io/trustyaiservices<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_LMEvalJobs[trustyai.opendatahub.io/lmevaljobs<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_GuardrailsOrchestrators[trustyai.opendatahub.io/guardrailsorchestrators<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_NemoGuardrails[trustyai.opendatahub.io/nemoguardrails<br/>create, delete, get, list, patch, update, watch]
        TrustyAI_Finalizers[trustyai.opendatahub.io/*/finalizers<br/>update]
        TrustyAI_Status[trustyai.opendatahub.io/*/status<br/>get, patch, update]
    end

    subgraph "API Resources - RBAC & Auth"
        RBAC_ClusterRoleBindings[rbac.authorization.k8s.io/clusterrolebindings<br/>create, delete, get, list, update, watch]
        Auth_TokenReviews[authentication.k8s.io/tokenreviews<br/>create]
        Auth_SubjectAccessReviews[authorization.k8s.io/subjectaccessreviews<br/>create]
    end

    subgraph "API Resources - Coordination"
        Coord_Leases[coordination.k8s.io/leases<br/>create, get, update]
        Coord_LeasesLeader[coordination.k8s.io/leases<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account to Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Proxy
    SA_Manager -->|bound via| RB_Leader

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    %% ClusterRole: manager-role permissions
    CR_Manager -->|permissions| Core_ConfigMaps
    CR_Manager -->|permissions| Core_PVCs
    CR_Manager -->|permissions| Core_Pods
    CR_Manager -->|permissions| Core_PodExec
    CR_Manager -->|permissions| Core_Secrets
    CR_Manager -->|permissions| Core_ServiceAccounts
    CR_Manager -->|permissions| Core_Services
    CR_Manager -->|permissions| Core_Events
    CR_Manager -->|permissions| Core_PVs
    CR_Manager -->|permissions| Apps_Deployments
    CR_Manager -->|permissions| Apps_DeploymentsFinalizers
    CR_Manager -->|permissions| Apps_DeploymentsStatus
    CR_Manager -->|permissions| KServe_InferenceServices
    CR_Manager -->|permissions| KServe_InferenceServicesFinalizers
    CR_Manager -->|permissions| KServe_ServingRuntimes
    CR_Manager -->|permissions| Istio_DestinationRules
    CR_Manager -->|permissions| Istio_VirtualServices
    CR_Manager -->|permissions| OpenShift_Routes
    CR_Manager -->|permissions| Monitoring_ServiceMonitors
    CR_Manager -->|permissions| Kueue_Workloads
    CR_Manager -->|permissions| Kueue_WorkloadsFinalizers
    CR_Manager -->|permissions| Kueue_WorkloadsStatus
    CR_Manager -->|permissions| Kueue_ResourceFlavors
    CR_Manager -->|permissions| Kueue_WorkloadPriorityClasses
    CR_Manager -->|permissions| TrustyAI_TrustyAIServices
    CR_Manager -->|permissions| TrustyAI_LMEvalJobs
    CR_Manager -->|permissions| TrustyAI_GuardrailsOrchestrators
    CR_Manager -->|permissions| TrustyAI_NemoGuardrails
    CR_Manager -->|permissions| TrustyAI_Finalizers
    CR_Manager -->|permissions| TrustyAI_Status
    CR_Manager -->|permissions| RBAC_ClusterRoleBindings
    CR_Manager -->|permissions| Coord_Leases

    %% ClusterRole: proxy-role permissions
    CR_Proxy -->|permissions| Auth_TokenReviews
    CR_Proxy -->|permissions| Auth_SubjectAccessReviews

    %% Role: leader-election-role permissions
    R_Leader -->|permissions| Coord_LeasesLeader

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_TrustyAI fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_Manager fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB_Proxy fill:#7ed321,stroke:#333,stroke-width:2px
    style RB_Leader fill:#7ed321,stroke:#333,stroke-width:2px
