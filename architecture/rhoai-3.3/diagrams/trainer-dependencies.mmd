graph LR
    Trainer[Kubeflow Trainer]

    %% External Dependencies (Required)
    Trainer -->|platform| K8s[Kubernetes v1.34.1]
    Trainer -->|multi-node training| JobSet[JobSet v0.10.1]

    %% External Dependencies (Optional)
    Trainer -.->|gang scheduling| Volcano[Volcano Scheduler v1.13.1]
    Trainer -.->|gang scheduling| Coscheduling[Coscheduling Plugin v0.34.1]
    Trainer -.->|leader-worker topology| LeaderWorkerSet[LeaderWorkerSet]
    Trainer -.->|metrics| PrometheusOp[Prometheus Operator]

    %% Internal ODH Dependencies
    Trainer -.->|queue mgmt| Kueue[Kueue<br/>Optional]
    Trainer -.->|secure comms| ServiceMesh[OpenShift Service Mesh<br/>Optional]
    Trainer -.->|monitoring| Monitoring[OpenShift Monitoring<br/>RHOAI]

    %% External Services
    Trainer -->|model storage| S3[S3 Storage<br/>AWS]
    Trainer -->|datasets/models| HuggingFace[HuggingFace Hub]
    Trainer -.->|storage| GCS[Google Cloud Storage<br/>Optional]
    Trainer -.->|storage| PVC[PersistentVolumeClaims<br/>Optional]

    %% Integration Points
    K8sAPI[Kubernetes API] -->|creates| JobSet
    K8sAPI -->|creates| Volcano
    JobSet -->|creates| Jobs[Kubernetes Jobs]
    Jobs -->|creates| Pods[Training Pods]
    Volcano -->|schedules| Pods

    %% RHOAI Extensions
    Trainer -->|progression tracking| Pods
    Trainer -->|network isolation| NetworkPolicies[NetworkPolicies<br/>RHOAI]

    %% Training Runtimes
    subgraph Runtimes["Built-in Training Runtimes (RHOAI)"]
        TorchDistributed[torch-distributed<br/>CUDA 12.8]
        TorchROCm[torch-distributed-rocm<br/>ROCm 6.4]
        TrainingHub[training-hub<br/>HuggingFace]
        DeepSpeed[deepspeed-distributed<br/>Memory-efficient]
        MLX[mlx-distributed<br/>Apple Silicon]
    end

    Trainer -->|uses| Runtimes

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style JobSet fill:#ff6b6b,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333
    style Coscheduling fill:#999,stroke:#333
    style LeaderWorkerSet fill:#999,stroke:#333
    style PrometheusOp fill:#999,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style ServiceMesh fill:#7ed321,stroke:#333
    style Monitoring fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style NetworkPolicies fill:#50e3c2,stroke:#333
    style TorchDistributed fill:#ee4c2c,stroke:#333
    style TorchROCm fill:#ee4c2c,stroke:#333
    style TrainingHub fill:#ee4c2c,stroke:#333
    style DeepSpeed fill:#ee4c2c,stroke:#333
    style MLX fill:#ee4c2c,stroke:#333
