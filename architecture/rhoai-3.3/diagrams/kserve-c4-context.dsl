// KServe C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/kserve.md

workspace {
    model {
        // People
        dataScientist = person "Data Scientist" "Creates and deploys ML models via InferenceService and LLMInferenceService CRs"
        mlEngineer = person "ML Engineer" "Manages model serving runtimes, InferenceGraphs, and deployment configurations"
        securityAdmin = person "Security Admin" "Manages RBAC, SCCs, and network policies for model serving workloads"

        // Primary system
        kserve = softwareSystem "KServe" "Kubernetes-native model serving platform providing serverless inference, LLM serving, and model pipeline orchestration for RHOAI" {
            controllerManager = container "kserve-controller-manager" "Main controller managing InferenceService, LLMInferenceService, InferenceGraph, TrainedModel CRs" "Go Operator (controller-runtime)" "Controller"
            webhookServer = container "Webhook Server" "Validates and mutates InferenceService and LLMInferenceService CRs" "Go (9443/TCP HTTPS)" "Webhook"
            kubeRBACProxy = container "kube-rbac-proxy" "Authentication proxy for metrics endpoint using TokenReview" "Go Sidecar (8443/TCP HTTPS)" "Sidecar"
            storageInitializer = container "storage-initializer" "Downloads model artifacts from S3/GCS/Azure/PVC into model serving containers" "Go Init Container" "InitContainer"
            kserveAgent = container "kserve-agent" "Multi-model serving agent with inference logging and request batching" "Go Sidecar" "Sidecar"
            kserveRouter = container "kserve-router" "Routes requests in InferenceGraph DAG pipelines across model nodes" "Go Service (8080/TCP)" "Router"
            localModelManager = container "localmodel-manager" "Manages LocalModelCache and LocalModelNode resources for node-local model caching" "Go Controller" "Controller"
            localModelNodeAgent = container "localmodelnode-agent" "Per-node agent managing local model downloads via Jobs" "Go DaemonSet" "Agent"
        }

        // LLM serving subsystem
        llmServing = softwareSystem "LLM Serving Components" "LLM-specific inference scheduling and routing" {
            llmDScheduler = container "llm-d-inference-scheduler" "LLM-specific inference scheduler for InferencePool workload routing" "Go/Python" "Scheduler"
            llmDRoutingSidecar = container "llm-d-routing-sidecar" "Routing sidecar for disaggregated prefill/decode topology" "Go Init Container" "Sidecar"
            vllmEngine = container "vLLM Engine" "vLLM inference engine for NVIDIA CUDA and AMD ROCm accelerators" "Python (8000/TCP)" "Runtime"
        }

        // External dependencies
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for mTLS, traffic routing via VirtualServices, and ingress gateway" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes-native ingress routing via HTTPRoutes for LLMInferenceService" "External"
        gieExtension = softwareSystem "Gateway API Inference Extension" "InferencePool and InferenceModel CRDs for LLM-aware request routing (v0.3.0)" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling and routing for InferenceServices (optional)" "External"
        lws = softwareSystem "LeaderWorkerSet" "Multi-node workload orchestration for distributed LLM serving (v0.6.2)" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling for InferenceServices (v2.17.3, optional)" "External"
        otelOperator = softwareSystem "OpenTelemetry Operator" "Distributed tracing configuration (v0.113.0, optional)" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "ServiceMonitor and PodMonitor CRDs for metrics collection (v0.76.2)" "External"

        // Internal ODH dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys KServe manifests via Kustomize overlays" "Internal ODH"
        openshiftIngress = softwareSystem "OpenShift Ingress" "Route CRs for InferenceGraph ingress on OpenShift" "Internal ODH"

        // External services
        s3Storage = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, MinIO, etc.)" "External Service"
        gcsStorage = softwareSystem "Google Cloud Storage" "Model artifact storage" "External Service"
        azureStorage = softwareSystem "Azure Blob Storage" "Model artifact storage" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for controller operations" "External Service"

        // Relationships - People
        dataScientist -> kserve "Creates InferenceService / LLMInferenceService via kubectl/dashboard"
        mlEngineer -> kserve "Manages ServingRuntimes, InferenceGraphs, and deployment configs"
        securityAdmin -> kserve "Configures RBAC roles, SCCs, and network policies"

        // Relationships - KServe to dependencies
        kserve -> istio "Creates VirtualServices, DestinationRules for ingress routing and mTLS"
        kserve -> gatewayAPI "Creates HTTPRoutes for LLMInferenceService and optionally InferenceService"
        kserve -> gieExtension "Creates InferencePool and InferenceModel CRs for LLM routing"
        kserve -> knative "Creates Knative Services for serverless autoscaling" "HTTP/80"
        kserve -> lws "Creates LeaderWorkerSets for multi-node LLM workloads"
        kserve -> keda "Creates ScaledObjects for event-driven autoscaling"
        kserve -> otelOperator "Creates OpenTelemetryCollector CRs for tracing"
        kserve -> prometheusOp "Creates ServiceMonitor/PodMonitor CRs" "HTTP/8080,15020"
        kserve -> s3Storage "Downloads model artifacts via storage-initializer" "HTTPS/443"
        kserve -> gcsStorage "Downloads model artifacts via storage-initializer" "HTTPS/443"
        kserve -> azureStorage "Downloads model artifacts via storage-initializer" "HTTPS/443"
        kserve -> k8sAPI "Controller API access (CRUD on CRs, Deployments, Services)" "HTTPS/443"

        // Relationships - Internal
        rhodsOperator -> kserve "Deploys via Kustomize overlays"
        kserve -> openshiftIngress "Creates Route CRs for InferenceGraph ingress" "HTTPS/443"

        // LLM serving relationships
        kserve -> llmServing "Deploys and manages LLM serving components"
        llmServing -> s3Storage "Downloads model artifacts" "HTTPS/443"
    }

    views {
        systemContext kserve "KServe-SystemContext" {
            include *
            autoLayout
        }

        container kserve "KServe-Containers" {
            include *
            autoLayout
        }

        container llmServing "LLMServing-Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Controller" {
                background #4a90e2
                color #ffffff
            }
            element "Sidecar" {
                background #6aa84f
                color #ffffff
            }
            element "InitContainer" {
                background #e69138
                color #ffffff
            }
            element "Router" {
                background #5b6abf
                color #ffffff
            }
            element "Scheduler" {
                background #5b6abf
                color #ffffff
            }
            element "Runtime" {
                background #cc0000
                color #ffffff
            }
            element "Agent" {
                background #e69138
                color #ffffff
            }
            element "Webhook" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
