// C4 Context Diagram for llama-stack-provider-ragas
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/llama-stack-provider-ragas.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Runs LLM evaluations using Ragas metrics"

        ragasProvider = softwareSystem "Llama Stack Provider Ragas" "Ragas evaluation provider for Llama Stack - supports inline and remote (KFP) execution modes" {
            inlineProvider = container "RagasEvaluatorInline" "Runs Ragas evaluation in-process within Llama Stack server" "Python Provider"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluation as Kubeflow Pipelines jobs" "Python Provider"
            inlineLLMWrapper = container "LlamaStackInlineLLM" "Adapts Llama Stack inference API to Ragas/Langchain LLM interface" "Python Wrapper"
            inlineEmbedWrapper = container "LlamaStackInlineEmbeddings" "Adapts Llama Stack inference API to Ragas/Langchain embeddings interface" "Python Wrapper"
            remoteLLMWrapper = container "LlamaStackRemoteLLM" "HTTP client wrapper for Llama Stack LLM API" "Python Wrapper"
            remoteEmbedWrapper = container "LlamaStackRemoteEmbeddings" "HTTP client wrapper for Llama Stack embeddings API" "Python Wrapper"
            kfpPipeline = container "ragas_evaluation_pipeline" "Two-step KFP pipeline: retrieve data, run Ragas evaluation" "KFP Pipeline"
            compatLayer = container "Compatibility Layer" "Backward compatibility for llama_stack import paths" "Python Module"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts evaluation providers and provides inference, dataset, benchmark APIs" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines (Data Science Pipelines)" "Pipeline orchestration for remote evaluation execution" "Internal RHOAI"
        ollamaVllm = softwareSystem "Ollama / vLLM" "LLM inference and embeddings backend" "Internal RHOAI"
        s3Storage = softwareSystem "S3-compatible Storage" "Stores evaluation result JSONL files" "External"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides base image configuration via ConfigMap" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API for config and token loading" "Infrastructure"

        // User interactions
        user -> llamaStackServer "Submits evaluation requests" "HTTP/8321"

        // Llama Stack Server hosts the provider
        llamaStackServer -> ragasProvider "Hosts as eval provider plugin" "Python API (in-process)"

        // Inline mode
        inlineProvider -> inlineLLMWrapper "Uses for LLM calls"
        inlineProvider -> inlineEmbedWrapper "Uses for embedding calls"
        inlineLLMWrapper -> llamaStackServer "Calls inference API" "Python API (in-process)"
        inlineEmbedWrapper -> llamaStackServer "Calls inference API" "Python API (in-process)"

        // Remote mode
        remoteProvider -> kubeflowPipelines "Submits and monitors pipeline runs" "HTTPS/443 Bearer Token"
        remoteProvider -> s3Storage "Fetches evaluation results" "HTTPS/443 AWS IAM"
        kfpPipeline -> llamaStackServer "Retrieves datasets and calls inference" "HTTP/8321"
        kfpPipeline -> s3Storage "Stores evaluation results" "HTTPS/443 AWS IAM"
        kfpPipeline -> remoteLLMWrapper "Uses for LLM calls"
        kfpPipeline -> remoteEmbedWrapper "Uses for embedding calls"

        // Inference backend
        llamaStackServer -> ollamaVllm "Forwards inference requests" "HTTP/11434"

        // Config
        remoteProvider -> trustyaiOperator "Reads ragas-provider-image ConfigMap" "Kubernetes API"
        remoteProvider -> k8sAPI "Loads auth tokens from kubeconfig" "HTTPS/443"
    }

    views {
        systemContext ragasProvider "SystemContext" {
            include *
            autoLayout
        }

        container ragasProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #d4a574
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
