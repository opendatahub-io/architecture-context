%% Security Network Diagram: TrustyAI Garak LLM Red Teaming Provider for Llama Stack
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / User"]
    end

    subgraph LlamaStack["LLAMA STACK SERVER (Port 8321)"]
        direction TB
        LLS["Llama Stack Server<br/>8321/TCP HTTP/HTTPS<br/>Auth: Configurable"]

        subgraph ProviderPlugin["TrustyAI Garak Provider (in-process)"]
            RemoteAdapter["GarakRemoteEvalAdapter<br/>remote::trustyai_garak"]
            InlineAdapter["GarakInlineEvalAdapter<br/>inline::trustyai_garak"]
            ShieldOrch["SimpleShieldOrchestrator"]
        end

        FilesAPI["Files API<br/>8321/TCP"]
        SafetyAPI["Safety API<br/>8321/TCP"]
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (Remote Mode)"]
        direction TB
        KFPAPI["KFP API Server<br/>HTTPS/TLS<br/>Auth: Bearer Token"]

        subgraph Pipeline["Pipeline Pods"]
            Validate["validate_inputs<br/>(KFP Pod)"]
            Scan["garak_scan<br/>(KFP Pod)"]
            Parse["parse_results<br/>(KFP Pod)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        vLLM["vLLM Inference Server<br/>HTTP/HTTPS<br/>Auth: API Key<br/>(OPENAICOMPATIBLE_API_KEY)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS/TLS<br/>Auth: SA Token"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP 8321/TCP<br/>Configurable TLS<br/>POST /v1/eval/run"| LLS

    %% Provider internal flows
    LLS --> RemoteAdapter
    LLS --> InlineAdapter

    %% Remote mode flow
    RemoteAdapter -->|"HTTPS/TLS<br/>Bearer Token"| KFPAPI
    KFPAPI --> Validate
    Validate --> Scan
    Scan --> Parse

    %% KFP pods to external
    Scan -->|"HTTP/HTTPS<br/>API Key"| vLLM
    Scan -->|"HTTP/HTTPS 8321/TCP<br/>tls_verify configurable"| FilesAPI
    Parse -->|"HTTP/HTTPS 8321/TCP<br/>tls_verify configurable"| FilesAPI
    Validate -->|"HTTP/HTTPS 8321/TCP"| LLS

    %% Inline mode flow
    InlineAdapter -->|"HTTP/HTTPS<br/>API Key<br/>subprocess: garak"| vLLM

    %% Shield flow
    ShieldOrch -->|"HTTP/HTTPS 8321/TCP<br/>Shield evaluation"| SafetyAPI

    %% K8s API access
    RemoteAdapter -->|"HTTPS 443/TCP<br/>SA Token<br/>ConfigMap: get"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef provider fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef kfp fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef api fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class LLS llamastack
    class RemoteAdapter,InlineAdapter,ShieldOrch provider
    class KFPAPI,Validate,Scan,Parse kfp
    class vLLM,K8sAPI extservice
    class FilesAPI,SafetyAPI api
