/*
 * C4 Context Diagram - llama-stack-k8s-operator
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Platform Admin / Data Scientist" "Creates and manages LlamaStackDistribution custom resources"

        llamaStackOperator = softwareSystem "llama-stack-k8s-operator" "Kubernetes operator managing Llama Stack server deployments via LlamaStackDistribution CRs" {
            controllerManager = container "Controller Manager" "Entry point with leader election, health/readiness probes, metrics server" "Go Binary"
            reconciler = container "LlamaStackDistribution Reconciler" "Watches LlamaStackDistribution CRs; reconciles Deployments, Services, NetworkPolicies, Ingresses, PVCs, HPAs, PDBs, SAs" "Go Controller (controller-runtime)"
            kustomizeRenderer = container "Kustomize Manifest Renderer" "Renders base manifests with Go transformer plugins for namespace, name, fields, NetworkPolicy" "Go Library (sigs.k8s.io/kustomize)"
            featureFlags = container "Feature Flags" "Controls operator behavior via ConfigMap-based feature flags" "Go Package"
            clusterInfo = container "ClusterInfo" "Detects namespace, loads distribution image mappings" "Go Package"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "AI inference distribution server managed by the operator" {
            serverPod = container "Llama Stack Server Pod" "Serves inference API on 8321/TCP" "Container (RELATED_IMAGE_RH_DISTRIBUTION)"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys llama-stack-k8s-operator via kustomize overlay" "Internal RHOAI"
        odhTrustedCA = softwareSystem "ODH Trusted CA Bundle" "Platform trusted CA certificates ConfigMap" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        ingressController = softwareSystem "Ingress Controller" "Kubernetes ingress for external access" "External"

        # Relationships
        user -> llamaStackOperator "Creates LlamaStackDistribution CR via kubectl"
        rhodsOperator -> llamaStackOperator "Deploys via kustomize overlay into redhat-ods-applications" "Kustomize"

        llamaStackOperator -> k8sAPI "CRUD operations on managed resources" "HTTPS/443 TLS 1.2+"
        k8sAPI -> llamaStackOperator "Watch events for CRs and ConfigMaps" "Watch stream TLS 1.2+"
        llamaStackOperator -> llamaStackServer "Health checks, provider/version queries" "HTTP/8321 plaintext"
        llamaStackOperator -> odhTrustedCA "Auto-detects and reads CA bundle ConfigMap" "Kubernetes API"

        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTPS/8443 TLS kube-rbac-proxy"

        ingressController -> llamaStackServer "Routes external traffic (opt-in)" "HTTP/8321 plaintext"

        # Internal container relationships
        controllerManager -> reconciler "Manages"
        reconciler -> kustomizeRenderer "Renders manifests"
        reconciler -> featureFlags "Reads feature flags"
        reconciler -> clusterInfo "Gets cluster/distribution info"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #357abd
                color #ffffff
            }
        }
    }
}
