// C4 Context Diagram - Kubeflow Trainer
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/trainer.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and manages distributed ML training jobs"
        admin = person "Platform Admin" "Manages ClusterTrainingRuntimes and cluster configuration"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes operator for distributed ML training via TrainJob/TrainingRuntime CRD API" {
            controllerManager = container "trainer-controller-manager" "Manages TrainJob, TrainingRuntime, ClusterTrainingRuntime CRDs; creates JobSet resources and NetworkPolicies" "Go Operator (controller-runtime)"
            trainJobController = container "TrainJob Controller" "Watches TrainJob CRs, reconciles JobSet objects, manages NetworkPolicies, polls training metrics" "Go Controller"
            runtimeController = container "TrainingRuntime Controller" "Watches TrainingRuntime CRs, manages finalizers" "Go Controller"
            clusterRuntimeController = container "ClusterTrainingRuntime Controller" "Watches ClusterTrainingRuntime CRs, manages finalizers across namespaces" "Go Controller"
            webhooks = container "Validating Webhooks" "Validates TrainJob, TrainingRuntime, ClusterTrainingRuntime CRs on create/update" "Admission Webhook (9443/TCP TLS)"
            certController = container "Cert Controller" "Self-manages TLS certificates for webhook server" "open-policy-agent/cert-controller"
            progressionTracker = container "Progression Tracker" "Polls training pod HTTP metrics for real-time progress tracking (RHAI feature)" "Go Component"
            networkPolicyManager = container "NetworkPolicy Manager" "Creates per-TrainJob NetworkPolicies for pod isolation (RHAI feature)" "Go Component"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        jobsetController = softwareSystem "JobSet Controller" "Manages multi-job training workloads via JobSet CRD" "External Dependency"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduling via PodGroups" "External Optional"
        kueue = softwareSystem "Kueue / Scheduler-Plugins" "Optional coscheduling via PodGroups" "External Optional"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys trainer manifests and manages container image references" "Internal RHOAI"

        // User interactions
        dataScientist -> trainer "Creates TrainJob CRs via kubectl/Dashboard" "HTTPS/443"
        admin -> trainer "Manages ClusterTrainingRuntimes" "HTTPS/443"

        // Trainer dependencies
        trainer -> k8sAPI "CRUD operations on CRs, Pods, Secrets, ConfigMaps, NetworkPolicies" "HTTPS/443 TLS 1.2+ ServiceAccount token"
        trainer -> jobsetController "Creates JobSet CRs for training workloads" "CRD interaction"
        k8sAPI -> trainer "Admission webhook calls for CR validation" "HTTPS/9443 TLS self-managed cert"
        prometheus -> trainer "Scrapes controller metrics via PodMonitor" "HTTPS/8443 TLS"
        trainer -> volcano "Creates PodGroup CRs for gang scheduling" "CRD interaction (optional)"
        trainer -> kueue "Creates PodGroup CRs for coscheduling" "CRD interaction (optional)"
        rhodsOperator -> trainer "Deploys and configures trainer manifests" "Kustomize"

        // Internal container relationships
        controllerManager -> trainJobController "Runs"
        controllerManager -> runtimeController "Runs"
        controllerManager -> clusterRuntimeController "Runs"
        controllerManager -> certController "Runs"
        trainJobController -> progressionTracker "Uses"
        trainJobController -> networkPolicyManager "Uses"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Dependency" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #BBBBBB
                color #ffffff
                border dashed
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
