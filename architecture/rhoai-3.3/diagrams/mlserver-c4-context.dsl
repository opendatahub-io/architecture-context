/*
 * MLServer C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/MLServer.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys and queries ML models via InferenceService"
        sre = person "SRE / Platform Admin" "Monitors MLServer health and performance"

        mlserver = softwareSystem "MLServer" "Python-based inference server implementing V2 Inference Protocol for serving ML models over REST and gRPC" {
            restServer = container "REST Server" "Serves V2 REST API endpoints for inference, health, metadata, and model repository" "FastAPI/Uvicorn, 8080/TCP"
            grpcServer = container "gRPC Server" "Serves V2 gRPC API for inference and model management" "grpcio Async, 8081/TCP"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics for scraping" "FastAPI/Uvicorn, 8082/TCP"
            kafkaServer = container "Kafka Server" "Optional async inference via Kafka topics" "aiokafka, 9092/TCP"
            dataPlane = container "DataPlane" "Core inference logic shared between REST and gRPC" "Python Handler"
            modelRegistry = container "Model Registry" "Multi-model registry managing model lifecycle" "Python Registry"
            inferencePool = container "Inference Pool" "Parallel inference workers for concurrent model serving" "Python Worker Pool"
            sklearnRuntime = container "mlserver-sklearn" "Scikit-learn model inference runtime" "Python Runtime Plugin"
            xgboostRuntime = container "mlserver-xgboost" "XGBoost model inference runtime" "Python Runtime Plugin"
            lightgbmRuntime = container "mlserver-lightgbm" "LightGBM model inference runtime" "Python Runtime Plugin"
            responseCache = container "Response Cache" "Optional caching of inference responses" "Python LocalCache"
        }

        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle and deploys MLServer pods" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Multi-model serving platform that can use MLServer as a backend" "Internal RHOAI"
        rhoaiOperator = softwareSystem "OpenShift AI Operator" "Manages lifecycle of serving runtimes including MLServer" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Receives distributed traces via OTLP" "External"
        kafka = softwareSystem "Kafka" "Message broker for async inference requests/responses" "External"
        s3Storage = softwareSystem "S3 / Object Storage" "Stores ML model artifacts" "External"
        pvcStorage = softwareSystem "PVC / Local Storage" "Mounted volume for model artifacts" "External"

        # User interactions
        dataScientist -> kserve "Creates InferenceService" "kubectl / Dashboard"
        dataScientist -> mlserver "Sends inference requests" "REST/gRPC via KServe Gateway, HTTPS/443"
        sre -> prometheus "Monitors metrics" "PromQL"

        # Internal container relationships
        restServer -> dataPlane "Routes inference requests"
        grpcServer -> dataPlane "Routes inference requests"
        kafkaServer -> dataPlane "Routes async requests"
        dataPlane -> modelRegistry "Looks up models"
        dataPlane -> responseCache "Checks/stores cached responses"
        modelRegistry -> inferencePool "Dispatches to workers"
        inferencePool -> sklearnRuntime "Loads and runs sklearn models"
        inferencePool -> xgboostRuntime "Loads and runs xgboost models"
        inferencePool -> lightgbmRuntime "Loads and runs lightgbm models"

        # External system relationships
        kserve -> mlserver "Deploys as InferenceService runtime container"
        modelMesh -> mlserver "Uses as serving backend" "HTTP/8080, gRPC/8081"
        rhoaiOperator -> kserve "Manages serving runtime lifecycle"
        prometheus -> mlserver "Scrapes metrics" "HTTP/8082"
        mlserver -> otelCollector "Exports traces" "gRPC OTLP"
        mlserver -> kafka "Consumes/produces async inference messages" "Kafka/9092"
        mlserver -> s3Storage "Downloads model artifacts" "HTTPS/443"
        mlserver -> pvcStorage "Reads model artifacts" "Filesystem"
    }

    views {
        systemContext mlserver "SystemContext" {
            include *
            autoLayout
        }

        container mlserver "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
