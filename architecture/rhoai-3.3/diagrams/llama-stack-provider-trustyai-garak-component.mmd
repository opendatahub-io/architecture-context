%% Component Structure Diagram: TrustyAI Garak LLM Red Teaming Provider for Llama Stack
%% Generated by: Claude Opus 4.6

graph TB
    subgraph LlamaStackServer["Llama Stack Server (port 8321)"]
        subgraph Provider["TrustyAI Garak Provider"]
            GarakEvalBase["GarakEvalBase<br/>(Shared Logic)"]
            GarakRemote["GarakRemoteEvalAdapter<br/>(remote::trustyai_garak)"]
            GarakInline["GarakInlineEvalAdapter<br/>(inline::trustyai_garak)"]
            ShieldOrch["SimpleShieldOrchestrator"]
            AvidReport["AVID Report Converter"]
            ResultUtils["Result Utils"]
            Compat["Compatibility Layer"]

            GarakRemote -->|extends| GarakEvalBase
            GarakInline -->|extends| GarakEvalBase
            GarakEvalBase -->|uses| ResultUtils
            GarakEvalBase -->|uses| AvidReport
            GarakEvalBase -->|uses| Compat
            GarakEvalBase -->|uses| ShieldOrch
        end

        FilesAPI["Llama Stack Files API"]
        SafetyAPI["Llama Stack Safety API"]
        InferenceAPI["Llama Stack Inference API"]
        BenchmarksAPI["Llama Stack Benchmarks API"]
    end

    subgraph KFPPipeline["KFP Pipeline (Remote Mode)"]
        ValidateInputs["validate_inputs<br/>(KFP Component)"]
        GarakScan["garak_scan<br/>(KFP Component)"]
        ParseResults["parse_results<br/>(KFP Component)"]

        ValidateInputs --> GarakScan
        GarakScan --> ParseResults
    end

    Client["Client / User"] -->|"POST /v1/eval/run"| LlamaStackServer
    GarakRemote -->|submits pipeline| KFPAPI["Kubeflow Pipelines API"]
    KFPAPI -->|creates| KFPPipeline
    GarakInline -->|subprocess| Garak["NVIDIA Garak CLI"]

    GarakScan -->|probes| vLLM["vLLM Inference Server"]
    GarakScan -->|uploads results| FilesAPI
    ParseResults -->|uploads reports| FilesAPI
    ShieldOrch -->|evaluates shields| SafetyAPI

    GarakRemote -->|reads ConfigMap| K8sAPI["Kubernetes API<br/>(443/TCP)"]
    GarakRemote -->|resolves base image| TrustyAIOp["TrustyAI Service Operator<br/>(ConfigMap)"]

