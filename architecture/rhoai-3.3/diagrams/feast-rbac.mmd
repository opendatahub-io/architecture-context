graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller[controller-manager<br/>feast-operator-system]
        SA_Online["{name}-online<br/>user-namespace"]
        SA_Offline["{name}-offline<br/>user-namespace"]
        SA_Registry["{name}-registry<br/>user-namespace"]
        SA_UI["{name}-ui<br/>user-namespace"]
        SA_Materialize["{name}-materialize<br/>user-namespace"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager[manager-role]
        CR_Editor[featurestore-editor-role]
        CR_Viewer[featurestore-viewer-role]
        CR_Leader[leader-election-role]
        CR_Metrics[metrics-auth-role]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager[manager-role-binding]
        CRB_Leader[leader-election-role-binding]
        CRB_Metrics[metrics-auth-role-binding]
    end

    subgraph APIResources["API Resources & Permissions"]
        subgraph FeastAPI["feast.dev"]
            FS_Resource["FeatureStore<br/>get, list, watch,<br/>create, update, patch, delete"]
            FS_Status["FeatureStore/status<br/>get, update, patch"]
            FS_Finalizers["FeatureStore/finalizers<br/>update"]
        end

        subgraph CoreAPI["core (v1)"]
            Core_Services["Services<br/>get, list, watch,<br/>create, update, delete"]
            Core_ConfigMaps["ConfigMaps<br/>get, list, watch,<br/>create, update, patch, delete"]
            Core_Secrets["Secrets<br/>get, list, watch"]
            Core_SA["ServiceAccounts<br/>get, list, watch,<br/>create, update, delete"]
            Core_PVC["PersistentVolumeClaims<br/>get, list, watch,<br/>create, update, delete"]
            Core_Pods["Pods<br/>get, list, watch"]
            Core_PodExec["Pods/exec<br/>create"]
        end

        subgraph AppsAPI["apps"]
            Apps_Deployments["Deployments<br/>get, list, watch,<br/>create, update, delete"]
        end

        subgraph BatchAPI["batch"]
            Batch_CronJobs["CronJobs<br/>get, list, watch,<br/>create, update, patch, delete"]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            RBAC_Roles["Roles, RoleBindings<br/>ClusterRoles, ClusterRoleBindings<br/>get, list, watch,<br/>create, update, delete"]
            RBAC_SAR["SubjectAccessReviews<br/>create"]
        end

        subgraph AuthAPI["authentication.k8s.io"]
            Auth_TokenReview["TokenReviews<br/>create"]
        end

        subgraph AuthzAPI["authorization.k8s.io"]
            Authz_SAR["SubjectAccessReviews<br/>create"]
        end

        subgraph RouteAPI["route.openshift.io"]
            Route_Routes["Routes<br/>get, list, watch,<br/>create, update, delete"]
        end

        subgraph KubeflowAPI["kubeflow.org"]
            KF_Notebooks["Notebooks<br/>get, list, watch"]
        end

        subgraph CRDAPI["apiextensions.k8s.io"]
            CRD_CRDs["CustomResourceDefinitions<br/>get, list"]
        end

        subgraph CoordinationAPI["coordination.k8s.io"]
            Coord_Leases["Leases<br/>get, list, watch,<br/>create, update, patch, delete"]
        end
    end

    %% Service Account to ClusterRoleBinding
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Leader
    SA_Controller -->|bound via| CRB_Metrics

    %% ClusterRoleBinding to ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Metrics -->|grants| CR_Metrics

    %% ClusterRole to Resources - manager-role
    CR_Manager -->|all verbs| FS_Resource
    CR_Manager -->|get, update, patch| FS_Status
    CR_Manager -->|update| FS_Finalizers
    CR_Manager -->|all verbs| Core_Services
    CR_Manager -->|all verbs| Core_ConfigMaps
    CR_Manager -->|all verbs| Core_SA
    CR_Manager -->|all verbs| Core_PVC
    CR_Manager -->|read-only| Core_Secrets
    CR_Manager -->|read-only| Core_Pods
    CR_Manager -->|create| Core_PodExec
    CR_Manager -->|all verbs| Apps_Deployments
    CR_Manager -->|all verbs| Batch_CronJobs
    CR_Manager -->|all verbs| RBAC_Roles
    CR_Manager -->|create| RBAC_SAR
    CR_Manager -->|create| Auth_TokenReview
    CR_Manager -->|all verbs| Route_Routes
    CR_Manager -->|read-only| KF_Notebooks
    CR_Manager -->|read-only| CRD_CRDs

    %% ClusterRole to Resources - editor-role
    CR_Editor -->|all verbs| FS_Resource

    %% ClusterRole to Resources - viewer-role
    CR_Viewer -->|read-only| FS_Resource

    %% ClusterRole to Resources - leader-election-role
    CR_Leader -->|all verbs| Core_ConfigMaps
    CR_Leader -->|all verbs| Coord_Leases

    %% ClusterRole to Resources - metrics-auth-role
    CR_Metrics -->|create| Auth_TokenReview
    CR_Metrics -->|create| Authz_SAR

    %% Feature Server Service Accounts (Runtime Permissions)
    SA_Online -.->|SubjectAccessReview<br/>for FeatureStore| RBAC_SAR
    SA_Offline -.->|SubjectAccessReview<br/>for FeatureStore| RBAC_SAR
    SA_Registry -.->|SubjectAccessReview<br/>for FeatureStore| RBAC_SAR

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef clusterrole fill:#f5a623,stroke:#333,stroke-width:2px
    classDef binding fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef feastapi fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class SA_Controller,SA_Online,SA_Offline,SA_Registry,SA_UI,SA_Materialize sa
    class CR_Manager,CR_Editor,CR_Viewer,CR_Leader,CR_Metrics clusterrole
    class CRB_Manager,CRB_Leader,CRB_Metrics binding
    class FS_Resource,FS_Status,FS_Finalizers feastapi
    class Core_Services,Core_ConfigMaps,Core_Secrets,Core_SA,Core_PVC,Core_Pods,Core_PodExec,Apps_Deployments,Batch_CronJobs,RBAC_Roles,RBAC_SAR,Auth_TokenReview,Authz_SAR,Route_Routes,KF_Notebooks,CRD_CRDs,Coord_Leases resource
