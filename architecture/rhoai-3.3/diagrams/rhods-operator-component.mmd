graph TB
    subgraph "RHODS Operator (3 replicas, leader election)"
        Manager[Operator Manager<br/>Deployment]
        DSCIController[DSCInitialization Controller<br/>Platform Init]
        DSCController[DataScienceCluster Controller<br/>Component Lifecycle]
        ComponentControllers[Component Controllers<br/>15+ Controllers]
        Webhook[Webhook Server<br/>9443/TCP HTTPS]
        Metrics[Metrics Service<br/>8443/TCP HTTP]
        Health[Health Probes<br/>8081/TCP HTTP]

        Manager --> DSCIController
        Manager --> DSCController
        Manager --> ComponentControllers
        Manager --> Webhook
        Manager --> Metrics
        Manager --> Health
    end

    subgraph "CRDs - Platform"
        DSC[DataScienceCluster<br/>datasciencecluster.opendatahub.io/v1,v2]
        DSCI[DSCInitialization<br/>dscinitialization.opendatahub.io/v1,v2]
    end

    subgraph "CRDs - Components"
        Dashboard[Dashboard<br/>components.platform.opendatahub.io]
        Workbenches[Workbenches]
        KServe[KServe]
        Pipelines[DataSciencePipelines]
        ModelReg[ModelRegistry]
        Ray[Ray]
        Training[TrainingOperator]
        Others[Kueue, TrustyAI, Feast, etc.]
    end

    subgraph "CRDs - Services"
        Monitoring[Monitoring<br/>services.platform.opendatahub.io]
        Auth[Auth]
        Gateway[GatewayConfig]
    end

    subgraph "External Dependencies"
        K8s[Kubernetes API<br/>6443/TCP HTTPS]
        OpenShift[OpenShift OAuth<br/>6443/TCP HTTPS]
        CertMgr[Cert Manager /<br/>Service CA]
        Prometheus[Prometheus Operator]
        Istio[Istio / Service Mesh<br/>2.4+]
        Serverless[OpenShift Serverless<br/>Knative 1.30+]
    end

    subgraph "Managed Namespaces"
        NSOperator[redhat-ods-operator]
        NSApps[redhat-ods-applications]
        NSMon[redhat-ods-monitoring]
        NSIstio[istio-system]
        NSKnative[knative-serving]
    end

    User[Platform Admin] -->|creates| DSC
    User -->|creates| DSCI
    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController

    K8s -->|validates/mutates via| Webhook

    DSCController -->|creates/updates| Dashboard
    DSCController -->|creates/updates| Workbenches
    DSCController -->|creates/updates| KServe
    DSCController -->|creates/updates| Pipelines
    DSCController -->|creates/updates| ModelReg
    DSCController -->|creates/updates| Ray
    DSCController -->|creates/updates| Training
    DSCController -->|creates/updates| Others

    DSCIController -->|creates/updates| Monitoring
    DSCIController -->|creates/updates| Auth
    DSCIController -->|creates/updates| Gateway

    Manager -->|API calls| K8s
    Manager -->|authenticates users| OpenShift
    Webhook -->|TLS certs from| CertMgr
    ComponentControllers -->|deploys operators to| NSApps
    ComponentControllers -->|configures monitoring in| NSMon
    ComponentControllers -->|integrates with| Istio
    ComponentControllers -->|integrates with| Serverless

    Prometheus -->|scrapes| Metrics

