    style DSCI fill:#f5a623,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333
    style Workbenches fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style K8s fill:#999,stroke:#333
