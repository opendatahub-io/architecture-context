/*
 * C4 Context Diagram: Guardrails Detectors
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-19
 * Source: architecture/rhoai-3.3/guardrails-detectors.md
 */

workspace {
    model {
        orchestratorUser = person "FMS Guardrails Orchestrator" "Invokes detectors for text content analysis on AI inputs/outputs"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Collection of detector algorithm microservices for AI safety guardrailing" {
            builtInDetector = container "Built-in Detector" "Lightweight heuristic/algorithmic detection (regex PII, file-type validation, custom Python)" "Python FastAPI, port 8080" "Microservice"
            huggingfaceDetector = container "HuggingFace Detector" "ML model-based content classification using AutoModelForSequenceClassification and GraniteForCausalLM" "Python FastAPI, port 8000" "Microservice"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-judge evaluation using vllm_judge library for content safety, toxicity, accuracy" "Python FastAPI, port 8000" "Microservice"
            commonFramework = container "Common Framework" "Shared DetectorBaseAPI, InstrumentedDetector, and BaseDetectorRegistry" "Python" "Library"
        }

        kserve = softwareSystem "KServe" "Manages model serving lifecycle via ServingRuntime/InferenceService CRDs" "External"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS encryption and traffic management via sidecar proxies" "External"
        vllmServer = softwareSystem "External vLLM Server" "OpenAI-compatible LLM inference server for judge evaluations" "External"
        s3Storage = softwareSystem "S3/MinIO Object Storage" "Model weights storage for HuggingFace detector" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model repository for downloading pre-trained models (optional)" "External"

        # Relationships
        orchestratorUser -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080, plaintext"
        orchestratorUser -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000, mTLS (Istio)"
        orchestratorUser -> llmJudgeDetector "POST /api/v1/text/contents, /generation" "HTTP/8000, mTLS (Istio)"

        builtInDetector -> commonFramework "Uses" "Python import"
        huggingfaceDetector -> commonFramework "Uses" "Python import"
        llmJudgeDetector -> commonFramework "Uses" "Python import"

        llmJudgeDetector -> vllmServer "Sends evaluation prompts" "HTTP/8080, OpenAI-compatible API"
        huggingfaceDetector -> s3Storage "Downloads model weights" "S3 API/9000, AWS credentials"
        huggingfaceDetector -> huggingfaceHub "Downloads models (dev)" "HTTPS/443, TLS 1.2+"

        kserve -> huggingfaceDetector "Manages deployment" "ServingRuntime/InferenceService CRDs"
        kserve -> llmJudgeDetector "Manages deployment" "ServingRuntime/InferenceService CRDs"
        istio -> huggingfaceDetector "Provides mTLS sidecar" "ISTIO_MUTUAL"
        istio -> llmJudgeDetector "Provides mTLS sidecar" "ISTIO_MUTUAL"

        prometheus -> builtInDetector "Scrapes metrics" "HTTP/8080 /metrics"
        prometheus -> huggingfaceDetector "Scrapes metrics" "HTTP/8000 /metrics"
        prometheus -> llmJudgeDetector "Scrapes metrics" "HTTP/8000 /metrics"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Microservice" {
                background #4a90e2
                color #ffffff
            }
            element "Library" {
                background #6c5ce7
                color #ffffff
            }
        }
    }
}
