graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[cluster-monitoring-view<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]
        CR_AuthDelegator[system:auth-delegator<br/>ClusterRole]
        CR_Monitoring[cluster-monitoring-view<br/>ClusterRole]
    end

    subgraph "Namespace Role Bindings"
        RB[odh-dashboard<br/>RoleBinding<br/>Namespace-scoped]
    end

    subgraph "Namespace Role"
        R[odh-dashboard<br/>Role<br/>Namespace-scoped]
    end

    subgraph "Core API Resources"
        CoreResources["configmaps, secrets, PVCs<br/>pods, services, serviceaccounts<br/>namespaces, endpoints, nodes"]
    end

    subgraph "ODH CRDs"
        OdhCRDs["OdhApplication<br/>OdhDashboardConfig<br/>OdhDocument<br/>OdhQuickStart<br/>AcceleratorProfile"]
    end

    subgraph "Component CRDs"
        ComponentCRDs["Notebook (kubeflow.org)<br/>InferenceService (kserve)<br/>ServingRuntime (kserve)<br/>ModelRegistry<br/>FeatureStore (feast)<br/>Account (NIM)"]
    end

    subgraph "Operator CRDs"
        OperatorCRDs["DataScienceCluster<br/>DSCInitialization"]
    end

    subgraph "OpenShift Resources"
        OpenshiftResources["Routes, ConsoleLinks<br/>ClusterVersions, Ingresses<br/>Users, Groups<br/>ImageStreams, Builds<br/>Templates, DeploymentConfigs"]
    end

    subgraph "RBAC Resources"
        RBACResources["RoleBindings<br/>ClusterRoleBindings<br/>Roles"]
    end

    subgraph "Auth Resources"
        AuthResources["TokenReviews<br/>SubjectAccessReviews"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB

    %% Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| CR_AuthDelegator
    CRB3 -->|grants| CR_Monitoring
    RB -->|grants| R

    %% ClusterRole to Resources
    CR -->|get, list, watch<br/>create, update, patch, delete| CoreResources
    CR -->|get, list, watch| OperatorCRDs
    CR -->|get, list, watch| OpenshiftResources
    CR -->|get, list, watch<br/>create, update, patch, delete| ComponentCRDs
    CR -->|list, get, create, patch, delete| RBACResources
    CR -->|create| AuthResources

    %% Auth Delegator
    CR_AuthDelegator -->|delegate authentication| AuthResources

    %% Monitoring
    CR_Monitoring -->|query metrics| Prometheus[Prometheus<br/>openshift-monitoring]

    %% Namespace Role to Resources
    R -->|get, list, watch<br/>create, update, patch, delete| OdhCRDs
    R -->|all verbs| Templates[Templates<br/>ServingRuntimes]
    R -->|manage| Deployments[Deployments<br/>DeploymentConfigs<br/>BuildConfigs]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style R fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_AuthDelegator fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_Monitoring fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CoreResources fill:#7ed321,stroke:#333,color:#000
    style OdhCRDs fill:#7ed321,stroke:#333,color:#000
    style ComponentCRDs fill:#7ed321,stroke:#333,color:#000
    style OperatorCRDs fill:#7ed321,stroke:#333,color:#000
    style OpenshiftResources fill:#7ed321,stroke:#333,color:#000
    style RBACResources fill:#7ed321,stroke:#333,color:#000
    style AuthResources fill:#7ed321,stroke:#333,color:#000
    style Templates fill:#7ed321,stroke:#333,color:#000
    style Deployments fill:#7ed321,stroke:#333,color:#000
    style Prometheus fill:#7ed321,stroke:#333,color:#000

    style CRB1 fill:#ddd,stroke:#333
    style CRB2 fill:#ddd,stroke:#333
    style CRB3 fill:#ddd,stroke:#333
    style RB fill:#ddd,stroke:#333
