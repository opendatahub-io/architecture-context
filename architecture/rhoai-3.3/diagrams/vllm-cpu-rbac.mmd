    end

    subgraph "Secrets"
        ModelSecret["model-serving-secret<br/>Type: Opaque<br/>HF Token / S3 Credentials<br/>Provisioned: User/Admin<br/>Auto-Rotate: No"]
        SSLSecret["ssl-certs<br/>Type: kubernetes.io/tls<br/>TLS certificates<br/>Provisioned: cert-manager/manual"]
        APIKeySecret["api-key<br/>Type: Opaque<br/>Bearer token(s) for --api-key<br/>Provisioned: User/Admin<br/>Auto-Rotate: No"]
