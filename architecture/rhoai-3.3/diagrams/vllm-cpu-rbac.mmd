    %% Flows
    RBACProxy -->|"authorized requests"| AuthMW
    AuthMW -->|"no --api-key"| Public
    AuthMW -->|"valid token"| Protected
    BearerCheck -->|"reads"| APIKeySecret
    Container -->|"mounts"| ModelSecret
    Container -->|"mounts"| SSLSecret
    KServeOp -->|"creates SA & roles"| Container
    RHOAIOp -->|"configures"| RBACProxy

