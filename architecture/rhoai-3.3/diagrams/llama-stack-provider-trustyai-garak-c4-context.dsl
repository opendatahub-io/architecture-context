/*
 * C4 Context Diagram: TrustyAI Garak LLM Red Teaming Provider for Llama Stack
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / Security Engineer" "Submits LLM vulnerability scans and reviews results"

        trustyaiGarak = softwareSystem "TrustyAI Garak Provider" "Llama Stack Eval provider for automated LLM red teaming using NVIDIA Garak" {
            remoteAdapter = container "GarakRemoteEvalAdapter" "Submits Garak scans as Kubeflow Pipeline runs for production workloads" "Python Provider Plugin"
            inlineAdapter = container "GarakInlineEvalAdapter" "Runs Garak scans as local subprocesses for development/testing" "Python Provider Plugin"
            evalBase = container "GarakEvalBase" "Shared eval logic: benchmark registration, command building, result parsing" "Python Base Class"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Orchestrates shield-augmented LLM scanning: input shields -> LLM -> output shields" "Python Class"
            avidConverter = container "AVID Report Converter" "Converts Garak report.jsonl to AVID taxonomy format" "Python Module"
            resultUtils = container "Result Utils" "Shared utilities for parsing generations, scores, and aggregated results" "Python Module"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Core framework hosting providers, exposing Eval/Files/Benchmarks/Inference APIs" "Internal RHOAI"
        kfp = softwareSystem "Data Science Pipelines (Kubeflow)" "Pipeline orchestration for remote scan execution" "Internal RHOAI"
        vllm = softwareSystem "vLLM Inference Server" "Target LLM model being scanned for vulnerabilities" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides ConfigMap for base image resolution" "Internal RHOAI"
        promptGuard = softwareSystem "Prompt Guard Shield" "Input/output shield for guardrail effectiveness testing" "Internal RHOAI"

        garak = softwareSystem "NVIDIA Garak" "LLM vulnerability scanning and red-teaming framework" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API for ConfigMap access and service discovery" "External"

        // User interactions
        user -> trustyaiGarak "Submits vulnerability scans via Llama Stack Eval API"
        user -> llamaStackServer "POST /v1/eval/run, GET /v1/eval/jobs/status" "HTTP/8321"

        // Provider to infrastructure
        trustyaiGarak -> llamaStackServer "Hosted as provider plugin; uses Files, Safety, Inference APIs" "HTTP/8321"
        trustyaiGarak -> kfp "Submits and monitors pipeline runs (remote mode)" "HTTPS, Bearer Token"
        trustyaiGarak -> vllm "Sends adversarial probes to target LLM" "HTTP/HTTPS, API Key"
        trustyaiGarak -> garak "Executes vulnerability scans via CLI subprocess" "Local subprocess"
        trustyaiGarak -> k8sAPI "Reads ConfigMaps for base image resolution" "HTTPS/443, SA Token"
        trustyaiGarak -> trustyaiOperator "Reads trustyai-service-operator-config ConfigMap" "Kubernetes API"
        trustyaiGarak -> promptGuard "Evaluates input/output shields" "HTTP/8321, Safety API"

        // Container relationships
        remoteAdapter -> evalBase "extends"
        inlineAdapter -> evalBase "extends"
        evalBase -> resultUtils "uses"
        evalBase -> avidConverter "uses"
        evalBase -> shieldOrchestrator "uses"
    }

    views {
        systemContext trustyaiGarak "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiGarak "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
