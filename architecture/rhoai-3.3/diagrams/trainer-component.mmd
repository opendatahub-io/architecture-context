    %% CRDs
    User["User / Dashboard"] -->|creates| TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    User -->|creates| TrainingRuntimeCR["TrainingRuntime CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    Admin["Admin"] -->|creates| ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/>(trainer.kubeflow.org/v1alpha1)"]

    TrainJobCR -->|watched by| TrainJobCtrl
    TrainingRuntimeCR -->|watched by| RuntimeCtrl
    ClusterTrainingRuntimeCR -->|watched by| ClusterRuntimeCtrl

    TrainJobCR -->|references| TrainingRuntimeCR
    TrainJobCR -->|references| ClusterTrainingRuntimeCR

    %% Created Resources
    TrainJobCtrl -->|creates| JobSetCR["JobSet CR<br/>(jobset.x-k8s.io)"]
    TrainJobCtrl -->|creates| NetworkPolicyCR["NetworkPolicy<br/>(per-TrainJob)"]

    JobSetCR -->|reconciled by| JobSetCtrl["JobSet Controller"]
    JobSetCtrl -->|creates| TrainingPods["Training Pods<br/>(PyTorch/DeepSpeed/MPI)"]

    %% Progression Tracking
    ProgressionTracker -->|polls metrics<br/>28080/TCP HTTP| TrainingPods

    %% Training Pod Communication
    TrainingPods -->|NCCL/MPI/gRPC<br/>29500/TCP + all ports| TrainingPods

    %% External Dependencies
    ControllerManager -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    ControllerManager -.->|optional| Volcano["Volcano Scheduler"]
    ControllerManager -.->|optional| Kueue["Kueue/Scheduler-Plugins"]
    Prometheus["Prometheus"] -->|scrapes<br/>8443/TCP HTTPS| ControllerManager

    %% Pre-configured Runtimes
    subgraph PreConfigured["Pre-configured ClusterTrainingRuntimes (RHOAI)"]
        TorchCUDA["torch-distributed<br/>(CUDA 12.8)"]
        TorchROCm["torch-distributed-rocm<br/>(ROCm 6.4)"]
        TrainingHub["training-hub<br/>(CUDA 12.8)"]
    end

    ClusterRuntimeCtrl -->|manages| PreConfigured

