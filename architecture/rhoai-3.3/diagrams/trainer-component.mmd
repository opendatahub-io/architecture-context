graph TB
    subgraph "Kubeflow Trainer Operator"
        Controller[trainer-controller-manager<br/>Go Controller/Operator]
        Webhook[Validating Webhooks<br/>9443/TCP HTTPS]
        TrainJobCtrl[TrainJob Controller]
        TrainingRuntimeCtrl[TrainingRuntime Controller]
        ClusterTrainingRuntimeCtrl[ClusterTrainingRuntime Controller]
        ProgressTracker[Progression Tracker<br/>RHOAI Extension]
        NetPolMgr[Network Policy Manager<br/>RHOAI Extension]

        Controller -->|validates| Webhook
        Controller -->|reconciles| TrainJobCtrl
        Controller -->|reconciles| TrainingRuntimeCtrl
        Controller -->|reconciles| ClusterTrainingRuntimeCtrl
        Controller -->|tracks| ProgressTracker
        Controller -->|manages| NetPolMgr
    end

    subgraph "Custom Resources"
        TrainJobCR[TrainJob CR<br/>trainer.kubeflow.org/v1alpha1]
        TrainingRuntimeCR[TrainingRuntime CR<br/>Namespaced]
        ClusterTrainingRuntimeCR[ClusterTrainingRuntime CR<br/>Cluster-scoped]
    end

    subgraph "Created Resources"
        JobSet[JobSet<br/>Multi-node training]
        PodGroup[PodGroup<br/>Gang scheduling]
        NetworkPolicy[NetworkPolicy<br/>Pod isolation]
        TrainingPods[Training Pods<br/>Launcher + Workers]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        JobSetCtrl[JobSet Controller]
        Volcano[Volcano Scheduler<br/>Optional]
        Prometheus[Prometheus<br/>RHOAI Monitoring]
        Kueue[Kueue<br/>Optional]
    end

    User[Data Scientist] -->|creates| TrainJobCR
    TrainJobCR -->|watched by| TrainJobCtrl
    TrainingRuntimeCR -->|watched by| TrainingRuntimeCtrl
    ClusterTrainingRuntimeCR -->|watched by| ClusterTrainingRuntimeCtrl

    TrainJobCtrl -->|creates| JobSet
    TrainJobCtrl -->|creates| PodGroup
    NetPolMgr -->|creates| NetworkPolicy

    JobSetCtrl -->|creates| TrainingPods
    Volcano -->|schedules| PodGroup

    ProgressTracker -->|polls metrics| TrainingPods
    Prometheus -->|scrapes| Controller

    Controller -->|integrates| K8sAPI
    TrainJobCtrl -->|integrates| JobSetCtrl
    TrainJobCtrl -.->|optional| Kueue

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333
    style ProgressTracker fill:#7ed321,stroke:#333
    style NetPolMgr fill:#7ed321,stroke:#333
    style TrainJobCR fill:#f5a623,stroke:#333
    style TrainingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333
    style JobSet fill:#d0d0d0,stroke:#333
    style TrainingPods fill:#d0d0d0,stroke:#333
    style Volcano fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
