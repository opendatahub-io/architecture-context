graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist<br/>kubectl/SDK]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        API[Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>User Auth + SA Tokens]
    end

    subgraph OpendatahubNS["OPENDATAHUB NAMESPACE (Controller)"]
        direction TB

        Controller[trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/trainer:v2.1.0]

        subgraph ControllerComponents["Controller Components"]
            Webhook[Validating Webhook<br/>9443/TCP HTTPS TLS<br/>mTLS Auth]
            Health[Health Probes<br/>8081/TCP HTTP<br/>No Auth]
            Metrics[Metrics Server<br/>8080/TCP HTTPS TLS<br/>PodMonitor]
            ProgressTracker[Progression Tracker<br/>RHOAI Extension]
        end

        Controller --- ControllerComponents
    end

    subgraph UserNS["USER NAMESPACE (Training Workloads)"]
        direction TB

        subgraph JobSet["JobSet: trainjob-name"]
            Launcher[Launcher Pod<br/>node-0<br/>GPU Runtime]
            Worker1[Worker Pod<br/>node-1<br/>GPU Runtime]
            Worker2[Worker Pod<br/>node-2<br/>GPU Runtime]
        end

        subgraph MetricsEndpoint["Metrics Endpoint"]
            PodMetrics["/metrics<br/>28080/TCP HTTP<br/>NetworkPolicy Restricted"]
        end

        NetPol[NetworkPolicy: trainjob-name<br/>Ingress:<br/>1. Same JobSet all ports<br/>2. Controller 28080/TCP]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3[S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM Auth]
        HF[HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS1.2+<br/>HF_TOKEN]
    end

    subgraph Scheduler["GANG SCHEDULING"]
        Volcano[Volcano Scheduler<br/>PodGroup<br/>All-or-nothing]
    end

    %% User to API
    User -->|HTTPS/6443<br/>TLS 1.3<br/>User Auth| API

    %% API to Webhook
    API -->|HTTPS/9443<br/>mTLS<br/>Validate TrainJob| Webhook

    %% API to Controller (watch)
    API -.->|Watch Stream<br/>TLS 1.3<br/>SA Token| Controller

    %% Controller to API (create resources)
    Controller -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token<br/>Create: JobSet, PodGroup, NetworkPolicy| API

    %% Gang Scheduling
    Volcano -->|Schedule<br/>All Pods| JobSet

    %% Progression Tracking
    ProgressTracker -->|HTTP/28080<br/>GET /metrics<br/>NetworkPolicy Allowed| PodMetrics
    ProgressTracker -->|HTTPS/6443<br/>Update Annotation| API

    %% Inter-pod Communication
    Launcher <-->|TCP Dynamic<br/>NCCL/MPI/gRPC<br/>NetworkPolicy Allowed| Worker1
    Launcher <-->|TCP Dynamic<br/>NCCL/MPI/gRPC<br/>NetworkPolicy Allowed| Worker2
    Worker1 <-->|TCP Dynamic<br/>NCCL/MPI/gRPC<br/>NetworkPolicy Allowed| Worker2

    %% External Storage
    Launcher -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/HF Token| S3
    Launcher -->|HTTPS/443<br/>TLS 1.2+<br/>HF Token| HF
    Worker1 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/HF Token| S3
    Worker2 -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/HF Token| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef training fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef scheduler fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class API controlplane
    class Controller,Webhook,Health,Metrics,ProgressTracker controller
    class Launcher,Worker1,Worker2,PodMetrics,NetPol training
    class S3,HF externalservice
    class Volcano scheduler
