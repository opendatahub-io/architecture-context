graph LR
    GD["Guardrails<br/>Detectors"]

    %% External Dependencies (Python libraries)
    GD -->|"web framework"| FastAPI["FastAPI 0.121.2"]
    GD -->|"ASGI server"| Uvicorn["uvicorn 0.30.5"]
    GD -->|"metrics"| PromClient["prometheus_client"]
    GD -->|"auto-instrumentation"| PromFastAPI["prometheus-fastapi-<br/>instrumentator"]

    %% HuggingFace-specific
    GD -->|"model loading (HF)"| Transformers["transformers 4.57.1"]
    GD -->|"ML inference (HF)"| PyTorch["torch 2.6.0"]
    GD -->|"tokenizer (HF)"| SentencePiece["sentencepiece 0.2.1"]
    GD -->|"tokenizer (HF)"| Tiktoken["tiktoken 0.12.0"]

    %% Judge-specific
    GD -->|"LLM evaluation (Judge)"| VLLMJudge["vllm-judge 0.1.8"]

    %% Built-in-specific
    GD -->|"JSON validation"| JsonSchema["jsonschema 4.24.0"]
    GD -->|"XML validation"| XmlSchema["xmlschema 4.1.0"]

    %% Internal ODH Dependencies
    GD -->|"invokes detectors<br/>HTTP 8080/8000"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployment mgmt<br/>ServingRuntime/InferenceService"| KServe["KServe"]
    GD -->|"mTLS sidecar<br/>ISTIO_MUTUAL"| Istio["Istio Service Mesh"]

    %% External Services
    GD -->|"LLM inference<br/>OpenAI API"| vLLM["External vLLM Server"]
    GD -->|"model storage<br/>S3 API/9000"| S3["S3/MinIO Storage"]
    GD -.->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>(optional)"]

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP"| GD

