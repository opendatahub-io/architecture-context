%% RBAC Visualization for vllm-gaudi
%% Generated by: Claude Opus 4.6
%% Note: vllm-gaudi does not define its own RBAC roles.
%% RBAC is delegated to KServe and the RHOAI operator.

graph TD
    subgraph "Container Identity"
        Container["vllm-gaudi Container<br/>UID: 2000 (vllm)<br/>GID: 0 (root group)<br/>Image: quay.io/rhoai/odh-vllm-gaudi-rhel9"]
    end

    subgraph "Platform RBAC (KServe-managed)"
        SA["ServiceAccount<br/>(KServe-assigned per InferenceService)"]
        KServeCRB["KServe ClusterRoleBinding"]
        KServeCR["KServe ClusterRole<br/>(manages ServingRuntime lifecycle)"]
    end

    subgraph "Authentication & Authorization"
        direction TB
        AuthAPI["API Endpoints /v1/*<br/>Auth: Bearer Token / mTLS<br/>Enforcement: KServe + Gateway API / Istio<br/>Policy: Platform-managed"]
        AuthHealth["/health Endpoint<br/>Auth: None<br/>Policy: Open (health probes)"]
    end

    subgraph "Secrets Access"
        HFSecret["(model-specific) Secret<br/>Type: Opaque<br/>Purpose: HuggingFace token<br/>Provisioned by: User<br/>Auto-Rotate: No"]
        S3Secret["(S3 credentials) Secret<br/>Type: Opaque<br/>Purpose: Object storage access<br/>Provisioned by: User/Platform<br/>Auto-Rotate: No"]
    end

    subgraph "Container Security"
        NonRoot["Non-root Execution<br/>UID 2000 / GID 0"]
        FIPS["FIPS Provider: REMOVED<br/>openssl-fips-provider-so"]
        BaseImage["Base: UBI 9.6<br/>registry.access.redhat.com/ubi9/ubi:9.6"]
    end

    Container -->|"runs as"| SA
    SA -->|"bound via"| KServeCRB
    KServeCRB -->|"grants"| KServeCR

    Container -->|"serves"| AuthAPI
    Container -->|"serves"| AuthHealth

    SA -->|"mounts"| HFSecret
    SA -->|"mounts"| S3Secret

    Container -->|"enforces"| NonRoot
    Container -->|"security"| FIPS
    Container -->|"built from"| BaseImage

    style Container fill:#4a90e2,color:#fff
    style SA fill:#5b9bd5,color:#fff
    style KServeCR fill:#f5a623,color:#fff
    style KServeCRB fill:#f5a623,color:#fff
    style AuthAPI fill:#7ed321,color:#fff
    style AuthHealth fill:#d5e8d4,stroke:#82b366
    style HFSecret fill:#e74c3c,color:#fff
    style S3Secret fill:#e74c3c,color:#fff
    style NonRoot fill:#27ae60,color:#fff
    style FIPS fill:#e67e22,color:#fff
    style BaseImage fill:#95a5a6,color:#fff
