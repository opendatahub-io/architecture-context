graph TB
    subgraph External["EXTERNAL - Untrusted"]
        Client[User Browser or<br/>MLflow Client]
    end

    subgraph Ingress["INGRESS - Gateway"]
        Gateway["data-science-gateway<br/>443/TCP to 8443/TCP<br/>TLS 1.3<br/>HTTPRoute /mlflow prefix"]
    end

    subgraph AppNamespace["APPLICATION NAMESPACE<br/>opendatahub or redhat-ods-applications"]
        direction TB

        MLflowSvc["MLflow Service<br/>ClusterIP<br/>8443/TCP HTTPS TLS1.3"]

        subgraph MLflowPod["MLflow Server Pod"]
            MLflowContainer["MLflow Container<br/>Port: 8443/HTTPS<br/>Auth: kubernetes-auth<br/>SA: mlflow-sa<br/>UID: 1001 (non-root)<br/>Seccomp: RuntimeDefault"]
        end

        NetworkPolicy["NetworkPolicy: mlflow<br/>Ingress: Allow TCP/8443<br/>Egress: Allow all"]
        TLSSecret["Secret: mlflow-tls<br/>Type: kubernetes.io/tls<br/>Provisioned: service-ca-operator"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE<br/>opendatahub or redhat-ods-applications"]
        direction TB

        OperatorPod["MLflow Operator Pod<br/>SA: controller-manager<br/>Metrics: 8443/HTTPS TLS1.2+<br/>Health: 8081/HTTP<br/>Read-only rootfs<br/>Non-root No caps"]

        MetricsSvc["controller-manager<br/>metrics-service<br/>8443/TCP HTTPS"]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
        OSConsole["OpenShift Console<br/>ConsoleLink integration"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES - Optional"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP<br/>TLS 1.2+ optional<br/>Auth: Username and Password"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM or Access Keys"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% External user flows
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Gateway
    Gateway -->|HTTPS/8443<br/>TLS 1.3<br/>Bearer Token forwarded| MLflowSvc
    MLflowSvc -->|HTTPS/8443<br/>TLS 1.3<br/>Bearer Token| MLflowContainer

    %% MLflow to K8s API
    MLflowContainer -->|HTTPS/6443<br/>TLS 1.2+<br/>self_subject_access_review<br/>SA Token: mlflow-sa| K8sAPI

    %% MLflow to external storage
    MLflowContainer -.->|PostgreSQL/5432<br/>TLS 1.2+ opt<br/>Backend and Registry Store| PostgreSQL
    MLflowContainer -.->|HTTPS/443<br/>TLS 1.2+<br/>Artifact Storage| S3

    %% Operator flows
    OperatorPod -->|HTTPS/6443<br/>TLS 1.2+<br/>Watch MLflow CRs<br/>Create resources<br/>SA Token: controller-manager| K8sAPI

    %% Monitoring
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MetricsSvc
    MetricsSvc -->|Forward| OperatorPod

    %% Console integration
    OperatorPod -.->|Creates ConsoleLink| OSConsole

    %% Security dependencies
    TLSSecret -.->|Mounted by| MLflowContainer
    NetworkPolicy -.->|Protects| MLflowPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class MLflowSvc,MLflowContainer,NetworkPolicy,TLSSecret application
    class OperatorPod,MetricsSvc operator
    class K8sAPI,OSConsole k8s
    class PostgreSQL,S3 externalservice
    class Prometheus monitoring
