%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser /<br/>ML Client SDK"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway (Envoy)<br/>Namespace: openshift-ingress<br/>443/TCP<br/>TLS 1.2+"]
        HTTPRoute["HTTPRoute (per MLflow CR)<br/>/mlflow/api/* → /api/*<br/>/mlflow/v1/* → /v1/*<br/>/mlflow/* → forward"]
        Gateway --- HTTPRoute
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["MLflow Operator<br/>SA: mlflow-operator-controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS (service-ca)"]
        end

        subgraph NS_Target["Namespace: target (per MLflow CR)"]
            MLflowServer["MLflow Server<br/>SA: mlflow-sa<br/>Port: 8443/TCP HTTPS<br/>TLS: service-ca cert<br/>Auth: K8s SubjectAccessReview"]
            NetworkPolicy["NetworkPolicy: mlflow<br/>Ingress: TCP 8443 (all NS)<br/>Egress: Allow all"]
            TLSSecret["Secret: mlflow-tls<br/>Type: kubernetes.io/tls<br/>Provisioned: service-ca<br/>Auto-rotate: Yes"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>Auth: SA Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        BackendDB["Backend Store<br/>(PostgreSQL/MySQL)<br/>Port: Configurable<br/>Auth: URI credentials"]
        ArtifactStorage["Artifact Storage<br/>(S3/GCS/Azure)<br/>443/TCP HTTPS<br/>Auth: Cloud credentials"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        ServiceCA["OpenShift service-ca<br/>TLS cert provisioning"]
        Prometheus["Prometheus<br/>Metrics scrape"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth / Bearer Token"| Gateway
    HTTPRoute -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Backend TLS passthrough"| MLflowServer

    %% Internal flows
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watch + SSA"| K8sAPI
    MLflowServer -->|"HTTPS/443<br/>TLS<br/>SubjectAccessReview"| K8sAPI

    %% Egress flows
    MLflowServer -->|"TCP<br/>Configurable<br/>URI credentials"| BackendDB
    MLflowServer -->|"HTTPS/443<br/>TLS<br/>Cloud credentials"| ArtifactStorage

    %% Platform flows
    ServiceCA -.->|"cert provisioning"| TLSSecret
    Prometheus -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token + SAR"| Operator

