// Feast Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates FeatureStore CRs and consumes features for ML training and inference"
        mlApplication = person "ML Application" "Consumes online features for real-time inference"

        feastOperator = softwareSystem "Feast Operator" "Kubernetes operator managing Feast feature store deployments on OpenShift" {
            controllerManager = container "Controller Manager" "FeatureStoreReconciler - manages FeatureStore CR lifecycle" "Go Operator (controller-runtime)"
            notebookReconciler = container "NotebookConfigMapReconciler" "Creates feast config ConfigMaps for labeled Kubeflow Notebooks" "Go Controller"
            authzModule = container "FeastAuthorization" "Deploys Kubernetes RBAC resources for auth-enabled feature stores" "Go Module"
            onlineStore = container "Online Store" "Serves features for real-time inference via HTTP/HTTPS" "Python Feature Server" "Dynamic"
            offlineStore = container "Offline Store" "Serves features for batch training via Arrow Flight" "Python Feature Server" "Dynamic"
            registryServer = container "Registry Server" "Feature metadata catalog via gRPC and REST" "Python Feature Server" "Dynamic"
            uiServer = container "UI Server" "Feature store web dashboard" "Python Feature Server" "Dynamic"
            cronJob = container "CronJob" "Runs feast apply and materialize-incremental on schedule" "Kubernetes CronJob" "Dynamic"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys feast-operator via kustomize overlay" "Internal RHOAI"
        kubeflowNotebooks = softwareSystem "Kubeflow Notebooks" "Interactive notebook environment for data scientists" "Internal ODH"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller exposing Routes externally" "OpenShift"
        openshiftCertSigner = softwareSystem "OpenShift Cert Signer" "Auto-provisions TLS certificates for services" "OpenShift"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "OpenShift"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster API server" "Kubernetes"

        externalDB = softwareSystem "External Database" "Snowflake, Cassandra, or SQL persistence backend" "External"
        gitRepos = softwareSystem "Git Repositories" "Source for feast project definitions" "External"

        // User interactions
        dataScientist -> feastOperator "Creates FeatureStore CR via kubectl/dashboard"
        mlApplication -> feastOperator "Queries online features" "HTTP/HTTPS 80/443"
        dataScientist -> kubeflowNotebooks "Uses notebooks with feast integration label"

        // Internal interactions
        rhodsOperator -> feastOperator "Deploys operator" "Kustomize"
        feastOperator -> kubernetesAPI "CRUD operations on cluster resources" "HTTPS/443 TLS 1.2+"
        feastOperator -> externalDB "Feature store persistence" "Varies"
        feastOperator -> gitRepos "Clone feast project dirs" "HTTPS/443"
        feastOperator -> kubeflowNotebooks "Watches Notebook CRs, creates config ConfigMaps"

        openshiftCertSigner -> feastOperator "Auto-provisions TLS certificates"
        openshiftRouter -> feastOperator "Routes external traffic to UI" "HTTPS/443 Reencrypt"
        prometheus -> feastOperator "Scrapes operator metrics" "HTTPS/8443"

        // Container-level interactions
        controllerManager -> kubernetesAPI "Watch FeatureStore CRs, manage resources" "HTTPS/443"
        controllerManager -> authzModule "Delegates RBAC creation"
        controllerManager -> onlineStore "Creates/manages deployment"
        controllerManager -> offlineStore "Creates/manages deployment"
        controllerManager -> registryServer "Creates/manages deployment"
        controllerManager -> uiServer "Creates/manages deployment"
        controllerManager -> cronJob "Creates/manages CronJob"
        notebookReconciler -> kubernetesAPI "Watch Notebooks, CRUD ConfigMaps" "HTTPS/443"
        onlineStore -> externalDB "Read/write features" "Varies"
        offlineStore -> externalDB "Read features for batch" "Varies"
        cronJob -> kubernetesAPI "kubectl exec into feast pod" "HTTPS/443"
    }

    views {
        systemContext feastOperator "SystemContext" {
            include *
            autoLayout
        }

        container feastOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #4a90e2
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "OpenShift" {
                background #ee0000
                color #ffffff
            }
            element "Kubernetes" {
                background #326ce5
                color #ffffff
            }
            element "Dynamic" {
                background #50c878
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
        }
    }
}
