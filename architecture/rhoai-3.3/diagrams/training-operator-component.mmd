graph TB
    subgraph "Training Operator Component"
        Controller[training-operator<br/>Main Controller]

        subgraph "Job Controllers"
            PyTorchCtrl[PyTorchJob Controller]
            TFJobCtrl[TFJob Controller]
            XGBoostCtrl[XGBoostJob Controller]
            MPIJobCtrl[MPIJob Controller]
            JAXJobCtrl[JAXJob Controller]
            PaddleJobCtrl[PaddleJob Controller]
        end

        Webhook[Validating Webhooks<br/>9443/TCP HTTPS]
        CertMgr[Cert Controller<br/>Built-in]
        Metrics[Metrics Server<br/>8080/TCP HTTP]
        Health[Health Probes<br/>8081/TCP HTTP]

        Controller -->|manages| PyTorchCtrl
        Controller -->|manages| TFJobCtrl
        Controller -->|manages| XGBoostCtrl
        Controller -->|manages| MPIJobCtrl
        Controller -->|manages| JAXJobCtrl
        Controller -->|manages| PaddleJobCtrl

        Webhook -->|validates| Controller
        CertMgr -->|provides certs| Webhook
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        JAXJob[JAXJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        Pods[Training Pods<br/>Master/Worker]
        Services[K8s Services<br/>Pod Discovery]
        ConfigMaps[ConfigMaps]
        HPA[HorizontalPodAutoscaler<br/>Optional]
        PodGroups[PodGroups<br/>Gang Scheduling]
    end

    User[Data Scientist] -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| XGBoostJob
    User -->|creates| MPIJob
    User -->|creates| JAXJob
    User -->|creates| PaddleJob

    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFJobCtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    MPIJob -->|watched by| MPIJobCtrl
    JAXJob -->|watched by| JAXJobCtrl
    PaddleJob -->|watched by| PaddleJobCtrl

    PyTorchCtrl -->|creates| Pods
    TFJobCtrl -->|creates| Pods
    XGBoostCtrl -->|creates| Pods
    MPIJobCtrl -->|creates| Pods
    JAXJobCtrl -->|creates| Pods
    PaddleJobCtrl -->|creates| Pods

    Controller -->|creates| Services
    Controller -->|creates| ConfigMaps
    Controller -->|creates| HPA
    Controller -->|creates| PodGroups

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Collection]
        Volcano[Volcano Scheduler<br/>Optional]
        SchedulerPlugins[scheduler-plugins<br/>Optional]
    end

    Controller -->|API calls| K8sAPI
    Metrics -->|scraped by| Prometheus
    Controller -.->|gang scheduling| Volcano
    Controller -.->|gang scheduling| SchedulerPlugins

