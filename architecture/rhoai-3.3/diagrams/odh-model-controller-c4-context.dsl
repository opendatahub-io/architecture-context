/*
 * C4 Context Diagram: odh-model-controller
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/odh-model-controller.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and deploys ML models via InferenceService and LLMInferenceService CRs"
        admin = person "Platform Admin" "Configures NIM accounts and platform settings"
        externalClient = person "External Client" "Sends inference requests to deployed models"

        odhModelController = softwareSystem "odh-model-controller" "Manages model serving infrastructure for KServe resources on OpenShift AI" {
            isvcController = container "InferenceService Controller" "Reconciles InferenceService CRs; creates Routes, monitoring, auth, KEDA resources" "Go Controller"
            llmisvcController = container "LLMInferenceService Controller" "Reconciles LLMInferenceService CRs; creates AuthPolicies, EnvoyFilters, RBAC" "Go Controller"
            igController = container "InferenceGraph Controller" "Watches InferenceGraph CRs for validation" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages monitoring RoleBindings, Ray TLS certs" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NGC API key validation, pull secrets, runtime templates" "Go Controller"
            cmController = container "ConfigMap Controller" "Aggregates CA certs into KServe-compatible format" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into storage-config" "Go Controller"
            podController = container "Pod Controller" "Manages per-pod Ray TLS certificates" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating/validating admission webhooks" "Go HTTPS Server" "9443/TCP"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Routes external traffic to services via OpenShift Routes" "External"
        gatewayAPI = softwareSystem "Gateway API (Istio)" "Gateway and HTTPRoute resources for LLMInferenceService ingress" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Authentication via AuthPolicy and Authorino" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "ServiceMonitor and PodMonitor for metrics collection" "External"
        keda = softwareSystem "KEDA" "TriggerAuthentication for autoscaling" "External"
        certManager = softwareSystem "OpenShift service-ca" "Provides TLS certificates for webhook server" "External"
        nvidiaNG = softwareSystem "NVIDIA NGC API" "NIM account validation and model catalog" "External"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata for label sync" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys odh-model-controller via Kustomize" "Internal ODH"
        dashboard = softwareSystem "ODH Dashboard" "UI for managing model serving" "Internal ODH"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core K8s API for all resource operations" "External"

        # User interactions
        user -> odhModelController "Creates InferenceService / LLMInferenceService via kubectl" "HTTPS/443"
        admin -> odhModelController "Creates NIM Account CRs" "HTTPS/443"
        externalClient -> openshiftRouter "Sends inference requests" "HTTPS/443"
        externalClient -> gatewayAPI "Sends inference requests (RHOAI 3.x)" "HTTPS/443"

        # Controller dependencies
        odhModelController -> k8sAPI "All resource CRUD operations" "HTTPS/443"
        odhModelController -> kserve "Watches/updates InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService" "HTTPS/443 (K8s API)"
        odhModelController -> openshiftRouter "Creates OpenShift Routes" "HTTPS/443 (K8s API)"
        odhModelController -> gatewayAPI "Watches Gateway, HTTPRoute" "HTTPS/443 (K8s API)"
        odhModelController -> kuadrant "Creates AuthPolicy, detects Authorino" "HTTPS/443 (K8s API)"
        odhModelController -> prometheusOp "Creates ServiceMonitor, PodMonitor" "HTTPS/443 (K8s API)"
        odhModelController -> keda "Creates TriggerAuthentication" "HTTPS/443 (K8s API)"
        odhModelController -> nvidiaNG "Validates NGC API keys, fetches model config" "HTTPS/443 TLS 1.2+"
        odhModelController -> modelRegistry "Syncs InferenceService labels" "HTTP(S) Configurable"

        # Platform relationships
        rhodsOperator -> odhModelController "Deploys via Kustomize base overlay"

        # Internal container relationships
        isvcController -> webhookServer "Registers mutating/validating webhooks"
        llmisvcController -> webhookServer "Registers validating webhooks"
        nimController -> webhookServer "Registers validating webhooks"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
