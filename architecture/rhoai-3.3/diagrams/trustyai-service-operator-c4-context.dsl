// C4 Context Diagram - TrustyAI Service Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates ML models and evaluates them for trustworthiness and safety"
        mlops = person "MLOps Engineer" "Deploys and manages AI/ML services and guardrails"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller Go operator managing AI trustworthiness and safety services" {
            tasController = container "TrustyAIService Controller" "Reconciles TrustyAIService CRs; deploys explainability services with bias/fairness monitoring" "Go Controller"
            lmesController = container "LMEvalJob Controller" "Reconciles LMEvalJob CRs; runs LM evaluation benchmark jobs" "Go Controller"
            gorchController = container "GuardrailsOrchestrator Controller" "Reconciles GuardrailsOrchestrator CRs; deploys content moderation services" "Go Controller"
            nemoController = container "NemoGuardrails Controller" "Reconciles NemoGuardrails CRs; deploys NVIDIA NeMo Guardrails servers" "Go Controller"
            jobManager = container "Job Manager" "Kueue integration for LMEvalJob workload scheduling" "Go Controller"
            operatorManager = container "Operator Manager" "Main entrypoint; health/readiness probes, metrics serving" "Go Binary"
        }

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys TrustyAI operator via kustomize overlays" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving platform; provides InferenceService and ServingRuntime CRDs" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving infrastructure" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / Monitoring Stack" "Metrics collection and alerting via ServiceMonitor CRs" "Internal RHOAI"
        certSigner = softwareSystem "OpenShift Service Serving Cert Signer" "Automatic TLS certificate provisioning" "OpenShift Platform"
        kueue = softwareSystem "Kueue" "Job queuing and resource management for batch workloads" "External"
        istio = softwareSystem "Istio Service Mesh" "Traffic management with VirtualService/DestinationRule" "External"
        kubeAPI = softwareSystem "Kubernetes API Server" "Cluster API for all controller-runtime operations" "Platform"

        // Relationships - Users
        datascientist -> trustyaiOperator "Creates TrustyAIService and LMEvalJob CRs via kubectl/dashboard"
        mlops -> trustyaiOperator "Creates GuardrailsOrchestrator and NemoGuardrails CRs"

        // Relationships - Deployment
        rhodsOperator -> trustyaiOperator "Deploys via kustomize overlays with RELATED_IMAGE env vars"

        // Relationships - Internal
        trustyaiOperator -> kserve "Watches/patches InferenceService; watches ServingRuntime" "Kubernetes API/HTTPS"
        trustyaiOperator -> modelMesh "Patches ModelMesh Deployments with payload processor config" "Kubernetes API/HTTPS"
        trustyaiOperator -> prometheus "Creates ServiceMonitor CRs for metrics scraping" "HTTP/8080"
        trustyaiOperator -> certSigner "Requests TLS certificates via service annotations" "Annotation-based"
        trustyaiOperator -> kueue "Creates Workload resources for LMEvalJob scheduling" "Kubernetes API/HTTPS"
        trustyaiOperator -> istio "Creates VirtualService/DestinationRule when Istio CRDs present" "Kubernetes API/HTTPS"
        trustyaiOperator -> kubeAPI "CRD management, Pod creation, pod/exec, leader election" "HTTPS/443"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "OpenShift Platform" {
                background #ee0000
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
        }
    }
}
