graph TD
    subgraph "Service Account"
        SA[kubeflow-trainer-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kubeflow-trainer-controller-manager<br/>Scope: cluster-wide]
    end

    subgraph "ClusterRole Permissions"
        CR[kubeflow-trainer-controller-manager]
    end

    subgraph "Core API Resources"
        ConfigMaps[core/ConfigMaps<br/>create, get, list, patch, update, watch]
        Secrets[core/Secrets<br/>create, get, list, patch, update, watch]
        Events[core/Events<br/>create, patch, update, watch]
        LimitRanges[core/LimitRanges<br/>get, list, watch]
        Pods[core/Pods<br/>get, list<br/>RHOAI Extension]
    end

    subgraph "Admission API Resources"
        Webhooks[admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations<br/>get, list, update, watch]
    end

    subgraph "Coordination API Resources"
        Leases[coordination.k8s.io/Leases<br/>create, get, list, update]
    end

    subgraph "JobSet API Resources"
        JobSets[jobset.x-k8s.io/JobSets<br/>create, get, list, patch, update, watch]
    end

    subgraph "Node API Resources"
        RuntimeClasses[node.k8s.io/RuntimeClasses<br/>get, list, watch]
    end

    subgraph "Scheduling API Resources"
        PodGroups[scheduling.volcano.sh<br/>scheduling.x-k8s.io<br/>PodGroups<br/>create, get, list, patch, update, watch]
    end

    subgraph "Trainer API Resources"
        TrainJobs[trainer.kubeflow.org<br/>TrainJobs<br/>get, list, patch, update, watch]
        TrainJobsStatus[trainer.kubeflow.org<br/>TrainJobs/status, /finalizers<br/>get, patch, update]
        TrainingRuntimes[trainer.kubeflow.org<br/>TrainingRuntimes<br/>get, list, patch, update, watch]
        TrainingRuntimesFinalizers[trainer.kubeflow.org<br/>TrainingRuntimes/finalizers<br/>get, patch, update]
        ClusterTrainingRuntimes[trainer.kubeflow.org<br/>ClusterTrainingRuntimes<br/>get, list, patch, update, watch]
        ClusterTrainingRuntimesFinalizers[trainer.kubeflow.org<br/>ClusterTrainingRuntimes/finalizers<br/>get, patch, update]
    end

    subgraph "Networking API Resources (RHOAI)"
        NetworkPolicies[networking.k8s.io<br/>NetworkPolicies<br/>get, list, watch, create, update, patch<br/>RHOAI Extension]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Secrets
    CR -->|permissions| Events
    CR -->|permissions| LimitRanges
    CR -->|permissions| Pods
    CR -->|permissions| Webhooks
    CR -->|permissions| Leases
    CR -->|permissions| JobSets
    CR -->|permissions| RuntimeClasses
    CR -->|permissions| PodGroups
    CR -->|permissions| TrainJobs
    CR -->|permissions| TrainJobsStatus
    CR -->|permissions| TrainingRuntimes
    CR -->|permissions| TrainingRuntimesFinalizers
    CR -->|permissions| ClusterTrainingRuntimes
    CR -->|permissions| ClusterTrainingRuntimesFinalizers
    CR -->|permissions| NetworkPolicies

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainJobs fill:#7ed321,stroke:#333
    style TrainJobsStatus fill:#7ed321,stroke:#333
    style TrainingRuntimes fill:#7ed321,stroke:#333
    style TrainingRuntimesFinalizers fill:#7ed321,stroke:#333
    style ClusterTrainingRuntimes fill:#7ed321,stroke:#333
    style ClusterTrainingRuntimesFinalizers fill:#7ed321,stroke:#333
    style JobSets fill:#ff6b6b,stroke:#333
    style NetworkPolicies fill:#50e3c2,stroke:#333
    style Pods fill:#50e3c2,stroke:#333
