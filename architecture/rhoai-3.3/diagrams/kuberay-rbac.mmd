graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>Operator Namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB[kuberay-operator<br/>ClusterRoleBinding]
        LeaderElection[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "Roles"
        CR[kuberay-operator<br/>ClusterRole]
        LeaderRole[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Pods[Core API<br/>pods, services, serviceaccounts<br/>configmaps, events, secrets, endpoints]
        PodStatus[Core API<br/>pods/status, pods/proxy<br/>services/status, services/proxy]
    end

    subgraph "Apps/Batch API Resources"
        Deployments[apps<br/>deployments]
        Jobs[batch<br/>jobs]
    end

    subgraph "Ray CRD Resources"
        RayClusters[ray.io<br/>rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers]
        RayJobs[ray.io<br/>rayjobs<br/>rayjobs/status<br/>rayjobs/finalizers]
        RayServices[ray.io<br/>rayservices<br/>rayservices/status<br/>rayservices/finalizers]
    end

    subgraph "Networking Resources"
        Network[networking.k8s.io<br/>ingresses, networkpolicies, ingressclasses]
        Routes[route.openshift.io<br/>routes]
        Gateway[gateway.networking.k8s.io<br/>httproutes, referencegrants, gateways]
    end

    subgraph "Certificate Resources"
        Certs[cert-manager.io<br/>certificates, issuers]
    end

    subgraph "RBAC Resources"
        RBACResources[rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterroles, clusterrolebindings]
    end

    subgraph "Other Resources"
        Leases[coordination.k8s.io<br/>leases]
        OpenShiftAuth[config.openshift.io<br/>authentications, oauths]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderElection
    CRB -->|grants| CR
    LeaderElection -->|grants| LeaderRole

    %% ClusterRole Permissions
    CR -->|get,list,watch,create,update,patch,delete| Pods
    CR -->|get,patch,update| PodStatus
    CR -->|get,list,watch,patch,update| Deployments
    CR -->|get,list,watch,create,update,patch,delete| Jobs
    CR -->|get,list,watch,create,update,patch,delete| RayClusters
    CR -->|get,list,watch,create,update,patch,delete| RayJobs
    CR -->|get,list,watch,create,update,patch,delete| RayServices
    CR -->|get,list,watch,create,update,patch,delete| Network
    CR -->|get,list,watch,create,update,patch,delete| Routes
    CR -->|get,list,watch,create,update,patch,delete| Gateway
    CR -->|get,list,watch,create,update,patch,delete| Certs
    CR -->|get,list,watch,create,update,delete| RBACResources
    CR -->|get,list,create,update| Leases
    CR -->|get,list,watch| OpenShiftAuth

    %% Leader Election
    LeaderRole -->|get,list,create,update| Leases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB fill:#e8e8e8,stroke:#333
    style LeaderElection fill:#e8e8e8,stroke:#333
    style RayClusters fill:#7ed321,stroke:#333,color:#000
    style RayJobs fill:#7ed321,stroke:#333,color:#000
    style RayServices fill:#7ed321,stroke:#333,color:#000
    style Pods fill:#d5e8d4,stroke:#333,color:#000
    style PodStatus fill:#d5e8d4,stroke:#333,color:#000
    style Deployments fill:#d5e8d4,stroke:#333,color:#000
    style Jobs fill:#d5e8d4,stroke:#333,color:#000
    style Network fill:#cce5ff,stroke:#333,color:#000
    style Routes fill:#cce5ff,stroke:#333,color:#000
    style Gateway fill:#cce5ff,stroke:#333,color:#000
    style Certs fill:#fff2cc,stroke:#333,color:#000
    style RBACResources fill:#ffe6cc,stroke:#333,color:#000
    style Leases fill:#e1d5e7,stroke:#333,color:#000
    style OpenShiftAuth fill:#e1d5e7,stroke:#333,color:#000
