/*
 * Kubeflow Notebook Controller - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / User" "Creates and manages Jupyter notebook instances via Dashboard or kubectl"

        kubeflow = softwareSystem "Kubeflow Notebook Controller" "Manages lifecycle of Notebook CRs by reconciling StatefulSets, Services, and idle culling" {
            notebookReconciler = container "NotebookReconciler" "Watches Notebook CRs; creates/updates StatefulSets, Services per notebook" "Go Controller (controller-runtime v0.21.0)"
            cullingReconciler = container "CullingReconciler" "Monitors notebook idle time via Jupyter API; scales down idle notebooks" "Go Controller"
            metricsCollector = container "Metrics Collector" "Exposes notebook_running, notebook_create_total, notebook_culling_total" "Prometheus Metrics :8080/TCP"
        }

        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science resources" "Internal ODH"
        odhNotebookController = softwareSystem "odh-notebook-controller" "Complementary controller handling OpenShift-specific networking (HTTPRoutes, kube-rbac-proxy, OAuth)" "Internal ODH"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform API for resource management" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and alerting" "External"
        istio = softwareSystem "Istio" "Service mesh (VirtualService support - disabled in RHOAI)" "External"

        # Relationships
        user -> odhDashboard "Creates notebooks via UI"
        user -> k8sAPI "Creates Notebook CRs via kubectl"
        odhDashboard -> k8sAPI "Creates Notebook CRs" "HTTPS/443"

        kubeflow -> k8sAPI "CRUD: Notebooks, StatefulSets, Services, Pods, Events" "HTTPS/443 TLS 1.2+ SA Token"
        kubeflow -> istio "Creates VirtualServices (disabled in RHOAI)" "networking.istio.io/v1alpha3"

        notebookReconciler -> k8sAPI "Creates StatefulSets, Services" "HTTPS/443"
        cullingReconciler -> k8sAPI "Sets stop annotation on idle notebooks" "HTTPS/443"

        odhNotebookController -> k8sAPI "Manages HTTPRoutes, auth sidecars for shared Notebook CRs" "HTTPS/443"
        prometheus -> kubeflow "Scrapes metrics" "HTTP/8080"
    }

    views {
        systemContext kubeflow "SystemContext" {
            include *
            autoLayout
            description "System context showing Kubeflow Notebook Controller in the RHOAI ecosystem"
        }

        container kubeflow "Containers" {
            include *
            autoLayout
            description "Internal structure of the Kubeflow Notebook Controller"
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
