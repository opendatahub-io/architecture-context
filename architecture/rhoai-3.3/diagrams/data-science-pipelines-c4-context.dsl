// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Users
        datascientist = person "Data Scientist" "Authors, submits, and monitors ML pipelines"
        mlEngineer = person "ML Engineer" "Manages pipeline schedules and production deployments"

        // Main system
        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines-based ML workflow orchestration platform for authoring, scheduling, executing, and tracking ML pipelines" {
            apiServer = container "ml-pipeline API Server" "REST/gRPC API for pipeline CRUD, run management, experiments, and artifacts" "Go Service" "8888/TCP REST, 8887/TCP gRPC"
            pipelineUI = container "ml-pipeline-ui" "Web dashboard for pipeline visualization, experiment management, and run monitoring" "Node.js/React" "3000/TCP"
            persistenceAgent = container "Persistence Agent" "Watches Argo Workflows and reports execution status to API server" "Go Agent"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages ScheduledWorkflow CRDs for cron/periodic pipeline execution" "Go Controller"
            viewerCRD = container "Viewer CRD Controller" "Manages Viewer CRDs for TensorBoard and visualization deployments" "Go Controller"
            cacheServer = container "Cache Server" "Mutating admission webhook for pipeline step caching" "Go Webhook" "8443/TCP HTTPS"
            mlmdServer = container "Metadata gRPC Server" "ML Metadata store for artifact and execution lineage tracking" "C++ gRPC" "8080/TCP"
            metadataEnvoy = container "Metadata Envoy" "HTTP-to-gRPC transcoding proxy for MLMD" "Envoy Proxy" "9090/TCP"
            metadataWriter = container "Metadata Writer" "Watches Workflows and writes execution metadata to MLMD" "Python Agent"
            vizServer = container "Visualization Server" "Generates visualization artifacts from pipeline outputs" "Python Service" "8888/TCP"
            driver = container "Driver" "V2 pipeline step driver - resolves inputs, creates outputs, manages caching" "Go Binary"
            launcher = container "Launcher V2" "V2 pipeline step launcher - executes user containers and uploads artifacts" "Go Binary"
            webhookServer = container "PipelineVersion Webhook" "Validates and mutates PipelineVersion resources" "Go Webhook" "8443/TCP HTTPS"
        }

        // External dependencies
        argoWorkflows = softwareSystem "Argo Workflows" "Pipeline execution engine - creates and manages Workflow CRs" "External"
        database = softwareSystem "MySQL/PostgreSQL" "Primary database for pipeline metadata, run history, and caching" "External"
        objectStorage = softwareSystem "MinIO/S3 Object Storage" "Pipeline artifact storage and log archival" "External"
        istio = softwareSystem "Istio Service Mesh" "mTLS and AuthorizationPolicy for multi-user traffic isolation" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management for webhooks" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "CRD management, RBAC, pod lifecycle" "External"

        // Internal ODH dependencies
        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Deploys and manages DSP component lifecycle in RHOAI" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Provides link/integration to pipeline UI" "Internal RHOAI"

        // User relationships
        datascientist -> dsp "Submits pipelines, monitors runs via UI and SDK"
        mlEngineer -> dsp "Manages scheduled pipelines and production workflows"

        // Internal container relationships
        pipelineUI -> apiServer "REST API calls" "HTTP/8888"
        persistenceAgent -> apiServer "Reports workflow status" "HTTP/8888"
        persistenceAgent -> k8sAPI "Watches Workflows" "HTTPS/443"
        scheduledWorkflow -> k8sAPI "Watches ScheduledWorkflows, creates Workflows" "HTTPS/443"
        viewerCRD -> k8sAPI "Watches Viewer CRs" "HTTPS/443"
        metadataWriter -> mlmdServer "Writes execution metadata" "gRPC/8080"
        metadataWriter -> k8sAPI "Watches Workflows" "HTTPS/443"
        metadataEnvoy -> mlmdServer "Proxies HTTP to gRPC" "gRPC/8080"
        apiServer -> database "Stores pipeline metadata" "DB protocol/3306,5432"
        apiServer -> objectStorage "Stores artifacts" "HTTP/9000"
        apiServer -> k8sAPI "Creates Workflows, manages CRDs" "HTTPS/443"
        apiServer -> webhookServer "PipelineVersion validation" "HTTPS/8443"
        cacheServer -> database "Checks cache entries" "DB protocol/3306,5432"
        driver -> apiServer "Resolves inputs" "HTTP/8888"
        launcher -> objectStorage "Uploads artifacts" "HTTP/9000"

        // External system relationships
        dsp -> argoWorkflows "Creates Workflow CRs for pipeline execution" "K8s API"
        dsp -> database "Pipeline metadata persistence" "DB protocol/3306,5432"
        dsp -> objectStorage "Pipeline artifact and log storage" "S3 API/9000"
        dsp -> istio "mTLS and authorization in multi-user mode"
        dsp -> certManager "TLS certificates for webhooks"
        dsp -> k8sAPI "CRD management, RBAC, pod lifecycle" "HTTPS/443"

        // Internal relationships
        dspo -> dsp "Deploys and manages lifecycle"
        dashboard -> dsp "UI integration and links"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
