// C4 Context Diagram for vllm-gaudi
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM models on Intel Gaudi hardware"

        vllmGaudi = softwareSystem "vllm-gaudi" "vLLM hardware plugin providing optimized LLM inference on Intel Gaudi (Habana) AI accelerators" {
            apiServer = container "vLLM API Server" "OpenAI-compatible REST API server for model inference" "Python / vLLM v0.16.0" "Web Server"
            hpuPlatform = container "HpuPlatform" "Registers HPU as a vLLM platform with device configuration and backend selection" "Python Plugin"
            hpuWorker = container "HPUWorker" "Manages HPU device lifecycle, KV-cache, model loading, and distributed execution" "Python Worker"
            hpuModelRunner = container "HPUModelRunner" "Executes model forward passes on HPU with bucketing and optimizations" "Python Model Runner"
            attentionBackends = container "Attention Backends" "HPU-optimized attention: HPUAttentionV1, UnifiedMLA, HPUMLAAttention" "Python Modules"
            customOps = container "Custom Ops" "HPU kernels: fused MoE, rotary embedding, FP8/GPTQ/AWQ quantization" "Python Modules"
            hpuCommunicator = container "HpuCommunicator" "Distributed communication using HCCL (Habana Collective Communication Library)" "Python Module"
            nixlConnector = container "NIXL KV Connector" "KV-cache transfer between disaggregated prefill/decode workers" "Python Module"
            modelOverrides = container "Model Overrides" "HPU-specific implementations for Gemma3, Qwen, DeepSeek, Pixtral, etc." "Python Modules"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform managing ServingRuntime lifecycle" "Internal RHOAI"
        modelController = softwareSystem "Model Controller" "Manages InferenceService CRs referencing this runtime" "Internal RHOAI"
        gatewayAPI = softwareSystem "Gateway API / Istio" "Provides TLS termination, routing, and authentication" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact metadata and versioning" "Internal RHOAI"
        gaudiHPU = softwareSystem "Intel Gaudi HPU" "Hardware accelerator with SynapseAI 1.23.0 driver stack" "External Hardware"
        s3 = softwareSystem "Object Storage (S3)" "Model artifact storage" "External Service"
        huggingface = softwareSystem "HuggingFace Hub" "Model weights and tokenizer distribution" "External Service"
        ray = softwareSystem "Ray" "Distributed execution framework for multi-HPU inference" "External Dependency"

        user -> vllmGaudi "Sends inference requests via HTTPS/443"
        user -> kserve "Creates InferenceService via kubectl"

        vllmGaudi -> gaudiHPU "Executes inference on HPU via PCIe/RDMA"
        vllmGaudi -> s3 "Downloads model weights" "HTTPS/443"
        vllmGaudi -> huggingface "Downloads model files" "HTTPS/443"
        vllmGaudi -> ray "Orchestrates multi-HPU workers" "TCP/6379"

        kserve -> vllmGaudi "Deploys as ServingRuntime container"
        modelController -> kserve "Manages InferenceService CRs"
        gatewayAPI -> vllmGaudi "Routes traffic with TLS termination" "HTTPS/443 → HTTP/8000"
        vllmGaudi -> modelRegistry "Fetches model metadata (optional)" "HTTPS"

        // Internal container relationships
        apiServer -> hpuPlatform "Delegates to HPU platform"
        hpuPlatform -> hpuWorker "Configures workers"
        hpuWorker -> hpuModelRunner "Manages model execution"
        hpuModelRunner -> attentionBackends "Uses attention backends"
        hpuModelRunner -> customOps "Uses custom HPU ops"
        hpuModelRunner -> modelOverrides "Loads HPU-optimized models"
        hpuWorker -> hpuCommunicator "Distributed communication via HCCL"
        hpuWorker -> nixlConnector "KV-cache transfer via NIXL"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External Hardware" {
                background #e67e22
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "External Dependency" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
