/*
 * NeMo Guardrails - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/NeMo-Guardrails.md
 */

workspace {
    model {
        user = person "AI Application Developer" "Configures guardrail rules and deploys NeMo Guardrails"

        nemoGuardrails = softwareSystem "NeMo Guardrails" "Programmable guardrails layer for LLM-based conversational systems" {
            server = container "Guardrails Server" "OpenAI-compatible chat completions API with guardrails applied" "FastAPI/Uvicorn, Python 3.12, Port 8000"
            actionsServer = container "Actions Server" "Executes guardrail actions remotely" "FastAPI/Uvicorn, Python 3.12, Port 8001"
            llmRailsEngine = container "LLMRails Engine" "Core guardrails engine intercepting LLM calls and applying input/output rails" "Python Library"
            colangRuntime = container "Colang Runtime" "Domain-specific language runtime for defining conversational flows (v1.0, v2.x)" "Python Library"
            guardrailsLibrary = container "Guardrails Library" "Built-in guardrails: self-check, hallucination, injection, jailbreak, PII, topic safety" "Python Modules"
            knowledgeBase = container "Knowledge Base" "RAG-based retrieval with embedding indexes (Annoy)" "Python Library"
            embeddingProviders = container "Embedding Providers" "FastEmbed, SentenceTransformers for text embeddings" "Python Modules"
            tracingSystem = container "Tracing System" "OpenTelemetry-compatible tracing" "Python Library"
        }

        trustyai = softwareSystem "TrustyAI" "AI model safety and explainability service" "Internal RHOAI"
        llmEndpoint = softwareSystem "LLM Serving Endpoint" "Backend LLM model (vLLM, TGIS, NIM)" "Internal RHOAI"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Pre-trained NLP model hosting (build-time only)" "External"
        kubernetes = softwareSystem "Kubernetes" "Container orchestration, ConfigMap management" "Platform"

        # Relationships - External
        user -> nemoGuardrails "Configures guardrails via ConfigMap (config.yaml, rails.co)"
        trustyai -> nemoGuardrails "Sends chat completions through guardrails" "HTTP/8000"
        nemoGuardrails -> llmEndpoint "Forwards requests to backend LLM" "HTTPS/443, API Key"
        nemoGuardrails -> otelCollector "Exports tracing spans" "gRPC/4317, TLS"
        nemoGuardrails -> huggingface "Downloads NLP models (build-time)" "HTTPS/443"
        kubernetes -> nemoGuardrails "Provides ConfigMap volume mounts"

        # Relationships - Internal
        server -> llmRailsEngine "Routes requests through guardrails engine"
        actionsServer -> guardrailsLibrary "Executes guardrail actions"
        llmRailsEngine -> colangRuntime "Parses and executes Colang flows"
        llmRailsEngine -> guardrailsLibrary "Applies input/output rails"
        llmRailsEngine -> knowledgeBase "Retrieves RAG context"
        knowledgeBase -> embeddingProviders "Generates text embeddings"
        server -> tracingSystem "Records tracing spans"
    }

    views {
        systemContext nemoGuardrails "SystemContext" {
            include *
            autoLayout
        }

        container nemoGuardrails "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
