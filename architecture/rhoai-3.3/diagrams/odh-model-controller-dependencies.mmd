graph LR
    ODHController[odh-model-controller]

    subgraph "External Dependencies (Required)"
        KServe[KServe v0.15.1<br/>Core model serving]
        Kubernetes[Kubernetes v1.11.3+<br/>Container orchestration]
        OpenShift[OpenShift v4.11+<br/>Routes, Templates]
    end

    subgraph "External Dependencies (Optional)"
        Prometheus[Prometheus Operator<br/>Metrics collection]
        KEDA[KEDA v2.x<br/>Event-driven autoscaling]
        CertManager[cert-manager<br/>TLS cert management]
        Kuadrant[Kuadrant<br/>AuthPolicy for API auth]
        Authorino[Authorino<br/>Authorization service]
        Istio[Istio<br/>Service mesh]
    end

    subgraph "Internal ODH Dependencies"
        ODHOperator[opendatahub-operator<br/>Platform configuration]
        ModelRegistry[model-registry<br/>Model metadata]
    end

    subgraph "Serving Runtime Dependencies"
        vLLM[vLLM v0.11.2<br/>LLM inference]
        OpenVINO[OpenVINO v2025.4<br/>Intel-optimized serving]
        MLServer[MLServer 1.7.1<br/>Multi-framework serving]
        Caikit[Caikit v0.27.7<br/>IBM AI toolkit]
        CaikitNLP[Caikit-nlp v0.5.8<br/>NLP runtime]
        TGI[Text Generation Inference<br/>Hugging Face TGI]
    end

    subgraph "External Services"
        NGC[NVIDIA NGC API<br/>NIM account validation]
        S3[S3 Storage<br/>Model artifacts]
    end

    subgraph "CRDs Watched"
        InferenceService[InferenceService<br/>serving.kserve.io/v1beta1]
        InferenceGraph[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        LLMInferenceService[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
        NIMAccount[NIM Account<br/>nim.opendatahub.io/v1]
    end

    %% Core dependencies
    ODHController -->|extends| KServe
    ODHController -->|runs on| Kubernetes
    ODHController -->|requires| OpenShift

    %% Optional integrations
    ODHController -.->|creates ServiceMonitors| Prometheus
    ODHController -.->|creates TriggerAuthentications| KEDA
    ODHController -.->|webhook certs| CertManager
    ODHController -.->|creates AuthPolicies| Kuadrant
    ODHController -.->|integrates| Authorino
    ODHController -.->|creates EnvoyFilters| Istio

    %% Internal dependencies
    ODHController -->|reads DSC config| ODHOperator
    ODHController -.->|optional API calls| ModelRegistry

    %% CRD watches
    KServe -->|provides| InferenceService
    KServe -->|provides| InferenceGraph
    KServe -->|provides| ServingRuntime
    KServe -->|provides| LLMInferenceService

    ODHController -->|watches/reconciles| InferenceService
    ODHController -->|watches/reconciles| InferenceGraph
    ODHController -->|watches/reconciles| ServingRuntime
    ODHController -->|watches/reconciles| LLMInferenceService
    ODHController -->|manages| NIMAccount

    %% External services
    ODHController -->|validates accounts| NGC
    ODHController -.->|inference workloads use| S3

    %% Serving runtimes
    ServingRuntime -.->|templates for| vLLM
    ServingRuntime -.->|templates for| OpenVINO
    ServingRuntime -.->|templates for| MLServer
    ServingRuntime -.->|templates for| Caikit
    ServingRuntime -.->|templates for| CaikitNLP
    ServingRuntime -.->|templates for| TGI

    %% Styling
    style ODHController fill:#4a90e2,stroke:#333,stroke-width:4px
    style KServe fill:#e74c3c,stroke:#333,stroke-width:2px
    style Kubernetes fill:#326ce5,stroke:#333,stroke-width:2px
    style OpenShift fill:#ee0000,stroke:#333,stroke-width:2px
    style Prometheus fill:#e6522c,stroke:#333
    style KEDA fill:#326ce5,stroke:#333
    style CertManager fill:#326ce5,stroke:#333
    style Kuadrant fill:#326ce5,stroke:#333
    style Authorino fill:#326ce5,stroke:#333
    style Istio fill:#466bb0,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style NGC fill:#76b900,stroke:#333
    style S3 fill:#ff9900,stroke:#333
    style InferenceService fill:#f5a623,stroke:#333
    style InferenceGraph fill:#f5a623,stroke:#333
    style ServingRuntime fill:#f5a623,stroke:#333
    style LLMInferenceService fill:#f5a623,stroke:#333
    style NIMAccount fill:#f5a623,stroke:#333
