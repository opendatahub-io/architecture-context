graph TD
    subgraph "Service Account"
        SA[odh-model-controller<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-model-controller-role-binding]
        CRB2[odh-model-controller-leader-election-role-binding]
        CRB3[odh-model-controller-proxy-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[odh-model-controller-role]
        CR2[odh-model-controller-leader-election-role]
        CR3[odh-model-controller-proxy-role]
        CR4[odh-model-controller-metrics-reader]
    end

    subgraph "KServe CRD Permissions"
        InferenceService[serving.kserve.io<br/>InferenceService<br/>get,list,patch,update,watch]
        InferenceGraph[serving.kserve.io<br/>InferenceGraph<br/>get,list,watch]
        ServingRuntime[serving.kserve.io<br/>ServingRuntime<br/>create,get,list,update,watch]
        LLMInferenceService[serving.kserve.io<br/>LLMInferenceService<br/>get,list,patch,post,update,watch]
    end

    subgraph "NIM CRD Permissions"
        NIMAccount[nim.opendatahub.io<br/>Account<br/>get,list,patch,update,watch<br/>finalizers: update<br/>status: get,list,update,watch]
    end

    subgraph "OpenShift Permissions"
        Routes[route.openshift.io<br/>Route<br/>create,delete,get,list,patch,update,watch<br/>custom-host: create]
        Templates[template.openshift.io<br/>Template<br/>create,delete,get,list,patch,update,watch]
        Auth[config.openshift.io<br/>Authentication<br/>get,list,watch]
    end

    subgraph "Monitoring Permissions"
        ServiceMonitor[monitoring.coreos.com<br/>ServiceMonitor<br/>create,delete,get,list,patch,update,watch]
        PodMonitor[monitoring.coreos.com<br/>PodMonitor<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Network Permissions"
        NetworkPolicy[networking.k8s.io<br/>NetworkPolicy<br/>create,delete,get,list,patch,update,watch]
        EnvoyFilter[networking.istio.io<br/>EnvoyFilter<br/>create,delete,get,list,patch,update,watch]
        Gateway[gateway.networking.k8s.io<br/>Gateway<br/>get,list,patch,update,watch<br/>finalizers: patch,update]
        HTTPRoute[gateway.networking.k8s.io<br/>HTTPRoute<br/>get,list,watch]
    end

    subgraph "RBAC Permissions"
        RoleBinding[rbac.authorization.k8s.io<br/>RoleBinding<br/>create,delete,get,list,patch,update,watch]
        ClusterRoleBinding[rbac.authorization.k8s.io<br/>ClusterRoleBinding<br/>create,delete,get,list,patch,update,watch]
        Role[rbac.authorization.k8s.io<br/>Role<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Core Resource Permissions"
        ConfigMaps[core<br/>ConfigMap<br/>create,delete,get,list,patch,update,watch]
        Secrets[core<br/>Secret<br/>create,delete,get,list,patch,update,watch]
        ServiceAccounts[core<br/>ServiceAccount<br/>create,delete,get,list,patch,update,watch]
        Services[core<br/>Service<br/>create,delete,get,list,patch,update,watch]
        Pods[core<br/>Pod<br/>create,get,list,patch,update,watch]
        Endpoints[core<br/>Endpoint<br/>create,get,list,patch,update,watch]
        Namespaces[core<br/>Namespace<br/>create,get,list,patch,update,watch]
        Events[core<br/>Event<br/>create,patch]
    end

    subgraph "KEDA Permissions"
        TriggerAuth[keda.sh<br/>TriggerAuthentication<br/>create,delete,get,list,patch,update,watch]
    end

    subgraph "Kuadrant Permissions"
        AuthPolicy[kuadrant.io<br/>AuthPolicy<br/>create,delete,get,list,patch,update,watch<br/>status: get,patch,update]
        Kuadrant[kuadrant.io<br/>Kuadrant<br/>get,list,watch]
        Authorino[operator.authorino.kuadrant.io<br/>Authorino<br/>get,list,watch]
    end

    subgraph "ODH Permissions"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>get,list,watch]
        DSCInit[dscinitialization.opendatahub.io<br/>DSCInitialization<br/>get,list,watch]
    end

    subgraph "Metrics Permissions"
        MetricsNodes[metrics.k8s.io<br/>Node<br/>get,list,watch]
        MetricsPods[metrics.k8s.io<br/>Pod<br/>get,list,watch]
    end

    subgraph "Leader Election Permissions"
        LEConfigMap[core<br/>ConfigMap<br/>get,list,watch,create,update,patch,delete]
        LELease[coordination.k8s.io<br/>Lease<br/>get,list,watch,create,update,patch,delete]
        LEEvent[core<br/>Event<br/>create,patch]
    end

    subgraph "Proxy Permissions"
        TokenReview[authentication.k8s.io<br/>TokenReview<br/>create]
        SubjectAccessReview[authorization.k8s.io<br/>SubjectAccessReview<br/>create]
    end

    subgraph "Metrics Reader Permissions"
        ServiceProxy[core<br/>Service/proxy<br/>get]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% Main role permissions
    CR1 -->|manages| InferenceService
    CR1 -->|manages| InferenceGraph
    CR1 -->|manages| ServingRuntime
    CR1 -->|manages| LLMInferenceService
    CR1 -->|manages| NIMAccount
    CR1 -->|creates| Routes
    CR1 -->|creates| Templates
    CR1 -->|reads| Auth
    CR1 -->|creates| ServiceMonitor
    CR1 -->|creates| PodMonitor
    CR1 -->|creates| NetworkPolicy
    CR1 -->|creates| EnvoyFilter
    CR1 -->|manages| Gateway
    CR1 -->|reads| HTTPRoute
    CR1 -->|creates| RoleBinding
    CR1 -->|creates| ClusterRoleBinding
    CR1 -->|creates| Role
    CR1 -->|manages| ConfigMaps
    CR1 -->|manages| Secrets
    CR1 -->|manages| ServiceAccounts
    CR1 -->|manages| Services
    CR1 -->|manages| Pods
    CR1 -->|manages| Endpoints
    CR1 -->|manages| Namespaces
    CR1 -->|creates| Events
    CR1 -->|creates| TriggerAuth
    CR1 -->|creates| AuthPolicy
    CR1 -->|reads| Kuadrant
    CR1 -->|reads| Authorino
    CR1 -->|reads| DSC
    CR1 -->|reads| DSCInit
    CR1 -->|reads| MetricsNodes
    CR1 -->|reads| MetricsPods

    %% Leader election role permissions
    CR2 -->|manages| LEConfigMap
    CR2 -->|manages| LELease
    CR2 -->|creates| LEEvent

    %% Proxy role permissions
    CR3 -->|creates| TokenReview
    CR3 -->|creates| SubjectAccessReview

    %% Metrics reader permissions
    CR4 -->|reads| ServiceProxy

