    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceService fill:#7ed321,stroke:#333
    style InferenceGraph fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style LLMInferenceService fill:#7ed321,stroke:#333
    style NIMAccount fill:#7ed321,stroke:#333
    style Routes fill:#ee0000,stroke:#333
    style Templates fill:#ee0000,stroke:#333
