// C4 Context Diagram: kube-auth-proxy
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/kube-auth-proxy.md

workspace {
    model {
        user = person "User / Data Scientist" "Accesses RHOAI platform services via browser or API client"
        apiClient = person "API Client / Service" "Programmatic access to metrics or protected endpoints"

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "FIPS-compliant authentication and authorization proxy for RHOAI platform services" {
            entrypoint = container "Entrypoint Multiplexer" "Selects between auth and rbac mode based on PROXY_MODE env var" "Go Binary"
            authProxy = container "kube-auth-proxy (auth mode)" "OIDC and OpenShift OAuth authentication proxy; handles login flows, session management, token validation, upstream proxying" "Go Reverse Proxy" "Port 4180/TCP or 443/TCP"
            rbacProxy = container "kube-rbac-proxy (rbac mode)" "Kubernetes RBAC authorization proxy; performs SubjectAccessReview for authenticated requests" "Go Reverse Proxy" "Port configurable/HTTPS"
            oidcModule = container "OIDC Provider Module" "Handles authentication via standards-compliant OIDC providers" "Go Module"
            osOAuthModule = container "OpenShift OAuth Provider Module" "Handles authentication via OpenShift built-in OAuth with auto-discovery" "Go Module"
        }

        oidcProvider = softwareSystem "OIDC Provider" "External OpenID Connect identity provider" "External"
        oauthServer = softwareSystem "OpenShift OAuth Server" "OpenShift built-in OAuth2 authorization server" "External"
        openshiftApi = softwareSystem "OpenShift API Server" "OpenShift API for user info lookup (user.openshift.io)" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Kubernetes API for SubjectAccessReview and TokenReview" "External"
        envoyGateway = softwareSystem "Envoy Gateway" "RHOAI Gateway API ingress with ext_authz support" "Internal RHOAI"
        redis = softwareSystem "Redis" "Optional session storage backend" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        upstreamApps = softwareSystem "Upstream RHOAI Applications" "RHOAI platform services (dashboard, notebooks, etc.)" "Internal RHOAI"

        // User interactions
        user -> envoyGateway "Accesses RHOAI services via browser" "HTTPS/443"
        apiClient -> rbacProxy "Accesses metrics/protected endpoints" "HTTPS/TLS 1.2+"
        envoyGateway -> authProxy "Delegates auth decisions via ext_authz" "HTTP/4180"

        // Internal component interactions
        entrypoint -> authProxy "Routes to auth mode" "PROXY_MODE=auth"
        entrypoint -> rbacProxy "Routes to rbac mode (default)" "PROXY_MODE=rbac"
        authProxy -> oidcModule "Uses for OIDC authentication"
        authProxy -> osOAuthModule "Uses for OpenShift OAuth authentication"

        // Auth mode egress
        authProxy -> oidcProvider "OIDC discovery, token exchange, validation" "HTTPS/443"
        authProxy -> oauthServer "OAuth authorization, token exchange" "HTTPS/443"
        authProxy -> openshiftApi "User info lookup" "HTTPS/443"
        authProxy -> redis "Session storage (optional)" "TCP/6379"
        authProxy -> upstreamApps "Forwards authenticated requests" "HTTP/HTTPS"

        // RBAC mode egress
        rbacProxy -> k8sApi "SubjectAccessReview, TokenReview" "HTTPS/443"
        rbacProxy -> upstreamApps "Forwards authorized requests" "HTTP/HTTPS/h2c"

        // Observability
        prometheus -> authProxy "Scrapes metrics" "HTTP/HTTPS"
        prometheus -> rbacProxy "Scrapes metrics" "HTTP/HTTPS"
    }

    views {
        systemContext kubeAuthProxy "SystemContext" {
            include *
            autoLayout
        }

        container kubeAuthProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
