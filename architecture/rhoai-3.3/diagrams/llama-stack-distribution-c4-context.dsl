/*
 * Llama Stack Distribution - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/llama-stack-distribution.md
 */

workspace {
    model {
        user = person "Data Scientist / Developer" "Creates and runs AI applications using Llama Stack APIs"

        llamaStackDistribution = softwareSystem "Llama Stack Distribution" "Pre-built container providing unified REST API for inference, agents, evaluation, safety, and vector store capabilities" {
            server = container "Llama Stack Server" "REST API server exposing Llama Stack APIs on port 8321" "Python (FastAPI/Uvicorn)"
            config = container "config.yaml" "Distribution configuration defining APIs, providers, storage, and registered resources" "YAML Configuration"
            entrypoint = container "entrypoint.sh" "Container entrypoint supporting custom run configs" "Shell Script"

            entrypoint -> server "Starts"
            config -> server "Configures providers and APIs"
        }

        # Internal RHOAI Dependencies
        vllm = softwareSystem "vLLM Serving Runtime" "Remote inference backend for LLM serving" "Internal RHOAI"
        trustyaiFMS = softwareSystem "TrustyAI FMS Orchestrator" "Safety guardrails orchestration" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "Remote RAGAS evaluation pipeline execution" "Internal RHOAI"

        # Data Stores
        postgresql = softwareSystem "PostgreSQL" "Persistent state storage (KV store, SQL stores, agent state)" "Data Store"
        milvus = softwareSystem "Milvus" "Remote vector database for similarity search" "Data Store"
        pgvector = softwareSystem "pgvector" "PostgreSQL-based vector database" "Data Store"
        qdrant = softwareSystem "Qdrant" "Remote vector database (HTTP/gRPC)" "Data Store"

        # Cloud Inference Providers
        awsBedrock = softwareSystem "AWS Bedrock" "Cloud inference provider" "External Cloud"
        watsonx = softwareSystem "IBM WatsonX" "Cloud inference provider" "External Cloud"
        azureOpenAI = softwareSystem "Azure OpenAI" "Cloud inference provider" "External Cloud"
        vertexAI = softwareSystem "Google Vertex AI" "Cloud inference provider" "External Cloud"
        openai = softwareSystem "OpenAI" "Cloud inference provider" "External Cloud"

        # Tool Services
        braveSearch = softwareSystem "Brave Search API" "Web search tool" "External Cloud"
        tavilySearch = softwareSystem "Tavily Search API" "Web search tool" "External Cloud"

        # Other External
        huggingface = softwareSystem "HuggingFace Hub" "Dataset and model downloads" "External Cloud"
        s3 = softwareSystem "S3/S3-compatible Storage" "File storage" "External Cloud"

        # Platform
        platformIngress = softwareSystem "Platform Ingress" "OpenShift Route / Gateway API providing TLS and auth" "Platform"

        # Relationships
        user -> platformIngress "Sends API requests" "HTTPS/443"
        platformIngress -> llamaStackDistribution "Forwards requests (TLS terminated)" "HTTP/8321"

        llamaStackDistribution -> vllm "Inference requests" "HTTP/HTTPS, API Token"
        llamaStackDistribution -> trustyaiFMS "Safety checks" "HTTP/HTTPS"
        llamaStackDistribution -> kubeflowPipelines "Evaluation pipeline execution" "HTTP/HTTPS, Token"

        llamaStackDistribution -> postgresql "State persistence" "SQL/5432"
        llamaStackDistribution -> milvus "Vector similarity search" "HTTP/gRPC, Token"
        llamaStackDistribution -> pgvector "Vector similarity search" "SQL/5432"
        llamaStackDistribution -> qdrant "Vector similarity search" "HTTP/gRPC/6333-6334, API Key"

        llamaStackDistribution -> awsBedrock "Cloud inference" "HTTPS/443, Bearer Token"
        llamaStackDistribution -> watsonx "Cloud inference" "HTTPS/443, API Key"
        llamaStackDistribution -> azureOpenAI "Cloud inference" "HTTPS/443, API Key"
        llamaStackDistribution -> vertexAI "Cloud inference" "HTTPS/443, GCP Credentials"
        llamaStackDistribution -> openai "Cloud inference" "HTTPS/443, API Key"

        llamaStackDistribution -> braveSearch "Web search" "HTTPS/443, API Key"
        llamaStackDistribution -> tavilySearch "Web search" "HTTPS/443, API Key"
        llamaStackDistribution -> huggingface "Dataset/model downloads" "HTTPS/443"
        llamaStackDistribution -> s3 "File storage" "HTTPS/443, AWS Keys"
    }

    views {
        systemContext llamaStackDistribution "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackDistribution "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Data Store" {
                background #9b59b6
                color #ffffff
                shape Cylinder
            }
            element "External Cloud" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #d79b00
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
