graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / Administrator]
    end

    subgraph K8sAPI["KUBERNETES API SERVER"]
        APIServer["API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client certs, Bearer tokens<br/>RBAC"]
    end

    subgraph Cluster["CLUSTER (Trusted - Internal Network)"]
        direction TB

        subgraph Controller["odh-model-controller Pod<br/>Namespace: redhat-ods-applications<br/>SA: odh-model-controller<br/>UID: 2000 (non-root)"]
            direction TB
            ControllerMgr["Controller Manager<br/>- InferenceService Reconciler<br/>- InferenceGraph Reconciler<br/>- ServingRuntime Reconciler<br/>- LLM InferenceService Reconciler<br/>- NIM Account Reconciler<br/>- ConfigMap/Secret Controllers"]

            WebhookSvc["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ (mTLS)<br/>Cert: odh-model-controller-webhook-cert"]

            MetricsSvc["Metrics Server<br/>8080/TCP HTTP<br/>Auth: Bearer Token<br/>TODO: Migrate to HTTPS 8443"]

            HealthSvc["Health Check Server<br/>8081/TCP HTTP<br/>GET /healthz, /readyz<br/>Auth: None"]
        end

        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>ServiceMonitor scraping"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        NGC["NVIDIA NGC API<br/>nvcr.io/api<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key"]

        ModelRegistry["Model Registry API<br/>(Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph Resources["RESOURCES CREATED"]
        Routes["OpenShift Routes"]
        NetworkPolicies["NetworkPolicies"]
        ServiceMonitors["ServiceMonitors"]
        RBAC["RBAC Resources"]
        TriggerAuth["KEDA TriggerAuthentications"]
        AuthPolicies["Kuadrant AuthPolicies"]
        EnvoyFilters["Istio EnvoyFilters"]
        Templates["NIM Templates"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>User credentials| APIServer

    APIServer -->|HTTPS/9443<br/>mTLS<br/>K8s API client cert| WebhookSvc

    APIServer -->|Watch HTTPS<br/>ServiceAccount Token| ControllerMgr

    ControllerMgr -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create/Update Resources| APIServer

    ControllerMgr -->|HTTPS/443<br/>TLS 1.2+<br/>NGC API Key| NGC

    ControllerMgr -.->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Optional| ModelRegistry

    Prometheus -->|HTTP/8080<br/>Bearer Token<br/>kube-rbac-proxy| MetricsSvc

    ControllerMgr -->|Creates| Routes
    ControllerMgr -->|Creates| NetworkPolicies
    ControllerMgr -->|Creates| ServiceMonitors
    ControllerMgr -->|Creates| RBAC
    ControllerMgr -->|Creates| TriggerAuth
    ControllerMgr -->|Creates| AuthPolicies
    ControllerMgr -->|Creates| EnvoyFilters
    ControllerMgr -->|Creates| Templates

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef apiserver fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef resources fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class APIServer apiserver
    class ControllerMgr,WebhookSvc,MetricsSvc,HealthSvc,Prometheus cluster
    class NGC,ModelRegistry externalservice
    class Routes,NetworkPolicies,ServiceMonitors,RBAC,TriggerAuth,AuthPolicies,EnvoyFilters,Templates resources
