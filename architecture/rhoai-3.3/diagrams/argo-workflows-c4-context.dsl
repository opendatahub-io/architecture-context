/*
 * Argo Workflows - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/argo-workflows.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines via Data Science Pipelines"

        argoWorkflows = softwareSystem "Argo Workflows" "Container-native workflow engine for orchestrating parallel jobs on Kubernetes" {
            workflowController = container "workflow-controller" "Watches Workflow/CronWorkflow CRDs, creates and manages pods for each workflow step, handles leader election, artifact GC, and workflow archival" "Go Controller"
            argoexec = container "argoexec" "Injected into workflow pods as emissary executor; manages step container lifecycle, collects artifacts, reports task results" "Go Sidecar"
            argoServer = container "argo-server" "REST/gRPC API and Web UI for workflow management; supports SSO, Bearer token, and server auth modes (not directly shipped as RHOAI container)" "Go API Server"
        }

        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and configures Argo Workflows components for pipeline execution" "Internal RHOAI"
        dspAPIServer = softwareSystem "Data Science Pipelines API Server" "Submits Workflow CRs for pipeline runs" "Internal RHOAI"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Core platform for pod management and CRD operations" "External"
        s3Storage = softwareSystem "S3/MinIO" "Artifact repository for workflow artifacts" "External"
        database = softwareSystem "PostgreSQL/MySQL" "Workflow persistence and archival (optional)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for argo-server (optional)" "External"

        # Relationships - System Context
        datascientist -> dspAPIServer "Submits pipeline runs"
        dspOperator -> argoWorkflows "Deploys and configures"
        dspAPIServer -> argoWorkflows "Submits Workflow CRs" "HTTPS/443"
        argoWorkflows -> kubernetesAPI "CRD operations, pod lifecycle, leader election" "HTTPS/443"
        argoWorkflows -> s3Storage "Artifact upload/download" "HTTPS/443 or HTTP/9000"
        argoWorkflows -> database "Workflow archival" "TCP/5432 or 3306"
        prometheus -> argoWorkflows "Scrapes metrics" "HTTP/9090"
        argoWorkflows -> oidcProvider "SSO authentication" "HTTPS/443"

        # Relationships - Container Level
        dspAPIServer -> kubernetesAPI "Creates Workflow CRs" "HTTPS/443 TLS 1.2+"
        workflowController -> kubernetesAPI "Watches CRDs, creates Pods, leader election" "HTTPS/443 TLS 1.2+"
        workflowController -> database "Archives workflows" "TCP/5432 or 3306"
        argoexec -> kubernetesAPI "Patches WorkflowTaskResult" "HTTPS/443 TLS 1.2+"
        argoexec -> s3Storage "Uploads artifacts" "HTTPS/443 TLS 1.2+"
        argoServer -> kubernetesAPI "Manages workflows" "HTTPS/443 TLS 1.2+"
        argoServer -> oidcProvider "OIDC Discovery + Token" "HTTPS/443 TLS 1.2+"
        prometheus -> workflowController "Scrapes /metrics" "HTTP/9090 plaintext"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #333333
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
