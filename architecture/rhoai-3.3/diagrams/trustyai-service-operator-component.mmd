graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller<br/>Kubebuilder v4]
        Webhook[Conversion Webhook<br/>v1alpha1 → v1]
        Controller -->|manages| Webhook
    end

    subgraph "Managed Components"
        TrustyAIService[TrustyAI Service<br/>Deployment]
        LMEvalDriver[LM Evaluation Driver<br/>Job Controller]
        GuardrailsOrch[Guardrails Orchestrator<br/>Deployment]
        NemoGuardrails[Nemo Guardrails<br/>Deployment]
        RBACProxy[kube-rbac-proxy<br/>Sidecar]
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>v1/v1alpha1]
        LMEvalJobCR[LMEvalJob CR<br/>v1alpha1]
        GuardrailsOrchCR[GuardrailsOrchestrator CR<br/>v1alpha1]
        NemoGuardrailsCR[NemoGuardrails CR<br/>v1alpha1]
    end

    subgraph "Storage Backends"
        PVC[PersistentVolumeClaim]
        Database[(PostgreSQL/MySQL<br/>Database)]
    end

    User[User] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsOrchCR
    User -->|creates| NemoGuardrailsCR

    TrustyAIServiceCR -->|watched by| Controller
    LMEvalJobCR -->|watched by| Controller
    GuardrailsOrchCR -->|watched by| Controller
    NemoGuardrailsCR -->|watched by| Controller

    Controller -->|creates/manages| TrustyAIService
    Controller -->|creates/manages| LMEvalDriver
    Controller -->|creates/manages| GuardrailsOrch
    Controller -->|creates/manages| NemoGuardrails
    Controller -->|creates| PVC
    Controller -->|configures| RBACProxy

    TrustyAIService -->|stores data| PVC
    TrustyAIService -->|stores data| Database

    Controller -->|depends on| KServe[KServe InferenceService]
    Controller -->|depends on| Istio[Istio Service Mesh]
    Controller -->|integrates| Prometheus[Prometheus Operator]
    Controller -->|integrates| Kueue[Kueue Job Queueing]
    Controller -->|integrates| OpenShift[OpenShift Routes]

    TrustyAIService -->|monitors| KServe
    GuardrailsOrch -->|patches| KServe
    LMEvalDriver -->|queries| KServe

