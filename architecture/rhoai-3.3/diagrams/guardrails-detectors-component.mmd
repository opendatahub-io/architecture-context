graph TB
    subgraph "Guardrails Detectors"
        subgraph "Built-in Detector (port 8080)"
            BuiltInApp["DetectorBaseAPI<br/>(FastAPI)"]
            RegexRegistry["RegexDetectorRegistry<br/>(email, CC, SSN, phone, IP, UK post)"]
            FileTypeRegistry["FileTypeDetectorRegistry<br/>(JSON, XML, YAML + schema)"]
            CustomRegistry["CustomDetectorRegistry<br/>(dynamic Python loader)"]
            BuiltInApp --> RegexRegistry
            BuiltInApp --> FileTypeRegistry
            BuiltInApp --> CustomRegistry
        end

        subgraph "HuggingFace Detector (port 8000)"
            HFApp["DetectorBaseAPI<br/>(FastAPI)"]
            HFDetector["HuggingFace Detector<br/>(AutoModelForSequenceClassification<br/>GraniteForCausalLM)"]
            HFApp --> HFDetector
        end

        subgraph "LLM Judge Detector (port 8000)"
            JudgeApp["DetectorBaseAPI<br/>(FastAPI)"]
            JudgeDetector["LLM Judge Detector<br/>(vllm_judge library)"]
            JudgeApp --> JudgeDetector
        end

        subgraph "Common"
            InstrumentedDetector["InstrumentedDetector<br/>(Prometheus counters)"]
            BaseDetectorRegistry["BaseDetectorRegistry<br/>(abstract)"]
        end

        RegexRegistry -.->|extends| BaseDetectorRegistry
        FileTypeRegistry -.->|extends| BaseDetectorRegistry
        CustomRegistry -.->|extends| BaseDetectorRegistry
        HFDetector -.->|extends| InstrumentedDetector
        JudgeDetector -.->|extends| InstrumentedDetector
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP mTLS| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP mTLS| JudgeApp

    JudgeDetector -->|OpenAI-compatible API<br/>HTTP| vLLM["External vLLM Server"]

    HFDetector -->|Model weights<br/>S3 API| S3["S3/MinIO Storage"]

    KServe["KServe"] -.->|manages deployment| HFApp
    KServe -.->|manages deployment| JudgeApp
    Istio["Istio Service Mesh"] -.->|mTLS sidecar| HFApp
    Istio -.->|mTLS sidecar| JudgeApp

    Prometheus["Prometheus"] -->|scrape /metrics| BuiltInApp
    Prometheus -->|scrape /metrics| HFApp
    Prometheus -->|scrape /metrics| JudgeApp

    style BuiltInApp fill:#4a90e2,color:#fff
    style HFApp fill:#4a90e2,color:#fff
    style JudgeApp fill:#4a90e2,color:#fff
