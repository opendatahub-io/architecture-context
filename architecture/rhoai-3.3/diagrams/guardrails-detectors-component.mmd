    style BaseDetectorRegistry fill:#6c5ce7,color:#fff
    style RegexRegistry fill:#74b9ff
    style FileTypeRegistry fill:#74b9ff
    style CustomRegistry fill:#74b9ff
    style HFDetector fill:#74b9ff
    style JudgeDetector fill:#74b9ff
    style Orchestrator fill:#7ed321,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style vLLM fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
