graph TB
    subgraph "Red Hat OpenShift AI 3.3 Platform"
        subgraph "Control Plane - redhat-ods-operator"
            RHODSOp[RHODS Operator<br/>v1.6.0-5550<br/>Central control plane]
            KServeOp[KServe Operator<br/>v0.15]
            ModelCtrl[odh-model-controller<br/>v1.27.0-1157]
            DSPOp[Data Science Pipelines Operator<br/>v0.0.1]
            ModelRegOp[Model Registry Operator<br/>4fdd8de]
            NBCtrl[ODH Notebook Controller<br/>v1.27.0-1417]
            TrainingOp[Training Operator<br/>v1.9.0]
            TrainerOp[Kubeflow Trainer<br/>v2.1.0]
            RayOp[KubeRay Operator<br/>v1.4.2]
            FeastOp[Feast Operator<br/>98a224e7c]
            MLflowOp[MLflow Operator<br/>49b5d8d]
            LlamaOp[Llama Stack Operator<br/>v0.6.0]
            TrustyOp[TrustyAI Operator<br/>v1.39.0]
        end

        subgraph "Platform Services - redhat-ods-applications"
            Dashboard[ODH Dashboard<br/>v1.21.0-18<br/>React UI]
            MLflowSvc[MLflow Instances<br/>Experiment tracking]
            LlamaSvc[Llama Stack Distributions<br/>LLM serving]
        end

        subgraph "User Workloads - User Namespaces"
            Notebooks[Jupyter/RStudio/CodeServer<br/>v20xx.2-1184<br/>ML Workbenches]
            InferenceSvc[InferenceServices<br/>Model serving pods]
            TrainJobs[Training Jobs<br/>PyTorch/TF/XGBoost/JAX]
            Pipelines[Pipeline Runs<br/>Argo Workflows]
            ModelReg[Model Registries<br/>Metadata storage]
            FeatureStore[Feast Feature Stores<br/>Online/Offline serving]
            RayClusters[Ray Clusters<br/>Distributed computing]
            TrustyAI[TrustyAI Services<br/>Explainability/Monitoring]
        end

        subgraph "External Dependencies"
            Istio[Istio Service Mesh<br/>VirtualServices, mTLS]
            Knative[Knative Serving<br/>Autoscaling]
            CertMgr[cert-manager<br/>TLS certificates]
            GatewayAPI[Gateway API<br/>HTTPRoutes]
            OAuth[OpenShift OAuth<br/>Authentication]
            S3[S3 Storage<br/>Model/artifact storage]
            PostgreSQL[PostgreSQL<br/>Metadata persistence]
            Redis[Redis<br/>Feature caching]
        end
    end

    %% Control plane relationships
    RHODSOp -->|deploys| Dashboard
    RHODSOp -->|deploys| KServeOp
    RHODSOp -->|deploys| ModelCtrl
    RHODSOp -->|deploys| DSPOp
    RHODSOp -->|deploys| ModelRegOp
    RHODSOp -->|deploys| NBCtrl
    RHODSOp -->|deploys| TrainingOp
    RHODSOp -->|deploys| TrainerOp
    RHODSOp -->|deploys| RayOp
    RHODSOp -->|deploys| FeastOp
    RHODSOp -->|deploys| MLflowOp
    RHODSOp -->|deploys| LlamaOp
    RHODSOp -->|deploys| TrustyOp

    %% Dashboard creates user resources
    Dashboard -->|creates| Notebooks
    Dashboard -->|creates| InferenceSvc
    Dashboard -->|creates| ModelReg
    Dashboard -->|creates| FeatureStore
    Dashboard -->|creates| MLflowSvc

    %% Operator manages workloads
    KServeOp -->|reconciles| InferenceSvc
    ModelCtrl -->|extends| InferenceSvc
    DSPOp -->|manages| Pipelines
    ModelRegOp -->|manages| ModelReg
    NBCtrl -->|manages| Notebooks
    TrainingOp -->|manages| TrainJobs
    TrainerOp -->|manages| TrainJobs
    RayOp -->|manages| RayClusters
    FeastOp -->|manages| FeatureStore
    MLflowOp -->|manages| MLflowSvc
    LlamaOp -->|manages| LlamaSvc
    TrustyOp -->|manages| TrustyAI

    %% Workload integrations
    Notebooks -->|submits| Pipelines
    Notebooks -->|creates| InferenceSvc
    Pipelines -->|deploys| InferenceSvc
    Pipelines -->|registers| ModelReg
    InferenceSvc -->|queries| FeatureStore
    TrainJobs -->|uses| FeatureStore
    TrustyOp -->|patches| InferenceSvc

    %% External dependencies
    KServeOp -->|uses| Istio
    KServeOp -->|uses| Knative
    KServeOp -->|uses| CertMgr
    ModelCtrl -->|creates| GatewayAPI
    NBCtrl -->|creates| GatewayAPI
    MLflowOp -->|creates| GatewayAPI
    Dashboard -->|authenticates via| OAuth
    Notebooks -->|authenticates via| OAuth
    InferenceSvc -->|downloads from| S3
    Pipelines -->|stores to| S3
    TrainJobs -->|stores to| S3
    ModelReg -->|persists to| PostgreSQL
    MLflowSvc -->|persists to| PostgreSQL
    FeatureStore -->|persists to| PostgreSQL
    FeatureStore -->|caches in| Redis
    TrustyAI -->|persists to| PostgreSQL

