graph TD
    subgraph "Service Accounts"
        SA_User["user-one<br/>(example SA)"]
    end

    subgraph "Role Bindings"
        RB["user-one-view<br/>(RoleBinding)<br/>Namespace: model-namespace"]
    end

    subgraph "Cluster Roles"
        CR_View["ClusterRole/view<br/>(Kubernetes built-in)"]
    end

    subgraph "KServe-Managed Auth"
        KServeAuth["KServe Auth Proxy<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
        IstioMTLS["Istio mTLS<br/>sidecar.istio.io/<br/>inject: 'true'<br/>Mode: ISTIO_MUTUAL"]
    end

    subgraph "Protected Endpoints"
        APIContents["/api/v1/text/contents<br/>POST<br/>Auth: Istio mTLS + KServe"]
        APIGeneration["/api/v1/text/generation<br/>POST<br/>Auth: Istio mTLS + KServe"]
    end

    subgraph "Unprotected Endpoints"
        Health["/health<br/>GET<br/>Auth: None"]
        Metrics["/metrics<br/>GET<br/>Auth: None"]
    end

    subgraph "Secrets"
        S3Secret["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>Type: Opaque (S3 connection)<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY<br/>Provisioned: Manual/ODH Dashboard<br/>Auto-Rotate: No"]
    end

    subgraph "Security Controls (Custom Detectors)"
        StaticAnalysis["Static Code Analysis<br/>CustomDetectorRegistry"]
        ForbiddenImports["Forbidden Imports:<br/>os, subprocess, sys, shutil"]
        ForbiddenCalls["Forbidden Calls:<br/>eval, exec, open, compile, input"]
        StaticAnalysis --> ForbiddenImports
        StaticAnalysis --> ForbiddenCalls
    end

    SA_User -->|"bound via"| RB
    RB -->|"grants"| CR_View

    KServeAuth -->|"enforces auth on"| APIContents
    KServeAuth -->|"enforces auth on"| APIGeneration
    IstioMTLS -->|"encrypts traffic to"| APIContents
    IstioMTLS -->|"encrypts traffic to"| APIGeneration

    style SA_User fill:#4a90e2,color:#fff
    style CR_View fill:#f5a623
    style RB fill:#74b9ff
    style KServeAuth fill:#e17055,color:#fff
    style IstioMTLS fill:#e17055,color:#fff
    style APIContents fill:#7ed321
    style APIGeneration fill:#7ed321
    style Health fill:#dfe6e9
    style Metrics fill:#dfe6e9
    style S3Secret fill:#fdcb6e
    style StaticAnalysis fill:#a29bfe,color:#fff
    style ForbiddenImports fill:#fd79a8,color:#fff
    style ForbiddenCalls fill:#fd79a8,color:#fff
