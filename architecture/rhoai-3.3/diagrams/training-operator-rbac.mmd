graph TD
    subgraph "Service Account"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[training-operator<br/>ClusterRoleBinding]
        RB1[training-operator-webhook<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "Roles"
        CR[training-operator<br/>ClusterRole]
        R[training-operator-webhook<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph "Core API Resources"
        ConfigMaps[core/configmaps]
        Events[core/events]
        Pods[core/pods]
        PodsExec[core/pods/exec]
        ServiceAccounts[core/serviceaccounts]
        Services[core/services]
        Secrets[core/secrets<br/>Namespace-scoped ONLY]
    end

    subgraph "Admission API Resources"
        ValidatingWebhooks[admissionregistration.k8s.io<br/>validatingwebhookconfigurations]
    end

    subgraph "Autoscaling API Resources"
        HPA[autoscaling<br/>horizontalpodautoscalers]
    end

    subgraph "Kubeflow CRDs"
        PyTorchJobs[kubeflow.org/pytorchjobs<br/>+ status, finalizers]
        TFJobs[kubeflow.org/tfjobs<br/>+ status, finalizers]
        XGBoostJobs[kubeflow.org/xgboostjobs<br/>+ status, finalizers]
        MPIJobs[kubeflow.org/mpijobs<br/>+ status, finalizers]
        JAXJobs[kubeflow.org/jaxjobs<br/>+ status, finalizers]
        PaddleJobs[kubeflow.org/paddlejobs<br/>+ status, finalizers]
    end

    subgraph "RBAC API Resources"
        Roles[rbac.authorization.k8s.io<br/>roles]
        RoleBindings[rbac.authorization.k8s.io<br/>rolebindings]
    end

    subgraph "Gang Scheduling Resources"
        VolcanoPodGroups[scheduling.volcano.sh<br/>podgroups]
        SchedulerPluginsPodGroups[scheduling.x-k8s.io<br/>podgroups]
    end

    subgraph "Networking Resources"
        NetworkPolicies[networking.k8s.io<br/>networkpolicies]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR
    RB1 -->|grants| R

    %% ClusterRole Permissions
    CR -->|create, list, update, watch| ConfigMaps
    CR -->|create, delete, get, list, patch, update, watch| Events
    CR -->|create, delete, get, list, patch, update, watch| Pods
    CR -->|create| PodsExec
    CR -->|create, get, list, watch| ServiceAccounts
    CR -->|create, delete, get, list, watch| Services
    CR -->|get, list, update, watch| ValidatingWebhooks
    CR -->|create, delete, get, list, patch, update, watch| HPA
    CR -->|create, delete, get, list, patch, update, watch| PyTorchJobs
    CR -->|create, delete, get, list, patch, update, watch| TFJobs
    CR -->|create, delete, get, list, patch, update, watch| XGBoostJobs
    CR -->|create, delete, get, list, patch, update, watch| MPIJobs
    CR -->|create, delete, get, list, patch, update, watch| JAXJobs
    CR -->|create, delete, get, list, patch, update, watch| PaddleJobs
    CR -->|create, list, update, watch| Roles
    CR -->|create, list, update, watch| RoleBindings
    CR -->|create, delete, get, list, patch, update, watch| VolcanoPodGroups
    CR -->|create, delete, get, list, patch, update, watch| SchedulerPluginsPodGroups
    CR -->|create, delete, get, list, patch, update, watch| NetworkPolicies

    %% Role Permissions (Namespace-scoped for secrets)
    R -->|get, list, watch| Secrets

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style R fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#7ed321,stroke:#333
    style RB1 fill:#7ed321,stroke:#333

    style ConfigMaps fill:#dae8fc,stroke:#333
    style Events fill:#dae8fc,stroke:#333
    style Pods fill:#dae8fc,stroke:#333
    style PodsExec fill:#dae8fc,stroke:#333
    style ServiceAccounts fill:#dae8fc,stroke:#333
    style Services fill:#dae8fc,stroke:#333
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px

    style ValidatingWebhooks fill:#fff2cc,stroke:#d6b656
    style HPA fill:#fff2cc,stroke:#d6b656

    style PyTorchJobs fill:#e1d5e7,stroke:#9673a6
    style TFJobs fill:#e1d5e7,stroke:#9673a6
    style XGBoostJobs fill:#e1d5e7,stroke:#9673a6
    style MPIJobs fill:#e1d5e7,stroke:#9673a6
    style JAXJobs fill:#e1d5e7,stroke:#9673a6
    style PaddleJobs fill:#e1d5e7,stroke:#9673a6

    style Roles fill:#d5e8d4,stroke:#82b366
    style RoleBindings fill:#d5e8d4,stroke:#82b366

    style VolcanoPodGroups fill:#ffe6cc,stroke:#d79b00
    style SchedulerPluginsPodGroups fill:#ffe6cc,stroke:#d79b00

    style NetworkPolicies fill:#f9f9f9,stroke:#666
