graph TB
    subgraph "odh-model-controller Component"
        Controller[Controller Manager]

        subgraph "Reconcilers"
            ISController[InferenceService Controller]
            IGController[InferenceGraph Controller]
            SRController[ServingRuntime Controller]
            LLMController[LLM InferenceService Controller]
            NIMController[NIM Account Controller]
            CMController[ConfigMap Controller]
            SecretController[Secret Controller]
            PodController[Pod Controller]
        end

        subgraph "Servers"
            Webhook[Webhook Server<br/>9443/TCP HTTPS]
            Metrics[Metrics Server<br/>8080/TCP HTTP]
            Health[Health Check Server<br/>8081/TCP HTTP]
        end

        Controller --> ISController
        Controller --> IGController
        Controller --> SRController
        Controller --> LLMController
        Controller --> NIMController
        Controller --> CMController
        Controller --> SecretController
        Controller --> PodController
    end

    subgraph "Custom Resources Managed"
        NIMAccount[NIM Account<br/>nim.opendatahub.io/v1]
    end

    subgraph "KServe CRDs Watched"
        InferenceService[InferenceService<br/>serving.kserve.io/v1beta1]
        InferenceGraph[InferenceGraph<br/>serving.kserve.io/v1alpha1]
        ServingRuntime[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        LLMInferenceService[LLMInferenceService<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Resources Created"
        Route[OpenShift Routes]
        NetworkPolicy[NetworkPolicies]
        ServiceMonitor[ServiceMonitors]
        RBAC[RBAC Resources]
        TriggerAuth[KEDA TriggerAuthentications]
        AuthPolicy[Kuadrant AuthPolicies]
        EnvoyFilter[Istio EnvoyFilters]
        Template[NIM Templates]
    end

    subgraph "External Dependencies"
        KServe[KServe v0.15.1]
        Prometheus[Prometheus Operator]
        KEDA[KEDA v2.x]
        Istio[Istio]
        Kuadrant[Kuadrant]
        NGC[NVIDIA NGC API]
    end

    User[User] -->|creates| InferenceService
    User -->|creates| NIMAccount

    InferenceService -->|watched by| ISController
    InferenceGraph -->|watched by| IGController
    ServingRuntime -->|watched by| SRController
    LLMInferenceService -->|watched by| LLMController
    NIMAccount -->|watched by| NIMController

    ISController -->|creates| Route
    ISController -->|creates| NetworkPolicy
    ISController -->|creates| ServiceMonitor
    ISController -->|creates| RBAC
    ISController -->|creates| TriggerAuth
    ISController -->|creates| AuthPolicy
    ISController -->|creates| EnvoyFilter

    NIMController -->|validates via| NGC
    NIMController -->|creates| Template

    Webhook -->|validates/mutates| InferenceService
    Webhook -->|validates/mutates| InferenceGraph
    Webhook -->|validates| NIMAccount

    Controller -->|depends on| KServe
    ISController -->|integrates| Prometheus
    ISController -->|integrates| KEDA
    ISController -->|integrates| Istio
    ISController -->|integrates| Kuadrant

