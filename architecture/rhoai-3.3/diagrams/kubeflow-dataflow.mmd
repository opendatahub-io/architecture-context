%% Kubeflow Notebook Controller - Data Flow Diagram
%% Generated by: Claude Opus 4.6

sequenceDiagram
    participant User as User / ODH Dashboard
    participant K8sAPI as Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+
    participant Controller as NotebookReconciler<br/>(kf-notebook-controller)
    participant Culler as CullingReconciler
    participant NB as Notebook Pod<br/>(StatefulSet)
    participant Prometheus as Prometheus

    rect rgb(230, 245, 255)
        Note over User,NB: Flow 1: Notebook Creation
        User->>K8sAPI: Create Notebook CR<br/>Auth: Bearer Token
        K8sAPI-->>Controller: Watch event (Notebook created)
        Controller->>K8sAPI: Create StatefulSet (1 replica)<br/>Auth: ServiceAccount Token
        Controller->>K8sAPI: Create ClusterIP Service<br/>:80 -> :8888<br/>Auth: ServiceAccount Token
        K8sAPI-->>Controller: Resources created
        Note over Controller: Emits events onto Notebook CR<br/>Increments notebook_create_total
    end

    rect rgb(255, 245, 230)
        Note over Culler,NB: Flow 2: Idle Notebook Culling
        loop Every IDLENESS_CHECK_PERIOD
            Culler->>NB: GET /api/kernels<br/>80/TCP HTTP No Auth
            NB-->>Culler: Kernel list (active/idle)
            Culler->>NB: GET /api/terminals<br/>80/TCP HTTP No Auth
            NB-->>Culler: Terminal list (active/idle)
            alt Idle > CULL_IDLE_TIME (default 1440 min)
                Culler->>K8sAPI: Set stop annotation on Notebook CR<br/>Auth: ServiceAccount Token
                Note over Culler: Increments notebook_culling_total<br/>Updates last_notebook_culling_timestamp_seconds
                K8sAPI-->>Controller: Watch event (annotation changed)
                Controller->>K8sAPI: Scale StatefulSet replicas to 0<br/>Auth: ServiceAccount Token
            end
        end
    end

    rect rgb(230, 255, 230)
        Note over Prometheus,Controller: Flow 3: Metrics Collection
        Prometheus->>Controller: GET /metrics<br/>8080/TCP HTTP No Auth
        Controller-->>Prometheus: notebook_running, notebook_create_total,<br/>notebook_create_failed_total,<br/>notebook_culling_total
    end
