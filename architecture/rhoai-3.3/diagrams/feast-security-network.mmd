%% Feast Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist /<br/>ML Application"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>feast-{name}-ui<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph Cluster["CLUSTER INTERNAL (ClusterIP Services)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["Feast Operator Controller Manager<br/>SA: feast-operator-controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS (TokenReview+SAR)"]
        end

        subgraph FeatureStoreNS["Namespace: {featurestore-namespace}"]
            Online["Online Store<br/>SA: feast-{name}<br/>80/443 → 6566/6567<br/>HTTP/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            Offline["Offline Store<br/>SA: feast-{name}<br/>80/443 → 8815/8816<br/>Arrow Flight HTTP/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            RegistryGRPC["Registry (gRPC)<br/>SA: feast-{name}<br/>80/443 → 6570/6571<br/>gRPC<br/>Auth: K8s RBAC / OIDC"]
            RegistryREST["Registry (REST)<br/>SA: feast-{name}<br/>80/443 → 6572/6573<br/>HTTP/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            UIService["UI Server<br/>80/443 → 8888/8443<br/>HTTP/HTTPS<br/>Auth: None"]
            Cron["CronJob<br/>SA: feast-{name}<br/>kubectl exec"]
        end
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        CertSigner["OpenShift Service<br/>Serving Cert Signer"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DB["Snowflake / Cassandra / SQL<br/>Varies<br/>Secret-based credentials"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Env credentials"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Reencrypt<br/>UI access"| Route
    Route -->|"HTTPS/8443<br/>Service serving certs"| UIService
    Client -->|"HTTP or HTTPS<br/>80/443<br/>K8s RBAC / OIDC"| Online
    Client -->|"HTTP or HTTPS<br/>80/443<br/>K8s RBAC / OIDC"| Offline

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"manages"| Online
    Operator -->|"manages"| Offline
    Operator -->|"manages"| RegistryGRPC
    Operator -->|"manages"| RegistryREST
    Operator -->|"manages"| UIService
    Operator -->|"manages"| Cron

    %% CronJob flows
    Cron -->|"HTTPS/443<br/>kubectl exec<br/>SA Token"| K8sAPI

    %% TLS provisioning
    CertSigner -.->|"auto-provisions<br/>TLS certs"| Online
    CertSigner -.->|"auto-provisions<br/>TLS certs"| Offline
    CertSigner -.->|"auto-provisions<br/>TLS certs"| RegistryGRPC
    CertSigner -.->|"auto-provisions<br/>TLS certs"| UIService

    %% Egress
    Online -->|"Varies<br/>Secret credentials"| DB
    Offline -->|"Varies<br/>Secret credentials"| DB

