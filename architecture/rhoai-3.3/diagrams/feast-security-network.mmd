graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[ML Application /<br/>Training Job /<br/>feast CLI]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - DMZ)"]
        RouteOnline["Route: {name}-online<br/>443/TCP → 80/443<br/>TLS Edge Termination"]
        RouteOffline["Route: {name}-offline<br/>443/TCP → 80/443<br/>TLS Edge Termination"]
        RouteRegistry["Route: {name}-registry<br/>443/TCP → 80/443<br/>TLS Edge Termination"]
        RouteUI["Route: {name}-ui<br/>443/TCP → 80/443<br/>TLS Edge Termination"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Namespace: user-namespace)"]
        direction TB

        subgraph FeatureServers["Feature Store Services"]
            OnlineFS["Online Feature Server<br/>SA: {name}-online<br/>6566/TCP HTTP, 6567/TCP HTTPS<br/>8000/TCP metrics<br/>Auth: Bearer/mTLS/RBAC"]
            OfflineFS["Offline Feature Server<br/>SA: {name}-offline<br/>8815/TCP HTTP, 8816/TCP HTTPS<br/>8000/TCP metrics<br/>Auth: Bearer/mTLS/RBAC"]
            RegistryFS["Registry Server<br/>SA: {name}-registry<br/>6570/TCP gRPC, 6571/TCP gRPC TLS<br/>6572/TCP REST, 6573/TCP REST TLS<br/>Auth: Bearer/mTLS/RBAC"]
            UIFS["UI Server<br/>SA: {name}-ui<br/>8888/TCP HTTP, 8443/TCP HTTPS"]
        end

        CronJob["Materialization CronJob<br/>SA: {name}-materialize<br/>origin-cli:4.17"]

        ClientCM[Client ConfigMap<br/>feature_store.yaml]
    end

    subgraph Persistence["PERSISTENCE LAYER"]
        SQLite[(SQLite<br/>PVC/Local<br/>At-rest encryption)]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+<br/>Password Auth<br/>Secret: {name}-db-secret"]
        Redis["Redis<br/>6379/TCP<br/>TLS 1.2+<br/>Password Auth<br/>Secret: {name}-redis-secret"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Access Key<br/>Secret: {name}-s3-secret"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token Validation<br/>Secret: {name}-oidc"]
        Git["Git Repository<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token Auth<br/>Secret: {name}-git-token"]
    end

    subgraph OperatorNS["FEAST OPERATOR (Namespace: feast-operator-system)"]
        Operator["Feast Operator<br/>SA: controller-manager<br/>8443/TCP metrics HTTPS<br/>8081/TCP health HTTP"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>SA Token Auth"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraping<br/>8000/TCP HTTP<br/>8443/TCP HTTPS"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS Edge<br/>Bearer/mTLS| RouteOnline
    Client -->|HTTPS/443<br/>TLS Edge<br/>Bearer/mTLS| RouteOffline
    Client -->|HTTPS/443<br/>TLS Edge<br/>Bearer/mTLS| RouteRegistry
    Client -->|HTTPS/443<br/>TLS Edge| RouteUI

    %% Ingress to Services
    RouteOnline -->|HTTP/80 or HTTPS/443<br/>Bearer/mTLS/None| OnlineFS
    RouteOffline -->|HTTP/80 or HTTPS/443<br/>Bearer/mTLS/None| OfflineFS
    RouteRegistry -->|HTTP/80 or HTTPS/443<br/>Bearer/mTLS/None| RegistryFS
    RouteUI -->|HTTP/80 or HTTPS/443| UIFS

    %% Internal Service Communication
    OnlineFS -->|gRPC/6570 or 6571<br/>TLS 1.2+ opt<br/>Bearer/mTLS/None| RegistryFS
    OfflineFS -->|gRPC/6570 or 6571<br/>TLS 1.2+ opt<br/>Bearer/mTLS/None| RegistryFS
    UIFS -->|REST/6572 or 6573<br/>TLS 1.2+ opt| RegistryFS
    CronJob -->|HTTP/6566 or HTTPS/6567<br/>Trigger Materialize| OnlineFS
    OnlineFS -->|HTTP/8815 or HTTPS/8816<br/>Fetch Features| OfflineFS

    %% Persistence
    OnlineFS -->|Local/Redis/PostgreSQL<br/>6379 or 5432| SQLite
    OnlineFS -->|PostgreSQL/5432<br/>TLS 1.2+<br/>Password| PostgreSQL
    OnlineFS -->|Redis/6379<br/>TLS 1.2+<br/>Password| Redis
    RegistryFS -->|Local/PostgreSQL/S3| SQLite
    RegistryFS -->|PostgreSQL/5432<br/>TLS 1.2+| PostgreSQL
    RegistryFS -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    OfflineFS -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    RegistryFS -->|HTTPS/443<br/>TLS 1.2+<br/>Token| Git

    %% Authentication
    OnlineFS -.->|Validate JWT<br/>HTTPS/443| OIDC
    OfflineFS -.->|Validate JWT<br/>HTTPS/443| OIDC
    RegistryFS -.->|Validate JWT<br/>HTTPS/443| OIDC

    %% Operator
    Operator -->|Watch FeatureStore CRs<br/>HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
    Operator -->|Create/Manage<br/>Deployments, Services<br/>Routes, CronJobs| FeatureServers
    Operator -->|Create| ClientCM
    Operator -->|Create| CronJob

    %% Monitoring
    OnlineFS -->|Export Metrics<br/>HTTP/8000| Prometheus
    OfflineFS -->|Export Metrics<br/>HTTP/8000| Prometheus
    Operator -->|Export Metrics<br/>HTTPS/8443<br/>Token Review| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8s fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef persistence fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class RouteOnline,RouteOffline,RouteRegistry,RouteUI ingress
    class OnlineFS,OfflineFS,RegistryFS,UIFS,CronJob,ClientCM k8s
    class SQLite persistence
    class PostgreSQL,Redis,S3,OIDC,Git externalservice
    class Operator,K8sAPI operator
    class Prometheus monitoring
