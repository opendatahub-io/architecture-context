/*
 * MLflow C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/mlflow.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist / ML Engineer" "Creates and tracks ML experiments, registers models, views traces"
        admin = person "Platform Admin" "Configures MLflow deployment and RBAC policies"

        mlflow = softwareSystem "MLflow" "AI/ML lifecycle platform providing experiment tracking, model registry, LLM observability/tracing, and evaluation" {
            trackingServer = container "MLflow Tracking Server" "Serves REST/GraphQL APIs for experiment tracking, model registry, artifact management, and tracing" "Python (Flask + FastAPI) / gunicorn + uvicorn"
            webUI = container "MLflow Web UI" "Browser-based UI for experiment visualization, model browsing, and trace inspection" "React SPA"
            k8sWorkspaceProvider = container "Kubernetes Workspace Provider" "Maps MLflow workspaces 1:1 to Kubernetes namespaces via background namespace watch loop" "Python Plugin"
            k8sAuthPlugin = container "Kubernetes Auth Plugin" "Enforces Kubernetes RBAC for every MLflow API request using SelfSubjectAccessReview/SubjectAccessReview" "Python Middleware"
            sqlalchemyStore = container "SQLAlchemy Store" "Persistence layer for experiment metadata, runs, model registry, and jobs" "Python / SQLAlchemy"
            artifactStore = container "Artifact Store" "Pluggable artifact storage for experiment artifacts and model files" "Python Module"
            otelEndpoint = container "OpenTelemetry Endpoint" "OTLP/HTTP trace ingestion endpoint for LLM observability" "FastAPI Router"
            prometheusExporter = container "Prometheus Exporter" "Metrics endpoint for monitoring" "Python Module"
        }

        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Authentication sidecar proxy that validates K8s SA tokens and injects identity headers" "Sidecar"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for namespace management and RBAC evaluation" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for metadata persistence" "External"
        s3Storage = softwareSystem "S3-compatible Object Storage" "Object storage for ML artifacts and model files" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Collects and forwards trace data" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages platform gateway and external exposure via Gateway API" "Internal RHOAI"

        # User interactions
        dataScientist -> kubeRBACProxy "Submits experiments, logs artifacts, registers models" "HTTPS/8443, Bearer Token (K8s SA)"
        dataScientist -> webUI "Views experiments, models, traces" "HTTPS/443"
        admin -> k8sAPI "Configures RBAC policies for mlflow.kubeflow.org resources" "kubectl"

        # Proxy to MLflow
        kubeRBACProxy -> trackingServer "Forwards authenticated requests" "HTTP/5000, x-remote-user headers"

        # Internal container relationships
        webUI -> trackingServer "AJAX API calls" "HTTP/5000"
        trackingServer -> k8sAuthPlugin "Delegates authorization checks"
        trackingServer -> k8sWorkspaceProvider "Resolves workspace from header"
        trackingServer -> sqlalchemyStore "Reads/writes metadata"
        trackingServer -> artifactStore "Reads/writes artifacts"
        trackingServer -> otelEndpoint "Routes OTLP trace data"
        trackingServer -> prometheusExporter "Exposes metrics"

        # External dependencies
        k8sAuthPlugin -> k8sAPI "SelfSubjectAccessReview / SubjectAccessReview" "HTTPS/443, SA Token"
        k8sWorkspaceProvider -> k8sAPI "Namespace list/watch" "HTTPS/443, SA Token"
        sqlalchemyStore -> postgresql "SQL queries" "PostgreSQL/5432, TLS, Username/Password"
        artifactStore -> s3Storage "PUT/GET artifacts" "HTTPS/443, AWS IAM / Access Key"

        # Monitoring
        prometheus -> trackingServer "Scrapes /metrics" "HTTP/5000"
        otelCollector -> otelEndpoint "Sends OTLP traces" "HTTP/5000, OTLP/HTTP"

        # Platform
        rhoaiOperator -> mlflow "Manages external exposure" "HTTPRoute (Gateway API)"
    }

    views {
        systemContext mlflow "SystemContext" "MLflow system context showing external actors and dependencies" {
            include *
            autoLayout
        }

        container mlflow "Containers" "MLflow internal container architecture" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #85bbf0
                color #000000
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Sidecar" {
                background #d5a6bd
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
