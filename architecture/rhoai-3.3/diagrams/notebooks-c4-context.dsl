/*
 * C4 Context Diagram - Notebooks (Workbench Images)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/notebooks.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Develops ML models using interactive workbench environments"
        mlEngineer = person "ML Engineer" "Builds and deploys ML pipelines using Elyra runtimes"
        admin = person "Platform Admin" "Manages RHOAI platform and workbench image lifecycle"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images providing interactive development environments (JupyterLab, Code Server, RStudio) and Elyra pipeline runtimes for RHOAI" {
            jupyterImages = container "Jupyter Workbench Images" "JupyterLab 4.4 environments with CPU, CUDA, and ROCm variants" "Container Images (10 variants)"
            codeServerImage = container "Code Server Image" "VS Code (code-server 4.104) web IDE with data science libraries" "Container Image"
            rstudioImages = container "RStudio Server Images" "RStudio Server 2025.09 with R 4.5, CPU and CUDA variants" "Container Images (2 variants)"
            runtimeImages = container "Elyra Pipeline Runtimes" "Headless pipeline execution images for Data Science Pipelines" "Container Images (7 variants)"
            baseImages = container "Base Images" "Shared base layers: UBI9 CPU, CUDA 12.6/12.8/13.0, ROCm 6.2/6.3/6.4" "Container Images (3 base types)"
            kustomizeManifests = container "Kustomize Manifests" "OpenShift ImageStream definitions and ConfigMaps for all images" "YAML/Kustomize"
        }

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Launches workbench pods from ImageStreams, injects auth proxy sidecars" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys ImageStream manifests to cluster via kustomize overlay" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Displays workbench image options to users based on ImageStream annotations" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "Uses Elyra pipeline runtime images for headless pipeline execution" "Internal RHOAI"

        konflux = softwareSystem "Konflux CI/CD" "Builds all container images via 110 Tekton PipelineRun definitions" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for resource management" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for notebook data and pipeline artifacts" "External"
        containerRegistries = softwareSystem "Container Registries" "registry.redhat.io, quay.io for image storage and distribution" "External"
        pypi = softwareSystem "PyPI / pip Registries" "Python package registries for workbench package installation" "External"
        databases = softwareSystem "Database Services" "Kafka, MongoDB, PostgreSQL, MySQL for data access from notebooks" "External"

        # Relationships
        dataScientist -> notebooks "Uses workbench environments via browser"
        mlEngineer -> notebooks "Executes ML pipelines using runtime images"
        admin -> rhodsOperator "Manages platform deployment"

        notebooks -> k8sAPI "kubectl/oc CLI from workbenches" "HTTPS/443"
        notebooks -> s3Storage "Data access via Boto3" "HTTPS/443"
        notebooks -> pypi "Package installation" "HTTPS/443"
        notebooks -> databases "Data access from notebooks" "Various ports"

        odhNotebookController -> notebooks "Reads ImageStreams, launches workbench pods"
        rhodsOperator -> notebooks "Deploys ImageStream manifests" "HTTPS/443"
        rhoaiDashboard -> notebooks "Reads ImageStream annotations for UI"
        dsPipelines -> notebooks "Uses runtime images for pipeline execution"

        konflux -> notebooks "Builds all container images" "HTTPS/443"
        notebooks -> containerRegistries "Image storage and pulls" "HTTPS/443"

        # Container relationships
        baseImages -> jupyterImages "Base layer for"
        baseImages -> codeServerImage "Base layer for"
        baseImages -> rstudioImages "Base layer for"
        baseImages -> runtimeImages "Base layer for"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
