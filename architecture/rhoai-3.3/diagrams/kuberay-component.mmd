%% Generated by: Claude Opus 4.6

graph TB
    subgraph KubeRayOperator["KubeRay Operator (opendatahub namespace)"]
        direction TB
        RCController["RayCluster Controller"]
        RJController["RayJob Controller"]
        RSController["RayService Controller"]
        AuthController["Authentication Controller"]
        NPController["NetworkPolicy Controller"]
        MTLSController["mTLS Controller"]
        MutWebhook["Mutating Webhook<br/>9443/TCP HTTPS"]
        ValWebhook["Validating Webhook<br/>9443/TCP HTTPS"]
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|creates| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|creates| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% Webhook intercepts
    RayClusterCR -->|intercepted by| MutWebhook
    MutWebhook -->|enforces defaults| ValWebhook

    %% Controller watches
    RayClusterCR -->|watched by| RCController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController
    RayClusterCR -->|watched by| AuthController
    RayClusterCR -->|watched by| NPController
    RayClusterCR -->|watched by| MTLSController

    %% What controllers create
    RCController -->|creates| HeadPod["Ray Head Pod<br/>8265/TCP, 10001/TCP, 6379/TCP"]
    RCController -->|creates| WorkerPods["Ray Worker Pods"]
    RCController -->|creates| HeadSvc["Head Service<br/>(ClusterIP)"]
    RJController -->|creates| SubmitterJob["Submitter Job<br/>(batch/v1)"]
    RJController -->|creates managed| RayClusterCR

    AuthController -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthController -->|creates| RefGrant["ReferenceGrant"]
    AuthController -->|injects| RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS"]

    NPController -->|creates| HeadNP["Head NetworkPolicy"]
    NPController -->|creates| WorkerNP["Worker NetworkPolicy"]

    MTLSController -->|creates| Issuer["cert-manager Issuer"]
    MTLSController -->|creates| Certificate["cert-manager Certificate"]

    %% External dependencies
    HTTPRoute -->|references| DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    MTLSController -->|depends on| CertManager["cert-manager"]
    RCController -->|depends on| K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% SCC
    SCC["SCC: run-as-ray-user<br/>UID 1000"] -.->|applied to| HeadPod
    SCC -.->|applied to| WorkerPods

