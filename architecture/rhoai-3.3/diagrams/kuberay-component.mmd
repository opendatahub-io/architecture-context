graph TB
    subgraph "KubeRay Operator Deployment"
        Operator[KubeRay Operator<br/>kuberay-operator]
        MutatingWebhook[Mutating Webhook<br/>9443/TCP HTTPS]
        ValidatingWebhook[Validating Webhook<br/>9443/TCP HTTPS]
        Metrics[Metrics Endpoint<br/>8080/TCP HTTP]

        Operator -->|serves| MutatingWebhook
        Operator -->|serves| ValidatingWebhook
        Operator -->|exposes| Metrics
    end

    subgraph "Controllers"
        RayClusterCtrl[RayCluster Controller<br/>Lifecycle & Autoscaling]
        RayJobCtrl[RayJob Controller<br/>Batch Execution]
        RayServiceCtrl[RayService Controller<br/>HA & Zero-downtime]
        NetworkPolicyCtrl[NetworkPolicy Controller<br/>Isolation]
        AuthCtrl[Authentication Controller<br/>mTLS & OAuth]

        Operator -->|contains| RayClusterCtrl
        Operator -->|contains| RayJobCtrl
        Operator -->|contains| RayServiceCtrl
        Operator -->|contains| NetworkPolicyCtrl
        Operator -->|contains| AuthCtrl
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Ray Cluster"
        HeadPod[Ray Head Pod<br/>GCS: 6379/TCP<br/>Dashboard: 8265/TCP<br/>Client: 10001/TCP]
        WorkerPods[Ray Worker Pods<br/>Autoscaled]

        HeadPod -->|manages| WorkerPods
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        CertManager[cert-manager<br/>TLS Certs]
        GatewayAPI[Gateway API<br/>Advanced Routing]
        Prometheus[Prometheus<br/>Metrics]
        Redis[External Redis<br/>GCS HA]
        ObjectStorage[Object Storage<br/>S3/GCS]
    end

    %% User interactions
    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% Webhook flow
    K8sAPI -->|admission| MutatingWebhook
    K8sAPI -->|admission| ValidatingWebhook

    %% Controller watches CRs
    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Controller creates resources
    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayJobCtrl -->|submits to| HeadPod
    RayServiceCtrl -->|manages| HeadPod

    %% External integrations
    Operator -->|manages resources| K8sAPI
    AuthCtrl -->|requests certs| CertManager
    RayClusterCtrl -->|creates routes| GatewayAPI
    Prometheus -->|scrapes| Metrics
    HeadPod -->|fault tolerance| Redis
    WorkerPods -->|data access| ObjectStorage

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,stroke:#333
    style RayJobCtrl fill:#4a90e2,stroke:#333
    style RayServiceCtrl fill:#4a90e2,stroke:#333
    style NetworkPolicyCtrl fill:#4a90e2,stroke:#333
    style AuthCtrl fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333
    style CertManager fill:#999,stroke:#333
    style GatewayAPI fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style ObjectStorage fill:#e8e8e8,stroke:#333
