// RHODS Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/rhods-operator.md

workspace {
    model {
        admin = person "Cluster Admin" "Configures RHOAI platform via DSCInitialization and DataScienceCluster CRs"
        datascientist = person "Data Scientist" "Uses AI/ML platform services (Dashboard, Notebooks, Model Serving, Pipelines)"

        rhodsOperator = softwareSystem "RHODS Operator" "Platform operator for Red Hat OpenShift AI - manages lifecycle of 14+ AI/ML components" {
            dsciController = container "DSCInitialization Controller" "Manages platform initialization: auth, monitoring, gateway, CA bundles" "Go Controller (controller-runtime)"
            dscController = container "DataScienceCluster Controller" "Manages component lifecycle (enable/disable) based on DSC CR" "Go Controller (controller-runtime)"
            gatewayController = container "Gateway Controller" "Deploys Gateway API infrastructure: GatewayClass, Gateway, kube-auth-proxy, EnvoyFilter" "Go Controller (reconciler framework)"
            authController = container "Auth Controller" "Manages authentication groups (admin/allowed)" "Go Controller"
            monitoringController = container "Monitoring Controller" "Deploys Prometheus, AlertManager, ServiceMonitors" "Go Controller"
            componentControllers = container "Component Controllers" "14+ controllers deploying kustomize manifests for Dashboard, KServe, DSP, Kueue, Ray, etc." "Go Controllers"
            webhookServer = container "Admission Webhooks" "Validates/mutates DSC, DSCI, HardwareProfile, and component resources" "Webhook Server (port 9443)"
        }

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "OAuth2 proxy for Gateway API authentication" "Deployed by Gateway Controller" {
            tags "Internal"
        }

        // External Dependencies
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API for resource management" {
            tags "External"
        }
        istio = softwareSystem "Istio / Service Mesh" "Service mesh for traffic management, mTLS, EnvoyFilter support" {
            tags "External"
        }
        gatewayApiController = softwareSystem "OpenShift Gateway API Controller" "Implements GatewayClass openshift.io/gateway-controller/v1" {
            tags "External"
        }
        olm = softwareSystem "OLM" "Operator Lifecycle Manager for operator installation and upgrades" {
            tags "External"
        }
        prometheusOperator = softwareSystem "Prometheus Operator" "Manages monitoring CRDs (ServiceMonitor, PrometheusRule)" {
            tags "External"
        }
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "User authentication (IntegratedOAuth mode)" {
            tags "External"
        }
        oidcProvider = softwareSystem "External OIDC Provider" "User authentication (OIDC mode)" {
            tags "External"
        }
        openshiftIngress = softwareSystem "OpenShift Ingress Controller" "External traffic routing and default TLS certificates" {
            tags "External"
        }
        certManager = softwareSystem "cert-manager" "Optional TLS certificate management" {
            tags "External"
        }

        // Internal ODH Components (managed by operator)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform" {
            tags "Internal ODH"
        }
        kserve = softwareSystem "KServe" "Serverless ML model serving" {
            tags "Internal ODH"
        }
        dsPipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" {
            tags "Internal ODH"
        }
        kueue = softwareSystem "Kueue" "Job scheduling and quota management" {
            tags "Internal ODH"
        }
        ray = softwareSystem "Ray" "Distributed computing framework" {
            tags "Internal ODH"
        }
        trustyai = softwareSystem "TrustyAI" "AI explainability and fairness" {
            tags "Internal ODH"
        }
        modelRegistry = softwareSystem "Model Registry" "ML model metadata storage" {
            tags "Internal ODH"
        }
        trainingOperator = softwareSystem "Training Operator" "Kubeflow distributed training" {
            tags "Internal ODH"
        }
        feast = softwareSystem "Feast Operator" "Feature store management" {
            tags "Internal ODH"
        }
        llamastack = softwareSystem "LlamaStack Operator" "LlamaStack management" {
            tags "Internal ODH"
        }
        mlflow = softwareSystem "MLflow Operator" "Experiment tracking" {
            tags "Internal ODH"
        }

        // Relationships
        admin -> rhodsOperator "Creates DSCInitialization & DataScienceCluster CRs via kubectl"
        datascientist -> dashboard "Accesses via Gateway API" "HTTPS/443"
        datascientist -> kserve "Deploys and queries models" "HTTPS/443"

        rhodsOperator -> k8sApi "Watches CRs, applies manifests" "HTTPS/6443"
        rhodsOperator -> istio "Creates EnvoyFilter, DestinationRule" "CRD"
        rhodsOperator -> gatewayApiController "Creates Gateway, GatewayClass" "CRD"
        rhodsOperator -> olm "Reads CSV, Subscription" "CRD"
        rhodsOperator -> prometheusOperator "Creates ServiceMonitor, PrometheusRule" "CRD"
        rhodsOperator -> openshiftIngress "Propagates default ingress certificate" "API/Secret watch"
        rhodsOperator -> certManager "Optional TLS certificate management" "CRD"

        rhodsOperator -> kubeAuthProxy "Deploys and configures" "Kubernetes API"
        kubeAuthProxy -> openshiftOAuth "Authenticates users (IntegratedOAuth)" "HTTPS/443"
        kubeAuthProxy -> oidcProvider "Authenticates users (OIDC mode)" "HTTPS/443"

        rhodsOperator -> dashboard "Deploys and manages" "kustomize manifests"
        rhodsOperator -> kserve "Deploys and manages" "kustomize manifests"
        rhodsOperator -> dsPipelines "Deploys and manages" "kustomize manifests"
        rhodsOperator -> kueue "Deploys and manages" "kustomize manifests"
        rhodsOperator -> ray "Deploys and manages" "kustomize manifests"
        rhodsOperator -> trustyai "Deploys and manages" "kustomize manifests"
        rhodsOperator -> modelRegistry "Deploys and manages" "kustomize manifests"
        rhodsOperator -> trainingOperator "Deploys and manages" "kustomize manifests"
        rhodsOperator -> feast "Deploys and manages" "kustomize manifests"
        rhodsOperator -> llamastack "Deploys and manages" "kustomize manifests"
        rhodsOperator -> mlflow "Deploys and manages" "kustomize manifests"

        // Internal container relationships
        dsciController -> gatewayController "Reconciles GatewayConfig" "in-process"
        dsciController -> authController "Reconciles Auth" "in-process"
        dsciController -> monitoringController "Reconciles Monitoring" "in-process"
        dscController -> componentControllers "Reconciles component CRs" "in-process"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #9b59b6
                color #ffffff
            }
        }
    }
}
