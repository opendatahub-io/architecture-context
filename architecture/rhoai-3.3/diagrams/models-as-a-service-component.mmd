%% Models as a Service - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "MaaS API Service"
        API["maas-api<br/>(Go/Gin HTTP Service)"]
        TokenMgr["Token Manager<br/>SA Token Issuance"]
        ModelMgr["Model Manager<br/>Model Discovery"]
        TierMapper["Tier Mapper<br/>Group-to-Tier Mapping"]
        APIKeySvc["API Key Service<br/>Persistent Key Mgmt"]
        ClusterCfg["Cluster Config<br/>Shared Informers"]
    end

    subgraph "Gateway & Policy Layer"
        Gateway["maas-default-gateway<br/>(Gateway API)<br/>openshift-default GatewayClass"]
        GatewayAuth["gateway-auth-policy<br/>(Kuadrant AuthPolicy)<br/>TokenReview + SAR"]
        MaaSAuth["maas-api-auth-policy<br/>(Kuadrant AuthPolicy)<br/>Identity Headers"]
        RateLimit["token-rate-limit-policy<br/>(TokenRateLimitPolicy)<br/>Per-tier limits"]
        Telemetry["telemetry-policy<br/>(TelemetryPolicy)<br/>Metrics Enrichment"]
    end

    subgraph "Configuration"
        TierCM["tier-to-group-mapping<br/>(ConfigMap)"]
    end

    User[User/Client] -->|HTTPS/443<br/>Bearer Token| Gateway
    Gateway -->|auth evaluation| GatewayAuth
    Gateway -->|auth evaluation| MaaSAuth
    Gateway -->|rate limiting| RateLimit
    Gateway -->|telemetry| Telemetry
    Gateway -->|HTTP/8080| API

    API --> TokenMgr
    API --> ModelMgr
    API --> TierMapper
    API --> APIKeySvc
    API --> ClusterCfg

    TierMapper -->|reads| TierCM

    %% CRD Watches
    ClusterCfg -->|watches| ISVC["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    ClusterCfg -->|watches| LLMISVC["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha1)"]
    ClusterCfg -->|watches| HTTPRoute["HTTPRoute CR<br/>(gateway.networking.k8s.io/v1)"]

    %% External Dependencies
    TokenMgr -->|TokenRequest<br/>SA Management| K8sAPI["Kubernetes API<br/>Server"]
    GatewayAuth -->|TokenReview<br/>SubjectAccessReview| K8sAPI
    ModelMgr -->|auth loopback<br/>check| Gateway

    %% Storage
    APIKeySvc -->|metadata| SQLite["SQLite<br/>(built-in)"]
    APIKeySvc -.->|HA mode| PostgreSQL["PostgreSQL<br/>(external)"]

    %% External Systems
    GatewayAuth -->|auth| Authorino["Authorino"]
    RateLimit -->|enforcement| Limitador["Limitador"]

