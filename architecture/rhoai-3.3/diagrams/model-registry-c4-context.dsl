// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/model-registry.md

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist" "Registers and manages ML models, versions, and artifacts"
        mlEngineer = person "ML Engineer" "Deploys models and monitors inference services"

        // Primary System
        modelRegistry = softwareSystem "Model Registry" "Central repository for ML model metadata, versions, artifacts, and inference service state" {
            proxy = container "model-registry proxy" "REST API server exposing OpenAPI v1alpha3 for managing registered models, versions, artifacts, experiments" "Go (chi router, GORM)" "Service"
            controller = container "model-registry controller" "Watches KServe InferenceService CRs, syncs deployment state with registry" "Go (controller-runtime)" "Controller"
            csi = container "CSI Storage Initializer" "Resolves model-registry:// URIs, downloads model artifacts for KServe" "Go" "InitContainer"
            catalog = container "model-catalog" "Aggregates model metadata from external sources (HuggingFace) into searchable catalog" "Go (chi router, GORM)" "Service"
            bff = container "model-registry-ui BFF" "Backend-for-frontend proxying API calls and managing K8s interactions" "Go" "Service"
            frontend = container "model-registry-ui frontend" "Web interface for browsing and managing models" "React/TypeScript" "WebApp"
            asyncUpload = container "async-upload job" "Transfers models between storage backends (S3, OCI, HuggingFace)" "Python" "Job"
        }

        // External Systems
        mysql = softwareSystem "MySQL Database" "Primary metadata store for model registry" "External"
        postgresql = softwareSystem "PostgreSQL Database" "Metadata store for model catalog" "External"
        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService CRD" "Internal ODH"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS, traffic management, and authorization" "External"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects" "Internal ODH"
        huggingface = softwareSystem "HuggingFace Hub" "External model repository for model metadata and artifacts" "External"
        s3 = softwareSystem "S3/OCI Storage" "External object storage for model artifacts" "External"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane API" "External"

        // System-level relationships
        dataScientist -> modelRegistry "Registers models, creates versions, browses catalog"
        mlEngineer -> modelRegistry "Deploys models via InferenceService, monitors deployments"
        modelRegistry -> mysql "Stores model metadata" "MySQL/3306"
        modelRegistry -> postgresql "Stores catalog metadata" "PostgreSQL/5432"
        modelRegistry -> kserve "Syncs InferenceService state, CSI storage initialization"
        modelRegistry -> istio "Uses for mTLS traffic encryption" "ISTIO_MUTUAL"
        modelRegistry -> huggingface "Fetches model metadata for catalog" "HTTPS/443"
        modelRegistry -> s3 "Downloads/uploads model artifacts" "HTTPS/443"
        modelRegistry -> k8sAPI "Watches CRDs, updates resources" "HTTPS/443"
        dashboard -> modelRegistry "Consumes REST API for model management views" "HTTP/8080"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS/8443"

        // Container-level relationships
        dataScientist -> frontend "Browses models and artifacts" "HTTPS"
        frontend -> bff "API calls" "HTTP/8080"
        bff -> proxy "REST API calls" "HTTP/8080"

        proxy -> mysql "Reads/writes model metadata" "MySQL/3306"
        catalog -> postgresql "Reads/writes catalog entries" "PostgreSQL/5432"
        catalog -> huggingface "Fetches model metadata" "HTTPS/443"

        controller -> proxy "Syncs InferenceService state" "HTTP/8080"
        controller -> k8sAPI "Watches InferenceService CRs, updates labels" "HTTPS/443"
        k8sAPI -> controller "Watch events for InferenceService" "HTTPS"

        csi -> proxy "Resolves model-registry:// URIs" "HTTP/8080"
        csi -> s3 "Downloads model artifacts" "HTTPS/443"
        kserve -> csi "Injects as init container"

        asyncUpload -> s3 "Transfers model artifacts" "HTTPS/443"
        asyncUpload -> huggingface "Downloads models" "HTTPS/443"

        dashboard -> proxy "REST API consumer" "HTTP/8080"
        prometheus -> controller "Scrapes metrics" "HTTPS/8443"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Service" {
                shape RoundedBox
            }
            element "Controller" {
                shape Hexagon
            }
            element "WebApp" {
                shape WebBrowser
            }
            element "Job" {
                shape Circle
            }
            element "InitContainer" {
                shape Diamond
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
