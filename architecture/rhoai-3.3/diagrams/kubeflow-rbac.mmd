graph TD
    subgraph "Service Accounts"
        SA_Controller[odh-notebook-controller-manager<br/>Namespace: redhat-ods-applications]
        SA_Notebook["{notebook-name}<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[odh-notebook-controller-manager-rolebinding]
    end

    subgraph "ClusterRole: odh-notebook-controller-manager-role"
        CR_Manager[odh-notebook-controller-manager-role]

        subgraph "Kubeflow Permissions"
            Perm_Notebooks["notebooks.kubeflow.org<br/>notebooks, notebooks/status, notebooks/finalizers<br/>get, list, watch, patch, update"]
        end

        subgraph "Gateway API Permissions"
            Perm_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes, referencegrants<br/>get, list, watch, create, update, patch, delete"]
            Perm_Gateways["gateway.networking.k8s.io<br/>gateways<br/>get, list, watch"]
        end

        subgraph "Core Resources"
            Perm_Core["core<br/>services, serviceaccounts, secrets, configmaps<br/>get, list, watch, create, update, patch"]
        end

        subgraph "Networking"
            Perm_NetPol["networking.k8s.io<br/>networkpolicies, networkpolicies/finalizers<br/>get, list, watch, create, update, patch"]
        end

        subgraph "RBAC Management"
            Perm_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterrolebindings<br/>get, list, watch, create, update, patch, delete"]
        end

        subgraph "Authentication & Authorization"
            Perm_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
            Perm_SubjectAccess["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        end

        subgraph "OpenShift Resources"
            Perm_OAuth["oauth.openshift.io<br/>oauthclients<br/>get, list, watch, update, patch, delete"]
            Perm_Images["image.openshift.io<br/>imagestreams<br/>get, list, watch"]
            Perm_Proxy["config.openshift.io<br/>proxies<br/>get, list, watch"]
            Perm_Routes["route.openshift.io<br/>routes<br/>get, list, watch"]
        end

        subgraph "Pipeline Integration"
            Perm_DSPA["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications, datasciencepipelinesapplications/api<br/>get, list, watch, create, update, patch, delete"]
        end
    end

    subgraph "Namespace Role: Leader Election"
        Role_Leader[odh-notebook-controller-leader-election-role<br/>Namespace: redhat-ods-applications]
        Perm_Leader["core: configmaps<br/>coordination.k8s.io: leases<br/>core: events<br/>get, list, watch, create, update, patch, delete"]
    end

    subgraph "Namespace RoleBinding: Leader Election"
        RB_Leader[odh-notebook-controller-leader-election-rolebinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "User Roles (Aggregated)"
        Role_Admin["notebooks-admin<br/>(aggregates to admin)<br/>notebooks, notebooks/status<br/>all verbs"]
        Role_Edit["notebooks-edit<br/>notebooks, notebooks/status<br/>get, list, watch, create, delete,<br/>deletecollection, patch, update"]
        Role_View["notebooks-view<br/>notebooks, notebooks/status<br/>get, list, watch"]
    end

    subgraph "Dynamic Notebook RBAC"
        RB_Pipeline["{notebook-name}-sa-rb<br/>Namespace: {user-namespace}"]
        Role_Pipeline["{dspa-name}-dspa<br/>Namespace: {user-namespace}"]
    end

    subgraph "kube-rbac-proxy Authorization"
        ProxyAuth["SubjectAccessReview:<br/>Verb: get<br/>Resource: notebooks<br/>API Group: kubeflow.org<br/>Name: {notebook-name}<br/>Namespace: {notebook-namespace}"]
    end

    %% Service Account to ClusterRole
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|includes| Perm_Notebooks
    CR_Manager -->|includes| Perm_HTTPRoutes
    CR_Manager -->|includes| Perm_Gateways
    CR_Manager -->|includes| Perm_Core
    CR_Manager -->|includes| Perm_NetPol
    CR_Manager -->|includes| Perm_RBAC
    CR_Manager -->|includes| Perm_TokenReview
    CR_Manager -->|includes| Perm_SubjectAccess
    CR_Manager -->|includes| Perm_OAuth
    CR_Manager -->|includes| Perm_Images
    CR_Manager -->|includes| Perm_Proxy
    CR_Manager -->|includes| Perm_Routes
    CR_Manager -->|includes| Perm_DSPA

    %% Leader Election
    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| Role_Leader
    Role_Leader -->|includes| Perm_Leader

    %% Notebook ServiceAccount to Pipeline Role
    SA_Notebook -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| Role_Pipeline

    %% kube-rbac-proxy uses SubjectAccessReview
    SA_Controller -->|creates SubjectAccessReview<br/>via| Perm_SubjectAccess
    Perm_SubjectAccess -->|enforces| ProxyAuth

    %% User roles (informational)
    Role_Admin -.->|allows users to| Perm_Notebooks
    Role_Edit -.->|allows users to| Perm_Notebooks
    Role_View -.->|allows users to| Perm_Notebooks

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style SA_Notebook fill:#6fa8dc,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:3px,color:#000
    style CRB_Manager fill:#ffd966,stroke:#333,stroke-width:2px,color:#000
    style Role_Leader fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style RB_Leader fill:#ffd966,stroke:#333,stroke-width:2px,color:#000

    style Perm_Notebooks fill:#7ed321,stroke:#333,color:#000
    style Perm_HTTPRoutes fill:#7ed321,stroke:#333,color:#000
    style Perm_Gateways fill:#7ed321,stroke:#333,color:#000
    style Perm_Core fill:#7ed321,stroke:#333,color:#000
    style Perm_NetPol fill:#7ed321,stroke:#333,color:#000
    style Perm_RBAC fill:#7ed321,stroke:#333,color:#000
    style Perm_TokenReview fill:#7ed321,stroke:#333,color:#000
    style Perm_SubjectAccess fill:#7ed321,stroke:#333,color:#000
    style Perm_OAuth fill:#7ed321,stroke:#333,color:#000
    style Perm_Images fill:#7ed321,stroke:#333,color:#000
    style Perm_Proxy fill:#7ed321,stroke:#333,color:#000
    style Perm_Routes fill:#7ed321,stroke:#333,color:#000
    style Perm_DSPA fill:#7ed321,stroke:#333,color:#000
    style Perm_Leader fill:#7ed321,stroke:#333,color:#000

    style Role_Pipeline fill:#b19cd9,stroke:#333,color:#000
    style RB_Pipeline fill:#d5a6db,stroke:#333,color:#000

    style Role_Admin fill:#e1d5e7,stroke:#333,color:#000
    style Role_Edit fill:#e1d5e7,stroke:#333,color:#000
    style Role_View fill:#e1d5e7,stroke:#333,color:#000

    style ProxyAuth fill:#f4cccc,stroke:#333,stroke-width:2px,color:#000
