graph TB
    subgraph "Feast Feature Store Platform"
        Operator[Feast Operator]
        OnlineServer[Online Feature Server<br/>FastAPI/gRPC]
        OfflineServer[Offline Feature Server<br/>FastAPI]
        RegistryServer[Registry Server<br/>gRPC/REST]
        UIServer[UI Server<br/>React/TypeScript]
        ClientCM[Client ConfigMap<br/>feature_store.yaml]
        CronJob[Materialization CronJob<br/>Optional]

        Operator -->|manages| OnlineServer
        Operator -->|manages| OfflineServer
        Operator -->|manages| RegistryServer
        Operator -->|manages| UIServer
        Operator -->|creates| ClientCM
        Operator -->|creates| CronJob
    end

    subgraph "Custom Resources"
        FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1]
    end

    subgraph "Persistence Layer"
        SQLite[(SQLite<br/>Default)]
        PostgreSQL[(PostgreSQL<br/>Optional)]
        Redis[(Redis<br/>Optional)]
        S3[(S3/Object Storage<br/>Optional)]
    end

    subgraph "External Services"
        OIDC[OIDC Provider<br/>Optional Auth]
        Git[Git Repository<br/>Feature Definitions]
        Prometheus[Prometheus<br/>Metrics]
    end

    subgraph "Client Applications"
        MLApp[ML Application]
        TrainingJob[Training Job]
        FeastCLI[feast CLI/SDK]
        Notebook[Kubeflow Notebook]
    end

    subgraph "OpenShift Integration"
        Routes[OpenShift Routes]
        CertManager[cert-manager<br/>TLS Certs]
    end

    User[User] -->|creates| FeatureStoreCR
    FeatureStoreCR -->|watched by| Operator

    MLApp -->|get online features| OnlineServer
    TrainingJob -->|get historical features| OfflineServer
    FeastCLI -->|manage features| RegistryServer
    Notebook -->|reads config| ClientCM

    OnlineServer -->|stores/retrieves| SQLite
    OnlineServer -->|stores/retrieves| PostgreSQL
    OnlineServer -->|stores/retrieves| Redis
    OnlineServer -->|queries metadata| RegistryServer

    OfflineServer -->|reads data| S3
    OfflineServer -->|queries metadata| RegistryServer

    RegistryServer -->|persists| SQLite
    RegistryServer -->|persists| PostgreSQL
    RegistryServer -->|persists| S3
    RegistryServer -->|syncs| Git

    CronJob -->|triggers| OnlineServer
    OnlineServer -->|materializes from| OfflineServer

    UIServer -->|queries| RegistryServer

    Operator -->|creates| Routes
    Operator -->|uses| CertManager
    Operator -->|integrates| Notebook

    OnlineServer -->|validates tokens| OIDC
    OfflineServer -->|validates tokens| OIDC
    RegistryServer -->|validates tokens| OIDC

    OnlineServer -->|exports| Prometheus
    OfflineServer -->|exports| Prometheus
    Operator -->|exports| Prometheus

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style OnlineServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style OfflineServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style RegistryServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style UIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style SQLite fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style CertManager fill:#7ed321,stroke:#333
    style Notebook fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
