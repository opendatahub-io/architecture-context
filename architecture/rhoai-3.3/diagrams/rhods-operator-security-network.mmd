graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Platform Admin<br/>kubectl/oc client]
    end

    subgraph K8sAPIBoundary["KUBERNETES API SERVER (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforced"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB

        Webhook["Webhook Service<br/>ClusterIP: 443/TCP → 9443/TCP<br/>TLS 1.2+ (cert-manager/Service CA)<br/>mTLS with API Server<br/>SA: controller-manager"]

        Operator["RHODS Operator Controller<br/>Deployment (3 replicas)<br/>Leader Election: 07ed84f7.opendatahub.io<br/>SA: controller-manager<br/>Pod Security:<br/>- runAsNonRoot: true<br/>- allowPrivilegeEscalation: false<br/>- seccompProfile: RuntimeDefault<br/>- capabilities.drop: ALL"]

        MetricsSvc["Metrics Service<br/>ClusterIP: 8443/TCP → 8080/TCP<br/>HTTP (no encryption)<br/>Auth: kube-rbac-proxy (Bearer token)"]

        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz (liveness)<br/>/readyz (readiness)<br/>Unauthenticated"]
    end

    subgraph ManagedNS["MANAGED NAMESPACES"]
        direction TB

        subgraph NSApps["redhat-ods-applications"]
            AppComponents["Application Components<br/>(Dashboard, Workbenches, etc.)<br/>NetworkPolicy: Allow 8443,8080,8081,<br/>5432,8082,8099,8181,9443/TCP"]
        end

        subgraph NSMon["redhat-ods-monitoring"]
            Prometheus["Prometheus<br/>Scrapes with ServiceAccount token"]
            MonStack["Monitoring Stack<br/>(AlertManager, Grafana)"]
        end

        subgraph NSIstio["istio-system (optional)"]
            Istio["Service Mesh Control Plane<br/>Istio 2.4+"]
        end

        subgraph NSKnative["knative-serving (optional)"]
            Knative["Serverless Infrastructure<br/>Knative 1.30+"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        OAuth["OpenShift OAuth Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth token<br/>(RHOAI user auth)"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secrets"]
        GitRepos["Component Git Repos<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>None (public repos)<br/>(optional, not default)"]
    end

    %% Flows
    Admin -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    K8sAPI -->|POST /validate-*, /mutate-*<br/>443→9443/TCP HTTPS<br/>mTLS - API server cert| Webhook

    Webhook -.->|Validation/Mutation response| K8sAPI

    K8sAPI -.->|Watch notification| Operator

    Operator -->|REST API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token<br/>controller-manager SA| K8sAPI

    Operator -->|Creates CRDs, Deployments,<br/>Services, RBAC, etc.| AppComponents

    Operator -.->|Configures monitoring| MonStack

    Operator -.->|Integrates - optional| Istio
    Operator -.->|Integrates - optional| Knative

    Prometheus -->|GET /metrics<br/>8443/TCP HTTP<br/>Bearer token - SA| MetricsSvc

    MetricsSvc -->|TokenReview API<br/>6443/TCP HTTPS| K8sAPI

    MetricsSvc -.->|Internal 8080/TCP<br/>HTTP| Operator

    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>OAuth token| OAuth

    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>Pull secrets| Registry

    Operator -.->|HTTPS/443<br/>TLS 1.2+ - optional| GitRepos

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef boundary fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Admin external
    class K8sAPI boundary
    class Webhook,Operator,MetricsSvc,HealthProbes operator
    class AppComponents,Prometheus,MonStack,Istio,Knative managed
    class OAuth,Registry,GitRepos externalservice
