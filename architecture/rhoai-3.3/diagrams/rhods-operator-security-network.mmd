%% RHODS Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.3/rhods-operator.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Ingress)"]
        Router["OpenShift Router / LB<br/>443/TCP<br/>TLS Reencrypt or Passthrough"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (openshift-ingress namespace)"]
        direction TB
        Gateway["data-science-gateway (Envoy)<br/>443/TCP HTTPS<br/>TLS 1.2+ Terminate<br/>Cert: data-science-gatewayconfig-tls"]

        AuthProxy["kube-auth-proxy (OAuth2 Proxy)<br/>Ports: 4180/HTTP, 8443/HTTPS, 9000/HTTP<br/>Cert: kube-auth-proxy-tls (service-CA)<br/>Creds: kube-auth-proxy-creds"]

        EnvoyFilter["EnvoyFilter: data-science-authn-filter<br/>(ext_authz + Lua filter)"]
        DestRule["DestinationRule: data-science-tls-rule<br/>(mTLS for 443, 8443)"]
        NetPol["NetworkPolicy: kube-auth-proxy<br/>Allow: Gateway pods, monitoring"]
    end

    subgraph AuthProviders["AUTHENTICATION PROVIDERS"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+"]
        OIDCProvider["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB
        Operator["RHODS Operator Pod<br/>SA: controller-manager"]
        WebhookSvc["Webhook Service<br/>443/TCP -> 9443/TCP<br/>HTTPS (service-CA cert)"]
        MetricsSvc["Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>(plaintext, no auth)"]
    end

    subgraph ServiceMesh["SERVICE MESH / INTERNAL CLUSTER"]
        direction TB
        BackendServices["Backend Services<br/>(Dashboard, KServe, DSP, etc.)<br/>via HTTPRoute<br/>mTLS (DestinationRule)"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        Prometheus["Prometheus<br/>Scrapes: 8080, 9000"]
    end

    %% External flow
    User -->|"HTTPS/443<br/>TLS 1.2+"| Router
    Router -->|"HTTPS/443<br/>TLS reencrypt"| Gateway

    %% Auth flow
    Gateway -->|"ext_authz<br/>HTTPS/8443<br/>TLS (service-CA)<br/>Cookie: _oauth2_proxy"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OAuthServer
    AuthProxy -.->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDCProvider

    %% Post-auth flow
    Gateway -->|"mTLS<br/>Bearer Token (Lua inject)"| BackendServices

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/9000<br/>plaintext"| AuthProxy
    Prometheus -->|"HTTP/8080<br/>plaintext"| MetricsSvc

    %% Webhook
    K8sAPI -->|"HTTPS/443->9443<br/>TLS client cert"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cluster fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router ingress
    class Gateway,AuthProxy,EnvoyFilter,DestRule,NetPol gateway
    class OAuthServer,OIDCProvider auth
    class BackendServices servicemesh
    class Operator,WebhookSvc,MetricsSvc operator
    class K8sAPI,Prometheus cluster
