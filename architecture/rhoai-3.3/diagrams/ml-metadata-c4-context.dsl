// ML Metadata (MLMD) - C4 Context Diagram
// Generated by: Claude Opus 4.6

workspace {
    model {
        pipelineBackend = person "Kubeflow Pipelines Backend" "Records and retrieves pipeline run metadata, artifacts, executions, and lineage"
        pipelineUI = person "Kubeflow Pipelines UI" "Queries metadata for pipeline visualization and artifact inspection"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving metadata associated with ML workflows including artifacts, executions, contexts, and lineage" {
            grpcServer = container "metadata_store_server" "C++ gRPC server exposing MetadataStoreService API for CRUD operations on ML metadata" "C++ gRPC Binary"
            serviceImpl = container "MetadataStoreServiceImpl" "Thread-safe gRPC service implementing all MetadataStoreService RPCs" "C++ Service"
            metadataStore = container "MetadataStore" "Core metadata store logic with support for MySQL, PostgreSQL, SQLite backends" "C++ Library"
            protoDefs = container "Protocol Buffer Definitions" "Defines the data model (Artifact, Execution, Context, Event) and gRPC service interface" "Proto2/Proto3"
        }

        mysql = softwareSystem "MySQL / MariaDB" "Persistent metadata storage backend" "External Database"
        postgresql = softwareSystem "PostgreSQL" "Persistent metadata storage backend (12.17+ bundled libpq)" "External Database"
        sqlite = softwareSystem "SQLite" "Lightweight local metadata storage (bundled)" "Embedded Database"

        dsPipelines = softwareSystem "Data Science Pipelines" "Primary consumer - Kubeflow Pipelines uses MLMD to store pipeline run metadata" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys and configures the MLMD gRPC server as part of pipeline infrastructure" "Internal RHOAI"

        // Relationships
        pipelineBackend -> mlmd "Records metadata via gRPC" "gRPC/HTTP2 8080/TCP"
        pipelineUI -> mlmd "Queries metadata via gRPC" "gRPC/HTTP2 8080/TCP"

        mlmd -> mysql "Stores metadata" "MySQL Protocol 3306/TCP"
        mlmd -> postgresql "Stores metadata" "PostgreSQL Protocol 5432/TCP"
        mlmd -> sqlite "Stores metadata locally" "File I/O"

        rhoaiOperator -> mlmd "Deploys and configures"
        dsPipelines -> mlmd "Uses as metadata backend" "gRPC/HTTP2 8080/TCP"

        // Container relationships
        grpcServer -> serviceImpl "Hosts"
        serviceImpl -> metadataStore "Uses for storage operations"
        serviceImpl -> protoDefs "Implements API defined by"
        metadataStore -> mysql "Queries" "MySQL Protocol 3306/TCP Optional TLS"
        metadataStore -> postgresql "Queries" "PostgreSQL Protocol 5432/TCP Optional TLS"
        metadataStore -> sqlite "Reads/Writes" "Local file"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External Database" {
                background #f5a623
                color #ffffff
                shape Cylinder
            }
            element "Embedded Database" {
                background #f5a623
                color #ffffff
                shape Cylinder
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
