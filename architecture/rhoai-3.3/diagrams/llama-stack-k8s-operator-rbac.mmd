graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_AuthProxy[auth-proxy-rolebinding<br/>RoleBinding]
        RB_LeaderElection[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_AuthProxy[auth-proxy-role<br/>ClusterRole]
    end

    subgraph "Roles (Namespace-scoped)"
        R_LeaderElection[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Core"
        CoreAPI["Core API<br/>━━━━━━━━━<br/>configmaps<br/>persistentvolumeclaims<br/>serviceaccounts<br/>services<br/>events"]
    end

    subgraph "API Resources - Apps"
        AppsAPI["Apps API<br/>━━━━━━━━━<br/>deployments"]
    end

    subgraph "API Resources - Autoscaling"
        AutoscalingAPI["Autoscaling API<br/>━━━━━━━━━━━━<br/>horizontalpodautoscalers"]
    end

    subgraph "API Resources - LlamaStack"
        LlamaStackAPI["llamastack.io API<br/>━━━━━━━━━━━━━━━<br/>llamastackdistributions<br/>llamastackdistributions/finalizers<br/>llamastackdistributions/status"]
    end

    subgraph "API Resources - Networking"
        NetworkingAPI["Networking API<br/>━━━━━━━━━━━━━<br/>ingresses<br/>networkpolicies"]
    end

    subgraph "API Resources - Policy"
        PolicyAPI["Policy API<br/>━━━━━━━━━<br/>poddisruptionbudgets"]
    end

    subgraph "API Resources - RBAC"
        RBACAPI["RBAC API<br/>━━━━━━━━━<br/>clusterroles<br/>clusterrolebindings<br/>rolebindings"]
    end

    subgraph "API Resources - Security (OpenShift)"
        SecurityAPI["Security API<br/>━━━━━━━━━━━━━<br/>securitycontextconstraints<br/>(anyuid)"]
    end

    subgraph "API Resources - Auth"
        AuthAPI["Authentication API<br/>━━━━━━━━━━━━━━━━<br/>tokenreviews"]
        AuthzAPI["Authorization API<br/>━━━━━━━━━━━━━━━<br/>subjectaccessreviews"]
    end

    subgraph "API Resources - Coordination"
        CoordinationAPI["Coordination API<br/>━━━━━━━━━━━━━━━<br/>leases"]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| RB_AuthProxy
    SA -->|bound via| RB_LeaderElection

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_AuthProxy -->|grants| CR_AuthProxy
    RB_LeaderElection -->|grants| R_LeaderElection

    %% manager-role Permissions
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| CoreAPI
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| AppsAPI
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| AutoscalingAPI
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| LlamaStackAPI
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| NetworkingAPI
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| PolicyAPI
    CR_Manager -->|get, list, watch, delete,<br/>create, patch, update| RBACAPI
    CR_Manager -->|use| SecurityAPI

    %% auth-proxy-role Permissions
    CR_AuthProxy -->|create| AuthAPI
    CR_AuthProxy -->|create| AuthzAPI

    %% leader-election-role Permissions
    R_LeaderElection -->|create, get, list, patch,<br/>update, watch, delete| CoreAPI
    R_LeaderElection -->|create, get, list, patch,<br/>update, watch, delete| CoordinationAPI

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_AuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Manager fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_AuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style R_LeaderElection fill:#7ed321,stroke:#333,stroke-width:2px
    style CoreAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style AppsAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style AutoscalingAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style LlamaStackAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style NetworkingAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style PolicyAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style RBACAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style SecurityAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style AuthAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style AuthzAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
    style CoordinationAPI fill:#e1d5e7,stroke:#333,stroke-width:1px
