// Training Operator (KFTO) - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or API"

        trainingOperator = softwareSystem "Training Operator (KFTO)" "Kubernetes operator managing distributed ML training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, and JAX" {
            controller = container "Training Operator" "Main operator binary with 6 framework controllers (PyTorch, TF, MPI, XGBoost, Paddle, JAX)" "Go (controller-runtime)"
            webhookServer = container "Webhook Server" "ValidatingWebhookConfiguration for training job CRDs" "HTTPS/9443"
            certRotator = container "Cert Rotator" "Self-managed TLS certificate rotation for webhook" "cert-controller"
        }

        kubernetes = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduling via PodGroups" "External Optional"
        schedulerPlugins = softwareSystem "Scheduler-plugins" "Optional gang scheduling via PodGroups" "External Optional"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys training-operator via kustomize overlay" "Internal RHOAI"

        // User interactions
        user -> trainingOperator "Submits PyTorchJob, TFJob, MPIJob, XGBoostJob, PaddleJob, JAXJob" "kubectl / HTTPS"

        // Operator interactions
        trainingOperator -> kubernetes "CRUD: Pods, Services, NetworkPolicies, HPAs, PodGroups, RBAC" "HTTPS/443"
        kubernetes -> trainingOperator "Webhook callbacks for CR validation" "HTTPS/9443"
        prometheus -> trainingOperator "Scrapes metrics via PodMonitor" "HTTP/8080"
        trainingOperator -> volcano "Creates PodGroup CRDs for gang scheduling" "Kubernetes API"
        trainingOperator -> schedulerPlugins "Creates PodGroup CRDs for gang scheduling" "Kubernetes API"

        // Deployment
        rhodsOperator -> trainingOperator "Deploys and configures via kustomize overlay" "Kustomize"

        // Internal container relationships
        controller -> webhookServer "Registers webhook endpoints"
        certRotator -> webhookServer "Rotates TLS certificates"
        controller -> kubernetes "Watches CRDs, creates Pods/Services" "HTTPS/443"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #cccccc
                color #333333
                border dashed
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                shape roundedBox
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
