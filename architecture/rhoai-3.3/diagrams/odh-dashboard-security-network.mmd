graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>HSTS Enabled"]
    end

    subgraph DashboardPod["APPLICATION POD (odh-dashboard)<br/>NetworkPolicy: odh-dashboard-allow-ports"]
        direction TB

        subgraph Container1["Container: kube-rbac-proxy"]
            Proxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>8444/TCP HTTPS (health)<br/>TLS: dashboard-proxy-tls<br/>OAuth validation"]
        end

        subgraph Container2["Container: odh-dashboard"]
            Backend["Dashboard Backend<br/>8080/TCP HTTP<br/>Node.js/Fastify<br/>User: 1001 (non-root)<br/>SA: odh-dashboard"]
        end

        subgraph ModularArch["Modular Architecture (Optional)"]
            MRUI["model-registry-ui<br/>8043/TCP HTTPS<br/>x-forwarded-access-token"]
            GenAIUI["gen-ai-ui<br/>8143/TCP HTTPS<br/>x-forwarded-access-token"]
            MaaSUI["maas-ui<br/>8243/TCP HTTPS<br/>x-forwarded-access-token"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>User credentials"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>cluster-monitoring-view"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ImageRegistry["Image Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Image pull secrets"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
    end

    %% User flow
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Router -->|HTTPS/8443<br/>TLS Reencrypt| Proxy

    %% OAuth validation
    Proxy -->|OAuth validation<br/>HTTPS/443| OAuth
    Proxy -->|TokenReview<br/>HTTPS/443| K8sAPI

    %% Internal pod communication
    Proxy -->|HTTP/8080<br/>localhost<br/>Impersonation headers| Backend

    %% Backend to services
    Backend -->|HTTPS/443<br/>ServiceAccount Token<br/>+ Impersonation| K8sAPI
    Backend -->|HTTPS/9091<br/>ServiceAccount Token<br/>Metrics queries| Prometheus
    Backend -->|Module federation<br/>token forwarding| MRUI
    Backend -->|Module federation<br/>token forwarding| GenAIUI
    Backend -->|Module federation<br/>token forwarding| MaaSUI

    %% External connections
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>Image pulls| ImageRegistry
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>AWS credentials| S3

    %% Styling by trust zone
    classDef external fill:#f9f9f9,stroke:#d32f2f,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#000
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#000
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class Client external
    class Router ingress
    class Proxy,Backend,MRUI,GenAIUI,MaaSUI pod
    class K8sAPI,OAuth,Prometheus internal
    class ImageRegistry,S3 externalservice
