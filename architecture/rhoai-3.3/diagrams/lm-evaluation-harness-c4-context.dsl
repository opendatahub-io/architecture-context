/*
 * C4 Context Diagram: lm-evaluation-harness
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.3/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Defines model evaluation jobs via LMEvalJob CRDs"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Batch job container for evaluating language models against standardized benchmarks (MMLU, HellaSwag, ARC, GSM8K, etc.)" {
            cli = container "lm_eval CLI" "Main entry point for running model evaluations" "Python CLI"
            evaluator = container "Evaluator Engine" "Core evaluation orchestration - manages task execution, model inference, metric calculation" "Python Module"
            modelBackends = container "Model Backends" "21 adapters for different LM inference backends (HuggingFace, vLLM, API models)" "Python Modules"
            taskRegistry = container "Task Registry" "150+ evaluation task families with 1200+ benchmark configurations" "Python + YAML"
            metricsLibrary = container "Metrics Library" "50+ offline evaluation metrics (accuracy, BLEU, ROUGE, F1)" "Python + bundled metrics"
            s3Downloader = container "S3 Downloader" "Downloads model artifacts from S3-compatible storage" "Python Script"
            ociPublisher = container "OCI Artifact Publisher" "Pushes evaluation results as OCI artifacts via skopeo" "Python Script"
        }

        trustyaiOperator = softwareSystem "TrustyAI LMEval Operator" "Creates Kubernetes Jobs using LMEval container image; defines LMEvalJob CRD" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model, tokenizer, and dataset repository" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Model artifact storage (AWS S3, IBM COS)" "External"
        ociRegistry = softwareSystem "OCI Container Registry" "Stores evaluation result artifacts (quay.io or custom)" "External"
        remoteLMAPI = softwareSystem "Remote LM API" "OpenAI-compatible or IBM watsonx.ai inference endpoints" "External"

        /* Relationships */
        dataScientist -> trustyaiOperator "Creates LMEvalJob CR via kubectl/dashboard"
        trustyaiOperator -> lmEvalHarness "Creates Kubernetes Job using container image"

        lmEvalHarness -> huggingfaceHub "Downloads models, tokenizers, datasets" "HTTPS/443, Bearer Token"
        lmEvalHarness -> s3Storage "Downloads model artifacts" "HTTPS/443, AWS SigV4"
        lmEvalHarness -> ociRegistry "Pushes evaluation result artifacts" "HTTPS/443, Docker auth"
        lmEvalHarness -> remoteLMAPI "Sends inference requests for API-based evaluation" "HTTP/HTTPS, Bearer Token"

        /* Internal relationships */
        cli -> evaluator "Invokes evaluation"
        evaluator -> modelBackends "Selects and uses model backend"
        evaluator -> taskRegistry "Loads evaluation tasks"
        evaluator -> metricsLibrary "Computes evaluation metrics"
        s3Downloader -> s3Storage "Downloads via boto3"
        ociPublisher -> ociRegistry "Pushes via skopeo"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
