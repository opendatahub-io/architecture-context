// C4 Context Diagram: Distributed Workloads
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/distributed-workloads.md

workspace {
    model {
        // Users
        datascientist = person "Data Scientist" "Submits distributed training jobs and Ray workloads"
        mlEngineer = person "ML Engineer" "Builds and manages training runtime images"

        // Primary System
        distributedWorkloads = softwareSystem "Distributed Workloads" "GPU-accelerated training runtime container images and integration test suite for RHOAI Distributed Workloads stack" {
            cudaImages = container "CUDA Training Images" "UBI9-based images with CUDA 12.1/12.4/12.8 + PyTorch" "Container Image"
            rocmImages = container "ROCm Training Images" "UBI9-based images with ROCm 6.2/6.4 + PyTorch" "Container Image"
            cpuImages = container "CPU Training Images" "UBI9-based CPU-only PyTorch images" "Container Image"
            universalImages = container "Universal Training Images" "Combined notebook + runtime images" "Container Image"
            rayImages = container "Ray Runtime Images" "Ray 2.52.1 cluster images with CUDA/ROCm support" "Container Image"
            testSuiteKFTO = container "KFTO Test Suite" "Tests for Kubeflow Training Operator + Kueue" "Go Test Suite"
            testSuiteTrainer = container "Trainer Test Suite" "Tests for Kubeflow Trainer v2" "Go Test Suite"
            testSuiteODH = container "ODH Test Suite" "Tests for Ray-based workloads" "Go Test Suite"
            testSuiteFMS = container "FMS Test Suite" "Tests for fms-hf-tuning SFT training" "Go Test Suite"
            testLib = container "Test Support Library" "Reusable K8s/OpenShift API interaction utilities" "Go Library"
            tektonPipelines = container "Tekton Pipelines" "Konflux CI/CD pipeline definitions" "Tekton PipelineRun"
        }

        // Internal ODH/RHOAI Dependencies
        kuberayOperator = softwareSystem "KubeRay Operator" "Manages RayCluster and RayJob lifecycle" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages PyTorchJob distributed training" "Internal RHOAI"
        trainerV2 = softwareSystem "Kubeflow Trainer v2" "Manages TrainJob and ClusterTrainingRuntime" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and resource quota management" "Internal RHOAI"
        kueueOperator = softwareSystem "Kueue Operator" "Manages Kueue deployment on OpenShift" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Component lifecycle management via DataScienceCluster" "Internal RHOAI"
        jobsetController = softwareSystem "JobSet Controller" "Manages groups of related Jobs" "Internal RHOAI"

        // External Dependencies
        kubernetesAPI = softwareSystem "Kubernetes API" "OpenShift/Kubernetes cluster API server" "External"
        s3Storage = softwareSystem "S3 Storage" "Model artifact and dataset storage" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Pre-trained model repository" "External"
        pypi = softwareSystem "PyPI" "Python package index" "External"
        ubi9 = softwareSystem "Red Hat UBI9" "Base container image" "External"
        konflux = softwareSystem "Konflux CI/CD" "Build and push container images" "External"

        // User Relationships
        datascientist -> distributedWorkloads "Runs distributed training using runtime images"
        mlEngineer -> distributedWorkloads "Builds and tests training images"

        // Internal Relationships
        distributedWorkloads -> kuberayOperator "Creates RayCluster/RayJob CRs" "HTTPS/6443"
        distributedWorkloads -> trainingOperator "Creates PyTorchJob CRs" "HTTPS/6443"
        distributedWorkloads -> trainerV2 "Creates TrainJob CRs" "HTTPS/6443"
        distributedWorkloads -> kueue "Job queuing and quota management" "HTTPS/6443"
        distributedWorkloads -> kueueOperator "Verifies Kueue deployment" "HTTPS/6443"
        distributedWorkloads -> rhoaiOperator "Manages component lifecycle via DSC" "HTTPS/6443"
        distributedWorkloads -> jobsetController "Creates JobSets for Trainer v2" "HTTPS/6443"

        // External Relationships
        distributedWorkloads -> kubernetesAPI "Cluster API interactions" "HTTPS/6443"
        distributedWorkloads -> s3Storage "Upload/download datasets and models" "HTTPS/443"
        distributedWorkloads -> huggingface "Download pre-trained models" "HTTPS/443"
        distributedWorkloads -> pypi "Install Python packages during build" "HTTPS/443"

        // Build Relationships
        cudaImages -> ubi9 "Built on" "Dockerfile"
        rocmImages -> ubi9 "Built on" "Dockerfile"
        cpuImages -> ubi9 "Built on" "Dockerfile"
        tektonPipelines -> konflux "Executed by" "Pipeline"
        tektonPipelines -> cudaImages "Builds"
        tektonPipelines -> rocmImages "Builds"
        tektonPipelines -> rayImages "Builds"

        // Test Relationships
        testSuiteKFTO -> testLib "Uses"
        testSuiteTrainer -> testLib "Uses"
        testSuiteODH -> testLib "Uses"
        testSuiteFMS -> testLib "Uses"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
