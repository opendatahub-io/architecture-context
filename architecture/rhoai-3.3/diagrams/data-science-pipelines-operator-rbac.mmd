    class CR_Manager,R_Leader,R_API,R_PA,R_SW,R_Argo,R_Runner,CR_AdminView role
    class Perm_DSPA,Perm_Pipeline,Perm_Argo,Perm_Core,Perm_Apps,Perm_RBAC,Perm_Route,Perm_Network,Perm_Monitor,Perm_KServe,Perm_Batch,Perm_Webhook,Perm_AdminView permission
