    %% Operator RBAC bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% ClusterRole permissions
    CR_Manager -->|manages| Perm_DSPA
    CR_Manager -->|manages| Perm_Pipeline
    CR_Manager -->|manages| Perm_Argo
    CR_Manager -->|manages| Perm_Core
    CR_Manager -->|manages| Perm_Apps
    CR_Manager -->|manages| Perm_RBAC
    CR_Manager -->|manages| Perm_Route
    CR_Manager -->|manages| Perm_Network
    CR_Manager -->|manages| Perm_Monitor
    CR_Manager -->|manages| Perm_KServe
    CR_Manager -->|manages| Perm_Batch
    CR_Manager -->|manages| Perm_Webhook

    %% Per-instance RBAC bindings
    SA_API -->|bound via| RB_API
    RB_API -->|grants| R_API
    R_API -.->|access to<br/>pipelines, runs<br/>workflows| Perm_Pipeline

    SA_PA -->|bound via| RB_PA
    RB_PA -->|grants| R_PA
    R_PA -.->|watch workflows<br/>write metadata| Perm_Argo

    SA_SW -->|bound via| RB_SW
    RB_SW -->|grants| R_SW
    R_SW -.->|create scheduled<br/>workflows| Perm_Pipeline

    SA_Argo -->|bound via| RB_Argo
    RB_Argo -->|grants| R_Argo
    R_Argo -.->|manage workflow<br/>pods| Perm_Core

    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -.->|task execution<br/>permissions| Perm_Core

    %% Aggregated view role
    CR_AdminView -->|provides| Perm_AdminView

