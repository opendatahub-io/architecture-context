    style JupyterTensorFlow fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterTrustyAI fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterLLM fill:#4a90e2,stroke:#333,stroke-width:2px
    style CodeServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style RStudio fill:#4a90e2,stroke:#333,stroke-width:2px
    style RuntimeMinimal fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimeDataScience fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimePyTorch fill:#7ed321,stroke:#333,stroke-width:2px
    style RuntimeTensorFlow fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebookController fill:#f5a623,stroke:#333,stroke-width:2px
    style Dashboard fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#f5a623,stroke:#333,stroke-width:2px
