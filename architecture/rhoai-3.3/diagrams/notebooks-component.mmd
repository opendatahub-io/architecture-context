graph TB
    subgraph "Notebooks Component"
        direction TB

        subgraph "Workbench Images - Jupyter"
            JupyterMinimal[Jupyter Minimal<br/>JupyterLab 4.4, Python 3.12]
            JupyterDataScience[Jupyter DataScience<br/>pandas, sklearn, numpy]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch, CUDA/ROCM]
            JupyterTensorFlow[Jupyter TensorFlow<br/>TensorFlow, CUDA/ROCM]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainability tools]
            JupyterLLM[Jupyter PyTorch+LLMCompressor<br/>Model optimization]
        end

        subgraph "Workbench Images - Other IDEs"
            CodeServer[CodeServer Workbench<br/>VS Code in browser]
            RStudio[RStudio Workbench<br/>R IDE, CPU/CUDA]
        end

        subgraph "Runtime Images"
            RuntimeMinimal[Pipeline Runtime Minimal<br/>Elyra execution]
            RuntimeDataScience[Pipeline Runtime DataScience<br/>pandas, sklearn]
            RuntimePyTorch[Pipeline Runtime PyTorch<br/>GPU support]
            RuntimeTensorFlow[Pipeline Runtime TensorFlow<br/>GPU support]
        end

        subgraph "Build Infrastructure"
            BaseImages[Base Images<br/>CPU/CUDA/ROCM foundations]
            ImageStreams[ImageStream Manifests<br/>OpenShift image catalog]
        end
    end

    subgraph "Deployment Infrastructure"
        NotebookController[odh-notebook-controller<br/>Operator]
        Dashboard[odh-dashboard<br/>UI]
        OAuthProxy[oauth-proxy<br/>Sidecar]
    end

    subgraph "User Resources"
        StatefulSet[StatefulSet<br/>Workbench Pod]
        PVC[Persistent Volume Claim<br/>User data storage]
        Service[Service 8888/TCP<br/>ClusterIP]
        Route[OpenShift Route<br/>HTTPS 443/TCP]
    end

    subgraph "External Dependencies"
        PyPI[pypi.org<br/>Python packages]
        Quay[quay.io<br/>Container registry]
        K8sAPI[Kubernetes API<br/>6443/TCP]
        S3[S3 Storage<br/>Model artifacts]
    end

    subgraph "Pipeline Integration"
        Elyra[Kubeflow Pipelines<br/>Elyra integration]
    end

    %% User workflow
    User[User] -->|selects image| Dashboard
    Dashboard -->|displays| ImageStreams
    User -->|creates workbench| NotebookController

    %% Deployment flow
    NotebookController -->|creates| StatefulSet
    NotebookController -->|creates| Service
    NotebookController -->|creates| Route
    NotebookController -->|creates| PVC
    NotebookController -->|mounts| PVC

    %% Image selection
    ImageStreams -.->|references| JupyterMinimal
    ImageStreams -.->|references| JupyterDataScience
    ImageStreams -.->|references| JupyterPyTorch
    ImageStreams -.->|references| RStudio
    ImageStreams -.->|references| CodeServer

    StatefulSet -->|uses image| JupyterMinimal
    StatefulSet -->|includes| OAuthProxy

    %% Service flow
    StatefulSet -->|exposes| Service
    Service -->|backend for| Route
    Route -->|external access| User

    %% Runtime dependencies
    StatefulSet -->|installs packages| PyPI
    StatefulSet -->|calls| K8sAPI
    StatefulSet -->|reads/writes| S3

    %% Pipeline integration
    Elyra -->|launches| RuntimeMinimal
    Elyra -->|launches| RuntimeDataScience
    Elyra -->|launches| RuntimePyTorch

    %% Build dependencies
    BaseImages -->|base for| JupyterMinimal
    BaseImages -->|base for| JupyterDataScience
    BaseImages -->|base for| JupyterPyTorch
    BaseImages -->|base for| JupyterTensorFlow
    BaseImages -->|base for| RuntimeMinimal

