graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
        Gateway["Gateway API<br/>data-science-gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge"]
        IstioGW["Istio Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph ControlPlane["CONTROL PLANE - redhat-ods-operator<br/>(ServiceAccount Token Auth)"]
        RHODSOp["RHODS Operator<br/>SA: rhods-operator<br/>8443/TCP metrics<br/>9443/TCP webhooks"]
        KServeOp["KServe Controller<br/>SA: kserve-controller-manager<br/>8443/TCP metrics<br/>9443/TCP webhooks"]
        ModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>8443/TCP metrics<br/>9443/TCP webhooks"]
        DSPOp["DSP Operator<br/>SA: ds-pipelines-operator"]
        OtherOps["11 Other Component Operators<br/>(Training, Model Reg, Feast, etc.)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES - redhat-ods-applications<br/>(OAuth Bearer Token Auth)"]
        Dashboard["ODH Dashboard<br/>SA: dashboard-sa<br/>8443/TCP kube-rbac-proxy<br/>8080/TCP React app"]
        MLflowSvc["MLflow Instances<br/>8443/TCP HTTPS<br/>Bearer Token"]
    end

    subgraph K8s["KUBERNETES CORE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>mTLS for ServiceAccounts<br/>TokenReview + RBAC"]
        OAuth["OpenShift OAuth<br/>443/TCP HTTPS<br/>OAuth 2.0/OIDC"]
    end

    subgraph UserWorkloads["USER WORKLOADS - {user-namespace}<br/>(Namespace Isolation + NetworkPolicies)"]
        direction TB

        subgraph NB["Notebooks"]
            Notebook["Jupyter StatefulSet<br/>SA: {workbench}-sa<br/>8888/TCP Jupyter<br/>8443/TCP oauth-proxy<br/>PVC: 10Gi RWO<br/>NP: Allow HTTPRoute ingress"]
        end

        subgraph IS["InferenceServices"]
            Predictor["Predictor Pod<br/>SA: {isvc}-sa<br/>8000/TCP HTTP/gRPC<br/>9000/TCP admin<br/>Istio sidecar: mTLS PERMISSIVE<br/>NP: Allow Istio gateway"]
        end

        subgraph Train["Training Jobs"]
            TrainPod["Training Pods<br/>SA: training-sa<br/>28080/TCP metrics<br/>Dynamic MPI/NCCL ports<br/>NP: Allow inter-pod + controller"]
        end

        subgraph Pipeline["Pipeline Runs"]
            PipelinePod["Argo Workflow Pods<br/>SA: pipeline-runner-sa<br/>NP: Allow DSP API, MLMD"]
        end

        subgraph MR["Model Registry"]
            ModelReg["REST API + PostgreSQL<br/>SA: model-registry-sa<br/>8443/TCP REST<br/>5432/TCP PostgreSQL<br/>NP: PostgreSQL isolation"]
        end

        subgraph Feast["Feast Feature Store"]
            FeastSvc["Online/Offline/Registry<br/>SA: feast-sa<br/>6566/TCP gRPC online<br/>8815/TCP HTTP offline<br/>6570/TCP registry"]
        end

        subgraph Trusty["TrustyAI"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-sa<br/>8080/TCP HTTP<br/>8443/TCP HTTPS<br/>Istio VirtualService"]
        end
    end

    subgraph ServiceMesh["SERVICE MESH (Optional)<br/>mTLS PERMISSIVE/STRICT"]
        Istio["Istio Service Mesh<br/>PeerAuthentication<br/>AuthorizationPolicy"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ sslmode=require<br/>Username/Password"]
        MySQL["MySQL/MariaDB<br/>3306/TCP<br/>TLS 1.2+<br/>Username/Password"]
        Redis["Redis<br/>6379/TCP<br/>TLS 1.2+ (optional)<br/>Password Auth"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token"]
        NGC["NVIDIA NGC API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key"]
        Registry["Image Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>Pull Secrets"]
        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% User to Platform
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Router
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| IstioGW

    %% Ingress to Services
    Router -->|"HTTPS/8443<br/>Bearer Token<br/>kube-rbac-proxy"| Dashboard
    Gateway -->|"HTTP/8888<br/>Bearer Token<br/>oauth-proxy"| Notebook
    Gateway -->|"HTTPS/8443<br/>Bearer Token"| MLflowSvc
    IstioGW -->|"HTTP/8000<br/>mTLS PERMISSIVE<br/>Service Identity"| Predictor

    %% Authentication
    Router -->|"OAuth Flow"| OAuth
    Gateway -->|"OAuth Flow"| OAuth
    Dashboard -->|"Token Validation"| K8sAPI
    Notebook -->|"Token Validation"| K8sAPI

    %% Operators to K8s API
    RHODSOp -->|"HTTPS/6443<br/>ServiceAccount Token<br/>TokenReview + RBAC"| K8sAPI
    KServeOp -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    ModelCtrl -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    DSPOp -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    OtherOps -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    Dashboard -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI

    %% Workloads to K8s API
    Notebook -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    Predictor -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    TrainPod -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI
    PipelinePod -->|"HTTPS/6443<br/>ServiceAccount Token"| K8sAPI

    %% Service Mesh
    Predictor -.->|"mTLS PERMISSIVE<br/>or STRICT"| Istio
    TrustyAI -.->|"mTLS + VirtualService"| Istio
    FeastSvc -.->|"mTLS (optional)"| Istio

    %% Workloads to External Services
    Notebook -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    TrainPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    PipelinePod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    ModelReg -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/Password"| PostgreSQL
    MLflowSvc -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/Password"| PostgreSQL
    FeastSvc -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/Password"| PostgreSQL
    TrustyAI -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/Password"| PostgreSQL

    PipelinePod -->|"MySQL/3306<br/>TLS 1.2+<br/>Username/Password"| MySQL

    FeastSvc -->|"Redis/6379<br/>Password"| Redis

    TrainPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Token"| HF

    ModelCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC API Key"| NGC

    RHODSOp -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets"| Registry
    KServeOp -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets"| Registry

    Notebook -->|"HTTPS/443<br/>TLS 1.2+"| PyPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef mesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px,stroke-dasharray: 5 5

    class User external
    class Router,Gateway,IstioGW ingress
    class RHODSOp,KServeOp,ModelCtrl,DSPOp,OtherOps controlplane
    class Dashboard,MLflowSvc platform
    class Notebook,Predictor,TrainPod,PipelinePod,ModelReg,FeastSvc,TrustyAI workload
    class K8sAPI,OAuth k8s
    class S3,PostgreSQL,MySQL,Redis,HF,NGC,Registry,PyPI extsvc
    class Istio mesh
