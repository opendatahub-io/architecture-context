graph TB
    subgraph "KServe Component"
        Controller[kserve-controller-manager<br/>Main Operator]
        Webhook[kserve-webhook-server<br/>Admission Webhook]
        Router[Router<br/>InferenceGraph Routing]
        LLMScheduler[llm-scheduler<br/>LLM Request Scheduling]
        LocalModelMgr[localmodel-manager<br/>Model Cache Controller]

        Controller -->|validates/mutates| Webhook
    end

    subgraph "Custom Resources"
        InferenceServiceCR[InferenceService<br/>v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>v1alpha1]
        InferenceGraphCR[InferenceGraph<br/>v1alpha1]
        LLMInferenceServiceCR[LLMInferenceService<br/>v1]
        TrainedModelCR[TrainedModel<br/>v1alpha1]
        LocalModelCacheCR[LocalModelCache<br/>v1alpha1]
    end

    subgraph "Runtime Pods"
        StorageInit[storage-initializer<br/>Init Container]
        Agent[agent<br/>Sidecar]
        Predictor[Predictor Pod<br/>Framework Runtime]

        StorageInit -->|downloads models| Predictor
        Agent -->|logging/batching| Predictor
    end

    subgraph "Node-Level Components"
        LocalNodeAgent[localmodelnode-agent<br/>DaemonSet]
        LocalNodeAgent -->|manages cache| LocalDisk[Local Disk Cache]
    end

    User[User/Dashboard] -->|creates| InferenceServiceCR
    User -->|creates| InferenceGraphCR
    User -->|creates| LLMInferenceServiceCR

    InferenceServiceCR -->|watched by| Controller
    ServingRuntimeCR -->|watched by| Controller
    InferenceGraphCR -->|watched by| Controller
    LLMInferenceServiceCR -->|watched by| Controller
    TrainedModelCR -->|watched by| Controller
    LocalModelCacheCR -->|watched by| LocalModelMgr

    Controller -->|creates| KnativeService[Knative Service]
    Controller -->|creates| Deployment[Deployment]
    Controller -->|creates| VirtualService[Istio VirtualService]
    Controller -->|creates| Route[OpenShift Route]

    InferenceGraphCR -->|creates| Router
    Router -->|routes to| Predictor

    LLMInferenceServiceCR -->|creates| LLMScheduler
    LLMScheduler -->|schedules to| PrefillWorker[Prefill Worker<br/>LeaderWorkerSet]
    LLMScheduler -->|schedules to| DecodeWorker[Decode Worker<br/>LeaderWorkerSet]

    subgraph "External Dependencies"
        Istio[Istio Service Mesh]
        Knative[Knative Serving]
        CertManager[cert-manager]
        S3[S3 Storage]
        GCS[Google Cloud Storage]
        Azure[Azure Blob Storage]
    end

    Controller -->|depends on| Istio
    Controller -->|depends on| Knative
    Controller -->|depends on| CertManager
    StorageInit -->|downloads from| S3
    StorageInit -->|downloads from| GCS
    StorageInit -->|downloads from| Azure

    subgraph "Internal ODH/RHOAI Dependencies"
        Dashboard[ODH Dashboard]
        ModelRegistry[Model Registry]
        ServiceMesh[Service Mesh OSSM]
        Pipelines[Data Science Pipelines]
    end

    Dashboard -->|UI management| Controller
    Predictor -->|integrates| ModelRegistry
    Controller -->|configures| ServiceMesh
    Pipelines -->|provides models| S3

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style Predictor fill:#7ed321,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333
    style Knative fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
