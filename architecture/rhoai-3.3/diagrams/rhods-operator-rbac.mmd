graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: redhat-ods-operator]
    end

    subgraph "ClusterRole Binding"
        CRB[opendatahub-operator-manager<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[opendatahub-operator-manager<br/>ClusterRole<br/>⚠️ CLUSTER-ADMIN LEVEL]
    end

    subgraph "Platform CRDs"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster, status, finalizers<br/>Verbs: get,list,watch,create,update,patch,delete]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization, status, finalizers<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Component CRDs"
        CompCRDs[components.platform.opendatahub.io<br/>Dashboard, Workbenches, DataSciencePipelines,<br/>KServe, Kueue, Ray, TrustyAI, ModelRegistry,<br/>TrainingOperator, FeastOperator, MLflowOperator,<br/>LlamaStackOperator, Trainer, ModelsAsService<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Service CRDs"
        SvcCRDs[services.platform.opendatahub.io<br/>Monitoring, Auth, GatewayConfig<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Infrastructure CRDs"
        InfraCRDs[infrastructure.opendatahub.io<br/>HardwareProfile<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Core Resources"
        Core["Core API Group ('')<br/>deployments, services, configmaps,<br/>secrets, serviceaccounts, pods, pvcs<br/>Verbs: get,list,watch,create,update,patch,delete"]
        Apps[apps<br/>deployments, replicasets, statefulsets<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "RBAC Resources ⚠️"
        RBAC[rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>Verbs: ALL]
    end

    subgraph "OpenShift Resources"
        Routes[route.openshift.io<br/>routes<br/>Verbs: get,list,watch,create,update,patch,delete]
        Users[user.openshift.io<br/>users, groups<br/>Verbs: get,list,watch,patch,delete,update]
        Console[console.openshift.io<br/>consolelinks<br/>Verbs: get,list,watch,create,update,patch,delete]
        OAuthClients[oauth.openshift.io<br/>oauthclients<br/>Verbs: get,list,watch,create,update,patch,delete]
        SCC[security.openshift.io<br/>securitycontextconstraints<br/>Verbs: get,list,watch,create,patch,use]
    end

    subgraph "Networking Resources"
        Network[networking.k8s.io<br/>networkpolicies, ingresses<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Monitoring Resources"
        Monitoring[monitoring.coreos.com<br/>servicemonitors, prometheusrules,<br/>prometheuses, alertmanagers<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Operator Lifecycle Manager"
        OLM[operators.coreos.com<br/>subscriptions, clusterserviceversions,<br/>catalogsources<br/>Verbs: get,list,watch,delete,update]
    end

    subgraph "Third-Party CRDs"
        KServeAPI[serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>clusterservingruntimes<br/>Verbs: get,list,watch,create,update,patch,delete]
        RayAPI[ray.io<br/>rayclusters, rayservices, rayjobs<br/>Verbs: get,list,watch,create,update,patch,delete]
        ArgoAPI[argoproj.io<br/>workflows<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "Admission Registration"
        Webhooks[admissionregistration.k8s.io<br/>validatingwebhookconfigurations,<br/>mutatingwebhookconfigurations<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    subgraph "CRD Management"
        CRDMgmt[apiextensions.k8s.io<br/>customresourcedefinitions<br/>Verbs: get,list,watch,create,update,patch,delete]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions
    CR -.->|full control| DSC
    CR -.->|full control| DSCI
    CR -.->|full control| CompCRDs
    CR -.->|full control| SvcCRDs
    CR -.->|full control| InfraCRDs
    CR -.->|full control| Core
    CR -.->|full control| Apps
    CR -.->|ALL VERBS ⚠️| RBAC
    CR -.->|full control| Routes
    CR -.->|full control| Users
    CR -.->|full control| Console
    CR -.->|full control| OAuthClients
    CR -.->|full control + use| SCC
    CR -.->|full control| Network
    CR -.->|full control| Monitoring
    CR -.->|get,list,watch,delete,update| OLM
    CR -.->|full control| KServeAPI
    CR -.->|full control| RayAPI
    CR -.->|full control| ArgoAPI
    CR -.->|full control| Webhooks
    CR -.->|full control| CRDMgmt

