graph LR
    DSPO[Data Science Pipelines Operator]

    %% External Platform Dependencies
    DSPO -->|"platform<br/>orchestration"| K8s[Kubernetes/OpenShift 4.11+]
    DSPO -->|"workflow execution<br/>embedded<br/>namespace-scoped"| Argo[Argo Workflows]
    DSPO -.->|"optional<br/>certificate mgmt"| CertManager[cert-manager]

    %% Database Dependencies (Required - choice of internal or external)
    DSPO -->|"metadata storage<br/>REQUIRED"| DBChoice{Database Choice}
    DBChoice -->|"dev/test<br/>auto-deployed"| MariaDB[MariaDB 10.3+]
    DBChoice -->|"production<br/>external"| ExternalDB[External MySQL/MariaDB]

    %% Storage Dependencies (Required - choice of internal or external)
    DSPO -->|"artifact storage<br/>REQUIRED"| StorageChoice{Storage Choice}
    StorageChoice -->|"dev/test<br/>auto-deployed"| Minio[Minio S3-compatible]
    StorageChoice -->|"production<br/>external"| ExternalS3[AWS S3 / S3-compatible]

    %% Internal ODH Dependencies
    DSPO -.->|"UI integration<br/>pipeline mgmt"| Dashboard[ODH Dashboard]
    DSPO -.->|"pipeline submission<br/>KFP SDK client"| Workbenches[Workbenches/Notebooks]
    DSPO -.->|"metrics collection<br/>ServiceMonitor"| Monitoring[OpenShift Monitoring]
    DSPO -.->|"deployment mgmt<br/>DSC component"| ODHOperator[ODH Operator]
    DSPO -.->|"optional<br/>model deployment"| KServe[KServe]

    %% External Services
    DSPO -->|"container images<br/>task execution"| ImageRegistry[Image Registries<br/>quay.io, registry.redhat.io]
    K8s -->|"API server"| K8sAPI[Kubernetes API Server<br/>6443/TCP]

    %% Integration Points (reverse dependencies - components that use DSPO)
    Dashboard -->|"UI calls"| DSPO
    Workbenches -->|"API calls<br/>KFP SDK"| DSPO
    ODHOperator -->|"manages via<br/>DataScienceCluster CR"| DSPO

    %% Optional ML Metadata
    DSPO -.->|"optional<br/>artifact lineage"| MLMD[ML Metadata<br/>Embedded]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style K8s fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Argo fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style CertManager fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#000
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff

    style DBChoice fill:#fff,stroke:#333,stroke-width:2px,color:#000
    style MariaDB fill:#ed7d31,stroke:#333,stroke-width:2px,color:#fff
    style ExternalDB fill:#ed7d31,stroke:#333,stroke-width:2px,color:#fff

    style StorageChoice fill:#fff,stroke:#333,stroke-width:2px,color:#000
    style Minio fill:#ffc000,stroke:#333,stroke-width:2px,color:#000
    style ExternalS3 fill:#ffc000,stroke:#333,stroke-width:2px,color:#000

    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Workbenches fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Monitoring fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServe fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#000

    style MLMD fill:#9673a6,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    style ImageRegistry fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
