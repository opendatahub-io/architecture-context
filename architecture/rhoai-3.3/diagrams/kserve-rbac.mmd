graph TD
    subgraph "Service Account"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB[kserve-manager-rolebinding<br/>ClusterRoleBinding]
        LeaderElectionRB[kserve-leader-election-rolebinding<br/>RoleBinding - kserve namespace]
        ProxyRB[kserve-proxy-rolebinding<br/>RoleBinding - kserve namespace]
    end

    subgraph "ClusterRole Permissions"
        CR[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "KServe API Resources"
        ISVC[serving.kserve.io<br/>InferenceService<br/>ClusterServingRuntime<br/>ServingRuntime<br/>InferenceGraph<br/>TrainedModel<br/>LLMInferenceService<br/>LLMInferenceServiceConfig<br/>LocalModelCache<br/>ClusterStorageContainer]
    end

    subgraph "Knative API Resources"
        KnativeSvc[serving.knative.dev<br/>Services]
    end

    subgraph "Istio API Resources"
        IstioRes[networking.istio.io<br/>VirtualServices<br/>DestinationRules]
    end

    subgraph "Core Kubernetes Resources"
        CoreRes[apps: Deployments<br/>core: Services, ServiceAccounts<br/>Secrets, ConfigMaps, Events<br/>Namespaces, Pods<br/>autoscaling: HorizontalPodAutoscalers]
    end

    subgraph "Networking Resources"
        NetRes[networking.k8s.io: Ingresses<br/>route.openshift.io: Routes<br/>gateway.networking.k8s.io:<br/>GatewayClasses, Gateways, HTTPRoutes<br/>discovery.k8s.io: EndpointSlices]
    end

    subgraph "Autoscaling & Observability"
        AutoObs[keda.sh: ScaledObjects<br/>monitoring.coreos.com:<br/>ServiceMonitors, PodMonitors<br/>opentelemetry.io:<br/>OpenTelemetryCollectors]
    end

    subgraph "Advanced Resources"
        AdvRes[leaderworkerset.x-k8s.io:<br/>LeaderWorkerSets<br/>inference.networking.k8s.io:<br/>InferencePools, InferenceModels<br/>InferenceObjectives<br/>admissionregistration.k8s.io:<br/>MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations<br/>rbac.authorization.k8s.io:<br/>ClusterRoleBindings, RoleBindings, Roles]
    end

    subgraph "Security & Auth"
        SecAuth[authentication.k8s.io:<br/>TokenReviews, SubjectAccessReviews<br/>security.openshift.io:<br/>SecurityContextConstraints<br/>openshift-ai-llminferenceservice-scc]
    end

    subgraph "Verbs"
        AllVerbs[create, delete, get, list,<br/>patch, update, watch]
        ReadVerbs[get, list, watch]
        CreateVerbs[create]
        UseVerbs[use]
        GetVerbs[get - /metrics non-resource URL]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderElectionRB
    SA -->|bound via| ProxyRB
    CRB -->|grants| CR

    %% Permissions
    CR -->|ALL verbs| ISVC
    CR -->|ALL verbs| KnativeSvc
    CR -->|ALL verbs| IstioRes
    CR -->|ALL verbs<br/>except Namespaces/Pods<br/>get,list,watch only| CoreRes
    CR -->|ALL verbs| NetRes
    CR -->|ALL verbs| AutoObs
    CR -->|ALL verbs| AdvRes
    CR -->|create only| SecAuth
    CR -->|use SCC| SecAuth
    CR -->|get /metrics| GetVerbs

    %% Detailed permissions notes
    ISVC -.->|Includes finalizers and status<br/>subresources| AllVerbs
    KnativeSvc -.->|Includes finalizers and status<br/>subresources| AllVerbs
    IstioRes -.->|Includes finalizers and status<br/>subresources| AllVerbs

    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR fill:#f5a623,stroke:#333,stroke-width:3px
    style CRB fill:#7ed321,stroke:#333,stroke-width:2px

    style ISVC fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style KnativeSvc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style IstioRes fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CoreRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NetRes fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style AutoObs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style AdvRes fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style SecAuth fill:#f5f5f5,stroke:#666,stroke-width:2px

    style AllVerbs fill:#7ed321,stroke:#333
    style ReadVerbs fill:#999,stroke:#333
    style CreateVerbs fill:#f5a623,stroke:#333
    style UseVerbs fill:#f5a623,stroke:#333
    style GetVerbs fill:#999,stroke:#333
