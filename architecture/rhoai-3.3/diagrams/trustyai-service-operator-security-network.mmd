    %% External flows
    Client -->|"HTTPS/443<br/>OpenShift auth"| TASRoute
    Client -->|"HTTPS/443<br/>OpenShift auth"| GORCHRoute
    Client -->|"HTTPS/443<br/>OpenShift auth"| NEMORoute

    %% Route to service flows
    TASRoute -->|"HTTPS/8443<br/>TLS reencrypt"| TASKRBP
    GORCHRoute -->|"HTTPS/8432<br/>TLS reencrypt"| GKRBP
    NEMORoute -->|"HTTPS/8443<br/>TLS reencrypt"| NKRBP

    %% Internal service flows
    TASKRBP -->|"HTTP/8080<br/>localhost"| TASSvc
    GKRBP -->|"HTTPS/8032<br/>serving cert"| GOrch
    GOrch -->|"HTTP/8080<br/>localhost"| GDetector
    GOrch -->|"HTTPS<br/>mTLS optional"| ExtDetectors
    NKRBP -->|"HTTP/8000<br/>localhost"| NServer

    %% Operator flows
    Operator -->|"HTTPS/443<br/>SA Token"| K8sAPI
    TASSvc -->|"HTTPS/TLS<br/>service cert"| InfSvc
    Prometheus -->|"HTTP/8080"| Operator
    Prometheus -->|"HTTP/8080"| TASSvc
    CertSigner -.->|"auto-provision"| TASKRBP
    CertSigner -.->|"auto-provision"| GKRBP

