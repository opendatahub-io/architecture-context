graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (OpenShift)"]
        Route["OpenShift Route<br/>{trustyai-name}<br/>443/TCP<br/>TLS Reencrypt"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            TrustyAI["TrustyAI Service<br/>SA: {trustyai-name}-sa<br/>Ports: 80/8080, 443/4443, 443/8443<br/>Image: trustyai-service"]
            Guardrails["Guardrails Orchestrator<br/>SA: {orchestrator-name}-sa<br/>443/TCP HTTPS"]
            LMEval["LMEvalJob Pod<br/>SA: {lmevaljob-name}-sa<br/>Job-based execution"]
        end

        subgraph NS_KServe["KServe InferenceServices"]
            InferenceService["InferenceService<br/>80/443 HTTP/HTTPS<br/>mTLS"]
            DetectorServices["Detector Services<br/>80/443 HTTP/HTTPS<br/>mTLS"]
            LLMService["LLM Service<br/>80/443 HTTP/HTTPS<br/>mTLS"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: trustyai-operator-system"]
            Operator["TrustyAI Operator<br/>SA: controller-manager"]
            MetricsService["Metrics Endpoint<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
        end

        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>API Token (optional)"]
        Database["Database<br/>PostgreSQL/MySQL<br/>JDBC TLS (optional)<br/>Username/Password"]
        PVC["PersistentVolumeClaim<br/>Filesystem Storage"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Reencrypt| Route

    %% Ingress to Service Mesh
    Route -->|HTTPS/443<br/>TLS service-serving cert<br/>mTLS| TrustyAI

    %% Service Mesh Flows
    InferenceService -->|HTTP/HTTPS 80/443<br/>mTLS Istio<br/>Service Identity| TrustyAI
    TrustyAI -->|Store Data<br/>JDBC/Filesystem| Database
    TrustyAI -->|Store Data<br/>Filesystem| PVC

    Guardrails -->|HTTP/HTTPS 80/443<br/>mTLS Istio| DetectorServices
    Guardrails -->|HTTP/HTTPS 80/443<br/>mTLS Istio| LLMService

    LMEval -->|HTTPS/443<br/>TLS 1.2+<br/>API Token| HuggingFace
    LMEval -->|gRPC/HTTP<br/>TLS| InferenceService

    %% Control Plane Flows
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Operator -->|Creates/Manages| TrustyAI
    Operator -->|Creates/Manages| Guardrails
    Operator -->|Creates/Manages| LMEval
    Operator -->|Patches| InferenceService

    Prometheus -->|HTTP/8443<br/>Bearer Token<br/>kube-rbac-proxy| MetricsService
    Prometheus -->|HTTP/8080<br/>GET /q/metrics| TrustyAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI,Guardrails,LMEval,InferenceService,DetectorServices,LLMService servicemesh
    class Operator,MetricsService,K8sAPI,Prometheus controlplane
    class HuggingFace,Database,PVC externalservice
