%% OpenVINO Model Server - RBAC & Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: OVMS does not define its own RBAC roles.
%% RBAC is managed by deploying controllers (KServe/ModelMesh).
%% This diagram shows the security context and auth mechanisms.

graph TD
    subgraph ContainerSecurity["Container Security Context"]
        User["User: ovms<br/>UID: 5000"]
        Group["Group: ovms<br/>GID: 5000"]
        SupGroups["Supplementary Groups<br/>39 (video), 44 (video1)<br/>GPU Access"]
        BaseImage["Base Image<br/>ubi9-minimal:9.7"]
        FIPS["FIPS Compliant: Yes"]
        Entrypoint["Entrypoint<br/>/ovms/bin/ovms"]
    end

    subgraph DeployerRBAC["Deployer RBAC (KServe/ModelMesh)"]
        KServeController["KServe Controller<br/>ServiceAccount"]
        KServeCR["ClusterRole<br/>kserve-manager-role"]
        KServeCRB["ClusterRoleBinding<br/>kserve-manager-rolebinding"]

        KServeController -->|"bound via"| KServeCRB
        KServeCRB -->|"grants"| KServeCR
    end

    subgraph APIResources["Kubernetes Resources Managed"]
        InferenceService["serving.kserve.io<br/>InferenceService"]
        ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
        Pods["core<br/>Pods"]
        Services["core<br/>Services"]
        Deployments["apps<br/>Deployments"]
    end

    KServeCR -->|"create, update, delete"| InferenceService
    KServeCR -->|"create, update, delete"| ServingRuntime
    KServeCR -->|"create, update, delete"| Pods
    KServeCR -->|"create, update, delete"| Services
    KServeCR -->|"create, update, delete"| Deployments

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        APIKeyAuth["API Key Auth<br/>--api_key_file / API_KEY env<br/>Protects: /v3/* endpoints<br/>Optional"]
        GatewayAuth["Gateway Auth<br/>Platform Gateway (Envoy)<br/>Bearer Token<br/>TLS 1.2+ termination"]
        RBACProxyAuth["kube-rbac-proxy<br/>Sidecar container<br/>RBAC authorization<br/>Port 8443/TCP"]
        NoAuth["No Built-in Auth<br/>/v1/*, /v2/*, gRPC, /metrics<br/>Relies on gateway/proxy"]
    end

    subgraph Secrets["Secrets"]
        APIKeySecret["API Key File<br/>Type: Opaque (file)<br/>Purpose: Generative endpoint auth<br/>Provisioned: User/Platform<br/>Rotation: Manual"]
        HFTokenSecret["HF_TOKEN<br/>Type: Env Variable<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: User<br/>Rotation: Manual"]
        StorageCreds["Cloud Storage Credentials<br/>Type: Various<br/>Purpose: S3/GCS/Azure auth<br/>Provisioned: User/Platform<br/>Rotation: Manual"]
    end

    GatewayAuth --> RBACProxyAuth
    RBACProxyAuth -->|"authorized"| NoAuth

