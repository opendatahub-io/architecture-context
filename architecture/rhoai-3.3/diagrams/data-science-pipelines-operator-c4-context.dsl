// Data Science Pipelines Operator - C4 Context Diagram
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.3/data-science-pipelines-operator.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages ML pipelines via Dashboard or API"

        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Kubernetes operator managing lifecycle of ML pipeline infrastructure per namespace" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs and reconciles all pipeline infrastructure components" "Go Operator (controller-runtime)"
            webhook = container "DS Pipelines Webhook" "Validates and mutates PipelineVersion CRs" "Go Webhook Server"
            apiServer = container "DS Pipelines API Server" "REST/gRPC API for pipeline management (per-DSPA)" "Go Service"
            kubeRBACProxy = container "kube-rbac-proxy" "RBAC-based authentication proxy sidecar for API Server and MLMD Envoy" "Sidecar"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo Workflows to database (per-DSPA)" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow" "Manages cron-scheduled pipeline runs (per-DSPA)" "Go Service"
            workflowController = container "Workflow Controller" "Argo Workflow controller for pipeline orchestration (per-DSPA, optional)" "Go Controller"
            mlmdGRPC = container "MLMD gRPC Server" "ML Metadata gRPC service for artifact/execution tracking (per-DSPA)" "gRPC Service"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting the MLMD gRPC server (per-DSPA)" "Envoy"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys DSPO via kustomize overlays" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "Pipeline management UI" "Internal RHOAI"
        openshiftServiceCA = softwareSystem "OpenShift Service CA" "Provides TLS certificates for pod-to-pod communication" "Platform"
        openshiftRouter = softwareSystem "OpenShift Router" "Exposes API Server and MLMD externally via Routes" "Platform"
        argoWorkflows = softwareSystem "Argo Workflows" "Pipeline execution via Workflow CRs" "Internal"
        kserve = softwareSystem "KServe" "ML model serving for inference from pipeline steps" "Internal RHOAI"
        codeflareRay = softwareSystem "CodeFlare/Ray" "Distributed compute via AppWrappers and RayClusters" "Internal RHOAI"
        mariaDB = softwareSystem "MariaDB" "Pipeline metadata storage (internal or external)" "Database"
        s3Store = softwareSystem "S3-compatible Object Store" "Pipeline artifact storage (Minio or external)" "Storage"
        k8sAPI = softwareSystem "Kubernetes API" "Resource management, RBAC, SAR checks" "Platform"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Platform"

        // Relationships
        user -> dashboard "Manages pipelines via UI"
        user -> dspo "Creates DSPA CRs via kubectl"
        dashboard -> openshiftRouter "REST API calls" "HTTPS/443"
        openshiftRouter -> kubeRBACProxy "Reencrypt TLS" "HTTPS/8443"
        kubeRBACProxy -> apiServer "Proxied requests" "HTTPS/8888"
        kubeRBACProxy -> k8sAPI "SubjectAccessReview checks" "HTTPS/6443"

        rhodsOperator -> dspo "Deploys via kustomize overlay"
        openshiftServiceCA -> dspo "Injects TLS certificates"

        controller -> apiServer "Creates/manages per-DSPA"
        controller -> persistenceAgent "Creates/manages per-DSPA"
        controller -> scheduledWorkflow "Creates/manages per-DSPA"
        controller -> workflowController "Creates/manages per-DSPA"
        controller -> mlmdGRPC "Creates/manages per-DSPA"
        controller -> mlmdEnvoy "Creates/manages per-DSPA"
        controller -> mariaDB "Health checks" "MySQL/3306"
        controller -> s3Store "Health checks" "S3 API"
        controller -> k8sAPI "Resource CRUD" "HTTPS/6443"

        apiServer -> mariaDB "Stores pipeline metadata" "MySQL/3306"
        apiServer -> s3Store "Stores pipeline artifacts" "HTTPS/443"
        apiServer -> k8sAPI "Creates Workflow CRs" "HTTPS/6443"
        apiServer -> kserve "Creates InferenceServices"
        apiServer -> codeflareRay "Creates AppWrappers/RayClusters"

        persistenceAgent -> apiServer "Polls run status" "HTTPS/8888"
        persistenceAgent -> k8sAPI "Watches Workflow status" "HTTPS/6443"
        scheduledWorkflow -> k8sAPI "Creates scheduled Workflows" "HTTPS/6443"

        mlmdEnvoy -> mlmdGRPC "Proxies gRPC" "gRPC"
        mlmdGRPC -> mariaDB "Stores metadata" "MySQL/3306"

        argoWorkflows -> workflowController "Executes pipelines via CRDs"
        prometheus -> controller "Scrapes metrics" "HTTP/8080"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #4a90e2
                color #ffffff
            }
            element "Database" {
                background #9b59b6
                color #ffffff
            }
            element "Storage" {
                background #f5a623
                color #ffffff
            }
            element "Internal" {
                background #50c878
                color #ffffff
            }
        }
    }
}
