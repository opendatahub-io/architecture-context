// RHOAI 3.3 Platform C4 Context Diagram (Structurizr DSL)
// Generated by Claude Opus 4.6

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Develops and trains ML models using notebooks and pipelines"
        mlEngineer = person "ML Engineer" "Deploys, serves, and monitors models in production"
        platformAdmin = person "Platform Administrator" "Manages RHOAI platform configuration and lifecycle"

        // RHOAI Platform
        rhoai = softwareSystem "Red Hat OpenShift AI 3.3" "Comprehensive AI/ML platform on OpenShift" {

            // Control Plane
            rhodsOperator = container "rhods-operator" "Central control plane managing all RHOAI components via DSC/DSCI CRDs" "Go 1.25 OLM Operator"
            dashboard = container "odh-dashboard" "Platform UI for workbenches, model serving, pipelines, settings" "TypeScript/React"
            authProxy = container "kube-auth-proxy" "OAuth2/OIDC proxy for Gateway API authentication" "Go 1.24"
            gateway = container "data-science-gateway" "Envoy-based Gateway API ingress with TLS termination" "Envoy"

            // Model Serving
            kserve = container "KServe" "Core model serving with InferenceService, LLMInferenceService CRDs" "Go 1.23 Operator"
            modelController = container "odh-model-controller" "Model serving infra: Routes, ServiceMonitors, AuthPolicies" "Go 1.24 Controller"
            servingRuntimes = container "Serving Runtimes" "vLLM, OpenVINO, MLServer, Llama Stack inference engines" "Multi-language"
            llmdScheduler = container "llm-d EPP" "Endpoint Picker for disaggregated LLM serving" "Go 1.24"
            maas = container "Models-as-a-Service" "API gateway with token/key management and rate limiting" "Go 1.24"

            // Training
            trainingOperator = container "Training Operator" "Kubeflow Training Operator v1 (PyTorchJob, TFJob, etc.)" "Go 1.25 Operator"
            trainer = container "Trainer" "Kubeflow Trainer v2 (TrainJob/TrainingRuntime + JobSet)" "Go 1.24 Operator"
            kuberay = container "KubeRay" "Ray cluster operator (RayCluster, RayJob, RayService)" "Go 1.24 Operator"

            // Pipelines
            dspo = container "DS Pipelines Operator" "Manages per-namespace pipeline infrastructure (DSPA CRs)" "Go 1.22 Operator"
            dsPipelines = container "DS Pipelines" "Kubeflow Pipelines (API server, persistence agent, cache)" "Go/Python"
            argoWorkflows = container "Argo Workflows" "Workflow engine for pipeline execution" "Go 1.25"
            mlMetadata = container "ML Metadata" "Pipeline artifact tracking (gRPC, MySQL/PostgreSQL backend)" "C++ gRPC"

            // Registry & Tracking
            modelRegistryOp = container "Model Registry Operator" "Manages ModelRegistry CRs with PostgreSQL provisioning" "Go Operator"
            modelRegistry = container "Model Registry" "Model metadata REST API, CSI driver, catalog integration" "Go/Python"
            mlflowOperator = container "MLflow Operator" "Manages MLflow CRs with Helm rendering, HTTPRoute" "Go 1.24 Operator"
            mlflow = container "MLflow Server" "Experiment tracking with K8s workspace provider" "Python"
            feast = container "Feast" "Feature store operator (FeatureStore CRD)" "Go/Python Operator"

            // AI Safety
            trustyaiOperator = container "TrustyAI Service Operator" "Multi-controller: TrustyAI, LMEval, Guardrails, NeMo" "Go 1.23 Operator"
            trustyai = container "TrustyAI Explainability" "Fairness metrics (SPD, DIR), bias tracking, drift detection" "Java 17 (Quarkus)"
            guardrailsOrch = container "Guardrails Orchestrator" "Content moderation coordinating detectors and LLM backends" "Rust"
            nemoGuardrails = container "NeMo Guardrails" "Programmable guardrails with Colang DSL" "Python"
            lmEval = container "LM Evaluation Harness" "LLM evaluation (50+ metrics, 1200+ benchmarks)" "Python"

            // Workbenches
            notebookController = container "Notebook Controller" "Notebook CRD, creates StatefulSets, idle culling" "Go 1.22"
            notebooks = container "Notebook Images" "Jupyter, Code Server, RStudio workbench images" "Multi-language"

            // Llama Stack
            llamaStackOp = container "Llama Stack Operator" "Manages LlamaStackDistribution CRs" "Go 1.24 Operator"
            llamaStackDistro = container "Llama Stack Distribution" "Llama Stack API server (inference, eval, safety)" "Python"
        }

        // External Systems
        openshift = softwareSystem "OpenShift Container Platform" "Kubernetes platform (v4.19-v4.21)" "External"
        istio = softwareSystem "Istio / Service Mesh" "mTLS, traffic routing, EnvoyFilter" "External"
        gatewayAPI = softwareSystem "Kubernetes Gateway API" "Gateway, GatewayClass, HTTPRoute CRDs" "External"
        kuadrant = softwareSystem "Kuadrant" "API management: AuthPolicy, RateLimitPolicy (Authorino)" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection, alerting, ServiceMonitor" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate lifecycle management" "External"
        kueue = softwareSystem "Kueue" "Job queueing and resource management" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and upgrades" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Model artifacts, pipeline artifacts" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model downloads and hosting" "External"
        database = softwareSystem "MySQL/PostgreSQL" "Metadata persistence for pipelines, registry, MLflow" "External"
        oauthProvider = softwareSystem "OAuth/OIDC Provider" "User authentication (OpenShift OAuth or external OIDC)" "External"
        containerRegistry = softwareSystem "Container Registry" "registry.redhat.io, quay.io (82 images)" "External"

        // Relationships - Users
        dataScientist -> rhoai "Creates notebooks, runs experiments, submits training jobs"
        mlEngineer -> rhoai "Deploys models, configures serving, manages pipelines"
        platformAdmin -> rhoai "Configures DSC/DSCI, manages platform lifecycle"

        // Relationships - External
        rhoai -> openshift "Runs on" "Kubernetes API/6443"
        rhoai -> istio "Uses for mTLS, traffic routing" "CRDs"
        rhoai -> gatewayAPI "Uses for platform ingress" "Gateway/HTTPRoute"
        rhoai -> kuadrant "Uses for API management" "AuthPolicy/RateLimitPolicy"
        rhoai -> prometheus "Exports metrics" "ServiceMonitor/PrometheusRule"
        rhoai -> certManager "Optional TLS management" "Certificate CRDs"
        rhoai -> kueue "Job scheduling" "Workload CRDs"
        rhoai -> olm "Installed and upgraded via" "CSV/Subscription"
        rhoai -> s3Storage "Stores model/pipeline artifacts" "HTTPS/443"
        rhoai -> huggingface "Downloads models" "HTTPS/443"
        rhoai -> database "Persists metadata" "TCP/3306 or 5432"
        rhoai -> oauthProvider "Authenticates users" "OAuth2/OIDC HTTPS/443"
        rhoai -> containerRegistry "Pulls container images" "HTTPS/443"

        // Internal relationships
        rhodsOperator -> dashboard "Deploys" "Kustomize"
        rhodsOperator -> kserve "Deploys" "Kustomize"
        rhodsOperator -> modelController "Deploys" "Kustomize"
        rhodsOperator -> dspo "Deploys" "Kustomize"
        rhodsOperator -> trainingOperator "Deploys" "Kustomize"
        rhodsOperator -> trainer "Deploys" "Kustomize"
        rhodsOperator -> kuberay "Deploys" "Kustomize"
        rhodsOperator -> trustyaiOperator "Deploys" "Kustomize"
        rhodsOperator -> modelRegistryOp "Deploys" "Kustomize"
        rhodsOperator -> feast "Deploys" "Kustomize"
        rhodsOperator -> llamaStackOp "Deploys" "Kustomize"
        rhodsOperator -> mlflowOperator "Deploys" "Kustomize"
        rhodsOperator -> maas "Deploys" "Kustomize"
        rhodsOperator -> authProxy "Configures" "DSCI"
        rhodsOperator -> gateway "Creates" "Gateway API"

        gateway -> authProxy "ext_authz" "HTTPS/8443"
        authProxy -> oauthProvider "Validates tokens" "HTTPS/443"

        kserve -> servingRuntimes "Creates" "InferenceService"
        modelController -> kserve "Watches InferenceService" "API"
        dspo -> dsPipelines "Deploys" "DSPA CR"
        dspo -> argoWorkflows "Deploys" "Per-DSPA"
        dspo -> mlMetadata "Deploys" "Per-DSPA"
        trustyaiOperator -> trustyai "Deploys" "TrustyAIService CR"
        trustyaiOperator -> guardrailsOrch "Deploys" "GuardrailsOrchestrator CR"
        trustyaiOperator -> nemoGuardrails "Deploys" "NemoGuardrails CR"
        trustyaiOperator -> lmEval "Creates" "LMEvalJob CR"
        modelRegistryOp -> modelRegistry "Deploys" "ModelRegistry CR"
        mlflowOperator -> mlflow "Deploys" "MLflow CR"
        llamaStackOp -> llamaStackDistro "Deploys" "LlamaStackDistribution CR"
        notebookController -> notebooks "Creates StatefulSets" "Notebook CR"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
