%% ModelMesh Serving - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA[modelmesh-controller<br/>ServiceAccount]
    end

    subgraph "Role Bindings"
        CRB1[modelmesh-controller-role-binding<br/>ClusterRoleBinding]
        CRB2[proxy-role-binding<br/>ClusterRoleBinding]
        RB1[modelmesh-controller-leader-election-role<br/>RoleBinding<br/>controller namespace]
    end

    subgraph "Roles"
        CR1[modelmesh-controller-role<br/>ClusterRole]
        CR2[proxy-role<br/>ClusterRole]
        R1[modelmesh-controller-leader-election-role<br/>Role]
    end

    subgraph CoreAPI["Core API Resources"]
        ConfigMaps["ConfigMaps<br/>create, delete, get, list,<br/>patch, update, watch"]
        Endpoints["Endpoints<br/>get, list, watch"]
        PVCs["PersistentVolumeClaims<br/>get, list, watch"]
        Namespaces["Namespaces + Finalizers<br/>get, list, patch,<br/>update, watch"]
        Secrets["Secrets<br/>create, delete, get, list,<br/>patch, update, watch"]
        Services["Services + Finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "Apps API Resources"
        Deployments["Deployments + Finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "serving.kserve.io Resources"
        ServingRuntimes["ServingRuntimes<br/>+ finalizers + status<br/>CRUD + watch"]
        ClusterServingRuntimes["ClusterServingRuntimes<br/>+ finalizers + status<br/>CRUD + watch"]
        Predictors["Predictors<br/>+ finalizers + status<br/>CRUD + watch"]
        InferenceServices["InferenceServices<br/>+ finalizers + status<br/>CRUD + watch"]
    end

    subgraph "Monitoring Resources"
        ServiceMonitors["ServiceMonitors<br/>monitoring.coreos.com<br/>CRUD + watch"]
    end

    subgraph "Autoscaling Resources"
        HPAs["HorizontalPodAutoscalers<br/>+ status<br/>get, list, watch,<br/>create, delete, update"]
    end

    subgraph "Auth API Resources"
        TokenReviews["TokenReviews<br/>authentication.k8s.io<br/>create"]
        SAR["SubjectAccessReviews<br/>authorization.k8s.io<br/>create"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% CR1 permissions
    CR1 -->|manages| ConfigMaps
    CR1 -->|reads| Endpoints
    CR1 -->|reads| PVCs
