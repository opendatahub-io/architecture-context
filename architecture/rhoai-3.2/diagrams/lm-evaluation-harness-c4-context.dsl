/* C4 Context Diagram - lm-evaluation-harness
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Triggers model evaluations via LMEvalJob CRD"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Batch container for evaluating language models against standardized benchmarks using EleutherAI lm-evaluation-harness" {
            cli = container "lm_eval CLI" "Main entry point for running evaluation tasks" "Python CLI"
            evaluator = container "Evaluator Engine" "Core evaluation orchestration: loads models, runs tasks, aggregates results" "Python Module"
            modelBackends = container "Model Backends" "19 model backend adapters (HuggingFace, vLLM, SGLang, OpenAI, Anthropic, etc.)" "Python Modules"
            taskFramework = container "Task Framework" "150+ task categories with YAML-driven task definitions and Unitxt integration" "Python/YAML"
            offlineMetrics = container "Offline Metrics" "53 bundled evaluation metrics for disconnected environments" "Python/YAML"
            s3Downloader = container "S3 Downloader" "Downloads model artifacts from S3-compatible storage" "Python Script"
            ociPublisher = container "OCI Artifact Publisher" "Publishes evaluation results as OCI artifacts using olot + skopeo" "Python Script"
            cache = container "Caching Module" "SQLite-based caching for model responses" "Python Module"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages LMEvalJob lifecycle via CRD" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and dataset artifact repository" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for model weights" "External"
        ociRegistry = softwareSystem "OCI Container Registry" "Container registry for result artifacts" "External"
        openaiAPI = softwareSystem "OpenAI API" "Remote model inference endpoint" "External"
        anthropicAPI = softwareSystem "Anthropic API" "Remote model inference endpoint" "External"
        watsonxAPI = softwareSystem "IBM WatsonX API" "Remote model inference endpoint" "External"
        localInference = softwareSystem "Local Inference Servers" "In-cluster model servers (vLLM, etc.)" "Internal"

        dataScientist -> trustyaiOperator "Creates LMEvalJob CR via kubectl/dashboard"
        trustyaiOperator -> lmEvalHarness "Creates Kubernetes Job using container image"
        lmEvalHarness -> huggingfaceHub "Downloads models and datasets" "HTTPS/443"
        lmEvalHarness -> s3Storage "Downloads model weights" "HTTPS/443"
        lmEvalHarness -> ociRegistry "Publishes evaluation results" "HTTPS/443"
        lmEvalHarness -> openaiAPI "Remote model evaluation" "HTTPS/443"
        lmEvalHarness -> anthropicAPI "Remote model evaluation" "HTTPS/443"
        lmEvalHarness -> watsonxAPI "Remote model evaluation" "HTTPS/443"
        lmEvalHarness -> localInference "Local model evaluation" "HTTP(S)/configurable"

        cli -> evaluator "Invokes evaluation"
        evaluator -> modelBackends "Loads model adapters"
        evaluator -> taskFramework "Loads evaluation tasks"
        evaluator -> cache "Caches responses"
        modelBackends -> huggingfaceHub "Downloads models"
        s3Downloader -> s3Storage "Downloads model artifacts"
        ociPublisher -> ociRegistry "Pushes result artifacts"
        taskFramework -> offlineMetrics "Computes metrics"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
