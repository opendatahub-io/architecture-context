graph TD
    subgraph "Operator Service Account"
        SA[controller-manager<br/>Namespace: llama-stack-k8s-operator-system<br/>UID: 1001 non-root]
    end

    subgraph "Cluster Role Bindings"
        CRB1[manager-rolebinding<br/>Cluster-wide]
        RB1[auth-proxy-rolebinding<br/>Operator Namespace]
        RB2[leader-election-rolebinding<br/>Operator Namespace]
    end

    subgraph "Roles & Permissions"
        ManagerRole[ClusterRole: manager-role]
        AuthProxyRole[Role: auth-proxy-role]
        LeaderRole[Role: leader-election-role]
    end

    subgraph "API Resources - llamastack.io"
        LLSD[LlamaStackDistribution<br/>llamastackdistributions]
        LLSDStatus[LlamaStackDistribution Status<br/>llamastackdistributions/status]
        LLSDFinalizers[LlamaStackDistribution Finalizers<br/>llamastackdistributions/finalizers]
    end

    subgraph "API Resources - apps"
        Deployments[Deployments]
    end

    subgraph "API Resources - core"
        Services[Services]
        ServiceAccounts[ServiceAccounts]
        PVCs[PersistentVolumeClaims]
        ConfigMaps[ConfigMaps]
    end

    subgraph "API Resources - networking"
        NetworkPolicies[NetworkPolicies<br/>networking.k8s.io]
    end

    subgraph "API Resources - policy"
        PDBs[PodDisruptionBudgets]
    end

    subgraph "API Resources - autoscaling"
        HPAs[HorizontalPodAutoscalers]
    end

    subgraph "API Resources - RBAC"
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
        ClusterRoles[ClusterRoles<br/>rbac.authorization.k8s.io]
        ClusterRoleBindings[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - OpenShift"
        SCC[SecurityContextConstraints<br/>anyuid<br/>security.openshift.io]
    end

    subgraph "API Resources - Coordination"
        Leases[Leases<br/>coordination.k8s.io]
    end

    subgraph "Llama Stack Server Service Account"
        LlamaSA["{instance-name}-sa<br/>Namespace: {user-namespace}"]
        ViewRole[ClusterRole: view<br/>Read-only K8s API access]
        LlamaRB["{instance-name}-rolebinding<br/>User Namespace"]
    end

    %% Operator SA bindings
    SA -->|bound via| CRB1
    SA -->|bound via| RB1
    SA -->|bound via| RB2

    CRB1 -->|grants| ManagerRole
    RB1 -->|grants| AuthProxyRole
    RB2 -->|grants| LeaderRole

    %% Manager Role permissions
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| LLSD
    ManagerRole -->|"get, update, patch"| LLSDStatus
    ManagerRole -->|update| LLSDFinalizers
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Deployments
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Services
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| ServiceAccounts
    ManagerRole -->|"get, list, watch,<br/>create"| PVCs
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch"| ConfigMaps
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| NetworkPolicies
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| PDBs
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| HPAs
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RoleBindings
    ManagerRole -->|"get, list, watch"| ClusterRoles
    ManagerRole -->|"get, list, delete"| ClusterRoleBindings
    ManagerRole -->|use| SCC

    %% Auth Proxy Role permissions
    AuthProxyRole -->|"get, list, watch"| ConfigMaps

    %% Leader Election Role permissions
    LeaderRole -->|"get, list, watch,<br/>create, update,<br/>patch"| Leases

    %% Llama Stack SA bindings
    LlamaSA -->|bound via| LlamaRB
    LlamaRB -->|grants| ViewRole
    ViewRole -.->|"read-only access"| ClusterRoles

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px
    style AuthProxyRole fill:#f5a623,stroke:#333
    style LeaderRole fill:#f5a623,stroke:#333
    style LLSD fill:#7ed321,stroke:#333
    style LLSDStatus fill:#7ed321,stroke:#333
    style LLSDFinalizers fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
    style PDBs fill:#7ed321,stroke:#333
    style HPAs fill:#7ed321,stroke:#333
    style RoleBindings fill:#7ed321,stroke:#333
    style ClusterRoles fill:#7ed321,stroke:#333
    style ClusterRoleBindings fill:#7ed321,stroke:#333
    style SCC fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Leases fill:#7ed321,stroke:#333
    style LlamaSA fill:#b8e986,stroke:#333,stroke-width:2px
    style ViewRole fill:#f5a623,stroke:#333
