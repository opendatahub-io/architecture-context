// C4 Context Diagram for rhods-operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        admin = person "Platform Admin" "Configures and manages the RHOAI platform"
        datascientist = person "Data Scientist" "Creates workbenches, pipelines, and deploys models"

        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Central platform operator managing AI/ML component lifecycle on OpenShift" {
            dsciController = container "DSCInitialization Controller" "Initializes platform: namespaces, Auth, GatewayConfig, Monitoring, CA bundles" "Go Controller"
            dscController = container "DataScienceCluster Controller" "Manages all AI/ML component lifecycles based on DSC spec" "Go Controller"
            gatewayController = container "Gateway Controller" "Deploys Gateway API infrastructure: Gateway, kube-auth-proxy, EnvoyFilter, DestinationRule" "Go Controller"
            authController = container "Auth Controller" "Manages admin/allowed groups via ClusterRoles and ClusterRoleBindings" "Go Controller"
            monitoringController = container "Monitoring Controller" "Deploys monitoring stack (MonitoringStack, Prometheus, alerting)" "Go Controller"
            webhookServer = container "Webhook Server" "Validates and mutates DSC, DSCI, HardwareProfile, Kueue, Serving CRs" "Go Webhook, Port 9443"
            kubeAuthProxy = container "kube-auth-proxy" "OAuth2/OIDC authentication proxy for Gateway API ingress" "Go Service, Port 8443"
        }

        // Internal ODH/RHOAI Components (managed by operator)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for managing AI/ML resources" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference serving" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches" "Jupyter notebook environments" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model metadata and versioning" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and scheduling" "Internal RHOAI"
        ray = softwareSystem "KubeRay" "Distributed computing framework" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI" "ML model explainability" "Internal RHOAI"
        trainingOp = softwareSystem "Training Operator" "Distributed training jobs" "Internal RHOAI"
        trainer = softwareSystem "Trainer" "Training runtime management" "Internal RHOAI"
        feast = softwareSystem "Feast Operator" "Feature store management" "Internal RHOAI"
        llamastack = softwareSystem "LlamaStack Operator" "LlamaStack deployment" "Internal RHOAI"
        mlflow = softwareSystem "MLflow Operator" "Experiment tracking" "Internal RHOAI"
        modelController = softwareSystem "Model Controller" "Model serving controller" "Internal RHOAI"

        // External Dependencies
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "OAuth2 authentication server" "External"
        gatewayApi = softwareSystem "Gateway API" "Kubernetes Gateway API infrastructure" "External"
        istio = softwareSystem "Istio / Service Mesh" "Service mesh for traffic management and mTLS" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "Monitoring CRDs and metrics collection" "External"
        certManager = softwareSystem "cert-manager" "Certificate management" "External"

        // Relationships
        admin -> rhoaiOperator "Creates DSCInitialization and DataScienceCluster CRs" "kubectl / HTTPS"
        datascientist -> dashboard "Accesses AI/ML platform UI" "HTTPS/443 via Gateway"

        rhoaiOperator -> k8sApi "Manages all cluster resources" "HTTPS/443"
        rhoaiOperator -> openshiftOAuth "Authenticates users via kube-auth-proxy" "HTTPS/443"
        rhoaiOperator -> istio "Creates EnvoyFilter and DestinationRule" "Kubernetes API"
        rhoaiOperator -> gatewayApi "Creates Gateway, GatewayClass, HTTPRoutes" "Kubernetes API"
        rhoaiOperator -> prometheusOp "Creates ServiceMonitor and PrometheusRule" "Kubernetes API"
        rhoaiOperator -> olm "Managed by OLM via Subscription" "Kubernetes API"
        rhoaiOperator -> certManager "Optional certificate management" "Kubernetes API"

        // Component deployments
        rhoaiOperator -> dashboard "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> kserve "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> workbenches "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> dsPipelines "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> modelRegistry "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> kueue "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> ray "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> trustyai "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> trainingOp "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> trainer "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> feast "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> llamastack "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> mlflow "Deploys from prefetched manifests" "Kustomize"
        rhoaiOperator -> modelController "Deploys from prefetched manifests" "Kustomize"
    }

    views {
        systemContext rhoaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
