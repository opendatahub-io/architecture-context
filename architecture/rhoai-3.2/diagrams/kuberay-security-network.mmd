            GCS["GCS Server<br/>6379/TCP plaintext/mTLS"]
        end

        subgraph WorkerGroup["Ray Worker Pods (SCC: run-as-ray-user, UID 1000)"]
            Workers["Ray Workers<br/>Dynamic ports"]
        end

        NetPol["NetworkPolicies<br/>(head + worker)"]
    end

    subgraph OperatorNS["OPERATOR LAYER (redhat-ods-applications)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>FIPS-compliant, non-root"]
        WebhookSvc["Webhook Service<br/>443→9443/TCP HTTPS<br/>OpenShift serving cert"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
