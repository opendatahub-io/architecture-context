    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Forwarded Auth"| RBACProxy

    %% Auth → K8s API (SAR check)
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (SAR)"| K8sAPI

    %% Auth → Dashboard
    RBACProxy -->|"HTTP/8265<br/>plaintext<br/>localhost only"| Dashboard

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator → cert-manager
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>CRD API"| CertManager

    %% K8s API → Webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (serving cert)<br/>Admission"| WebhookSvc

    %% Prometheus → Operator
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>Metrics scrape"| Operator

    %% Head ↔ Workers (mTLS optional)
    GCS -->|"TCP/6379<br/>plaintext/mTLS<br/>cert-manager CA"| Workers

    %% Head → Redis
    GCS -->|"TCP/6379<br/>plaintext/TLS<br/>Password (optional)"| Redis

