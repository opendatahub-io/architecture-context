graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User/CI Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / SA Token"]
        Route["OpenShift Route<br/>{cluster}-{namespace}.apps.{domain}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge"]
    end

    subgraph OperatorNamespace["Namespace: {operator-namespace}"]
        direction TB

        subgraph OperatorPod["KubeRay Operator Pod"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator"]
            WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS 1.2+<br/>K8s API mTLS"]
            MetricsEndpoint["Metrics/Health<br/>8080/TCP HTTP"]
        end
    end

    subgraph UserNamespace["Namespace: {user-namespace}"]
        direction TB

        subgraph HeadPodContainer["Ray Head Pod"]
            RayHead["Ray Head Container<br/>SA: {raycluster}-sa"]
            GCS["GCS Service<br/>6379/TCP TCP<br/>mTLS optional"]
            Dashboard["Dashboard<br/>8265/TCP HTTP"]
            ClientAPI["Client API<br/>10001/TCP TCP<br/>mTLS optional"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>TLS 1.3"]

            RayHead --> GCS
            RayHead --> Dashboard
            RayHead --> ClientAPI
            OAuthProxy -.->|proxies to| Dashboard
        end

        subgraph WorkerPods["Ray Worker Pods (N replicas)"]
            Worker1["Ray Worker<br/>SA: {raycluster}-sa"]
            Worker2["Ray Worker<br/>SA: {raycluster}-sa"]
        end

        HeadService["Head Service<br/>ClusterIP<br/>6379, 8265, 10001, 8443"]

        HeadPodContainer --> HeadService
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client Credentials"]
        CertManager["cert-manager<br/>TLS Certificate Mgmt<br/>via K8s API"]
        Redis["External Redis<br/>6379/TCP<br/>TLS 1.2+ optional<br/>Username/Password"]
        Registry["Container Registry<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS<br/>Pull Secret"]
        Prometheus["Prometheus<br/>HTTP Pull /metrics<br/>8080/TCP"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    Client -->|HTTPS/443<br/>TLS 1.2+| Route

    %% Ingress to Operator
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS| WebhookSvc
    K8sAPI <-->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| Operator

    %% Route to OAuth Proxy
    Route -->|HTTPS/8443<br/>TLS 1.3| OAuthProxy

    %% Operator to K8s API
    Operator -->|Watch CRDs<br/>Create Resources<br/>HTTPS/6443| K8sAPI

    %% Worker to Head
    Worker1 -->|TCP/6379<br/>Ray Protocol<br/>mTLS optional| GCS
    Worker2 -->|TCP/6379<br/>Ray Protocol<br/>mTLS optional| GCS

    %% OAuth Proxy to OAuth Server
    OAuthProxy -->|Validate Tokens<br/>HTTPS/443<br/>TLS 1.2+| OAuthServer

    %% External Services
    Operator -->|Create Certs/Issuers<br/>via K8s API| CertManager
    RayHead -.->|GCS FT<br/>Redis/6379<br/>TLS optional| Redis
    RayHead -.->|Pull Images<br/>HTTPS/443| Registry
    Prometheus -.->|Scrape Metrics<br/>HTTP/8080| MetricsEndpoint

    %% NetworkPolicy enforcement
    subgraph NetworkPolicyZone["NetworkPolicy Enforcement (when enabled)"]
        NPHead["Head Pod NP:<br/>Allow: Workers, Operator NS, Same NS<br/>Egress: DNS, API, Workers"]
        NPWorker["Worker Pod NP:<br/>Allow: Head, Workers<br/>Egress: DNS, Head, Workers"]
    end

    NPHead -.->|enforces| HeadPodContainer
    NPWorker -.->|enforces| WorkerPods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef raycluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class K8sAPI,Route ingress
    class Operator,WebhookSvc,MetricsEndpoint operator
    class RayHead,GCS,Dashboard,ClientAPI,OAuthProxy,Worker1,Worker2,HeadService raycluster
    class OAuthServer,CertManager,Redis,Registry,Prometheus externalservice
    class NPHead,NPWorker security
