// ODH Dashboard - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Platform Admin" "Manages data science workloads, notebooks, model serving, and platform configuration"

        odhDashboard = softwareSystem "ODH Dashboard (rhods-dashboard)" "Web-based management UI for Red Hat OpenShift AI platform" {
            backend = container "odh-dashboard Backend" "Main dashboard backend - serves frontend, proxies K8s API, handles REST routes" "Node.js 22 / Fastify"
            frontend = container "React/PatternFly Frontend" "User-facing management UI for OpenShift AI platform" "React SPA"
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-based authentication/authorization proxy fronting the dashboard" "Go sidecar"
            modelRegistryUI = container "model-registry-ui" "Model Registry management UI plugin (federated module)" "React / Module Federation"
            genAiUI = container "gen-ai-ui" "Generative AI management UI plugin (federated module)" "React / Module Federation"
        }

        // External / Infrastructure Systems
        gateway = softwareSystem "data-science-gateway" "Gateway API ingress gateway in openshift-ingress namespace" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for all resource management" "External"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics platform" "External"
        openshiftConsole = softwareSystem "OpenShift Console" "OpenShift web console with application launcher" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "OpenShift authentication provider" "External"

        // Internal ODH Systems
        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform" "Internal ODH"
        modelRegistryOp = softwareSystem "Model Registry Operator" "Manages model registry instances" "Internal ODH"
        notebookController = softwareSystem "Kubeflow Notebook Controller" "Manages Jupyter notebook lifecycle" "Internal ODH"
        dscOperator = softwareSystem "DataScienceCluster Operator" "Manages OpenShift AI platform components" "Internal ODH"
        nimOperator = softwareSystem "NIM Operator" "Manages NVIDIA NIM accounts and serving" "Internal ODH"
        llamaStack = softwareSystem "LlamaStack Operator" "Manages LlamaStack distributions" "Internal ODH"
        feast = softwareSystem "Feast Operator" "Manages feature stores" "Internal ODH"
        rhodsOperator = softwareSystem "RHOAI Operator" "Deploys and configures dashboard via kustomize" "Internal ODH"

        // Relationships - External
        user -> odhDashboard "Manages workloads via browser" "HTTPS/443"
        user -> gateway "Accesses dashboard" "HTTPS/443"
        gateway -> odhDashboard "Routes traffic via HTTPRoute" "HTTPS/8443"
        odhDashboard -> k8sAPI "Proxies all K8s API calls for frontend" "HTTPS/6443, WSS/6443"
        odhDashboard -> prometheus "Queries metrics for visualizations" "HTTPS/9090"
        odhDashboard -> openshiftConsole "ConsoleLink CR for launcher integration" "N/A"
        openshiftOAuth -> odhDashboard "Provides user authentication" "OAuth redirect"

        // Relationships - Internal ODH
        odhDashboard -> kserve "Reads InferenceService, ServingRuntime CRDs" "via K8s API"
        odhDashboard -> modelRegistryOp "Manages ModelRegistry CRDs" "via K8s API"
        odhDashboard -> notebookController "Manages Notebook CRDs" "via K8s API"
        odhDashboard -> dscOperator "Reads DataScienceCluster, DSCInitialization CRDs" "via K8s API"
        odhDashboard -> nimOperator "Manages NIM Account CRDs" "via K8s API"
        odhDashboard -> llamaStack "Reads LlamaStackDistribution CRDs" "via K8s API"
        odhDashboard -> feast "Reads FeatureStore CRDs" "via K8s API"
        rhodsOperator -> odhDashboard "Deploys via kustomize overlays" "Kustomize"

        // Container relationships
        user -> kubeRbacProxy "HTTPS requests" "HTTPS/8443"
        kubeRbacProxy -> k8sAPI "SubjectAccessReview" "HTTPS/6443"
        kubeRbacProxy -> backend "Authenticated requests" "HTTP/8080 (localhost)"
        backend -> frontend "Serves SPA" "Static files"
        backend -> k8sAPI "Proxies API calls" "HTTPS/6443"
        backend -> modelRegistryUI "Proxies federated module" "HTTPS/8043"
        backend -> genAiUI "Proxies federated module" "HTTPS/8143"
        backend -> prometheus "Metrics queries" "HTTPS/9090"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
