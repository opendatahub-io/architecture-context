graph TD
    subgraph "Service Accounts"
        SA[training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole: training-operator"
        CR[Operator Permissions]
    end

    subgraph "User Roles"
        EditRole[ClusterRole:<br/>training-edit]
        ViewRole[ClusterRole:<br/>training-view]
    end

    subgraph "Core Resources"
        Pods["Pods<br/>create, delete, get, list,<br/>patch, update, watch"]
        PodExec["Pods/exec<br/>create<br/>(⚠️ MPI launcher)"]
        Services["Services<br/>create, delete, get,<br/>list, watch"]
        ConfigMaps["ConfigMaps<br/>create, list, update, watch"]
        Secrets["Secrets<br/>get, list, update, watch<br/>(⚠️ Webhook certs)"]
        Events["Events<br/>create, delete, get, list,<br/>patch, update, watch"]
        SAs["ServiceAccounts<br/>create, get, list, watch"]
    end

    subgraph "Kubeflow CRDs (kubeflow.org)"
        PyTorchJob["PyTorchJobs<br/>pytorchjobs/status<br/>pytorchjobs/finalizers<br/>Full CRUD + watch"]
        TFJob["TFJobs<br/>tfjobs/status<br/>tfjobs/finalizers<br/>Full CRUD + watch"]
        XGBoostJob["XGBoostJobs<br/>xgboostjobs/status<br/>xgboostjobs/finalizers<br/>Full CRUD + watch"]
        MPIJob["MPIJobs<br/>mpijobs/status<br/>mpijobs/finalizers<br/>Full CRUD + watch"]
        PaddleJob["PaddleJobs<br/>paddlejobs/status<br/>paddlejobs/finalizers<br/>Full CRUD + watch"]
        JAXJob["JAXJobs<br/>jaxjobs/status<br/>jaxjobs/finalizers<br/>Full CRUD + watch"]
    end

    subgraph "Other Resources"
        Webhooks["ValidatingWebhookConfigurations<br/>get, list, update, watch"]
        HPA["HorizontalPodAutoscalers<br/>Full CRUD + watch"]
        RBAC["Roles, RoleBindings<br/>create, list, update, watch"]
        PodGroupV["PodGroups<br/>(scheduling.volcano.sh)<br/>Full CRUD + watch"]
        PodGroupS["PodGroups<br/>(scheduling.x-k8s.io)<br/>Full CRUD + watch"]
        NetPol["NetworkPolicies<br/>Full CRUD + watch"]
    end

    subgraph "User Permissions (training-edit)"
        UserEdit["Training Jobs<br/>(kubeflow.org)<br/>Full CRUD + watch<br/>Status: get"]
    end

    subgraph "User Permissions (training-view)"
        UserView["Training Jobs<br/>(kubeflow.org)<br/>get, list, watch<br/>Status: get"]
    end

