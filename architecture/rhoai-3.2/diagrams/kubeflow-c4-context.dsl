// C4 Context Diagram - ODH Notebook Controller (kubeflow)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and accesses Jupyter notebook workbenches via ODH Dashboard"
        admin = person "Platform Admin" "Manages OpenShift platform and RHOAI configuration"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends upstream Kubeflow Notebook Controller with OpenShift-specific lifecycle: Gateway API ingress, kube-rbac-proxy auth, network policies, CA certs, pipeline integration" {
            reconciler = container "OpenshiftNotebookReconciler" "Watches Notebook CRs, reconciles HTTPRoutes, ReferenceGrants, NetworkPolicies, kube-rbac-proxy resources, RBAC bindings, CA cert ConfigMaps, pipeline secrets" "Go Controller (controller-runtime)"
            webhook = container "NotebookWebhook" "Mutating admission webhook: injects kube-rbac-proxy sidecar, mounts CA certs, resolves ImageStream references, manages reconciliation locks" "Go Admission Webhook"
            kubeRbacProxy = container "kube-rbac-proxy Sidecar" "Authentication/authorization proxy injected into notebook pods; validates bearer tokens via TokenReview + SubjectAccessReview" "Go Sidecar Container"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller managing StatefulSets for Notebook CRs" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API for ingress routing (HTTPRoute, ReferenceGrant, Gateway)" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Container platform providing ImageStreams, service-ca, OAuthClient, Proxy config" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core Kubernetes API for resource CRUD operations" "External"

        dataScienceGateway = softwareSystem "data-science-gateway" "Envoy-based Gateway in openshift-ingress namespace routing external traffic to notebooks" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "RHOAI operator providing Gateway controller and platform Gateway" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for creating and managing Notebook workbenches" "Internal RHOAI"
        dspa = softwareSystem "Data Science Pipelines" "DataSciencePipelinesApplication for Elyra pipeline integration" "Internal RHOAI"
        serviceCA = softwareSystem "OpenShift service-ca Operator" "Auto-provisions TLS certificates for annotated Services" "External"

        // Relationships
        user -> odhDashboard "Creates notebook workbenches via" "HTTPS/443"
        user -> dataScienceGateway "Accesses notebooks via" "HTTPS/443, TLS 1.2+"
        odhDashboard -> k8sAPI "Creates Notebook CRs via" "HTTPS/443"

        k8sAPI -> webhook "Calls mutating webhook" "HTTPS/443->8443, TLS (service-ca)"
        reconciler -> k8sAPI "CRUD: HTTPRoutes, ReferenceGrants, NetworkPolicies, Services, RBAC, Secrets" "HTTPS/443, SA token"
        webhook -> k8sAPI "Reads ImageStreams, ConfigMaps" "HTTPS/443, SA token"

        dataScienceGateway -> kubeRbacProxy "Routes authenticated requests" "HTTPS/8443, TLS (service-ca), Bearer token"
        kubeRbacProxy -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443, SA token"

        reconciler -> dspa "Reads DSPA CR for Elyra pipeline config" "via K8s API"
        rhodsOperator -> dataScienceGateway "Manages Gateway resource" "Gateway API"
        serviceCA -> odhNotebookController "Provisions TLS certs for webhook and proxy Services" "Service annotation"

        odhNotebookController -> kubeflowNotebookController "Shared watch on kubeflow.org/v1 Notebook CRD" ""
        odhNotebookController -> gatewayAPI "Creates HTTPRoutes and ReferenceGrants" "Gateway API v1.2.1"
        odhNotebookController -> ocp "Uses ImageStreams, service-ca, Proxy config" "OpenShift APIs"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
