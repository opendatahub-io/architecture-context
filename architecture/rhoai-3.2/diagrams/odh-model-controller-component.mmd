graph TB
    subgraph "ODH Model Controller"
        Manager[Manager Process]

        subgraph "Reconcilers"
            ISVCCtrl[InferenceService Controller]
            SRCtrl[ServingRuntime Controller]
            LLMCtrl[LLMInferenceService Controller]
            NIMCtrl[NIM Account Controller]
            IGCtrl[InferenceGraph Controller]
            SecretCtrl[Secret Controller]
            CMCtrl[ConfigMap Controller]
            PodCtrl[Pod Controller]
        end

        subgraph "Webhooks"
            PodWebhook[Pod Mutating Webhook]
            ISVCMutate[InferenceService Mutating]
            ISVCValidate[InferenceService Validating]
            IGMutate[InferenceGraph Mutating]
            IGValidate[InferenceGraph Validating]
            NIMValidate[NIM Account Validating]
        end

        subgraph "HTTP Servers"
            MetricsServer[Metrics Server<br/>8080/TCP]
            HealthServer[Health Server<br/>8081/TCP]
            WebhookServer[Webhook Server<br/>9443/TCP HTTPS]
        end

        Manager --> ISVCCtrl
        Manager --> SRCtrl
        Manager --> LLMCtrl
        Manager --> NIMCtrl
        Manager --> IGCtrl
        Manager --> SecretCtrl
        Manager --> CMCtrl
        Manager --> PodCtrl

        Manager --> MetricsServer
        Manager --> HealthServer
        Manager --> WebhookServer

        WebhookServer --> PodWebhook
        WebhookServer --> ISVCMutate
        WebhookServer --> ISVCValidate
        WebhookServer --> IGMutate
        WebhookServer --> IGValidate
        WebhookServer --> NIMValidate
    end

    subgraph "Watched Resources (KServe)"
        ISVC[InferenceService CR]
        SR[ServingRuntime CR]
        LLM[LLMInferenceService CR]
        IG[InferenceGraph CR]
        NIM[Account CR<br/>nim.opendatahub.io]
    end

    subgraph "Created Resources per ISVC"
        Route[OpenShift Route<br/>External HTTPS]
        NetPol[NetworkPolicy<br/>Ingress Rules]
        SA[ServiceAccount]
        Role[Role/RoleBinding]
        SvcMon[ServiceMonitor]
        PodMon[PodMonitor]
    end

    subgraph "Created Resources per LLM"
        AuthPol[AuthPolicy<br/>Kuadrant]
        EnvoyFilt[EnvoyFilter<br/>Istio]
        HTTPRt[HTTPRoute<br/>Gateway API]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        MR[Model Registry<br/>443/TCP HTTPS]
        NGC[NVIDIA NGC API<br/>443/TCP HTTPS]
    end

    subgraph "Platform Resources"
        DSC[DataScienceCluster]
        DSCI[DSCInitialization]
    end

    %% Watches
    ISVC -.->|watched by| ISVCCtrl
    SR -.->|watched by| SRCtrl
    LLM -.->|watched by| LLMCtrl
    IG -.->|watched by| IGCtrl
    NIM -.->|watched by| NIMCtrl

    %% Creates resources
    ISVCCtrl -->|creates| Route
    ISVCCtrl -->|creates| NetPol
    ISVCCtrl -->|creates| SA
    ISVCCtrl -->|creates| Role
    ISVCCtrl -->|creates| SvcMon
    ISVCCtrl -->|creates| PodMon

    LLMCtrl -->|creates| AuthPol
    LLMCtrl -->|creates| EnvoyFilt
    LLMCtrl -->|creates| HTTPRt

    %% External interactions
    ISVCCtrl -->|registers| MR
    NIMCtrl -->|validates| NGC

    Manager -->|API calls| K8sAPI

    %% Platform config
    Manager -.->|reads config| DSC
    Manager -.->|reads config| DSCI

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px
    style ISVCCtrl fill:#4a90e2,stroke:#333
    style SRCtrl fill:#4a90e2,stroke:#333
    style LLMCtrl fill:#4a90e2,stroke:#333
    style NIMCtrl fill:#4a90e2,stroke:#333
    style IGCtrl fill:#4a90e2,stroke:#333
    style MetricsServer fill:#f5a623,stroke:#333
    style WebhookServer fill:#f5a623,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style SR fill:#7ed321,stroke:#333
    style LLM fill:#7ed321,stroke:#333
    style IG fill:#7ed321,stroke:#333
    style NIM fill:#7ed321,stroke:#333
    style Route fill:#d0d0d0,stroke:#333
    style NetPol fill:#d0d0d0,stroke:#333
    style SA fill:#d0d0d0,stroke:#333
    style AuthPol fill:#d0d0d0,stroke:#333
    style EnvoyFilt fill:#d0d0d0,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style MR fill:#999,stroke:#333
    style NGC fill:#999,stroke:#333
