%% FMS Guardrails Orchestrator - RBAC / Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: This is a non-operator service with no CRDs or RBAC manifests.
%% This diagram shows container security and TLS configuration instead.

graph TD
    subgraph ContainerSecurity["Container Security"]
        User["orchestr8 User<br/>UID: 1001"]
        Group["root Group (GID: 0)<br/>supplementary: orchestr8 (GID: 1001)"]
        Shell["/sbin/nologin"]
        BaseImage["Base Image:<br/>ubi9/ubi-minimal"]
        Binary["Binary Hardening:<br/>Symbols stripped, LTO enabled"]
        HealthCheck["HEALTHCHECK: NONE<br/>(disabled in container)"]
    end

    subgraph TLSConfig["TLS Configuration"]
        direction TB

        subgraph ServerTLS["Server-side TLS (Inbound 8033/TCP)"]
            TLSKey["TLS_KEY_PATH<br/>(server private key)"]
            TLSCert["TLS_CERT_PATH<br/>(server certificate)"]
            ClientCA["TLS_CLIENT_CA_CERT_PATH<br/>(client CA for mTLS)"]
        end

        subgraph ClientTLS["Client-side TLS (Outbound)"]
            NamedTLS["Named TLS Configs<br/>(config.yaml)"]
            CertPath["cert_path<br/>(client certificate)"]
            KeyPath["key_path<br/>(client private key)"]
            CACertPath["ca_cert_path<br/>(server CA trust)"]
            InsecureMode["insecure: true/false<br/>(skip verification)"]
        end
    end

    subgraph Secrets["Kubernetes Secrets"]
        ServerCert["TLS Server Certificate<br/>Type: kubernetes.io/tls<br/>Provisioned by: Platform / cert-manager<br/>Auto-Rotate: No (file-based)"]
        ClientCerts["TLS Client Certificates<br/>Type: kubernetes.io/tls<br/>Provisioned by: Platform / cert-manager<br/>Auto-Rotate: No (file-based)"]
        CACerts["TLS CA Certificates<br/>Type: Opaque<br/>Provisioned by: Platform / cert-manager<br/>Auto-Rotate: No (file-based)"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        HeaderPassthrough["Header Passthrough<br/>passthrough_headers in config.yaml"]
        TokenRewrite["X-Forwarded-Access-Token Rewrite<br/>-> Authorization: Bearer token"]
    end

    %% Relationships
    ServerCert -->|mounted as file| TLSKey
    ServerCert -->|mounted as file| TLSCert
    CACerts -->|mounted as file| ClientCA
    ClientCerts -->|mounted as file| CertPath
    ClientCerts -->|mounted as file| KeyPath
    CACerts -->|mounted as file| CACertPath

    style User fill:#4a90e2,color:#fff
    style Group fill:#4a90e2,color:#fff
    style ServerCert fill:#f5a623,color:#fff
    style ClientCerts fill:#f5a623,color:#fff
    style CACerts fill:#f5a623,color:#fff
    style HeaderPassthrough fill:#7ed321,color:#fff
    style TokenRewrite fill:#7ed321,color:#fff
    style TLSKey fill:#dae8fc,stroke:#6c8ebf
    style TLSCert fill:#dae8fc,stroke:#6c8ebf
    style ClientCA fill:#dae8fc,stroke:#6c8ebf
    style NamedTLS fill:#e1d5e7,stroke:#9673a6
    style CertPath fill:#e1d5e7,stroke:#9673a6
    style KeyPath fill:#e1d5e7,stroke:#9673a6
    style CACertPath fill:#e1d5e7,stroke:#9673a6
    style InsecureMode fill:#f8cecc,stroke:#b85450
