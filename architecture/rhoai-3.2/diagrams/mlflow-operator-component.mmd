graph TB
    subgraph "MLflow Operator"
        Controller[mlflow-operator-manager<br/>Controller Runtime]
        HelmRenderer[Helm Chart Renderer<br/>helm.sh/helm/v3]
        ConsoleLinkMgr[ConsoleLink Manager]
        HTTPRouteMgr[HTTPRoute Manager]

        Controller -->|uses| HelmRenderer
        Controller -->|manages| ConsoleLinkMgr
        Controller -->|manages| HTTPRouteMgr
    end

    subgraph "Custom Resources"
        MLflowCR[MLflow CR<br/>mlflow.opendatahub.io/v1]
    end

    subgraph "MLflow Instance Resources"
        MLflowDeploy[MLflow Deployment<br/>Python/uvicorn]
        MLflowService[MLflow Service<br/>8443/TCP HTTPS]
        MLflowPVC[PVC<br/>SQLite Storage]
        TLSSecret[mlflow-tls Secret<br/>TLS Certificate]
        NetworkPolicy[NetworkPolicy<br/>Ingress/Egress]
        HTTPRoute[HTTPRoute<br/>Gateway API]
        ConsoleLink[ConsoleLink<br/>OpenShift]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        ServiceCA[service-ca-operator<br/>OpenShift]
        Gateway[Gateway<br/>HTTPRoute]
        PostgreSQL[PostgreSQL<br/>Backend Store]
        S3[S3 Storage<br/>Artifacts]
    end

    %% CR Flow
    User[User/CI] -->|creates| MLflowCR
    MLflowCR -->|watched by| Controller

    %% Resource Creation
    Controller -->|creates/updates| MLflowDeploy
    Controller -->|creates| MLflowService
    Controller -->|creates| MLflowPVC
    Controller -->|creates| NetworkPolicy
    Controller -->|creates| HTTPRoute
    Controller -->|creates| ConsoleLink
    Controller -->|annotates service| ServiceCA
    ServiceCA -->|provisions| TLSSecret

    %% Instance Dependencies
    MLflowDeploy -->|uses| TLSSecret
    MLflowDeploy -->|serves on| MLflowService
    MLflowDeploy -->|mounts| MLflowPVC
    HTTPRoute -->|routes to| MLflowService

    %% External Integrations
    Controller -->|manages resources| K8sAPI
    MLflowDeploy -->|connects to| PostgreSQL
    MLflowDeploy -->|stores artifacts| S3
    MLflowDeploy -->|authenticates via| K8sAPI
    HTTPRoute -->|references| Gateway

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style HelmRenderer fill:#4a90e2,stroke:#333
    style MLflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style MLflowDeploy fill:#7ed321,stroke:#333,stroke-width:2px
    style ServiceCA fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Gateway fill:#7ed321,stroke:#333
