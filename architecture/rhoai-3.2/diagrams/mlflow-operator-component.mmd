%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph OperatorPod["MLflow Operator (controller-manager)"]
        Controller["MLflow Controller<br/>controller-runtime"]
        HelmRenderer["Helm Renderer<br/>Embedded Chart Engine"]
        RoutingCtrl["Routing Controller<br/>HTTPRoute + ConsoleLink"]
        Controller -->|renders CR spec| HelmRenderer
        Controller -->|manages ingress| RoutingCtrl
    end

    subgraph ManagedResources["Managed Resources (per MLflow CR)"]
        MLflowDeploy["MLflow Deployment<br/>Tracking Server + kubernetes-auth"]
        MLflowSvc["MLflow Service<br/>8443/TCP HTTPS"]
        MLflowSA["ServiceAccount<br/>mlflow-sa"]
        MLflowPVC["PersistentVolumeClaim<br/>Artifact Storage"]
        MLflowNP["NetworkPolicy<br/>Allow 8443 ingress"]
        MLflowCR_RBAC["ClusterRole + Binding<br/>namespace list/watch"]
        MLflowTLS["mlflow-tls Secret<br/>service-ca cert"]
    end

    Admin[Platform Admin] -->|creates| MLflowCR["MLflow CR<br/>mlflow.opendatahub.io/v1<br/>(Cluster-scoped)"]
    MLflowCR -->|watched by| Controller

    HelmRenderer -->|SSA apply| MLflowDeploy
    HelmRenderer -->|SSA apply| MLflowSvc
    HelmRenderer -->|SSA apply| MLflowSA
    HelmRenderer -->|SSA apply| MLflowPVC
    HelmRenderer -->|SSA apply| MLflowNP
    HelmRenderer -->|SSA apply| MLflowCR_RBAC

    RoutingCtrl -->|creates| HTTPRoute["HTTPRoute<br/>Gateway API"]
    RoutingCtrl -->|creates| ConsoleLink["ConsoleLink<br/>OpenShift Console"]

    HTTPRoute -->|parent ref| DSGateway["data-science-gateway<br/>openshift-ingress"]
    DSGateway -->|routes to| MLflowSvc

    Controller -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP"]
    Controller -->|deployed by| RhodsOp["rhods-operator"]

    ServiceCA["OpenShift service-ca"] -->|provisions| MLflowTLS
    MLflowTLS -->|mounted in| MLflowDeploy

    Prometheus["Prometheus"] -->|scrapes 8443/TCP| MetricsSvc["Operator Metrics Service<br/>8443/TCP HTTPS"]

