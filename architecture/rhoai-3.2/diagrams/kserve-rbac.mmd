graph TD
    subgraph "Service Accounts"
        SA_Controller[kserve-controller-manager<br/>Namespace: kserve]
        SA_InferenceService["{isvc-name}-sa<br/>Namespace: {user-namespace}"]
        SA_Router["{graph-name}-router-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kserve-manager-rolebinding]
        CRB_LeaderElection[kserve-leader-election-rolebinding]
        CRB_Proxy[kserve-proxy-rolebinding]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager[kserve-manager-role]
        CR_LeaderElection[kserve-leader-election-role]
        CR_Proxy[kserve-proxy-role]
    end

    subgraph "API Resources - KServe CRDs"
        direction LR
        InferenceService["serving.kserve.io<br/>InferenceService"]
        ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
        ClusterServingRuntime["serving.kserve.io<br/>ClusterServingRuntime"]
        InferenceGraph["serving.kserve.io<br/>InferenceGraph"]
        TrainedModel["serving.kserve.io<br/>TrainedModel"]
        LLMInferenceService["serving.kserve.io<br/>LLMInferenceService"]
    end

    subgraph "API Resources - Core K8s"
        direction LR
        Services["core<br/>Services"]
        Secrets["core<br/>Secrets"]
        ServiceAccounts["core<br/>ServiceAccounts"]
        ConfigMaps["core<br/>ConfigMaps"]
        Events["core<br/>Events"]
    end

    subgraph "API Resources - Apps"
        direction LR
        Deployments["apps<br/>Deployments"]
        HPA["autoscaling<br/>HorizontalPodAutoscalers"]
    end

    subgraph "API Resources - Networking & Service Mesh"
        direction LR
        KnativeServices["serving.knative.dev<br/>Services"]
        VirtualServices["networking.istio.io<br/>VirtualServices"]
        DestinationRules["networking.istio.io<br/>DestinationRules"]
        HTTPRoutes["gateway.networking.k8s.io<br/>HTTPRoutes"]
        Routes["route.openshift.io<br/>Routes"]
    end

    subgraph "API Resources - Autoscaling & Monitoring"
        direction LR
        ScaledObjects["keda.sh<br/>ScaledObjects"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors"]
        PodMonitors["monitoring.coreos.com<br/>PodMonitors"]
        OtelCollectors["opentelemetry.io<br/>OpenTelemetryCollectors"]
    end

    subgraph "API Resources - RBAC & Admission"
        direction LR
        ValidatingWebhooks["admissionregistration.k8s.io<br/>ValidatingWebhookConfigurations"]
        MutatingWebhooks["admissionregistration.k8s.io<br/>MutatingWebhookConfigurations"]
        RoleBindings["rbac.authorization.k8s.io<br/>RoleBindings"]
        Roles["rbac.authorization.k8s.io<br/>Roles"]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_Proxy

    %% ClusterRole Bindings
    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_Proxy -->|grants| CR_Proxy

    %% ClusterRole Permissions - KServe CRDs
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| InferenceService
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ServingRuntime
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ClusterServingRuntime
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| InferenceGraph
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| TrainedModel
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| LLMInferenceService

    %% ClusterRole Permissions - Core K8s
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Services
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Secrets
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ServiceAccounts
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ConfigMaps
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Events

    %% ClusterRole Permissions - Apps
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Deployments
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| HPA

    %% ClusterRole Permissions - Networking
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| KnativeServices
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| VirtualServices
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| DestinationRules
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| HTTPRoutes
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Routes

    %% ClusterRole Permissions - Autoscaling & Monitoring
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ScaledObjects
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ServiceMonitors
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| PodMonitors
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| OtelCollectors

    %% ClusterRole Permissions - RBAC & Admission
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| ValidatingWebhooks
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| MutatingWebhooks
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| RoleBindings
    CR_Manager -->|create, delete, get, list,<br/>patch, update, watch| Roles

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_InferenceService fill:#4a90e2,stroke:#333
    style SA_Router fill:#4a90e2,stroke:#333
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333
    style CR_Proxy fill:#f5a623,stroke:#333
    style CRB_Manager fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB_LeaderElection fill:#7ed321,stroke:#333
    style CRB_Proxy fill:#7ed321,stroke:#333

    style InferenceService fill:#d5e8d4,stroke:#82b366
    style ServingRuntime fill:#d5e8d4,stroke:#82b366
    style ClusterServingRuntime fill:#d5e8d4,stroke:#82b366
    style InferenceGraph fill:#d5e8d4,stroke:#82b366
    style TrainedModel fill:#d5e8d4,stroke:#82b366
    style LLMInferenceService fill:#d5e8d4,stroke:#82b366
