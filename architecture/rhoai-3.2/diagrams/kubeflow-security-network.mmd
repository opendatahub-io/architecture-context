%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>(Envoy)<br/>Namespace: openshift-ingress<br/>443/TCP, TLS 1.2+ SIMPLE"]
    end

    subgraph GatewayResources["GATEWAY API RESOURCES"]
        HTTPRoute["HTTPRoute<br/>nb-{ns}-{notebook}<br/>Path: /notebook/{ns}/{name}"]
        RefGrant["ReferenceGrant<br/>notebook-httproute-access<br/>(per user namespace)"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE (opendatahub)"]
        direction TB
        Controller["ODH Notebook Controller<br/>SA: odh-notebook-controller-manager<br/>CR: odh-notebook-controller-manager-role"]
        WebhookSvc["Webhook Service<br/>443/TCP -> 8443/TCP<br/>TLS (service-ca cert)<br/>Auth: K8s API server client cert"]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>No auth"]
        HealthProbe["Health Probes<br/>/healthz /readyz<br/>8081/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACE (per notebook)"]
        direction TB

        subgraph NotebookPod["Notebook Pod"]
            KRBP["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS (service-ca cert)<br/>Auth: Bearer Token<br/>-> TokenReview + SAR"]
            NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>plaintext (loopback)"]
        end

        ProxySvc["{notebook}-kube-rbac-proxy<br/>Service 8443/TCP<br/>TLS (service-ca)"]
        NetPolCtrl["{notebook}-ctrl-np<br/>Allow controller ns -> 8888"]
        NetPolProxy["{notebook}-kube-rbac-proxy-np<br/>Allow all -> 8443"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
    end

    subgraph InternalDeps["INTERNAL DEPENDENCIES"]
        DSPA["DSPA CR<br/>(pipeline config)"]
        ImageStreams["OpenShift ImageStreams<br/>(image resolution)"]
        ServiceCA["OpenShift service-ca<br/>(TLS cert provisioning)"]
        KFCtrl["Kubeflow Notebook Controller<br/>(upstream, manages StatefulSet)"]
    end

    %% External Access Flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer token (auth enabled)"| ProxySvc
    Gateway -->|"HTTP/8888<br/>No auth (auth disabled)"| NotebookContainer
    ProxySvc --> KRBP
    KRBP -->|"HTTPS/443<br/>TokenReview + SAR<br/>SA token"| K8sAPI
    KRBP -->|"HTTP/8888<br/>plaintext loopback<br/>X-Auth-Request-User"| NotebookContainer

    %% Controller Flows
    Controller -->|"HTTPS/443<br/>SA token<br/>CRUD resources"| K8sAPI
    Controller -->|creates| HTTPRoute
    Controller -->|creates| RefGrant
    HTTPRoute -->|"references parent"| Gateway
    RefGrant -->|"authorizes cross-ns"| HTTPRoute

    %% Webhook Flow
    K8sAPI -->|"HTTPS/443->8443<br/>TLS (service-ca)<br/>API server client cert"| WebhookSvc

    %% Internal Dependencies
    Controller -.->|"reads via K8s API"| DSPA
    WebhookSvc -.->|"reads via K8s API"| ImageStreams
    ServiceCA -.->|"provisions certs"| WebhookSvc
    ServiceCA -.->|"provisions certs"| ProxySvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef gatewayapi fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class Controller,WebhookSvc,MetricsSvc,HealthProbe controller
    class KRBP,NotebookContainer,ProxySvc,NetPolCtrl,NetPolProxy userns
    class K8sAPI k8s
    class DSPA,ImageStreams,ServiceCA,KFCtrl internal
    class HTTPRoute,RefGrant gatewayapi
