graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[External User<br/>Data Scientist]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IstioGateway["Istio Gateway<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Optional: Bearer Token"]
        VirtualService["Istio VirtualService<br/>notebook-{name}-vs<br/>Gateway: kubeflow/kubeflow-gateway"]
    end

    subgraph ServiceMesh["SERVICE MESH (Namespace Isolation)"]
        direction TB

        subgraph UserNamespace["Namespace: {user-namespace}"]
            NotebookService["Service: notebook-{name}<br/>ClusterIP<br/>80/TCP → 8888/TCP<br/>HTTP (plaintext or mTLS)"]
            NotebookPod["Notebook Pod<br/>Jupyter Server<br/>8888/TCP HTTP<br/>SA: default<br/>fsGroup: 100"]
        end

        subgraph ControllerNamespace["Namespace: odh-notebook-controller"]
            ControllerPod["Controller Deployment<br/>SA: service-account<br/>User: 1001 (non-root)<br/>FIPS Enabled"]
            Manager["manager container<br/>rhoai/odh-kf-notebook-controller<br/>8080/TCP /metrics (HTTP)<br/>8081/TCP /healthz (HTTP)"]
            RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC enforcement"]
            MetricsService["Service: metrics<br/>ClusterIP<br/>8443/TCP HTTPS"]

            ControllerPod --> Manager
            ControllerPod --> RBACProxy
            RBACProxy -->|proxies| Manager
        end
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount JWT"]
    end

    subgraph Integration["INTEGRATION POINTS"]
        JupyterWebApp["jupyter-web-app<br/>UI Frontend<br/>Creates Notebook CRs"]
        Prometheus["Prometheus<br/>Metrics Collection<br/>8443/TCP HTTPS"]
    end

    %% User access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| IstioGateway
    IstioGateway -->|"HTTP/80<br/>mTLS (if Istio)"| VirtualService
    VirtualService -->|"HTTP/80<br/>mTLS (if Istio)"| NotebookService
    NotebookService -->|"HTTP/8888<br/>Plaintext<br/>No Auth"| NotebookPod

    %% Controller flows
    Manager -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch Notebooks, Manage StatefulSets/Services"| K8sAPI
    Manager -.->|"HTTP/8888<br/>Plaintext<br/>No Auth<br/>GET /api/kernels (culling)"| NotebookPod

    %% Integration flows
    JupyterWebApp -->|"HTTPS/443<br/>TLS 1.2+<br/>User/SA Token<br/>Create Notebook CR"| K8sAPI
    K8sAPI -.->|"Watch events<br/>HTTPS<br/>SA Token"| Manager

    %% Metrics flow
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>RBAC SubjectAccessReview"| MetricsService
    MetricsService -->|"HTTPS/8443<br/>TLS 1.2+"| RBACProxy
    RBACProxy -->|"HTTP/8080<br/>Localhost"| Manager

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef integration fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class IstioGateway,VirtualService ingress
    class NotebookService,NotebookPod,ControllerPod,Manager,RBACProxy,MetricsService servicemesh
    class K8sAPI k8s
    class JupyterWebApp,Prometheus integration
