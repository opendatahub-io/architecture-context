%% RBAC Visualization: llm-d-routing-sidecar
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Subjects"
        SA["ServiceAccount<br/>(configurable)"]
        AuthGroup["Group:<br/>system:authenticated"]
    end

    subgraph "Role Bindings"
        ExecRB["exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        SSRFRB["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "Roles"
        ExecRole["exec-role"]
        SSRFRole["ssrf-allowlist-role"]
    end

    subgraph "API Resources"
        PodsExec["core<br/>pods/exec"]
        Pods["core<br/>pods"]
        InferencePools["inference.networking.x-k8s.io<br/>inferencepools"]
    end

    %% Bindings
    AuthGroup -->|"bound via"| ExecRB
    ExecRB -->|"grants"| ExecRole

    SA -->|"bound via"| SSRFRB
    SSRFRB -->|"grants"| SSRFRole

    %% Permissions
    ExecRole -->|"create"| PodsExec

    SSRFRole -->|"get, watch, list"| Pods
    SSRFRole -->|"get, watch, list"| InferencePools

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style AuthGroup fill:#4a90e2,stroke:#333,color:#fff
    style ExecRole fill:#f5a623,stroke:#333
    style SSRFRole fill:#f5a623,stroke:#333
