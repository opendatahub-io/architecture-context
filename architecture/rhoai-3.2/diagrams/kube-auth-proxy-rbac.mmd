%% RBAC Visualization: kube-auth-proxy
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Pod ServiceAccount"
        SA["Pod ServiceAccount<br/>(e.g., dashboard-sa,<br/>notebook-controller-sa)"]
    end

    subgraph "Required Role Bindings"
        CRB1["ClusterRoleBinding<br/>(provisioned by deploying operator)"]
    end

    subgraph "Required ClusterRole Permissions"
        CR["ClusterRole<br/>(required by kube-rbac-proxy)"]
    end

    subgraph "Kubernetes API Resources"
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        Users["user.openshift.io<br/>users"]
    end

    subgraph "Authentication Mechanisms"
        direction LR
        BearerAuth["Bearer Token<br/>(TokenReview validation)"]
        mTLSAuth["mTLS / x509<br/>(Client certificate)"]
        OIDCAuth["OIDC JWT<br/>(Token validation)"]
    end

    subgraph "Authorization Mechanisms"
        direction LR
        SARCheck["SubjectAccessReview<br/>(Kubernetes RBAC check)"]
        StaticAuthz["Static Authorization<br/>(config-based rules)"]
        MetricsAuthz["Hardcoded Metrics<br/>Authorizer"]
    end

    subgraph "Secrets Required"
        CookieSecret["cookie-secret<br/>Opaque<br/>Session cookie encryption<br/>Manual/Operator provisioned"]
        ClientSecret["client-secret<br/>Opaque<br/>OAuth2 client secret<br/>Manual/Operator provisioned"]
        TLSSecret["tls-cert/key<br/>kubernetes.io/tls<br/>HTTPS listener cert<br/>cert-manager/Manual"]
        JWTKey["jwt_signing_key.pem<br/>Opaque (file)<br/>JWT signing key<br/>Built into image"]
        SAToken["ServiceAccount token<br/>k8s.io/sa-token<br/>OpenShift OAuth client<br/>Auto-provisioned, auto-rotated"]
    end

    SA -->|"bound via"| CRB1
    CRB1 -->|"grants"| CR
    CR -->|"create"| TokenReview
    CR -->|"create"| SAR
    CR -->|"get"| Users

    %% Auth flow
    BearerAuth -->|"validates via"| TokenReview
    mTLSAuth -->|"extracts identity from"| SA
    OIDCAuth -->|"validates JWT claims"| SA

    %% Authz flow
    SARCheck -->|"checks via"| SAR
    StaticAuthz -->|"evaluates config rules"| CR
    MetricsAuthz -->|"allows /metrics access"| CR

    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style CRB1 fill:#f5a623,color:#fff
    style TokenReview fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style Users fill:#7ed321,color:#fff
