/* Training Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/training-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or ODH Dashboard"

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Kubernetes-native operator for managing distributed ML training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, and JAX" {
            controller = container "Training Operator" "Main operator binary managing all training job CRDs with per-framework controllers" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates creation/update of all training job CRDs via ValidatingWebhookConfiguration" "Go Service, 9443/TCP HTTPS"
            certRotator = container "Cert Rotator" "Self-manages TLS certificates for webhook server" "cert-controller v0.12.0"
        }

        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform and API server" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and monitoring" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys training-operator via kustomize overlay" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduling via PodGroup CRDs" "External Optional"
        schedulerPlugins = softwareSystem "scheduler-plugins" "Optional gang scheduling via PodGroup CRDs" "External Optional"
        kueue = softwareSystem "Kueue / MultiKueue" "Optional external job management delegation" "External Optional"

        # Relationships
        user -> trainingOperator "Submits PyTorchJob, TFJob, XGBoostJob, MPIJob, PaddleJob, JAXJob CRs" "kubectl / HTTPS 443"
        user -> kubernetes "Creates training job CRs" "HTTPS/443, Bearer Token"

        kubernetes -> trainingOperator "Sends webhook validation requests" "HTTPS/9443, TLS self-signed"
        trainingOperator -> kubernetes "Watches CRDs, creates Pods/Services/NetworkPolicies/HPAs" "HTTPS/443, SA Token"

        rhodsOperator -> trainingOperator "Deploys and configures via kustomize" "Kustomize overlay"
        prometheus -> trainingOperator "Scrapes operator metrics via PodMonitor" "HTTP/8080, plaintext"

        trainingOperator -> volcano "Creates PodGroup CRDs for gang scheduling" "HTTPS/443, SA Token"
        trainingOperator -> schedulerPlugins "Creates PodGroup CRDs for gang scheduling" "HTTPS/443, SA Token"
        trainingOperator -> kueue "Delegates job management via ManagedBy field" "HTTPS/443, SA Token"

        # Internal container relationships
        controller -> webhookServer "Validates job CRDs"
        certRotator -> webhookServer "Provides TLS certificates"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #cccccc
                color #333333
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
