/*
 * ModelMesh C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/modelmesh.md
 */

workspace {
    model {
        client = person "ML Client" "Sends inference requests and manages models via gRPC API"

        modelmesh = softwareSystem "ModelMesh" "Distributed LRU cache and routing layer for high-scale, high-density model serving" {
            core = container "ModelMesh Core" "Distributed LRU cache engine with model lifecycle management, placement, and auto-scaling" "Java 21"
            api = container "ModelMesh API" "External gRPC API server exposing model management and proxied inference endpoints" "gRPC Server (port 8033)"
            sidecar = container "SidecarModelMesh" "Bridges ModelMesh to colocated model runtime containers via gRPC ModelRuntime interface" "Java Service"
            vmodelMgr = container "VModelManager" "Virtual model management enabling zero-downtime model updates" "Java Service"
            payloadProc = container "PayloadProcessor" "Pluggable payload processing pipeline for logging and forwarding" "Java Service"
            metrics = container "Metrics Server" "Prometheus metrics endpoint (HTTPS :2112) or StatsD push" "Netty Server"
            healthProbe = container "Health Probe Server" "Liveness/readiness probe endpoint (/live, /ready)" "HTTP Server (port 8089)"
            preStop = container "PreStop Server" "Coordinated pod shutdown, blocks until model propagation completes" "HTTP Server (port 8080)"
            litelinks = container "Litelinks" "Inter-pod RPC and service discovery framework" "IBM Litelinks"
        }

        etcd = softwareSystem "etcd" "Distributed key-value store for model registry, instance tracking, leader election" "External"
        modelRuntime = softwareSystem "Model Runtime" "Actual model loading/unloading and inference execution (triton, mlserver, etc.)" "Sidecar Container"
        modelmeshServing = softwareSystem "modelmesh-serving" "Controller managing ModelMesh deployments, ServingRuntime and InferenceService CRs" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server" "External"
        storageBackend = softwareSystem "Storage Backend" "Model artifact storage (S3, PVC, etc.)" "External"

        # External relationships
        client -> modelmesh "Sends gRPC inference/management requests" "gRPC/8033, TLS + mTLS (optional)"
        modelmeshServing -> modelmesh "Manages deployments and configuration"
        modelmesh -> etcd "Stores/retrieves model registry, state coordination, leader election" "gRPC/2379, TLS, Cert-based"
        modelmesh -> modelRuntime "Delegates model loading/unloading/inference" "gRPC/8085 or UDS, plaintext (localhost)"
        modelRuntime -> storageBackend "Fetches model artifacts" "HTTPS (varies)"
        prometheus -> modelmesh "Scrapes metrics" "HTTPS/2112, TLS (self-signed)"
        modelmesh -> k8sApi "Pod metadata, service account" "HTTPS/443"

        # Internal container relationships
        api -> core "Routes requests"
        core -> sidecar "Delegates to runtime"
        core -> vmodelMgr "Virtual model operations"
        core -> payloadProc "Processes payloads"
        core -> litelinks "Inter-pod communication"
        core -> metrics "Emits metrics"
    }

    views {
        systemContext modelmesh "SystemContext" {
            include *
            autoLayout
        }

        container modelmesh "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Sidecar Container" {
                background #85bb65
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
