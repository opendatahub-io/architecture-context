// C4 Context Diagram: odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys ML models via InferenceService/LLMInferenceService CRs"
        platformAdmin = person "Platform Admin" "Configures RHOAI platform and manages NIM accounts"

        odmController = softwareSystem "odh-model-controller" "Manages model serving infrastructure lifecycle (Routes, Auth, Monitoring, TLS, RBAC) for KServe InferenceServices and LLMInferenceServices" {
            isvcController = container "InferenceService Controller" "Reconciles InferenceServices in RawDeployment mode; creates Routes, RBAC, monitoring, KEDA resources" "Go Controller"
            llmController = container "LLMInferenceService Controller" "Reconciles LLMInferenceServices; creates AuthPolicies, EnvoyFilters, RBAC" "Go Controller"
            srtController = container "ServingRuntime Controller" "Manages Prometheus monitoring RoleBindings and Ray TLS certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM integration: API key validation, model config, pull secrets, templates" "Go Controller"
            cmController = container "ConfigMap Controller" "Distributes CA certificate bundles for KServe storage access" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into KServe storage-config" "Go Controller"
            podController = container "Pod Controller" "Manages per-pod Ray TLS certificates for multi-node serving" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating/Validating webhooks for Pods, InferenceServices, InferenceGraphs, LLMInferenceServices, NIM Accounts" "Go Webhook Server" "9443/TCP HTTPS"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs and controller" "External" {
            tags "External"
        }
        istio = softwareSystem "Istio" "Service mesh for traffic management and mTLS; EnvoyFilter target for LLMInferenceService auth" "External" {
            tags "External"
        }
        kuadrant = softwareSystem "Kuadrant Operator" "AuthPolicy management for Gateway API authentication on LLMInferenceServices" "External" {
            tags "External"
        }
        authorino = softwareSystem "Authorino" "Authentication enforcement for Gateway API routes" "External" {
            tags "External"
        }
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute/Gateway references for LLMInferenceService traffic routing" "External" {
            tags "External"
        }
        keda = softwareSystem "KEDA" "Event-driven autoscaling via TriggerAuthentication with Prometheus metrics" "External" {
            tags "External"
        }
        promOperator = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor CRDs for metrics collection" "External" {
            tags "External"
        }
        openShift = softwareSystem "OpenShift Platform" "Route API, Template API, service-ca operator" "External" {
            tags "External"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys odh-model-controller via kustomize overlay" "Internal ODH" {
            tags "Internal ODH"
        }
        odhDashboard = softwareSystem "ODH Dashboard" "UI for managing model serving; uses labeled ServingRuntime templates" "Internal ODH" {
            tags "Internal ODH"
        }
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata; optional sync for InferenceServices" "Internal ODH" {
            tags "Internal ODH"
        }
        dsc = softwareSystem "DataScienceCluster" "Platform configuration CR; read for model registry namespace" "Internal ODH" {
            tags "Internal ODH"
        }

        ngcAPI = softwareSystem "NVIDIA NGC API" "NIM API key validation and model catalog" "External Service" {
            tags "External Service"
        }
        k8sAPI = softwareSystem "Kubernetes API Server" "Core API server for CRD watch and resource CRUD" "Platform" {
            tags "Platform"
        }

        // User relationships
        user -> odmController "Creates InferenceService / LLMInferenceService via kubectl/oc"
        platformAdmin -> odmController "Creates NIM Account CRs, configures platform"

        // Controller to external dependencies
        odmController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs"
        odmController -> istio "Creates EnvoyFilters for Gateway TLS (LLMInferenceService)"
        odmController -> kuadrant "Creates AuthPolicies for Gateway/HTTPRoute auth"
        odmController -> authorino "Watches Authorino CRs for resync triggers"
        odmController -> gatewayAPI "References Gateways and HTTPRoutes"
        odmController -> keda "Creates TriggerAuthentications for autoscaling"
        odmController -> promOperator "Creates ServiceMonitors/PodMonitors for metrics"
        odmController -> openShift "Creates Routes, manages Templates, uses service-ca certs"
        odmController -> k8sAPI "CRD watch, resource CRUD" "HTTPS/443"

        // Controller to internal ODH
        rhodsOperator -> odmController "Deploys via kustomize"
        odhDashboard -> odmController "Uses labeled ServingRuntime Templates"
        odmController -> modelRegistry "Syncs InferenceService metadata (optional)" "HTTPS/443"
        odmController -> dsc "Reads model registry namespace config"

        // Controller to external services
        odmController -> ngcAPI "Validates NGC API keys, fetches model catalog" "HTTPS/443"
    }

    views {
        systemContext odmController "SystemContext" {
            include *
            autoLayout
        }

        container odmController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "External Service" {
                background #f5a623
                color #000000
            }
            element "Platform" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
