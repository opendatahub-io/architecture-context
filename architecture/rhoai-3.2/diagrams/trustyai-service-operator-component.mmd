graph TB
    subgraph "TrustyAI Service Operator"
        Operator[TrustyAI Operator<br/>Main Controller]
        OperatorMetrics[Metrics Endpoint<br/>8080/TCP HTTP]
        OperatorHealth[Health/Ready<br/>8081/TCP HTTP]

        Operator -->|exposes| OperatorMetrics
        Operator -->|exposes| OperatorHealth
    end

    subgraph "Managed Resources"
        subgraph "TrustyAI Service"
            TASDeployment[TrustyAI Service Pod]
            TASProxy[kube-rbac-proxy]
            TASStorage[(PVC or Database)]

            TASDeployment -->|secured by| TASProxy
            TASDeployment -->|persists to| TASStorage
        end

        subgraph "LMEval Jobs"
            LMEvalJob[LMEval Job Pod]
            LMESDriver[LMES Driver Sidecar<br/>18080/TCP]
            S3Storage[(S3 Storage)]

            LMEvalJob -->|coordinates via| LMESDriver
            LMEvalJob -->|outputs to| S3Storage
        end

        subgraph "Guardrails Orchestrator"
            GOrchestrator[Orchestrator<br/>8032/8432/TCP]
            GGateway[Gateway Sidecar<br/>8090/TCP]
            GDetectors[Built-in Detectors<br/>8080/TCP]
            GProxy[kube-rbac-proxy]

            GGateway -->|routes to| GOrchestrator
            GOrchestrator -->|uses| GDetectors
            GOrchestrator -->|secured by| GProxy
        end

        subgraph "NeMo Guardrails"
            NeMo[NeMo Guardrails<br/>8000/TCP]
            NeMoProxy[kube-rbac-proxy<br/>8443/TCP]

            NeMo -->|secured by| NeMoProxy
        end
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>v1]
        LMEvalJobCR[LMEvalJob CR<br/>v1alpha1]
        GuardrailsOrchestratorCR[GuardrailsOrchestrator CR<br/>v1alpha1]
        NemoGuardrailsCR[NemoGuardrails CR<br/>v1alpha1]
    end

    subgraph "External Dependencies"
        KServe[KServe<br/>InferenceServices]
        Istio[Istio Service Mesh<br/>VirtualService/DestinationRule]
        OpenShiftRoutes[OpenShift Routes]
        Kueue[Kueue<br/>Workloads]
        Prometheus[Prometheus<br/>ServiceMonitor]
    end

    %% CRD to Operator relationships
    TrustyAIServiceCR -->|watched by| Operator
    LMEvalJobCR -->|watched by| Operator
    GuardrailsOrchestratorCR -->|watched by| Operator
    NemoGuardrailsCR -->|watched by| Operator

    %% Operator creates managed resources
    Operator -->|creates/manages| TASDeployment
    Operator -->|creates/manages| LMEvalJob
    Operator -->|creates/manages| GOrchestrator
    Operator -->|creates/manages| NeMo

    %% External integrations
    Operator -->|patches| KServe
    Operator -->|creates| Istio
    Operator -->|creates| OpenShiftRoutes
    Operator -->|integrates| Kueue
    Operator -->|configures| Prometheus

    TASDeployment -->|monitors| KServe
    GOrchestrator -->|calls| KServe
    LMEvalJob -->|evaluates| KServe

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333
    style LMEvalJobCR fill:#f5a623,stroke:#333
    style GuardrailsOrchestratorCR fill:#f5a623,stroke:#333
    style NemoGuardrailsCR fill:#f5a623,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#999,stroke:#333
    style OpenShiftRoutes fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
