        direction TB
        Manager["Manager<br/>:8080 metrics | :8081 health"]
        TASCtrl["TAS Controller"]
        LMESCtrl["LMES Controller"]
        GORCHCtrl["GORCH Controller"]
        NeMoCtrl["NeMo Guardrails Controller"]
        JobMgrCtrl["Job Manager Controller"]
        Manager --> TASCtrl
        Manager --> LMESCtrl
        Manager --> GORCHCtrl
        Manager --> NeMoCtrl
        Manager --> JobMgrCtrl
    end

    %% CRDs
    TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1,v1"]
    LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GuardrailsOrchestratorCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NemoGuardrailsCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD Watches
    TrustyAIServiceCR -->|watched by| TASCtrl
    LMEvalJobCR -->|watched by| LMESCtrl
    GuardrailsOrchestratorCR -->|watched by| GORCHCtrl
    NemoGuardrailsCR -->|watched by| NeMoCtrl

    %% TAS Created Resources
    TASCtrl -->|creates| TASDeployment["TAS Deployment<br/>(TrustyAI + kube-rbac-proxy)"]
    TASCtrl -->|creates| TASService["TAS Services<br/>:80/:443/:8443"]
    TASCtrl -->|creates| TASRoute["OpenShift Route<br/>TLS Reencrypt"]
    TASCtrl -->|creates| TASServiceMonitor["ServiceMonitor"]
    TASCtrl -->|creates| TASIstio["Istio DestinationRule<br/>+ VirtualService"]

    %% LMES Created Resources
    LMESCtrl -->|creates| EvalPod["Eval Pod<br/>(driver + eval containers)"]
    LMESCtrl -->|pod/exec| EvalPod

    %% GORCH Created Resources
    GORCHCtrl -->|creates| GORCHDeployment["GORCH Deployment<br/>(orchestrator + gateway +<br/>detectors + kube-rbac-proxy)"]
    GORCHCtrl -->|creates| GORCHService["GORCH Services<br/>:8432/:8490/:8034/:8480"]
    GORCHCtrl -->|creates| GORCHRoute["OpenShift Routes"]
    GORCHCtrl -->|creates| GORCHConfigMap["Auto-generated ConfigMap"]

    %% NeMo Created Resources
    NeMoCtrl -->|creates| NeMoDeployment["NeMo Deployment<br/>(NeMo + kube-rbac-proxy)"]
    NeMoCtrl -->|creates| NeMoService["NeMo Services<br/>:443/:80"]
    NeMoCtrl -->|creates| NeMoRoute["OpenShift Route"]

    %% Job Manager
    JobMgrCtrl -->|creates| KueueWorkload["Kueue Workload"]

    %% External Dependencies
    TASCtrl -->|watches/patches| KServeIS["KServe InferenceService"]
    GORCHCtrl -->|reads| KServeIS
    GORCHCtrl -->|reads| KServeSR["KServe ServingRuntime"]
    JobMgrCtrl -->|integrates| Kueue["Kueue"]

    %% Users
    User["User / Data Scientist"] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsOrchestratorCR
    User -->|creates| NemoGuardrailsCR

