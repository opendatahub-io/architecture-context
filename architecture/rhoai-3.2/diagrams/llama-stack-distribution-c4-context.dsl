// C4 Context Diagram - Llama Stack Distribution
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Developer" "Uses Llama Stack APIs for inference, agents, RAG, evaluation, and safety"

        llamaStack = softwareSystem "Llama Stack Distribution" "Unified API server for inference, agents, evaluation, safety, and RAG capabilities" {
            server = container "Llama Stack Server" "Core API server exposing Llama Stack APIs on port 8321/TCP" "Python (FastAPI/Uvicorn)"
            runConfig = container "run.yaml" "Runtime configuration defining providers, storage backends, models, and server settings" "YAML Configuration"
            embeddingModel = container "granite-embedding-125m-english" "Pre-downloaded embedding model for inline embedding" "PyTorch/sentence-transformers"
        }

        // Internal RHOAI Dependencies
        vllm = softwareSystem "vLLM Serving Runtime" "LLM and embedding inference backend" "Internal RHOAI"
        trustyaiFMS = softwareSystem "TrustyAI FMS Orchestrator" "Content safety guardrails service" "Internal RHOAI"
        trustyaiEval = softwareSystem "TrustyAI LM Eval / RAGAS" "LLM and RAG evaluation services" "Internal RHOAI"
        kubeflow = softwareSystem "Kubeflow Pipelines" "Remote evaluation pipeline orchestration" "Internal RHOAI"

        // Data Stores
        postgresql = softwareSystem "PostgreSQL" "Persistent KV and SQL storage backend" "Data Store"
        milvus = softwareSystem "Milvus" "Remote vector database for similarity search" "Data Store"
        pgvector = softwareSystem "pgvector" "PostgreSQL-based vector database" "Data Store"

        // External Cloud Services
        bedrock = softwareSystem "AWS Bedrock" "Remote LLM inference service" "External Cloud"
        azureOpenAI = softwareSystem "Azure OpenAI" "Remote LLM inference service" "External Cloud"
        vertexAI = softwareSystem "Google Vertex AI" "Remote LLM inference service" "External Cloud"
        openai = softwareSystem "OpenAI API" "Remote LLM inference service" "External Cloud"
        watsonx = softwareSystem "IBM WatsonX" "Remote LLM inference service" "External Cloud"
        braveSearch = softwareSystem "Brave Search API" "Web search tool runtime" "External Cloud"
        tavily = softwareSystem "Tavily Search API" "Web search tool runtime" "External Cloud"
        s3 = softwareSystem "AWS S3" "File storage" "External Cloud"
        huggingface = softwareSystem "HuggingFace Hub" "Model and dataset downloads" "External Cloud"

        // Platform Infrastructure
        rhoaiPlatform = softwareSystem "RHOAI Platform" "Gateway API, kube-rbac-proxy, service mesh" "Platform"

        // Relationships
        user -> llamaStack "Sends API requests via" "HTTP/8321"
        user -> rhoaiPlatform "Connects through" "HTTPS"
        rhoaiPlatform -> llamaStack "Routes traffic to" "HTTP/8321"

        llamaStack -> vllm "Sends inference requests" "HTTP/HTTPS, API Token"
        llamaStack -> trustyaiFMS "Sends safety check requests" "HTTP/HTTPS"
        llamaStack -> trustyaiEval "Submits evaluation jobs" "HTTP/HTTPS, Token"
        llamaStack -> kubeflow "Orchestrates evaluation pipelines" "HTTP/HTTPS, Token"

        llamaStack -> postgresql "Stores persistent state" "PostgreSQL/5432, Username/Password"
        llamaStack -> milvus "Performs vector search" "gRPC/HTTP, Token"
        llamaStack -> pgvector "Performs vector search" "PostgreSQL/5432, Username/Password"

        llamaStack -> bedrock "Remote inference" "HTTPS/443, Bearer Token"
        llamaStack -> azureOpenAI "Remote inference" "HTTPS/443, API Key"
        llamaStack -> vertexAI "Remote inference" "HTTPS/443, SA Credentials"
        llamaStack -> openai "Remote inference" "HTTPS/443, API Key"
        llamaStack -> watsonx "Remote inference" "HTTPS/443, API Key"
        llamaStack -> braveSearch "Web search" "HTTPS/443, API Key"
        llamaStack -> tavily "Web search" "HTTPS/443, API Key"
        llamaStack -> s3 "File storage" "HTTPS/443, Access Key"
        llamaStack -> huggingface "Downloads models/datasets" "HTTPS/443, Optional Token"
    }

    views {
        systemContext llamaStack "SystemContext" {
            include *
            autoLayout
        }

        container llamaStack "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Data Store" {
                background #f5a623
                color #ffffff
                shape Cylinder
            }
            element "External Cloud" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #ffe6cc
                color #333333
            }
        }
    }
}
