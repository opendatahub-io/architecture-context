        end
    end

    subgraph ControllerZone["CONTROLLER (NetworkPolicy: modelmesh-controller)"]
        Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>8080/TCP metrics<br/>8081/TCP health probes<br/>9443/TCP webhook (TLS)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd<br/>2379/TCP gRPC<br/>plaintext/TLS<br/>Basic Auth"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        S3["Object Storage (S3/MinIO)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AccessKey/SecretKey"]
        OpenShiftOAuth["OpenShift OAuth<br/>HTTPS TLS<br/>Token Validation"]
