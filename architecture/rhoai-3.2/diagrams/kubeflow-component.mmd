graph TB
    subgraph "Notebook Controller (Kubeflow)"
        Manager[Manager<br/>Controller Process]
        NotebookReconciler[NotebookReconciler<br/>Controller]
        CullingReconciler[CullingReconciler<br/>Optional Controller]
        MetricsExporter[Metrics Exporter<br/>Prometheus]
        RBACProxy[kube-rbac-proxy<br/>Sidecar]

        Manager --> NotebookReconciler
        Manager --> CullingReconciler
        Manager --> MetricsExporter
        RBACProxy -->|proxies| MetricsExporter
    end

    subgraph "Custom Resources"
        NotebookCRv1[Notebook CR v1<br/>kubeflow.org]
        NotebookCRv1beta1[Notebook CR v1beta1<br/>kubeflow.org]
        NotebookCRv1alpha1[Notebook CR v1alpha1<br/>kubeflow.org]
    end

    subgraph "Managed Resources"
        StatefulSet[StatefulSet<br/>Notebook Instance]
        Service[Service<br/>ClusterIP]
        VirtualService[Istio VirtualService<br/>Optional]
        NotebookPod[Notebook Pod<br/>Jupyter Server]

        StatefulSet --> NotebookPod
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Istio[Istio<br/>Service Mesh]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    subgraph "Integration Points"
        JupyterWebApp[jupyter-web-app<br/>UI Frontend]
    end

    %% User interactions
    User[Data Scientist] -->|creates via| JupyterWebApp
    JupyterWebApp -->|creates| NotebookCRv1

    %% CR watching
    NotebookCRv1 -->|watched by| NotebookReconciler
    NotebookCRv1beta1 -->|watched by| NotebookReconciler
    NotebookCRv1alpha1 -->|watched by| NotebookReconciler

    %% Resource creation
    NotebookReconciler -->|creates/updates| StatefulSet
    NotebookReconciler -->|creates/updates| Service
    NotebookReconciler -->|creates/updates| VirtualService

    %% Culling
    CullingReconciler -->|queries /api/kernels| NotebookPod
    CullingReconciler -->|updates annotations| NotebookCRv1
    NotebookReconciler -->|scales down| StatefulSet

    %% External dependencies
    NotebookReconciler -->|API calls| K8sAPI
    CullingReconciler -->|API calls| K8sAPI
    NotebookReconciler -->|creates when USE_ISTIO=true| Istio
    Prometheus -->|scrapes| RBACProxy

    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style CullingReconciler fill:#4a90e2,stroke:#333,stroke-width:2px
    style MetricsExporter fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookCRv1 fill:#f5a623,stroke:#333,stroke-width:2px
    style NotebookCRv1beta1 fill:#f5a623,stroke:#333,stroke-width:1px
    style NotebookCRv1alpha1 fill:#f5a623,stroke:#333,stroke-width:1px
    style StatefulSet fill:#7ed321,stroke:#333,stroke-width:2px
    style Service fill:#7ed321,stroke:#333,stroke-width:2px
    style VirtualService fill:#7ed321,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style NotebookPod fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Prometheus fill:#999,stroke:#333,stroke-width:2px
    style JupyterWebApp fill:#50e3c2,stroke:#333,stroke-width:2px
