// C4 Context Diagram: kube-auth-proxy
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "User / Data Scientist" "Accesses RHOAI applications via browser or API client"
        envoyGateway = person "Envoy Gateway" "Gateway API ingress controller requesting ext_authz decisions"

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "FIPS-compliant dual-mode authentication (OIDC/OAuth) and authorization (RBAC) sidecar proxy for RHOAI" {
            entrypoint = container "entrypoint" "Mode-switching wrapper binary, selects auth or rbac mode via PROXY_MODE env var" "Go Binary"
            authProxy = container "kube-auth-proxy" "OIDC and OpenShift OAuth authentication proxy, intercepts requests and handles authn flows" "Go Reverse Proxy" {
                tags "AuthMode"
            }
            rbacProxy = container "kube-rbac-proxy" "Kubernetes RBAC authorization proxy using TokenReview and SubjectAccessReview" "Go Reverse Proxy" {
                tags "RBACMode"
            }
            sessionStore = container "Session Store" "Manages user sessions via cookies or optional Redis-backed stores" "Middleware"
        }

        // External Systems
        oidcProvider = softwareSystem "External OIDC Provider" "Standards-compliant OIDC identity provider (BYOIDC)" {
            tags "External"
        }
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "OpenShift built-in OAuth service with auto-discovery" {
            tags "External"
        }
        k8sAPI = softwareSystem "Kubernetes API Server" "Provides TokenReview, SubjectAccessReview, and user.openshift.io APIs" {
            tags "External"
        }
        redis = softwareSystem "Redis" "Optional distributed session storage (Sentinel/Cluster supported)" {
            tags "External"
        }

        // Internal RHOAI Systems (consumers of the sidecar)
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Red Hat OpenShift AI Dashboard" {
            tags "Internal RHOAI"
        }
        notebookControllers = softwareSystem "Notebook Controllers" "Jupyter notebook management controllers" {
            tags "Internal RHOAI"
        }
        modelServing = softwareSystem "Model Serving" "ML model inference endpoints (KServe, ModelMesh)" {
            tags "Internal RHOAI"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "External"
        }

        // Upstream Application (generic)
        upstreamApp = softwareSystem "Upstream Application" "The application being protected by the sidecar proxy" {
            tags "Internal RHOAI"
        }

        // Relationships
        user -> kubeAuthProxy "Authenticates via OIDC/OAuth or presents Bearer token" "HTTPS/443"
        envoyGateway -> kubeAuthProxy "Checks auth status via ext_authz" "HTTP/4180 /oauth2/auth"

        kubeAuthProxy -> oidcProvider "OIDC discovery, token exchange, userinfo" "HTTPS/443"
        kubeAuthProxy -> openshiftOAuth "OAuth authorization, token redemption" "HTTPS/443"
        kubeAuthProxy -> k8sAPI "TokenReview, SubjectAccessReview, user info" "HTTPS/443"
        kubeAuthProxy -> redis "Session storage (optional)" "TCP/6379"
        kubeAuthProxy -> upstreamApp "Forwards authenticated/authorized requests" "HTTP/configurable"

        prometheus -> kubeAuthProxy "Scrapes metrics" "HTTP(S)/configurable /metrics"

        // Container-level relationships
        entrypoint -> authProxy "Starts in auth mode" "PROXY_MODE=auth"
        entrypoint -> rbacProxy "Starts in rbac mode (default)" "PROXY_MODE=rbac"
        authProxy -> oidcProvider "OIDC token exchange" "HTTPS/443"
        authProxy -> openshiftOAuth "OAuth token redemption" "HTTPS/443"
        authProxy -> sessionStore "Stores/retrieves sessions"
        sessionStore -> redis "Distributed sessions" "TCP/6379"
        rbacProxy -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443"
        authProxy -> upstreamApp "Forward with X-Forwarded-User/Email/Groups" "HTTP"
        rbacProxy -> upstreamApp "Forward with x-remote-user/groups" "HTTP/h2c"

        // Sidecar usage
        rhoaiDashboard -> kubeAuthProxy "Uses as sidecar (auth/rbac mode)" "4180 or 8443/TCP"
        notebookControllers -> kubeAuthProxy "Uses as sidecar (rbac mode)" "8443/TCP"
        modelServing -> kubeAuthProxy "Uses as sidecar (rbac mode)" "8443/TCP"
    }

    views {
        systemContext kubeAuthProxy "SystemContext" {
            include *
            autoLayout
        }

        container kubeAuthProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "AuthMode" {
                background #4a90e2
            }
            element "RBACMode" {
                background #4a90e2
            }
        }
    }
}
