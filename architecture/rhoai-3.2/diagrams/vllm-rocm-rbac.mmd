graph TD
    subgraph "Note: RBAC Managed by Platform"
        Note["vLLM ROCm does NOT define its own RBAC.<br/>All RBAC is managed by platform components."]
    end

    subgraph "Platform RBAC Components"
        direction TB

        subgraph "KServe RBAC"
            KServeSA["ServiceAccount<br/>kserve-controller-manager"]
            KServeCR["ClusterRole<br/>kserve-manager-role"]
            KServeSA -->|"bound via ClusterRoleBinding"| KServeCR
            KServeCR -->|"manages"| ISvc["InferenceService CR<br/>(deploys vLLM pods)"]
            KServeCR -->|"manages"| SRT["ServingRuntime CR<br/>(defines vLLM image)"]
        end

        subgraph "kube-rbac-proxy Auth (Pod Sidecar)"
            KRBP["kube-rbac-proxy<br/>(sidecar container)"]
            SAR["SubjectAccessReview<br/>(Kubernetes API)"]
            KRBP -->|"validates requests via"| SAR
            SAR -->|"checks"| BearerToken["Bearer Token<br/>from Client"]
        end

        subgraph "Gateway API Auth"
            GW["RHOAI Gateway<br/>(Envoy)"]
            HTTPRoute["HTTPRoute<br/>(model-specific hostname)"]
            GW -->|"routes via"| HTTPRoute
            HTTPRoute -->|"targets"| KRBP
        end

        subgraph "Service Mesh Auth (gRPC Path)"
            PeerAuth["PeerAuthentication<br/>mTLS STRICT"]
            ClientCert["Client Certificate<br/>(ModelMesh Router)"]
            PeerAuth -->|"enforces"| ClientCert
            ClientCert -->|"authenticates to"| TGISPort["vLLM TGIS :8033/gRPC"]
        end
    end

    subgraph "Container Security Context"
        VLLMPod["vLLM ROCm Pod"]
        RunAs["runAsUser: 2000<br/>(non-root)"]
        FIPS["FIPS Compliance: Enabled"]
        BaseImg["Base: rhaiis/vllm-rocm-rhel9<br/>(Red Hat certified)"]
        VLLMPod --- RunAs
        VLLMPod --- FIPS
        VLLMPod --- BaseImg
    end

    subgraph "Secrets"
        GitAuth["git-auth (Opaque)<br/>Konflux CI builds<br/>No auto-rotate"]
        ModelCreds["model-credentials (Opaque)<br/>S3/storage access<br/>No auto-rotate"]
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style KServeSA fill:#4a90e2,color:#fff
    style KServeCR fill:#f5a623,color:#fff
    style ISvc fill:#7ed321,color:#fff
    style SRT fill:#7ed321,color:#fff
    style KRBP fill:#f5a623,color:#fff
    style GW fill:#f5a623,color:#fff
    style PeerAuth fill:#e74c3c,color:#fff
    style VLLMPod fill:#4a90e2,color:#fff
