graph TD
    subgraph "Service Account"
        SA[kubeflow-trainer-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Binding"
        CRB[kubeflow-trainer-controller-manager<br/>ClusterRoleBinding<br/>Scope: cluster-wide]
    end

    subgraph "ClusterRole Permissions"
        CR[kubeflow-trainer-controller-manager<br/>ClusterRole]
    end

    subgraph "Core API Resources"
        ConfigMaps[ConfigMaps<br/>API: v1<br/>Verbs: create, get, list, patch, update, watch]
        Secrets[Secrets<br/>API: v1<br/>Verbs: create, get, list, patch, update, watch]
        Events[Events<br/>API: v1<br/>Verbs: create, patch, update, watch]
        LimitRanges[LimitRanges<br/>API: v1<br/>Verbs: get, list, watch]
    end

    subgraph "Admission Control"
        Webhooks[ValidatingWebhookConfigurations<br/>API: admissionregistration.k8s.io<br/>Verbs: get, list, update, watch]
    end

    subgraph "Coordination API"
        Leases[Leases<br/>API: coordination.k8s.io<br/>Verbs: create, get, list, update<br/>Purpose: Leader election]
    end

    subgraph "JobSet API"
        JobSets[JobSets<br/>API: jobset.x-k8s.io<br/>Verbs: create, get, list, patch, update, watch]
    end

    subgraph "Node API"
        RuntimeClasses[RuntimeClasses<br/>API: node.k8s.io<br/>Verbs: get, list, watch]
    end

    subgraph "Scheduling APIs"
        PodGroups[PodGroups<br/>API: scheduling.volcano.sh<br/>API: scheduling.x-k8s.io<br/>Verbs: create, get, list, patch, update, watch]
    end

    subgraph "Trainer CRDs"
        ClusterTrainingRuntimes[ClusterTrainingRuntimes<br/>API: trainer.kubeflow.org<br/>Verbs: get, list, patch, update, watch]
        TrainingRuntimes[TrainingRuntimes<br/>API: trainer.kubeflow.org<br/>Verbs: get, list, patch, update, watch]
        TrainJobs[TrainJobs<br/>API: trainer.kubeflow.org<br/>Verbs: get, list, patch, update, watch]
    end

    subgraph "Finalizers & Status"
        Finalizers[CRD Finalizers<br/>clustertrainingruntimes/finalizers<br/>trainingruntimes/finalizers<br/>trainjobs/finalizers<br/>Verbs: get, patch, update]
        Status[TrainJob Status<br/>trainjobs/status<br/>Verbs: get, patch, update]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Permissions
    CR -->|manages| ConfigMaps
    CR -->|manages| Secrets
    CR -->|creates| Events
    CR -->|reads| LimitRanges
    CR -->|updates| Webhooks
    CR -->|leader election| Leases
    CR -->|creates & manages| JobSets
    CR -->|reads| RuntimeClasses
    CR -->|creates & manages| PodGroups
    CR -->|watches & manages| ClusterTrainingRuntimes
    CR -->|watches & manages| TrainingRuntimes
    CR -->|watches & manages| TrainJobs
    CR -->|updates| Finalizers
    CR -->|updates| Status

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#5a9fd4,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:3px,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,stroke-width:1px
    style Secrets fill:#7ed321,stroke:#333,stroke-width:1px
    style Events fill:#7ed321,stroke:#333,stroke-width:1px
    style LimitRanges fill:#7ed321,stroke:#333,stroke-width:1px
    style Webhooks fill:#bd10e0,stroke:#333,stroke-width:1px
    style Leases fill:#50e3c2,stroke:#333,stroke-width:1px
    style JobSets fill:#f8e71c,stroke:#333,stroke-width:2px
    style RuntimeClasses fill:#7ed321,stroke:#333,stroke-width:1px
    style PodGroups fill:#f8e71c,stroke:#333,stroke-width:1px
    style ClusterTrainingRuntimes fill:#ff6b6b,stroke:#333,stroke-width:2px
    style TrainingRuntimes fill:#ff6b6b,stroke:#333,stroke-width:2px
    style TrainJobs fill:#ff6b6b,stroke:#333,stroke-width:2px
    style Finalizers fill:#ff9f43,stroke:#333,stroke-width:1px
    style Status fill:#ff9f43,stroke:#333,stroke-width:1px
