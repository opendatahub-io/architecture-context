graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]
        AuthCtrl[Authentication Controller]
        NetworkPolicyCtrl[NetworkPolicy Controller]
        mTLSCtrl[mTLS Controller]
        ValidatingWebhook[Validating Webhook]
        MutatingWebhook[Mutating Webhook]

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
        Operator --> AuthCtrl
        Operator --> NetworkPolicyCtrl
        Operator --> mTLSCtrl
        Operator --> ValidatingWebhook
        Operator --> MutatingWebhook
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Resources"
        HeadPod[Ray Head Pod<br/>GCS: 6379<br/>Dashboard: 8265<br/>Client: 10001]
        WorkerPods[Ray Worker Pods<br/>N replicas]
        HeadService[Head Service<br/>ClusterIP]

        HeadPod --> HeadService
        WorkerPods -.->|connect to| HeadPod
    end

    subgraph "Security Resources"
        NetworkPolicy[NetworkPolicies]
        Certificates[cert-manager<br/>Certificates]
        OAuthProxy[OAuth Proxy<br/>Sidecar]

        OAuthProxy -.->|sidecar in| HeadPod
    end

    subgraph "External Access"
        Route[OpenShift Route<br/>HTTPS/443]
        HTTPRoute[Gateway API<br/>HTTPRoute]

        Route -.->|routes to| HeadService
        HTTPRoute -.->|routes to| HeadService
    end

    %% User interactions
    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CR to Controller
    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Webhooks
    RayClusterCR -->|validated by| ValidatingWebhook
    RayClusterCR -->|mutated by| MutatingWebhook

    %% Controller creates resources
    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadService

    AuthCtrl -->|creates| Route
    AuthCtrl -->|creates| HTTPRoute
    AuthCtrl -->|creates| OAuthProxy

    NetworkPolicyCtrl -->|creates| NetworkPolicy
    mTLSCtrl -->|creates| Certificates

    %% External dependencies
    RayClusterCtrl -->|depends on| K8s[Kubernetes API<br/>1.26+]
    AuthCtrl -->|depends on| OpenShiftOAuth[OpenShift OAuth]
    mTLSCtrl -->|depends on| CertManager[cert-manager<br/>1.11+]
    HeadPod -->|optionally uses| ExternalRedis[External Redis<br/>GCS FT]

    %% Internal integrations
    RayClusterCtrl -.->|integrates| Kueue[Kueue<br/>optional]
    Operator -->|exposes| Metrics[Prometheus Metrics<br/>:8080/metrics]

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style RayClusterCtrl fill:#4a90e2
    style RayJobCtrl fill:#4a90e2
    style RayServiceCtrl fill:#4a90e2
    style AuthCtrl fill:#4a90e2
    style NetworkPolicyCtrl fill:#4a90e2
    style mTLSCtrl fill:#4a90e2

    style RayClusterCR fill:#f5a623
    style RayJobCR fill:#f5a623
    style RayServiceCR fill:#f5a623

    style HeadPod fill:#7ed321
    style WorkerPods fill:#7ed321

    style K8s fill:#e8e8e8
    style OpenShiftOAuth fill:#e8e8e8
    style CertManager fill:#e8e8e8
    style ExternalRedis fill:#e8e8e8
    style Kueue fill:#7ed321
