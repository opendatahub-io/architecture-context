    RSController -->|manages| RayClusterCR

    AuthController -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthController -->|creates| RefGrant["ReferenceGrant"]
    AuthController -->|creates| AuthCM["Auth ConfigMap"]
    AuthController -->|creates| AuthSA["ServiceAccount"]

    NPController -->|creates| NetPol["NetworkPolicies<br/>(head + worker)"]

    MTLSController -->|creates| Issuer["cert-manager Issuer"]
    MTLSController -->|creates| Certs["TLS Certificates<br/>(head + worker)"]

    %% External dependencies
    RCController -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP"]
