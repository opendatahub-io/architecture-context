    RayClusterCR -->|watched by| MTLSController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController

    %% Webhook
    RayClusterCR -->|validated by| Webhook

    %% Controller outputs
    RCController -->|creates| HeadPod["Ray Head Pod<br/>+ kube-rbac-proxy sidecar"]
