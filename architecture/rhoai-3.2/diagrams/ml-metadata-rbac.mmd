---
title: ML Metadata - RBAC and Security Visualization (Generated by Claude Opus 4.6)
---
graph TD
    subgraph "gRPC Client Authentication"
        Client["gRPC Client<br/>(Kubeflow Pipelines /<br/>Data Science Pipelines)"]
    end

    subgraph "Server TLS Configuration (SSLConfig)"
        ServerCert["server_cert<br/>(PEM server certificate)"]
        ServerKey["server_key<br/>(PEM private key)"]
        CustomCA["custom_ca<br/>(PEM CA certificate)"]
        ClientVerify["client_verify<br/>(mTLS enforcement)"]
    end

    subgraph "Authentication Modes"
        Insecure["Insecure Mode<br/>(No SSL config)<br/>Plaintext gRPC"]
        TLSOnly["TLS Mode<br/>(server_cert + server_key)<br/>Encrypted, no client auth"]
        MTLS["mTLS Mode<br/>(+ client_verify=true)<br/>Encrypted + client cert required"]
    end

    subgraph "Database Authentication"
        MySQLAuth["MySQL Auth<br/>Username/Password<br/>+ Optional TLS client certs"]
        PostgreSQLAuth["PostgreSQL Auth<br/>Username/Password or Passfile<br/>+ sslmode (disable/allow/<br/>verify-ca/verify-full)"]
    end

    subgraph "Secrets"
        ConfigFile["metadata_store_server_config_file<br/>(ConfigMap/File)<br/>Provisioned by: Platform Operator"]
        MySQLPwd["mysql_config_password<br/>(Env/Flag)<br/>No auto-rotate"]
        PostgreSQLPwd["postgres_config_password<br/>(Env/Flag)<br/>No auto-rotate"]
        SSLCerts["SSL Certificates<br/>(server_key, server_cert, custom_ca)<br/>cert-manager or manual"]
        DBCerts["DB SSL Certs<br/>(sslcert, sslkey, sslrootcert)<br/>For MySQL & PostgreSQL"]
    end

    %% Authentication flow
    Client -->|"Option 1"| Insecure
    Client -->|"Option 2"| TLSOnly
    Client -->|"Option 3"| MTLS

    ServerCert -->|configures| TLSOnly
    ServerKey -->|configures| TLSOnly
    ServerCert -->|configures| MTLS
    ServerKey -->|configures| MTLS
    CustomCA -->|validates clients| MTLS
    ClientVerify -->|enables| MTLS

    %% Database auth
    MySQLPwd -->|credentials| MySQLAuth
    PostgreSQLPwd -->|credentials| PostgreSQLAuth
    DBCerts -->|TLS certs| MySQLAuth
    DBCerts -->|TLS certs| PostgreSQLAuth

    %% Config
    ConfigFile -->|provides| ServerCert
    ConfigFile -->|provides| ServerKey
    ConfigFile -->|provides| CustomCA

