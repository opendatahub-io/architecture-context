/*
 * TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/trustyai-explainability.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Requests fairness metrics, drift analysis, and model explanations"
        sre = person "SRE / Platform Admin" "Monitors fairness and drift metrics via Prometheus"

        trustyai = softwareSystem "TrustyAI Explainability" "AI fairness metrics, model explainability, and data drift detection service" {
            core = container "explainability-core" "Core XAI library: fairness metrics (SPD, DIR), explainers (LIME, SHAP, CF, PDP, TSSaliency), drift detectors (KS Test, Fourier MMD, Meanshift)" "Java Library"
            service = container "explainability-service" "Quarkus REST service exposing XAI capabilities, with Prometheus metric publishing and payload ingestion" "Quarkus 3.8.5, Port 8080/TCP"
            connectors = container "explainability-connectors" "gRPC client connectors for KServe V2 Inference Protocol" "Java, gRPC 1.75.0"
            arrow = container "explainability-arrow" "Apache Arrow bridge for Java-Python data interchange" "Java Library"
            csvStorage = container "CSVDataSource" "PVC-backed CSV file storage for inference data" "PersistentVolumeClaim"
            dbStorage = container "HibernateDataSource" "Database-backed storage for inference data" "Hibernate ORM"

            service -> core "Uses for metrics, explanations, drift detection"
            service -> connectors "Uses for gRPC model calls"
            service -> csvStorage "Reads/writes inference data" "File I/O"
            service -> dbStorage "Reads/writes inference data" "JDBC/3306"
        }

        modelmesh = softwareSystem "ModelMesh Serving" "Model serving platform for inference" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference platform" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages TrustyAI Service deployment lifecycle" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        mariadb = softwareSystem "MariaDB / MySQL" "Relational database for inference data storage" "External"
        minio = softwareSystem "MinIO / S3" "Object storage for inference data" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "RHOAI web console" "Internal RHOAI"

        datascientist -> trustyai "Requests fairness metrics, explanations" "REST/HTTP 8080"
        sre -> prometheus "Views fairness/drift dashboards"

        modelmesh -> trustyai "Sends inference payloads" "HTTP/8080 POST /consumer/kserve/v2"
        kserve -> trustyai "Sends inference payloads via CloudEvents" "HTTP/8080 CloudEvents"
        trustyai -> kserve "Queries models for explanations" "gRPC KServe V2"
        trustyai -> modelmesh "Queries models for explanations" "gRPC KServe V2"
        prometheus -> trustyai "Scrapes fairness/drift metrics" "HTTP/8080 GET /q/metrics"
        trustyaiOperator -> trustyai "Manages deployment lifecycle" "Kubernetes API"
        trustyai -> mariadb "Stores/retrieves inference data" "MySQL/3306"
        trustyai -> minio "Stores/retrieves inference data" "HTTP(S)"
        odhDashboard -> trustyai "Displays TrustyAI metrics" "REST/HTTP"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
