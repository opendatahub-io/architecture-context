/*
 * ML Metadata (MLMD) - C4 Context Diagram
 * Generated by: Claude Opus 4.6
 *
 * View with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace ml-metadata-c4-context.dsl -format png
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Runs ML pipelines that generate metadata"
        platformoperator = person "Platform Operator" "Deploys and configures MLMD server"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving metadata associated with ML workflows" {
            server = container "metadata_store_server" "C++ gRPC server exposing MetadataStoreService API on port 8080" "C++ / gRPC / Bazel"
            serviceImpl = container "MetadataStoreServiceImpl" "Implements all 52 RPC methods; thread-safe, sequential concurrent access" "C++ gRPC Service"
            metadataStore = container "MetadataStore" "Core CRUD operations for artifacts, executions, contexts, events" "C++ Library"
            pythonClient = container "Python Client Library" "High-level Python API for interacting with MLMD" "Python / grpcio"
        }

        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "ML pipeline orchestration; primary consumer of MLMD" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "RHOAI pipeline orchestration; deploys and manages MLMD instances" "Internal RHOAI"
        mysql = softwareSystem "MySQL / MariaDB" "Relational database for persistent metadata storage" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for persistent metadata storage" "External"

        datascientist -> kubeflowPipelines "Runs ML pipelines"
        kubeflowPipelines -> mlmd "Records and retrieves pipeline metadata" "gRPC/8080"
        dsp -> mlmd "Deploys MLMD server; uses for metadata tracking" "Kubernetes API + gRPC/8080"
        platformoperator -> dsp "Configures pipeline deployments"
        mlmd -> mysql "Stores metadata" "MySQL/3306 (Optional TLS)"
        mlmd -> postgresql "Stores metadata" "PostgreSQL/5432 (Optional TLS)"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
