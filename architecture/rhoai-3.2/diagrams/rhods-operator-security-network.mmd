%% Security Network Diagram for rhods-operator
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS reencrypt (OcpRoute)<br/>or LoadBalancer"]
    end

    subgraph GatewayInfra["GATEWAY INFRASTRUCTURE (openshift-ingress)"]
        direction TB

        Gateway["data-science-gateway<br/>(Envoy/Gateway API)<br/>443/TCP TLS Terminate<br/>Cert: data-science-gatewayconfig-tls"]

        EnvoyFilter["EnvoyFilter<br/>data-science-authn-filter<br/>ext_authz intercept"]

        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS (auth)<br/>9000/TCP HTTP (metrics)<br/>Cert: kube-auth-proxy-tls<br/>Creds: kube-auth-proxy-creds"]

        DestRule["DestinationRule<br/>data-science-tls-rule<br/>mTLS ports 8443, 443"]

        Gateway --> EnvoyFilter
        EnvoyFilter -->|ext_authz<br/>8443/TCP HTTPS| AuthProxy
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        direction TB

        Operator["rhods-operator<br/>Controller Manager<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP"]

        WebhookSvc["Webhook Server<br/>443/TCP → 9443/TCP HTTPS<br/>Cert: webhook-cert<br/>Auth: TLS client cert"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Client Creds"]

        Prometheus["Prometheus<br/>(openshift-monitoring)<br/>Scrapes metrics"]

        Istio["Istio / Service Mesh<br/>EnvoyFilter + DestinationRule"]

        OLM["OLM<br/>Subscription/CSV"]

        PromOp["Prometheus Operator<br/>ServiceMonitor CRDs"]
    end

    subgraph BackendServices["BACKEND SERVICES (via HTTPRoute)"]
        Backend["Dashboard / KServe /<br/>Workbenches / etc.<br/>443 or 8443/TCP HTTPS"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| Router
    Router -->|"HTTPS/443<br/>TLS reencrypt"| Gateway
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2/OIDC"| OAuthServer
    EnvoyFilter -->|"HTTPS/443 or 8443<br/>mTLS (DestinationRule)<br/>Bearer Token"| Backend

    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator --- WebhookSvc

    Prometheus -->|"HTTP/9000<br/>plaintext<br/>NetworkPolicy allows"| AuthProxy
    Prometheus -->|"HTTP/8080<br/>plaintext"| Operator

