graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Administrator]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - DMZ)"]
        PrometheusRoute["Prometheus Route<br/>prometheus-redhat-ods-monitoring.apps.{cluster}<br/>443/TCP → 9091/TCP<br/>TLS 1.2+ Edge Termination<br/>OpenShift OAuth"]
        AlertmanagerRoute["Alertmanager Route<br/>alertmanager-redhat-ods-monitoring.apps.{cluster}<br/>443/TCP → 9093/TCP<br/>TLS 1.2+ Edge Termination<br/>OpenShift OAuth"]
    end

    subgraph Monitoring["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>SA: prometheus<br/>Port: 9091/TCP HTTP<br/>RBAC: cluster-monitoring-view"]
        Alertmanager["Alertmanager<br/>Port: 9093/TCP HTTP"]
        BlackboxExporter["Blackbox Exporter<br/>Port: 9115/TCP HTTP"]
    end

    subgraph Operator["OPERATOR NAMESPACE (redhat-ods-operator)"]
        OperatorPod["RHOAI Operator Pod<br/>SA: controller-manager<br/>Replicas: 3 (HA)<br/>Security: runAsNonRoot, drop ALL caps"]

        subgraph Services["Operator Services"]
            MetricsService["controller-manager-metrics-service<br/>8443/TCP HTTPS<br/>TLS: kube-rbac-proxy + service-ca<br/>Auth: Bearer Token"]
            WebhookService["webhook-service<br/>443/TCP → 9443/TCP HTTPS<br/>TLS 1.2+ service-ca<br/>Auth: mTLS (API server)"]
            HealthEndpoints["Health Endpoints<br/>/healthz, /readyz<br/>8081/TCP HTTP<br/>Auth: None (kubelet only)"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount tokens"]
        Kubelet["Kubelet<br/>Health probe access"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OLM["OLM<br/>Operator Lifecycle Manager<br/>443/TCP HTTPS<br/>ServiceAccount Auth"]
        ImageRegistry["Image Registries<br/>registry.redhat.io, quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Secrets"]
        ComponentWebhooks["Component Webhooks<br/>443/TCP HTTPS<br/>mTLS"]
    end

    subgraph DeployedResources["DEPLOYED RESOURCES"]
        DSC["DataScienceCluster CR"]
        DSCI["DSCInitialization CR"]
        ComponentCRs["Component CRs<br/>(Dashboard, KServe, etc.)"]
        K8sResources["K8s Resources<br/>(Deployments, Services, ConfigMaps)"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+ Edge<br/>OAuth| PrometheusRoute
    User -->|HTTPS/443<br/>TLS 1.2+ Edge<br/>OAuth| AlertmanagerRoute

    %% Ingress to Monitoring
    PrometheusRoute -->|HTTP/9091<br/>Internal| Prometheus
    AlertmanagerRoute -->|HTTP/9093<br/>Internal| Alertmanager

    %% Monitoring to Operator
    Prometheus -->|HTTPS/8443<br/>TLS service-ca<br/>Bearer Token| MetricsService
    MetricsService -.->|Proxied by<br/>kube-rbac-proxy| OperatorPod

    %% Prometheus internal
    Prometheus -->|HTTP/9093<br/>Internal| Alertmanager
    Prometheus -->|HTTP/9115<br/>Internal| BlackboxExporter

    %% User to API Server
    User -->|kubectl apply<br/>HTTPS/6443 TLS 1.2+<br/>kubeconfig| K8sAPI

    %% API Server to Operator
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>Webhook validation| WebhookService
    WebhookService -.->|Handled by| OperatorPod

    %% Operator to API Server
    OperatorPod -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% API Server to Resources
    K8sAPI -->|Creates/Manages| DSC
    K8sAPI -->|Creates/Manages| DSCI
    K8sAPI -->|Creates/Manages| ComponentCRs
    K8sAPI -->|Creates/Manages| K8sResources

    %% Kubelet health checks
    Kubelet -->|HTTP/8081<br/>Plaintext<br/>Internal only| HealthEndpoints
    HealthEndpoints -.->|Served by| OperatorPod

    %% Operator to External Services
    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| OLM
    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| ImageRegistry
    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>mTLS| ComponentWebhooks

    %% Network Policy annotations
    OperatorPod -.->|"NetworkPolicy: Allow from<br/>monitoring, console, OLM, ODH namespaces"| Operator
    Prometheus -.->|"NetworkPolicy: Allow from<br/>same namespace, openshift-monitoring"| Monitoring

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef resources fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class PrometheusRoute,AlertmanagerRoute ingress
    class Prometheus,Alertmanager,BlackboxExporter monitoring
    class OperatorPod,MetricsService,WebhookService,HealthEndpoints operator
    class K8sAPI,Kubelet controlplane
    class OLM,ImageRegistry,ComponentWebhooks externalservice
    class DSC,DSCI,ComponentCRs,K8sResources resources
