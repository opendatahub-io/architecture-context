// C4 Context Diagram: Guardrails Detectors
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/guardrails-detectors.md

workspace {
    model {
        user = person "Application Developer" "Deploys and configures guardrail detectors for content safety"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Collection of detector microservices for text content analysis including PII detection, ML classification, and LLM-as-a-judge evaluation" {
            builtInDetector = container "Built-in Detector" "Regex-based PII detection, file-type validation (JSON/XML/YAML), and custom user-defined detector functions" "Python FastAPI, port 8080" "Microservice"
            huggingfaceDetector = container "HuggingFace Detector" "Loads HuggingFace transformer models for ML-based text classification (toxicity, harm, jailbreak, bias)" "Python FastAPI + PyTorch, port 8000" "Microservice"
            llmJudgeDetector = container "LLM Judge Detector" "Uses vllm_judge for LLM-as-a-judge evaluations (safety, accuracy, helpfulness)" "Python FastAPI + vllm-judge, port 8000" "Microservice"
            commonLibrary = container "Common Library" "Shared FastAPI base app, API schema (Pydantic), Prometheus instrumentation" "Python Package" "Library"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestrates guardrail evaluations by routing requests to detector services" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Manages detector deployment lifecycle via ServingRuntime and InferenceService CRs" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS encryption and service identity for inter-service communication" "External"
        vllmServer = softwareSystem "vLLM Inference Server" "OpenAI-compatible inference server for LLM-as-a-judge evaluations" "Internal RHOAI"
        s3Storage = softwareSystem "S3/MinIO Storage" "Stores model artifacts for HuggingFace detector" "External"
        prometheus = softwareSystem "Prometheus" "Scrapes detector metrics for observability" "External"

        // Relationships
        orchestrator -> guardrailsDetectors "Invokes detector endpoints for guardrail evaluation" "HTTP/8080,8000 Istio mTLS"
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080 Istio mTLS"
        orchestrator -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000 Istio mTLS"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents" "HTTP/8000 Istio mTLS"

        llmJudgeDetector -> vllmServer "Sends evaluation prompts for LLM-as-a-judge scoring" "HTTP/8080 Istio mTLS"
        huggingfaceDetector -> s3Storage "Loads model artifacts at startup via KServe Storage Initializer" "HTTP/9000 AWS IAM"

        kserve -> guardrailsDetectors "Manages detector pods via ServingRuntime and InferenceService"
        istio -> guardrailsDetectors "Provides mTLS and service identity"
        prometheus -> guardrailsDetectors "Scrapes /metrics endpoint" "HTTP/8080,8000"

        builtInDetector -> commonLibrary "Uses shared base app and schemas"
        huggingfaceDetector -> commonLibrary "Uses shared base app and schemas"
        llmJudgeDetector -> commonLibrary "Uses shared base app and schemas"

        user -> orchestrator "Sends content for guardrail evaluation"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Microservice" {
                shape RoundedBox
                background #4a90e2
                color #ffffff
            }
            element "Library" {
                shape Component
                background #6cb4ee
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
