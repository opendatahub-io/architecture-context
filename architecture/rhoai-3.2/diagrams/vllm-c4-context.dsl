/*
 * vLLM CUDA Serving Runtime - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / Application" "Sends inference requests to deployed LLM models"

        vllm = softwareSystem "vLLM CUDA Serving Runtime" "GPU-accelerated LLM inference runtime with OpenAI-compatible HTTP and TGIS gRPC APIs" {
            adapter = container "vllm-tgis-adapter" "Wraps vLLM with TGIS-compatible gRPC interface; serves as container entrypoint" "Python"
            engine = container "vLLM Engine" "Core LLM inference with PagedAttention, continuous batching, CUDA kernels" "Python/C++"
            cuda = container "CUDA Kernels" "GPU compute for model inference" "CUDA"
        }

        kserve = softwareSystem "KServe" "Orchestrates deployment, scaling, and traffic routing for serving runtimes" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Alternative model serving orchestration with multi-model support" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and artifact locations" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "User interface for deploying models with serving runtimes" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / Monitoring" "Metrics collection and monitoring" "Internal RHOAI"

        istio = softwareSystem "Gateway / Istio" "Ingress gateway for external traffic, TLS termination" "External"
        s3 = softwareSystem "S3-compatible Storage" "Model weight and artifact storage" "External"
        hfHub = softwareSystem "Hugging Face Hub" "Public model and tokenizer repository" "External"
        gpu = softwareSystem "NVIDIA GPU Hardware" "CUDA-capable GPU for inference compute" "External"

        user -> istio "Sends inference requests" "HTTPS/443 TLS 1.2+"
        istio -> vllm "Routes to vLLM pod" "HTTP/8000 plaintext"
        user -> vllm "Direct gRPC inference" "gRPC/8033"

        kserve -> vllm "Deploys, scales, manages pods" "Kubernetes API"
        modelmesh -> vllm "Routes inference requests" "gRPC/8033"
        dashboard -> kserve "UI-driven model deployment"
        modelRegistry -> kserve "Provides model artifact locations"
        prometheus -> vllm "Scrapes metrics" "HTTP/8000 /metrics"

        vllm -> s3 "Downloads model weights at startup" "HTTPS/443 TLS 1.2+"
        vllm -> hfHub "Downloads models/tokenizers if not cached" "HTTPS/443 TLS 1.2+"
        vllm -> gpu "CUDA compute for inference" "CUDA device"
    }

    views {
        systemContext vllm "SystemContext" {
            include *
            autoLayout
        }

        container vllm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
