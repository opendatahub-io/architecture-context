// Model Registry Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages ML model registries and catalogs"
        admin = person "Platform Admin" "Manages RHOAI platform and operator configuration"

        modelRegistryOperator = softwareSystem "Model Registry Operator" "Kubernetes operator managing Model Registry and Model Catalog instances on OpenShift" {
            mrReconciler = container "ModelRegistryReconciler" "Reconciles ModelRegistry CRs; creates Deployments, Services, Routes, RBAC per instance" "Go Controller (controller-runtime)"
            mcReconciler = container "ModelCatalogReconciler" "Manages singleton model-catalog service with PostgreSQL, kube-rbac-proxy, RBAC" "Go Controller (controller-runtime)"
            migrationMgr = container "StorageMigrationManager" "Monitors CRD version changes; triggers v1alpha1-to-v1beta1 migration" "Go Background Process"
            webhooks = container "Admission Webhooks" "Defaults and validates ModelRegistry CR specs" "Mutating + Validating Webhooks"
            capDetect = container "Cluster Capability Detection" "Detects OpenShift vs K8s, BYOIDC mode, available APIs at startup" "Go Utility"
        }

        managedRegistry = softwareSystem "Model Registry Instance" "Per-instance model registry with REST API, kube-rbac-proxy auth, and database backend" {
            mrContainer = container "model-registry REST" "ML model metadata REST API" "Go Service, 8080/TCP HTTP"
            kubeRbacProxy = container "kube-rbac-proxy" "Authentication sidecar performing SubjectAccessReview" "Go Proxy, 8443/TCP HTTPS"
            postgres = container "PostgreSQL 16" "Model metadata storage" "PostgreSQL, 5432/TCP"
        }

        modelCatalog = softwareSystem "Model Catalog" "Singleton catalog service aggregating model metadata across registries" {
            catContainer = container "Catalog REST" "Model catalog REST API" "Go Service, 8080/TCP HTTP"
            catProxy = container "Catalog kube-rbac-proxy" "Authentication sidecar for catalog" "Go Proxy, 8443/TCP HTTPS"
            catPostgres = container "Catalog PostgreSQL" "Catalog metadata storage" "PostgreSQL, 5432/TCP"
        }

        // External systems
        rhodsOperator = softwareSystem "rhods-operator" "RHOAI platform operator that deploys component operators" "Internal RHOAI"
        k8sApiServer = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management and auth delegation" "Infrastructure"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller exposing routes externally" "Infrastructure"
        openshiftServingCert = softwareSystem "OpenShift Serving Cert Controller" "Auto-provisions TLS certificates for annotated services" "Infrastructure"
        rhoaiAuthService = softwareSystem "RHOAI Auth Service" "Provides admin group configuration for catalog RBAC" "Internal RHOAI"
        rhoaiModelRegistryCR = softwareSystem "RHOAI ModelRegistry Component CR" "Platform component CR for owner references" "Internal RHOAI"
        externalDB = softwareSystem "External Database" "User-provided PostgreSQL or MySQL database" "External"

        // Relationships
        user -> modelRegistryOperator "Creates ModelRegistry CRs via kubectl/API"
        user -> managedRegistry "Accesses model metadata via REST API" "HTTPS/443"
        user -> modelCatalog "Browses model catalog" "HTTPS/443"
        admin -> modelRegistryOperator "Configures operator and registry instances"

        rhodsOperator -> modelRegistryOperator "Deploys via Kustomize overlay" "Kustomize"
        modelRegistryOperator -> k8sApiServer "Watches CRs, creates/manages resources" "HTTPS/6443"
        modelRegistryOperator -> managedRegistry "Creates and manages lifecycle"
        modelRegistryOperator -> modelCatalog "Creates and manages singleton catalog"
        modelRegistryOperator -> rhoaiAuthService "Reads admin groups for catalog RBAC" "HTTPS/6443"
        modelRegistryOperator -> rhoaiModelRegistryCR "Reads for owner references" "HTTPS/6443"

        managedRegistry -> k8sApiServer "TokenReview + SubjectAccessReview" "HTTPS/6443"
        managedRegistry -> externalDB "Model metadata storage" "PostgreSQL/5432 or MySQL/3306"
        modelCatalog -> k8sApiServer "TokenReview + SubjectAccessReview" "HTTPS/6443"

        openshiftRouter -> managedRegistry "Routes traffic to kube-rbac-proxy" "HTTPS/8443 reencrypt"
        openshiftRouter -> modelCatalog "Routes traffic to catalog proxy" "HTTPS/8443 reencrypt"
        openshiftServingCert -> managedRegistry "Provisions TLS certificates"
        openshiftServingCert -> modelCatalog "Provisions TLS certificates"
        openshiftServingCert -> modelRegistryOperator "Provisions webhook and metrics TLS certificates"

        k8sApiServer -> modelRegistryOperator "Calls admission webhooks" "HTTPS/9443"
    }

    views {
        systemContext modelRegistryOperator "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistryOperator "OperatorContainers" {
            include *
            autoLayout
        }

        container managedRegistry "RegistryContainers" {
            include *
            autoLayout
        }

        container modelCatalog "CatalogContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "External" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
