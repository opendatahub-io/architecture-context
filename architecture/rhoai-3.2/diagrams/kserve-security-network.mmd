graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ (edge termination)<br/>RequestAuthentication (JWT validation)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Port: 8012/TCP"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            Predictor["Predictor Pod<br/>SA: {isvc-name}-sa<br/>Port: 8080/TCP<br/>Init: storage-initializer<br/>Sidecar: agent, istio-proxy"]
            Transformer["Transformer Service<br/>SA: {isvc-name}-sa<br/>Port: 8080/TCP<br/>Sidecar: istio-proxy"]
            Router["Router Service<br/>InferenceGraph Mode<br/>SA: {graph-name}-router-sa<br/>Port: 8080/TCP"]
        end

        Activator -->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity + Bearer Token| Predictor
        Predictor <-->|HTTP/8080<br/>mTLS STRICT<br/>Service Identity| Transformer
        Router -->|HTTP/8080<br/>mTLS STRICT<br/>Propagated Headers| Predictor
        Router -->|HTTP/8080<br/>mTLS STRICT| Transformer
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: kserve)"]
        direction TB
        Controller["KServe Controller Manager<br/>SA: kserve-controller-manager<br/>Ports: 8080/TCP (metrics), 8081/TCP (health)"]
        Webhook["KServe Webhook Server<br/>Service: 443/TCP → 9443/TCP<br/>TLS Cert: kserve-webhook-server-cert"]

        Controller -->|manages| Webhook
    end

    subgraph K8sControlPlane["Kubernetes Control Plane"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM / Access Keys"]
        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: GCP Service Account"]
        Registry["Container Registries<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secrets"]
        ModelRegistry["Model Registry (ODH)<br/>REST API<br/>mTLS (service mesh)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token opt| Gateway
    Gateway -->|HTTP/8012 or 8080<br/>mTLS STRICT<br/>Service Identity| Activator

    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>Client Cert| Webhook

    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM or Access Keys| S3
    Predictor -->|HTTPS/443<br/>TLS 1.2+<br/>GCP Service Account| GCS
    Controller -->|HTTP/8080<br/>mTLS<br/>Service Identity| ModelRegistry

    Prometheus -->|HTTP/8080<br/>None - NetworkPolicy| Controller
    Prometheus -->|HTTP/8080 or 9090<br/>None - NetworkPolicy| Predictor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class Activator,Predictor,Transformer,Router servicemesh
    class Controller,Webhook,K8sAPI controlplane
    class S3,GCS,Registry,ModelRegistry externalservice
    class Prometheus monitoring
