%% Security Network Diagram - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS"]
        Dashboard["RHOAI Dashboard<br/>443/TCP<br/>TLS 1.2+<br/>OAuth Authentication"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / Client Certs"]
        NotebookCtrl["odh-notebook-controller<br/>NS: redhat-ods-applications<br/>Creates Pod + Service + HTTPRoute<br/>Injects kube-rbac-proxy"]
        Operator["rhods-operator<br/>NS: redhat-ods-operator<br/>Deploys Kustomize overlays"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Per-User Namespace)"]
        direction TB
        KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (RBAC)"]
        Workbench["Workbench Container<br/>JupyterLab: 8888/TCP<br/>RStudio: 8787/TCP<br/>Code Server: 8080/TCP<br/>HTTP plaintext (localhost)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        RHIO["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret Token<br/>N-1 images (FIPS)"]
        Quay["quay.io/modh<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret Token<br/>N-2 to N-6 images"]
        PyPI["pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth (build time)"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth (build time)"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Dashboard
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"Notebook CR event"| NotebookCtrl
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Kustomize apply"| K8sAPI
    NotebookCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Create Pod+Svc"| K8sAPI

    User -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP/8888<br/>plaintext<br/>localhost<br/>No Auth"| Workbench

    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| RHIO
    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| Quay

