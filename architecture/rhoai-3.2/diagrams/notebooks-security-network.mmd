graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>{notebook}-{namespace}.apps.{cluster}<br/>443/TCP → 8443/TCP<br/>TLS Edge Termination"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Namespace: {user-namespace})"]
        direction TB

        subgraph Container1["Container: OAuth Proxy Sidecar"]
            OAuthProxy["OAuth Proxy<br/>SA: {notebook}-sa<br/>Port: 8443/TCP HTTPS"]
        end

        subgraph Container2["Container: Jupyter Workbench"]
            Jupyter["Jupyter Server<br/>SA: {notebook}-sa<br/>UID: 1001<br/>Port: 8888/TCP HTTP<br/>Caps: ALL dropped<br/>Seccomp: runtime/default"]
        end
    end

    subgraph AuthServices["AUTHENTICATION SERVICES"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth2 Token Validation"]
    end

    subgraph EgressDestinations["EGRESS DESTINATIONS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Signature v4"]
        Git["Git Repositories<br/>443/TCP HTTPS TLS 1.2+<br/>SSH Key/Token"]
        PyPI["PyPI Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Public"]
    end

    subgraph BuildPipeline["BUILD PIPELINE (Konflux)"]
        direction TB
        GitHub["GitHub Webhook"]
        KonfluxListener["Konflux EventListener<br/>443/TCP HTTPS<br/>Webhook Secret"]
        Tekton["Tekton PipelineRun"]
        UBIRegistry["UBI Registry<br/>443/TCP HTTPS<br/>Pull Secret"]
        Scanner["Vulnerability Scanner<br/>443/TCP HTTPS<br/>API Token"]
        Cosign["Image Signing (Cosign)"]
        Quay["quay.io Registry<br/>443/TCP HTTPS<br/>Push Token"]
    end

    subgraph Secrets["SECRETS"]
        OAuthSecret["oauth-config<br/>(Opaque)"]
        TLSSecret["notebook-tls<br/>(kubernetes.io/tls)<br/>Auto-rotate: 90d"]
        PullSecret["pull-secret<br/>(dockerconfigjson)"]
        AWSSecret["aws-connection<br/>(Opaque)"]
        GitSecret["git-ssh-key<br/>(ssh-auth)"]
    end

    %% User flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Public| Route
    Route -->|HTTPS/8443<br/>TLS 1.2+| OAuthProxy
    OAuthProxy -->|HTTPS/443<br/>OAuth2 Token| OSAuth
    OSAuth -.->|Token Valid<br/>User authorized| OAuthProxy
    OAuthProxy -->|HTTP/8888<br/>Localhost<br/>No encryption| Jupyter

    %% Egress flows
    Jupyter -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Auth| S3
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>SSH/Token| Git
    Jupyter -->|HTTPS/443<br/>TLS 1.2+| PyPI

    %% Build flow
    GitHub -->|HTTPS/443<br/>Webhook Secret| KonfluxListener
    KonfluxListener -->|Trigger| Tekton
    Tekton -->|HTTPS/443<br/>Pull Secret| UBIRegistry
    Tekton -->|Build| Scanner
    Scanner -->|CVE Pass| Cosign
    Cosign -->|HTTPS/443<br/>Push Token| Quay

    %% Secrets usage
    OAuthSecret -.->|used by| OAuthProxy
    TLSSecret -.->|used by| Route
    PullSecret -.->|used by| WorkbenchPod
    AWSSecret -.->|used by| Jupyter
    GitSecret -.->|used by| Jupyter

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class OAuthProxy,Jupyter workbench
    class OSAuth auth
    class K8sAPI,S3,Git,PyPI egress
    class GitHub,KonfluxListener,Tekton,UBIRegistry,Scanner,Cosign,Quay build
    class OAuthSecret,TLSSecret,PullSecret,AWSSecret,GitSecret secrets
