    subgraph "Roles"
        MixtralRole["mixtral-view-role<br/>(Role)"]
        PrometheusRole["prometheus-view-role<br/>(Role)"]
        RegistryRole["registry-user<br/>(Role)"]
    end

    subgraph "Pipeline Runtime Permissions"
        CoreSecrets["core<br/>secrets"]
        CoreNamespaces["core<br/>namespaces"]
        PyTorchJobs["kubeflow.org<br/>pytorchjobs"]
        DSPAResource["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications"]
    end

    subgraph "Supplementary Role Resources"
        MixtralIS["serving.kserve.io<br/>inferenceservices<br/>(resourceName: mixtral)"]
        PrometheusIS["serving.kserve.io<br/>inferenceservices<br/>(resourceName: prometheus)"]
        RegistryRes["Model Registry<br/>Resources"]
    end

    %% Supplementary RBAC
    MixtralSA -->|bound via| MixtralBinding
    MixtralBinding -->|grants| MixtralRole
    MixtralRole -->|get| MixtralIS

    PrometheusSA -->|bound via| PrometheusBinding
    PrometheusBinding -->|grants| PrometheusRole
    PrometheusRole -->|get| PrometheusIS

    %% Pipeline Runtime RBAC
    PipelineSA -->|get| CoreSecrets
    PipelineSA -->|get| CoreNamespaces
    PipelineSA -->|"create, get, list,<br/>watch, delete"| PyTorchJobs
    PipelineSA -->|list| DSPAResource
    PipelineSA -->|bound via| RegistryBinding
    RegistryBinding -->|grants| RegistryRole
    RegistryRole -->|"registry-user perms"| RegistryRes

