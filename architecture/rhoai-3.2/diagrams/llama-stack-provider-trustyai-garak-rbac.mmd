%% RBAC Visualization: llama-stack-provider-trustyai-garak
%% Generated by: Claude Opus 4.6
%% Note: No ClusterRoles defined by this component. Shows required permissions.

graph TD
    subgraph "Provider Identity"
        SA["ServiceAccount<br/>(KFP pipeline / Llama Stack server)"]
    end

    subgraph "Required Permissions"
        direction TB

        subgraph KFPAccess["KFP Access Requirements"]
            KFP_Pipelines["pipelines.kubeflow.org<br/>pipelines"]
            KFP_Runs["pipelines.kubeflow.org<br/>runs"]
            KFP_Experiments["pipelines.kubeflow.org<br/>experiments"]
        end

        subgraph CoreAccess["Core API Requirements"]
            ConfigMaps["core ('')<br/>configmaps"]
        end

        subgraph LlamaStackAccess["Llama Stack API Requirements"]
            Files["Llama Stack<br/>files"]
            Inference["Llama Stack<br/>inference"]
            Safety["Llama Stack<br/>safety (optional)"]
        end
    end

    subgraph "Authentication Mechanisms"
        BearerToken["Bearer Token<br/>(KUBEFLOW_PIPELINES_TOKEN)"]
        SAToken["ServiceAccount Token<br/>(kubeconfig)"]
        APIKey["API Key<br/>(OPENAICOMPATIBLE_API_KEY)"]
        LSAuth["Llama Stack Auth<br/>(configurable)"]
    end

    subgraph "Secrets"
        InferenceSecret["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Keys: vLLM URL, API token, model name"]
        KFPSecret["kubeflow-pipelines-token<br/>Type: Opaque<br/>Keys: KFP API auth token"]
        KFPConfig["KUBEFLOW_PIPELINES_TOKEN<br/>Type: SecretStr (Pydantic)<br/>Provider config alternative"]
    end

    subgraph "ConfigMaps"
        TrustyAIConfig["trustyai-service-operator-config<br/>NS: redhat-ods-applications<br/>Key: garak-provider-image"]
        GarakConfig["kubeflow-garak-config<br/>NS: user namespace<br/>Keys: KFP endpoint, namespace,<br/>base image, Llama Stack URL"]
    end

    %% Permission flows
    SA -->|"requires"| KFPAccess
    SA -->|"requires"| CoreAccess
    SA -->|"requires"| LlamaStackAccess

    SA -->|"authenticates via"| BearerToken
    SA -->|"authenticates via"| SAToken
    SA -->|"authenticates via"| APIKey
    SA -->|"authenticates via"| LSAuth

    %% Verbs
    SA -->|"create, get, list"| KFP_Pipelines
    SA -->|"create, get, list"| KFP_Runs
    SA -->|"create, get, list"| KFP_Experiments
    SA -->|"get"| ConfigMaps
    SA -->|"create, get, list"| Files

    %% Secret usage
    BearerToken -.->|"sourced from"| KFPSecret
    BearerToken -.->|"sourced from"| KFPConfig
    APIKey -.->|"sourced from"| InferenceSecret

    %% ConfigMap usage
    ConfigMaps -.->|"reads"| TrustyAIConfig
    ConfigMaps -.->|"reads"| GarakConfig

