// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // People
        dataScientist = person "Data Scientist" "Creates ML models, runs evaluations, configures guardrails"
        securityEngineer = person "Security Engineer" "Configures guardrails policies and reviews AI safety"

        // Primary System
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages AI/ML trustworthiness, evaluation, and guardrails services on OpenShift AI" {
            operatorManager = container "Operator Manager" "controller-runtime manager; leader election, metrics :8080, health :8081" "Go Binary"
            tasController = container "TAS Controller" "Reconciles TrustyAIService CRs; creates Deployments with kube-rbac-proxy, Services, Routes, PVCs, ServiceMonitors, Istio resources" "Go Controller"
            lmesController = container "LMES Controller" "Reconciles LMEvalJob CRs; creates eval Pods with driver + eval containers; manages job lifecycle" "Go Controller"
            gorchController = container "GORCH Controller" "Reconciles GuardrailsOrchestrator CRs; creates multi-container Deployments with orchestrator, gateway, detectors, kube-rbac-proxy sidecars" "Go Controller"
            nemoController = container "NeMo Controller" "Reconciles NemoGuardrails CRs; creates Deployments with optional kube-rbac-proxy sidecar" "Go Controller"
            jobMgrController = container "Job Manager Controller" "Kueue integration for LMEvalJob scheduling; creates Kueue Workloads" "Go Controller"
        }

        // Managed Workloads (created dynamically)
        trustyaiService = softwareSystem "TrustyAI Service" "Explainability and bias monitoring for ML models" "Managed Workload" {
            tags "Managed"
        }
        lmevalPods = softwareSystem "LMEval Pods" "Language model evaluation jobs using lm-eval harness" "Managed Workload" {
            tags "Managed"
        }
        gorchService = softwareSystem "Guardrails Orchestrator" "Orchestration layer for content detection across multiple detector services" "Managed Workload" {
            tags "Managed"
        }
        nemoService = softwareSystem "NeMo Guardrails Server" "NVIDIA NeMo Guardrails for programmable guardrails" "Managed Workload" {
            tags "Managed"
        }

        // External Dependencies
        kserve = softwareSystem "KServe" "InferenceService and ServingRuntime CRD provider" "External" {
            tags "External"
        }
        kueue = softwareSystem "Kueue" "Job queuing and resource management" "External" {
            tags "External"
        }
        openshiftRoutes = softwareSystem "OpenShift Router" "External access via Routes with TLS termination" "External" {
            tags "External"
        }
        prometheusOp = softwareSystem "Prometheus Operator" "Metrics collection via ServiceMonitors" "External" {
            tags "External"
        }
        istio = softwareSystem "Istio Service Mesh" "DestinationRules and VirtualServices for mesh integration" "External" {
            tags "External"
        }
        openshiftServiceCA = softwareSystem "OpenShift Service CA" "Automatic TLS certificate provisioning" "External" {
            tags "External"
        }

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys TrustyAI operator via kustomize overlays" "Internal RHOAI" {
            tags "Internal"
        }

        // External Services
        llmEndpoints = softwareSystem "LLM Endpoints" "External model endpoints (OpenAI, Watsonx, etc.)" "External Service" {
            tags "ExternalService"
        }
        s3Storage = softwareSystem "S3-compatible Storage" "Offline dataset storage for LMEval" "External Service" {
            tags "ExternalService"
        }
        ociRegistries = softwareSystem "OCI Registries" "Container registries for LMEval output upload" "External Service" {
            tags "ExternalService"
        }

        // Relationships - Users
        dataScientist -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator, NemoGuardrails CRs" "kubectl / HTTPS"
        securityEngineer -> trustyaiOperator "Configures guardrails policies" "kubectl / HTTPS"

        // Relationships - Operator internals
        operatorManager -> tasController "Manages"
        operatorManager -> lmesController "Manages"
        operatorManager -> gorchController "Manages"
        operatorManager -> nemoController "Manages"
        operatorManager -> jobMgrController "Manages"

        // Relationships - Controller to managed workloads
        tasController -> trustyaiService "Creates and manages Deployments, Services, Routes" "Kubernetes API"
        lmesController -> lmevalPods "Creates eval Pods; manages via pod/exec" "Kubernetes API / SPDY"
        gorchController -> gorchService "Creates multi-container Deployments, ConfigMaps" "Kubernetes API"
        nemoController -> nemoService "Creates Deployments with optional auth" "Kubernetes API"

        // Relationships - External dependencies
        trustyaiOperator -> kserve "Watches/patches InferenceServices and reads ServingRuntimes" "Kubernetes API"
        jobMgrController -> kueue "Creates Workloads for job scheduling" "Kubernetes API"
        tasController -> openshiftRoutes "Creates Routes for external access" "Kubernetes API"
        gorchController -> openshiftRoutes "Creates Routes for external access" "Kubernetes API"
        nemoController -> openshiftRoutes "Creates Routes for external access" "Kubernetes API"
        tasController -> prometheusOp "Creates ServiceMonitors" "Kubernetes API"
        gorchController -> prometheusOp "Creates ServiceMonitors" "Kubernetes API"
        tasController -> istio "Creates DestinationRules and VirtualServices" "Kubernetes API"
        trustyaiOperator -> openshiftServiceCA "Annotation-triggered TLS cert provisioning"
        rhodsOperator -> trustyaiOperator "Deploys via kustomize; injects image params" "Kustomize"

        // Relationships - Managed workloads to external services
        lmevalPods -> llmEndpoints "Evaluates models" "HTTPS/443 TLS 1.2+"
        lmevalPods -> s3Storage "Downloads offline datasets" "HTTPS/443 TLS 1.2+"
        lmevalPods -> ociRegistries "Uploads evaluation outputs" "HTTPS/443 TLS 1.2+"
        gorchService -> kserve "Sends content to detector InferenceServices" "HTTPS mTLS"
        trustyaiService -> kserve "Monitors InferenceService payloads" "HTTP/HTTPS"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Person" {
                background #9b59b6
                color #ffffff
                shape Person
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "ExternalService" {
                background #e67e22
                color #ffffff
            }
        }
    }
}
