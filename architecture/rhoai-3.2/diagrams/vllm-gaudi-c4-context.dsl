// C4 Context Diagram for vLLM Gaudi
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/vllm-gaudi.md

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries LLM models for inference"
        mlEngineer = person "ML Engineer" "Configures and manages model serving infrastructure"

        vllmGaudi = softwareSystem "vLLM Gaudi" "High-throughput LLM inference engine optimized for Intel Gaudi HPU accelerators, providing OpenAI-compatible and gRPC APIs" {
            apiServer = container "vLLM OpenAI API Server" "OpenAI-compatible REST API for chat completions, completions, embeddings" "Python FastAPI/Uvicorn" "Port 8000/TCP"
            grpcAdapter = container "vllm-tgis-adapter" "TGIS-compatible gRPC interface for inference" "Python gRPC" "Port 8033/TCP"
            asyncEngine = container "AsyncLLMEngine" "Request scheduling, continuous batching, PagedAttention KV cache" "Python"
            hpuWorker = container "HPUWorker" "Executes model inference on Intel Gaudi HPU devices" "Python PyTorch"
            hpuModelRunner = container "HPUModelRunner" "Runs model forward passes with Habana optimizations" "Python"
            executor = container "Ray/MP Executor" "Orchestrates distributed inference across multiple HPU workers" "Python Ray/MPI"
            sshd = container "SSHD" "SSH daemon for MPI-operator v2 distributed coordination" "OpenSSH" "Port 3022/TCP"
            sslRefresher = container "SSLCertRefresher" "Monitors and hot-reloads SSL certificate files" "Python"
            metrics = container "Prometheus Metrics" "Exposes serving metrics at /metrics endpoint" "Python prometheus_client"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform managing InferenceService lifecycle" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and artifacts" "Internal RHOAI"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Web UI for managing ML workloads" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model weight and tokenizer repository" "External"
        gaudiRuntime = softwareSystem "Intel Gaudi Runtime" "HPU device drivers, firmware, runtime libraries" "External"
        otel = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"

        // User interactions
        datascientist -> vllmGaudi "Sends inference requests via OpenAI-compatible API" "HTTP/HTTPS 8000/TCP"
        datascientist -> vllmGaudi "Sends inference requests via TGIS gRPC" "gRPC 8033/TCP"
        mlEngineer -> kserve "Configures InferenceService to use vLLM Gaudi runtime"

        // Internal container relationships
        apiServer -> asyncEngine "Submits inference requests" "Python IPC"
        grpcAdapter -> asyncEngine "Submits inference requests" "Python API"
        asyncEngine -> executor "Distributes work to HPU workers"
        executor -> hpuWorker "Manages worker lifecycle"
        hpuWorker -> hpuModelRunner "Delegates model execution"
        apiServer -> sslRefresher "Uses for TLS cert management"
        apiServer -> metrics "Exposes metrics"

        // External relationships
        kserve -> vllmGaudi "Deploys and manages as serving runtime container" "HTTP 8000, gRPC 8033"
        vllmGaudi -> hfHub "Downloads model weights and tokenizer files" "HTTPS/443 TLS 1.2+ HF_TOKEN"
        vllmGaudi -> gaudiRuntime "Interfaces with Intel Gaudi HPU hardware" "HPU Runtime"
        prometheus -> vllmGaudi "Scrapes serving metrics" "HTTP 8000/TCP /metrics"
        dashboard -> kserve "Displays served models from vLLM" "API"
        vllmGaudi -> otel "Exports distributed traces (optional)" "HTTP/gRPC configurable"
        modelRegistry -> vllmGaudi "Provides model artifact locations" "HuggingFace Hub API"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
