%% RBAC Matrix Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA_Controller["odh-notebook-controller-manager<br/>(opendatahub namespace)"]
        SA_Notebook["{notebook-name}<br/>(user namespace, per notebook)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Main["odh-notebook-controller-<br/>manager-rolebinding<br/>(cluster-scoped)"]
        CRB_AuthDelegator["{notebook}-rbac-{ns}-<br/>auth-delegator<br/>(cluster-scoped, dynamic)"]
    end

    subgraph "Role Bindings"
        RB_Leader["leader-election-rolebinding<br/>(opendatahub namespace)"]
        RB_Elyra["elyra-pipelines-{notebook}<br/>(notebook namespace, dynamic)"]
    end

    subgraph "ClusterRoles"
        CR_Main["odh-notebook-controller-manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Edit["notebooks-edit<br/>(aggregated to edit)"]
        CR_View["notebooks-view<br/>(aggregated to view)"]
        CR_Admin["notebooks-admin<br/>(aggregated to admin)"]
    end

    subgraph "Roles"
        R_Leader["leader-election-role<br/>(opendatahub)"]
        R_Pipeline["ds-pipeline-user-access-dspa<br/>(notebook namespace)"]
    end

    subgraph "API Resources - Core & OpenShift"
        ConfigMaps["core<br/>ConfigMaps"]
        Secrets["core<br/>Secrets"]
        ServiceAccounts["core<br/>ServiceAccounts"]
        Services["core<br/>Services"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
        Proxies["config.openshift.io<br/>Proxies"]
        OAuthClients["oauth.openshift.io<br/>OAuthClients"]
        Routes["route.openshift.io<br/>Routes"]
        ImageStreamsRes["image.openshift.io<br/>ImageStreams"]
    end

    subgraph "API Resources - Kubeflow"
        Notebooks["kubeflow.org<br/>Notebooks"]
        NotebooksFinalizers["kubeflow.org<br/>Notebooks/finalizers"]
        NotebooksStatus["kubeflow.org<br/>Notebooks/status"]
    end

    subgraph "API Resources - Gateway & Network"
        Gateways["gateway.networking.k8s.io<br/>Gateways"]
        HTTPRoutes["gateway.networking.k8s.io<br/>HTTPRoutes"]
        RefGrants["gateway.networking.k8s.io<br/>ReferenceGrants"]
        NetPols["networking.k8s.io<br/>NetworkPolicies"]
        NetPolsFinalizers["networking.k8s.io<br/>NetworkPolicies/finalizers"]
    end

    subgraph "API Resources - DSPA & RBAC"
        DSPAs["opendatahub.io<br/>DataSciencePipelinesApplications"]
        DSPAsAPI["opendatahub.io<br/>DSPAs/api"]
        CRBs["rbac.authorization.k8s.io<br/>ClusterRoleBindings"]
        RoleBindings["rbac.authorization.k8s.io<br/>RoleBindings"]
        Roles["rbac.authorization.k8s.io<br/>Roles"]
    end

    %% Controller SA bindings
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| RB_Leader
    CRB_Main -->|grants| CR_Main
    RB_Leader -->|grants| R_Leader

    %% Notebook SA bindings (dynamic)
    SA_Notebook -->|bound via| CRB_AuthDelegator
    SA_Notebook -->|bound via| RB_Elyra
    CRB_AuthDelegator -->|grants| CR_AuthDelegator
    RB_Elyra -->|grants| R_Pipeline

    %% ClusterRole permissions
    CR_Main -->|"get,list,watch,<br/>create,update,patch"| ConfigMaps
    CR_Main -->|"get,list,watch,<br/>create,update,patch"| Secrets
    CR_Main -->|"get,list,watch,<br/>create,update,patch"| ServiceAccounts
    CR_Main -->|"get,list,watch,<br/>create,update,patch"| Services
    CR_Main -->|create| TokenReviews
    CR_Main -->|create| SAR
    CR_Main -->|"get,list,watch"| Proxies
    CR_Main -->|"get,list,watch"| DSPAs
    CR_Main -->|"CRUD"| DSPAsAPI
    CR_Main -->|"get,list,watch"| Gateways
    CR_Main -->|"CRUD + watch"| HTTPRoutes
    CR_Main -->|"CRUD + watch"| RefGrants
    CR_Main -->|"get,list,watch"| ImageStreamsRes
    CR_Main -->|"get,list,watch,<br/>patch,update"| Notebooks
    CR_Main -->|"patch,update"| NotebooksFinalizers
    CR_Main -->|get| NotebooksStatus
    CR_Main -->|"CRUD + watch"| NetPols
    CR_Main -->|"patch,update"| NetPolsFinalizers
    CR_Main -->|"CRUD + watch"| OAuthClients
    CR_Main -->|"CRUD + watch"| CRBs
    CR_Main -->|"CRUD + watch"| RoleBindings
    CR_Main -->|"CRUD + watch"| Roles
    CR_Main -->|get| Routes

    %% Aggregated roles
    CR_Edit -->|"get,list,watch,create,<br/>delete,patch,update"| Notebooks
    CR_View -->|"get,list,watch"| Notebooks
    CR_Admin -->|inherits| CR_Edit

    %% Auth delegator
    CR_AuthDelegator -->|create| TokenReviews
    CR_AuthDelegator -->|create| SAR

