graph TD
    subgraph "Service Accounts"
        SA[service-account<br/>Namespace: odh-notebook-controller]
    end

    subgraph "Cluster-Level RBAC"
        CRB1[ClusterRoleBinding<br/>role-binding]
        CRB2[ClusterRoleBinding<br/>auth-proxy-role-binding]
        CR1[ClusterRole<br/>role]
        CR2[ClusterRole<br/>auth-proxy-role]
    end

    subgraph "Namespace-Level RBAC"
        RB1[RoleBinding<br/>leader-election-role-binding<br/>Namespace: odh-notebook-controller]
        R1[Role<br/>leader-election-role<br/>Namespace: odh-notebook-controller]
    end

    subgraph "Cluster-Wide API Resources"
        Events[core/events<br/>create, get, list, patch, watch]
        Pods[core/pods<br/>delete, get, list, watch]
        Services[core/services<br/>* all verbs]
        StatefulSets[apps/statefulsets<br/>* all verbs]
        Notebooks[kubeflow.org/notebooks<br/>notebooks/finalizers<br/>notebooks/status<br/>* all verbs]
        VirtualServices[networking.istio.io/virtualservices<br/>* all verbs]
        SubjectAccessReviews[authorization.k8s.io/subjectaccessreviews<br/>create]
        TokenReviews[authentication.k8s.io/tokenreviews<br/>create]
    end

    subgraph "Namespace-Scoped API Resources"
        ConfigMaps[core/configmaps<br/>get, list, watch, create, update, patch, delete]
        ConfigMapsStatus[core/configmaps/status<br/>get, update, patch]
        EventsNS[core/events<br/>create]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    %% ClusterRole Bindings
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2

    %% RoleBinding
    RB1 -->|grants| R1

    %% ClusterRole Permissions (role)
    CR1 -->|permissions| Events
    CR1 -->|permissions| Pods
    CR1 -->|permissions| Services
    CR1 -->|permissions| StatefulSets
    CR1 -->|permissions| Notebooks
    CR1 -->|permissions| VirtualServices

    %% ClusterRole Permissions (auth-proxy-role)
    CR2 -->|permissions| SubjectAccessReviews
    CR2 -->|permissions| TokenReviews

    %% Role Permissions (leader-election-role)
    R1 -->|permissions| ConfigMaps
    R1 -->|permissions| ConfigMapsStatus
    R1 -->|permissions| EventsNS

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style RB1 fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style R1 fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Events fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style Pods fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style Services fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style StatefulSets fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style Notebooks fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style VirtualServices fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    style SubjectAccessReviews fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    style TokenReviews fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    style ConfigMaps fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    style ConfigMapsStatus fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    style EventsNS fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
