    end

    subgraph DSPStack["DSP Stack (Per DSPA Namespace)"]
        direction TB
        APIServer["DS Pipeline API Server<br/>HTTP: 8888, gRPC: 8887"]
        RBACProxy1["kube-rbac-proxy<br/>(API Server sidecar)<br/>Port: 8443/HTTPS"]
        PersistenceAgent["Persistence Agent<br/>Syncs run status"]
        ScheduledWF["Scheduled Workflow<br/>Cron-scheduled runs"]
        WFController["Workflow Controller<br/>Argo Workflow execution"]
        MLMDServer["MLMD gRPC Server<br/>Port: 8080/gRPC"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>Port: 9090/gRPC"]
        RBACProxy2["kube-rbac-proxy<br/>(MLMD Envoy sidecar)<br/>Port: 8443/HTTPS"]
        MariaDB["MariaDB<br/>Port: 3306/MySQL"]
        Minio["Minio<br/>S3-compatible storage"]
    end

    %% CRDs
    DSPACR["DSPA CR<br/>DataSciencePipelinesApplication"]
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWFCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    WorkflowCR["Workflow CR<br/>argoproj.io"]

    %% External
    User["User / Dashboard"]
    Router["OpenShift Router<br/>443/HTTPS"]
    K8sAPI["Kubernetes API<br/>443/HTTPS"]
    ServiceCA["OpenShift service-ca<br/>TLS Certificate Generation"]
    ExternalDB["External DB<br/>(optional)"]
    ExternalS3["External S3<br/>(optional)"]

    %% Operator relationships
    User -->|creates| DSPACR
    DSPACR -->|watched by| Controller
    Controller -->|deploys all| DSPStack
    Controller -->|creates| APIServer
    Controller -->|creates| PersistenceAgent
    Controller -->|creates| ScheduledWF
    Controller -->|creates| WFController
    Controller -->|creates| MLMDServer
    Controller -->|creates| MLMDEnvoy
    Controller -->|creates| MariaDB
    Controller -->|creates| Minio

    %% Webhook
    PipelineCR -->|validated by| Webhook
    PipelineVersionCR -->|validated by| Webhook

    %% Data flow
    Router -->|reencrypt TLS| RBACProxy1
    RBACProxy1 -->|SAR authorized| APIServer
    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|creates| WorkflowCR
    WorkflowCR -->|executed by| WFController
    PersistenceAgent -->|syncs status| APIServer
    PersistenceAgent -->|watches| WorkflowCR
    ScheduledWF -->|manages| ScheduledWFCR
    MLMDServer -->|stores lineage| MariaDB
    RBACProxy2 -->|proxies| MLMDEnvoy
    MLMDEnvoy -->|forwards| MLMDServer

    %% External dependencies
    Controller -->|manages resources| K8sAPI
    ServiceCA -->|provisions certs| DSPStack
    MariaDB -.->|or| ExternalDB
    Minio -.->|or| ExternalS3

