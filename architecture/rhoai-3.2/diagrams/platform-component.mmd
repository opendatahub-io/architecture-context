graph TB
    subgraph "RHOAI 3.2 Platform"
        subgraph "Platform Control Plane (redhat-ods-operator)"
            RHODSOp[RHODS Operator<br/>v1.6.0]
        end

        subgraph "Application Services (redhat-ods-applications)"
            Dashboard[ODH Dashboard<br/>v1.21.0]
            ModelReg[Model Registry Operator<br/>b068597]
            MLflow[MLflow Operator<br/>cd9ad05]
            Feast[Feast Operator<br/>0.58.0]
            TrustyAI[TrustyAI Operator<br/>a2e891d]
            LlamaStack[Llama Stack Operator<br/>v0.5.0]
        end

        subgraph "Kubeflow Components (opendatahub)"
            NotebookCtrl[Notebook Controller<br/>1.27.0]
            TrainingOp[Training Operator<br/>1.9.0]
            Trainer[Trainer<br/>2.1.0]
            KubeRay[KubeRay Operator<br/>72c07895]
        end

        subgraph "Model Serving (istio-system/knative-serving)"
            KServe[KServe<br/>27c1e99b7]
            ODHModelCtrl[ODH Model Controller<br/>v1.27.0]
        end

        subgraph "ML Pipelines (user namespaces)"
            DSPO[Data Science Pipelines Operator<br/>9d94973]
        end

        subgraph "Monitoring (redhat-ods-monitoring)"
            Prometheus[Prometheus]
            Alertmanager[Alertmanager]
        end

        subgraph "Infrastructure"
            Istio[Istio Service Mesh]
            Knative[Knative Serving]
            K8sAPI[Kubernetes API Server]
            OAuth[OpenShift OAuth]
        end
    end

    subgraph "User Workloads (user namespaces)"
        Notebooks[Jupyter/RStudio/VSCode<br/>Workbenches]
        InfSvc[InferenceServices<br/>Model Serving]
        TrainJobs[Training Jobs<br/>PyTorch/TF/XGBoost/JAX]
        RayClusters[Ray Clusters]
        Pipelines[ML Pipelines<br/>Argo Workflows]
    end

    subgraph "External Services"
        S3[S3 Storage<br/>Models/Artifacts]
        PostgreSQL[PostgreSQL<br/>Metadata]
        Registry[Container Registry<br/>quay.io/registry.redhat.io]
    end

    %% Platform control flow
    RHODSOp -->|manages| Dashboard
    RHODSOp -->|manages| KServe
    RHODSOp -->|manages| DSPO
    RHODSOp -->|manages| NotebookCtrl
    RHODSOp -->|manages| TrainingOp
    RHODSOp -->|manages| Trainer
    RHODSOp -->|manages| ModelReg
    RHODSOp -->|manages| MLflow
    RHODSOp -->|manages| Feast
    RHODSOp -->|manages| TrustyAI
    RHODSOp -->|manages| KubeRay
    RHODSOp -->|manages| LlamaStack

    %% Dashboard integrations
    Dashboard -->|API calls| KServe
    Dashboard -->|API calls| ModelReg
    Dashboard -->|API calls| MLflow
    Dashboard -->|API calls| DSPO
    Dashboard -->|creates CRDs| NotebookCtrl
    Dashboard -->|creates CRDs| TrainingOp
    Dashboard -->|metrics queries| Prometheus

    %% KServe dependencies
    KServe -->|traffic mgmt| Istio
    KServe -->|autoscaling| Knative
    KServe -->|monitoring| ODHModelCtrl
    KServe -->|metadata| ModelReg
    KServe -->|monitored by| TrustyAI

    %% ODH Model Controller
    ODHModelCtrl -->|manages| KServe
    ODHModelCtrl -->|creates Routes| K8sAPI

    %% Data Science Pipelines
    DSPO -->|creates| Pipelines
    DSPO -->|deploys to| KServe
    DSPO -->|stores metadata| PostgreSQL
    DSPO -->|stores artifacts| S3

    %% Notebook Controller
    NotebookCtrl -->|creates| Notebooks
    NotebookCtrl -->|optional routing| Istio

    %% Training Operator & Trainer
    TrainingOp -->|creates| TrainJobs
    Trainer -->|creates| TrainJobs

    %% KubeRay
    KubeRay -->|creates| RayClusters
    KubeRay -->|auth| OAuth

    %% TrustyAI
    TrustyAI -->|monitors| InfSvc
    TrustyAI -->|stores data| PostgreSQL

    %% MLflow
    MLflow -->|stores metadata| PostgreSQL
    MLflow -->|stores artifacts| S3

    %% Feast
    Feast -->|stores metadata| PostgreSQL

    %% Model Registry
    ModelReg -->|stores metadata| PostgreSQL

    %% User workloads external access
    Notebooks -->|pulls images| Registry
    Notebooks -->|stores data| S3
    TrainJobs -->|pulls images| Registry
    TrainJobs -->|stores checkpoints| S3
    InfSvc -->|loads models| S3
    Pipelines -->|stores artifacts| S3

    %% All components use K8s API
    RHODSOp -->|manages CRDs| K8sAPI
    Dashboard -->|API server| OAuth

    %% Monitoring
    Prometheus -->|scrapes metrics| RHODSOp
    Prometheus -->|scrapes metrics| KServe
    Prometheus -->|scrapes metrics| DSPO
    Prometheus -->|scrapes metrics| InfSvc

