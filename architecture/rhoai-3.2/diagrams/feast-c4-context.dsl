// Feast Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/feast.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates FeatureStore CRs and consumes features for ML models"
        mlApplication = person "ML Application" "Queries online/offline feature stores for inference and training"

        feastOperator = softwareSystem "Feast Operator" "Manages Feast feature store deployments on Kubernetes/OpenShift via FeatureStore CR" {
            controllerManager = container "FeatureStoreReconciler" "Watches FeatureStore CRs and reconciles Deployments, Services, ConfigMaps, PVCs, CronJobs, Routes" "Go (controller-runtime)"
            notebookReconciler = container "NotebookConfigMapReconciler" "Watches Notebook CRs and creates Feast client ConfigMaps for notebook integration" "Go (controller-runtime)"
            authzModule = container "FeastAuthorization" "Manages Kubernetes RBAC and OIDC authorization for Feast services" "Go Module"
            featureServer = container "Feature Server" "Multi-container pod running registry, online, offline, and UI servers" "Python 3.11 (Feast SDK)"
            cronJob = container "Materialization CronJob" "Scheduled feast apply and feast materialize-incremental via kubectl exec" "ose-cli"
        }

        // Internal ODH/RHOAI dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys feast-operator via kustomize overlays" "Internal RHOAI"
        kubeflowNotebooks = softwareSystem "Kubeflow Notebook Controller" "Manages Jupyter notebook lifecycle" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal"

        // Platform dependencies
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "Platform"
        openshiftServiceCA = softwareSystem "OpenShift Service CA" "Auto-provisions TLS certificates for services" "Platform"
        odhTrustedCA = softwareSystem "ODH Trusted CA Bundle" "Custom CA bundle for Feast pods" "Platform"

        // External dependencies
        gitRepos = softwareSystem "Git Repositories" "Feast project source code" "External"
        externalDB = softwareSystem "External Databases" "Snowflake, PostgreSQL, Cassandra persistence backends" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Object store persistence for offline/registry data" "External"

        // Relationships - Users
        dataScientist -> feastOperator "Creates FeatureStore CR via kubectl/dashboard"
        mlApplication -> feastOperator "Queries online/offline features" "HTTP/gRPC"

        // Relationships - Internal
        controllerManager -> authzModule "Configures authorization"
        controllerManager -> featureServer "Creates and manages"
        controllerManager -> cronJob "Creates and manages"
        notebookReconciler -> kubeflowNotebooks "Watches Notebook CRs" "HTTPS/443"

        // Relationships - Platform
        rhodsOperator -> feastOperator "Deploys via kustomize overlays"
        feastOperator -> k8sAPI "CRUD resources (Deployments, Services, ConfigMaps, PVCs)" "HTTPS/443"
        feastOperator -> openshiftServiceCA "Auto-provision TLS certs via annotation"
        featureServer -> odhTrustedCA "Mounts custom CA bundle"
        prometheus -> feastOperator "Scrapes operator metrics" "HTTPS/8443"

        // Relationships - External
        featureServer -> gitRepos "Clones feast project (init container)" "HTTPS/443"
        featureServer -> externalDB "Reads/writes feature data" "TLS/Various"
        featureServer -> s3Storage "Stores offline/registry data" "HTTPS/443"
    }

    views {
        systemContext feastOperator "SystemContext" {
            include *
            autoLayout
        }

        container feastOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #666666
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
