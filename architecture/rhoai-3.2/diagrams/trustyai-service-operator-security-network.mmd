graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Dashboard]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        RouteTA["OpenShift Route<br/>trustyai-service-&lt;name&gt;-route<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge"]
        RouteGO["OpenShift Route<br/>guardrails-orchestrator-&lt;name&gt;-route<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge"]
        RouteNG["OpenShift Route<br/>nemo-guardrails-&lt;name&gt;-route<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph OperatorNS["Operator Namespace: &lt;operator-namespace&gt;"]
            direction TB
            Operator["TrustyAI Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3<br/>ServiceAccount Token"]

            Operator -->|watches/creates| K8sAPI
        end

        subgraph TrustyAINS["TrustyAI Namespace: &lt;user-namespace&gt;"]
            direction TB
            ProxyTA["kube-rbac-proxy<br/>8443/TCP HTTPS TLS 1.2+<br/>Bearer Token → SAR"]
            TASPod["TrustyAI Service Pod<br/>SA: &lt;trustyai-service&gt;-sa<br/>8443/TCP HTTPS"]
            DB["PostgreSQL/MySQL<br/>5432/3306 TCP<br/>TLS 1.2+ (optional)<br/>Username/Password"]
            KServe["KServe InferenceService<br/>443/TCP HTTPS<br/>mTLS or None"]
            Prom["Prometheus<br/>9443/TCP HTTPS<br/>mTLS"]

            ProxyTA -->|authorizes| TASPod
            TASPod -->|persists| DB
            KServe -->|payloads| TASPod
            TASPod -->|metrics| Prom
        end

        subgraph LMEvalNS["LMEval Namespace: &lt;user-namespace&gt;"]
            direction TB
            LMEvalPod["LMEval Job Pod<br/>SA: &lt;lmevaljob&gt;-sa"]
            Driver["LMES Driver Sidecar<br/>18080/TCP HTTP<br/>None"]
            ModelAPI["Model Endpoint<br/>443/8080 TCP<br/>HTTPS/HTTP<br/>API Key or mTLS"]

            LMEvalPod -->|coordinates| Driver
            LMEvalPod -->|evaluates| ModelAPI
        end

        subgraph GuardrailsNS["Guardrails Namespace: &lt;user-namespace&gt;"]
            direction TB
            Gateway["Guardrails Gateway<br/>8090/TCP HTTP"]
            Orchestrator["Guardrails Orchestrator<br/>8032/TCP HTTP internal<br/>8432/TCP HTTPS via proxy<br/>SA: &lt;guardrails-orchestrator&gt;-sa"]
            Detectors["Built-in Detectors<br/>8080/TCP HTTP"]
            ExtDetector["External Detector<br/>InferenceService<br/>443/TCP HTTPS mTLS"]
            LLMInf["LLM InferenceService<br/>443/TCP HTTPS mTLS"]

            Gateway -->|routes| Orchestrator
            Orchestrator -->|checks| Detectors
            Orchestrator -->|calls| ExtDetector
            Orchestrator -->|forwards| LLMInf
        end

        subgraph NeMoNS["NeMo Namespace: &lt;user-namespace&gt;"]
            direction TB
            NeMoPod["NeMo Guardrails Pod<br/>SA: &lt;nemo-guardrails&gt;-sa<br/>8000/TCP HTTP no auth<br/>8443/TCP HTTPS via proxy"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4"]
        Istio["Istio Service Mesh<br/>VirtualService/DestinationRule<br/>mTLS STRICT"]
        Kueue["Kueue<br/>Workload Management<br/>via K8s API"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteTA
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteGO
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| RouteNG

    %% Ingress to Services
    RouteTA -->|HTTPS/443| ProxyTA
    RouteGO -->|HTTPS/8432| Orchestrator
    RouteNG -->|HTTPS/8443| NeMoPod

    %% Operator integrations
    Operator -->|patches| KServe
    Operator -->|creates| Istio
    Operator -->|integrates| Kueue

    %% LMEval to S3
    LMEvalPod -->|outputs<br/>HTTPS/443<br/>TLS 1.2+<br/>AWS Sig V4| S3

    %% Service Mesh
    Istio -.->|mTLS| TASPod
    Istio -.->|mTLS| KServe
    Istio -.->|mTLS| ExtDetector
    Istio -.->|mTLS| LLMInf

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class RouteTA,RouteGO,RouteNG ingress
    class Operator operator
    class ProxyTA,TASPod,LMEvalPod,Driver,Orchestrator,Gateway,Detectors,NeMoPod service
    class S3,Istio,Kueue,ModelAPI,ExtDetector,LLMInf,DB,KServe,Prom externalservice
