// C4 Context Diagram: Text Generation Inference Server (TGIS)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/text-generation-inference.md

workspace {
    model {
        // Users / Actors
        datascientist = person "Data Scientist" "Deploys and queries LLM inference endpoints"
        sre = person "SRE / Platform Engineer" "Monitors and operates the inference platform"

        // TGIS System
        tgis = softwareSystem "Text Generation Inference Server (TGIS)" "High-performance text generation inference server providing gRPC and HTTP APIs for serving large language models" {
            launcher = container "Launcher" "Process orchestrator that spawns Python model server shards and the router" "Rust Binary"
            router = container "Router" "Request gateway providing gRPC (FMaaS GenerationService) and HTTP endpoints with continuous batching" "Rust Binary (tonic + axum)"
            pythonServer = container "Python Server" "Model inference backend using PyTorch, runs as one or more shards" "Python (PyTorch)"
            inferenceEngine = container "Inference Engine Abstraction" "Pluggable inference backends: hf_transformers, tgis_native, ibm_fms, hf_optimum_ort" "Python Module"
            cudaKernels = container "Custom CUDA Kernels" "Optimized GPU kernels including Flash Attention v2 and Paged Attention" "Python/CUDA Extension"
        }

        // Internal RHOAI Dependencies
        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh Serving" "Intelligent model routing and serving" "Internal RHOAI"

        // Infrastructure
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Infrastructure"
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform (OCP 4.19/4.20)" "Infrastructure"
        nvidiaGPU = softwareSystem "NVIDIA GPU (CUDA 12.1)" "GPU compute acceleration" "Infrastructure"

        // External Dependencies
        hfHub = softwareSystem "HuggingFace Hub" "Model weight repository" "External"
        modelStorage = softwareSystem "Model Storage (PVC)" "Persistent volume for model weights" "Storage"

        // Relationships - Users
        datascientist -> kserve "Creates InferenceService to deploy TGIS" "kubectl / Dashboard"
        datascientist -> modelmesh "Creates InferenceService to deploy TGIS" "kubectl / Dashboard"
        sre -> prometheus "Monitors TGIS metrics" "Grafana / AlertManager"

        // Relationships - TGIS interactions
        kserve -> tgis "Sends inference requests" "gRPC/8033, Optional TLS/mTLS"
        modelmesh -> tgis "Sends inference requests" "gRPC/8033, Optional TLS/mTLS"
        kubernetes -> tgis "Health probes" "HTTP/3000"
        prometheus -> tgis "Scrapes metrics" "HTTP/3000 /metrics"

        // Relationships - TGIS outbound
        tgis -> modelStorage "Loads model weights" "Filesystem (Volume Mount)"
        tgis -> hfHub "Downloads model weights (offline only)" "HTTPS/443, Optional HF Token"
        tgis -> nvidiaGPU "GPU inference computation" "CUDA 12.1"

        // Internal container relationships
        launcher -> router "Spawns process"
        launcher -> pythonServer "Spawns shard processes"
        router -> pythonServer "Inference requests" "Unix Socket gRPC, plaintext"
        pythonServer -> inferenceEngine "Delegates inference"
        inferenceEngine -> cudaKernels "GPU-accelerated operations"
    }

    views {
        systemContext tgis "SystemContext" {
            include *
            autoLayout
        }

        container tgis "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "External" {
                background #f5a623
                color #ffffff
            }
            element "Storage" {
                background #d4a574
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
