/*
 * C4 Context Diagram: llama-stack-provider-ragas
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Evaluates LLM and RAG pipeline quality using standardized benchmarks"

        ragasProvider = softwareSystem "Llama Stack Provider Ragas" "Out-of-tree Llama Stack evaluation provider integrating Ragas framework for LLM/RAG quality assessment" {
            inlineProvider = container "RagasEvaluatorInline" "Runs Ragas evaluations in-process within Llama Stack server" "Python Provider"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluations to Kubeflow Pipelines for distributed execution" "Python Provider"
            inlineLLMWrapper = container "LlamaStackInlineLLM" "Adapts Llama Stack inference API to Ragas BaseRagasLLM interface" "Python Wrapper"
            inlineEmbedWrapper = container "LlamaStackInlineEmbeddings" "Adapts Llama Stack embeddings API to Ragas BaseRagasEmbeddings interface" "Python Wrapper"
            remoteLLMWrapper = container "LlamaStackRemoteLLM" "Adapts Llama Stack client for KFP component execution" "Python Wrapper"
            remoteEmbedWrapper = container "LlamaStackRemoteEmbeddings" "Adapts Llama Stack client embeddings for KFP component execution" "Python Wrapper"
            kfpPipeline = container "ragas_evaluation_pipeline" "Orchestrates data retrieval and evaluation in Kubeflow Pipelines" "KFP Pipeline"
            containerImage = container "KFP Container Image" "UBI9/Python 3.12 based image for KFP pipeline component execution" "OCI Image"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts eval provider plugins; provides inference, datasets, files, benchmarks APIs" "Internal RHOAI" {
            tags "Internal"
        }

        kubeflowPipelines = softwareSystem "Kubeflow Pipelines (Data Science Pipelines)" "Distributed pipeline execution platform on OpenShift" "Internal RHOAI" {
            tags "Internal"
        }

        ollama = softwareSystem "Ollama" "Default local LLM inference and embedding backend" "External" {
            tags "External"
        }

        vllm = softwareSystem "vLLM" "Alternative inference backend" "External" {
            tags "External"
        }

        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for evaluation results" "External" {
            tags "External"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides base image reference via ConfigMap" "Internal RHOAI" {
            tags "Internal"
        }

        k8sAPI = softwareSystem "Kubernetes API" "Cluster API for ConfigMap reads and kubeconfig loading" "External" {
            tags "External"
        }

        ragas = softwareSystem "Ragas Framework" "Core evaluation framework for LLM/RAG quality metrics" "External" {
            tags "External"
        }

        /* Relationships */
        user -> ragasProvider "Submits evaluation jobs via Llama Stack Eval API" "HTTP/8321"
        ragasProvider -> llamaStackServer "Runs as provider plugin; calls inference, datasets, embeddings APIs" "In-process / HTTP/8321"
        ragasProvider -> kubeflowPipelines "Submits and monitors pipeline runs" "HTTPS/443 Bearer Token"
        ragasProvider -> s3Storage "Stores and retrieves evaluation results" "HTTPS/443 AWS IAM"
        ragasProvider -> k8sAPI "Reads ConfigMaps, loads kubeconfig" "HTTPS/443 SA Token"
        ragasProvider -> ragas "Uses evaluation metrics (answer_relevancy, faithfulness, etc.)" "Python Library"
        llamaStackServer -> ollama "Inference and embeddings" "HTTP/11434"
        llamaStackServer -> vllm "Alternative inference" "HTTPS/configurable"
        trustyaiOperator -> ragasProvider "Provides KFP base image reference" "ConfigMap"

        /* Container-level relationships */
        inlineProvider -> inlineLLMWrapper "Uses for LLM inference"
        inlineProvider -> inlineEmbedWrapper "Uses for embeddings"
        remoteProvider -> remoteLLMWrapper "Uses for LLM inference in KFP"
        remoteProvider -> remoteEmbedWrapper "Uses for embeddings in KFP"
        remoteProvider -> kfpPipeline "Submits pipeline"
        kfpPipeline -> containerImage "Runs in"
    }

    views {
        systemContext ragasProvider "SystemContext" {
            include *
            autoLayout
        }

        container ragasProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
