graph TB
    subgraph "Notebooks Component - Container Images"
        subgraph "Workbench Images"
            JupyterMin[Jupyter Minimal<br/>Python 3.12 + JupyterLab 4.4]
            JupyterDS[Jupyter DataScience<br/>pandas, scikit-learn, matplotlib]
            JupyterPyTorch[Jupyter PyTorch<br/>CUDA 12.8 / ROCm 6.3]
            JupyterTF[Jupyter TensorFlow<br/>CUDA 12.8 / ROCm 6.3]
            JupyterTrusty[Jupyter TrustyAI<br/>Explainability tools]
            CodeServer[CodeServer DataScience<br/>VS Code in browser]
            RStudio[RStudio Minimal<br/>R development environment]
        end

        subgraph "Runtime Images"
            RuntimeMin[Runtime Minimal<br/>Lightweight Python]
            RuntimeDS[Runtime DataScience<br/>Common ML libraries]
            RuntimePyTorch[Runtime PyTorch<br/>GPU-accelerated training]
            RuntimeTF[Runtime TensorFlow<br/>GPU-accelerated training]
        end

        subgraph "Base Images"
            BaseUBI9[UBI9 Python Base]
            BaseCUDA[CUDA 12.8 Base]
            BaseROCm[ROCm 6.3 Base]
        end
    end

    subgraph "ODH/RHOAI Platform Components"
        NotebookController[ODH Notebook Controller]
        Dashboard[ODH Dashboard]
        KFP[Kubeflow Pipelines]
        Elyra[Elyra]
        OAuthProxy[OAuth Proxy]
        ImageStream[OpenShift ImageStream]
    end

    subgraph "Build System"
        Konflux[Konflux CI/CD]
        QuayRegistry[quay.io Registry]
    end

    subgraph "Deployed Workbench"
        WorkbenchPod[Workbench Pod<br/>Port 8888/TCP]
        OAuthSidecar[OAuth Proxy Sidecar<br/>Port 8443/TCP]
        Route[OpenShift Route<br/>HTTPS/443]
    end

    %% Build flow
    Konflux -->|builds| JupyterMin
    Konflux -->|builds| JupyterDS
    Konflux -->|builds| JupyterPyTorch
    Konflux -->|builds| JupyterTF
    Konflux -->|builds| CodeServer
    Konflux -->|builds| RStudio
    Konflux -->|builds| RuntimeMin
    Konflux -->|builds| RuntimeDS
    Konflux -->|builds| RuntimePyTorch
    Konflux -->|builds| RuntimeTF

    JupyterMin -->|pushes to| QuayRegistry
    RuntimeMin -->|pushes to| QuayRegistry
    QuayRegistry -->|referenced by| ImageStream

    %% Base image relationships
    BaseUBI9 -.->|base for| JupyterMin
    BaseUBI9 -.->|base for| JupyterDS
    BaseUBI9 -.->|base for| RuntimeMin
    BaseCUDA -.->|base for| JupyterPyTorch
    BaseCUDA -.->|base for| JupyterTF
    BaseROCm -.->|base for| JupyterPyTorch

    %% Consumption flow
    ImageStream -->|images listed in| Dashboard
    ImageStream -->|pulls from| NotebookController
    ImageStream -->|runtime images for| KFP
    ImageStream -->|runtime images for| Elyra

    %% Deployment flow
    NotebookController -->|creates| WorkbenchPod
    NotebookController -->|creates| OAuthSidecar
    NotebookController -->|creates| Route

    WorkbenchPod -->|uses image| JupyterDS
    OAuthSidecar -->|proxies to| WorkbenchPod
    Route -->|routes to| OAuthSidecar

