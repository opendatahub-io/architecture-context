%% Models as a Service - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS - Gateway API (openshift-ingress)"]
        Gateway["maas-default-gateway<br/>Hostname: maas.CLUSTER_DOMAIN<br/>80/TCP HTTP + 443/TCP HTTPS<br/>TLS Terminate (default-ingress-cert)<br/>Controller: openshift.io/gateway-controller/v1"]

        subgraph Policies["Gateway Policies"]
            AuthPol["gateway-auth-policy<br/>KubernetesTokenReview<br/>+ SubjectAccessReview<br/>+ Tier enrichment callback"]
            RatePol["gateway-rate-limits<br/>Free: 5/2m<br/>Premium: 20/2m<br/>Enterprise: 50/2m"]
            TokenPol["gateway-token-rate-limits<br/>Free: 100 tok/1m<br/>Premium: 50K tok/1m<br/>Enterprise: 100K tok/1m"]
            TelPol["telemetry-policy<br/>model/tier/user labels"]
        end

        Gateway --> AuthPol
        Gateway --> RatePol
        Gateway --> TokenPol
        Gateway --> TelPol
    end

    subgraph Application["APPLICATION (Cluster Internal)"]
        direction TB

        subgraph NS_MaaS["Namespace: maas-api"]
            MaaSAPI["maas-api<br/>Go/Gin REST API<br/>SA: maas-api<br/>Service: ClusterIP 8080/TCP<br/>Endpoints: /v1/models, /v1/tokens,<br/>/v1/api-keys, /v1/tiers/lookup"]
            MaaSAuth["maas-api-auth-policy<br/>KubernetesTokenReview<br/>Injects X-MaaS-Username<br/>X-MaaS-Group headers"]
        end

        subgraph NS_Tier["Namespace: {instance}-tier-{tier}"]
            TierSA["User ServiceAccounts<br/>(per-user, per-tier isolation)"]
        end
    end

    subgraph ModelInference["MODEL INFERENCE"]
        KServeBackend["LLMInferenceService Backend<br/>8000/TCP HTTPS<br/>via HTTPRoute"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>SA Token Auth"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Connection URL credentials"]
    end

    %% External to Gateway
    Client -->|"HTTPS/443<br/>TLS Terminate<br/>Bearer Token (SA token)<br/>Audience: maas-default-gateway-sa"| Gateway

    %% Gateway to Application
    Gateway -->|"HTTP/8080<br/>plaintext (cluster-internal)<br/>X-MaaS-Username/Group headers"| MaaSAPI
    MaaSAuth -->|"protects"| MaaSAPI
    AuthPol -->|"HTTP/8080 tier lookup<br/>callback /v1/tiers/lookup"| MaaSAPI

    %% Gateway to Model
    Gateway -->|"HTTPS/8000<br/>TLS<br/>Proxied request"| KServeBackend

    %% Application to Cluster Services
    MaaSAPI -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Informers, TokenRequest,<br/>TokenReview, SA CRUD"| K8sAPI
    MaaSAPI -->|"creates/deletes"| TierSA

    %% Optional external
    MaaSAPI -.->|"TCP/5432<br/>TLS (configurable)<br/>Credentials"| PostgreSQL

    %% Monitoring
    Prometheus -->|"HTTP scrape"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef policy fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class AuthPol,RatePol,TokenPol,TelPol,MaaSAuth policy
    class MaaSAPI,TierSA application
    class K8sAPI,Prometheus cluster
    class KServeBackend application
    class PostgreSQL externalservice
