graph TB
    SA["ServiceAccount:
    kuberay-operator"]

    CRB["ClusterRoleBinding:
    kuberay-operator"]

    CR["ClusterRole:
    kuberay-operator"]

    RaySA["ServiceAccount:
    raycluster-name-sa
    (per RayCluster)"]

    subgraph "Core Resources"
        CoreRes["Pods, Services, ConfigMaps,
        Secrets, ServiceAccounts,
        Events, Endpoints
        ---
        Verbs: create, delete,
        get, list, patch, update, watch"]
    end

    subgraph "Ray CRDs"
        RayRes["ray.io/v1:
        RayClusters, RayJobs, RayServices
        + status, finalizers
        ---
        Verbs: create, delete,
        get, list, patch, update, watch"]
    end

    subgraph "Networking"
        NetworkRes["networking.k8s.io:
        Ingresses, NetworkPolicies
        ---
        route.openshift.io: Routes
        ---
        gateway.networking.k8s.io:
        HTTPRoutes, ReferenceGrants
        ---
        Verbs: create, delete,
        get, list, patch, update, watch"]
    end

    subgraph "Security & Auth"
        SecurityRes["cert-manager.io:
        Certificates, Issuers
        ---
        config.openshift.io:
        Authentications, OAuths (read-only)
        ---
        authentication.k8s.io:
        TokenReviews (create)
        ---
        authorization.k8s.io:
        SubjectAccessReviews (create)"]
    end

    subgraph "Workloads"
        WorkloadRes["apps: Deployments (read-only)
        ---
        batch: Jobs
        ---
        Verbs: get, list, patch, update, watch"]
    end

    subgraph "RBAC Management"
        RBACRes["rbac.authorization.k8s.io:
        Roles, RoleBindings (manage)
        ClusterRoles, ClusterRoleBindings (read)
        ---
        coordination.k8s.io:
        Leases (leader election)"]
    end

    RayPods["Ray Head & Worker Pods"]

    SA -->|bound via| CRB
    CRB -->|grants| CR

    CR -->|full access| CoreRes
    CR -->|full access| RayRes
    CR -->|full access| NetworkRes
    CR -->|manages certs & validates tokens| SecurityRes
    CR -->|read & manage| WorkloadRes
    CR -->|manage roles & leader election| RBACRes

    RaySA -.->|identity for| RayPods

    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:3px,color:#000
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style RaySA fill:#6ca6e2,stroke:#333,stroke-width:2px,color:#fff
    style RayPods fill:#7ed321,stroke:#333,color:#000

    style CoreRes fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style RayRes fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NetworkRes fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style SecurityRes fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style WorkloadRes fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style RBACRes fill:#fff2cc,stroke:#d6b656,stroke-width:2px
