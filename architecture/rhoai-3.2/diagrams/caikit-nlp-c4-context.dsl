/*
 * C4 Context Diagram for caikit-nlp
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/caikit-nlp.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Sends inference requests to deployed NLP models"

        caikitNlp = softwareSystem "caikit-nlp" "NLP runtime library providing text generation, embeddings, reranking, classification via Caikit framework" {
            httpServer = container "HTTP Server" "REST API server for NLP inference tasks" "Python / Caikit Runtime" "Port 8080/TCP"
            grpcServer = container "gRPC Server" "gRPC API server for NLP inference tasks" "Python / Caikit Runtime" "Port 8085/TCP"
            textGenModules = container "Text Generation Modules" "Local text generation, TGIS-backed generation, PEFT prompt tuning" "Python Modules"
            embeddingModules = container "Embedding Modules" "Text embedding, reranking, sentence similarity via sentence-transformers" "Python Modules"
            classificationModules = container "Classification Modules" "Sequence and token classification via HuggingFace" "Python Modules"
            tgisAutoFinder = container "TGISAutoFinder" "Automatic discovery and configuration of TGIS-hosted models" "Python Module"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - Remote LLM inference backend" "Internal RHOAI"
        kserve = softwareSystem "KServe / ModelMesh" "Deploys and orchestrates caikit-nlp containers as inference endpoints" "Internal RHOAI"
        rhoaiGateway = softwareSystem "RHOAI Gateway" "Platform ingress gateway managing TLS termination and authentication" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage" "PVC or S3-based storage for model artifacts" "Internal RHOAI"
        huggingFaceHub = softwareSystem "HuggingFace Hub" "Public model repository for downloading model weights" "External"
        caikitCore = softwareSystem "Caikit Core Framework" "AI framework providing runtime, task/module abstractions" "External Library"

        # External relationships
        user -> rhoaiGateway "Sends inference requests" "HTTPS/443"
        rhoaiGateway -> caikitNlp "Forwards requests" "HTTP/8080, gRPC/8085"
        kserve -> caikitNlp "Deploys and manages containers"
        caikitNlp -> tgis "Remote text generation inference" "gRPC/8033-8034, Configurable mTLS"
        caikitNlp -> modelStorage "Loads model artifacts" "Volume mount"
        caikitNlp -> huggingFaceHub "Downloads models (when enabled)" "HTTPS/443"
        caikitNlp -> caikitCore "Uses runtime and module abstractions" "Python import"

        # Internal container relationships
        httpServer -> textGenModules "Routes text generation requests"
        httpServer -> embeddingModules "Routes embedding/rerank requests"
        httpServer -> classificationModules "Routes classification requests"
        grpcServer -> textGenModules "Routes text generation requests"
        grpcServer -> embeddingModules "Routes embedding/rerank requests"
        grpcServer -> classificationModules "Routes classification requests"
        textGenModules -> tgis "Remote inference via TGIS backend" "gRPC"
        tgisAutoFinder -> tgis "Discovers available models" "gRPC"
    }

    views {
        systemContext caikitNlp "SystemContext" {
            include *
            autoLayout
        }

        container caikitNlp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Library" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
