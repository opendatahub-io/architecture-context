%% Model Registry Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        MRRoute["{name}-https Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt<br/>NetworkPolicy: ingress only"]
        CatRoute["model-catalog-https Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt<br/>NetworkPolicy: ingress only"]
    end

    subgraph AuthProxy["AUTH PROXY (kube-rbac-proxy)"]
        MRProxy["kube-rbac-proxy<br/>(per MR instance)<br/>8443/TCP HTTPS<br/>SubjectAccessReview:<br/>get services/{name}"]
        CatProxy["kube-rbac-proxy<br/>(Model Catalog)<br/>8443/TCP HTTPS<br/>SubjectAccessReview:<br/>get services/model-catalog"]
    end

    subgraph Application["APPLICATION LAYER"]
        MRREST["Model Registry REST<br/>8080/TCP HTTP<br/>SA: {name}"]
        CatREST["Model Catalog REST<br/>8080/TCP HTTP<br/>SA: model-catalog"]
    end

    subgraph Database["DATABASE LAYER"]
        MRPostgres["PostgreSQL<br/>(per MR instance)<br/>5432/TCP<br/>Password Auth"]
        CatPostgres["Catalog PostgreSQL<br/>5432/TCP<br/>Password Auth"]
        ExtDB["External PostgreSQL/MySQL<br/>5432 or 3306/TCP<br/>Optional TLS"]
    end

    subgraph OperatorPlane["OPERATOR MANAGEMENT PLANE"]
        Operator["MR Operator Manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS (SAR)<br/>Webhooks: 9443/TCP HTTPS (mTLS)"]
        Migration["StorageMigrationManager<br/>v1alpha1 → v1beta1"]
    end

    subgraph K8sPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["K8s API Server<br/>6443/TCP HTTPS TLS<br/>TokenReview + SAR"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| MRRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatRoute

    %% Route to proxy
    MRRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>serving cert"| MRProxy
    CatRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>serving cert"| CatProxy

    %% Proxy auth delegation
    MRProxy -->|"HTTPS/6443<br/>TokenReview+SAR<br/>SA token"| K8sAPI
    CatProxy -->|"HTTPS/6443<br/>TokenReview+SAR<br/>SA token"| K8sAPI

    %% Proxy to app
    MRProxy -->|"HTTP/8080<br/>localhost<br/>no auth"| MRREST
    CatProxy -->|"HTTP/8080<br/>localhost<br/>no auth"| CatREST

    %% App to DB
    MRREST -->|"PostgreSQL/5432<br/>or MySQL/3306<br/>Password + Optional TLS"| MRPostgres
    MRREST -.->|"External DB<br/>Optional TLS"| ExtDB
    CatREST -->|"PostgreSQL/5432<br/>Password"| CatPostgres

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS<br/>SA token"| K8sAPI
    K8sAPI -->|"Watch events<br/>ModelRegistry CRs"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class MRRoute,CatRoute ingress
    class MRProxy,CatProxy authproxy
    class MRREST,CatREST application
    class MRPostgres,CatPostgres,ExtDB database
    class Operator,Migration operator
    class K8sAPI k8s
