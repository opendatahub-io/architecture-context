graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client/User]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Termination<br/>Route: &lt;registry-name&gt;-https"]
    end

    subgraph AppLayer["APPLICATION LAYER<br/>Namespace: &lt;registry-namespace&gt;"]
        direction TB

        subgraph OAuthContainer["OAuth Proxy Container Opt"]
            OAuthProxy["OAuth Proxy<br/>8443/TCP HTTPS<br/>SA: &lt;registry-name&gt;-sa<br/>Secret: oauth-proxy (TLS)"]
        end

        OAuthServer["OpenShift OAuth Server<br/>openshift-authentication<br/>443/TCP HTTPS TLS1.2+<br/>Bearer Token Validation"]

        subgraph APIContainer["Model Registry REST API Container"]
            RestAPI["Model Registry API<br/>8080/TCP HTTP<br/>9090/TCP gRPC (deprecated)<br/>SA: &lt;registry-name&gt;-sa<br/>UID: 65532 (non-root)<br/>Capabilities: ALL dropped"]
        end
    end

    subgraph DBLayer["DATABASE LAYER<br/>Namespace: &lt;registry-namespace&gt;"]
        direction TB

        PostgreSQL["PostgreSQL 16<br/>5432/TCP<br/>TLS 1.2+ opt<br/>PVC Storage<br/>Secret: &lt;registry-name&gt;-db"]

        MySQL["MySQL 8.0+<br/>3306/TCP<br/>TLS 1.2+ opt<br/>Secret: &lt;registry-name&gt;-db"]
    end

    subgraph OperatorLayer["OPERATOR LAYER<br/>Namespace: &lt;operator-namespace&gt;"]
        direction TB

        Controller["Controller Manager<br/>SA: controller-manager<br/>UID: 65532 (non-root)<br/>Capabilities: ALL dropped"]

        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>Endpoints: /mutate-*, /validate-*<br/>Secret: webhook-server-cert"]

        MetricsProxy["kube-rbac-proxy<br/>8443/TCP HTTPS TLS1.2+<br/>mTLS + SubjectAccessReview<br/>Secret: metrics-service"]

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.3<br/>Service Account Token"]
    end

    subgraph ServiceMesh["OPTIONAL SERVICE MESH"]
        direction TB
        IstioGW["Istio Gateway"]
        Authorino["Authorino<br/>50051/TCP gRPC mTLS<br/>AuthConfig CRDs<br/>JWT Token Validation"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Service Account Token"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>Service CA cert| OAuthProxy
    OAuthProxy -->|HTTPS/443<br/>TLS 1.2+<br/>Token Validation| OAuthServer
    OAuthProxy -->|HTTP/8080<br/>Validated Token<br/>HTTP header| RestAPI

    RestAPI -->|PostgreSQL/5432<br/>TLS 1.2+ opt<br/>Password + Client Cert| PostgreSQL
    RestAPI -->|MySQL/3306<br/>TLS 1.2+ opt<br/>Password + Client Cert| MySQL

    Controller -->|HTTPS/443<br/>TLS 1.3<br/>SA Token| K8sAPI
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>API Server cert| Webhook

    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>SA Token| MetricsProxy
    MetricsProxy -->|SubjectAccessReview| K8sAPI

    IstioGW -->|gRPC/50051<br/>mTLS<br/>Service Identity| Authorino
    Authorino -.->|AuthN/AuthZ| RestAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router ingress
    class OAuthProxy,OAuthServer,RestAPI app
    class PostgreSQL,MySQL database
    class Controller,Webhook,MetricsProxy,K8sAPI operator
    class IstioGW,Authorino servicemesh
    class Prometheus monitoring
