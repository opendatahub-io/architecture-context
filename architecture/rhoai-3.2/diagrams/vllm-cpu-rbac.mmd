%% vLLM CPU - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "vLLM CPU RBAC Model"
        direction TB

        Note["Note: vLLM CPU does not define its own RBAC resources.<br/>It runs as a workload container, not an operator.<br/>RBAC is managed by KServe or the deploying operator."]
    end

    subgraph "Authentication Mechanisms"
        direction TB

        APIKeyAuth["API Key Authentication<br/>(Bearer Header)<br/>Configured via --api-key<br/>or VLLM_API_KEY env var"]
        MTLSAuth["mTLS Authentication<br/>(Client Certificates)<br/>Configured via --ssl-cert-reqs"]
        NoAuth["/metrics Endpoint<br/>No Authentication<br/>Always Open"]
    end

    subgraph "Secrets & Credentials"
        direction TB

        SSLKey["ssl-keyfile<br/>Type: File mount<br/>Purpose: TLS private key<br/>Auto-Rotate: Yes (SSLCertRefresher)"]
        SSLCert["ssl-certfile<br/>Type: File mount<br/>Purpose: TLS certificate<br/>Auto-Rotate: Yes (SSLCertRefresher)"]
        SSLCACert["ssl-ca-certs<br/>Type: File mount<br/>Purpose: CA certs for client verify<br/>Auto-Rotate: Yes (SSLCertRefresher)"]
        HFToken["hf-token<br/>Type: Env (HF_TOKEN)<br/>Purpose: HuggingFace auth<br/>Auto-Rotate: No"]
        S3Creds["s3-credentials<br/>Type: Env vars<br/>Purpose: S3 access<br/>Auto-Rotate: No"]
        VLLMAPIKey["vllm-api-key<br/>Type: Env (VLLM_API_KEY)<br/>Purpose: API endpoint auth<br/>Auto-Rotate: No"]
    end

    subgraph "Protected Endpoints"
        HTTP8000["HTTP Endpoints<br/>Port 8000/TCP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/embeddings<br/>/v1/models<br/>(+ more)"]
        GRPC8033["gRPC Endpoint<br/>Port 8033/TCP<br/>TGIS Inference<br/>No Auth"]
        MetricsEP["/metrics<br/>Port 8000/TCP<br/>Prometheus metrics<br/>No Auth"]
    end

    %% Auth to endpoints
    APIKeyAuth -->|"protects"| HTTP8000
    MTLSAuth -->|"protects"| HTTP8000
    NoAuth -->|"open access"| MetricsEP

    %% Secrets to auth
    VLLMAPIKey -->|"provides key"| APIKeyAuth
    SSLKey -->|"TLS key"| MTLSAuth
    SSLCert -->|"TLS cert"| MTLSAuth
    SSLCACert -->|"CA verification"| MTLSAuth

    %% External auth
    HFToken -->|"auth to"| HFHub["HuggingFace Hub"]
    S3Creds -->|"auth to"| S3["S3 Storage"]

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style APIKeyAuth fill:#4a90e2,stroke:#333,color:#fff
    style MTLSAuth fill:#4a90e2,stroke:#333,color:#fff
    style NoAuth fill:#e8e8e8,stroke:#333
    style SSLKey fill:#f5a623,stroke:#333
    style SSLCert fill:#f5a623,stroke:#333
    style SSLCACert fill:#f5a623,stroke:#333
    style HFToken fill:#f5a623,stroke:#333
    style S3Creds fill:#f5a623,stroke:#333
    style VLLMAPIKey fill:#f5a623,stroke:#333
    style HTTP8000 fill:#7ed321,stroke:#333,color:#fff
    style GRPC8033 fill:#7ed321,stroke:#333,color:#fff
    style MetricsEP fill:#7ed321,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
