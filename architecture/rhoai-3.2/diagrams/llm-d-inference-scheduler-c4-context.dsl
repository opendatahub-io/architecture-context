// C4 Context Diagram - llm-d-inference-scheduler
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "ML Engineer / Client" "Sends inference requests to LLM models"

        llmdScheduler = softwareSystem "llm-d-inference-scheduler" "Optimized routing and scheduling for LLM inference requests via Kubernetes Gateway API" {
            epp = container "EPP (Endpoint Picker)" "Receives inference requests via Envoy ext-proc gRPC, runs pluggable filter/scorer pipeline, returns optimal pod selection" "Go Service"
            sidecar = container "P/D Routing Sidecar" "Reverse proxy on decode workers; orchestrates prefill/decode disaggregation via NIXL v2, LMCache, or SGLang protocols" "Go Sidecar Proxy"
            filterPlugins = container "Filter Plugins" "Exclude pods based on criteria (by-label, decode-filter, prefill-filter)" "Go Plugin System"
            scorerPlugins = container "Scorer Plugins" "Score candidate pods (prefix-cache, load-aware, session-affinity, active-request)" "Go Plugin System"
            ssrfValidator = container "SSRF Allowlist Validator" "Watches InferencePool and Pod resources to build dynamic allowlist for prefill target validation" "Go Controller"
        }

        envoyGateway = softwareSystem "Envoy Gateway" "Data plane proxy that forwards requests to EPP via ext-proc gRPC" "External"
        vllm = softwareSystem "vLLM Model Servers" "Backend LLM model-serving pods (prefill and decode workers)" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for resource discovery and RBAC" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Tokenizer model downloads for precise prefix cache scoring" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        gatewayAPI = softwareSystem "Gateway API / InferencePool CRD" "Kubernetes Gateway API and GIE CRDs for inference traffic routing" "External"

        // User interactions
        user -> envoyGateway "Sends inference requests" "HTTP/80"
        envoyGateway -> llmdScheduler "ext-proc routing decisions" "gRPC/9002"
        envoyGateway -> vllm "Forwards to selected pod" "HTTP/8000"
        envoyGateway -> sidecar "Routes P/D requests" "HTTP(S)/8000"

        // Internal interactions
        epp -> filterPlugins "Runs filter pipeline"
        epp -> scorerPlugins "Runs scorer pipeline"
        sidecar -> vllm "Proxies to local decoder and remote prefillers" "HTTP(S)/8001"
        sidecar -> ssrfValidator "Validates prefill targets"

        // External dependencies
        llmdScheduler -> k8sAPI "Watches InferencePool, Pod resources" "HTTPS/443"
        llmdScheduler -> huggingface "Downloads tokenizer models" "HTTPS/443"
        llmdScheduler -> gatewayAPI "Consumes InferencePool CRD" "Kubernetes API"
        vllm -> epp "KV cache events" "ZeroMQ/5557"
        prometheus -> llmdScheduler "Scrapes metrics" "HTTP/9090"
    }

    views {
        systemContext llmdScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmdScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
