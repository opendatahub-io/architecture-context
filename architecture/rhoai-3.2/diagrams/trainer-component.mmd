graph TB
    subgraph "Kubeflow Trainer Operator"
        ControllerManager[trainer-controller-manager<br/>Deployment]
        WebhookServer[webhook-server<br/>Port 9443/TCP HTTPS TLS 1.2+]
        TrainJobController[trainjob-controller]
        RuntimeController[trainingruntime-controller]
        ClusterRuntimeController[clustertrainingruntime-controller]
        ProgressionWatcher[progression-watcher<br/>RHOAI Plugin]

        ControllerManager --> TrainJobController
        ControllerManager --> RuntimeController
        ControllerManager --> ClusterRuntimeController
        ControllerManager --> ProgressionWatcher
        ControllerManager --> WebhookServer
    end

    subgraph "Custom Resources"
        TrainJobCR[TrainJob CR<br/>trainer.kubeflow.org/v1alpha1<br/>Namespaced]
        TrainingRuntimeCR[TrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1<br/>Namespaced]
        ClusterTrainingRuntimeCR[ClusterTrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1<br/>Cluster-scoped]
    end

    subgraph "External Dependencies"
        JobSetController[JobSet Controller<br/>jobset.x-k8s.io/v1alpha2]
        VolcanoScheduler[Volcano Scheduler<br/>Optional Gang Scheduling]
        KubeAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional TLS Cert Provisioning]
    end

    subgraph "RHOAI Integration"
        Dashboard[RHOAI Dashboard<br/>UI for TrainJob creation]
        Prometheus[Prometheus<br/>Metrics Collection]
        ModelRegistry[Model Registry<br/>Store trained models]
        S3Storage[S3 Storage<br/>Datasets/Checkpoints]
    end

    subgraph "Training Workloads"
        JobSet[JobSet Resource<br/>Created by TrainJob Controller]
        TrainingPods[Training Pods<br/>Distributed ML Training]
    end

    %% User Flow
    User[User/Data Scientist] -->|creates| TrainJobCR
    Dashboard -->|creates| TrainJobCR

    %% CRD Watching
    TrainJobCR -->|watched by| TrainJobController
    TrainingRuntimeCR -->|watched by| RuntimeController
    ClusterTrainingRuntimeCR -->|watched by| ClusterRuntimeController

    %% Webhook Validation
    KubeAPI -->|validates via| WebhookServer

    %% Resource Creation
    TrainJobController -->|creates| JobSet
    JobSetController -->|creates| TrainingPods
    TrainJobController -->|references| TrainingRuntimeCR
    TrainJobController -->|references| ClusterTrainingRuntimeCR

    %% External Dependencies
    TrainJobController -->|API calls| KubeAPI
    TrainJobController -.->|optional| VolcanoScheduler
    WebhookServer -.->|cert provisioning| CertManager

    %% Training Job Integrations
    TrainingPods -->|download datasets| S3Storage
    TrainingPods -->|upload checkpoints| S3Storage
    TrainingPods -.->|store models| ModelRegistry

    %% Monitoring
    Prometheus -->|scrapes metrics| ControllerManager
    ProgressionWatcher -->|tracks| TrainingPods

    %% Styling
    style ControllerManager fill:#4a90e2,stroke:#333,stroke-width:2px
    style WebhookServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrainJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style JobSetController fill:#999,stroke:#333,stroke-width:2px
    style VolcanoScheduler fill:#999,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style S3Storage fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainingPods fill:#4a90e2,stroke:#333,stroke-width:2px
