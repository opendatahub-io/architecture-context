        MPIPlugin["MPI Plugin<br/>(OpenMPI/SSH)"]
        CoschedulingPlugin["Coscheduling Plugin"]
        VolcanoPlugin["Volcano Plugin"]
    end

    TrainJobCtrl -->|uses| JobSetPlugin
    TrainJobCtrl -->|configures via| TorchPlugin
    TrainJobCtrl -->|configures via| MPIPlugin
    TrainJobCtrl -->|creates PodGroup| CoschedulingPlugin
    TrainJobCtrl -->|creates PodGroup| VolcanoPlugin

    %% CRDs
    User["User / Dashboard"] -->|creates| TrainJobCR["TrainJob CR"]
    TrainJobCR -->|watched by| TrainJobCtrl
    TrainJobCR -->|references| RuntimeCR["TrainingRuntime CR"]
    TrainJobCR -->|references| ClusterRuntimeCR["ClusterTrainingRuntime CR"]
    RuntimeCR -->|watched by| RuntimeCtrl
    ClusterRuntimeCR -->|watched by| ClusterRuntimeCtrl

    %% Created Resources
    JobSetPlugin -->|creates| JobSet["JobSet CR"]
    JobSet -->|manages| TrainingPods["Training Pods"]

    %% Progression Tracking
    ProgressTracker -->|polls /metrics<br/>28080/TCP HTTP| TrainingPods
    ProgressTracker -->|updates annotations| TrainJobCR

    %% External Dependencies
    TrainJobCtrl -->|CRUD via| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    JobSet -->|managed by| JobSetCtrl["JobSet Controller<br/>(sigs.k8s.io/jobset)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes 8443/TCP HTTPS| TrainerOperator

