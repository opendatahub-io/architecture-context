// Data Science Pipelines Tekton - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates, manages, and monitors ML pipelines"

        dspTekton = softwareSystem "Data Science Pipelines Tekton" "Kubeflow Pipelines backend adapted for Tekton, enabling ML pipeline orchestration on OpenShift" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API for pipeline, experiment, run, and job management" "Go Service" "Port 8888 HTTP, 8887 gRPC"
            cacheServer = container "cache-server" "Mutating admission webhook for pipeline step caching" "Go Webhook" "Port 8443 HTTPS"
            persistenceAgent = container "ds-pipeline-persistenceagent" "Watches Tekton PipelineRuns and syncs status to API server" "Go Service"
            scheduledWorkflow = container "ds-pipeline-scheduledworkflow" "Manages ScheduledWorkflow CRDs for recurring runs" "Go Controller"
            pipelineUI = container "ds-pipeline-ui" "Web UI for pipeline management with OAuth proxy sidecar" "React/TypeScript" "Port 3000 HTTP, 8443 HTTPS"
            vizServer = container "ds-pipeline-visualizationserver" "Renders pipeline output visualizations" "Python Service" "Port 8888 HTTP"
            viewerController = container "ds-pipeline-viewer-crd" "Watches Viewer CRDs and creates visualization Deployments" "Go Controller"
            metadataGRPC = container "metadata-grpc-deployment" "ML Metadata gRPC server for artifact/execution tracking" "C++ ml-metadata" "Port 8080 gRPC"
            metadataEnvoy = container "metadata-envoy-deployment" "Envoy proxy fronting MLMD gRPC server" "Envoy Proxy" "Port 9090 gRPC"
            metadataWriter = container "metadata-writer" "Watches PipelineRuns and writes execution metadata to MLMD" "Python Service"
            loopsController = container "pipeline-loops-controller" "Custom Tekton controller for PipelineLoop CRD" "Go Controller"
            artifactManager = container "artifact-manager" "Manages artifact upload/download to S3-compatible storage" "Python Utility"
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine (PipelineRun, TaskRun CRDs)" "External" {
            tags "External"
        }
        mysql = softwareSystem "MySQL/MariaDB" "Pipeline metadata, MLMD, and cache data storage" "External" {
            tags "External"
        }
        minio = softwareSystem "S3/MinIO Object Storage" "Pipeline artifact and log storage" "External" {
            tags "External"
        }
        openshiftOAuth = softwareSystem "OpenShift OAuth" "User authentication for UI access" "External" {
            tags "External"
        }
        k8sAPI = softwareSystem "Kubernetes API Server" "Container orchestration and CRD management" "External" {
            tags "External"
        }
        envoyProxy = softwareSystem "Envoy Proxy" "gRPC proxy for MLMD" "External" {
            tags "External"
        }

        odhDashboard = softwareSystem "ODH Dashboard" "Registers DSP as application tile" "Internal ODH" {
            tags "Internal ODH"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "Internal ODH" {
            tags "Internal ODH"
        }
        seldon = softwareSystem "Seldon" "ML model serving (SeldonDeployment CRD)" "Internal ODH" {
            tags "Internal ODH"
        }

        // External relationships
        dataScientist -> dspTekton "Creates and manages ML pipelines via UI" "HTTPS/8443"
        dspTekton -> tekton "Executes pipeline workflows" "CRD (PipelineRun, TaskRun) via kube-api HTTPS/443"
        dspTekton -> mysql "Stores pipeline metadata, MLMD, cache data" "MySQL/3306 plaintext"
        dspTekton -> minio "Stores pipeline artifacts and logs" "HTTP/9000 AccessKey/SecretKey"
        dspTekton -> openshiftOAuth "Authenticates UI users" "HTTPS/443 OAuth2"
        dspTekton -> k8sAPI "Manages CRDs, PipelineRuns, RBAC" "HTTPS/443 ServiceAccount token"
        odhDashboard -> dspTekton "Displays as application tile" "OdhApplication CRD"
        prometheus -> dspTekton "Scrapes metrics" "HTTP/8888 /metrics"

        // Internal container relationships
        dataScientist -> pipelineUI "Manages pipelines" "HTTPS/8443 OAuth"
        pipelineUI -> apiServer "REST API calls" "HTTP/8888"
        apiServer -> mysql "Pipeline metadata queries" "MySQL/3306"
        apiServer -> minio "Artifact storage" "HTTP/9000"
        apiServer -> k8sAPI "Create/manage PipelineRuns" "HTTPS/443"
        apiServer -> vizServer "Visualization requests" "HTTP/8888"
        persistenceAgent -> k8sAPI "Watch PipelineRuns" "HTTPS/443"
        persistenceAgent -> apiServer "Sync run status" "HTTP/8888"
        scheduledWorkflow -> k8sAPI "Watch ScheduledWorkflows, create PipelineRuns" "HTTPS/443"
        viewerController -> k8sAPI "Watch Viewers, create Deployments" "HTTPS/443"
        metadataWriter -> k8sAPI "Watch PipelineRuns" "HTTPS/443"
        metadataWriter -> metadataEnvoy "Write execution metadata" "gRPC/9090"
        metadataEnvoy -> metadataGRPC "Forward gRPC requests" "gRPC/8080"
        metadataGRPC -> mysql "Store MLMD data" "MySQL/3306"
        cacheServer -> k8sAPI "Admission webhook" "HTTPS/8443"
    }

    views {
        systemContext dspTekton "SystemContext" {
            include *
            autoLayout
        }

        container dspTekton "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            relationship "Relationship" {
                dashed false
            }
        }
    }
}
