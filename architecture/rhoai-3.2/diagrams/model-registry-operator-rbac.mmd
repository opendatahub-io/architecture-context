graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: &lt;operator-namespace&gt;"]
        SA_Registry["&lt;registry-name&gt;-sa<br/>Namespace: &lt;registry-namespace&gt;"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_Proxy[proxy-role<br/>ClusterRole]
        CR_Leader[leader-election-role<br/>Role]
    end

    subgraph "Roles (Per Registry Instance)"
        R_User["registry-user-&lt;registry-name&gt;<br/>Role<br/>Namespace: &lt;registry-namespace&gt;"]
    end

    subgraph "API Resources - Core"
        R_ConfigMaps[configmaps]
        R_PVCs[persistentvolumeclaims]
        R_Secrets[secrets]
        R_ServiceAccounts[serviceaccounts]
        R_Services[services]
        R_Endpoints[endpoints]
        R_Pods[pods, pods/log]
        R_Events[events]
    end

    subgraph "API Resources - Apps"
        R_Deployments[apps/deployments]
    end

    subgraph "API Resources - ModelRegistry"
        R_ModelRegistries[modelregistry.opendatahub.io/<br/>modelregistries]
        R_MR_Status[modelregistry.opendatahub.io/<br/>modelregistries/status]
        R_MR_Finalizers[modelregistry.opendatahub.io/<br/>modelregistries/finalizers]
    end

    subgraph "API Resources - RBAC"
        R_ClusterRoleBindings[rbac.authorization.k8s.io/<br/>clusterrolebindings]
        R_RoleBindings[rbac.authorization.k8s.io/<br/>rolebindings]
        R_Roles[rbac.authorization.k8s.io/<br/>roles]
    end

    subgraph "API Resources - OpenShift"
        R_Routes[route.openshift.io/<br/>routes, routes/custom-host]
        R_Ingresses[config.openshift.io/<br/>ingresses]
        R_Groups[user.openshift.io/<br/>groups]
    end

    subgraph "API Resources - Networking"
        R_NetworkPolicies[networking.k8s.io/<br/>networkpolicies]
    end

    subgraph "API Resources - Auth"
        R_TokenReviews[authentication.k8s.io/<br/>tokenreviews]
        R_SubjectAccessReviews[authorization.k8s.io/<br/>subjectaccessreviews]
    end

    subgraph "API Resources - Extensions"
        R_CRDs[apiextensions.k8s.io/<br/>customresourcedefinitions]
        R_StorageVersionMigrations[migration.k8s.io/<br/>storageversionmigrations]
    end

    %% Bindings
    SA_Controller -->|bound via<br/>manager-rolebinding| CR_Manager
    SA_Controller -->|bound via<br/>leader-election-rolebinding| CR_Leader
    SA_Controller -->|bound via<br/>proxy-rolebinding| CR_Proxy

    %% Manager Role Permissions
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_ConfigMaps
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_PVCs
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Secrets
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_ServiceAccounts
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Services
    CR_Manager -->|get, list, watch| R_Endpoints
    CR_Manager -->|get, list, watch| R_Pods
    CR_Manager -->|create, patch| R_Events
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Deployments
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_ModelRegistries
    CR_Manager -->|get, patch, update| R_MR_Status
    CR_Manager -->|update| R_MR_Finalizers
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_ClusterRoleBindings
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_RoleBindings
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Roles
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Routes
    CR_Manager -->|get, list, watch| R_Ingresses
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_Groups
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_NetworkPolicies
    CR_Manager -->|create| R_TokenReviews
    CR_Manager -->|create| R_SubjectAccessReviews
    CR_Manager -->|get, list, watch| R_CRDs
    CR_Manager -->|create, delete, get,<br/>list, patch, update, watch| R_StorageVersionMigrations

    %% Proxy Role Permissions
    CR_Proxy -->|create| R_TokenReviews
    CR_Proxy -->|create| R_SubjectAccessReviews

    %% Registry User Role
    R_User -->|get| R_Services
    SA_Registry -.->|bound via<br/>&lt;registry-name&gt;-rolebinding<br/>created per user/SA| R_User

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef clusterrole fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#e67e22,stroke:#333,stroke-width:2px
    classDef resource fill:#7ed321,stroke:#333,stroke-width:1px
    classDef resourceAuth fill:#9b59b6,stroke:#333,stroke-width:1px,color:#fff

    class SA_Controller,SA_Registry sa
    class CR_Manager,CR_Proxy clusterrole
    class CR_Leader,R_User role
    class R_ConfigMaps,R_PVCs,R_Secrets,R_ServiceAccounts,R_Services,R_Endpoints,R_Pods,R_Events,R_Deployments,R_ModelRegistries,R_MR_Status,R_MR_Finalizers,R_ClusterRoleBindings,R_RoleBindings,R_Roles,R_Routes,R_Ingresses,R_Groups,R_NetworkPolicies,R_CRDs,R_StorageVersionMigrations resource
    class R_TokenReviews,R_SubjectAccessReviews resourceAuth
