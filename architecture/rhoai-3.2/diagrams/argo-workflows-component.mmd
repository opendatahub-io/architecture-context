graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        Controller["workflow-controller<br/>Go Binary (Deployment)<br/>Ports: 9090/TCP metrics, 6060/TCP health"]
        ArgoExec["argoexec<br/>Go Binary (Sidecar/Init)<br/>Emissary Executor Pattern"]
        ArgoServer["argo-server<br/>Go Binary (Deployment)<br/>Port: 2746/TCP gRPC+REST"]
        UI["UI (React)<br/>Embedded in argo-server"]
        ArgoServer --- UI
    end

    subgraph CRDs["Custom Resource Definitions (argoproj.io/v1alpha1)"]
        WorkflowCR["Workflow"]
        CronWorkflow["CronWorkflow"]
        WorkflowTemplate["WorkflowTemplate"]
        ClusterWFTemplate["ClusterWorkflowTemplate"]
        WorkflowTaskSet["WorkflowTaskSet"]
        WorkflowTaskResult["WorkflowTaskResult"]
        WorkflowArtifactGC["WorkflowArtifactGCTask"]
        WorkflowEventBinding["WorkflowEventBinding"]
    end

    DSP["Data Science Pipelines<br/>(DSP API Server)"] -->|creates| WorkflowCR
    WorkflowCR -->|watched by| Controller
    CronWorkflow -->|watched by| Controller
    WorkflowTemplate -->|referenced by| Controller
    ClusterWFTemplate -->|referenced by| Controller

    Controller -->|creates Pods with| ArgoExec
    Controller -->|manages| WorkflowTaskSet
    Controller -->|reads| WorkflowTaskResult
    Controller -->|creates| WorkflowArtifactGC

    ArgoExec -->|reports via| WorkflowTaskResult
    ArgoServer -->|queries| WorkflowCR
    ArgoServer -->|manages| CronWorkflow
    ArgoServer -->|manages| WorkflowTemplate

    subgraph ExternalDeps["External Dependencies"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
        S3["S3/MinIO<br/>Artifact Storage"]
        DB["PostgreSQL/MySQL<br/>(Optional Archiving)"]
        OIDC["OIDC Provider<br/>(Optional SSO)"]
    end

    Controller -->|Pod CRUD, CR watch| K8sAPI
    ArgoExec -->|artifact upload| S3
    ArgoExec -->|patch results| K8sAPI
    Controller -->|archive workflows| DB
    ArgoServer -->|query archives| DB
    ArgoServer -->|validate tokens| OIDC

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus"]
    end

    Prometheus -->|scrape :9090| Controller
    Prometheus -->|scrape :9090| ArgoServer

