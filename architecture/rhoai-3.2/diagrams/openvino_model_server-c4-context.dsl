// OpenVINO Model Server - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries ML models for inference"
        mlEngineer = person "ML Engineer" "Configures model serving runtimes and pipelines"

        ovms = softwareSystem "OpenVINO Model Server" "High-performance model inference server using OpenVINO for optimized AI model serving via gRPC and REST APIs" {
            grpcModule = container "GRPCServerModule" "Hosts gRPC server with TFS and KServe V2 services" "C++ gRPC Server"
            httpModule = container "HTTPServerModule" "Hosts REST/HTTP server for v1/v2/v3 API endpoints" "C++ HTTP Server"
            servableManager = container "ServableManagerModule" "Manages model lifecycle, loading, versioning, and serving" "C++ Module"
            metricModule = container "MetricModule" "Prometheus-compatible metrics collection and exposition" "C++ Module"
            hfPullModule = container "HfPullModelModule" "Downloads models from HuggingFace Hub" "C++ Module"
            llmModule = container "LLM Module" "OpenAI-compatible chat/completions via MediaPipe" "C++ MediaPipe Graph"
            embeddingsModule = container "Embeddings Module" "OpenAI-compatible text embeddings" "C++ MediaPipe Graph"
            rerankModule = container "Rerank Module" "Cohere-compatible reranking" "C++ MediaPipe Graph"
            dagScheduler = container "DAG Scheduler" "Directed Acyclic Graph pipeline execution" "C++ Library"
            filesystemBackends = container "Filesystem Backends" "Local, S3, GCS, Azure Blob model access" "C++ Libraries"
        }

        kserve = softwareSystem "KServe" "Standardized serverless ML inference platform - deploys OVMS as ServingRuntime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Multi-model serving infrastructure - can use OVMS as runtime" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"

        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, MinIO)" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External"
        azureBlob = softwareSystem "Azure Blob Storage" "Model artifact storage" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Pre-trained model repository" "External"
        openvinoRuntime = softwareSystem "OpenVINO Runtime" "Intel AI inference engine backend" "External Library"

        // User interactions
        datascientist -> kserve "Creates InferenceService via kubectl/dashboard"
        datascientist -> ovms "Sends inference requests" "gRPC/8085, HTTP/8080"
        mlEngineer -> kserve "Configures ServingRuntime"

        // Infrastructure relationships
        kserve -> ovms "Deploys as inference container" "gRPC/8085"
        modelmesh -> ovms "Uses as serving runtime" "gRPC/configurable"
        prometheus -> ovms "Scrapes metrics" "HTTP /metrics"

        // OVMS to external services
        ovms -> s3 "Downloads model artifacts" "HTTPS/443"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443"
        ovms -> azureBlob "Downloads model artifacts" "HTTPS/443"
        ovms -> huggingface "Downloads models via git" "HTTPS/443"
        ovms -> openvinoRuntime "Inference execution" "In-process C++ API"

        // Internal container relationships
        grpcModule -> servableManager "Model inference requests"
        httpModule -> servableManager "Model inference requests"
        httpModule -> llmModule "OpenAI v3 requests"
        httpModule -> embeddingsModule "Embeddings requests"
        httpModule -> rerankModule "Rerank requests"
        servableManager -> filesystemBackends "Load models"
        servableManager -> dagScheduler "Pipeline execution"
        hfPullModule -> huggingface "Git clone models"
        filesystemBackends -> s3 "S3 model access"
        filesystemBackends -> gcs "GCS model access"
        filesystemBackends -> azureBlob "Azure model access"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Library" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
