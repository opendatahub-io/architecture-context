/*
 * FMS Guardrails Orchestrator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        client = person "API Client" "Sends text generation requests with guardrails enforcement"

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Rust-based middleware that coordinates AI text generation with content safety guardrails" {
            guardrailsServer = container "Guardrails Server" "Main API server handling guardrails requests on port 8033" "Rust (Axum/Tokio)"
            healthServer = container "Health Server" "Health and info endpoints on port 8034" "Rust (Axum)"
            generationClient = container "GenerationClient" "gRPC client for TGIS/caikit-nlp backends" "Rust (Tonic)"
            openaiClient = container "OpenAiClient" "HTTP client for OpenAI-compatible backends" "Rust (Reqwest)"
            detectorClient = container "DetectorClient" "HTTP client for content safety detectors" "Rust (Reqwest)"
            chunkerClient = container "ChunkerClient" "gRPC client for text chunking services" "Rust (Tonic)"
            tlsModule = container "TLS Module" "TLS/mTLS configuration for server and client connections" "Rust (rustls/ring)"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - LLM generation backend" "Internal RHOAI"
        caikitNlp = softwareSystem "caikit-nlp" "NLP text generation backend" "Internal RHOAI"
        chunkers = softwareSystem "caikit Chunkers" "Text chunking/tokenization services" "Internal RHOAI"
        detectors = softwareSystem "Content Safety Detectors" "HAP, toxicity, and content safety detection services" "Internal RHOAI"
        vllm = softwareSystem "vLLM / OpenAI-compatible" "Chat completions and completions generation backend" "Internal RHOAI"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry traces and metrics collector" "External"

        # Relationships
        client -> orchestrator "Sends text generation/detection requests" "HTTP/HTTPS 8033/TCP, TLS 1.2+/mTLS"
        orchestrator -> tgis "Text generation requests" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> caikitNlp "NLP text generation" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> chunkers "Text chunking/tokenization" "gRPC/HTTP2, TLS/mTLS"
        orchestrator -> detectors "Content safety detection" "HTTP/HTTPS, TLS/mTLS"
        orchestrator -> vllm "Chat completions / completions" "HTTP/HTTPS, TLS/mTLS"
        orchestrator -> otlpCollector "Traces and metrics export" "OTLP gRPC/HTTP 4317-4318/TCP"

        # Container-level relationships
        guardrailsServer -> generationClient "Invokes for LLM generation"
        guardrailsServer -> openaiClient "Invokes for OpenAI generation"
        guardrailsServer -> detectorClient "Invokes for content detection"
        guardrailsServer -> chunkerClient "Invokes for text chunking"
        guardrailsServer -> tlsModule "Uses for TLS/mTLS"
        generationClient -> tgis "gRPC Generate/GenerateStream" "gRPC/HTTP2"
        generationClient -> caikitNlp "gRPC TextGenerationTask" "gRPC/HTTP2"
        chunkerClient -> chunkers "gRPC ChunkerTokenizationTask" "gRPC/HTTP2"
        detectorClient -> detectors "POST /api/v1/text/*" "HTTP/HTTPS"
        openaiClient -> vllm "POST /v1/chat/completions" "HTTP/HTTPS"
    }

    views {
        systemContext orchestrator "SystemContext" {
            include *
            autoLayout
        }

        container orchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #f5a623
                color #ffffff
                shape person
            }
            element "Container" {
                background #5ba3d9
                color #ffffff
            }
        }
    }
}
