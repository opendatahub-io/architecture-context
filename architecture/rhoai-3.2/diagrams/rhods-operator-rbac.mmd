graph TD
    subgraph "Service Accounts"
        ControllerSA[controller-manager<br/>Namespace: redhat-ods-operator]
        PrometheusSA[prometheus<br/>Namespace: redhat-ods-monitoring]
    end

    subgraph "ClusterRole Bindings"
        ManagerCRB[opendatahub-operator-manager-rolebinding<br/>ClusterRoleBinding]
        PromScraperRB[prometheus-rolebinding-scraper<br/>RoleBinding]
        PromViewerRB[prometheus-rolebinding-viewer<br/>RoleBinding]
    end

    subgraph "Roles"
        ManagerCR[opendatahub-operator-manager-role<br/>ClusterRole]
        ClusterMonView[cluster-monitoring-view<br/>ClusterRole]
        ViewRole[view<br/>ClusterRole]
    end

    subgraph "Operator API Groups & Resources"
        direction TB
        DSCResources["datasciencecluster.opendatahub.io<br/>• datascienceclusters<br/>• datascienceclusters/status<br/>• datascienceclusters/finalizers<br/>Verbs: * (all)"]
        DSCIResources["dscinitialization.opendatahub.io<br/>• dscinitializations<br/>• dscinitializations/status<br/>• dscinitializations/finalizers<br/>Verbs: * (all)"]
        ComponentResources["components.opendatahub.io<br/>• dashboards, datasciencepipelines<br/>• kserve, kueue, ray, trustyai<br/>• modelregistry, workbenches<br/>• trainingoperator, feastoperator<br/>• mlflowoperator, llamastackoperator<br/>Verbs: * (all)"]
        ServiceResources["services.opendatahub.io<br/>• auths, monitorings, gateways<br/>Verbs: * (all)"]
        InfraResources["infrastructure.opendatahub.io<br/>• hardwareprofiles<br/>Verbs: * (all)"]
    end

    subgraph "Core Kubernetes Resources"
        direction TB
        CoreResources["Core API Group (v1)<br/>• pods, services, serviceaccounts<br/>• secrets, configmaps<br/>• persistentvolumeclaims<br/>• namespaces, events<br/>Verbs: get, list, watch, create, update, patch, delete"]
        AppsResources["apps<br/>• deployments, replicasets<br/>• statefulsets<br/>Verbs: * (all)"]
        RBACResources["rbac.authorization.k8s.io<br/>• roles, rolebindings<br/>• clusterroles, clusterrolebindings<br/>Verbs: * (all)"]
        NetworkResources["networking.k8s.io<br/>• networkpolicies, ingresses<br/>Verbs: * (all)"]
    end

    subgraph "OpenShift Resources"
        direction TB
        RouteResources["route.openshift.io<br/>• routes<br/>Verbs: get, list, watch, create, update, patch, delete"]
        SecurityResources["security.openshift.io<br/>• securitycontextconstraints<br/>• Specific: anyuid, restricted<br/>Verbs: * (all)"]
        OAuthResources["oauth.openshift.io<br/>• oauthclients<br/>Verbs: * (all)"]
        OperatorResources["operator.openshift.io<br/>• consoles, ingresscontrollers<br/>Verbs: get, list, watch, patch, delete"]
        ConfigResources["config.openshift.io<br/>• clusterversions, proxies<br/>Verbs: get, list, watch"]
    end

    subgraph "Monitoring Resources"
        direction TB
        MonitoringResources["monitoring.coreos.com<br/>• servicemonitors, podmonitors<br/>• prometheusrules<br/>• prometheuses, alertmanagers<br/>Verbs: * (all)"]
    end

    subgraph "OLM Resources"
        direction TB
        OLMResources["operators.coreos.com<br/>• subscriptions<br/>• clusterserviceversions<br/>• catalogsources<br/>Verbs: get, list, watch, delete, update"]
    end

    subgraph "API Extensions"
        direction TB
        CRDResources["apiextensions.k8s.io<br/>• customresourcedefinitions<br/>Verbs: * (all)"]
    end

    subgraph "Authentication & Authorization"
        direction TB
        AuthResources["authentication.k8s.io<br/>• tokenreviews<br/>Verbs: create, get"]
        AuthzResources["authorization.k8s.io<br/>• subjectaccessreviews<br/>Verbs: create, get"]
    end

    %% Service Account to Bindings
    ControllerSA -->|bound via| ManagerCRB
    PrometheusSA -->|bound via| PromScraperRB
    PrometheusSA -->|bound via| PromViewerRB

    %% Bindings to Roles
    ManagerCRB -->|grants| ManagerCR
    PromScraperRB -->|grants| ClusterMonView
    PromViewerRB -->|grants| ViewRole

    %% Manager ClusterRole to Resources
    ManagerCR -->|manages| DSCResources
    ManagerCR -->|manages| DSCIResources
    ManagerCR -->|manages| ComponentResources
    ManagerCR -->|manages| ServiceResources
    ManagerCR -->|manages| InfraResources
    ManagerCR -->|manages| CoreResources
    ManagerCR -->|manages| AppsResources
    ManagerCR -->|manages| RBACResources
    ManagerCR -->|manages| NetworkResources
    ManagerCR -->|manages| RouteResources
    ManagerCR -->|manages| SecurityResources
    ManagerCR -->|manages| OAuthResources
    ManagerCR -->|manages| OperatorResources
    ManagerCR -->|manages| ConfigResources
    ManagerCR -->|manages| MonitoringResources
    ManagerCR -->|manages| OLMResources
    ManagerCR -->|manages| CRDResources
    ManagerCR -->|manages| AuthResources
    ManagerCR -->|manages| AuthzResources

    %% Prometheus permissions
    ClusterMonView -->|read metrics from| MonitoringResources
    ViewRole -->|read resources in| CoreResources

