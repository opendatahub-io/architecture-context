/*
 * KServe C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/kserve.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and deploys ML models for inference via InferenceService CRDs"
        externalClient = person "External Client" "Sends inference requests to deployed models"

        kserve = softwareSystem "KServe" "Kubernetes-native ML model serving controller for RHOAI. Manages InferenceService, LLMInferenceService, InferenceGraph, and TrainedModel CRDs." {
            controllerManager = container "KServe Controller Manager" "Main controller reconciling InferenceService, LLMInferenceService, InferenceGraph, and TrainedModel CRDs into Deployments, Services, and ingress resources" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates and defaults all KServe CRDs via admission webhooks" "Go (9443/TCP HTTPS)"
            storageInitializer = container "Storage Initializer" "Init container that downloads model artifacts from S3/GCS/Azure/OCI/HuggingFace" "Go (init container)"
            kserveAgent = container "KServe Agent" "Sidecar for multi-model serving, inference logging, and batching" "Go (sidecar)"
            kserveRouter = container "KServe Router" "Routes requests between InferenceServices in an InferenceGraph DAG" "Go"
            kubeRbacProxy = container "kube-rbac-proxy" "Authentication/authorization proxy for inference and metrics endpoints" "Go (sidecar, 8443/TCP)"
            llmScheduler = container "llm-d Inference Scheduler" "Intelligent LLM request routing via Gateway API Inference Extensions (InferencePool)" "Go"
            routingSidecar = container "llm-d Routing Sidecar" "Request routing within llm-d disaggregated topology" "Go (sidecar)"
        }

        # External Dependencies
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (v4.19/v4.20)" "External"
        istio = softwareSystem "Istio / Service Mesh" "VirtualService-based ingress and traffic management (v1.24.x)" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute-based ingress (v1.2.1)" "External"
        gieController = softwareSystem "Gateway API Inference Extension" "InferencePool/InferenceModel for LLM scheduling (v0.3.0)" "External"
        knativeServing = softwareSystem "Knative Serving" "Serverless autoscaling (v0.44.0, not default in RHOAI)" "External"
        keda = softwareSystem "KEDA" "Custom autoscaling via ScaledObjects (v2.16.1)" "External"
        leaderWorkerSet = softwareSystem "LeaderWorkerSet" "Multi-node LLM inference workloads (v0.6.2)" "External"
        certManager = softwareSystem "OpenShift service-ca" "Webhook TLS certificate injection" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor for metrics (v0.76.2)" "External"
        otelOp = softwareSystem "OpenTelemetry Operator" "Inference tracing/telemetry (v0.113.0)" "External"

        # Internal RHOAI Dependencies
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys KServe manifests via kustomize overlay" "Internal RHOAI"
        openshiftIngress = softwareSystem "OpenShift Ingress" "Gateway for external inference access (openshift-ai-inference)" "Internal RHOAI"

        # External Services
        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage" "External Service"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External Service"
        azure = softwareSystem "Azure Blob Storage" "Model artifact storage" "External Service"
        ociRegistry = softwareSystem "OCI Registries" "Model artifact storage (OCI artifacts)" "External Service"
        huggingFace = softwareSystem "HuggingFace Hub" "Model artifact storage" "External Service"

        # Relationships
        dataScientist -> kserve "Creates InferenceService / LLMInferenceService via kubectl" "HTTPS/443"
        externalClient -> openshiftIngress "Sends inference requests" "HTTPS/443"
        openshiftIngress -> kserve "Routes to predictor pods" "HTTP/80"

        kserve -> kubernetes "Reconciles CRDs, creates resources" "HTTPS/443"
        kserve -> istio "Creates VirtualServices/DestinationRules for traffic routing"
        kserve -> gatewayAPI "Creates HTTPRoutes for ingress"
        kserve -> gieController "Creates InferencePool/InferenceModel for LLM scheduling"
        kserve -> knativeServing "Creates Knative Services (serverless mode)"
        kserve -> keda "Creates ScaledObjects for custom autoscaling"
        kserve -> leaderWorkerSet "Creates LeaderWorkerSets for multi-node serving"
        kserve -> prometheusOp "Creates ServiceMonitors/PodMonitors"
        kserve -> otelOp "Creates OpenTelemetryCollectors"

        rhodsOperator -> kserve "Deploys via kustomize overlay"
        certManager -> kserve "Injects webhook TLS certificates"

        storageInitializer -> s3 "Downloads model artifacts" "HTTPS/443"
        storageInitializer -> gcs "Downloads model artifacts" "HTTPS/443"
        storageInitializer -> azure "Downloads model artifacts" "HTTPS/443"
        storageInitializer -> ociRegistry "Downloads model artifacts" "HTTPS/443"
        storageInitializer -> huggingFace "Downloads model artifacts" "HTTPS/443"

        controllerManager -> webhookServer "Admission validation"
        controllerManager -> kubernetes "CRD reconciliation" "HTTPS/443"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
        }

        container kserve "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
