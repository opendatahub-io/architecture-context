/*
 * NeMo Guardrails - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/NeMo-Guardrails.md
 */

workspace {
    model {
        developer = person "Application Developer" "Builds LLM-powered applications with guardrail enforcement"
        platformAdmin = person "Platform Admin" "Deploys and configures NeMo Guardrails via RHOAI operator"

        nemoGuardrails = softwareSystem "NeMo Guardrails" "Programmable guardrails for LLM-based conversational systems - controls and secures LLM outputs" {
            guardrailsServer = container "Guardrails Server" "Main HTTP server exposing OpenAI-compatible chat completions API with guardrail enforcement" "FastAPI/Uvicorn, Python 3.12, Port 8000"
            actionsServer = container "Actions Server" "Separate server for executing custom guardrail actions remotely" "FastAPI, Port 8001"
            llmRailsEngine = container "LLMRails Engine" "Core engine that loads configs and orchestrates guardrail evaluation pipeline" "Python Runtime"
            colangRuntime = container "Colang Runtime" "Interpreter for Colang DSL (v1.0/v2.x) defining conversational flows and guardrails" "DSL Interpreter"
            guardrailsLibrary = container "Guardrails Library" "Built-in guardrail modules: content safety, hallucination, jailbreak, injection, PII, topic safety, fact checking" "Python Plugins"
            embeddingsEngine = container "Embeddings Engine" "Embedding model management for semantic similarity (FastEmbed, SentenceTransformers)" "ML Pipeline"
            knowledgeBase = container "Knowledge Base" "RAG-style document store for retrieval-augmented guardrail evaluation" "Document Store"
            tracingSystem = container "Tracing System" "OpenTelemetry-compatible tracing for guardrail execution spans" "OpenTelemetry"
        }

        llmBackend = softwareSystem "LLM Inference Service" "Backend LLM for inference (vLLM, NVIDIA NIM, OpenAI)" "External"
        redis = softwareSystem "Redis" "Optional conversation thread persistence" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "ML model repository (build-time only in disconnected mode)" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Platform operator managing deployment and ingress" "Internal RHOAI"
        clientApp = softwareSystem "Client Application" "LLM-powered application consuming guardrailed chat API" "External"

        # External relationships
        developer -> clientApp "Develops"
        platformAdmin -> rhoaiOperator "Configures guardrails deployment"
        clientApp -> nemoGuardrails "POST /v1/chat/completions" "HTTP/8000"
        rhoaiOperator -> nemoGuardrails "Deploys and manages" "Kubernetes API"

        # Internal container relationships
        guardrailsServer -> llmRailsEngine "Orchestrates guardrail evaluation"
        actionsServer -> llmRailsEngine "Executes custom actions"
        llmRailsEngine -> colangRuntime "Evaluates Colang flows"
        colangRuntime -> guardrailsLibrary "Applies input/output rails"
        llmRailsEngine -> embeddingsEngine "Generates embeddings"
        llmRailsEngine -> knowledgeBase "Retrieves relevant documents"
        guardrailsServer -> tracingSystem "Exports execution traces"

        # Egress relationships
        nemoGuardrails -> llmBackend "LLM inference requests" "HTTPS/443, TLS 1.2+, API Key"
        nemoGuardrails -> redis "Thread persistence" "Redis/6379, Optional TLS"
        nemoGuardrails -> otelCollector "Trace export" "gRPC/4317 or HTTP/4318, TLS"
        nemoGuardrails -> huggingFace "Model downloads (build-time)" "HTTPS/443"
    }

    views {
        systemContext nemoGuardrails "SystemContext" {
            include *
            autoLayout
        }

        container nemoGuardrails "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
