// Trainer C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/trainer.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages distributed ML training jobs"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes-native operator for managing distributed ML training jobs via TrainJob, TrainingRuntime, and ClusterTrainingRuntime CRDs" {
            controller = container "Trainer Controller Manager" "Reconciles TrainJob CRs, builds JobSet resources from runtime templates, manages progression tracking" "Go Operator (controller-runtime)" "Controller"
            webhook = container "Validating Webhook" "Validates TrainJob, TrainingRuntime, ClusterTrainingRuntime CRs on CREATE/UPDATE" "Admission Webhook" "Webhook"
            certManager = container "Certificate Manager" "Self-managed webhook certificate rotation (cert-controller)" "Go Component" "Internal"
            progressTracker = container "Progression Tracker (RHAI)" "Polls training pods for real-time metrics, updates TrainJob annotations" "Go Component" "RHOAI Feature"
            runtimePlugins = container "Runtime Framework Plugins" "JobSet, Torch, MPI, Coscheduling, Volcano plugins for building training workloads" "Go Plugins" "Plugins"
        }

        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster control plane API" "External"
        jobsetController = softwareSystem "JobSet Controller" "Manages JobSet CRs, creates underlying Jobs and Pods" "External"
        prometheus = softwareSystem "Prometheus / Monitoring Stack" "Metrics collection and alerting" "Internal ODH"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages Trainer controller via kustomize overlays" "Internal ODH"
        schedulerPlugins = softwareSystem "Scheduler Plugins (Coscheduling)" "Gang-scheduling via PodGroup CRs" "External Optional"
        volcano = softwareSystem "Volcano" "Gang-scheduling via Volcano PodGroup CRs" "External Optional"
        kueue = softwareSystem "Kueue (MultiKueue)" "Multi-cluster job management" "External Optional"

        // Relationships
        user -> trainer "Creates TrainJob CRs via kubectl / Dashboard"
        trainer -> kubernetesAPI "CRUD on CRDs, JobSets, Secrets, ConfigMaps, PodGroups" "HTTPS/443, TLS 1.2+, SA Token"
        trainer -> jobsetController "Creates JobSet CRs for training workloads" "CRD"
        controller -> webhook "Validates CRs via admission webhooks"
        controller -> runtimePlugins "Builds workloads using framework plugins"
        progressTracker -> kubernetesAPI "Lists pods, patches TrainJob annotations" "HTTPS/443"

        prometheus -> trainer "Scrapes controller metrics via PodMonitor" "HTTPS/8443, TLS (self-signed)"
        rhodsOperator -> trainer "Deploys and configures controller" "Kustomize"

        trainer -> schedulerPlugins "Creates PodGroup CRs for gang-scheduling" "CRD (optional)"
        trainer -> volcano "Creates PodGroup CRs for gang-scheduling" "CRD (optional)"
        kueue -> trainer "Manages TrainJobs via managedBy field" "CRD (optional)"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #cccccc
                color #333333
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Controller" {
                background #4a90e2
                color #ffffff
            }
            element "Webhook" {
                background #4a90e2
                color #ffffff
            }
            element "Internal" {
                background #5b9bd5
                color #ffffff
            }
            element "RHOAI Feature" {
                background #e67e22
                color #ffffff
            }
            element "Plugins" {
                background #3498db
                color #ffffff
            }
        }
    }
}
