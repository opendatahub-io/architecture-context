%% Security Network Diagram: kube-auth-proxy
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Browser"]
    end

    subgraph Ingress["INGRESS (Edge TLS Termination)"]
        Route["OpenShift Route / Gateway API<br/>443/TCP external<br/>TLS 1.2+ termination"]
    end

    subgraph Pod["POD (Sidecar Pattern)"]
        direction TB

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP<br/>Auth: Cookie/Bearer/OIDC<br/>Endpoints: /oauth2/*, /*"]
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ (configurable ciphers)<br/>Auth: Bearer (TokenReview)<br/>mTLS (x509) / OIDC JWT"]
        end

        UpstreamApp["Upstream Application<br/>configurable port<br/>HTTP/h2c (pod-internal)<br/>Trusts X-Forwarded-* headers"]
    end

    subgraph ExtAuthz["ENVOY ext_authz"]
        Envoy["Envoy Gateway<br/>GET /oauth2/auth<br/>Response: 200 OK / 401"]
    end

    subgraph AuthProviders["AUTHENTICATION PROVIDERS"]
        OIDCProv["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Client ID/Secret"]
        OSSrvr["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Client ID/SA Token"]
    end

    subgraph K8sServices["KUBERNETES API"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token<br/>APIs: TokenReview, SAR,<br/>user.openshift.io"]
    end

    subgraph OptionalSvc["OPTIONAL SERVICES"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Auth: Password optional<br/>Sentinel/Cluster supported"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>configurable port<br/>HTTP/HTTPS<br/>/metrics endpoint"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Route
    Route -->|"HTTP/4180<br/>Edge TLS terminated"| AuthProxy
    Route -->|"HTTPS/8443<br/>TLS 1.2+ passthrough"| RBACProxy

    %% Pod-internal flows
    AuthProxy -->|"HTTP/configurable<br/>No encryption (pod-internal)<br/>X-Forwarded-User/Email/Groups"| UpstreamApp
    RBACProxy -->|"HTTP or h2c/configurable<br/>No encryption (pod-internal)<br/>x-remote-user/groups"| UpstreamApp

    %% Envoy ext_authz
    Envoy -->|"HTTP/4180<br/>Pod-internal<br/>Cookie/Bearer forwarded"| AuthProxy

    %% Auth provider egress
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client ID/Secret"| OIDCProv
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OSSrvr

    %% K8s API egress
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR"| K8sAPI
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token<br/>user.openshift.io"| K8sAPI

    %% Optional
    AuthProxy -.->|"TCP/6379<br/>TLS optional<br/>Password optional"| Redis

    %% Monitoring
    Prometheus -->|"HTTP(S)/configurable<br/>/metrics"| AuthProxy
    Prometheus -->|"HTTP(S)/configurable<br/>/metrics"| RBACProxy

