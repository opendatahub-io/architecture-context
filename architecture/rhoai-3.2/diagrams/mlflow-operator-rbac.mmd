graph TD
    subgraph "Operator RBAC"
        OpSA[ServiceAccount<br/>controller-manager<br/>Namespace: operator-ns]
        OpCRB[ClusterRoleBinding<br/>manager-rolebinding]
        OpCR[ClusterRole<br/>manager-role]
        OpRB[RoleBinding<br/>manager-rolebinding<br/>NS: redhat-ods-applications/opendatahub]
        OpRole[Role<br/>manager-role<br/>NS: redhat-ods-applications/opendatahub]
    end

    subgraph "MLflow Instance RBAC"
        MLflowSA[ServiceAccount<br/>mlflow-sa<br/>Namespace: instance-ns]
        MLflowCRB[ClusterRoleBinding<br/>mlflow]
        MLflowCR[ClusterRole<br/>mlflow]
    end

    subgraph "Aggregate Roles"
        ViewRole[ClusterRole<br/>mlflow-view<br/>aggregates to: view, edit, admin]
        EditRole[ClusterRole<br/>mlflow-edit<br/>aggregates to: edit, admin]
    end

    subgraph "Operator ClusterRole Permissions"
        direction TB
        OpPerm1["mlflow.opendatahub.io<br/>mlflows, mlflows/status, mlflows/finalizers<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OpPerm2["core<br/>namespaces<br/>Verbs: get, list, watch"]
        OpPerm3["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OpPerm4["console.openshift.io<br/>consolelinks<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OpPerm5["gateway.networking.k8s.io<br/>httproutes<br/>Verbs: get, list, watch, create, update, patch, delete"]
    end

    subgraph "Operator Namespace Role Permissions"
        direction TB
        OpNSPerm1["core<br/>serviceaccounts, services, secrets, persistentvolumeclaims<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OpNSPerm2["apps<br/>deployments<br/>Verbs: get, list, watch, create, update, patch, delete"]
        OpNSPerm3["networking.k8s.io<br/>networkpolicies<br/>Verbs: get, list, watch, create, update, patch, delete"]
    end

    subgraph "MLflow ClusterRole Permissions"
        direction TB
        MLflowPerm1["core<br/>namespaces<br/>Verbs: get, list, watch<br/>Purpose: Workspaces feature"]
    end

    subgraph "Aggregate Role Permissions"
        direction TB
        ViewPerm["mlflow.opendatahub.io<br/>mlflows, mlflows/status<br/>Verbs: get, list, watch"]
        EditPerm["mlflow.opendatahub.io<br/>mlflows, mlflows/finalizers<br/>Verbs: create, delete, deletecollection, patch, update"]
    end

    %% Operator RBAC Flow
    OpSA -->|bound via| OpCRB
    OpCRB -->|grants| OpCR
    OpCR -->|cluster permissions| OpPerm1
    OpCR -->|cluster permissions| OpPerm2
    OpCR -->|cluster permissions| OpPerm3
    OpCR -->|cluster permissions| OpPerm4
    OpCR -->|cluster permissions| OpPerm5

    OpSA -->|bound via| OpRB
    OpRB -->|grants| OpRole
    OpRole -->|namespace permissions| OpNSPerm1
    OpRole -->|namespace permissions| OpNSPerm2
    OpRole -->|namespace permissions| OpNSPerm3

    %% MLflow Instance RBAC Flow
    MLflowSA -->|bound via| MLflowCRB
    MLflowCRB -->|grants| MLflowCR
    MLflowCR -->|cluster permissions| MLflowPerm1

    %% Aggregate Roles Flow
    ViewRole -->|permissions| ViewPerm
    EditRole -->|permissions| EditPerm

    %% Styling
    style OpSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style OpCR fill:#f5a623,stroke:#333,stroke-width:2px
    style OpRole fill:#f5a623,stroke:#333,stroke-width:2px
    style MLflowSA fill:#7ed321,stroke:#333,stroke-width:2px
    style MLflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ViewRole fill:#9b59b6,stroke:#333
    style EditRole fill:#9b59b6,stroke:#333

    style OpPerm1 fill:#fff9e6,stroke:#f5a623
    style OpPerm2 fill:#fff9e6,stroke:#f5a623
    style OpPerm3 fill:#fff9e6,stroke:#f5a623
    style OpPerm4 fill:#fff9e6,stroke:#f5a623
    style OpPerm5 fill:#fff9e6,stroke:#f5a623

    style OpNSPerm1 fill:#fff9e6,stroke:#f5a623
    style OpNSPerm2 fill:#fff9e6,stroke:#f5a623
    style OpNSPerm3 fill:#fff9e6,stroke:#f5a623

    style MLflowPerm1 fill:#e8f5e9,stroke:#7ed321

    style ViewPerm fill:#f3e5f5,stroke:#9b59b6
    style EditPerm fill:#f3e5f5,stroke:#9b59b6
