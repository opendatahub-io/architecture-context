graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[Data Scientist /<br/>ODH Dashboard]
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        API["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["Training Operator Pod<br/>SA: training-operator<br/>UID: 65532 (non-root)<br/>Istio: Disabled"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS<br/>Self-signed cert"]
            Metrics["Metrics Server<br/>8080/TCP HTTP<br/>No Auth"]
            Health["Health Server<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
            Controllers["Framework Controllers<br/>PyTorch, TF, XGBoost,<br/>MPI, Paddle, JAX"]
        end

        Secrets["Secret:<br/>training-operator-webhook-cert<br/>(kubernetes.io/tls)"]
    end

    subgraph UserNS["USER NAMESPACE (training jobs)"]
        direction TB

        subgraph TrainingJob["PyTorchJob Training Resources"]
            MasterPod["Master Pod<br/>pytorchjob-example-master-0<br/>SA: default"]
            MasterSvc["Service: master-0<br/>ClusterIP<br/>23456/TCP"]
            WorkerPods["Worker Pods<br/>pytorchjob-example-worker-*<br/>SA: default"]
            NetPol["NetworkPolicy<br/>(job isolation)"]
        end
    end

    subgraph ExternalSvcs["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Image Pull Secrets"]
        Prom["Prometheus<br/>Scrape 8080/TCP"]
        Volcano["Volcano Scheduler<br/>(Optional)<br/>Gang Scheduling"]
    end

    %% Flows
    Client -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| API
    API -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>ValidatingWebhook| Webhook
    Webhook -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| API
    Controllers -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch CRDs, Manage Resources| API
    API -->|Creates/Manages| MasterPod
    API -->|Creates/Manages| WorkerPods
    API -->|Creates/Manages| MasterSvc
    API -->|Creates/Manages| NetPol

    Secrets -.->|Mounted as Volume| Webhook

    WorkerPods -->|TCP/23456<br/>Framework Protocol<br/>No Encryption| MasterSvc
    WorkerPods -->|TCP/Various<br/>P2P Framework Protocol<br/>No Encryption| WorkerPods

    Prom -->|HTTP/8080<br/>Scrape /metrics| Metrics

    OperatorPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secrets| Registry
    MasterPod -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secrets| Registry
    WorkerPods -->|HTTPS/443<br/>TLS 1.2+<br/>Image Pull Secrets| Registry

    Controllers -.->|HTTPS/6443<br/>Create PodGroups<br/>Optional| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326CE5,stroke:#1a5490,stroke-width:2px,color:#fff
    classDef operator fill:#4a90e2,stroke:#2E5C8A,stroke-width:2px
    classDef training fill:#7ed321,stroke:#5a9b18,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f5a623,stroke:#d68910,stroke-width:2px

    class Client external
    class API k8s
    class Webhook,Metrics,Health,Controllers operator
    class MasterPod,WorkerPods,MasterSvc,NetPol training
    class Registry,Prom,Volcano externalservice
    class Secrets secret
