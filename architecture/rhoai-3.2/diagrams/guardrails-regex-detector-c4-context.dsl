// C4 Context Diagram - Guardrails Regex Detector
// Generated by: Claude Opus 4.6

workspace {
    model {
        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestrates LLM guardrail checks by routing text through multiple detectors" "Internal RHOAI"

        regexDetector = softwareSystem "Guardrails Regex Detector" "Lightweight regex-based text detection microservice for PII and custom pattern matching" {
            httpService = container "regex-detector" "Axum HTTP service serving REST API for regex-based text content detection" "Rust 1.84.0 / Axum 0.7.9"
            emailDetector = component "email_address_detector" "Detects email addresses using predefined regex" "Built-in Detector"
            ssnDetector = component "ssn_detector" "Detects US Social Security numbers using predefined regex" "Built-in Detector"
            ccDetector = component "credit_card_detector" "Detects credit card numbers (Visa, MC, Discover, Amex)" "Built-in Detector"
            customHandler = component "custom regex handler" "Processes arbitrary user-supplied regex patterns at request time" "Dynamic Detector"
        }

        k8sCluster = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (OCP 4.19/4.20)" "External"

        // Relationships
        orchestrator -> regexDetector "Sends text content for PII/regex detection" "HTTP/8080 plaintext"
        regexDetector -> k8sCluster "Deployed as ClusterIP service" "Kubernetes API"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
            description "System context showing Guardrails Regex Detector in the RHOAI ecosystem"
        }

        container regexDetector "Containers" {
            include *
            autoLayout
            description "Container view showing the regex detector service internals"
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Component" {
                background #85bbf0
                color #000000
            }
        }
    }
}
