graph TB
    subgraph "Feast Operator Component"
        Controller[Feast Operator Controller<br/>Go Deployment]
        MetricsService[Metrics Service<br/>8443/TCP HTTPS]
        HealthProbe[Health Probes<br/>8081/TCP HTTP]

        Controller -->|exposes| MetricsService
        Controller -->|exposes| HealthProbe
    end

    subgraph "Feature Store Services (Managed)"
        Registry[Registry Service<br/>gRPC: 6570/6571<br/>REST: 6572/6573]
        OnlineStore[Online Store<br/>6566/6567 HTTP/HTTPS]
        OfflineStore[Offline Store<br/>8815/8816 HTTP/HTTPS]
        WebUI[Web UI<br/>8888/8443 HTTP/HTTPS]

        Registry -.->|feature metadata| OnlineStore
        Registry -.->|feature metadata| OfflineStore
    end

    subgraph "Storage"
        RegistryPVC[Registry Storage PVC<br/>5Gi]
        OnlinePVC[Online Storage PVC<br/>5Gi SQLite]
        OfflinePVC[Offline Storage PVC<br/>20Gi Parquet/DuckDB]

        Registry -->|persists to| RegistryPVC
        OnlineStore -->|persists to| OnlinePVC
        OfflineStore -->|persists to| OfflinePVC
    end

    subgraph "Custom Resources"
        FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1]
    end

    subgraph "Configuration"
        ClientConfigMap["Client ConfigMaps<br/>feast-(name)-client"]
        CABundle["CA Bundle ConfigMap<br/>feast-(name)-ca-bundle"]
        NamespaceRegistry[Namespace Registry<br/>feast-configs-registry]
    end

    subgraph "Scheduled Jobs"
        CronJobs[CronJobs<br/>Feature Materialization]
    end

    User[User] -->|creates| FeatureStoreCR
    FeatureStoreCR -->|watched by| Controller

    Controller -->|creates/manages| Registry
    Controller -->|creates/manages| OnlineStore
    Controller -->|creates/manages| OfflineStore
    Controller -->|creates/manages| WebUI
    Controller -->|creates/manages| CronJobs
    Controller -->|creates| ClientConfigMap
    Controller -->|creates| CABundle
    Controller -->|updates| NamespaceRegistry

    MLApp[ML Application] -->|retrieves features| OnlineStore
    DataScientist[Data Scientist] -->|explores features| WebUI
    FeastClient[Feast Client] -->|queries metadata| Registry

    Controller -->|integrates with| K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
    Controller -.->|optional| Notebooks[Kubeflow Notebooks<br/>ConfigMap injection]
    Controller -.->|OpenShift only| Routes[OpenShift Routes<br/>External access]

    OnlineStore -.->|optional| PostgreSQL[(PostgreSQL<br/>5432/TCP)]
    OnlineStore -.->|optional| Cassandra[(Cassandra<br/>9042/TCP)]
    Registry -.->|optional| S3[S3 Storage<br/>443/TCP HTTPS]
    OfflineStore -.->|optional| Snowflake[(Snowflake<br/>443/TCP HTTPS)]

    Prometheus[Prometheus] -->|scrapes| MetricsService

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Registry fill:#7ed321,stroke:#333,stroke-width:2px
    style OnlineStore fill:#7ed321,stroke:#333,stroke-width:2px
    style OfflineStore fill:#7ed321,stroke:#333,stroke-width:2px
    style WebUI fill:#7ed321,stroke:#333,stroke-width:2px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Cassandra fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Snowflake fill:#e8e8e8,stroke:#333
