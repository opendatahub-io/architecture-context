graph TB
    subgraph "KServe Component"
        Controller[kserve-controller-manager<br/>Operator]
        Webhook[Webhook Server<br/>9443/TCP HTTPS mTLS]
        LocalModelMgr[localmodel-manager<br/>Controller]

        Controller -->|validates/mutates| Webhook
        Controller -->|manages| LocalModelMgr
    end

    subgraph "User Resources"
        User[User/CI] -->|creates| InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        User -->|creates| ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        User -->|creates| InferenceGraphCR[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Watched Resources"
        InferenceServiceCR -->|watched by| Controller
        ServingRuntimeCR -->|watched by| Controller
        InferenceGraphCR -->|watched by| Controller
        TrainedModelCR[TrainedModel CR] -->|watched by| Controller
        LocalModelCacheCR[LocalModelCache CR] -->|watched by| LocalModelMgr
    end

    subgraph "Created Resources - Serverless Mode"
        Controller -->|creates| KnativeService[Knative Service]
        Controller -->|creates| IstioVS[Istio VirtualService]
        Controller -->|creates| IstioDR[Istio DestinationRule]
        KnativeService -->|provisions| PredictorPod[Predictor Pod<br/>8080/TCP HTTP]
        KnativeService -->|provisions| TransformerPod[Transformer Pod<br/>8080/TCP HTTP]
    end

    subgraph "Created Resources - Raw Deployment Mode"
        Controller -->|creates| K8sDeployment[Kubernetes Deployment]
        Controller -->|creates| K8sService[Kubernetes Service]
        Controller -->|creates| HPA[HorizontalPodAutoscaler]
        Controller -->|creates| ScaledObject[KEDA ScaledObject]
        Controller -->|creates| HTTPRoute[Gateway API HTTPRoute]
    end

    subgraph "Runtime Components"
        PredictorPod -->|init container| StorageInit[storage-initializer<br/>downloads models]
        PredictorPod -->|sidecar| Agent[agent<br/>logging/batching]
        RouterPod[router<br/>InferenceGraph routing] -->|routes to| PredictorPod
    end

    subgraph "External Dependencies (Required)"
        Controller -->|depends on| K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        StorageInit -->|downloads from| S3[S3 Storage<br/>443/TCP HTTPS AWS IAM]
        StorageInit -->|downloads from| GCS[GCS Storage<br/>443/TCP HTTPS GCP SA]
    end

    subgraph "External Dependencies (Optional)"
        Controller -->|integrates| Knative[Knative Serving 0.44.0<br/>Serverless autoscaling]
        Controller -->|integrates| Istio[Istio 1.24+<br/>Service mesh routing]
        Controller -->|integrates| KEDA[KEDA 2.16+<br/>Event-driven autoscaling]
        Controller -->|integrates| GatewayAPI[Gateway API 1.2.1<br/>Modern ingress]
        Webhook -->|cert provisioning| CertManager[cert-manager]
    end

    subgraph "Internal ODH Integration"
        Controller -->|integrates| ModelRegistry[Model Registry<br/>REST API metadata]
        PredictorPod -->|authorized by| Authorino[Authorino<br/>Token validation]
        Controller -->|UI integration| Dashboard[ODH Dashboard<br/>REST API]
    end

    subgraph "Monitoring"
        Controller -->|exposes| Metrics[Metrics Endpoint<br/>8080/TCP HTTP]
        Metrics -->|scraped by| Prometheus[Prometheus<br/>ServiceMonitor]
    end

    subgraph "Node-Level Components"
        LocalModelNodeAgent[localmodelnode-agent<br/>DaemonSet] -->|manages cache| NodeCache[Local Model Cache]
        LocalModelMgr -->|coordinates| LocalModelNodeAgent
    end

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style InferenceGraphCR fill:#f5a623,stroke:#333
    style Knative fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style KEDA fill:#999,stroke:#333
    style GatewayAPI fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Authorino fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
