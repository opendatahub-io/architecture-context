%% Model Registry - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.2/model-registry.md

graph TB
    subgraph "Model Registry Component"
        Proxy["Model Registry Proxy<br/>(Go REST API - chi router)<br/>Port: 8080/TCP"]
        Controller["InferenceService Controller<br/>(Go Operator - controller-runtime)"]
        CSI["CSI Storage Initializer<br/>(Go CLI - KServe init container)"]
        CatalogServer["Model Catalog Server<br/>(Go REST API)<br/>Port: 8080/TCP"]
        AsyncUpload["Async Upload Job<br/>(Python K8s Job)"]
        UI["Model Registry UI<br/>(Node.js/React)<br/>Port: 8080/TCP"]
        PythonClient["Python Client SDK"]
    end

    subgraph "APIs"
        RegistryAPI["/api/model_registry/v1alpha3/*<br/>registered_models, model_versions,<br/>model_artifacts, inference_services,<br/>serving_environments, experiments"]
        CatalogAPI["/api/model_catalog/v1alpha1/*<br/>labels, models, sources"]
    end

    Proxy --> RegistryAPI
    CatalogServer --> CatalogAPI

    %% CRDs Watched
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    ClusterStorageCR["ClusterStorageContainer<br/>(serving.kserve.io/v1alpha1)"]

    InferenceServiceCR -->|"watched by"| Controller
    CSI -->|"registered via"| ClusterStorageCR

    %% Controller interactions
    Controller -->|"syncs state via REST"| Proxy

    %% Data stores
    MySQL["MySQL 8.3+<br/>Port: 3306/TCP"]
    PostgreSQL["PostgreSQL<br/>Port: 5432/TCP"]

    Proxy -->|"metadata store"| MySQL
    Proxy -.->|"alternative store"| PostgreSQL
    CatalogServer -->|"catalog store"| PostgreSQL

    %% External dependencies
    Istio["Istio Service Mesh<br/>(mTLS, VirtualService,<br/>AuthorizationPolicy)"]
    KServe["KServe<br/>(InferenceService CRDs)"]
    HuggingFace["HuggingFace API<br/>443/TCP HTTPS"]
    ModelStorage["Model Storage<br/>(S3/OCI)<br/>443/TCP HTTPS"]

    Proxy -->|"mesh routing"| Istio
    Controller -->|"watches CRDs"| KServe
    CSI -->|"downloads models"| ModelStorage
    CatalogServer -->|"fetches catalog"| HuggingFace

    %% UI interaction
    UI -->|"REST API consumer"| Proxy

    %% Async upload
    AsyncUpload -->|"registers models"| Proxy
    AsyncUpload -->|"copies models"| ModelStorage

