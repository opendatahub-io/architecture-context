/* C4 Context Diagram - ilab-on-ocp
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Triggers InstructLab fine-tuning pipeline with taxonomy and model parameters"

        ilabOnOCP = softwareSystem "InstructLab on OCP (ilab-on-ocp)" "KFP pipeline for LLM fine-tuning: synthetic data generation, distributed training, evaluation, and model upload" {
            pipelineDAG = container "Pipeline DAG (pipeline.py)" "Main InstructLab KFP pipeline definition orchestrating all stages" "Python / KFP v2"
            sdgComponent = container "SDG Component" "Synthetic Data Generation using teacher model via OpenAI-compatible API" "Python / instructlab.sdg"
            trainingComponent = container "Training Component" "Data processing and PyTorchJob launcher for distributed training" "Python / kubeflow-training"
            evalComponent = container "Evaluation Component" "MT-Bench and MMLU model evaluation with judge model" "Python / instructlab.eval"
            utilsComponent = container "Utils Component" "Prerequisites checks, model upload to OCI/Model Registry" "Python"
            runtimeImage = container "Runtime Image" "odh-ml-pipelines-runtime-generic container image" "Konflux Build"
        }

        dspa = softwareSystem "Data Science Pipelines (DSPA)" "Hosts and executes KFP pipelines, manages artifacts" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serves teacher (Mixtral) and judge (Prometheus) models via InferenceService" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages distributed PyTorchJob training workloads" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and version information" "Internal RHOAI"
        serviceMesh = softwareSystem "Red Hat OpenShift Service Mesh v2" "Traffic management for KServe model serving" "Internal RHOAI"
        serverless = softwareSystem "Red Hat OpenShift Serverless" "Serverless infrastructure for KServe" "Internal RHOAI"
        authorino = softwareSystem "Red Hat Authorino" "Authorization for RHOAI components" "Internal RHOAI"
        ociRegistry = softwareSystem "OCI Registry (quay.io)" "Stores trained ModelCar images" "External"
        gitRepo = softwareSystem "Git Repository" "Hosts taxonomy repository for SDG" "External"
        gpuOperator = softwareSystem "NVIDIA GPU Operator" "Provides GPU access for training and evaluation pods" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API for resource management" "External"

        dataScientist -> ilabOnOCP "Submits pipeline run via DSPA UI/API"
        ilabOnOCP -> dspa "Pipeline hosting and execution" "KFP REST API / HTTPS 443"
        ilabOnOCP -> kserve "SDG and evaluation model inference" "OpenAI REST API / HTTP 8080"
        ilabOnOCP -> trainingOperator "Creates distributed training jobs" "Kubernetes CRD (PyTorchJob) / HTTPS 443"
        ilabOnOCP -> modelRegistry "Registers trained model versions" "REST API / HTTPS 443"
        ilabOnOCP -> ociRegistry "Pushes trained ModelCar images" "Container Registry API / HTTPS 443"
        ilabOnOCP -> gitRepo "Clones taxonomy for SDG" "HTTPS 443 or SSH 22"
        ilabOnOCP -> gpuOperator "GPU access for training/eval" "CUDA/NCCL"
        ilabOnOCP -> k8sAPI "Manages secrets, PyTorchJobs, custom objects" "HTTPS 443"
        kserve -> serviceMesh "Traffic routing and mTLS"
        kserve -> serverless "Serverless autoscaling"
        dspa -> authorino "Authorization"

        pipelineDAG -> sdgComponent "Orchestrates SDG stage"
        pipelineDAG -> trainingComponent "Orchestrates training stage"
        pipelineDAG -> evalComponent "Orchestrates evaluation stage"
        pipelineDAG -> utilsComponent "Orchestrates prerequisites and upload"
        sdgComponent -> kserve "Teacher model completions" "POST /v1/chat/completions"
        evalComponent -> kserve "Judge model scoring" "POST /v1/chat/completions"
        trainingComponent -> trainingOperator "Creates PyTorchJob" "Kubernetes API"
        utilsComponent -> ociRegistry "Pushes ModelCar" "skopeo / HTTPS"
        utilsComponent -> modelRegistry "Registers model" "REST API"
    }

    views {
        systemContext ilabOnOCP "SystemContext" {
            include *
            autoLayout
        }

        container ilabOnOCP "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
