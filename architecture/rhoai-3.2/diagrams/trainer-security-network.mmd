graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Data Scientist]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>AuthN: Bearer Token<br/>AuthZ: RBAC"]
    end

    subgraph OpendatahubNS["OPENDATAHUB NAMESPACE (Controller)"]
        direction TB

        Controller["trainer-controller-manager<br/>Deployment (replicas: 1)<br/>SA: kubeflow-trainer-controller-manager<br/>runAsNonRoot: true<br/>allowPrivilegeEscalation: false"]

        WebhookServer["Webhook Server<br/>9443/TCP HTTPS TLS 1.2+<br/>mTLS (API server client cert)<br/>Validates: TrainJob, TrainingRuntime"]

        HealthChecks["Health Checks<br/>8081/TCP HTTP (no auth)<br/>/healthz, /readyz"]

        MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS TLS 1.2+<br/>Bearer Token Auth<br/>/metrics"]

        Controller --> WebhookServer
        Controller --> HealthChecks
        Controller --> MetricsEndpoint
    end

    subgraph JobSetDependency["JOBSET CONTROLLER (External)"]
        JobSetController["JobSet Controller<br/>jobset.x-k8s.io/v1alpha2<br/>Creates: Jobs, Pods"]
    end

    subgraph UserNamespaces["USER NAMESPACES (Training Workloads)"]
        direction TB

        TrainingPods["Training Pods<br/>SA: {trainjob-name}-sa<br/>Image: quay.io/modh/training:py312-cuda128-torch280"]

        PodNetwork["Pod-to-Pod Communication<br/>29500/TCP (PyTorch)<br/>Protocol: TCP<br/>Encryption: None (NCCL)<br/>Auth: None (trusted network)"]

        TrainingPods --> PodNetwork
        PodNetwork --> TrainingPods
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM/S3 Credentials<br/>Purpose: Datasets/Checkpoints"]

        Registry["Container Registry<br/>quay.io/modh/training<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secrets"]

        Volcano["Volcano Scheduler (Optional)<br/>scheduling.volcano.sh<br/>Via K8s API 6443/TCP"]
    end

    subgraph RHOAIIntegration["RHOAI INTEGRATION"]
        Dashboard["RHOAI Dashboard<br/>Creates TrainJob CRs<br/>Via K8s API"]

        Prometheus["Prometheus<br/>8443/TCP HTTPS TLS 1.2+<br/>Bearer Token Auth<br/>Scrapes controller metrics"]

        ModelRegistry["Model Registry (Optional)<br/>Store trained models<br/>API/ServiceAccount Auth"]
    end

    %% User to K8s API
    User -->|HTTPS/6443<br/>Bearer Token| K8sAPI

    %% Dashboard to K8s API
    Dashboard -->|HTTPS/6443<br/>User Credentials| K8sAPI

    %% K8s API to Webhook
    K8sAPI -->|HTTPS/9443<br/>mTLS| WebhookServer

    %% Controller to K8s API
    Controller -->|HTTPS/6443<br/>ServiceAccount Token<br/>RBAC: kubeflow-trainer-controller-manager| K8sAPI

    %% Controller creates resources
    Controller -.->|Creates JobSet| JobSetController

    %% JobSet creates Pods
    JobSetController -->|Creates Jobs/Pods<br/>Via K8s API| TrainingPods

    %% Training Pod external access
    TrainingPods -->|HTTPS/443<br/>S3 Credentials| S3
    TrainingPods -->|HTTPS/443<br/>Pull Secrets| Registry
    TrainingPods -.->|Store models| ModelRegistry

    %% Controller optional integrations
    Controller -.->|HTTPS/6443<br/>Create PodGroups| Volcano

    %% Prometheus scraping
    Prometheus -->|HTTPS/8443<br/>Bearer Token| MetricsEndpoint

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef rhoai fill:#e1bee7,stroke:#8e24aa,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookServer,HealthChecks,MetricsEndpoint controller
    class JobSetController,Volcano externalservice
    class TrainingPods,PodNetwork workload
    class S3,Registry externalservice
    class Dashboard,Prometheus,ModelRegistry rhoai
