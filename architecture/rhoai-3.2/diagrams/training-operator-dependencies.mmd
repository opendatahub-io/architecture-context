graph LR
    TrainingOp[Kubeflow Training Operator<br/>v1.9.0]

    %% External Dependencies (Required)
    TrainingOp -->|orchestration| K8s[Kubernetes 1.27+]
    TrainingOp -->|controller framework| ControllerRuntime[controller-runtime v0.19.1]

    %% External Dependencies (Optional)
    TrainingOp -.->|gang scheduling| Volcano[Volcano v1.9.0]
    TrainingOp -.->|gang scheduling| SchedulerPlugins[scheduler-plugins v0.28.9]
    TrainingOp -.->|cert management| CertManager[cert-manager]

    %% Internal ODH Dependencies
    TrainingOp -->|metrics| PrometheusInt[Prometheus<br/>via PodMonitor]
    Dashboard[ODH Dashboard] -->|UI display| TrainingOp

    %% External Services
    TrainingOp -->|API calls| K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
    TrainingOp -->|image pull| Registry[Container Registry<br/>443/TCP HTTPS]

    %% Framework Support
    subgraph "Supported ML Frameworks"
        PyTorch[PyTorch<br/>PyTorchJob CRD]
        TensorFlow[TensorFlow<br/>TFJob CRD]
        XGBoost[XGBoost<br/>XGBoostJob CRD]
        MPI[MPI<br/>MPIJob CRD]
        Paddle[PaddlePaddle<br/>PaddleJob CRD]
        JAX[JAX<br/>JAXJob CRD]
    end

    TrainingOp -->|manages| PyTorch
    TrainingOp -->|manages| TensorFlow
    TrainingOp -->|manages| XGBoost
    TrainingOp -->|manages| MPI
    TrainingOp -->|manages| Paddle
    TrainingOp -->|manages| JAX

    %% Resources Created
    subgraph "Managed Resources"
        Pods[Pods<br/>Master + Workers]
        Services[Services<br/>ClusterIP/Headless]
        NetPol[NetworkPolicies<br/>Job Isolation]
        PodGroup[PodGroups<br/>Gang Scheduling]
    end

    TrainingOp -->|creates| Pods
    TrainingOp -->|creates| Services
    TrainingOp -->|creates| NetPol
    TrainingOp -.->|creates<br/>if enabled| PodGroup

