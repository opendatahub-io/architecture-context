graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User/Client]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Gateway - HTTPRoute<br/>443/TCP → 8443/TCP<br/>HTTPS TLS 1.3 Passthrough"]
    end

    subgraph ServiceLayer["SERVICE LAYER (redhat-ods-applications / opendatahub)"]
        direction TB

        subgraph MLflowService["MLflow Service"]
            Service["mlflow Service<br/>ClusterIP<br/>8443/TCP → 8443/TCP<br/>TLS: mlflow-tls (service-ca)"]
        end

        subgraph MLflowPod["MLflow Pod"]
            direction TB
            Pod["MLflow Server<br/>uvicorn HTTPS/8443<br/>SA: mlflow-sa<br/>Auth: k8s-auth (self_subject_access_review)"]
            PVC["PVC<br/>SQLite Storage<br/>ReadWriteOnce"]
            Pod -.->|mounts| PVC
        end

        Service -->|routes to| Pod
    end

    subgraph ControlPlane["CONTROL PLANE (Operator)"]
        direction TB
        Operator["mlflow-operator-manager<br/>SA: controller-manager<br/>Metrics: HTTPS/8443"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
        PostgreSQL["PostgreSQL (optional)<br/>5432/TCP TLS 1.2+<br/>DB Credentials"]
        S3["S3 Storage (optional)<br/>443/TCP HTTPS TLS 1.2+<br/>AWS Signature v4"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        ServiceCA["service-ca-operator<br/>OpenShift<br/>TLS Cert Provisioning"]
    end

    %% Request Flows
    Client -->|"HTTPS/443 TLS1.3<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443 TLS1.3<br/>Passthrough Bearer Token"| Service

    %% MLflow to External
    Pod -->|"HTTPS/6443 TLS1.2+<br/>Client Bearer Token<br/>self_subject_access_review"| K8sAPI
    Pod -->|"HTTPS/6443 TLS1.2+<br/>SA Token mlflow-sa<br/>List Namespaces"| K8sAPI
    Pod -.->|"PostgreSQL/5432<br/>TLS1.2+ optional<br/>DB Credentials"| PostgreSQL
    Pod -.->|"HTTPS/443 TLS1.2+<br/>AWS Signature v4"| S3

    %% Operator Flows
    Operator -->|"HTTPS/6443 TLS1.2+<br/>SA Token<br/>CRD/Resource Mgmt"| K8sAPI
    Operator -->|"Annotate Service"| ServiceCA
    ServiceCA -->|"Provision mlflow-tls Secret"| MLflowService
    Prometheus -->|"HTTPS/8443 TLS1.2+<br/>SA Token"| Operator

    %% NetworkPolicy
    Note1[NetworkPolicy: mlflow<br/>Ingress: 8443/TCP from all<br/>Egress: all unrestricted]
    Note1 -.->|applies to| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicelayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef note fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class Gateway ingress
    class Service,Pod,PVC servicelayer
    class Operator controlplane
    class K8sAPI,PostgreSQL,S3,Prometheus,ServiceCA externalservice
    class Note1 note
