// MLflow C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/mlflow.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Tracks experiments, manages models, and browses ML artifacts"
        mlEngineer = person "ML Engineer" "Deploys models and monitors LLM traces"

        mlflow = softwareSystem "MLflow" "Open-source ML lifecycle platform providing experiment tracking, model registry, tracing, and artifact management with Kubernetes-native RBAC" {
            trackingServer = container "MLflow Tracking Server" "Core server providing REST/GraphQL APIs for experiment tracking, model registry, and artifact management" "Flask/FastAPI, Python 3.11, Gunicorn/Uvicorn"
            ui = container "MLflow UI" "Web-based UI for browsing experiments, runs, models, traces, and prompts" "React/TypeScript"
            workspaceProvider = container "Kubernetes Workspace Provider" "Maps Kubernetes namespaces to MLflow workspaces with watch-based caching" "Python Plugin"
            authPlugin = container "Kubernetes Authorization Plugin" "Enforces Kubernetes RBAC (SelfSubjectAccessReview/SubjectAccessReview) on all MLflow API requests" "Python Middleware"
            otlpIngestion = container "OTLP Trace Ingestion" "Accepts OpenTelemetry Protocol traces via protobuf for LLM observability" "FastAPI Router"
            artifactProxy = container "Artifact Proxy" "Proxies artifact storage operations to configured backends" "Flask Handler"
            trackingStore = container "SQLAlchemy Tracking Store" "Persists experiment/run metadata to SQL databases" "SQLAlchemy/Alembic"
        }

        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Authentication proxy forwarding user identity headers" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for namespace management and access reviews" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for tracking and model registry persistence" "External"
        s3 = softwareSystem "S3-compatible Storage" "Object storage for ML artifacts and model files" "External"
        minio = softwareSystem "MinIO" "S3-compatible object storage (alternative backend)" "External"
        otelCollectors = softwareSystem "OpenTelemetry Collectors" "Instrumented applications sending OTLP traces" "External"

        // User interactions
        dataScientist -> mlflow "Tracks experiments, logs artifacts, registers models" "REST API/GraphQL via HTTPS/8443"
        mlEngineer -> mlflow "Manages models, reviews traces" "REST API/UI via HTTPS/8443"

        // External proxy
        dataScientist -> kubeRbacProxy "Authenticates via Bearer Token" "HTTPS/8443"
        kubeRbacProxy -> mlflow "Forwards authenticated requests" "HTTP/5000"

        // Internal container relationships
        trackingServer -> authPlugin "Delegates authorization"
        trackingServer -> workspaceProvider "Resolves workspace from namespace"
        trackingServer -> trackingStore "Persists experiment/run data"
        trackingServer -> artifactProxy "Proxies artifact operations"
        trackingServer -> ui "Serves React UI"
        trackingServer -> otlpIngestion "Routes OTLP requests"

        // External dependencies
        authPlugin -> k8sAPI "SelfSubjectAccessReview / SubjectAccessReview" "HTTPS/443"
        workspaceProvider -> k8sAPI "Namespace list/watch" "HTTPS/443"
        trackingStore -> postgresql "SQL queries for tracking store" "TCP/5432"
        artifactProxy -> s3 "Store/retrieve artifacts" "HTTPS/443"
        artifactProxy -> minio "Store/retrieve artifacts (alt)" "HTTP(S)/9000"
        otelCollectors -> otlpIngestion "Send OTLP traces" "HTTP/5000 protobuf"
    }

    views {
        systemContext mlflow "SystemContext" {
            include *
            autoLayout
        }

        container mlflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
