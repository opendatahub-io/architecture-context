// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/model-registry.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates, registers, and manages ML models"
        mlEngineer = person "ML Engineer" "Deploys and monitors ML models in production"

        modelRegistry = softwareSystem "Model Registry" "Central repository for recording and retrieving metadata associated with ML model developer and data scientist workflows" {
            proxy = container "Model Registry Proxy" "Primary REST API for model metadata CRUD operations (v1alpha3)" "Go REST API (chi router), Port 8080/TCP" "Component"
            controller = container "InferenceService Controller" "Watches KServe InferenceService CRs and syncs state with registry" "Go Operator (controller-runtime)" "Component"
            csiInitializer = container "CSI Storage Initializer" "Downloads model artifacts using model-registry:// URI scheme" "Go CLI (KServe init container)" "Component"
            catalogServer = container "Model Catalog Server" "Serves catalog of ML models from external sources" "Go REST API, Port 8080/TCP" "Component"
            asyncUpload = container "Async Upload Job" "Copies models between storage backends and registers in registry" "Python K8s Job" "Component"
            ui = container "Model Registry UI" "Web UI for browsing and managing model registry entries" "Node.js/React, Port 8080/TCP" "Component"
            pythonClient = container "Python Client SDK" "Python client library for Model Registry API" "Python" "Component"
        }

        // External Dependencies
        mysql = softwareSystem "MySQL 8.3+" "Primary metadata store for model registry" "Database"
        postgresql = softwareSystem "PostgreSQL" "Alternative metadata store / catalog database" "Database"
        kserve = softwareSystem "KServe" "ML model serving platform providing InferenceService CRDs" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS, traffic routing via kubeflow-gateway" "External"
        huggingface = softwareSystem "HuggingFace" "External model catalog source provider" "External"
        modelStorage = softwareSystem "Model Storage (S3/OCI)" "Model artifact storage" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "External"

        // Internal ODH Components
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform" "Internal ODH"

        // Relationships - Users
        dataScientist -> modelRegistry "Registers models, creates versions, browses catalog"
        mlEngineer -> modelRegistry "Manages inference services, monitors deployments"
        dataScientist -> ui "Browses and manages model registry via UI"

        // Container-level relationships
        proxy -> mysql "Stores/retrieves model metadata" "MySQL/3306, Configurable TLS 1.2+"
        proxy -> postgresql "Alternative metadata storage" "PostgreSQL/5432"
        controller -> proxy "Syncs InferenceService state" "HTTP/8080"
        controller -> k8sApi "Watches/patches InferenceService CRs" "HTTPS/443"
        csiInitializer -> proxy "Retrieves model artifact URI" "HTTP/8080"
        csiInitializer -> modelStorage "Downloads model artifacts" "HTTPS/443"
        catalogServer -> postgresql "Stores catalog entries" "PostgreSQL/5432"
        catalogServer -> huggingface "Fetches model catalog data" "HTTPS/443"
        asyncUpload -> proxy "Registers models in registry" "HTTP/8080"
        asyncUpload -> modelStorage "Copies model artifacts" "HTTPS/443"
        ui -> proxy "REST API consumer" "HTTP/8080, Istio mTLS"
        pythonClient -> proxy "REST API client" "HTTP/8080"

        // System-level relationships
        modelRegistry -> mysql "Stores metadata" "MySQL/3306, TLS 1.2+"
        modelRegistry -> postgresql "Stores catalog/alternative metadata" "PostgreSQL/5432"
        modelRegistry -> kserve "Watches InferenceService CRs, registers ClusterStorageContainer" "K8s API"
        modelRegistry -> istio "Traffic routing via kubeflow-gateway, mTLS" "VirtualService/DestinationRule"
        modelRegistry -> huggingface "Fetches external model catalog" "HTTPS/443"
        modelRegistry -> modelStorage "Downloads/uploads model artifacts" "HTTPS/443"
        modelRegistry -> k8sApi "Controller watches and patches resources" "HTTPS/443"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS/8443"
        dashboard -> modelRegistry "Manages models via UI" "HTTP/8080"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Database" {
                background #438dd5
                color #ffffff
                shape Cylinder
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
