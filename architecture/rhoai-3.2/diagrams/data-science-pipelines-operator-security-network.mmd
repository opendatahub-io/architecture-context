graph TB
    subgraph External["EXTERNAL Untrusted"]
        Client[Data Scientist or<br/>ODH Dashboard]
    end

    subgraph Ingress["INGRESS DMZ"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>TLS 1.3 Reencrypt"]
        Proxy["kube-rbac-proxy<br/>8443/TCP → 8888/TCP<br/>SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER Namespace dspa-namespace"]
        direction TB

        subgraph APIComponents["API and Control Plane"]
            API["DS Pipelines API Server<br/>SA - ds-pipeline-name<br/>8888/TCP HTTP/HTTPS TLS 1.3 opt<br/>8887/TCP gRPC TLS 1.3 opt<br/>Auth - Bearer Token"]
            Persist["Persistence Agent<br/>SA - ds-pipeline-name"]
            Scheduled["Scheduled Workflow Controller<br/>SA - ds-pipeline-name"]
        end

        subgraph MLMDComponents["ML Metadata"]
            MLMDgRPC["MLMD gRPC<br/>SA - ds-pipeline-name<br/>8080/TCP gRPC<br/>mTLS opt"]
            Envoy["MLMD Envoy Proxy<br/>SA - ds-pipeline-name<br/>9090/TCP gRPC/HTTP2<br/>8443/TCP HTTPS<br/>mTLS"]
        end

        subgraph Storage["Storage Layer"]
            MariaDB["MariaDB<br/>SA - mariadb-name<br/>3306/TCP MySQL<br/>TLS 1.2+ opt<br/>MySQL Auth<br/>NetworkPolicy - Restricted"]
            Minio["Minio<br/>SA - minio-name<br/>9000/TCP HTTP/S3<br/>80/TCP HTTP<br/>No TLS<br/>AWS SigV4"]
        end

        subgraph Execution["Workflow Execution"]
            ArgoController["Argo Workflow Controller<br/>SA - ds-pipeline-argo-name<br/>Metrics - 9090/TCP HTTP"]
            WfPod["Workflow Pod<br/>SA - pipeline-runner-name"]
        end
    end

    subgraph OperatorLayer["OPERATOR LAYER Namespace redhat-ods-applications"]
        Operator["Data Science Pipelines Operator<br/>SA - controller-manager<br/>8080/TCP Metrics HTTP<br/>8081/TCP Health HTTP"]
    end

    subgraph K8s["KUBERNETES PLATFORM"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Tokens"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExternalDB["External MySQL or MariaDB<br/>3306/TCP<br/>TLS 1.2+<br/>MySQL Auth"]
        ExternalS3["External S3 ODF or AWS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM or SigV4"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Route
    Route -->|HTTPS/8443<br/>TLS 1.3<br/>Bearer Token| Proxy
    Proxy -->|SubjectAccessReview| K8sAPI
    Proxy -->|HTTP or HTTPS/8888<br/>TLS 1.3 opt<br/>Bearer Token| API

    %% API to Storage
    API -->|MySQL/3306<br/>TLS 1.2+ opt<br/>MySQL password| MariaDB
    API -->|HTTP/9000<br/>S3 API<br/>AWS SigV4| Minio
    API -->|gRPC/8080<br/>mTLS opt| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>TLS 1.2+ opt| MariaDB

    %% Envoy Proxy
    Envoy -->|gRPC/8080<br/>mTLS| MLMDgRPC

    %% API to K8s
    API -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Persist -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Persist -->|MySQL/3306<br/>TLS 1.2+ opt<br/>MySQL password| MariaDB
    Scheduled -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Argo Workflows
    ArgoController -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    K8sAPI -->|Creates| WfPod
    WfPod -->|HTTP/9000<br/>S3 API<br/>AWS SigV4| Minio
    WfPod -->|gRPC/8080<br/>mTLS opt| MLMDgRPC
    WfPod -->|gRPC/8887<br/>TLS 1.3 opt<br/>Bearer Token| API

    %% Operator
    Operator -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watches: DSPA CRs| K8sAPI

    %% External Services opt
    API -.->|MySQL/3306<br/>TLS 1.2+<br/>MySQL Auth| ExternalDB
    API -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/SigV4| ExternalS3
    WfPod -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/SigV4| ExternalS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Route,Proxy ingress
    class API,Persist,Scheduled,MLMDgRPC,Envoy,ArgoController,WfPod app
    class MariaDB,Minio storage
    class Operator operator
    class K8sAPI platform
    class ExternalDB,ExternalS3 externalservice
