%% Data Science Pipelines Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / ODH Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        APIRoute["ds-pipeline-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>service-ca cert"]
        MLMDRoute["ds-pipeline-md-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>service-ca cert"]
    end

    subgraph AuthLayer["AUTHENTICATION (kube-rbac-proxy)"]
        RBAC1["kube-rbac-proxy<br/>(API Server sidecar)<br/>8443/TCP → 8888/TCP<br/>SAR: dspa/api"]
        RBAC2["kube-rbac-proxy<br/>(MLMD Envoy sidecar)<br/>8443/TCP → 9090/TCP<br/>SAR: dspa/api"]
    end

    subgraph DSPNamespace["DSP COMPONENTS (NetworkPolicy-protected)"]
        direction TB

        subgraph APIGroup["API Layer"]
            APIServer["DS Pipeline API Server<br/>8888/TCP HTTP, 8887/TCP gRPC<br/>TLS (PodToPodTLS)<br/>SA: ds-pipeline-{name}"]
        end

        subgraph AgentGroup["Agents & Controllers"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}"]
            SWF["Scheduled Workflow<br/>SA: ds-pipeline-scheduledworkflow-{name}"]
            WFC["Workflow Controller<br/>Argo Workflows<br/>Metrics: 9090/TCP"]
        end

        subgraph MLMDGroup["ML Metadata"]
            Envoy["MLMD Envoy Proxy<br/>9090/TCP gRPC<br/>TLS (service-ca)"]
            MLMD["MLMD gRPC Server<br/>8080/TCP gRPC<br/>TLS (PodToPodTLS)"]
        end

        subgraph DataGroup["Data Stores"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>TLS (PodToPodTLS)<br/>NP: mariadb-{name}"]
            Minio["Minio<br/>9000/TCP S3<br/>SA credentials"]
        end

        PipelinePod["Pipeline Pod<br/>(v2_component)"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        DSPO["DSPO Controller Manager<br/>8080/TCP metrics (plaintext)<br/>8081/TCP health (plaintext)<br/>SA: dspo-controller-manager"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token Auth"]
        ServiceCA["OpenShift service-ca<br/>Auto TLS cert generation"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        ExtDB["External Database<br/>3306/TCP MySQL<br/>TLS (configurable)"]
        ExtS3["External S3 Storage<br/>443/TCP HTTPS<br/>AWS S3 credentials"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>Bearer Token"| APIRoute
    User -->|"HTTPS/443<br/>Bearer Token"| MLMDRoute

    %% Ingress to Auth
    APIRoute -->|"HTTPS/8443<br/>TLS reencrypt"| RBAC1
    MLMDRoute -->|"HTTPS/8443<br/>TLS reencrypt"| RBAC2

    %% Auth to K8s API (SAR)
    RBAC1 -.->|"SAR check<br/>443/TCP TLS"| K8sAPI
    RBAC2 -.->|"SAR check<br/>443/TCP TLS"| K8sAPI

    %% Auth to components
    RBAC1 -->|"HTTP/8888<br/>TLS (PodToPodTLS)"| APIServer
    RBAC2 -->|"gRPC/9090<br/>TLS (service-ca)"| Envoy

    %% Internal DSP flows
    PA -->|"HTTP/8888<br/>TLS"| APIServer
    APIServer -->|"MySQL/3306<br/>TLS, DB creds"| MariaDB
    APIServer -->|"S3 API<br/>S3 creds"| Minio
    Envoy -->|"gRPC/8080<br/>TLS"| MLMD
    MLMD -->|"MySQL/3306<br/>TLS, DB creds"| MariaDB
    PipelinePod -->|"gRPC/8080<br/>TLS, NP-restricted"| MLMD

    %% Operator flows
    DSPO -->|"HTTPS/443<br/>SA Token"| K8sAPI
    DSPO -->|"manages"| DSPNamespace
    PA -->|"HTTPS/443<br/>Watch Workflows"| K8sAPI
    APIServer -->|"HTTPS/443<br/>Create Workflows"| K8sAPI

    %% Platform
    ServiceCA -.->|"provisions certs"| DSPNamespace
    Prometheus -->|"HTTP/8080<br/>plaintext"| DSPO
    Prometheus -->|"HTTP/9090<br/>plaintext"| WFC

    %% External services (optional)
    MariaDB -.->|"or"| ExtDB
    Minio -.->|"or"| ExtS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef dsp fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class APIRoute,MLMDRoute ingress
    class RBAC1,RBAC2 auth
    class APIServer,PA,SWF,WFC,Envoy,MLMD,MariaDB,Minio,PipelinePod dsp
    class DSPO operator
    class K8sAPI,ServiceCA,Prometheus platform
    class ExtDB,ExtS3 externalsvc
