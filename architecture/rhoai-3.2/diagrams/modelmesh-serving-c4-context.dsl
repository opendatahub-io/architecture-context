// ModelMesh Serving - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates ServingRuntimes and deploys ML models for inference"

        modelmeshServing = softwareSystem "ModelMesh Serving" "Kubernetes operator managing multi-model serving runtimes using ModelMesh distributed model serving framework" {
            controller = container "modelmesh-controller" "Main operator managing ServingRuntime, Predictor, and Service reconciliation" "Go Operator (controller-runtime)"
            srReconciler = container "ServingRuntime Reconciler" "Watches ServingRuntime/ClusterServingRuntime CRs, creates runtime Deployments" "Go Controller"
            predictorReconciler = container "Predictor Reconciler" "Watches Predictor/InferenceService CRs, manages VModel lifecycle" "Go Controller"
            serviceReconciler = container "Service Reconciler" "Creates/manages inference Services and ServiceMonitor resources" "Go Controller"
            webhook = container "ServingRuntime Webhook" "Validates ServingRuntime and ClusterServingRuntime CR specs" "ValidatingWebhookConfiguration"
            modelmeshContainer = container "ModelMesh Container" "Java-based model mesh for distributed model routing, caching, and load balancing" "Java Sidecar"
            oauthProxy = container "oauth-proxy" "OpenShift OAuth authentication proxy for HTTPS inference endpoint" "Sidecar"
            restProxy = container "rest-proxy" "Translates REST/HTTP inference requests to gRPC for ModelMesh" "Sidecar"
            puller = container "Storage Helper (puller)" "Downloads models from storage backends (S3, PVC) to local cache" "Sidecar"
        }

        etcd = softwareSystem "etcd" "Distributed coordination store for model placement and routing" "External"
        kubernetes = softwareSystem "Kubernetes API Server" "Container orchestration platform" "External"
        openshift = softwareSystem "OpenShift" "Platform for OAuth authentication and serving certificates" "External"
        objectStorage = softwareSystem "Object Storage (S3/MinIO)" "Model artifact storage backend" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        kserve = softwareSystem "KServe" "CRD API types (ServingRuntime, InferenceService)" "External"

        // User interactions
        user -> modelmeshServing "Creates ServingRuntime, Predictor, InferenceService CRs via kubectl/dashboard"
        user -> modelmeshServing "Sends inference requests" "gRPC/8033 or HTTPS/8443"

        // Internal relationships
        controller -> srReconciler "Delegates ServingRuntime reconciliation"
        controller -> predictorReconciler "Delegates Predictor reconciliation"
        controller -> serviceReconciler "Delegates Service reconciliation"
        srReconciler -> modelmeshContainer "Injects as sidecar in runtime Deployments"
        predictorReconciler -> modelmeshContainer "VModel register/unregister" "gRPC/8033"
        oauthProxy -> restProxy "Forwards authenticated requests" "HTTP/8008"
        restProxy -> modelmeshContainer "Translates REST to gRPC" "gRPC/8033"
        modelmeshContainer -> puller "Model loading requests" "gRPC/8086"

        // External dependencies
        modelmeshServing -> etcd "Model placement coordination, event streaming" "gRPC/2379"
        modelmeshServing -> kubernetes "Watch/manage CRDs, Deployments, Services, Secrets" "HTTPS/443"
        modelmeshServing -> objectStorage "Download model artifacts" "HTTPS/443"
        oauthProxy -> openshift "Validate OAuth tokens" "HTTPS"
        prometheus -> modelmeshServing "Scrape metrics" "HTTP/2112, HTTP/8080"
        modelmeshServing -> kserve "Uses CRD API types" "API dependency"
    }

    views {
        systemContext modelmeshServing "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
