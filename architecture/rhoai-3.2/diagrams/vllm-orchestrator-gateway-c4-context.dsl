/*
 * C4 Context Diagram: vllm-orchestrator-gateway
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/vllm-orchestrator-gateway.md
 */

workspace {
    model {
        client = person "API Consumer" "Client workloads that need guardrailed LLM chat completions"

        gateway = softwareSystem "vLLM Orchestrator Gateway" "Rust HTTP gateway providing OpenAI-compatible chat completion endpoints with configurable guardrail detector pipelines" {
            configLoader = container "Configuration Loader" "Reads and validates YAML gateway configuration (orchestrator, detectors, routes)" "Rust Module (config.rs)"
            apiModels = container "API Models" "Defines request/response data structures for orchestrator communication" "Rust Module (api.rs)"
            detectorRouter = container "Detector Router" "Maps route names to detector configurations and injects them into orchestrator requests" "Rust/Axum Handler"
            streamHandler = container "Streaming Handler" "Handles SSE streaming chat completions with detection-based fallback" "Rust/Axum Handler"
            tlsBuilder = container "TLS Client Builder" "Builds mTLS-capable HTTP client for orchestrator communication" "Rust Function"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Backend service that performs content detection and LLM chat completions" "Internal RHOAI"
        detectors = softwareSystem "Content Detectors" "Content detection services (e.g., regex-detector for PII) registered with the orchestrator" "Internal RHOAI"
        vllm = softwareSystem "vLLM / LLM Backend" "LLM serving engine for chat completion inference" "Internal RHOAI"
        certManager = softwareSystem "cert-manager / service-ca operator" "Provides TLS certificates for mTLS communication" "External"

        # System Context relationships
        client -> gateway "POST /{route_name}/v1/chat/completions" "HTTP/8090, plaintext, Authorization pass-through"
        gateway -> orchestrator "POST /api/v2/chat/completions-detection" "HTTP or HTTPS/8085, Optional mTLS"
        orchestrator -> detectors "Invokes registered detectors" "Internal"
        orchestrator -> vllm "Chat completion inference" "Internal"
        certManager -> gateway "Provisions TLS certificates" "Kubernetes Secrets"

        # Container relationships
        client -> detectorRouter "POST /{route_name}/v1/chat/completions" "HTTP/8090"
        configLoader -> detectorRouter "Provides route-to-detector mappings"
        configLoader -> apiModels "Defines request/response schemas"
        detectorRouter -> streamHandler "Delegates streaming requests"
        detectorRouter -> tlsBuilder "Gets HTTP client"
        streamHandler -> tlsBuilder "Gets HTTP client"
        tlsBuilder -> orchestrator "HTTP/HTTPS requests with optional mTLS" "8085/TCP"
    }

    views {
        systemContext gateway "SystemContext" {
            include *
            autoLayout
        }

        container gateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
