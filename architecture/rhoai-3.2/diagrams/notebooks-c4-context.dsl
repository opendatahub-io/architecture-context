// C4 Context Diagram - Notebooks (Workbench Images)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and uses notebook workbenches for ML development"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images for Jupyter, Code Server, and RStudio workbench environments plus Elyra pipeline runtime images" {
            baseImages = container "Base Images" "Foundation images with OS packages, Python runtime, and GPU drivers (CPU, CUDA 12.8, ROCm 6.3)" "Container Images"
            jupyterWorkbenches = container "Jupyter Workbenches" "JupyterLab 4.4 workbench images: Minimal, Data Science, PyTorch, TensorFlow, TrustyAI, LLM Compressor" "Container Images"
            codeServerWorkbench = container "Code Server Workbench" "VS Code-based web IDE (code-server 4.104) with data science libraries" "Container Image"
            rstudioWorkbench = container "RStudio Workbench" "RStudio Server 2025.09 with R 4.5, built on-cluster via BuildConfig" "Container Image"
            runtimeImages = container "Pipeline Runtime Images" "Elyra pipeline execution runtime images (Minimal, Data Science, PyTorch, TensorFlow)" "Container Images"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream and BuildConfig definitions (19 ImageStreams, 2 BuildConfigs)" "YAML / Kustomize"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys ImageStream manifests via kustomize overlays" "Internal RHOAI"
        notebookController = softwareSystem "odh-notebook-controller" "Manages workbench pod lifecycle, injects auth sidecars" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Web UI for managing workbenches and ML workflows" "Internal RHOAI"
        elyra = softwareSystem "Elyra" "Pipeline execution framework using runtime images" "Internal RHOAI"
        konflux = softwareSystem "Konflux" "CI/CD build system for container images via Tekton pipelines" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Red Hat container registry for signed RHOAI images" "External"
        quayIO = softwareSystem "quay.io/modh" "Community container registry for older workbench images" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Kubernetes platform with ImageStream and BuildConfig support" "External"

        // Relationships
        user -> rhoaiDashboard "Selects workbench image" "HTTPS/443"
        rhoaiDashboard -> notebooks "Reads ImageStream annotations to display available images" "HTTPS/6443"
        rhodsOperator -> notebooks "Deploys ImageStream manifests from overlays/additional" "Kustomize apply"
        notebookController -> notebooks "Resolves image references for workbench pod creation" "HTTPS/6443"
        elyra -> notebooks "Uses runtime images for pipeline execution"
        konflux -> notebooks "Builds container images, nudges params-latest.env" "Tekton pipelines"
        notebooks -> registryRedHat "Sources N-1 version images" "HTTPS/443"
        notebooks -> quayIO "Sources N-2 through N-6 version images" "HTTPS/443"
        notebooks -> ocp "Deploys ImageStreams and BuildConfigs" "HTTPS/6443"

        // Internal container relationships
        baseImages -> jupyterWorkbenches "Foundation for"
        baseImages -> codeServerWorkbench "Foundation for"
        baseImages -> rstudioWorkbench "Foundation for"
        baseImages -> runtimeImages "Foundation for"
        kustomizeManifests -> jupyterWorkbenches "References"
        kustomizeManifests -> codeServerWorkbench "References"
        kustomizeManifests -> rstudioWorkbench "References"
        kustomizeManifests -> runtimeImages "References"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
