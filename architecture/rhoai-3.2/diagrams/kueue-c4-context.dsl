/*
 * Kueue C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.2/kueue.md
 */

workspace {
    model {
        user = person "Data Scientist" "Submits ML training jobs and batch workloads"
        platformAdmin = person "Platform Admin" "Configures quotas, queues, and resource policies"

        kueue = softwareSystem "Kueue" "Kubernetes-native job queueing system managing workload admission based on quota and fair-sharing policies" {
            controllerManager = container "kueue-controller-manager" "Main controller managing all Kueue CRDs, scheduling, webhooks" "Go Operator (controller-runtime)" {
                clusterQueueCtrl = component "ClusterQueue Controller" "Manages ClusterQueue lifecycle, quota tracking" "Controller"
                localQueueCtrl = component "LocalQueue Controller" "Manages namespace-scoped LocalQueues" "Controller"
                workloadCtrl = component "Workload Controller" "Manages Workload CRs and admission state" "Controller"
                resourceFlavorCtrl = component "ResourceFlavor Controller" "Manages heterogeneous resource types" "Controller"
                admissionCheckCtrl = component "AdmissionCheck Controller" "Manages external admission checks" "Controller"
                cohortCtrl = component "Cohort Controller" "Manages hierarchical cohort resource sharing" "Controller"
                provisioningACC = component "Provisioning ACC" "Creates ProvisioningRequest CRs for auto-scaler" "Controller"
                tasCtrl = component "TAS Controller" "Topology-Aware Scheduling for pod placement" "Controller"
                scheduler = component "Scheduler" "Admission scheduling engine with fair-sharing and preemption" "Component"
                webhookServer = component "Webhook Server" "Mutating and validating admission webhooks" "Webhook (9443/TCP HTTPS)"
                metricsServer = component "Metrics Server" "Prometheus metrics endpoint" "HTTPS (8443/TCP)"
                jobFrameworkCtrl = component "Job Framework Controllers" "Integration for batch/Job, Kubeflow, Ray, JobSet, AppWrapper" "Controllers"
            }
        }

        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform (>= 1.25.0)" "External"
        kubeflowTraining = softwareSystem "Kubeflow Training Operator" "Manages distributed training jobs (PyTorchJob, TFJob, MPIJob)" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay Operator" "Manages Ray clusters and jobs" "Internal RHOAI"
        jobsetController = softwareSystem "JobSet Controller" "Manages JobSet resources" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare Operator" "Manages AppWrapper resources" "Internal RHOAI"
        clusterAutoscaler = softwareSystem "Cluster Autoscaler" "Node provisioning via ProvisioningRequest API" "External"
        certManager = softwareSystem "cert-manager" "Certificate management (optional)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and alerting" "External"

        # Relationships
        user -> kueue "Submits jobs (batch/Job, PyTorchJob, RayJob, etc.) via kubectl"
        platformAdmin -> kueue "Configures ClusterQueues, ResourceFlavors, quotas via kubectl"

        kueue -> kubernetes "CRD management, watch, leader election" "HTTPS/443"
        kueue -> clusterAutoscaler "Creates ProvisioningRequest for node scaling" "HTTPS/443"
        kueue -> certManager "Optional certificate management" "HTTPS/443"

        kubeflowTraining -> kueue "Jobs queued via Workload CRs" "CRD Watch"
        kuberay -> kueue "RayJob/RayCluster queued via Workload CRs" "CRD Watch"
        jobsetController -> kueue "JobSets queued via Workload CRs" "CRD Watch"
        codeflare -> kueue "AppWrappers queued via Workload CRs" "CRD Watch"

        prometheus -> kueue "Scrapes metrics" "HTTPS/8443"
    }

    views {
        systemContext kueue "SystemContext" {
            include *
            autoLayout
        }

        container kueue "Containers" {
            include *
            autoLayout
        }

        component controllerManager "Components" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Component" {
                background #85bbf0
                color #000000
            }
        }
    }
}
