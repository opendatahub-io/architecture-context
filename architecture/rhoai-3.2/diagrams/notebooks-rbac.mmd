graph TD
    subgraph "Service Accounts"
        SA["ServiceAccount<br/>{notebook}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB["RoleBinding<br/>notebook-sa-rolebinding<br/>Binds: notebook-sa-role → {notebook}-sa"]
    end

    subgraph "Roles (Namespace-scoped)"
        Role["Role<br/>notebook-sa-role<br/>Typical workbench permissions"]
    end

    subgraph "API Resources - Core (v1)"
        Pods["pods<br/>get, list"]
        Services["services<br/>get, list"]
        ConfigMaps["configmaps<br/>get, list"]
        Secrets["secrets<br/>get, list"]
    end

    subgraph "API Resources - Batch"
        Jobs["batch/jobs<br/>create, get, list, delete"]
    end

    subgraph "Workbench Pod"
        Container1["Container: OAuth Proxy<br/>Uses SA: {notebook}-sa"]
        Container2["Container: Jupyter<br/>Uses SA: {notebook}-sa"]
    end

    subgraph "OAuth Authorization"
        OAuthPolicy["OAuth Policy<br/>User must be namespace member<br/>Enforced by: oauth-proxy"]
    end

    subgraph "Secrets Used by Workbench"
        OAuthSecret["{notebook}-oauth-config<br/>(Opaque)<br/>OAuth proxy config"]
        TLSSecret["{notebook}-tls<br/>(kubernetes.io/tls)<br/>TLS cert for HTTPS"]
        PullSecret["{user}-pull-secret<br/>(dockerconfigjson)<br/>Registry credentials"]
        AWSSecret["aws-connection-{name}<br/>(Opaque)<br/>S3 credentials"]
        GitSecret["git-ssh-key<br/>(kubernetes.io/ssh-auth)<br/>Git SSH key"]
    end

    %% ServiceAccount to Pod
    SA -.->|mounted in| Container1
    SA -.->|mounted in| Container2

    %% RoleBinding relationships
    SA -->|bound via| RB
    RB -->|grants| Role

    %% Role to Resources
    Role -->|get, list| Pods
    Role -->|get, list| Services
    Role -->|get, list| ConfigMaps
    Role -->|get, list| Secrets
    Role -->|create, get, list, delete| Jobs

    %% OAuth
    OAuthPolicy -.->|validates user| Container1
    Container1 -.->|proxies to| Container2

    %% Secrets usage
    OAuthSecret -.->|used by| Container1
    TLSSecret -.->|used by| Container1
    PullSecret -.->|used by| Container2
    AWSSecret -.->|optional| Container2
    GitSecret -.->|optional| Container2

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style Role fill:#f5a623,color:#000
    style RB fill:#7ed321,color:#000
    style Pods fill:#d5e8d4,stroke:#82b366
    style Services fill:#d5e8d4,stroke:#82b366
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style Jobs fill:#d5e8d4,stroke:#82b366
    style Container1 fill:#dae8fc,stroke:#6c8ebf
    style Container2 fill:#dae8fc,stroke:#6c8ebf
    style OAuthPolicy fill:#ffe6cc,stroke:#d79b00
    style OAuthSecret fill:#f8cecc,stroke:#b85450
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style PullSecret fill:#f8cecc,stroke:#b85450
    style AWSSecret fill:#f8cecc,stroke:#b85450
    style GitSecret fill:#f8cecc,stroke:#b85450
