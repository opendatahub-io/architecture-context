%% RBAC Visualization - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Note: This component does not define its own RBAC. Diagram shows
%% the RBAC enforcement model managed by notebook controllers.

graph TD
    subgraph "Authentication Flow (RHOAI 3.x)"
        UserBrowser[User Browser]
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>(injected by odh-notebook-controller)"]
        WorkbenchUI["Workbench Container<br/>(JupyterLab / RStudio / Code Server)"]
    end

    subgraph "RBAC Enforcement"
        BearerToken["Bearer Token<br/>(from OpenShift OAuth)"]
        K8sAPI["Kubernetes API Server<br/>Token Review + SubjectAccessReview"]
        NotebookSA["Notebook ServiceAccount<br/>(per-user namespace)"]
    end

    subgraph "Operator-Managed RBAC"
        RHODSOpSA["rhods-operator SA<br/>NS: redhat-ods-operator"]
        RHODSOpRole["ClusterRole<br/>rhods-operator-manager-role"]
        ISPerms["ImageStream Permissions<br/>image.openshift.io/ImageStream<br/>get, list, watch, create, update, patch"]
        BCPerms["BuildConfig Permissions<br/>build.openshift.io/BuildConfig<br/>get, list, watch, create, update"]
    end

    subgraph "Notebook Controller RBAC"
        NotebookCtrlSA["odh-notebook-controller SA<br/>NS: redhat-ods-applications"]
        NotebookCtrlRole["ClusterRole<br/>notebook-controller-role"]
        PodPerms["Pod Permissions<br/>core/Pod<br/>get, list, watch, create, update, delete"]
        SvcPerms["Service Permissions<br/>core/Service<br/>get, list, watch, create, update, delete"]
        RoutePerms["HTTPRoute Permissions<br/>gateway.networking.k8s.io/HTTPRoute<br/>get, list, watch, create, update, delete"]
    end

    subgraph "Secrets"
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for RStudio builds<br/>Provisioned by: Cluster Admin<br/>Auto-Rotate: No"]
    end

    %% Authentication flow
    UserBrowser -->|"HTTPS/8443<br/>Bearer Token"| KubeRBACProxy
    KubeRBACProxy -->|"validates token"| K8sAPI
    K8sAPI -->|"checks RBAC"| NotebookSA
    KubeRBACProxy -->|"HTTP/8888 localhost<br/>if authorized"| WorkbenchUI
    BearerToken -.->|"presented by"| UserBrowser

    %% Operator RBAC
    RHODSOpSA -->|"bound to"| RHODSOpRole
    RHODSOpRole -->|"grants"| ISPerms
    RHODSOpRole -->|"grants"| BCPerms

    %% Controller RBAC
    NotebookCtrlSA -->|"bound to"| NotebookCtrlRole
    NotebookCtrlRole -->|"grants"| PodPerms
    NotebookCtrlRole -->|"grants"| SvcPerms
    NotebookCtrlRole -->|"grants"| RoutePerms

    %% Secrets
    RHELSecret -.->|"used by"| BCPerms

    %% Styling
    style UserBrowser fill:#f9f9f9,stroke:#999
    style KubeRBACProxy fill:#4a90e2,color:#fff
    style WorkbenchUI fill:#4a90e2,color:#fff
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style NotebookSA fill:#d5e8d4,stroke:#82b366
    style RHODSOpSA fill:#4a90e2,color:#fff
    style RHODSOpRole fill:#f5a623,color:#fff
    style NotebookCtrlSA fill:#4a90e2,color:#fff
    style NotebookCtrlRole fill:#f5a623,color:#fff
    style ISPerms fill:#7ed321,color:#fff
    style BCPerms fill:#7ed321,color:#fff
    style PodPerms fill:#7ed321,color:#fff
    style SvcPerms fill:#7ed321,color:#fff
    style RoutePerms fill:#7ed321,color:#fff
    style RHELSecret fill:#e6b8af,stroke:#cc4125
    style BearerToken fill:#fff2cc,stroke:#d6b656
