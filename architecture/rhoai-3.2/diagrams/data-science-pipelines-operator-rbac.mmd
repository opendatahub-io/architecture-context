graph TD
    subgraph "Operator Namespace - redhat-ods-applications"
        SA_Controller[ServiceAccount -<br/>controller-manager]
    end

    subgraph "Per-DSPA Namespace - dspa-namespace"
        SA_DSPipeline[ServiceAccount -<br/>ds-pipeline-NAME]
        SA_Argo[ServiceAccount -<br/>ds-pipeline-argo-NAME]
        SA_Runner[ServiceAccount -<br/>pipeline-runner-NAME]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[ClusterRoleBinding -<br/>manager-rolebinding]
        CRB_Argo[ClusterRoleBinding -<br/>ds-pipeline-argo-binding]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_DSPipeline[RoleBinding -<br/>ds-pipeline-NAME]
        RB_Argo[RoleBinding -<br/>argo-binding]
        RB_Runner[RoleBinding -<br/>pipeline-runner-NAME]
    end

    subgraph "ClusterRole Permissions"
        CR_Manager[ClusterRole -<br/>manager-role]
        CR_Argo[ClusterRole -<br/>argo-cluster-role]
    end

    subgraph "Role Permissions (Namespace-scoped)"
        R_DSPipeline[Role -<br/>ds-pipeline]
        R_Argo[Role -<br/>argo]
        R_Runner[Role -<br/>pipeline-runner]
    end

    subgraph "API Resources - DSPO Operator"
        DSPA_CRD[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
        Pipeline_CRD[pipelines.kubeflow.org<br/>Pipeline, PipelineVersion]
        Workflow_CRD[argoproj.io<br/>Workflow, WorkflowTemplate]
        Core_Resources[Core Resources<br/>ConfigMaps, Secrets, Services,<br/>ServiceAccounts, PVCs]
        Apps_Resources[apps<br/>Deployments, ReplicaSets]
        RBAC_Resources[rbac.authorization.k8s.io<br/>Roles, RoleBindings,<br/>ClusterRoles, ClusterRoleBindings]
        Network_Resources[route.openshift.io<br/>Routes<br/>networking.k8s.io<br/>NetworkPolicies]
        Integration_Resources[serving.kserve.io<br/>InferenceServices<br/>ray.io<br/>RayClusters, RayJobs<br/>workload.codeflare.dev<br/>AppWrappers]
        Auth_Resources[authentication.k8s.io<br/>TokenReviews<br/>authorization.k8s.io<br/>SubjectAccessReviews]
    end

    subgraph "API Resources - Argo Workflows"
        Argo_Workflows[argoproj.io<br/>Workflows, WorkflowTemplates,<br/>CronWorkflows]
        Argo_Pods[Core<br/>Pods, Pods/log, Pods/exec]
        Argo_Config[Core<br/>ConfigMaps read-only]
        Argo_PVC[Core<br/>PersistentVolumeClaims]
    end

    subgraph "API Resources - Pipeline Runner"
        Runner_Pods[Core<br/>Pods workflow task execution]
        Runner_Secrets[Core<br/>Secrets storage credentials]
        Runner_CRD[Integration CRDs<br/>KServe, Ray, CodeFlare]
    end

    %% Service Account Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_DSPipeline -->|bound via| RB_DSPipeline
    SA_Argo -->|bound via| CRB_Argo
    SA_Argo -->|bound via| RB_Argo
    SA_Runner -->|bound via| RB_Runner

    %% ClusterRole Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Argo -->|grants| CR_Argo

    %% RoleBindings to Roles
    RB_DSPipeline -->|grants| R_DSPipeline
    RB_Argo -->|grants| R_Argo
    RB_Runner -->|grants| R_Runner

    %% Operator Permissions
    CR_Manager -->|create,delete,get,list,patch,update,watch| DSPA_CRD
    CR_Manager -->|create,delete,get,list,patch,update,watch| Pipeline_CRD
    CR_Manager -->|*,create,patch| Workflow_CRD
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Resources
    CR_Manager -->|*,create,delete,get,list,patch,update,watch| Apps_Resources
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_Resources
    CR_Manager -->|create,delete,get,list,patch,update,watch| Network_Resources
    CR_Manager -->|create,delete,get,list,patch| Integration_Resources
    CR_Manager -->|create| Auth_Resources

    %% Argo Permissions
    CR_Argo -->|create,delete,get,list,watch,update,patch| Argo_Workflows
    CR_Argo -->|create,get,list,watch,delete,patch| Argo_Pods
    CR_Argo -->|get,watch,list| Argo_Config
    CR_Argo -->|create,delete| Argo_PVC

    %% Pipeline Runner Permissions
    R_Runner -->|create,get,list,watch| Runner_Pods
    R_Runner -->|get,list| Runner_Secrets
    R_Runner -->|create,delete,get,list,patch| Runner_CRD

    %% Styling
    style SA_Controller fill -#4a90e2,stroke -#333,color -#fff
    style SA_DSPipeline fill -#4a90e2,stroke -#333,color -#fff
    style SA_Argo fill -#4a90e2,stroke -#333,color -#fff
    style SA_Runner fill -#4a90e2,stroke -#333,color -#fff

    style CR_Manager fill -#f5a623,stroke -#333,color -#000
    style CR_Argo fill -#f5a623,stroke -#333,color -#000
    style R_DSPipeline fill -#f5a623,stroke -#333,color -#000
    style R_Argo fill -#f5a623,stroke -#333,color -#000
    style R_Runner fill -#f5a623,stroke -#333,color -#000

    style CRB_Manager fill -#9b59b6,stroke -#333,color -#fff
    style CRB_Argo fill -#9b59b6,stroke -#333,color -#fff
    style RB_DSPipeline fill -#9b59b6,stroke -#333,color -#fff
    style RB_Argo fill -#9b59b6,stroke -#333,color -#fff
    style RB_Runner fill -#9b59b6,stroke -#333,color -#fff

    style DSPA_CRD fill -#7ed321,stroke -#333,color -#000
    style Pipeline_CRD fill -#7ed321,stroke -#333,color -#000
    style Workflow_CRD fill -#7ed321,stroke -#333,color -#000
    style Core_Resources fill -#7ed321,stroke -#333,color -#000
    style Apps_Resources fill -#7ed321,stroke -#333,color -#000
    style RBAC_Resources fill -#7ed321,stroke -#333,color -#000
    style Network_Resources fill -#7ed321,stroke -#333,color -#000
    style Integration_Resources fill -#7ed321,stroke -#333,color -#000
    style Auth_Resources fill -#7ed321,stroke -#333,color -#000
    style Argo_Workflows fill -#7ed321,stroke -#333,color -#000
    style Argo_Pods fill -#7ed321,stroke -#333,color -#000
    style Argo_Config fill -#7ed321,stroke -#333,color -#000
    style Argo_PVC fill -#7ed321,stroke -#333,color -#000
    style Runner_Pods fill -#7ed321,stroke -#333,color -#000
    style Runner_Secrets fill -#7ed321,stroke -#333,color -#000
    style Runner_CRD fill -#7ed321,stroke -#333,color -#000
