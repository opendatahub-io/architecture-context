// Models as a Service - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "API Consumer" "Data scientist, developer, or application consuming LLM inference via MaaS gateway"

        maas = softwareSystem "Models as a Service (MaaS)" "Centralized API for managing, authenticating, and rate-limiting access to LLM inference services" {
            maasApi = container "maas-api" "OpenAI-compatible model listing, token/API key management, tier lookup" "Go/Gin REST API"
            gateway = container "maas-default-gateway" "Single ingress point for all MaaS traffic, TLS termination" "Gateway API Gateway"
            authPolicy = container "gateway-auth-policy" "Token authentication (TokenReview), tier enrichment, SAR authorization" "Kuadrant AuthPolicy"
            rateLimitPolicy = container "gateway-rate-limits" "Per-user, tier-based request rate limiting" "Kuadrant RateLimitPolicy"
            tokenRateLimitPolicy = container "gateway-token-rate-limits" "Per-user, tier-based token consumption limiting" "Kuadrant TokenRateLimitPolicy"
            telemetryPolicy = container "telemetry-policy" "Metrics enrichment with model, tier, and user labels" "Kuadrant TelemetryPolicy"
            tierMapping = container "tier-to-group-mapping" "Maps user groups to subscription tiers" "ConfigMap"
        }

        kserve = softwareSystem "KServe" "Serves LLM models via InferenceService and LLMInferenceService CRDs" "External"
        kuadrant = softwareSystem "Kuadrant" "Policy engine providing AuthPolicy, RateLimitPolicy enforcement" "External"
        authorino = softwareSystem "Authorino" "Authentication (TokenReview) and authorization (SAR) via Kuadrant" "External"
        limitador = softwareSystem "Limitador" "Rate limiting enforcement engine via Kuadrant" "External"
        gatewayAPI = softwareSystem "Gateway API" "Gateway and HTTPRoute resources for ingress" "External"
        openshiftGW = softwareSystem "OpenShift Gateway Controller" "Provisions load balancer for gateway" "External"
        k8sAPI = softwareSystem "Kubernetes API" "ServiceAccount, TokenRequest, TokenReview, informers" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        postgresql = softwareSystem "PostgreSQL" "External database for API key metadata (optional, HA mode)" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Configures KServe in RawDeployment mode via DataScienceCluster" "Internal RHOAI"

        // User interactions
        user -> maas "Sends inference requests, manages tokens/API keys" "HTTPS/443"
        user -> gateway "Model inference and API requests" "HTTPS/443, Bearer Token"

        // Internal container relationships
        gateway -> authPolicy "Enforces authentication and authorization"
        gateway -> rateLimitPolicy "Enforces request rate limits"
        gateway -> tokenRateLimitPolicy "Enforces token consumption limits"
        gateway -> telemetryPolicy "Enriches metrics"
        gateway -> maasApi "Routes /v1/models, /maas-api/* traffic" "HTTP/8080"
        authPolicy -> maasApi "Tier lookup callback" "HTTP/8080, /v1/tiers/lookup"
        maasApi -> tierMapping "Reads tier configuration"

        // External dependencies
        maas -> kserve "Watches InferenceService and LLMInferenceService CRDs" "HTTPS/443 informer"
        maas -> kuadrant "AuthPolicy, RateLimitPolicy enforcement"
        kuadrant -> authorino "Authentication/authorization delegation"
        kuadrant -> limitador "Rate limiting delegation"
        maas -> gatewayAPI "Gateway and HTTPRoute resources"
        maas -> openshiftGW "Provisions load balancer for gateway"
        maas -> k8sAPI "Informers, TokenRequest, TokenReview, SA management" "HTTPS/443"
        maas -> prometheus "Limitador metrics via ServiceMonitor" "HTTP"
        maas -> postgresql "API key metadata storage (optional)" "TCP/5432, TLS"
        rhoaiOperator -> maas "Configures KServe mode"

        // Model traffic
        gateway -> kserve "Proxies inference requests to model backends" "HTTPS/8000"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
