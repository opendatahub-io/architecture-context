graph TB
    subgraph "RHOAI Operator (rhods-operator)"
        DSCController[DSC Controller<br/>DataScienceCluster Reconciler]
        DSCIController[DSCI Controller<br/>DSCInitialization Reconciler]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS]
        ManifestDeployer[Manifest Deployer<br/>Kustomize Engine]

        subgraph "Component Controllers"
            DashboardCtrl[Dashboard Controller]
            KServeCtrl[KServe Controller]
            WorkbenchCtrl[Workbenches Controller]
            PipelinesCtrl[Pipelines Controller]
            ModelRegCtrl[Model Registry Controller]
            RayCtrl[Ray Controller]
            TrainingCtrl[Training Operator Controller]
            TrustyAICtrl[TrustyAI Controller]
            KueueCtrl[Kueue Controller]
            FeastCtrl[Feast Controller]
            MLflowCtrl[MLflow Controller]
            LlamaCtrl[Llama Stack Controller]
        end

        subgraph "Service Controllers"
            AuthCtrl[Auth Service Controller]
            MonitoringCtrl[Monitoring Service Controller]
            GatewayCtrl[Gateway Service Controller]
        end

        subgraph "Monitoring Stack"
            Prometheus[Prometheus<br/>9091/TCP HTTP]
            Alertmanager[Alertmanager<br/>9093/TCP HTTP]
            BlackboxExporter[Blackbox Exporter<br/>9115/TCP HTTP]
        end
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        ComponentCRs[Component CRs<br/>components.opendatahub.io/v1alpha1]
        ServiceCRs[Service CRs<br/>services.opendatahub.io/v1alpha1]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        OLM[OLM Operators<br/>Subscription/CSV Management]
        ServiceMesh[OpenShift Service Mesh<br/>Istio 2.x - Optional]
        Serverless[OpenShift Serverless<br/>Knative 1.x - Optional]
        CertManager[cert-manager<br/>1.x - Optional]
        ImageRegistry[Image Registries<br/>443/TCP HTTPS]
    end

    subgraph "Deployed Components"
        Dashboard[ODH Dashboard]
        KServe[KServe]
        Workbenches[Workbenches]
        Pipelines[Data Science Pipelines]
        ModelRegistry[Model Registry]
    end

    %% User interactions
    User[User/GitOps] -->|kubectl apply| DSC
    User -->|kubectl apply| DSCI

    %% Webhook validation
    K8sAPI -->|validate/mutate| WebhookServer
    WebhookServer -->|validated| K8sAPI

    %% Controller watches
    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController
    ComponentCRs -->|watched by| DashboardCtrl
    ComponentCRs -->|watched by| KServeCtrl
    ComponentCRs -->|watched by| WorkbenchCtrl
    ServiceCRs -->|watched by| AuthCtrl

    %% DSC Controller creates component CRs
    DSCController -->|creates/updates| ComponentCRs
    DSCController -->|creates/updates| ServiceCRs

    %% Component controllers deploy
    DashboardCtrl -->|uses| ManifestDeployer
    KServeCtrl -->|uses| ManifestDeployer
    WorkbenchCtrl -->|uses| ManifestDeployer
    PipelinesCtrl -->|uses| ManifestDeployer
    ModelRegCtrl -->|uses| ManifestDeployer

    %% Manifest deployer applies to cluster
    ManifestDeployer -->|applies manifests| K8sAPI

    %% Deployed components
    K8sAPI -->|creates| Dashboard
    K8sAPI -->|creates| KServe
    K8sAPI -->|creates| Workbenches
    K8sAPI -->|creates| Pipelines
    K8sAPI -->|creates| ModelRegistry

    %% External dependencies
    DSCController -->|API calls| K8sAPI
    DSCIController -->|API calls| K8sAPI
    DSCController -->|manages subscriptions| OLM
    KServeCtrl -->|requires| ServiceMesh
    KServeCtrl -->|requires| Serverless
    WebhookServer -.->|optional| CertManager
    ManifestDeployer -->|pulls images| ImageRegistry

    %% Monitoring
    MonitoringCtrl -->|deploys| Prometheus
    MonitoringCtrl -->|deploys| Alertmanager
    MonitoringCtrl -->|deploys| BlackboxExporter
    DSCController -->|metrics| Prometheus
    DashboardCtrl -->|metrics| Prometheus
    KServeCtrl -->|metrics| Prometheus

    %% Styling
    style DSCController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCIController fill:#4a90e2,stroke:#333,stroke-width:2px
    style WebhookServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style ManifestDeployer fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSC fill:#f5a623,stroke:#333,stroke-width:2px
    style DSCI fill:#f5a623,stroke:#333,stroke-width:2px
    style ComponentCRs fill:#f5a623,stroke:#333,stroke-width:2px
    style ServiceCRs fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Serverless fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style Workbenches fill:#7ed321,stroke:#333,stroke-width:2px
    style Pipelines fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#bd10e0,stroke:#333,stroke-width:2px
    style Alertmanager fill:#bd10e0,stroke:#333,stroke-width:2px
