graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        DataScientist[Data Scientist<br/>kubectl/oc]
        ExternalClient[External Client<br/>Model Inference]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.3<br/>Bearer Token Auth"]
        Router["OpenShift Router<br/>443/TCP<br/>HTTPS TLS 1.2+<br/>Edge/Reencrypt"]
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: opendatahub)"]
        direction TB

        subgraph Controller["ODH Model Controller"]
            direction TB
            Manager["Manager Process<br/>SA: odh-model-controller<br/>UID: 2000 non-root<br/>FIPS: strictfipsruntime"]

            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ service-ca<br/>mTLS client cert"]
            MetricsSrv["Metrics Server<br/>8080/TCP HTTP<br/>Bearer Token planned"]
            HealthSrv["Health Server<br/>8081/TCP HTTP<br/>localhost only"]

            Manager --> WebhookSrv
            Manager --> MetricsSrv
            Manager --> HealthSrv
        end

        WebhookCert["Secret: webhook-cert<br/>Type: kubernetes.io/tls<br/>Auto-rotate: service-ca"]
    end

    subgraph DataPlane["DATA PLANE (User Namespaces)"]
        Predictor["Predictor Pods<br/>SA: isvc-name-sa<br/>Label: component=predictor"]
        NetPol["NetworkPolicy<br/>allow-from-openshift-ingress"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelRegistry["Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token<br/>optional: MODELREGISTRY_STATE=managed"]
        NGC["NVIDIA NGC API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key<br/>optional: NIM_STATE=managed"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor/PodMonitor"]
    end

    %% External to Ingress
    DataScientist -->|HTTPS/6443<br/>TLS 1.3<br/>Bearer Token| K8sAPI
    ExternalClient -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer or Anonymous| Router

    %% Ingress to Control Plane
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>mTLS client cert| WebhookSrv
    K8sAPI -.->|API watches and operations<br/>Bearer Token SA| Manager

    %% Ingress to Data Plane
    Router -->|HTTP or HTTPS<br/>varies| Predictor

    %% Control Plane egress
    Manager -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token SA<br/>Watch CRDs, create resources| K8sAPI
    Manager -.->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Register models| ModelRegistry
    Manager -.->|HTTPS/443<br/>TLS 1.2+<br/>NGC API Key<br/>Validate and fetch models| NGC

    %% Secrets
    WebhookSrv -.->|mounts| WebhookCert

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Bearer Token planned<br/>Scrape metrics| MetricsSrv

    %% Network Policies
    Router -.->|allowed by| NetPol
    NetPol -.->|protects| Predictor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#cce5ff,stroke:#4a90e2,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class DataScientist,ExternalClient external
    class K8sAPI,Router ingress
    class Manager,WebhookSrv,MetricsSrv,HealthSrv controlplane
    class Predictor,NetPol dataplane
    class ModelRegistry,NGC externalservice
    class Prometheus monitoring
    class WebhookCert secret
