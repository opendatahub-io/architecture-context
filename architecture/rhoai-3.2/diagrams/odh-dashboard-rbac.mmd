graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Dashboard namespace]
    end

    subgraph "Cluster-Level Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[odh-dashboard-image-puller<br/>ClusterRoleBinding]
    end

    subgraph "Namespace-Level Bindings"
        RB1[odh-dashboard<br/>RoleBinding<br/>Dashboard namespace]
        RB2[cluster-monitoring-view<br/>RoleBinding<br/>Dashboard namespace]
    end

    subgraph "Cluster Roles"
        CR[odh-dashboard<br/>ClusterRole]
        CR2[system:auth-delegator<br/>ClusterRole]
        CR3[system:image-puller<br/>ClusterRole]
        CR4[cluster-monitoring-view<br/>ClusterRole]
    end

    subgraph "Namespace Roles"
        NR[odh-dashboard<br/>Role<br/>Dashboard namespace]
    end

    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1
    SA -->|bound via| RB2

    CRB1 -->|grants| CR
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    RB1 -->|grants| NR
    RB2 -->|grants| CR4

    subgraph "Core API Resources (Cluster)"
        CoreNodes[nodes<br/>get, list]
        CoreCM[configmaps, secrets, pvc<br/>create, delete, get, list,<br/>patch, update, watch]
        CorePods[pods, services,<br/>serviceaccounts<br/>get, list, watch]
        CoreNS[namespaces<br/>patch]
    end

    subgraph "OpenShift Resources (Cluster)"
        OSMachine[machineautoscalers,<br/>machinesets<br/>get, list]
        OSConfig[clusterversions,<br/>ingresses<br/>get, watch, list]
        OSCSV[clusterserviceversions,<br/>subscriptions<br/>get, list, watch]
        OSImage[imagestreams/layers<br/>get]
        OSRoute[routes<br/>get, list, watch]
        OSConsole[consolelinks, consoles<br/>get, list, watch]
        OSUser[users, groups<br/>get, list, watch]
    end

    subgraph "RBAC Resources (Cluster)"
        RBACRes[rolebindings,<br/>clusterrolebindings,<br/>roles<br/>list, get, create,<br/>patch, delete]
        AuthRes[tokenreviews,<br/>subjectaccessreviews<br/>create]
    end

    subgraph "ODH CRDs (Cluster)"
        DSC[datascienceclusters,<br/>dscinitializations<br/>list, watch, get]
        Notebooks[notebooks<br/>kubeflow.org<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
        InferSvc[inferenceservices<br/>serving.kserve.io<br/>get, list, watch]
        ModelReg[modelregistries<br/>modelregistry.opendatahub.io<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
        FeastFS[featurestores<br/>feast.dev<br/>get, list, watch]
        LlamaStack[llamastackdistributions<br/>llamastack.io<br/>get, list, watch]
    end

    subgraph "Dashboard CRDs (Namespace)"
        AccelProf[acceleratorprofiles<br/>dashboard.opendatahub.io<br/>create, get, list,<br/>update, patch, delete]
        OdhApp[odhapplications,<br/>odhdocuments<br/>dashboard.opendatahub.io<br/>get, list]
        QuickStart[odhquickstarts<br/>console.openshift.io<br/>get, list]
        DashConfig[odhdashboardconfigs<br/>opendatahub.io<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
    end

    subgraph "Namespace Resources"
        NSRoute[routes<br/>route.openshift.io<br/>get, list, watch]
        NSCron[cronjobs<br/>batch<br/>get, update, delete]
        NSImage[imagestreams<br/>image.openshift.io<br/>create, get, list,<br/>update, patch, delete]
        NSBuild[builds, buildconfigs<br/>build.openshift.io<br/>list]
        NSDeploy[deployments<br/>apps<br/>patch, update]
        NSDC[deploymentconfigs<br/>apps.openshift.io<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
        NSTemplate[templates<br/>template.openshift.io<br/>all verbs]
        NSRuntime[servingruntimes<br/>serving.kserve.io<br/>all verbs]
        NSNotebook[notebooks<br/>kubeflow.org<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
        NSNIM[accounts<br/>nim.opendatahub.io<br/>get, list, watch,<br/>create, update,<br/>patch, delete]
    end

