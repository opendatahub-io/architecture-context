// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines via Data Science Pipelines"

        argoWorkflows = softwareSystem "Argo Workflows" "Container-native workflow engine for orchestrating parallel jobs on Kubernetes; executes Data Science Pipeline runs" {
            workflowController = container "workflow-controller" "Watches Workflow CRs, orchestrates pod creation for workflow steps, manages DAG execution and lifecycle" "Go Binary (Deployment)"
            argoexec = container "argoexec" "Runs inside workflow pods; manages artifact collection, output parameter capture, and container lifecycle" "Go Binary (Sidecar)"
            argoServer = container "argo-server" "API server exposing gRPC + REST APIs on port 2746/TCP; serves the Argo Workflows UI; handles SSO authentication" "Go Binary (Deployment)"
        }

        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration platform" "Internal RHOAI"
        kubernetes = softwareSystem "Kubernetes API" "Container orchestration platform" "External"
        s3 = softwareSystem "S3/MinIO Storage" "Artifact repository for workflow step inputs/outputs" "External"
        postgresql = softwareSystem "PostgreSQL/MySQL" "Optional workflow archiving and node status offloading" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for argo-server" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // Relationships
        datascientist -> dsp "Submits pipeline runs via DSP UI/API"
        dsp -> argoWorkflows "Creates Workflow CRs" "HTTPS/443 via K8s API"

        workflowController -> kubernetes "Pod CRUD, CR watch, leader election" "HTTPS/443 TLS 1.2+"
        argoexec -> kubernetes "Patch WorkflowTaskResult" "HTTPS/443 TLS 1.2+"
        argoexec -> s3 "Upload/download artifacts" "HTTPS/443 or HTTP/9000"
        workflowController -> postgresql "Archive workflows" "TCP/5432 or 3306, TLS optional"
        argoServer -> postgresql "Query archived workflows" "TCP/5432 or 3306, TLS optional"
        argoServer -> oidcProvider "Validate SSO tokens" "HTTPS/443 TLS 1.2+"
        argoServer -> kubernetes "Query CRs, manage resources" "HTTPS/443 TLS 1.2+"
        prometheus -> workflowController "Scrape metrics" "HTTP/9090 plaintext"
        prometheus -> argoServer "Scrape metrics" "HTTP/9090 plaintext"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
