/*
 * C4 Context Diagram: model-metadata-collection
 * Generated by: Claude Opus 4.6
 *
 * Render with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace model-metadata-collection-c4-context.dsl -format png
 */

workspace {
    model {
        buildEngineer = person "Build Engineer" "Maintains CI/CD pipelines and model catalog configuration"
        dashboardUser = person "Data Scientist / Platform User" "Browses model catalog in RHOAI Dashboard"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time Go CLI tool and static data container that collects, enriches, and catalogs Red Hat AI validated model metadata" {
            modelExtractor = container "model-extractor CLI" "Extracts metadata from OCI modelcar containers, enriches with HuggingFace data, generates YAML catalogs" "Go 1.24 CLI"
            metadataReport = container "metadata-report CLI" "Generates metadata completeness reports from catalog data" "Go 1.24 CLI"
            dataContainer = container "Data Container" "Ships pre-generated catalog YAML files at /app/data via volume mount; runs sleep infinity as non-root UID 1001" "ubi9-minimal Container"
        }

        huggingface = softwareSystem "HuggingFace" "ML model hub with collections, model details, and READMEs" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Red Hat container registry hosting modelcar OCI images" "External"
        konflux = softwareSystem "Konflux CI/CD" "Tekton-based build pipeline for building and publishing container images" "External"

        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Web UI for managing and browsing AI/ML resources" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores and serves model metadata via API" "Internal RHOAI"

        /* Build-time relationships */
        buildEngineer -> konflux "Configures build pipelines and model index files"
        konflux -> modelExtractor "Triggers build pipeline" "" "Build-time"
        modelExtractor -> huggingface "Fetches model collections, details, READMEs" "HTTPS/443, TLS 1.2+, No Auth"
        modelExtractor -> registryRedHat "Pulls modelcar manifests and layers" "HTTPS/443, TLS 1.2+, Docker Credentials"
        modelExtractor -> dataContainer "Catalog files copied into container image" "" "Build-time"

        /* Runtime relationships */
        dataContainer -> rhoaiDashboard "Provides catalog YAML files" "Volume Mount (Filesystem)"
        dashboardUser -> rhoaiDashboard "Browses model catalog"

        /* Data format alignment */
        modelMetadataCollection -> modelRegistry "Catalog format aligns with Model Registry schema" "" "Data Format"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
            description "System context showing model-metadata-collection in the RHOAI ecosystem"
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
            description "Container view showing build-time CLI tools and runtime data container"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
