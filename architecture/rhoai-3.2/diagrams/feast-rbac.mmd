graph TD
    subgraph "Service Accounts"
        SA_Manager["controller-manager<br/>Namespace: operator-ns"]
        SA_FeatureStore["feast-name-sa<br/>Namespace: user-ns<br/>Per FeatureStore"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[controller-manager-rolebinding]
        CRB_Metrics[metrics-auth-rolebinding]
    end

    subgraph "Role Bindings (Namespaced)"
        RB_Leader["leader-election-rolebinding<br/>Namespace: operator-ns"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_Metrics[metrics-auth-role]
        CR_Editor["featurestore-editor-role<br/>User-facing"]
        CR_Viewer["featurestore-viewer-role<br/>User-facing"]
    end

    subgraph "Namespaced Roles"
        R_Leader["leader-election-role<br/>Namespace: operator-ns"]
    end

    subgraph "API Resources - Feast"
        API_FS[feast.dev<br/>FeatureStore, FeatureStore/status,<br/>FeatureStore/finalizers]
    end

    subgraph "API Resources - Core Workloads"
        API_Deployments[apps/Deployments]
        API_Services[core/Services]
        API_ConfigMaps[core/ConfigMaps]
        API_PVCs[core/PersistentVolumeClaims]
        API_ServiceAccounts[core/ServiceAccounts]
        API_Secrets[core/Secrets]
        API_Pods[core/Pods, Pods/exec]
        API_Namespaces[core/Namespaces]
    end

    subgraph "API Resources - Batch"
        API_CronJobs[batch/CronJobs]
    end

    subgraph "API Resources - RBAC"
        API_RBAC[rbac.authorization.k8s.io<br/>Roles, RoleBindings,<br/>ClusterRoles, ClusterRoleBindings,<br/>SubjectAccessReviews]
    end

    subgraph "API Resources - OpenShift"
        API_Routes[route.openshift.io/Routes]
    end

    subgraph "API Resources - Extensions"
        API_CRDs[apiextensions.k8s.io/CustomResourceDefinitions]
    end

    subgraph "API Resources - Auth"
        API_TokenReview[authentication.k8s.io/TokenReviews]
    end

    subgraph "API Resources - Kubeflow"
        API_Notebooks[kubeflow.org/Notebooks]
    end

    %% Service Account to Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Metrics
    SA_Manager -->|bound via| RB_Leader

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    RB_Leader -->|grants| R_Leader

    %% ClusterRole manager-role permissions
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_FS
    CR_Manager -->|get,list,watch,create,update,delete| API_Deployments
    CR_Manager -->|get,list,watch,create,update,delete| API_Services
    CR_Manager -->|get,list,watch,create,update,delete| API_ConfigMaps
    CR_Manager -->|get,list,watch,create,update,delete| API_PVCs
    CR_Manager -->|get,list,watch,create,update,delete| API_ServiceAccounts
    CR_Manager -->|get,list,watch| API_Secrets
    CR_Manager -->|get,list,watch| API_Pods
    CR_Manager -->|create| API_Pods
    CR_Manager -->|get,list,watch| API_Namespaces
    CR_Manager -->|get,list,watch,create,update,patch,delete| API_CronJobs
    CR_Manager -->|get,list,watch,create,update,delete| API_RBAC
    CR_Manager -->|get,list,watch,create,update,delete| API_Routes
    CR_Manager -->|get,list| API_CRDs
    CR_Manager -->|create| API_TokenReview
    CR_Manager -->|get,list,watch| API_Notebooks

    %% ClusterRole metrics-auth-role permissions
    CR_Metrics -->|create| API_TokenReview
    CR_Metrics -->|create| API_RBAC

    %% Role leader-election-role permissions
    R_Leader -->|get,list,watch,create,update,patch,delete| API_ConfigMaps
    R_Leader -->|get,list,watch,create,update,patch,delete| LeaderLease[coordination.k8s.io/Leases]
    R_Leader -->|create,patch| Events[core/Events]

    %% User-facing roles
    CR_Editor -->|get,list,watch,create,update,patch,delete| API_FS
    CR_Viewer -->|get,list,watch| API_FS

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef api fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef userRole fill:#50e3c2,stroke:#333,stroke-width:2px

    class SA_Manager,SA_FeatureStore serviceAccount
    class CRB_Manager,CRB_Metrics,RB_Leader binding
    class CR_Manager,CR_Metrics,R_Leader role
    class CR_Editor,CR_Viewer userRole
    class API_FS,API_Deployments,API_Services,API_ConfigMaps,API_PVCs,API_ServiceAccounts,API_Secrets,API_Pods,API_Namespaces,API_CronJobs,API_RBAC,API_Routes,API_CRDs,API_TokenReview,API_Notebooks,LeaderLease,Events api
