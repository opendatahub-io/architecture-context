graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[User/Data Scientist]
        MLApp[ML Application]
    end

    subgraph Ingress["INGRESS - OpenShift Routes"]
        Route["OpenShift Route<br/>*.apps.cluster<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge/Passthrough"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER - Internal"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: SA Tokens, User creds"]

        subgraph OperatorNamespace["Namespace: operator-ns"]
            Operator["Feast Operator Controller<br/>SA: controller-manager<br/>UID: 65532 runAsNonRoot<br/>Capabilities: drop ALL"]
            MetricsService["Metrics Service<br/>8443/TCP HTTPS TLS 1.2+<br/>kube-rbac-proxy<br/>Auth: Bearer Token + SAR"]
        end

        subgraph UserNamespace["Namespace: user-ns"]
            direction TB

            Registry["Registry Service<br/>SA: feast-name-sa<br/>6570/TCP gRPC HTTP<br/>6571/TCP gRPC HTTPS TLS 1.2+<br/>6572/TCP REST HTTP<br/>6573/TCP REST HTTPS TLS 1.2+<br/>Auth: Configurable"]

            OnlineStore["Online Store<br/>SA: feast-name-sa<br/>6566/TCP HTTP<br/>6567/TCP HTTPS TLS 1.2+<br/>Auth: Configurable None/RBAC/OIDC"]

            OfflineStore["Offline Store<br/>SA: feast-name-sa<br/>8815/TCP HTTP<br/>8816/TCP HTTPS TLS 1.2+<br/>Auth: Configurable"]

            WebUI["Web UI<br/>SA: feast-name-sa<br/>8888/TCP HTTP<br/>8443/TCP HTTPS TLS 1.2+<br/>Auth: Configurable"]

            RegistryPVC["PVC: registry-storage<br/>5Gi"]
            OnlinePVC["PVC: online-storage<br/>5Gi SQLite"]
            OfflinePVC["PVC: offline-storage<br/>20Gi Parquet/DuckDB"]

            Registry --> RegistryPVC
            OnlineStore --> OnlinePVC
            OfflineStore --> OfflinePVC
        end

        Prometheus["Prometheus<br/>Namespace: monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM/Access Keys"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ optional<br/>Auth: Username/Password"]
        Snowflake["Snowflake<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: OAuth/Key Pair"]
        GitServer["Git Repository<br/>443/TCP HTTPS or 22/TCP SSH<br/>Auth: Token/SSH Key"]
        Cassandra["Cassandra<br/>9042/TCP CQL<br/>TLS 1.2+ optional<br/>Auth: Username/Password"]
    end

    %% External flows
    User -->|HTTPS/6443<br/>User credentials| K8sAPI
    User -->|HTTPS/443<br/>TLS 1.2+| Route
    Route -->|HTTP/HTTPS<br/>80/443/TCP<br/>Auth: Configurable| WebUI

    MLApp -->|HTTP/HTTPS<br/>6566/6567/TCP<br/>TLS 1.2+ optional<br/>Auth: Configurable| OnlineStore

    %% Operator flows
    K8sAPI -.->|Watch/Informer<br/>CRD events| Operator
    Operator -->|HTTPS/6443<br/>SA Token<br/>Creates/Manages| K8sAPI

    Operator -.->|Creates/Manages| Registry
    Operator -.->|Creates/Manages| OnlineStore
    Operator -.->|Creates/Manages| OfflineStore
    Operator -.->|Creates/Manages| WebUI

    %% Monitoring
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+ self-signed<br/>Bearer Token + SAR| MetricsService
    MetricsService -->|TokenReview<br/>SubjectAccessReview| K8sAPI

    %% External service connections
    Registry -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    OnlineStore -.->|PostgreSQL/5432<br/>TLS 1.2+ opt<br/>Username/Password| PostgreSQL
    OnlineStore -.->|CQL/9042<br/>TLS 1.2+ opt<br/>Username/Password| Cassandra
    OfflineStore -.->|HTTPS/443<br/>TLS 1.2+<br/>OAuth/Key Pair| Snowflake
    Operator -.->|HTTPS/443 or SSH/22<br/>TLS 1.2+/SSH<br/>Token/SSH Key| GitServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef featureService fill:#7ed321,stroke:#333,stroke-width:2px
    classDef storage fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,MLApp external
    class Route ingress
    class Operator,MetricsService operator
    class Registry,OnlineStore,OfflineStore,WebUI featureService
    class RegistryPVC,OnlinePVC,OfflinePVC storage
    class S3,PostgreSQL,Snowflake,GitServer,Cassandra externalService
    class K8sAPI,Prometheus k8s
