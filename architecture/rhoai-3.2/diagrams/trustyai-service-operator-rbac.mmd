graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>Namespace: &lt;operator-namespace&gt;]
    end

    subgraph "Cluster Role Bindings"
        CRB1[manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[auth-proxy-rolebinding<br/>ClusterRoleBinding]
        RB1[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "Cluster Roles"
        CR[manager-role<br/>ClusterRole]
        CR2[auth-proxy-role<br/>ClusterRole]
        R1[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Core"
        Core1[Core APIs<br/>configmaps, pvcs, pods<br/>secrets, serviceaccounts<br/>services, events, pvs]
        Core2[pods/exec]
    end

    subgraph "API Resources - Apps"
        Apps[apps<br/>deployments<br/>deployments/finalizers<br/>deployments/status]
    end

    subgraph "API Resources - KServe"
        KServe[serving.kserve.io<br/>inferenceservices<br/>inferenceservices/finalizers<br/>servingruntimes]
    end

    subgraph "API Resources - Istio"
        Istio[networking.istio.io<br/>destinationrules<br/>virtualservices]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io<br/>routes]
    end

    subgraph "API Resources - Monitoring"
        Monitoring[monitoring.coreos.com<br/>servicemonitors]
    end

    subgraph "API Resources - Kueue"
        Kueue[kueue.x-k8s.io<br/>workloads<br/>workloads/finalizers<br/>workloads/status<br/>resourceflavors<br/>workloadpriorityclasses]
    end

    subgraph "API Resources - RBAC"
        RBAC[rbac.authorization.k8s.io<br/>clusterrolebindings]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAI[trustyai.opendatahub.io<br/>trustyaiservices<br/>lmevaljobs<br/>guardrailsorchestrators<br/>nemoguardrails<br/>+ finalizers and status]
    end

    subgraph "API Resources - Coordination"
        Coordination[coordination.k8s.io<br/>leases]
        APIExt[apiextensions.k8s.io<br/>customresourcedefinitions]
        Scheduling[scheduling.k8s.io<br/>priorityclasses]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1

    CRB1 -->|grants| CR
    CRB2 -->|grants| CR2
    RB1 -->|grants| R1

    %% Permissions
    CR -->|create, delete, get, list<br/>patch, update, watch| Core1
    CR -->|create, delete, get, list, watch| Core2
    CR -->|create, patch, update, watch| Core1

    CR -->|create, delete, get, list<br/>patch, update, watch| Apps
    CR -->|update| Apps
    CR -->|get, patch, update| Apps

    CR -->|get, list, patch<br/>update, watch| KServe
    CR -->|delete, get, list, patch<br/>update, watch| KServe

    CR -->|create, delete, get, list<br/>patch, update, watch| Istio

    CR -->|create, delete, get, list<br/>patch, update, watch| Routes

    CR -->|create, list, watch| Monitoring

    CR -->|create, delete, get, list<br/>patch, update, watch| Kueue
    CR -->|update| Kueue
    CR -->|get, patch, update| Kueue
    CR -->|get, list, watch| Kueue

    CR -->|create, delete, get<br/>list, update, watch| RBAC

    CR -->|create, delete, get, list<br/>patch, update, watch| TrustyAI
    CR -->|update| TrustyAI
    CR -->|get, patch, update| TrustyAI

    CR -->|create, get, update| Coordination
    CR -->|get, list, watch| APIExt
    CR -->|get, list, watch| Scheduling

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333
    style R1 fill:#f5a623,stroke:#333
    style CRB1 fill:#e8e8e8,stroke:#333
    style CRB2 fill:#e8e8e8,stroke:#333
    style RB1 fill:#e8e8e8,stroke:#333
    style TrustyAI fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#95a5a6,stroke:#333
    style Routes fill:#95a5a6,stroke:#333
    style Kueue fill:#95a5a6,stroke:#333
    style Core1 fill:#d5e8d4,stroke:#333
    style Core2 fill:#d5e8d4,stroke:#333
    style Apps fill:#d5e8d4,stroke:#333
    style Monitoring fill:#95a5a6,stroke:#333
    style RBAC fill:#e74c3c,stroke:#333
    style Coordination fill:#d5e8d4,stroke:#333
    style APIExt fill:#d5e8d4,stroke:#333
    style Scheduling fill:#d5e8d4,stroke:#333
