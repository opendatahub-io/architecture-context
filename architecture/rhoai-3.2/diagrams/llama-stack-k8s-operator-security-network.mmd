graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User / Data Scientist]
        Prometheus[Prometheus<br/>Metrics Scraper]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.3<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(llama-stack-k8s-operator-system)"]
        direction TB

        subgraph OperatorPod["Operator Pod"]
            Controller["Controller Manager<br/>SA: controller-manager<br/>UID: 1001 (non-root)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        Controller -->|8080/TCP HTTP<br/>localhost| RBACProxy
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph LlamaDeployment["Llama Stack Deployment"]
            LlamaPod["Llama Stack Pod<br/>SA: {instance-name}-sa<br/>fsGroup: 1001<br/>SCC: anyuid"]
        end

        LlamaService["ClusterIP Service<br/>{instance-name}-service<br/>8321/TCP HTTP"]
        LlamaPVC["PersistentVolumeClaim<br/>{instance-name}-pvc<br/>10Gi (default)"]
        UserConfig["ConfigMap<br/>run.yaml config"]

        LlamaPod -->|exposes| LlamaService
        LlamaPod -->|mounts| LlamaPVC
        LlamaPod -->|reads| UserConfig

        NetworkPolicyBox["NetworkPolicy (Optional)<br/>{instance-name}-network-policy<br/>Feature Flag Enabled"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB

        Registry["Container Registry<br/>quay.io/docker.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Credentials"]

        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]

        vLLM["vLLM Inference<br/>8000/TCP HTTP/gRPC<br/>API Key (optional)"]

        Ollama["Ollama Inference<br/>11434/TCP HTTP<br/>API Key (optional)"]
    end

    subgraph InternalODH["INTERNAL ODH/RHOAI"]
        Dashboard["ODH Dashboard<br/>UI for CR Management"]
        TrustedCA["ODH Trusted CA Bundle<br/>ConfigMap<br/>Auto-detected"]
        ModelRegistry["Model Registry<br/>Metadata Service"]
    end

    %% User flows
    User -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token (User)"| K8sAPI
    Dashboard -->|"Create LlamaStackDistribution<br/>via K8s API"| K8sAPI

    %% Operator watch and reconciliation
    K8sAPI -->|"Watch Stream<br/>TLS 1.3<br/>Bearer Token (SA)"| Controller
    Controller -->|"CRUD Operations<br/>HTTPS/443<br/>TLS 1.3<br/>Bearer Token (SA)"| K8sAPI

    %% Operator creates resources
    Controller -.->|creates/manages| LlamaDeployment
    Controller -.->|creates/manages| LlamaService
    Controller -.->|creates/manages| LlamaPVC
    Controller -.->|creates if enabled| NetworkPolicyBox
    Controller -->|auto-detects| TrustedCA

    %% Metrics collection
    Prometheus -->|"GET /metrics<br/>HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| RBACProxy
    RBACProxy -->|"SubjectAccessReview<br/>HTTPS/443"| K8sAPI

    %% Llama Stack external calls
    LlamaPod -->|"Pull Images<br/>HTTPS/443<br/>TLS 1.2+"| Registry
    LlamaPod -->|"Download Models<br/>HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HF
    LlamaPod -->|"Inference Requests<br/>HTTP/8000"| vLLM
    LlamaPod -->|"Inference Requests<br/>HTTP/11434"| Ollama
    LlamaPod -.->|"Query Metadata<br/>(optional)"| ModelRegistry

    %% Client access
    Client["Client Application"] -->|"HTTP/8321<br/>No Auth (default)"| LlamaService
    LlamaService -->|"Port 8321/TCP"| LlamaPod

    %% Network Policy rules
    NetworkPolicyBox -.->|"Ingress: Allow<br/>app.kubernetes.io/part-of=llama-stack<br/>Port 8321/TCP"| LlamaService
    NetworkPolicyBox -.->|"Ingress: Allow<br/>from operator namespace<br/>Port 8321/TCP"| LlamaService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef operatorns fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalodh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Prometheus,Client external
    class K8sAPI k8scontrol
    class Controller,RBACProxy,HealthProbe,OperatorPod operatorns
    class LlamaPod,LlamaService,LlamaPVC,UserConfig,LlamaDeployment userns
    class Registry,HF,vLLM,Ollama externalservice
    class Dashboard,TrustedCA,ModelRegistry internalodh
    class NetworkPolicyBox security
