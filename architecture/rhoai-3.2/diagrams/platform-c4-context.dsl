/*
 * RHOAI 3.2 Platform - C4 Context & Container Diagram
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        // Personas
        datascientist = person "Data Scientist" "Develops, trains, and deploys ML models using notebooks and pipelines"
        mlops = person "MLOps Engineer" "Manages model serving, pipelines, and platform operations"
        admin = person "Platform Admin" "Configures and manages the RHOAI platform on OpenShift"

        // Main System
        rhoai = softwareSystem "RHOAI 3.2" "Red Hat OpenShift AI - comprehensive AI/ML platform on OpenShift" {
            // Tier 0
            rhodsOperator = container "rhods-operator" "Top-level platform operator managing all component lifecycles, Gateway API, auth, monitoring" "Go 1.25, OLM Operator"

            // Tier 1 - Core Infrastructure
            gateway = container "data-science-gateway" "Gateway API ingress with Envoy ext_authz filter" "Gateway API, openshift-ingress"
            kubeAuthProxy = container "kube-auth-proxy" "Dual-mode OAuth2/OIDC + RBAC authentication proxy" "Go 1.24"
            dashboard = container "odh-dashboard" "Platform management UI with federated plugins" "TypeScript, Fastify + React, Node.js 22"
            kserve = container "kserve" "Model serving controller for InferenceService, LLMInferenceService, Gateway API HTTPRoute" "Go 1.24, Operator"
            odhModelController = container "odh-model-controller" "Model serving infrastructure - Routes, RBAC, monitoring, auth policies" "Go 1.24, Operator"
            notebookController = container "kubeflow Notebook Controller" "Manages notebook workbench lifecycle, Gateway API HTTPRoute, kube-rbac-proxy injection" "Go 1.24, Operator"

            // Tier 2 - Platform Services
            dspOperator = container "data-science-pipelines-operator" "Deploys DSP stack per DSPA CR (API server, persistence, scheduler)" "Go 1.21, Operator"
            dspApi = container "data-science-pipelines" "KFP v2 backend API for pipeline management and execution" "Go 1.21, REST API"
            argoWorkflows = container "argo-workflows" "Workflow engine backend for Data Science Pipelines" "Go 1.23"
            mlmd = container "ml-metadata" "MLMD metadata store for artifacts, executions, contexts, lineage" "C++/Python, gRPC"
            modelRegistryOp = container "model-registry-operator" "Manages ModelRegistry instances with kube-rbac-proxy, Routes" "Go 1.24, Operator"
            modelRegistry = container "model-registry" "Central ML model metadata repository with REST API and CSI storage initializer" "Go 1.24/Python, REST + Controller"
            kueue = container "kueue" "Job queueing system with 11 CRDs, quota management" "Go 1.24, Operator"
            kuberay = container "kuberay" "Ray cluster operator managing RayCluster/RayJob/RayService" "Go 1.24, Operator"
            codeflare = container "codeflare-operator" "Manages RayCluster security: OAuth, mTLS, NetworkPolicies" "Go 1.23, Operator"
            trainingOperator = container "training-operator" "Kubeflow Training Operator for PyTorchJob, TFJob, etc." "Go 1.23, Operator"
            trainer = container "trainer" "Kubeflow Trainer v2 managing TrainJob with JobSet backend" "Go 1.24, Operator"
            trustyaiOp = container "trustyai-service-operator" "Manages TrustyAI, LMEvalJob, Guardrails, NeMo CRs" "Go 1.23, Operator"
            feast = container "feast" "Feature store operator managing FeatureStore CRs" "Go 1.24, Operator"
            mlflowOp = container "mlflow-operator" "Manages MLflow tracking server instances" "Go 1.24, Operator"
            mlflow = container "mlflow" "Experiment tracking, model registry, tracing" "Python 3.11, REST/GraphQL"
            llamaStackOp = container "llama-stack-k8s-operator" "Manages LlamaStackDistribution CRs" "Go 1.24, Operator"
            llamaStack = container "llama-stack-distribution" "Llama Stack server with provider integrations" "Python 3.12, HTTP"
            maas = container "models-as-a-service" "MaaS API for LLM access management with Kuadrant auth" "Go 1.25, REST + Gateway"

            // Tier 3 - Inference Runtimes
            vllm = container "vLLM Runtimes" "CUDA/CPU/Gaudi/ROCm GPU inference engines (OpenAI-compatible)" "Python, 8000/HTTP 8033/gRPC"
            tgis = container "TGIS" "IBM text-generation-inference server" "Rust/Python, 8033/gRPC"
            ovms = container "OVMS" "Intel-optimized model serving (OpenVINO)" "C++/Python, 8000/HTTP 8001/gRPC"
            caikit = container "Caikit" "Caikit-NLP and Caikit-TGIS serving runtimes" "Python 3.11, 8080/HTTP 8085/gRPC"
            modelmesh = container "ModelMesh" "Distributed LRU model serving cache" "Java 21, sidecar"
            restProxy = container "rest-proxy" "KServe V2 REST-to-gRPC translation" "Go, 8008/HTTP"

            // Tier 3 - Guardrails
            guardrailsOrch = container "fms-guardrails-orchestrator" "Content detector/chunker/LLM coordination" "Rust, 8034/HTTP"
            guardrailsDet = container "guardrails-detectors" "Content detection services (built-in, HF, LLM Judge)" "Python/FastAPI, 8080/HTTP"
            nemoGuardrails = container "NeMo-Guardrails" "NVIDIA NeMo programmable guardrails" "Python 3.12, 8000/HTTP"
            vllmGateway = container "vllm-orchestrator-gateway" "Guardrailed chat completions gateway" "Rust, 8090/HTTP"

            // Tier 3 - Scheduling
            llmdEpp = container "llm-d EPP" "Gateway API Inference Extension for prefix-aware P/D scheduling" "Go 1.24"
            llmdSidecar = container "llm-d-routing-sidecar" "Disaggregated prefill/decode routing with NIXL KV transfer" "Go 1.24"

            // Tier 3 - Evaluation
            trustyai = container "trustyai-explainability" "AI fairness metrics, explainability (LIME, SHAP), drift detection" "Java 17, Quarkus"
            lmeval = container "lm-evaluation-harness" "150+ benchmark tasks for LLM evaluation" "Python 3.11, Batch Job"
        }

        // External Systems
        ocp = softwareSystem "OpenShift Container Platform" "Container orchestration platform (OCP 4.19/4.20)" "External"
        s3 = softwareSystem "S3-Compatible Storage" "Model artifacts, pipeline artifacts, data storage" "External"
        database = softwareSystem "Database (PostgreSQL/MySQL/MariaDB)" "Metadata persistence for pipelines, model registry, MLflow, feast" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model repository and datasets" "External"
        ociRegistry = softwareSystem "OCI Container Registry" "Container and model image registry" "External"

        // User interactions
        datascientist -> dashboard "Manages notebooks, pipelines, model deployments" "HTTPS/443"
        datascientist -> vllm "Sends inference requests" "HTTPS/443 via Gateway"
        datascientist -> dspApi "Creates and runs pipelines" "HTTPS/443 via Gateway"
        mlops -> dashboard "Configures serving runtimes, monitors models" "HTTPS/443"
        mlops -> modelRegistry "Registers and tracks models" "HTTPS/443 via Gateway"
        admin -> rhodsOperator "Configures DataScienceCluster CR" "kubectl/oc"

        // Internal relationships
        rhodsOperator -> gateway "Creates and manages" "Gateway API"
        rhodsOperator -> kubeAuthProxy "Deploys"
        rhodsOperator -> kserve "Deploys via DSC"
        rhodsOperator -> odhModelController "Deploys via DSC"
        rhodsOperator -> notebookController "Deploys via DSC"
        rhodsOperator -> dashboard "Deploys via DSC"
        rhodsOperator -> dspOperator "Deploys via DSC"
        rhodsOperator -> modelRegistryOp "Deploys via DSC"
        rhodsOperator -> kueue "Deploys via DSC"
        rhodsOperator -> kuberay "Deploys via DSC"
        rhodsOperator -> trainingOperator "Deploys via DSC"
        rhodsOperator -> trainer "Deploys via DSC"
        rhodsOperator -> trustyaiOp "Deploys via DSC"
        rhodsOperator -> feast "Deploys via DSC"
        rhodsOperator -> mlflowOp "Deploys via DSC"
        rhodsOperator -> llamaStackOp "Deploys via DSC"
        rhodsOperator -> maas "Deploys via DSC"

        gateway -> kubeAuthProxy "ext_authz authentication" "HTTPS/8443"

        kserve -> vllm "Creates InferenceService pods"
        kserve -> tgis "Creates InferenceService pods"
        kserve -> ovms "Creates InferenceService pods"
        kserve -> caikit "Creates InferenceService pods"

        dspOperator -> dspApi "Deploys per DSPA"
        dspOperator -> argoWorkflows "Deploys per DSPA"
        dspOperator -> mlmd "Deploys per DSPA"
        argoWorkflows -> mlmd "Logs artifacts/executions" "gRPC/8080"

        modelRegistryOp -> modelRegistry "Deploys per ModelRegistry CR"
        mlflowOp -> mlflow "Deploys per MLflow CR"
        llamaStackOp -> llamaStack "Deploys per LlamaStackDistribution CR"

        trustyaiOp -> trustyai "Deploys per TrustyAIService CR"
        trustyaiOp -> guardrailsOrch "Deploys per GuardrailsOrchestrator CR"
        trustyaiOp -> nemoGuardrails "Deploys per NemoGuardrails CR"
        trustyaiOp -> lmeval "Deploys per LMEvalJob CR"

        vllmGateway -> guardrailsOrch "Routes requests" "HTTP/8034"
        guardrailsOrch -> guardrailsDet "Content detection" "HTTP/8080"
        guardrailsOrch -> vllm "LLM inference" "HTTP/8000"

        kuberay -> codeflare "Security management"
        kueue -> trainingOperator "Job queueing" "Workload integration"

        llmdEpp -> llmdSidecar "Pod selection for P/D"

        // External dependencies
        rhodsOperator -> ocp "Manages platform on OCP" "HTTPS/443"
        dspApi -> s3 "Stores pipeline artifacts" "HTTPS/443"
        modelmesh -> s3 "Loads model artifacts" "HTTPS/443"
        modelRegistry -> database "Stores model metadata" "TCP/5432"
        mlflow -> database "Stores experiment data" "TCP/5432"
        mlmd -> database "Stores pipeline metadata" "TCP/5432"
        feast -> database "Stores feature data" "TCP/5432"
        lmeval -> hfHub "Downloads evaluation datasets" "HTTPS/443"
        modelRegistry -> ociRegistry "Pulls model images" "HTTPS/443"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
