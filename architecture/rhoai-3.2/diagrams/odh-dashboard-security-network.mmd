graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (Reencrypt)"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        Proxy["kube-rbac-proxy<br/>SA: odh-dashboard<br/>8443/TCP HTTPS<br/>8444/TCP Health<br/>OAuth Token Validation<br/>Injects User/Group Headers"]
    end

    subgraph AppLayer["APPLICATION LAYER (Trusted)"]
        direction TB

        subgraph Backend["Dashboard Backend Pod"]
            BackendApp["Node.js/Fastify<br/>8080/TCP HTTP<br/>SA: odh-dashboard<br/>Replicas: 2 (HA)<br/>CPU: 500m-1000m<br/>Memory: 1Gi-2Gi"]
            Frontend["React Frontend<br/>PatternFly UI"]
            BackendApp -.->|serves| Frontend
        end

        subgraph Plugins["Module Federation Plugins"]
            GenAI["GenAI Plugin"]
            ModelReg["Model Registry Plugin"]
            MaaS["MaaS Plugin"]
        end

        Frontend -.->|loads at runtime| GenAI
        Frontend -.->|loads at runtime| ModelReg
        Frontend -.->|loads at runtime| MaaS
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        OAuth["OpenShift OAuth<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Token Validation"]
        Thanos["Thanos Querier<br/>NS: openshift-monitoring<br/>9092/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ODHServices["ODH SERVICES (Internal)"]
        direction TB
        ModelRegSvc["Model Registry<br/>8080/TCP HTTP/HTTPS<br/>Bearer Token"]
        FeastSvc["Feast Registry<br/>8080/TCP HTTP/HTTPS<br/>Bearer Token"]
        ImageReg["Image Registry<br/>5000/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph CRs["CUSTOM RESOURCES WATCHED"]
        OdhApp["OdhApplication<br/>dashboard.opendatahub.io"]
        OdhDoc["OdhDocument<br/>dashboard.opendatahub.io"]
        QuickStart["OdhQuickStart<br/>console.openshift.io"]
        DashConfig["OdhDashboardConfig<br/>opendatahub.io"]
        Notebook["Notebook<br/>kubeflow.org"]
        InferSvc["InferenceService<br/>serving.kserve.io"]
    end

    %% External Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route
    Route -->|HTTPS/8443<br/>Reencrypt<br/>OAuth Token| Proxy
    Proxy -->|HTTP/8080<br/>Localhost Only<br/>X-Auth-Request-User/Groups| BackendApp

    %% Backend Egress
    BackendApp -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Proxy -->|Token Validation| OAuth
    BackendApp -->|HTTPS/9092<br/>TLS 1.2+<br/>SA Token| Thanos
    BackendApp -->|HTTP/HTTPS 8080<br/>Bearer Token| ModelRegSvc
    BackendApp -->|HTTP/HTTPS 8080<br/>Bearer Token| FeastSvc
    BackendApp -->|HTTPS/5000<br/>TLS 1.2+<br/>SA Token| ImageReg

    %% CRD Interactions
    BackendApp -.->|reads| OdhApp
    BackendApp -.->|reads| OdhDoc
    BackendApp -.->|reads| QuickStart
    BackendApp -.->|reads/writes| DashConfig
    BackendApp -.->|CRUD| Notebook
    BackendApp -.->|reads| InferSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef odh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef crs fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class Proxy auth
    class BackendApp,Frontend,GenAI,ModelReg,MaaS app
    class K8sAPI,OAuth,Thanos k8s
    class ModelRegSvc,FeastSvc,ImageReg odh
    class OdhApp,OdhDoc,QuickStart,DashConfig,Notebook,InferSvc crs
