%% ODH Dashboard - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (re-encrypt)<br/>HTTPRoute: all paths (/)"]
    end

    subgraph AuthLayer["AUTH PROXY LAYER"]
        KRP["kube-rbac-proxy<br/>SA: rhods-dashboard<br/>Listen: 8443/TCP (HTTPS/TLS)<br/>Health: 8444/TCP (HTTPS/TLS)<br/>AuthN: SubjectAccessReview<br/>(projects list permission)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Pod: rhods-dashboard)<br/>Namespace: redhat-ods-applications"]
        direction TB

        Dashboard["odh-dashboard Backend<br/>SA: rhods-dashboard<br/>Node.js 22 / Fastify<br/>Port: 8080/TCP (HTTP, localhost)<br/>Serves: React/PatternFly SPA"]

        subgraph FederatedModules["Federated UI Modules"]
            MReg["model-registry-ui<br/>Port: 8043/TCP (HTTPS)<br/>TLS: serving cert<br/>Auth: x-forwarded-access-token"]
            GenAI["gen-ai-ui<br/>Port: 8143/TCP (HTTPS)<br/>TLS: serving cert<br/>Auth: x-forwarded-access-token"]
        end

        Dashboard -->|"HTTPS/8043<br/>User token header"| MReg
        Dashboard -->|"HTTPS/8143<br/>User token header"| GenAI
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS/WSS<br/>TLS<br/>User token / SA token"]
        Prom["Prometheus<br/>9090/TCP HTTPS<br/>TLS<br/>SA token (cluster-monitoring-view)"]
    end

    subgraph ManagedCRDs["MANAGED RESOURCES (via K8s API)"]
        direction LR
        IS["InferenceService<br/>ServingRuntime"]
        MR["ModelRegistry"]
        NB["Notebook"]
        DSC["DataScienceCluster<br/>DSCInitialization"]
        NIM["Account (NIM)"]
        LS["LlamaStackDistribution"]
        FS["FeatureStore"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth redirect"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS re-encrypt<br/>Gateway headers"| KRP
    KRP -->|"SubjectAccessReview<br/>HTTPS/6443<br/>SA token"| K8sAPI
    KRP -->|"HTTP/8080<br/>plaintext (localhost)<br/>X-Auth-Request-User/Groups"| Dashboard

    %% Backend egress
    Dashboard -->|"HTTPS/6443<br/>User token (forwarded)"| K8sAPI
    Dashboard -->|"WSS/6443<br/>Bearer token subprotocol"| K8sAPI
    Dashboard -->|"HTTPS/9090<br/>SA token"| Prom

    %% K8s API to CRDs
    K8sAPI -.->|"manages"| IS
    K8sAPI -.->|"manages"| MR
    K8sAPI -.->|"manages"| NB
    K8sAPI -.->|"manages"| DSC
    K8sAPI -.->|"manages"| NIM
    K8sAPI -.->|"manages"| LS
    K8sAPI -.->|"manages"| FS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef federated fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef crd fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Browser external
    class Gateway ingress
    class KRP authproxy
    class Dashboard application
    class MReg,GenAI federated
    class K8sAPI,Prom clusterservice
    class IS,MR,NB,DSC,NIM,LS,FS crd
