// C4 Context Diagram - CodeFlare Operator
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/codeflare-operator.md

workspace {
    model {
        user = person "Data Scientist" "Creates RayClusters and AppWrappers for distributed ML workloads"

        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages RayCluster lifecycle with OAuth proxy, mTLS, and batch scheduling on OpenShift AI" {
            rayclusterController = container "RayCluster Controller" "Watches RayCluster CRs, creates Routes, Services, Secrets, NetworkPolicies, and CA certificates" "Go Controller (controller-runtime)"
            rayclusterWebhook = container "RayCluster Webhooks" "Injects oauth-proxy sidecar, mTLS init containers; validates immutability" "Mutating + Validating Webhooks"
            appwrapperController = container "AppWrapper Controller" "Manages AppWrapper CRs for batch scheduling with quota management" "Embedded Go Controller"
            appwrapperWebhook = container "AppWrapper Webhooks" "Validates and defaults AppWrapper resources" "Mutating + Validating Webhooks"
            certController = container "Cert Controller" "Manages webhook TLS certificates" "cert-controller library"
            configManager = container "Configuration Manager" "Loads operator config from ConfigMap" "ConfigMap-based"
        }

        kuberayOperator = softwareSystem "KubeRay Operator" "Provides RayCluster CRD and manages Ray cluster pods" "External"
        odhOperator = softwareSystem "ODH Operator" "Manages OpenShift AI platform components" "Internal RHOAI"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "OpenShift authentication server" "External"
        kueue = softwareSystem "Kueue" "Job queueing and quota management" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server" "External"
        prometheus = softwareSystem "Prometheus / Monitoring" "Metrics collection and alerting" "Internal RHOAI"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller for external access" "External"

        // User interactions
        user -> codeflareOperator "Creates RayCluster and AppWrapper CRs via kubectl"
        user -> openshiftRouter "Accesses Ray Dashboard and RayClient" "HTTPS/443"

        // Operator dependencies
        codeflareOperator -> kuberayOperator "Watches RayCluster CRs created by KubeRay"
        codeflareOperator -> odhOperator "Reads DSCInitialization CR for namespace discovery"
        codeflareOperator -> openshiftOAuth "OAuth authentication flow via oauth-proxy sidecar" "HTTPS/443"
        codeflareOperator -> kueue "Quota reservation for AppWrapper workloads"
        codeflareOperator -> k8sAPI "Controller operations, webhook registration, RBAC" "HTTPS/443"

        // Integration points
        openshiftRouter -> codeflareOperator "Routes traffic to oauth-proxy and Ray head" "HTTPS/8443, gRPC/10001"
        prometheus -> codeflareOperator "Scrapes operator metrics" "HTTP/8080"
    }

    views {
        systemContext codeflareOperator "SystemContext" {
            include *
            autoLayout
        }

        container codeflareOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
