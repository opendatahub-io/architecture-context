// C4 Context Diagram: llama-stack-provider-trustyai-garak
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Security Engineer" "Runs LLM vulnerability scans and red-teaming assessments"

        garakProvider = softwareSystem "Llama Stack Provider: TrustyAI Garak" "Out-of-tree Llama Stack evaluation provider for automated LLM red-teaming using NVIDIA Garak" {
            remoteAdapter = container "GarakRemoteEvalAdapter" "Submits Garak scans as KFP pipeline runs" "Python Llama Stack Provider"
            inlineAdapter = container "GarakInlineEvalAdapter" "Runs Garak scans as local subprocess" "Python Llama Stack Provider"
            baseEval = container "GarakEvalBase" "Shared benchmark registration, command building, result parsing" "Python Base Class"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Routes probes through input/output shields for effectiveness testing" "Python Callable"
            avidGenerator = container "AVID Report Generator" "Converts Garak results to AVID taxonomy-compliant reports" "Python Module"
            resultUtils = container "Result Utilities" "Parses and combines JSONL and AVID data" "Python Module"
        }

        llamaStack = softwareSystem "Llama Stack Distribution Server" "Hosts providers and exposes Eval, Inference, Files, Safety APIs" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines (KFP)" "Kubeflow Pipelines for running containerized scan workloads" "Internal RHOAI"
        vllm = softwareSystem "vLLM Inference Server" "Target LLM model for vulnerability scanning" "Internal RHOAI"
        trustyaiOp = softwareSystem "TrustyAI Service Operator" "Provides ConfigMap for base image resolution" "Internal RHOAI"
        promptGuard = softwareSystem "Prompt-Guard-86M" "Guardrail model for shield effectiveness testing" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API" "ConfigMap reads, authentication" "External"
        garakEngine = softwareSystem "NVIDIA Garak" "LLM vulnerability scanner engine (v0.12.0)" "External"

        // User interactions
        user -> garakProvider "Submits vulnerability scans via Eval API" "HTTP/8321"
        user -> llamaStack "Calls Eval API endpoints" "HTTP/8321"

        // Provider hosted by Llama Stack
        llamaStack -> garakProvider "Hosts as Eval provider plugin" "in-process"

        // Provider outbound
        garakProvider -> dsp "Submits and monitors KFP pipeline runs" "HTTPS/443 Bearer Token"
        garakProvider -> vllm "Scans target LLM models" "HTTP(S) API Key"
        garakProvider -> llamaStack "Calls Inference, Files, Safety APIs" "HTTP(S)/8321"
        garakProvider -> k8sAPI "Reads ConfigMaps, loads kube config" "HTTPS/443 SA Token"
        garakProvider -> trustyaiOp "Reads trustyai-service-operator-config ConfigMap" "Kubernetes API"
        garakProvider -> garakEngine "Runs Garak CLI for vulnerability scanning" "subprocess / container"
        garakProvider -> promptGuard "Tests shield effectiveness via Safety API" "HTTP(S)/8321"

        // Container relationships
        remoteAdapter -> baseEval "extends"
        inlineAdapter -> baseEval "extends"
        baseEval -> shieldOrchestrator "uses for shield testing"
        baseEval -> avidGenerator "generates compliance reports"
        baseEval -> resultUtils "parses scan results"
    }

    views {
        systemContext garakProvider "SystemContext" {
            include *
            autoLayout
        }

        container garakProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
