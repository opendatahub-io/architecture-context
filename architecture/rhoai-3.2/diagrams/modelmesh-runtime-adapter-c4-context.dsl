// C4 Context Diagram: modelmesh-runtime-adapter
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.2/modelmesh-runtime-adapter.md

workspace {
    model {
        admin = person "Platform Admin" "Configures storage credentials and deploys ModelMesh Serving"
        datascientist = person "Data Scientist" "Deploys ML models via InferenceService CRs"

        modelmeshServing = softwareSystem "ModelMesh Serving" "Scalable model serving platform for Kubernetes" {
            modelmeshController = container "ModelMesh Controller" "Manages model placement and routing across pods" "Go"
            runtimeAdapter = container "ModelMesh Runtime Adapter" "Sidecar: pulls model artifacts from storage and adapts model lifecycle calls to runtime-specific APIs" "Go/Python Sidecar" {
                puller = component "model-serving-puller" "gRPC server intercepting model load/unload; downloads artifacts from remote storage" "Go gRPC Server :8084"
                pullmanLib = component "pullman" "Pluggable storage provider framework (S3, Azure, GCS, HTTP, PVC)" "Go Library"
                tritonAdapter = component "triton-adapter" "Translates ModelRuntime gRPC to Triton gRPC API" "Go gRPC Server :8085"
                mlserverAdapter = component "mlserver-adapter" "Translates ModelRuntime gRPC to MLServer gRPC API" "Go gRPC Server :8085"
                ovmsAdapter = component "ovms-adapter" "Translates ModelRuntime gRPC to OVMS gRPC API" "Go gRPC Server :8085"
                torchserveAdapter = component "torchserve-adapter" "Translates ModelRuntime gRPC to TorchServe gRPC API" "Go gRPC Server :8085"
                tfConverter = component "tf_pb.py" "Converts Keras models to TensorFlow SavedModel format" "Python 3.11"
            }
            tritonServer = container "Triton Inference Server" "NVIDIA model inference runtime" "C++ :8001" "External"
            mlserver = container "Seldon MLServer" "Python-based model inference runtime (KFServing V2)" "Python :8001" "External"
            ovms = container "OpenVINO Model Server" "Intel model inference runtime" "C++ :8001" "External"
            torchserve = container "TorchServe" "PyTorch model serving runtime" "Java :7071/:7070" "External"
        }

        s3 = softwareSystem "S3-compatible Storage" "Model artifact storage (AWS S3, IBM COS)" "External"
        azure = softwareSystem "Azure Blob Storage" "Model artifact storage on Azure" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage on GCP" "External"
        k8s = softwareSystem "Kubernetes API" "Provides Secret mounting and Pod scheduling" "External"

        // Person relationships
        datascientist -> modelmeshServing "Deploys models via InferenceService CR"
        admin -> modelmeshServing "Configures storage-config Secrets"

        // System-level relationships
        modelmeshServing -> s3 "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        modelmeshServing -> azure "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        modelmeshServing -> gcs "Downloads model artifacts" "HTTPS/443 TLS 1.2+"
        k8s -> modelmeshServing "Mounts storage-config Secret"

        // Container-level relationships
        modelmeshController -> runtimeAdapter "Model lifecycle calls" "gRPC/8084 plaintext localhost"
        runtimeAdapter -> tritonServer "Adapted model load/unload" "gRPC/8001 plaintext localhost"
        runtimeAdapter -> mlserver "Adapted model load/unload" "gRPC/8001 plaintext localhost"
        runtimeAdapter -> ovms "Adapted model load/unload" "gRPC/8001 plaintext localhost"
        runtimeAdapter -> torchserve "Adapted model load/unload" "gRPC/7071 plaintext localhost"

        // Component-level relationships
        puller -> pullmanLib "Uses for storage downloads"
        puller -> tritonAdapter "Forwards load/unload" "gRPC/8085 localhost"
        puller -> mlserverAdapter "Forwards load/unload" "gRPC/8085 localhost"
        puller -> ovmsAdapter "Forwards load/unload" "gRPC/8085 localhost"
        puller -> torchserveAdapter "Forwards load/unload" "gRPC/8085 localhost"
        puller -> tfConverter "Keras to TF conversion"
        pullmanLib -> s3 "Downloads artifacts" "HTTPS/443"
        pullmanLib -> azure "Downloads artifacts" "HTTPS/443"
        pullmanLib -> gcs "Downloads artifacts" "HTTPS/443"
    }

    views {
        systemContext modelmeshServing "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshServing "Containers" {
            include *
            autoLayout
        }

        component runtimeAdapter "Components" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Component" {
                background #85bbf0
                color #000000
            }
        }
    }
}
