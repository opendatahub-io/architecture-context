graph TD
    subgraph "Service Accounts"
        SA1[notebook-controller-service-account]
        SA2[odh-notebook-controller-manager]
    end

    subgraph "ClusterRole Bindings"
        CRB1[notebook-controller-role-binding]
        CRB2[odh-notebook-controller-manager-rolebinding]
        CRB3[notebook-controller-leader-election-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[notebook-controller-role]
        CR2[odh-notebook-controller-manager-role]
        CR3[notebook-controller-leader-election-role]
    end

    subgraph "notebook-controller-role Permissions"
        R1_1[kubeflow.org<br/>notebooks, notebooks/finalizers,<br/>notebooks/status<br/>Verbs: *]
        R1_2[core<br/>services, pods, events<br/>Verbs: *, get, list, watch, delete, create, patch]
        R1_3[apps<br/>statefulsets<br/>Verbs: *]
        R1_4[networking.istio.io<br/>virtualservices<br/>Verbs: *]
    end

    subgraph "odh-notebook-controller-manager-role Permissions"
        R2_1[kubeflow.org<br/>notebooks, notebooks/finalizers,<br/>notebooks/status<br/>Verbs: get, list, watch, patch, update]
        R2_2[core<br/>configmaps, secrets,<br/>serviceaccounts, services<br/>Verbs: create, get, list, patch, update, watch]
        R2_3[datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications,<br/>datasciencepipelinesapplications/api<br/>Verbs: get, list, watch, create, delete, patch, update]
        R2_4[gateway.networking.k8s.io<br/>gateways, httproutes, referencegrants<br/>Verbs: create, delete, get, list, patch, update, watch]
        R2_5[oauth.openshift.io<br/>oauthclients<br/>Verbs: delete, get, list, patch, update, watch]
        R2_6[route.openshift.io<br/>routes<br/>Verbs: get, list, watch]
        R2_7[networking.k8s.io<br/>networkpolicies,<br/>networkpolicies/finalizers<br/>Verbs: create, get, list, patch, update, watch]
        R2_8[rbac.authorization.k8s.io<br/>clusterrolebindings, rolebindings, roles<br/>Verbs: create, delete, get, list, patch, update, watch]
        R2_9[authentication.k8s.io<br/>tokenreviews<br/>Verbs: create]
        R2_10[authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create]
    end

    subgraph "notebook-controller-leader-election-role Permissions"
        R3_1[core<br/>configmaps<br/>Verbs: get, list, watch, create, update, patch]
        R3_2[coordination.k8s.io<br/>leases<br/>Verbs: get, create, update]
    end

    %% Service Account to ClusterRoleBinding
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB3
    SA2 -->|bound via| CRB2

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% ClusterRole to Permissions
    CR1 -->|permissions| R1_1
    CR1 -->|permissions| R1_2
    CR1 -->|permissions| R1_3
    CR1 -->|permissions| R1_4

    CR2 -->|permissions| R2_1
    CR2 -->|permissions| R2_2
    CR2 -->|permissions| R2_3
    CR2 -->|permissions| R2_4
    CR2 -->|permissions| R2_5
    CR2 -->|permissions| R2_6
    CR2 -->|permissions| R2_7
    CR2 -->|permissions| R2_8
    CR2 -->|permissions| R2_9
    CR2 -->|permissions| R2_10

    CR3 -->|permissions| R3_1
    CR3 -->|permissions| R3_2

