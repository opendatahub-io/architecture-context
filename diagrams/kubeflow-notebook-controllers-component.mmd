graph TB
    subgraph "Kubeflow Notebook Controllers"
        NBC[notebook-controller]
        CULLER[notebook-controller-culler]
        ODHNBC[odh-notebook-controller]
        WEBHOOK[notebook-webhook]

        NBC -->|monitors| CULLER
        ODHNBC -->|validates/mutates| WEBHOOK
    end

    subgraph "Custom Resources"
        NOTEBOOK_V1[Notebook v1<br/>storage version]
        NOTEBOOK_V1B[Notebook v1beta1<br/>webhook support]
        NOTEBOOK_V1A[Notebook v1alpha1<br/>conversion]
    end

    subgraph "Created Resources"
        STATEFULSET[StatefulSet<br/>notebook pods]
        SERVICE[ClusterIP Service<br/>notebook port]
        ROUTE[OpenShift Route<br/>external access]
        HTTPROUTE[Gateway HTTPRoute<br/>Gateway API]
        VIRTUALSERVICE[Istio VirtualService<br/>Istio ingress]
        OAUTH[OAuth Client<br/>authentication]
        NETPOL[NetworkPolicy<br/>traffic control]
        RBAC_RES[RBAC Roles/Bindings<br/>permissions]
    end

    subgraph "External Dependencies"
        K8S[Kubernetes API Server]
        ISTIO[Istio Service Mesh]
        DSPA[Data Science Pipelines]
        OAUTH_SERVER[OpenShift OAuth]
        CERTMGR[cert-manager /<br/>OpenShift Service CA]
    end

    subgraph "Integration Points"
        DASHBOARD[Kubeflow Dashboard]
        PROMETHEUS[Prometheus Metrics]
        FEAST[Feast ConfigMap]
    end

    User[Data Scientist] -->|creates| NOTEBOOK_V1
    NOTEBOOK_V1 -->|watched by| NBC
    NOTEBOOK_V1 -->|watched by| ODHNBC

    NBC -->|creates| STATEFULSET
    NBC -->|creates| SERVICE
    NBC -->|creates optional| VIRTUALSERVICE

    ODHNBC -->|creates| ROUTE
    ODHNBC -->|creates| HTTPROUTE
    ODHNBC -->|creates| OAUTH
    ODHNBC -->|creates| NETPOL
    ODHNBC -->|creates| RBAC_RES

    NBC -->|API calls| K8S
    ODHNBC -->|API calls| K8S
    CULLER -->|stops idle| STATEFULSET

    ODHNBC -->|integrates| DSPA
    ODHNBC -->|integrates| OAUTH_SERVER
    ODHNBC -->|integrates| FEAST
    NBC -->|integrates optional| ISTIO
    WEBHOOK -->|cert from| CERTMGR

    DASHBOARD -->|creates| NOTEBOOK_V1
    ODHNBC -->|exposes| PROMETHEUS

    VIRTUALSERVICE -.->|uses| ISTIO
    ROUTE -.->|uses| OAUTH_SERVER

    style NBC fill:#4a90e2
    style ODHNBC fill:#4a90e2
    style CULLER fill:#4a90e2
    style WEBHOOK fill:#4a90e2
    style NOTEBOOK_V1 fill:#f5a623
    style NOTEBOOK_V1B fill:#f5a623
    style NOTEBOOK_V1A fill:#f5a623
    style K8S fill:#999
    style ISTIO fill:#999
    style CERTMGR fill:#999
    style DSPA fill:#7ed321
    style OAUTH_SERVER fill:#7ed321
    style DASHBOARD fill:#7ed321
    style PROMETHEUS fill:#7ed321
    style FEAST fill:#7ed321
